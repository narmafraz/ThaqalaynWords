{"lemma":"سَوَّمَ","slug":"سَوَّمَ","root":"س.#.م","root_slug":"س-_-م","root_link":"/words/roots/س-_-م","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَوَّمْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَوَّمْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَوَّمْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَوَّمْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَوَّمْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَوَّمَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَوَّمَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَوَّما","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَوَّمَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَوَّمُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَوَّمْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُسَوِّم","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُسَوِّمِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُسَوِّمِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُسَوِّما","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُسَوِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُسَوِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُسَوِّمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُسَوِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُسَوِّم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُسَوِّم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُسَوِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُسَوِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسَوِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَوِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسَوِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسَوِّمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسَوِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُسَوِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسَوِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَوَّمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَوَّمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n21323","n21330"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%88%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to impose, to force"},{"pos":"verb","gloss":"to mark"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21323","headword_ar":"سَوْمٌ","root":"swm","body":[{"kind":"text","text":", inf. n. of"},{"kind":"arabic","text_bw":"saAma","text_ar":"سَامَ"},{"kind":"text","text":", primarily signifies The"},{"kind":"italic_en","text":"going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going away, engaged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupied, in seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in seeking for"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in seeking to find and take"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to get,"},{"kind":"text","text":"a thing: and sometimes it is used as meaning the"},{"kind":"italic_en","text":"going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going away;"},{"kind":"text","text":"as when it is said of camels [or the like]: and sometimes, as meaning the"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking for"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking to find and take"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to get;"},{"kind":"text","text":"as when it relates to selling or buying. (Er-Rághib, TA.) ―         -b2-  You say,"},{"kind":"arabic","text_bw":"saAmati AlmaA$iyapu","text_ar":"سَامَتِ المَاشِيَةُ"},{"kind":"text","text":"(S, Mgh, Msb, TA) or"},{"kind":"arabic","text_bw":"Aln~aEamu","text_ar":"النَّعَمُ"},{"kind":"text","text":"(M) or"},{"kind":"arabic","text_bw":"AlmaAlu","text_ar":"المَالُ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"tasuwmu","text_ar":"تَسُومُ"},{"kind":"text","text":", (S, M, Msb,) inf. n."},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":", (S, M, Mgh, Msb,)"},{"kind":"italic_en","text":"The cattle pastured"},{"kind":"text","text":"(S, M, Mgh, Msb, K, TA)"},{"kind":"italic_en","text":"by themselves"},{"kind":"text","text":"(Msb)"},{"kind":"italic_en","text":"where they pleased;"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"Alganamu","text_ar":"الغَنَمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"went away at random,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roved, pasturing where they pleased."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence,"},{"kind":"arabic","text_bw":"sAm","text_ar":"سام"},{"kind":"text","text":", inf n as above,"},{"kind":"italic_en","text":"He did as he pleased."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"xal~ayotuhu","text_ar":"خَلَّيْتُهُ"},{"kind":"arabic","text_bw":"wasawomahu","text_ar":"وَسَوْمَهُ"},{"kind":"italic_en","text":"I left him to do as he pleased."},{"kind":"text","text":"(S, M, K * [In the CK,"},{"kind":"arabic","text_bw":"xal~Ahu wasaw~amahu limaAyuriyduhu","text_ar":"خَلّاهُ وَسَوَّمَهُ لِمَايُرِيدُهُ"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"xal~aAhu","text_ar":"خَلَّاهُ"},{"kind":"arabic","text_bw":"wasawomahu limaA yuriyduhu","text_ar":"وَسَوْمَهُ لِمَا يُرِيدُهُ"},{"kind":"text","text":"; and the like is done in one of my copies of the S. See also 2.]) ―         -b4-  And"},{"kind":"arabic","text_bw":"saAma","text_ar":"سَامَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"saAmati AlA_ibilu","text_ar":"سَامَتِ الاـِبِلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alr~iyHu","text_ar":"الرِّيحُ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"Alr~iyaAHu","text_ar":"الرِّيَاحُ"},{"kind":"text","text":", (S,) inf. n. as above, (S, M,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"the camels,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the wind,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"the winds,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"passed, went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went on"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"along:"},{"kind":"text","text":"(S, M, K:) or"},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"passing,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"quickly;"},{"kind":"text","text":"one says of a she camel,"},{"kind":"arabic","text_bw":"saAmat","text_ar":"سَامَت"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"she passed,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"quickly;"},{"kind":"text","text":"(As, TA;) and hence the saying of Dhu-l-Bijádeyn cited in art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"taEar~aDa","text_ar":"تَعَرَّضَ"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"passing,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"quickly, with the desire of making a sound in going along."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"saAmati AlT~ayoru EalaY","text_ar":"سَامَتِ الطَّيْرُ عَلَى"},{"kind":"arabic","text_bw":"Al$~aYo'i","text_ar":"الشَّىْءِ"},{"kind":"text","text":", (M, K,) aor. and inf. n. as above, (M,)"},{"kind":"italic_en","text":"The birds went,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hovered,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"circled, round about the thing:"},{"kind":"text","text":"(M, K:) or, as some say,"},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":"signifies any"},{"kind":"italic_en","text":"going,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hovering,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"circling, round about."},{"kind":"text","text":"(M.)       -A2-  [As mentioned in the first sentence of this art.,]"},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":"is also in selling and buying. (S.) You say,"},{"kind":"arabic","text_bw":"sAm Als~iloEapa","text_ar":"سام السِّلْعَةَ"},{"kind":"text","text":", (Mgh, Msb,) aor. and inf. n. as above, (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the seller)"},{"kind":"italic_en","text":"offered the commodity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"article of merchandise,"},{"kind":"text","text":"(Mgh, Msb:) and it is also said of the purchaser, like ↓"},{"kind":"arabic","text_bw":"AisotaAmahaA","text_ar":"اِسْتَامَهَا","orth_type":"arrow"},{"kind":"text","text":", (Mgh, Msb,) meaning"},{"kind":"italic_en","text":"he sought to obtain the sale of the commodity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"article of merchandise:"},{"kind":"text","text":"and one says also of the seller, and of the purchaser,"},{"kind":"arabic","text_bw":"sAm biAls~iloEapi","text_ar":"سام بِالسِّلْعَةِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he mentioned the price of the commodity"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in offering it for sale,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in offering to purchase it"},{"kind":"text","text":"]: (Msb:) and in like manner,"},{"kind":"arabic","text_bw":"sumotu fulaAnFA siloEatiY","text_ar":"سُمْتُ فُلَانًا سِلْعَتِى"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"I said to such a one,"},{"kind":"text","text":"“"},{"kind":"italic_en","text":"Wilt thou take"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"purchase"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"my commodity for such a price?"},{"kind":"text","text":"” (TA:) and"},{"kind":"arabic","text_bw":"saAmaniY bisiloEatihi","text_ar":"سَامَنِى بِسِلْعَتِهِ"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(the seller, Msb)"},{"kind":"italic_en","text":"mentioned to me the price of his commodity"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in offering it for sale"},{"kind":"text","text":"]: (Msb, TA:) [and, agreeably with these explanations,] Kr says that"},{"kind":"arabic","text_bw":"Als~awomu","text_ar":"السَّوْمُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AlEaroDu","text_ar":"العَرْضُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the act of offering,"},{"kind":"text","text":"&c.]: (M, TA:) or"},{"kind":"arabic","text_bw":"sumotu biAls~iloEapi","text_ar":"سُمْتُ بِالسِّلْعَةِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"suwaAmN","text_ar":"سُوَامٌ"},{"kind":"text","text":", with damm; (K, TK; [in the former only said to be syn. with"},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":"in selling and buying;]) and ↓"},{"kind":"arabic","text_bw":"saAwamotu","text_ar":"سَاوَمْتُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"siwaAmN","text_ar":"سِوَامٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aisotamotu","text_ar":"اِسْتَمْتُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"text","text":"; signify"},{"kind":"arabic","text_bw":"gaAlayotu","text_ar":"غَالَيْتُ"},{"kind":"text","text":"[which means"},{"kind":"italic_en","text":"I offered the commodity for sale, mentioning its price, and was exorbitant in my demand:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"I purchased the commodity for a dear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an excessive, price:"},{"kind":"text","text":"and both these meanings are app. here intended]: (M, K, TA:) and in like manner,"},{"kind":"arabic","text_bw":"Als~iloEapa","text_ar":"السِّلْعَةَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aisotamotuhu","text_ar":"اِسْتَمْتُهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I offered to him the commodity for sale,"},{"kind":"text","text":"&c.: and"},{"kind":"italic_en","text":"I purchased of him the commodity,"},{"kind":"text","text":"&c.]: (TA:) or, as some say, (so in the TA, but in the M and K “ and, ”) this last, as also"},{"kind":"arabic","text_bw":"EalaY Als~iloEapi","text_ar":"عَلَى السِّلْعَةِ"},{"kind":"text","text":", ↓"},{"kind":"arabic","text_bw":"Aisotamotuhu","text_ar":"اِسْتَمْتُهُ","orth_type":"arrow"},{"kind":"text","text":", means ↓"},{"kind":"arabic","text_bw":"saA^alotuhu sawomahaA","text_ar":"سَاَلْتُهُ سَوْمَهَا","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I asked him the price at which the commodity was to be sold"},{"kind":"text","text":"]: (M, K, TA:) and"},{"kind":"arabic","text_bw":"saAmaniyhaA","text_ar":"سَامَنِيهَا"},{"kind":"text","text":", (M,) or ↓"},{"kind":"arabic","text_bw":"saAwamaniyhaA","text_ar":"سَاوَمَنِيهَا","orth_type":"arrow"},{"kind":"text","text":", (TA, [but the former is app. the right,]) means ↓"},{"kind":"arabic","text_bw":"*akara liY sawomahaA","text_ar":"ذَكَرَ لِى سَوْمَهَا","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he mentioned to me the price at which it was to be sold"},{"kind":"text","text":"]: (M, TA:) you say also,"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aisotamotu","text_ar":"اِسْتَمْتُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"bisiloEatiY","text_ar":"بِسِلْعَتِى"},{"kind":"text","text":"when you mention the price of the commodity [i. e. it means"},{"kind":"italic_en","text":"I mentioned to him the price at which I would sell my commodity"},{"kind":"text","text":"]: and you say,"},{"kind":"arabic","text_bw":"min~iY siloEatiY","text_ar":"مِنِّى سِلْعَتِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AisotaAma","text_ar":"اِسْتَامَ","orth_type":"arrow"},{"kind":"text","text":"when he is the person who offers to thee the price [i. e. it means"},{"kind":"italic_en","text":"he offered to me a price for my commodity;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he sought to obtain from me the sale of my commodity by offering a price for it"},{"kind":"text","text":"]: (TA:) and"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AisotaAma","text_ar":"اِسْتَامَ","orth_type":"arrow"},{"kind":"italic_en","text":"he contended"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by bidding"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"against me in a sale:"},{"kind":"text","text":"(S, * PS:) or"},{"kind":"arabic","text_bw":"EalaY~a Als~iloEapa","text_ar":"عَلَىَّ السِّلْعَةَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AisotaAma","text_ar":"اِسْتَامَ","orth_type":"arrow"},{"kind":"text","text":", which means"},{"kind":"arabic","text_bw":"AstAm EalaY sawomiY","text_ar":"استام عَلَى سَوْمِى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he sought to obtain the sale of the commodity in opposition to me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to my seeking it"},{"kind":"text","text":"]. (Msb. [See also 3.]) Hence, [Mo- hammad is related to have said,]"},{"kind":"arabic","text_bw":"laA yasuwmu Alr~ajulu EalaY","text_ar":"لَا يَسُومُ الرَّجُلُ عَلَى"},{"kind":"arabic","text_bw":"sawomi A^axiyhi","text_ar":"سَوْمِ اَخِيهِ"},{"kind":"text","text":", (Mgh,) or"},{"kind":"arabic","text_bw":"lAyswm A^aHadukumo ElY swm","text_ar":"لايسوم اَحَدُكُمْ على سوم"},{"kind":"arabic","text_bw":"Axyh","text_ar":"اخيه"},{"kind":"text","text":", (Msb,) i. e. ["},{"kind":"italic_en","text":"The man,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any one of you,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"shall not purchase"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in opposition to his brother"},{"kind":"text","text":"]: (Mgh, Msb:) and it may mean"},{"kind":"italic_en","text":"shall not sell;"},{"kind":"text","text":"the case being that of a man's offering to the purchaser his commodity for a certain price, and another's then saying, “ I have the like thereof for less than this price: ” so that the prohibition relates in common to the seller and the buyer: (M:) and the saying is also related otherwise, i. e. ↓"},{"kind":"arabic","text_bw":"laAyasotaAmu","text_ar":"لَايَسْتَامُ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"shall not purchase."},{"kind":"text","text":"(Mgh.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"nahaY Eani Als~awomi qabola TuluwEi","text_ar":"نَهَى عَنِ السَّوْمِ قَبْلَ طُلُوعِ"},{"kind":"arabic","text_bw":"Al$~amosi","text_ar":"الشَّمْسِ"},{"kind":"text","text":", meaning, accord. to Aboo-Is-hák,"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"arabic","text_bw":"bisiloEatihi","text_ar":"بِسِلْعَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yusaAwima","text_ar":"يُسَاوِمَ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(Mohammad)"},{"kind":"italic_en","text":"forbade the offering a commodity for sale before the rising of the sun"},{"kind":"text","text":"]; because that is a time in which God is to be praised, and one should not be diverted by other occupation: or, he says, it may mean"},{"kind":"italic_en","text":"the pasturing of camels;"},{"kind":"text","text":"because, before sunrise, when the pasturage is moist with dew, it occasions a fatal disease. (TA.) You say also,"},{"kind":"arabic","text_bw":"sumotuka","text_ar":"سُمْتُكَ"},{"kind":"arabic","text_bw":"HasanapF","text_ar":"حَسَنَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baEiyraka siymapF","text_ar":"بَعِيرَكَ سِيمَةً","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have mentioned to thee a good price for thy camel"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AisotaAma","text_ar":"اِسْتَامَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"gaAliyapF","text_ar":"غَالِيَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"siymapF","text_ar":"سِيمَةً","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He demanded for it a dear price"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"Hvr","text_ar":"حثر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"saAmahu biEamalK","text_ar":"سَامَهُ بِعَمَلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made to him an offer of working, mentioning the rate of payment;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bargained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted, with him for work"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"Eml","text_ar":"عمل"},{"kind":"text","text":". [See also 3.]) ―         -b2-  The Arabs also say,"},{"kind":"arabic","text_bw":"EaraDa EalaY~a sawoma EaAl~apK","text_ar":"عَرَضَ عَلَىَّ سَوْمَ عَالَّةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He offered to me in the manner of offering"},{"kind":"text","text":"water"},{"kind":"italic_en","text":"to camels taking a second draught"},{"kind":"text","text":"]; meaning like the saying of the vulgar,"},{"kind":"arabic","text_bw":"EaroDa saAbiriY~K","text_ar":"عَرْضَ سَابِرِىٍّ"},{"kind":"text","text":": (Ks, TA: [see art."},{"kind":"arabic","text_bw":"sbr","text_ar":"سبر"},{"kind":"text","text":":]) a prov. applied to him who offers to thee that of which thou hast no need. (Sh, TA. [See also art."},{"kind":"arabic","text_bw":"El","text_ar":"عل"},{"kind":"text","text":"; and see Freytag's Arab. Prov. ii. 84.]) ―         -b3-  And you say,"},{"kind":"arabic","text_bw":"saAmahu AlA^mora","text_ar":"سَامَهُ الامْرَ"},{"kind":"text","text":", (M, K,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"sawomN","text_ar":"سَوْمٌ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"He imposed upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him to undertake, the affair, as a task,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in spite of difficulty"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconvenience;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he ordered, required,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained, him to do the thing, it being difficult"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconvenient:"},{"kind":"text","text":"(M, K, TA:) or"},{"kind":"italic_en","text":"he brought upon him the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event;"},{"kind":"text","text":"(Zj, M, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"saw~amahu","text_ar":"سَوَّمَهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tasowiymN","text_ar":"تَسْوِيمٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"he endeavoured to induce him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him, to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to incur, the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event:"},{"kind":"text","text":"(Sh, TA:) it is mostly used in relation to punishment, and evil, (Zj, M, K, TA,) and wrong-doing: and hence the saying in the Kur [ii. 46 and vii. 137 and xiv. 6],"},{"kind":"arabic","text_bw":"yasuwmuwnakumo","text_ar":"يَسُومُونَكُمْ"},{"kind":"arabic","text_bw":"suwo'a A@loEa*aAbi","text_ar":"سُوْءَ ا@لْعَذَابِ"},{"kind":"italic_en","text":"They bringing upon you evil punish-"},{"kind":"page_break","n":1475},{"kind":"italic_en","text":"ment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"torment:"},{"kind":"text","text":"(Zj, M, TA:) or"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring, for you evil punishment:"},{"kind":"text","text":"(Ksh and Bd in ii. 46:) or"},{"kind":"italic_en","text":"endeavouring to induce you to incur it:"},{"kind":"text","text":"(Ksh ibid.:) from"},{"kind":"arabic","text_bw":"saAmahu xasofFA","text_ar":"سَامَهُ خَسْفًا"},{"kind":"text","text":"[expl. by what here follows]. (Ksh and Bd ibid.) You say,"},{"kind":"arabic","text_bw":"sumotuhu xasofFA","text_ar":"سُمْتُهُ خَسْفًا"},{"kind":"italic_en","text":"I brought upon him"},{"kind":"arabic","text_bw":"xasof","text_ar":"خَسْف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"wrong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrong treatment,"},{"kind":"text","text":"as expl. in the Ksh and by Bd ubi suprà]: or"},{"kind":"italic_en","text":"I endeavoured to induce him to incur it"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aradotuhu Ealayohi","text_ar":"اَرَدْتُهُ عَلَيْهِ"},{"kind":"text","text":"): (S:) [see also"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"sumotuhu xuT~apa xasofK","text_ar":"سُمْتُهُ خُطَّةَ خَسْفٍ"},{"kind":"text","text":"; expl. in art."},{"kind":"arabic","text_bw":"xT","text_ar":"خط"},{"kind":"text","text":":] and"},{"kind":"arabic","text_bw":"siyma Alxasofa","text_ar":"سِيمَ الخَسْفَ"},{"kind":"italic_en","text":"He was constrained to incur,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do, what is termed"},{"kind":"arabic","text_bw":"Alxasof","text_ar":"الخَسْف"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"abasement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that which was difficult"},{"kind":"text","text":"]: (TA:) and"},{"kind":"arabic","text_bw":"sumotuhu *ul~FA","text_ar":"سُمْتُهُ ذُلًّا"},{"kind":"italic_en","text":"I abased him."},{"kind":"text","text":"(Msb.)       -A3-"},{"kind":"arabic","text_bw":"saAmahu","text_ar":"سَامَهُ"},{"kind":"text","text":", aor. as above, also signifies"},{"kind":"italic_en","text":"He kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clave, to it, not quitting it."},{"kind":"text","text":"(M, * TA.)       -A4-  See also 4."}],"source_refs":["S","Mgh","Msb","TA","M","K","Sh","Zj"]},{"entry_id":"n21330","headword_ar":"سَوْمٌ","root":"swm","body":[{"kind":"text","text":"[is originally an inf. n.: see 1, passim:       -A2-  and is also used as a subst. signifying The"},{"kind":"italic_en","text":"price"},{"kind":"text","text":"of any commodity, or article of merchandise; like ↓"},{"kind":"arabic","text_bw":"siymapN","text_ar":"سِيمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"suwmapN","text_ar":"سُومَةٌ","orth_type":"arrow"},{"kind":"text","text":"]. You say,"},{"kind":"arabic","text_bw":"saA^alotuhu sawomahaA","text_ar":"سَاَلْتُهُ سَوْمَهَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"*akara liY sawomahaA","text_ar":"ذَكَرَ لِى سَوْمَهَا"},{"kind":"text","text":", referring to a"},{"kind":"arabic","text_bw":"siloEap","text_ar":"سِلْعَة"},{"kind":"text","text":"[or commodity]: see 1, in the former half of the paragraph. And"},{"kind":"arabic","text_bw":"HasanapF","text_ar":"حَسَنَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sumotuka baEiyraka siymapF","text_ar":"سُمْتُكَ بَعِيرَكَ سِيمَةً","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AisotaAma","text_ar":"اِسْتَامَ"},{"kind":"arabic","text_bw":"gaAliyapF","text_ar":"غَالِيَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fiyhi siymapF","text_ar":"فِيهِ سِيمَةً","orth_type":"arrow"},{"kind":"text","text":": see again 1, in the latter half of the paragraph. And ↓"},{"kind":"arabic","text_bw":"A_in~ahu lagaAliY Als~iymapi","text_ar":"اـِنَّهُ لَغَالِى السِّيمَةِ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K) and ↓"},{"kind":"arabic","text_bw":"Als~uwmapi","text_ar":"السُّومَةِ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Als~awomi","text_ar":"السَّوْمِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Verily it is dear in price"},{"kind":"text","text":"]. (M, K.) ↓"},{"kind":"arabic","text_bw":"siymapN","text_ar":"سِيمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"suwmapN","text_ar":"سُومَةٌ","orth_type":"arrow"},{"kind":"text","text":"are both substs. from"},{"kind":"arabic","text_bw":"saAma","text_ar":"سَامَ"},{"kind":"text","text":"as used in the phrase"},{"kind":"arabic","text_bw":"saAmaniY","text_ar":"سَامَنِى"},{"kind":"arabic","text_bw":"Alr~ajulu bisiloEatihi","text_ar":"الرَّجُلُ بِسِلْعَتِهِ"},{"kind":"text","text":"[and the like]; (TA;)"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"qiymapN","text_ar":"قِيمَةٌ"},{"kind":"text","text":". (Har p. 435 in explanation of the former.)"}],"source_refs":["S","M","K"]}]},"classical_definitions":null}