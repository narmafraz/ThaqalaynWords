le":"past_1ms","form":"اِعْتَلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":true,"lemma_key":"اِعْتَلَّ","root":"عتل","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n30123"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B9%D9%92%D8%AA%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be affected by a defect; to be sick, to be morbid"},{"pos":"verb","gloss":"to be weak, to be defective"},{"pos":"verb","gloss":"to give as a pretext, to justify oneself with"}]},"etymology":null,"ipa":["/iʕ.tal.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30123","headword_ar":"اعتلّ","root":"El","body":[{"kind":"text","text":": see 1, latter half. ―         -b2-  [Hence,"},{"kind":"arabic","text_bw":"AEtl~t","text_ar":"اعتلّت"},{"kind":"arabic","text_bw":"Alr~iyHu","text_ar":"الرِّيحُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wind became faint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feeble."},{"kind":"text","text":"]       -A2-  See also 5, first sentence. ―         -b2-  Also"},{"kind":"italic_en","text":"He excused himself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urged, an excuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plea;"},{"kind":"text","text":"(MA, K, * TA; *) or"},{"kind":"italic_en","text":"he laid hold upon a plea,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an allegation."},{"kind":"text","text":"(El-Fárábee, Msb.) You say,"},{"kind":"arabic","text_bw":"AEtl~","text_ar":"اعتلّ"},{"kind":"arabic","text_bw":"Ealayohi biEil~apK","text_ar":"عَلَيْهِ بِعِلَّةٍ"},{"kind":"text","text":"(S, MA, O)"},{"kind":"italic_en","text":"He adduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urged, an excuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plea,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pretext, for it."},{"kind":"text","text":"(MA.) And hence,"},{"kind":"arabic","text_bw":"AiEotilaAlaAtu AlfuqahaA='i","text_ar":"اِعْتِلَالَاتُ الفُقَهَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The pleas,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allegations, of the lawyers, which they adduce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon which they lay hold"},{"kind":"text","text":"]. (Msb.)       -A3-"},{"kind":"arabic","text_bw":"AEtl~hu","text_ar":"اعتلّهُ"},{"kind":"italic_en","text":"He hindered, prevented, impeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld, him; turned him back"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away; retarded him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diverted him by occupying him otherwise; from an affair."},{"kind":"text","text":"(S, O.) ―         -b2-  And (S, O, in the K “ or ”)"},{"kind":"italic_en","text":"He accused him of a crime, an offence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an injurious action, that he had not committed."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["S","MA","O"]}]},"classical_definitions":null}