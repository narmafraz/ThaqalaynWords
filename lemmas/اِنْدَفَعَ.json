":["n12717"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AF%D9%8E%D9%81%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dive into, to rush into","tags":["reflexive"]},{"pos":"verb","gloss":"to set up, to begin","tags":["reflexive"],"examples":[{"text":"اِنْدَفَعَتْ فِي ٱلضَّحِكِ","english":"She burst out laughing."}]}]},"etymology":null,"ipa":["/in.da.fa.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12717","headword_ar":"اندفع","root":"dfE","body":[{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"dafaEahu","text_ar":"دَفَعَهُ"},{"kind":"text","text":"; (S, K, TA;) and ↓"},{"kind":"arabic","text_bw":"tdf~E","text_ar":"تدفّع","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"df~Ehu","text_ar":"دفّعهُ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tdAfE","text_ar":"تدافع","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"dAfEhu","text_ar":"دافعهُ"},{"kind":"text","text":": but all three are used in the same sense: see 6: (TA:) [the first, however, primarily signifies"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became impelled, pushed, thrust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"driven;"},{"kind":"text","text":"and particularly,"},{"kind":"italic_en","text":"so as to be removed from his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, place; became propelled; became repelled; became impelled, pushed, thrust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"driven, away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"onwards; became put away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed from its place;"},{"kind":"text","text":"as is implied in the S and K and TA: whereas the second, properly, has an intensive signification: and the third properly denotes the acting of two or more persons or things, or of several parts or portions of a thing, against, or upon, one another; as is shown by exs. and explanations above: though the second and third are often used in the primary sense of the first.] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AndfE","text_ar":"اندفع"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He went away"},{"kind":"text","text":"into the country, or land,"},{"kind":"italic_en","text":"in any manner:"},{"kind":"text","text":"(Lth:) or, said of a horse [&c.], (tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"went quickly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swiftly"},{"kind":"text","text":"(S, K, TA) ["},{"kind":"italic_en","text":"as though impelled"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"propelled; pressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pushed, on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forward; rushed; launched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke, forth; it poured forth with vehemence, as though impelled:"},{"kind":"text","text":"see 1, which has a similar meaning, particularly in the phrases"},{"kind":"arabic","text_bw":"dafaEa AlmaA='u","text_ar":"دَفَعَ المَا=ءُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Als~ayolu","text_ar":"السَّيْلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"dafaEa fiY Eadowihi","text_ar":"دَفَعَ فِى عَدْوِهِ"},{"kind":"text","text":", &c.]. ―         -b3-"},{"kind":"arabic","text_bw":"AndfE fiY","text_ar":"اندفع فِى"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"AlHadiyvi","text_ar":"الحَدِيثِ"},{"kind":"text","text":", (S, K, TA,) and"},{"kind":"arabic","text_bw":"fiY AlA_ino$aAdi","text_ar":"فِى الاـِنْشَادِ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He pushed on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressed on, in discourse,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in reciting"},{"kind":"text","text":"poetry; or"},{"kind":"italic_en","text":"entered thereinto;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"launched forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out, thereinto;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profuse, therein;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dilated therein;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"began it, commenced it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^afaADa fiyhi","text_ar":"اَفَاضَ فِيهِ"},{"kind":"text","text":". (K, TA.) And"},{"kind":"arabic","text_bw":"AndfE fiY AlD~aHiki","text_ar":"اندفع فِى الضَّحِكِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He broke forth into laughing"},{"kind":"text","text":"]. (JK in art."},{"kind":"arabic","text_bw":"bwq","text_ar":"بوق"},{"kind":"text","text":".) ―         -b4-  ["},{"kind":"arabic","text_bw":"AndfE fiY","text_ar":"اندفع فِى"},{"kind":"arabic","text_bw":"AlT~aEaAmi","text_ar":"الطَّعَامِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He fell to eating of the food;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"applied himself eagerly to it."},{"kind":"text","text":"] ―         -b5-"},{"kind":"arabic","text_bw":"AndfE fiYAlA^amori","text_ar":"اندفع فِىالاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He acted with penetrating energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpness, vigorousness, and effectiveness, in the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maDaY fiyhi","text_ar":"مَضَى فِيهِ"},{"kind":"text","text":". (A, TA.)"}],"source_refs":["TA","Lth","S","K"]}]},"classical_definitions":null}