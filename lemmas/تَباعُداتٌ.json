{"lemma":"تَباعُداتٌ","slug":"تَباعُداتٌ","root":"ب.ع.د","root_slug":"ب-ع-د","root_link":"/words/roots/ب-ع-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n2864"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D8%A7%D8%B9%D9%8F%D8%AF%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to drift away from each other, become far apart, diverge, separate, become estranged","tags":["intransitive","reciprocal"]},{"pos":"noun","gloss":"verbal noun of تَبَاعَدَ (tabāʕada) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"being distant, going to a distance, divergence"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of تَبَاعَدَ (tabāʕada)."},"ipa":["/ta.qaː.ra.ba/","/ta.baː.ʕud/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2864","headword_ar":"تباعد","root":"bEd","body":[{"kind":"text","text":": see 1, in six places. ―         -b2-  [It also signifies"},{"kind":"italic_en","text":"He became alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged,"},{"kind":"text","text":"from his family or friends. ―         -b3-  And"},{"kind":"arabic","text_bw":"tbAEdwA","text_ar":"تباعدوا"},{"kind":"italic_en","text":"They became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, one from another; they went, removed, retired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdrew themselves, to a distance, far away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off, one from another; they removed themselves far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept aloof, one from another."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"kaAnuwA mutaqaAribiyna fatabaAEaduwA","text_ar":"كَانُوا مُتَقَارِبِينَ فَتَبَاعَدُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They were near, one to another, and they became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, one from another"},{"kind":"text","text":"]. (A.)"}],"source_refs":[]}]},"classical_definitions":null}