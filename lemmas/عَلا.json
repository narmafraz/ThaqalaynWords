orpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْلُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":76,"cross_references":{"qac":{"found":true,"lemma_key":"عَلا","root":"علو","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n30391","n30401"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%84%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be exalted, high"},{"pos":"verb","gloss":"to tower over (someone, something)","examples":[{"text":"عَلَوْا فَوْقَ ٱلْمَاءِ.","english":"They floated over water."}]},{"pos":"verb","gloss":"to exceed"},{"pos":"verb","gloss":"to rise","examples":[{"text":"وَكُلَّمَا كَانَ ٱلْمَدَى أَكْبَرَ، عَلَا ٱلصَّوْتُ.","english":"The larger the amplitude, the louder the sound."},{"text":"عَلَا ٱلطَّائِرُ فِي ٱلسَّمَاءِ.","english":"The bird rose in the sky."}]},{"pos":"verb","gloss":"to overwhelm","tags":["transitive"]},{"pos":"verb","gloss":"to climb (something)","tags":["transitive"],"examples":[{"text":"عَلَوْتُ ٱلشَّجَرَةَ.","english":"I climbed the tree."}]},{"pos":"verb","gloss":"to cover","tags":["transitive"]},{"pos":"adj","gloss":"feminine plural of أَعْلَى (ʔaʕlā, “higher, upper; superior”)","tags":["feminine","form-of","plural"]},{"pos":"noun","gloss":"worktop, a rock or iron on which tools are smithed or أَقِط (ʔaqiṭ) cooked","tags":["collective","obsolete"],"examples":[{"text":"وَأَوْرَثَكَ القَيْنٌ الْعَلَاةَ وَمِرْجَلًا … وَإِصْلَاحَ أَخْرَاتِ الْفُؤُوسِ الْكَرَازِمِ","english":"Your heiresses: the smith on the anvil and boiling pot … and the mending the nicks in the hafted axe-blades"}]}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew עָלָה (ʿālã́)."},"ipa":["/ʕa.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30391","headword_ar":"عَلَا","root":"Elw","body":[{"kind":"text","text":", (Msb, K,) aor."},{"kind":"arabic","text_bw":"yaEoluw","text_ar":"يَعْلُو"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"EaliYa","text_ar":"عَلِىَ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tEl~Y","text_ar":"تعلّى","orth_type":"arrow"},{"kind":"text","text":"[which last see also below]; (K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high, elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lofty;"},{"kind":"text","text":"(Msb, K; *) syn."},{"kind":"arabic","text_bw":"AirotafaEa","text_ar":"اِرْتَفَعَ"},{"kind":"text","text":"; (Msb;) and so ↓"},{"kind":"arabic","text_bw":"tEAlY","text_ar":"تعالى","orth_type":"arrow"},{"kind":"text","text":": (S, K:) or you say,"},{"kind":"arabic","text_bw":"EalaA fiY AlmakaAni","text_ar":"عَلَا فِى المَكَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, in place"},{"kind":"text","text":"], aor."},{"kind":"arabic","text_bw":"yaEoluw","text_ar":"يَعْلُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"EaliYa fiY Al$~arafi","text_ar":"عَلِىَ فِى الشَّرَفِ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exalted, in dignity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"], (S, Mgh,) with kesr, (S,) aor."},{"kind":"arabic","text_bw":"yaEolaY","text_ar":"يَعْلَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EalaA='N","text_ar":"عَلَا=ءٌ"},{"kind":"text","text":"; (S, Mgh;) and also"},{"kind":"arabic","text_bw":"EalaA","text_ar":"عَلَا"},{"kind":"text","text":", with fet-h, aor."},{"kind":"arabic","text_bw":"yaEolaY","text_ar":"يَعْلَى"},{"kind":"text","text":": a poet says,"},{"kind":"quote","text":"lam~aA EalaA kaEobuka liY Ealiytu"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"When thy nobility became exalted to me, I became exalted"},{"kind":"text","text":"]; thus combining the two dial. vars.: (S:) or you say,"},{"kind":"arabic","text_bw":"EaliYa fiY AlmakaArimi","text_ar":"عَلِىَ فِى المَكَارِمِ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, eminent in generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honourable, actions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"qualities"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"EalaA='N","text_ar":"عَلَا=ءٌ"},{"kind":"text","text":"[in some copies of the K"},{"kind":"arabic","text_bw":"EalFA","text_ar":"عَلًا"},{"kind":"text","text":"]; (Msb, K;) and"},{"kind":"arabic","text_bw":"EalaA","text_ar":"عَلَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":"; (K;) and thus the two verbs are used in the saying of the poet cited above: (TA:) and ↓"},{"kind":"arabic","text_bw":"AstElY","text_ar":"استعلى","orth_type":"arrow"},{"kind":"text","text":", said of a man, signifies the same as"},{"kind":"arabic","text_bw":"EalaA","text_ar":"عَلَا"},{"kind":"text","text":". (S.) [Hence,]"},{"kind":"arabic","text_bw":"Ealati Al$~amosu","text_ar":"عَلَتِ الشَّمْسُ"},{"kind":"italic_en","text":"The sun became high;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AiEotalat","text_ar":"اِعْتَلَت","orth_type":"arrow"},{"kind":"text","text":": (Nawádir el-Aaráb, TA in art."},{"kind":"arabic","text_bw":"dlk","text_ar":"دلك"},{"kind":"text","text":":) and [hence,]"},{"kind":"arabic","text_bw":"EalaA Aln~ahaAru","text_ar":"عَلَا النَّهَارُ"},{"kind":"italic_en","text":"The day became advanced, the sun being somewhat high;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AirotafaEa","text_ar":"اِرْتَفَعَ"},{"kind":"text","text":"[q. v.]; as also ↓"},{"kind":"arabic","text_bw":"AEtlY","text_ar":"اعتلى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstElY","text_ar":"استعلى","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"EalaA fiY AlmakaAni","text_ar":"عَلَا فِى المَكَانِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":", signifies [also]"},{"kind":"italic_en","text":"He ascended the place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the place;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaEida","text_ar":"صَعِدَ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Ealawotu EalaY Aljabali","text_ar":"عَلَوْتُ عَلَى الجَبَلِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ealawotu A^aEolaAhu","text_ar":"عَلَوْتُ اَعْلَاهُ"},{"kind":"text","text":"are syn. [as meaning"},{"kind":"italic_en","text":"I ascended the mountain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the mountain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the top,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest part, thereof"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Ealawotuhu","text_ar":"عَلَوْتُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ealawotu fiyhi","text_ar":"عَلَوْتُ فِيهِ"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"I ascended it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"raqiytu","text_ar":"رَقِيتُ"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"EalaAhu","text_ar":"عَلَاهُ"},{"kind":"text","text":"(S, Msb, K, TA) and"},{"kind":"arabic","text_bw":"EalaA bihi","text_ar":"عَلَا بِهِ"},{"kind":"text","text":", (K, TA, [in the CK"},{"kind":"arabic","text_bw":"El~Ah wbh","text_ar":"علّاه وبه"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"EalaAhu wabihi","text_ar":"عَلَاهُ وَبِهِ"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"AstElAhu","text_ar":"استعلاهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) and ↓"},{"kind":"arabic","text_bw":"AEtlAhu","text_ar":"اعتلاهُ","orth_type":"arrow"},{"kind":"text","text":", (S,) and ↓"},{"kind":"arabic","text_bw":"AiEolawolaAhu","text_ar":"اِعْلَوْلَاهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AElAhu","text_ar":"اعلاهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"El~Ah","text_ar":"علّاه","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) this last [for which the CK has"},{"kind":"arabic","text_bw":"EAlAhu","text_ar":"عالاهُ"},{"kind":"text","text":"] being with teshdeed, (TA,) and ↓"},{"kind":"arabic","text_bw":"EAlAhu","text_ar":"عالاهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EAlY","text_ar":"عالى","orth_type":"arrow"},{"kind":"text","text":", (K, TA, [in the CK"},{"kind":"arabic","text_bw":"EAl~aAhu wbh","text_ar":"عالَّاهُ وبه"},{"kind":"text","text":",]) are syn., (S, K,) signifying"},{"kind":"italic_en","text":"He ascended it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon it;"},{"kind":"text","text":"(K; [in the CK"},{"kind":"arabic","text_bw":"SaE~adahu","text_ar":"صَعَّدَهُ"},{"kind":"text","text":", and so in my MS. copy of the K, but in other copies"},{"kind":"arabic","text_bw":"SaEidahu","text_ar":"صَعِدَهُ"},{"kind":"text","text":", which is certainly the right reading;]) whether the object be a mountain or a beast: (TA:) [or] you say,"},{"kind":"arabic","text_bw":"EalaA Ald~aAb~apa","text_ar":"عَلَا الدَّابَّةَ"},{"kind":"italic_en","text":"He mounted the beast;"},{"kind":"text","text":"(K, TA;) and in like manner, anything: (TA:) and"},{"kind":"arabic","text_bw":"EalaY Als~aToHa","text_ar":"عَلَى السَّطْحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEoliyhi","text_ar":"يَعْلِيهِ"},{"kind":"text","text":"; (K, TA;) but in the M"},{"kind":"arabic","text_bw":"EaliYa Als~aToHa","text_ar":"عَلِىَ السَّطْحَ"},{"kind":"text","text":", i. e., like"},{"kind":"arabic","text_bw":"raDiYa","text_ar":"رَضِىَ"},{"kind":"text","text":"; (TA;) inf. n."},{"kind":"arabic","text_bw":"EaloYN","text_ar":"عَلْىٌ"},{"kind":"text","text":"(K, TA) and"},{"kind":"arabic","text_bw":"EiloYN","text_ar":"عِلْىٌ"},{"kind":"text","text":"(TA, and so accord. to some copies of the K,) and"},{"kind":"arabic","text_bw":"EuliY~N","text_ar":"عُلِىٌّ"},{"kind":"text","text":"; (TA, and so accord. to other copies of the K instead of"},{"kind":"arabic","text_bw":"EiloYN","text_ar":"عِلْىٌ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"He ascended upon the flat house-top;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaEidahu","text_ar":"صَعِدَهُ"},{"kind":"text","text":". (K, TA.) ―         -b3-  ["},{"kind":"arabic","text_bw":"EalaAhu","text_ar":"عَلَاهُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, upon it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arose, upon it; overlay it; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, superincumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supernatant, upon it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overspread it;"},{"kind":"text","text":"as scum, and rust, &c. And"},{"kind":"italic_en","text":"It lay on him as a burden."},{"kind":"text","text":"Hence,] one says,"},{"kind":"arabic","text_bw":"maA saA^alotuka maA yaEoluwka ZahorFA","text_ar":"مَا سَاَلْتُكَ مَا يَعْلُوكَ ظَهْرًا"},{"kind":"text","text":"i. e. [(assumed tropical:)"},{"kind":"italic_en","text":"I did not ask,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demand, of thee, what would lie as a burden on thy back;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"what would be onerous, burdensome, oppressive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome, to thee."},{"kind":"text","text":"(TA.) ―         -b4-  And [hence also]"},{"kind":"arabic","text_bw":"EalaAhu","text_ar":"عَلَاهُ"},{"kind":"italic_en","text":"It over-"},{"kind":"page_break","n":2143},{"kind":"italic_en","text":"topped it, rose above it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exceeded it in height."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"dSr","text_ar":"دصر"},{"kind":"text","text":".) [And in like manner, ↓"},{"kind":"arabic","text_bw":"AstElY","text_ar":"استعلى","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"It became elevated above it."},{"kind":"text","text":"] ―         -b5-  And"},{"kind":"arabic","text_bw":"Ealawotuhumo","text_ar":"عَلَوْتُهُمْ"},{"kind":"arabic","text_bw":"biAl$~arafi","text_ar":"بِالشَّرَفِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biAljamaAli","text_ar":"بِالجَمَالِ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, superior to them in nobility"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in goodliness"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"frE","text_ar":"فرع"},{"kind":"text","text":".) ―         -b6-  And"},{"kind":"arabic","text_bw":"EalaAhu","text_ar":"عَلَاهُ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"He had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained, ascendency over him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"EalaA Ealayohi","text_ar":"عَلَا عَلَيْهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstElY","text_ar":"استعلى","orth_type":"arrow"},{"kind":"text","text":": and] (assumed tropical:)"},{"kind":"italic_en","text":"he overcame him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained, the mastery over him;"},{"kind":"text","text":"(S, Msb, TA;) and"},{"kind":"italic_en","text":"subdued him;"},{"kind":"text","text":"(Msb;) namely, his opponent, or adversary; as also ↓"},{"kind":"arabic","text_bw":"AstElAhu","text_ar":"استعلاهُ","orth_type":"arrow"},{"kind":"text","text":": and in like manner,"},{"kind":"arabic","text_bw":"EalaA HaAjatahu","text_ar":"عَلَا حَاجَتَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstElAhA","text_ar":"استعلاها","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"he gained the mastery over the object of his want:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AEtlY","text_ar":"اعتلى","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"he prevailed against the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had power over it, and overcame it;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaA lil$~aYo'i","text_ar":"عَلَا لِلشَّىْءِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEoluw","text_ar":"يَعْلُو"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, able to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to bear, the thing."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"EalaA","text_ar":"عَلَا"},{"kind":"arabic","text_bw":"biAlA^amori","text_ar":"بِالاَمْرِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"AiDoTalaEa bihi waA@sotaqal~a","text_ar":"اِضْطَلَعَ بِهِ وَا@سْتَقَلَّ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"He had strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, sufficient for the affair, and had absolute control over it"},{"kind":"text","text":"]: (S: [so in one of my copies: the other has"},{"kind":"arabic","text_bw":"AiT~alaEa","text_ar":"اِطَّلَعَ"},{"kind":"text","text":", which I find also in the PS and in my copy of the TA; and which is allowed by some, but disallowed by others, in the sense of"},{"kind":"arabic","text_bw":"AiDoTalaEa","text_ar":"اِضْطَلَعَ"},{"kind":"text","text":", as is shown voce"},{"kind":"arabic","text_bw":"muDoTaliEN","text_ar":"مُضْطَلِعٌ"},{"kind":"text","text":":]) a poet says,"},{"kind":"quote","text":"faA@Eomido limaA taEoluw famaA laka biAl~a*iY\n                      \n                     \n                        laA tasotaTiyEu mina AlA^umuwri yadaAni"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Then aim thou at that for which thou hast sufficient strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, and over which thou hast absolute control:"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"being understood after"},{"kind":"arabic","text_bw":"tElw","text_ar":"تعلو"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"for what object hast thou"},{"kind":"text","text":"in meddling"},{"kind":"italic_en","text":"with that which a pair of hands cannot accomplish, of affairs?"},{"kind":"text","text":"]. (S.) [And hence, perhaps,] one says to him who possesses much property,"},{"kind":"arabic","text_bw":"AEl bh","text_ar":"اعل به"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"Abq bEdh","text_ar":"ابق بعده"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"AuEolu bihi","text_ar":"اُعْلُ بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Aiboqa baEodahu","text_ar":"اِبْقَ بَعْدَهُ"},{"kind":"text","text":", as though meaning (assumed tropical:)"},{"kind":"italic_en","text":"Have thou ability to consume it,"},{"kind":"text","text":"and so"},{"kind":"italic_en","text":"survive thou it;"},{"kind":"text","text":"like as one says to him who puts on a new garment,"},{"kind":"arabic","text_bw":"A^aboli","text_ar":"اَبْلِ"},{"kind":"text","text":"(see 4 in art."},{"kind":"arabic","text_bw":"blw","text_ar":"بلو"},{"kind":"text","text":")]: or [perhaps a mistake for “ and ”] it is [virtually] a prayer for his continuance in life. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"Ealawotu EalaY fulaAnK Alr~iyHa","text_ar":"عَلَوْتُ عَلَى فُلَانٍ الرِّيحَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I was"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"went"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"on the windward side of such a one:"},{"kind":"text","text":"and one says,"},{"kind":"arabic","text_bw":"laA taEolu Alr~iyHa EalaY AlS~ayodi fayaraAHa riyHaka wayanofira","text_ar":"لَا تَعْلُ الرِّيحَ عَلَى الصَّيْدِ فَيَرَاحَ رِيحَكَ وَيَنْفِرَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Go not thou on the windward side of the game, lest it scent thy odour, and take fright and flee"},{"kind":"text","text":"]. (TA.) ―         -b8-"},{"kind":"arabic","text_bw":"Ealawotuhu biAls~ayofi","text_ar":"عَلَوْتُهُ بِالسَّيْفِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I smote him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with the sword;"},{"kind":"text","text":"or, more properly,"},{"kind":"italic_en","text":"I set upon him therewith"},{"kind":"text","text":"]. (S, TA.) And [in like manner] one says,"},{"kind":"arabic","text_bw":"EalaAhu biAl$~atomi waAlD~arobi","text_ar":"عَلَاهُ بِالشَّتْمِ وَالضَّرْبِ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"He set upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assailed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overcame him, with reviling and beating"},{"kind":"text","text":"]. (S and M in art."},{"kind":"arabic","text_bw":"vwl","text_ar":"ثول"},{"kind":"text","text":", &c.) ―         -b9-"},{"kind":"arabic","text_bw":"EalaA fiY","text_ar":"عَلَا فِى"},{"kind":"arabic","text_bw":"AlA^aroDi","text_ar":"الاَرْضِ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":", (S,) signifies (assumed tropical:)"},{"kind":"italic_en","text":"He exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magnified, himself,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the earth,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"behaved proudly, insolently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitantly."},{"kind":"text","text":"(S, * TA.) And [in like manner]"},{"kind":"arabic","text_bw":"laA taEoluwA EalaY A@ll~`hi","text_ar":"لَا تَعْلُوا عَلَى ا@للّٰهِ"},{"kind":"text","text":", in the Kur xliv. 18, (assumed tropical:)"},{"kind":"italic_en","text":"Exalt not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magnify not, yourselves against God;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behave not proudly,"},{"kind":"text","text":"&c. (Bd, Jel.) ―         -b10-"},{"kind":"arabic","text_bw":"EalaA Eanohu","text_ar":"عَلَا عَنْهُ"},{"kind":"text","text":"[lit. signifies"},{"kind":"italic_en","text":"It rose from it:"},{"kind":"text","text":"and hence,]"},{"kind":"italic_en","text":"it recoiled from it,"},{"kind":"text","text":"i. e., a thing from another thing;"},{"kind":"italic_en","text":"it did not cleave to it:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taEoluw Eanohu AlEayonu","text_ar":"تَعْلُو عَنْهُ العَيْنُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The eye recoils from him."},{"kind":"text","text":"(TA.) ―         -b11-"},{"kind":"arabic","text_bw":"AuEolu Ean~iY","text_ar":"اُعْلُ عَنِّى"},{"kind":"text","text":": see 3. ―         -b12-"},{"kind":"arabic","text_bw":"EalaA bihi","text_ar":"عَلَا بِهِ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"A^aEolaAhu","text_ar":"اَعْلَاهُ"},{"kind":"text","text":": see expl. with the latter below."}],"source_refs":["Msb","K","S","Mgh","TA"]},{"entry_id":"n30401","headword_ar":"عَلَا","root":"Elw","body":[{"kind":"text","text":"[as a subst.]: see the next preceding paragraph, in two places.       -A2-  See also"},{"kind":"arabic","text_bw":"EalaApN","text_ar":"عَلَاةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}