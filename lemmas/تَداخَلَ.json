earch_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AF%D8%A7%D8%AE%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pass through each other or one another; to intertwine; to intermesh; to interpenetrate","tags":["intransitive","reciprocal"]},{"pos":"verb","gloss":"to interfere, to intervene, to interpose","tags":["intransitive"]},{"pos":"verb","gloss":"to interfere, to intervene, to interpose; to meddle in; to intrude on","tags":["intransitive"]},{"pos":"noun","gloss":"verbal noun of تَدَاخَلَ (tadāḵala) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"interference, intervention"},{"pos":"noun","gloss":"interlocking, meshing"},{"pos":"noun","gloss":"superimposition"},{"pos":"noun","gloss":"shading, blending"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12250","headword_ar":"تداخل","root":"dxl","body":[{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"daxala baEoDuhu fiY baEoDK","text_ar":"دَخَلَ بَعْضُهُ فِى بَعْضٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"One part of it entered into another,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts of it into others;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"it became intermixed, intermingled, commixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commingled; it intermixed; it became confused:"},{"kind":"text","text":"and hence it often means"},{"kind":"italic_en","text":"it became compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"qSr","text_ar":"قصر"},{"kind":"text","text":".) [Hence,]"},{"kind":"arabic","text_bw":"tadaAxalN","text_ar":"تَدَاخَلٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"entering"},{"kind":"text","text":"of joints"},{"kind":"italic_en","text":"one into another;"},{"kind":"text","text":"(M;) as also ↓"},{"kind":"arabic","text_bw":"dixaAlN","text_ar":"دِخَالٌ","orth_type":"arrow"},{"kind":"text","text":"(JK, M, K) and ↓"},{"kind":"arabic","text_bw":"daxiylN","text_ar":"دَخِيلٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) but this last is not in the M [nor in the JK], and requires consideration: (TA:) [perhaps the joints ("},{"kind":"arabic","text_bw":"mafaASil","text_ar":"مَفَاصِل"},{"kind":"text","text":") here mentioned are those of a coat of mail; for it is said immediately before in the JK that"},{"kind":"arabic","text_bw":"dixaAlN","text_ar":"دِخَالٌ"},{"kind":"text","text":"in coats of mail signifies"},{"kind":"italic_en","text":"firmness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compactness, of make."},{"kind":"text","text":"Hence also,]"},{"kind":"arabic","text_bw":"tadaAxulu","text_ar":"تَدَاخُلُ"},{"kind":"arabic","text_bw":"All~ugaAti","text_ar":"اللُّغَاتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The intermixture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commixture, of dialects"},{"kind":"text","text":"]. (Mz 17th"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"tadaAxulu AlA^umuwri","text_ar":"تَدَاخُلُ الاُمُورِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The dubiousness and confusedness of affairs;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"AlA^umuwri","text_ar":"الاُمُورِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"dixaAlu","text_ar":"دِخَالُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b2-  See also 1, in the latter half of the paragraph.       -A2-  [It is also trans.] You say,"},{"kind":"arabic","text_bw":"tadaAxalani minohu $aYo'N","text_ar":"تَدَاخَلَنِ مِنْهُ شَىْءٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Something thereof,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"therefrom, crept into me,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"into my mind"},{"kind":"text","text":"]. (S, TA. [In the former, this meaning seems to be indicated by what there immediately precedes.]) And"},{"kind":"arabic","text_bw":"tadaAxalaniY mino h`*aA AlA^amori ramaDN","text_ar":"تَدَاخَلَنِى مِنْ هٰذَا الاَمْرِ رَمَضٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Distress and disquietude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief, crept into me from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in consequence of, this thing"},{"kind":"text","text":"]. (A and TA in art."},{"kind":"arabic","text_bw":"rmD","text_ar":"رمض"},{"kind":"text","text":".)"}],"source_refs":["JK","M","K","TA"]}]},"classical_definitions":null}