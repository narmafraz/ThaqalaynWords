{"lemma":"بُرُودٌ","slug":"بُرُودٌ","root":"ب.ر.د","root_slug":"ب-ر-د","root_link":"/words/roots/ب-ر-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n2229"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D8%B1%D9%8F%D9%88%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a kind of garment without nap"},{"pos":"noun","gloss":"plural of بُرْد (burd)","tags":["form-of","plural"]},{"pos":"noun","gloss":"verbal noun of بَرَدَ (barada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"having a cooling effect, rendering cold"}]},"etymology":{"source":"wiktextract","text":"Alteration of بُرْد (burd) from Old Armenian բուրդ (burd)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2229","headword_ar":"بَرُودٌ","root":"brd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"baAridN","text_ar":"بَارِدٌ"},{"kind":"text","text":". ―         -b2-  Beverage"},{"kind":"italic_en","text":"that cools the heat of thirst."},{"kind":"text","text":"(T.) ―         -b3-  Also, (T, L, K,) and ↓"},{"kind":"arabic","text_bw":"maboruwdN","text_ar":"مَبْرُودٌ","orth_type":"arrow"},{"kind":"text","text":", (T, M, A, L, K,) Bread"},{"kind":"italic_en","text":"upon which water is poured;"},{"kind":"text","text":"(T, L, K;)"},{"kind":"italic_en","text":"which is moistened with cold water:"},{"kind":"text","text":"(A:) eaten by women to make them fat. (M, A, L.) The subst. applied to such bread is ↓"},{"kind":"arabic","text_bw":"bariydN","text_ar":"بَرِيدٌ","orth_type":"arrow"},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"baruwdN","text_ar":"بَرُودٌ"},{"kind":"text","text":"[as an epithet in which the quality of a subst. predominates] also signifies"},{"kind":"italic_en","text":"Cold water which one pours upon his head."},{"kind":"text","text":"(M.) ―         -b5-"},{"kind":"italic_en","text":"Anything with which a thing is rendered cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cooled."},{"kind":"text","text":"(S, M.) ―         -b6-"},{"kind":"italic_en","text":"A collyrium which cools the eye;"},{"kind":"text","text":"(Lth, T, M, Msb;) also termed"},{"kind":"arabic","text_bw":"baruwdu","text_ar":"بَرُودُ"},{"kind":"arabic","text_bw":"AlEayoni","text_ar":"العَيْنِ"},{"kind":"text","text":". (T, S.) ―         -b7-"},{"kind":"arabic","text_bw":"baruwdu AlZ~il~i","text_ar":"بَرُودُ الظِّلِّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Pleasant in social intercourse:"},{"kind":"text","text":"applied alike to the male and the female. (TA, from a trad.) ―         -b8-"},{"kind":"arabic","text_bw":"vawobN baruwdN","text_ar":"ثَوْبٌ بَرُودٌ"},{"kind":"italic_en","text":"A garment without nap:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"a garment that is not warm nor soft."},{"kind":"text","text":"(TA.)"}],"source_refs":["T","L","K","M","A"]}]},"classical_definitions":null}