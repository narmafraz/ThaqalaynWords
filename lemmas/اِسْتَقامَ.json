1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْتَقِيم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":23,"cross_references":{"qac":{"found":true,"lemma_key":"اِسْتَقامَ","root":"قوم","pos":"V","occurrence_count":10},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n42891"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%82%D8%A7%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to rise, to stand up","tags":["intransitive"]},{"pos":"verb","gloss":"to straighten up, to become erect","tags":["intransitive"]},{"pos":"verb","gloss":"to be or become straight","tags":["intransitive"]},{"pos":"verb","gloss":"to stretch ahead (of a road)","tags":["intransitive"]},{"pos":"verb","gloss":"to be honest, to be sincere","tags":["intransitive"]},{"pos":"verb","gloss":"to be right, to be proper","tags":["intransitive"]},{"pos":"verb","gloss":"to improve (of conditions)","tags":["intransitive"]},{"pos":"verb","gloss":"to persist","tags":["intransitive"]},{"pos":"verb","gloss":"to fix the price of (a good, a product)","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Compare قَامَ (qāma, “to rise”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42891","headword_ar":"اِسْتَقَامَ","root":"qwm","body":[{"kind":"italic_en","text":"It became right; direct; in a right state; straight: even: tended towards the right, or desired, point, or object; had a right direction, or tendency; was regular."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"AisotaqaAma EalaY Tariyqi","text_ar":"اِسْتَقَامَ عَلَى طَرِيقِ"},{"kind":"arabic","text_bw":"AlHaq~i","text_ar":"الحَقِّ"},{"kind":"text","text":"(K, art."},{"kind":"arabic","text_bw":"r$d","text_ar":"رشد"},{"kind":"text","text":")"},{"kind":"italic_en","text":"He continued in the way of truth, or the right way;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"―         -b3-"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"text","text":"? ―         -b4-"},{"kind":"arabic","text_bw":"lamo yasotaqimi AlA^amoru","text_ar":"لَمْ يَسْتَقِمِ الاَمْرُ"},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"taEa*~ara","text_ar":"تَعَذَّرَ"},{"kind":"text","text":". ―         -b5-"},{"kind":"arabic","text_bw":"AstqAm lahu AlA^amoru","text_ar":"استقام لَهُ الاَمْرُ"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became in a right state for him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AiEotadala","text_ar":"اِعْتَدَلَ"},{"kind":"text","text":". (S.) ―         -b6-"},{"kind":"arabic","text_bw":"AisotaqaAma","text_ar":"اِسْتَقَامَ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, right, direct, rightly directed, undeviating, straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"even:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, stood right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erect."},{"kind":"text","text":"(MA, KL.)"},{"kind":"italic_en","text":"He went right on, straight on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"undeviatingly:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"zaEaba","text_ar":"زَعَبَ"},{"kind":"text","text":":) whence"},{"kind":"arabic","text_bw":"AisotaqaAma EalaY AlT~ariyqapi","text_ar":"اِسْتَقَامَ عَلَى الطَّرِيقَةِ"},{"kind":"italic_en","text":"he went on undeviatingly in the way."},{"kind":"text","text":"(See Kur lxxii. 16.)"},{"kind":"italic_en","text":"He went right; pursued a right course; acted rightly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"justly."},{"kind":"text","text":"See also"},{"kind":"arabic","text_bw":"sad~a","text_ar":"سَدَّ"},{"kind":"text","text":", with which it is syn."},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an affair)"},{"kind":"italic_en","text":"was direct in its tendency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a right tendency. It"},{"kind":"text","text":"(discourse, &c.)"},{"kind":"italic_en","text":"had a right tenour."},{"kind":"text","text":"―         -b7-  See 2."}],"source_refs":[]}]},"classical_definitions":null}