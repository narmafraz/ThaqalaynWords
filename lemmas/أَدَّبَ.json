","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤَدِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَدِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَدَّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَدَّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤَدِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَدِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَدَّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَدَّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤَدِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُؤَدَّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَدَّبْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَدَّبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَدِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَدِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَدَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَدَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":31,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n420","","n422","n423","n424","n11973"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"host"}]},"etymology":null,"ipa":["/ʔaː.dib/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n420","headword_ar":"اَدَبَ","root":"Adb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^idobN","text_ar":"اِدْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He invited"},{"kind":"text","text":"(people, S, or a man, K)"},{"kind":"italic_en","text":"to his repast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"banquet;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"A=daba","text_ar":"ا=دَبَ","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"A=daba A_ilaY TaEaAmihi","text_ar":"ا=دَبَ اـِلَى طَعَامِهِ"},{"kind":"text","text":"aor"},{"kind":"arabic","text_bw":"yuwdibu","text_ar":"يُودِبُ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"yuw^odibu","text_ar":"يُوْدِبُ"},{"kind":"text","text":"], (AZ, S,) inf. n."},{"kind":"arabic","text_bw":"A_iydaAbN","text_ar":"اـِيدَابٌ"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"A_iy^odaAbN","text_ar":"اـِيْدَابٌ"},{"kind":"text","text":"]. (AZ, S, K.) You say,"},{"kind":"arabic","text_bw":"A^adaba Alqawoma","text_ar":"اَدَبَ القَوْمَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"A^adaba EalaY Alqawomi","text_ar":"اَدَبَ عَلَى القَوْمِ"},{"kind":"text","text":", aor. as above, (T,)"},{"kind":"italic_en","text":"He invited the people to his repast."},{"kind":"text","text":"(T, S.) And"},{"kind":"arabic","text_bw":"A^adabahumo EalaY","text_ar":"اَدَبَهُمْ عَلَى"},{"kind":"arabic","text_bw":"AlA^amri","text_ar":"الاَمرِ"},{"kind":"italic_en","text":"He collected them together for the affair."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"jiyraAnaka litu$aAwirahumo","text_ar":"جِيرَانَكَ لِتُشَاوِرَهُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^uwdibu","text_ar":"اُودِبُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will collect thy neighbours in order that thou mayest consult with them"},{"kind":"text","text":"]. (A.) The primary signification of"},{"kind":"arabic","text_bw":"A^adobN","text_ar":"اَدْبٌ"},{"kind":"text","text":"is The act of"},{"kind":"italic_en","text":"inviting."},{"kind":"text","text":"(T.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb, K;) or"},{"kind":"arabic","text_bw":"A^adiba","text_ar":"اَدِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (so in a copy of the M;) inf. n."},{"kind":"arabic","text_bw":"A^adobN","text_ar":"اَدْبٌ"},{"kind":"text","text":", (M, Mgh, Msb,) or"},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He made a repast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"banquet,"},{"kind":"text","text":"(M, Msb, K,)"},{"kind":"italic_en","text":"and invited people to it;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"A=daba","text_ar":"ا=دَبَ","orth_type":"arrow"},{"kind":"text","text":", (M,) aor. and inf. n. as above: (TA:) or"},{"kind":"italic_en","text":"he collected and invited people to his repast."},{"kind":"text","text":"(Mgh.) ―         -b3-  [Hence also, as will be seen below, voce"},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^adabahu","text_ar":"اَدَبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^adobN","text_ar":"اَدْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He taught him the discipline of the mind, and the acquisition of good qualities and attributes of the mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul;"},{"kind":"text","text":"(Msb;) and ↓"},{"kind":"arabic","text_bw":"A^d~bhu","text_ar":"ادّبهُ","orth_type":"arrow"},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"taA^odiybN","text_ar":"تَاْدِيبٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"the same;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he taught him what is termed"},{"kind":"arabic","text_bw":"A^adab","text_ar":"اَدَب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"good discipline of the mind and manners,"},{"kind":"text","text":"&c.; i. e."},{"kind":"italic_en","text":"he disciplined him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"educated him, well; rendered him well-bred, wellmannered, polite; instructed him in polite accomplishments;"},{"kind":"text","text":"&c.]: (S, M, A, Mgh, K:) or the latter verb, inf. n."},{"kind":"arabic","text_bw":"taA^odiybu","text_ar":"تَاْدِيبُ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he taught him well,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much, the discipline of the mind, and the acquisition of good qualities and attributes of the mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul:"},{"kind":"text","text":"and hence, this latter also signifies"},{"kind":"italic_en","text":"he disciplined him, chastised him, corrected him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punished him, for his evil conduct;"},{"kind":"text","text":"because discipline, or chastisement, is a means of inviting a person to what is properly termed"},{"kind":"arabic","text_bw":"AlA^adabu","text_ar":"الاَدَبُ"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"A^aduba","text_ar":"اَدُبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (AZ, T, S, M, K,) inf. n."},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He was"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, characterized by what is termed"},{"kind":"arabic","text_bw":"A^adab","text_ar":"اَدَب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"good discipline of the mind and manners,"},{"kind":"text","text":"&c.; i. e.,"},{"kind":"italic_en","text":"well disciplined, well-educated, well-bred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"well-mannered, polite, instructed in polite accomplishments,"},{"kind":"text","text":"&c.]. (AZ, T, S, M, K.)"}],"source_refs":["K","AZ","S","T","M","Mgh","Msb","TA","A"]},{"entry_id":"n422","headword_ar":"اَدْبٌ","root":"Adb","body":[{"kind":"text","text":", (S, M, K,) or, accord. to some, ↓"},{"kind":"arabic","text_bw":"A_idobN","text_ar":"اـِدْبٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"Wonderful;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a wonderful thing;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"; (S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^udobapN","text_ar":"اُدْبَةٌ","orth_type":"arrow"},{"kind":"text","text":"[used in the latter sense]. (K.) You say, ↓"},{"kind":"arabic","text_bw":"jaA='a fulaAnN biA^amorK A_idobK","text_ar":"جَا=ءَ فُلَانٌ بِاَمْرٍ اـِدْبٍ","orth_type":"arrow"},{"kind":"italic_en","text":"Such a one did a wonderful thing."},{"kind":"text","text":"(As, T. *)       -A2-  See also"},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":", last sentence."}],"source_refs":["S","M","K","TA"]},{"entry_id":"n423","headword_ar":"اـِدْبٌ","root":"Adb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adabN","text_ar":"اَدَبٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n424","headword_ar":"اَدَبٌ","root":"Adb","body":[{"kind":"text","text":", so termed because it invites men to the acquisition of praiseworthy qualities and dispositions, and forbids them from acquiring such as are evil, (T, Mgh,) signifies"},{"kind":"italic_en","text":"Discipline of the mind;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"good qualities and attributes of the mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"every praiseworthy discipline by which a man is trained in any excellence:"},{"kind":"text","text":"(AZ, Mgh, Msb:) ["},{"kind":"italic_en","text":"good discipline of the mind and manners; good education; good breeding; good manners; politeness; polite accomplishments:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"ZarofN","text_ar":"ظَرْفٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"excellence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elegance, of mind, manners, address, and speech"},{"kind":"text","text":"]: and"},{"kind":"italic_en","text":"a good manner of taking"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receiving"},{"kind":"text","text":"[what is given or offered or imparted, or what is to be acquired]: (M, A, K:) or"},{"kind":"italic_en","text":"good qualities and attributes of the mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"doing of generous"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honourable actions:"},{"kind":"text","text":"(El-Jawáleekee:) or the"},{"kind":"italic_en","text":"practice of what is praiseworthy both in words and actions:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"holding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping, to those things which are approved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deemed good:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"honouring of those who are above one, and being gentle, courteous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"civil, to those who are below one:"},{"kind":"text","text":"(Towsheeh:) or"},{"kind":"italic_en","text":"a faculty which preserves him in whom it exists from what would disgrace him:"},{"kind":"text","text":"(MF:) it is of two kinds,"},{"kind":"arabic","text_bw":"A^adabu","text_ar":"اَدَبُ"},{"kind":"arabic","text_bw":"Aln~afosi","text_ar":"النَّفْسِ"},{"kind":"text","text":"[which embraces all the significations explained above], and"},{"kind":"arabic","text_bw":"A^adabu Ald~arosi","text_ar":"اَدَبُ الدَّرْسِ"},{"kind":"text","text":"[which signifies"},{"kind":"italic_en","text":"the discipline to be observed in the prosecution of study, by the disciple with respect to the preceptor, and by the preceptor with respect to the disciple:"},{"kind":"text","text":"see ‘Haji Khalfæ Lexicon,’ Vol. I. p. 212]: (S, Btl, Mgh:) [also"},{"kind":"italic_en","text":"deportment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a mode of conduct"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaviour,"},{"kind":"text","text":"absolutely; for one speaks of good"},{"kind":"arabic","text_bw":"A^adab","text_ar":"اَدَب"},{"kind":"text","text":"and bad"},{"kind":"arabic","text_bw":"A^adab","text_ar":"اَدَب"},{"kind":"text","text":":] the pl. is"},{"kind":"arabic","text_bw":"A=daAbN","text_ar":"ا=دَابٌ"},{"kind":"text","text":"[which is often employed, and so is the sing. also, as signifying the"},{"kind":"italic_en","text":"rules of discipline to be observed in the exercise of a function,"},{"kind":"text","text":"such as that of a judge, and of a governor; and"},{"kind":"italic_en","text":"in the exercise of an art,"},{"kind":"text","text":"such as that of the disputer, and the orator, and the poet, and the scribe; &c.]. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"Eilomu AlA^adabi","text_ar":"عِلْمُ الاَدَبِ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"The science of philology;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the science by which one guards against error in the language of the Arabs, with respect to words and with respect to writing;"},{"kind":"text","text":"(‘Haji Khalfæ Lexicon,’ Vol. I. p. 215;) [and so, simply,"},{"kind":"arabic","text_bw":"AlA^adabu","text_ar":"الاَدَبُ"},{"kind":"text","text":": which is also used to signify"},{"kind":"italic_en","text":"polite literature:"},{"kind":"text","text":"but in this sense, and like wise] as applied to"},{"kind":"italic_en","text":"the sciences relating to the Arabic language,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the philological sciences,"},{"kind":"text","text":"which are also termed ↓"},{"kind":"arabic","text_bw":"AlEuluwmu AlA^adabiy~aAtu","text_ar":"العُلُومُ الاَدَبِيَّاتُ","orth_type":"arrow"},{"kind":"text","text":",]"},{"kind":"arabic","text_bw":"AlA^adabu","text_ar":"الاَدَبُ"},{"kind":"text","text":"is a post-classical term, innovated in the time of El-Islám. (El-Jawá- leekee.)       -A2-"},{"kind":"arabic","text_bw":"A^adabu AlbaHori","text_ar":"اَدَبُ البَحْرِ"},{"kind":"text","text":", (A, K,) or"},{"kind":"arabic","text_bw":"AlbaHori","text_ar":"البَحْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^adobu","text_ar":"اَدْبُ","orth_type":"arrow"},{"kind":"text","text":", (T, L,) (tropical:)"},{"kind":"italic_en","text":"The abundance of the water of the sea."},{"kind":"text","text":"(T, A, L, K.)"}],"source_refs":["T","Mgh","Msb","AZ","M","A","K","MF","S","Btl","L"]},{"entry_id":"n11973","headword_ar":"اَدَبٌّ","root":"db","body":[{"kind":"italic_en","text":"Having down"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"upon the face:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"having much hair:"},{"kind":"text","text":"(M, K:) and"},{"kind":"italic_en","text":"having much"},{"kind":"arabic","text_bw":"wabar","text_ar":"وَبَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fur"},{"kind":"text","text":"]: (M:) it is applied to a man: (M:) and to a camel, (M, K,) in the second of these senses, (K, TA,) or in the third sense, or as meaning"},{"kind":"italic_en","text":"having much fur upon the face;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^azab~u","text_ar":"اَزَبُّ"},{"kind":"text","text":": (M:) and occurs in a trad. written"},{"kind":"arabic","text_bw":"A^adobab","text_ar":"اَدْبَب"},{"kind":"text","text":", (M, K,) to assimilate it in measure to a preceding word, namely,"},{"kind":"arabic","text_bw":"Hawo'ab","text_ar":"حَوْءَب"},{"kind":"text","text":": (M:) the fem. is"},{"kind":"arabic","text_bw":"dab~aA='u","text_ar":"دَبَّا=ءُ"},{"kind":"text","text":"; with which ↓"},{"kind":"arabic","text_bw":"dabibapN","text_ar":"دَبِبَةٌ","orth_type":"arrow"},{"kind":"text","text":"is syn.; (M, K;) signifying a woman"},{"kind":"italic_en","text":"having hair upon her face:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"having much hair upon the"},{"kind":"arabic","text_bw":"jabiyn","text_ar":"جَبِين"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"part above the temple"},{"kind":"text","text":"]. (M, TA.)"}],"source_refs":["K","TA","M"]}]}}