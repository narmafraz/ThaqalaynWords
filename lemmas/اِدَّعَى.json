"p"},{"role":"present_1ms","form":"أَدَّع","in_corpus":true,"count":49,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدَّعِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدَّعِي","in_corpus":true,"count":48,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدَّعَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدَّعَى","in_corpus":true,"count":48,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"اِدَّعَيْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِدَّعَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":479,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n12617"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AF%D9%8E%D9%91%D8%B9%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12617","headword_ar":"اِدَّعَى","root":"dEw","body":[{"kind":"italic_en","text":"He asserted"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to be his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to belong to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to be due to him,"},{"kind":"text","text":"either truly or falsely: (K, * TA:)"},{"kind":"italic_en","text":"he claimed"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"laid claim to"},{"kind":"text","text":"it; or"},{"kind":"italic_en","text":"demanded"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"for himself:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he desired"},{"kind":"text","text":"a thing; or"},{"kind":"italic_en","text":"wished for"},{"kind":"text","text":"it. (Msb.) And"},{"kind":"arabic","text_bw":"Aid~aEawuA Al$~aYo'a","text_ar":"اِدَّعَوُا الشَّىْءَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Al$Y'","text_ar":"الشىء"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tadaAEawuA","text_ar":"تَدَاعَوُا","orth_type":"arrow"},{"kind":"text","text":"signify the same [i. e."},{"kind":"italic_en","text":"They claimed the thing, every one of them for himself"},{"kind":"text","text":"]. (Mgh.) You say,"},{"kind":"arabic","text_bw":"Aid~aEayotu EalaY fulaAnK","text_ar":"اِدَّعَيْتُ عَلَى فُلَانٍ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I asserted myself to have a claim upon such a one for such a thing; preferred a claim against such a one for such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claimed of such a one such a thing"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"Aid~aEaY zayodN","text_ar":"اِدَّعَى زَيْدٌ"},{"kind":"arabic","text_bw":"EalaY Eamorw maAlFA","text_ar":"عَلَى عَمْرو مَالًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Zeyd asserted himself to have a claim upon 'Amr for property;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preferred a claim against 'Amr"},{"kind":"text","text":"&c.]. (Mgh.) And"},{"kind":"arabic","text_bw":"Aid~aEayota","text_ar":"اِدَّعَيْتَ"},{"kind":"arabic","text_bw":"EalaY~a maA lamo A^afoEalo","text_ar":"عَلَىَّ مَا لَمْ اَفْعَلْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou hast asserted against me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charged against me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accused me of, that which I have not done"},{"kind":"text","text":"]. (S and K in art."},{"kind":"arabic","text_bw":"$rb","text_ar":"شرب"},{"kind":"text","text":", and S in art."},{"kind":"arabic","text_bw":"Akl","text_ar":"اكل"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"h`*aA A@l~a*iY kunotumo bihi tad~aEuwna","text_ar":"هٰذَا ا@لَّذِى كُنْتُمْ بِهِ تَدَّعُونَ"},{"kind":"text","text":", in the Kur [lxvii. 27], means"},{"kind":"italic_en","text":"This is that on account of which ye used to assert vain and false things:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"which ye used to deny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disbelieve:"},{"kind":"text","text":"or, accord. to Fr, the latter verb may here be used in the sense of"},{"kind":"arabic","text_bw":"tadoEuwna","text_ar":"تَدْعُونَ"},{"kind":"text","text":"; and the meaning may be,"},{"kind":"italic_en","text":"this is that which ye desired to hasten, and for which ye prayed"},{"kind":"text","text":"to God in the words of the Kur [viii. 32], “ O God, if this be the truth from Thee, then rain Thou upon us stones from Heaven, or bring upon us some [other] painful punishment: ” it may be from"},{"kind":"arabic","text_bw":"Ald~uEaA='u","text_ar":"الدُّعَا=ءُ"},{"kind":"text","text":": and it may be from"},{"kind":"arabic","text_bw":"Ald~aEowaY","text_ar":"الدَّعْوَى"},{"kind":"text","text":": (TA:) [i. e.] it means"},{"kind":"italic_en","text":"this is that which ye used to demand, and desire to hasten;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Ald~uEaA='u","text_ar":"الدُّعَا=ءُ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"that which ye used to assert,"},{"kind":"text","text":"[namely,] that there will be no raising to life; from"},{"kind":"arabic","text_bw":"Ald~aEowaY","text_ar":"الدَّعْوَى"},{"kind":"text","text":". (Bd.) And"},{"kind":"arabic","text_bw":"walahumo maA yad~aEuwna","text_ar":"وَلَهُمْ مَا يَدَّعُونَ"},{"kind":"text","text":", in the Kur [xxxvi. 57], is explained as meaning"},{"kind":"italic_en","text":"And they shall have what they desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wish for;"},{"kind":"text","text":"which is referrible to the meaning of"},{"kind":"arabic","text_bw":"Ald~uEaA='u","text_ar":"الدُّعَا=ءُ"},{"kind":"text","text":". (TA.) ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"Aid~aEaY gayora A^abiyhi","text_ar":"اِدَّعَى غَيْرَ اَبِيهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He asserted the relationship of father to him of one who was not his father;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claimed as his father one who was not his father"},{"kind":"text","text":"]. (T, Mgh, Msb.) And"},{"kind":"arabic","text_bw":"yad~aEiY A_ilaY gayori A^abiyhi","text_ar":"يَدَّعِى اـِلَى غَيْرِ اَبِيهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He asserts his relationship as a son,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claims the relationship of a son, to one who is not his father"},{"kind":"text","text":"]. (T, Msb. See 4, in three places.) And"},{"kind":"arabic","text_bw":"yad~aEiyhi gayoru A^abiyhi","text_ar":"يَدَّعِيهِ غَيْرُ اَبِيهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"One who is not his father asserts him to be his son;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claims him as his son"},{"kind":"text","text":"]. (T, Msb.)"},{"kind":"arabic","text_bw":"AlAid~iEaA='u","text_ar":"الاِدِّعَا=ءُ"},{"kind":"text","text":"in war signifies"},{"kind":"italic_en","text":"The asserting one's relationship;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AlAiEotizaA='u","text_ar":"الاِعْتِزَا=ءُ"},{"kind":"text","text":"; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"Alt~adaAEiY","text_ar":"التَّدَاعِى","orth_type":"arrow"},{"kind":"text","text":"; (TA;) i. e. the saying “ I am such a one the son of such a one. ” (S.) And [hence] sometimes it includes the meaning of"},{"kind":"italic_en","text":"Informing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"telling;"},{"kind":"text","text":"and therefore"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"may be prefixed to its objective complement; so that one says,"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"yad~aEiY bikarami fiEaAlihi","text_ar":"يَدَّعِى بِكَرَمِ فِعَالِهِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Such a one informs of the generosity of his deeds."},{"kind":"text","text":"(Msb.)"}],"source_refs":["TA"]}]},"classical_definitions":null}