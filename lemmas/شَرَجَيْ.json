{"lemma":"شَرَجَيْ","slug":"شَرَجَيْ","root":"ش.ر.ج","root_slug":"ش-ر-ج","root_link":"/words/roots/ش-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n22059","n22060","n22064","n22065"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%8E%D8%AC%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to interweave, to put together, to compact"},{"pos":"verb","gloss":"to cause to be intermixed"},{"pos":"verb","gloss":"to weave around, to circumligate"},{"pos":"noun","gloss":"verbal noun of شَرَجَ (šaraja) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"place where water flows from a stony tract to a plain"},{"pos":"noun","gloss":"party of men, squad, consortium"},{"pos":"noun","gloss":"sort, species, group"},{"pos":"noun","gloss":"fissure"},{"pos":"noun","gloss":"perineum"},{"pos":"noun","gloss":"loop; ring, eyelet; buttonhole"},{"pos":"noun","gloss":"anus"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22059","headword_ar":"شَرَجَ","root":"$rj","body":[{"kind":"text","text":": see 4. ―         -b2-  Also, (S, A, O, TA,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"$arojN","text_ar":"شَرْجٌ"},{"kind":"text","text":", (S, O, K, TA,)"},{"kind":"italic_en","text":"He put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"set, together"},{"kind":"text","text":"bricks ("},{"kind":"arabic","text_bw":"labin","text_ar":"لَبِن"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"in order, side by side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one upon another, compactly;"},{"kind":"text","text":"(S, A, O, K, TA;) and (O) so ↓"},{"kind":"arabic","text_bw":"$r~j","text_ar":"شرّج","orth_type":"arrow"},{"kind":"text","text":", (O, Mgh, Msb,) with teshdeed, (Msb,) inf. n."},{"kind":"arabic","text_bw":"ta$oriyjN","text_ar":"تَشْرِيجٌ"},{"kind":"text","text":". (O, Mgh.) ―         -b3-  And"},{"kind":"italic_en","text":"He collected together,"},{"kind":"text","text":"(O, K,) or"},{"kind":"italic_en","text":"put together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joined,"},{"kind":"text","text":"(L,) any thing or things,"},{"kind":"italic_en","text":"one part to another,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one thing to another;"},{"kind":"text","text":"(O, L;) as also ↓"},{"kind":"arabic","text_bw":"$r~j","text_ar":"شرّج","orth_type":"arrow"},{"kind":"text","text":". (L.) ―         -b4-  [And app."},{"kind":"italic_en","text":"He wove"},{"kind":"text","text":"palm-leaves: see"},{"kind":"arabic","text_bw":"$riyjapN","text_ar":"شرِيجَةٌ"},{"kind":"text","text":", below; and see also"},{"kind":"arabic","text_bw":"$ariyTN","text_ar":"شَرِيطٌ"},{"kind":"text","text":".] ―         -b5-  And"},{"kind":"italic_en","text":"He mixed"},{"kind":"text","text":"(A, O, K) beverage, or wine: and in like manner ↓"},{"kind":"arabic","text_bw":"$r~j","text_ar":"شرّج","orth_type":"arrow"},{"kind":"italic_en","text":"he mixed"},{"kind":"text","text":"honey &c. with water. (O.) ―         -b6-  And"},{"kind":"arabic","text_bw":"$arajahu fiY AlA^amori","text_ar":"شَرَجَهُ فِى الاَمْرِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TK,) inf. n. as above, (K, TK,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, a partner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharer,"},{"kind":"text","text":"(K, TK,)"},{"kind":"italic_en","text":"with him in the affair."},{"kind":"text","text":"(TK.)       -A2-  Also, (O,) inf. n. as above, (K,)"},{"kind":"italic_en","text":"He lied;"},{"kind":"text","text":"(O, K;) like"},{"kind":"arabic","text_bw":"saraja","text_ar":"سَرَجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sadaja","text_ar":"سَدَجَ"},{"kind":"text","text":". (O.)       -A3-"},{"kind":"arabic","text_bw":"$arija","text_ar":"شَرِجَ"},{"kind":"text","text":", (O, TA,) with kesr to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautifully fat."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["S","A","O","TA","K","Mgh","Msb","L","TK"]},{"entry_id":"n22060","headword_ar":"شرّج","root":"$rj","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ta$oriyjN","text_ar":"تَشْرِيجٌ"},{"kind":"text","text":": see above, in three places. ―         -b2-  Also, said of pasture, or herbage,"},{"kind":"italic_en","text":"It caused"},{"kind":"text","text":"the flesh of an animal"},{"kind":"italic_en","text":"to be intermixed with fat."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"$ur~ija","text_ar":"شُرِّجَ"},{"kind":"text","text":", said of the flesh of an animal,"},{"kind":"italic_en","text":"It was intermixed with fat:"},{"kind":"text","text":"(S, O:) or"},{"kind":"italic_en","text":"was made to be of two colours by reason of the fat and the flesh:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"biAl$~aHomi","text_ar":"بِالشَّحْمِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"t$r~j","text_ar":"تشرّج","orth_type":"arrow"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the flesh)"},{"kind":"italic_en","text":"became intermixed with fat."},{"kind":"text","text":"(S, O, K.)       -A2-  And"},{"kind":"arabic","text_bw":"ta$oriyjN","text_ar":"تَشْرِيجٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"sewing with stitches far apart."},{"kind":"text","text":"(S, O, K) ―         -b2-  See also 4."}],"source_refs":["S","O","TA","K"]},{"entry_id":"n22064","headword_ar":"شَرْجٌ","root":"$rj","body":[{"kind":"italic_en","text":"A place in which water flows from a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"stony tract such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Har~ap","text_ar":"حَرَّة"},{"kind":"italic_en","text":"to a soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain, tract;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"$arojapN","text_ar":"شَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or the latter signifies [simply]"},{"kind":"italic_en","text":"a place in which water flows;"},{"kind":"text","text":"and some elide the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", saying"},{"kind":"arabic","text_bw":"$arojN","text_ar":"شَرْجٌ"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"$iraAjN","text_ar":"شِرَاجٌ"},{"kind":"text","text":"(S, Mgh, Msb, K, expl. in the Mgh agreeably with the former explanation above, and said in the Msb to be pl. of"},{"kind":"arabic","text_bw":"$arojapN","text_ar":"شَرْجَةٌ"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"$uruwjN","text_ar":"شُرُوجٌ"},{"kind":"text","text":". (S, K.)       -A2-  Also"},{"kind":"italic_en","text":"A party,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct body"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"class"},{"kind":"text","text":"[of men]. (S, K.) One says,"},{"kind":"arabic","text_bw":"A^aSobaHuwA fiY","text_ar":"اَصْبَحُوا فِى"},{"kind":"arabic","text_bw":"h`*aA AlA^amori $arojayoni","text_ar":"هٰذَا الاَمْرِ شَرْجَيْنِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"They became, in this affair,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"two parties."},{"kind":"text","text":"(S.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A^aSobaHa Aln~aAsu $arojayoni fiY Als~afari","text_ar":"اَصْبَحَ النَّاسُ شَرْجَيْنِ فِى السَّفَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"men, became two parties in the journey"},{"kind":"text","text":"]; meaning, half of them fasting, and half of them breaking the fast. (TA.) ―         -b2-  And The"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"of another; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"$ariyjN","text_ar":"شَرِيجٌ","orth_type":"arrow"},{"kind":"text","text":": (O, K:) the latter from the same word as meaning “ a piece of wood [or a branch] that is split into two halves; ” each of which is the"},{"kind":"arabic","text_bw":"$ryj","text_ar":"شريج"},{"kind":"text","text":"of the other. (O.) One says,"},{"kind":"arabic","text_bw":"h`*aA $aroju h`*aA","text_ar":"هٰذَا شَرْجُ هٰذَا"},{"kind":"italic_en","text":"This is the like of this."},{"kind":"text","text":"(S.) ―         -b3-  And"},{"kind":"italic_en","text":"A sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species."},{"kind":"text","text":"(S, K.) One says,"},{"kind":"arabic","text_bw":"humaA $arojN waAHidN","text_ar":"هُمَا شَرْجٌ وَاحِدٌ"},{"kind":"italic_en","text":"They two are one sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species."},{"kind":"text","text":"(S.) ―         -b4-  And"},{"kind":"arabic","text_bw":"$arojaAni","text_ar":"شَرْجَانِ"},{"kind":"text","text":"Any"},{"kind":"italic_en","text":"two different colours:"},{"kind":"text","text":"(S:) [and] ↓"},{"kind":"arabic","text_bw":"$ariyjaAni","text_ar":"شَرِيجَانِ","orth_type":"arrow"},{"kind":"text","text":"signifies [the same, i. e.]"},{"kind":"italic_en","text":"two different colours"},{"kind":"text","text":"(K, TA) of anything; or, accord. to IAar,"},{"kind":"italic_en","text":"two mixed colours, not black and white:"},{"kind":"text","text":"(TA:) and ↓ this latter, also, the"},{"kind":"italic_en","text":"two lines of the"},{"kind":"arabic","text_bw":"nayraAni","text_ar":"نَيرَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"two ornamental borders"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"burod","text_ar":"بُرْد"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"one of which is"},{"kind":"arabic","text_bw":"A^axoDar","text_ar":"اَخْضَر"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"of a dark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ashy, dust-colour"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and the other white"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"red."},{"kind":"text","text":"(O.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Al$~aroju","text_ar":"الشَّرْجُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"falos","text_ar":"فَلْس"},{"kind":"text","text":"[in measure, not to be confounded with"},{"kind":"arabic","text_bw":"Al$~araju","text_ar":"الشَّرَجُ"},{"kind":"text","text":"], signifies The ["},{"kind":"italic_en","text":"perinæum,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"part between the anus and the testicles."},{"kind":"text","text":"(IKtt, TA.)"}],"source_refs":["TA","Msb","O","K","S"]},{"entry_id":"n22065","headword_ar":"شَرَجٌ","root":"$rj","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"loops"},{"kind":"text","text":"(S, Mgh, O, Msb, K) of the [leathern receptacle called]"},{"kind":"arabic","text_bw":"Eayobap","text_ar":"عَيْبَة"},{"kind":"text","text":", (S, Mgh, O, Msb,) and of the [tent called]"},{"kind":"arabic","text_bw":"xayomap","text_ar":"خَيْمَة"},{"kind":"text","text":", (O, TA,) and the like, and of the"},{"kind":"arabic","text_bw":"muSoHaf","text_ar":"مُصْحَف"},{"kind":"text","text":"[or copy of the Kur-án, &c.]: (TA:) [the loops here meant being such as are inserted one into another, to close a bag &c.: see 4:] pl."},{"kind":"arabic","text_bw":"A^a$oraAjN","text_ar":"اَشْرَاجٌ"},{"kind":"text","text":". (S, Msb.) [And it seems also, from what here follows, to signify"},{"kind":"italic_en","text":"A single loop."},{"kind":"text","text":"] ―         -b2-  (assumed tropical:)  The"},{"kind":"italic_en","text":"anus:"},{"kind":"text","text":"(Msb, TA:) or hence"},{"kind":"arabic","text_bw":"$araju Ald~uburi","text_ar":"شَرَجُ الدُّبُرِ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"the anus."},{"kind":"text","text":"(Mgh.) ―         -b3-  And (assumed tropical:)  The"},{"kind":"italic_en","text":"vulva"},{"kind":"text","text":"of a woman: (O, K:) pl. as above. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"$araju Ald~araAhimi","text_ar":"شَرَجُ الدَّرَاهِمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The purse for money"},{"kind":"text","text":"]. (M and K in art."},{"kind":"arabic","text_bw":"Sr","text_ar":"صر"},{"kind":"text","text":": in the CK,"},{"kind":"arabic","text_bw":"$aroj","text_ar":"شَرْج"},{"kind":"text","text":".)       -A2-  Also"},{"kind":"italic_en","text":"A place of expanding"},{"kind":"text","text":"of a valley: (S, O, K:) pl. as above. (S.) ―         -b2-  And"},{"kind":"italic_en","text":"The Milky Way in the sky:"},{"kind":"text","text":"(S:) or so"},{"kind":"arabic","text_bw":"Al$~araju","text_ar":"الشَّرَجُ"},{"kind":"text","text":". (K.)       -A3-  Also"},{"kind":"italic_en","text":"A splitting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cracking,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Aino$iqaAqN","text_ar":"اِنْشِقَاقٌ"},{"kind":"text","text":", S, and so in some copies of the K, or"},{"kind":"arabic","text_bw":"$uqaAqN","text_ar":"شُقَاقٌ"},{"kind":"text","text":", so in other copies of the K and in the O,)"},{"kind":"italic_en","text":"in a bow."},{"kind":"text","text":"(S, O, K.) ―         -b2-  And in a beast, The"},{"kind":"italic_en","text":"having one of the two testicles larger than the other."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["S","Mgh","O","Msb","K","TA"]}]}}