},{"role":"present_2mp","form":"تَخْبُثُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْبُثْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْبُث","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْبُث","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْبُثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْبُثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْبُثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْبُثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْبُثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْبُثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْبُثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"خَبُثْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَبُثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَخْبُث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْبُث","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":true,"lemma_key":"خَبُثَ","root":"خبث","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n9864"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%A8%D9%8F%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become bad or evil, to commit evil act"}]},"etymology":null,"ipa":["/xa.bu.θa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9864","headword_ar":"خَبُثَ","root":"xbv","body":[{"kind":"text","text":", (S, Mgh, Msb, K, &c.,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xabaAvapN","text_ar":"خَبَاثَةٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", the former being a simple subst., (Msb,) or both, (Mgh, K, [the latter word erroneously written in the CK"},{"kind":"arabic","text_bw":"xabov","text_ar":"خَبْث"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"xabaAviyapN","text_ar":"خَبَاثِيَةٌ"},{"kind":"text","text":", (K,) said of a thing, (S, Mgh, Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xabiyv","text_ar":"خَبِيث"},{"kind":"text","text":"[q. v., meaning"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"&c.];"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"TaAba","text_ar":"طَابَ"},{"kind":"text","text":". (S, Mgh, Msb, K.) [Hence,]"},{"kind":"arabic","text_bw":"xabuvato raAy^iHatuhu","text_ar":"خَبُثَتْ رَايِحَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Its,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his, odour was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"xabuva TaEomuhu","text_ar":"خَبُثَ طَعْمُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Its taste was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, foul, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nauseous"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"xabuvato nafosuhu","text_ar":"خَبُثَتْ نَفْسُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His soul"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stomach"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became heavy;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"it heaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became agitated by a tendency to vomit;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gavato","text_ar":"غَثَتْ"},{"kind":"text","text":": (A and TA in the present art., and S and K in art."},{"kind":"arabic","text_bw":"gvY","text_ar":"غثى"},{"kind":"text","text":": [see also"},{"kind":"arabic","text_bw":"ma*irato nafosuhu","text_ar":"مَذِرَتْ نَفْسُهُ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"m*r","text_ar":"مذر"},{"kind":"text","text":":]) a phrase forbidden by Mohammad to be used; as though he disliked the word"},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":". (TA.) One says of certain food,"},{"kind":"arabic","text_bw":"taxobuvu Eanohu Aln~afosu","text_ar":"تَخْبُثُ عَنْهُ النَّفْسُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stomach, becomes heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heaves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becomes agitated by a tendency to vomit, in consequence of it"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":", (S, A, K,) inf. n."},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", (S, K,) said of a man, signifies [in like manner]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xabiyv","text_ar":"خَبِيث"},{"kind":"text","text":", (S, A, K,) meaning"},{"kind":"italic_en","text":"bad, corrupt, base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable; wicked, deceitful, guileful, artful, crafty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning."},{"kind":"text","text":"(S, K, TA. [See also 4.]) [Hence,]"},{"kind":"arabic","text_bw":"xabuva bihaA","text_ar":"خَبُثَ بِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He committed adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication, with her."},{"kind":"text","text":"(A, Mgh, Msb, K.) ―         -b3-  [It is also said of a venomous reptile and the like, meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, malignant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noxious; impure, unclean, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"]"}],"source_refs":["Msb","K","S","Mgh","A"]}]},"classical_definitions":null}