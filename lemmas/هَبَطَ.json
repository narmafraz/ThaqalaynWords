gen":"m","num":"d"},{"role":"present_3fd","form":"تَهْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْبِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْبُطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْبُطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهْبِطُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْبِطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْبُطُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْبُطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْبِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَهْبُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَهْبِط","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْبِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"هَبَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَبَطْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَهْبُط","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْبُط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":86,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n40853"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%A8%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to descend; to go or come down; to fall","examples":[{"text":"كَيْفَ أُضَيِّعُ هَذِهِ الْفُرْصَةَ الَّتِي هَبَطَتْ مِنَ السَّمَاءِ","english":"How can I miss this opportunity that fell from the sky?"}]},{"pos":"verb","gloss":"to make descend; to bring down, tear down","examples":[{"text":"برلين ما صمدت ناولني وهبط","english":"Berlin couldn't take it, so pour me another and tear down this wall."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40853","headword_ar":"هَبَطَ","root":"hbT","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (Msb, K,) but the latter is of rare occurrence, (Msb,) inf. n."},{"kind":"arabic","text_bw":"hubuwTN","text_ar":"هُبُوطٌ"},{"kind":"text","text":", (S, K,) of that whereof the aor. is"},{"kind":"text","text":", and of that whereof the aor. is"},{"kind":"text","text":"; (TA;) or of the latter only, that of the former being"},{"kind":"arabic","text_bw":"haboTN","text_ar":"هَبْطٌ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(said of water &c., Msb,)"},{"kind":"italic_en","text":"descended:"},{"kind":"text","text":"(S, Msb, K:) and ↓"},{"kind":"arabic","text_bw":"thb~T","text_ar":"تهبّط","orth_type":"arrow"},{"kind":"italic_en","text":"he descended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went down a declivity;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it sloped down;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A_inoHadara","text_ar":"اـِنْحَدَرَ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AnhbT","text_ar":"انهبط","orth_type":"arrow"},{"kind":"text","text":"signifies the same as this last; or (assumed tropical:)"},{"kind":"italic_en","text":"he became lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degraded;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A_inoHaT~a","text_ar":"اـِنْحَطَّ"},{"kind":"text","text":"; (K;) being quasi-pass. of ↓"},{"kind":"arabic","text_bw":"A^ahobaTahu","text_ar":"اَهْبَطَهُ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,) and it may be also of"},{"kind":"arabic","text_bw":"habaTahu","text_ar":"هَبَطَهُ"},{"kind":"text","text":", as is said in the M. (TA.) You say,"},{"kind":"arabic","text_bw":"habaTonaA fiY","text_ar":"هَبَطْنَا فِى"},{"kind":"arabic","text_bw":"HaduwrK SaEobapK","text_ar":"حَدُورٍ صَعْبَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We descended a difficult declivity"},{"kind":"text","text":"]. (A, in art."},{"kind":"arabic","text_bw":"Hdr","text_ar":"حدر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"habaTa AlwaAdiYa","text_ar":"هَبَطَ الوَادِىَ"},{"kind":"text","text":", (Bd, ii. 58, and Msb,) [as though it were trans., for"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"arabic","text_bw":"AlwaAdiY","text_ar":"الوَادِى"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"hubuwTN","text_ar":"هُبُوطٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"We descended into the valley."},{"kind":"text","text":"(Bd, Msb.) And"},{"kind":"arabic","text_bw":"habaTa minohu","text_ar":"هَبَطَ مِنْهُ"},{"kind":"italic_en","text":"He came forth from it."},{"kind":"text","text":"(Bd, ubi supra.) It is said in the Kur, ii. 58,"},{"kind":"arabic","text_bw":"A_ihobiTuwA miSorFA","text_ar":"اـِهْبِطُوا مِصْرًا"},{"kind":"italic_en","text":"Descend ye into Misr:"},{"kind":"text","text":"(Bd:) accord. to one reading,"},{"kind":"arabic","text_bw":"A^uhobuTuwA","text_ar":"اُهْبُطُوا"},{"kind":"text","text":". (Bd, TA.) You say also"},{"kind":"arabic","text_bw":"habaTa balada ka*aA","text_ar":"هَبَطَ بَلَدَ كَذَا"},{"kind":"italic_en","text":"He entered such a town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"habaTotu mino mawoDiEK A_ilaY mawoDiEK","text_ar":"هَبَطْتُ مِنْ مَوْضِعٍ اـِلَى مَوْضِعٍ"},{"kind":"italic_en","text":"I removed him from a place to a place."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"haboTN","text_ar":"هَبْطٌ"},{"kind":"text","text":"also signifies (tropical:) The"},{"kind":"italic_en","text":"falling into evil:"},{"kind":"text","text":"(K, TA:) and (tropical:)  the"},{"kind":"italic_en","text":"being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, low, abject, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile:"},{"kind":"text","text":"(TA:) and (tropical:)  the"},{"kind":"italic_en","text":"suffering loss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diminution."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"habaTa mino manozilatihi","text_ar":"هَبَطَ مِنْ مَنْزِلَتِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He fell from his honourable station."},{"kind":"text","text":"(TA.) [See also 7, mentioned above.] And"},{"kind":"arabic","text_bw":"habaTa fulaAnN","text_ar":"هَبَطَ فُلَانٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one became low, abject, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"habaTa mina Alxa$oyapi","text_ar":"هَبَطَ مِنَ الخَشْيَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abject, and lowly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive, from fear"},{"kind":"text","text":"(TA.) [See Kur, ii. 69.] And"},{"kind":"arabic","text_bw":"habaTa Alqawomu","text_ar":"هَبَطَ القَوْمُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, became in a state of abasement and diminution."},{"kind":"text","text":"(TA.) Whence the trad., (TA,)"},{"kind":"arabic","text_bw":"A^all~`hum~a gaboTFA laA haboTFA","text_ar":"اَللّٰهُمَّ غَبْطًا لَا هَبْطًا"},{"kind":"text","text":", (S, TA,) i. e."},{"kind":"arabic","text_bw":"nasoA^aluka","text_ar":"نَسْاَلُكَ"},{"kind":"arabic","text_bw":"AlgiboTapa wanaEuw*u bika mino A^ano nahobiTa Eano HaAlinaA","text_ar":"الغِبْطَةَ وَنَعُوذُ بِكَ مِنْ اَنْ نَهْبِطَ عَنْ حَالِنَا"},{"kind":"text","text":"((tropical:)"},{"kind":"italic_en","text":"O God,"},{"kind":"text","text":"we ask of Thee"},{"kind":"italic_en","text":"a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition,"},{"kind":"text","text":"and we put our trust in Thee for preservation"},{"kind":"italic_en","text":"that we may not become brought down from our state"},{"kind":"text","text":"]: (S.) mentioned [and explained] before, in art."},{"kind":"arabic","text_bw":"gbT","text_ar":"غبط"},{"kind":"text","text":", q. v. (TA.) [But in this instance,"},{"kind":"arabic","text_bw":"haboTFA","text_ar":"هَبْطًا"},{"kind":"text","text":"may be regarded as the inf. n. of the trans. v. to be mentioned below.] You say also,"},{"kind":"arabic","text_bw":"habaTato A_ibiliY","text_ar":"هَبَطَتْ اـِبِلِى"},{"kind":"arabic","text_bw":"waganamiY","text_ar":"وَغَنَمِى"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hunuwTN","text_ar":"هُنُوطٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"My camels, and my sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, suffered loss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diminution:"},{"kind":"text","text":"and in the same sense"},{"kind":"arabic","text_bw":"habaTa","text_ar":"هَبَطَ"},{"kind":"text","text":"is said of flesh, and of fat, and of fatness. (TA.) And"},{"kind":"arabic","text_bw":"habaTa vamanu Als~iloEapi","text_ar":"هَبَطَ ثَمَنُ السِّلْعَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The price of the commodity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"article of merchandise, became diminished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lessened,"},{"kind":"text","text":"(S, Msb, K, TA.)"},{"kind":"italic_en","text":"below its former full rate;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"became lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abated."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"habaTa AlEidolu","text_ar":"هَبَطَ العِدْلُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The counterpoising portion of the load became adjusted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged, made even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made easy,"},{"kind":"text","text":"upon the camel. (TA.)       -A2-"},{"kind":"arabic","text_bw":"habaTahu","text_ar":"هَبَطَهُ"},{"kind":"text","text":", (S, Msb. K.) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"haboTN","text_ar":"هَبْطٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(namely water. &c., Msb,)"},{"kind":"italic_en","text":"to descend:"},{"kind":"text","text":"(S, Msb, K;) ["},{"kind":"italic_en","text":"he sent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"east, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, down;"},{"kind":"text","text":"] as also ↓"},{"kind":"arabic","text_bw":"AhbThu","text_ar":"اهبطهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Als~anapu A_ilaY","text_ar":"السَّنَةُ اـِلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ahobaTatohumu","text_ar":"اَهْبَطَتْهُمُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlA^amoSaAri","text_ar":"الاَمْصَارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The year of dearth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drought, caused them to go down to the cities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"great towns"},{"kind":"text","text":"]. (A, in art."},{"kind":"arabic","text_bw":"Hsr","text_ar":"حسر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"habaTahu balada ka*aA","text_ar":"هَبَطَهُ بَلَدَ كَذَا"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, caused him to enter such a town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country."},{"kind":"text","text":"(K.) [And"},{"kind":"arabic","text_bw":"habaTa bihi EalaY makaAnK","text_ar":"هَبَطَ بِهِ عَلَى مَكَانٍ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made him to alight upon a place:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"zaH~a","text_ar":"زَحَّ"},{"kind":"text","text":".] ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He lowered him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degraded him, from his state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"(Fr;) as also ↓"},{"kind":"arabic","text_bw":"AhbThu","text_ar":"اهبطهُ","orth_type":"arrow"},{"kind":"text","text":"; (Fr, S;) i. e., God did so; (Fr;) or a man: (S:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(time, or fortune,)"},{"kind":"italic_en","text":"caused his wealth, and his goodness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beneficence, to go away, after he had abounded therein."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"habaTa AlmaraDu laHomahu","text_ar":"هَبَطَ المَرَضُ لَحْمَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The disease rendered him lean; emaciated him:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"diminished his flesh."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"habaTa","text_ar":"هَبَطَ"},{"kind":"arabic","text_bw":"vamana Als~iloEapi","text_ar":"ثَمَنَ السِّلْعَةِ"},{"kind":"text","text":", (S, K.) inf. n."},{"kind":"arabic","text_bw":"haboTN","text_ar":"هَبْطٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God, K, or a man, S)"},{"kind":"italic_en","text":"diminished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lessened, the price of the commodity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"article of merchandise;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abated, it;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AhbThu","text_ar":"اهبطهُ","orth_type":"arrow"},{"kind":"text","text":", said of a man: (A 'Obeyd, S, M:) or"},{"kind":"arabic","text_bw":"habaTa mina Alv~amani","text_ar":"هَبَطَ مِنَ الثَّمَنِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"he diminished somewhat from the price;"},{"kind":"text","text":"and sometimes ↓"},{"kind":"arabic","text_bw":"AhbThu","text_ar":"اهبطهُ","orth_type":"arrow"},{"kind":"text","text":"is used in this sense. (Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"habaTa AlEidola","text_ar":"هَبَطَ العِدْلَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He adjusted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged, made even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made easy, the counterpoising portion of the load"},{"kind":"text","text":"upon the camel (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"habaTa fulaAnFA","text_ar":"هَبَطَ فُلَانًا"},{"kind":"italic_en","text":"He beat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"struck, such a one."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","K","TA","Bd"]}]}}