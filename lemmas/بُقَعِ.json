{"lemma":"بُقَعِ","slug":"بُقَعِ","root":"ب.ق.ع","root_slug":"ب-ق-ع","root_link":"/words/roots/ب-ق-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بُقْعَة","root":"بقع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3004"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D9%82%D9%8E%D8%B9%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"spot, stain, smudge"},{"pos":"noun","gloss":"patch, area, place, region"}]},"etymology":null,"ipa":["/buq.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3004","headword_ar":"بَقِعَ","root":"bqE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"baqaEN","text_ar":"بَقَعٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a bird, and a dog,)"},{"kind":"italic_en","text":"was black and white;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"baliqa","text_ar":"بَلِقَ"},{"kind":"text","text":"; (K;) [or rather]"},{"kind":"arabic","text_bw":"baqaEN","text_ar":"بَقَعٌ"},{"kind":"text","text":"in birds and dogs is like"},{"kind":"arabic","text_bw":"balaqN","text_ar":"بَلَقٌ"},{"kind":"text","text":"in beasts that are ridden, or horses and the like: (S, K:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a crow, &c.,)"},{"kind":"italic_en","text":"was partycoloured"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pied."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a drawer of water, L, K, from a well, by means of a pulley and rope and bucket, L)"},{"kind":"italic_en","text":"had his body sprinkled with the water, so that some parts of it became wetted."},{"kind":"text","text":"(L. K.)       -A2-"},{"kind":"arabic","text_bw":"maA A^adoriY A^ayona baqaEa","text_ar":"مَا اَدْرِى اَيْنَ بَقَعَ"},{"kind":"italic_en","text":"I know not whither he went;"},{"kind":"text","text":"(S, K;) as though one said, to what"},{"kind":"arabic","text_bw":"buqoEap","text_ar":"بُقْعَة"},{"kind":"text","text":"of the"},{"kind":"arabic","text_bw":"biqaAE","text_ar":"بِقَاع"},{"kind":"text","text":"of the earth he went; (S;) not used except negatively; (TA;) as also ↓"},{"kind":"arabic","text_bw":"baq~aEa","text_ar":"بَقَّعَ","orth_type":"arrow"},{"kind":"text","text":". (Fr, K.) ―         -b2-"},{"kind":"arabic","text_bw":"baqaEatohumu Ald~aAhiyapu","text_ar":"بَقَعَتْهُمُ الدَّاهِيَةُ"},{"kind":"italic_en","text":"The calamity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortune, befell them."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"buqiEa","text_ar":"بُقِعَ"},{"kind":"text","text":", (S, K,) like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was assailed with bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul, speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language:"},{"kind":"text","text":"(S, O, K:) or"},{"kind":"italic_en","text":"with calumny, slander,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false accusation."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"buqiEa biqabiyHK","text_ar":"بُقِعَ بِقَبِيحٍ"},{"kind":"italic_en","text":"He was assailed with foul, evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable, speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language."},{"kind":"text","text":"(L.)"}],"source_refs":["Msb","K","S","O"]}]},"classical_definitions":null}