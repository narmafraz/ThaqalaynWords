:"SaHoraA='","text_ar":"صَحْرَا=ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"and such as is called"},{"kind":"arabic","text_bw":"faDaA='","text_ar":"فَضَا=ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"containing no soft place in which the feet sink, nor any mountain, nor any"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hill such as is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"text","text":";"},{"kind":"italic_en","text":"sometimes wide, and sometimes of little width:"},{"kind":"text","text":"(ISh:) [and]"},{"kind":"italic_en","text":"a conspicuous road:"},{"kind":"text","text":"(Bd in xxxv. 25:) pl."},{"kind":"arabic","text_bw":"A^ajodaAdN","text_ar":"اَجْدَادٌ"},{"kind":"text","text":". (ISh.) It is said in a prov.,"},{"kind":"arabic","text_bw":"mano salaka Aljadada A^amina AlEivaAra","text_ar":"مَنْ سَلَكَ الجَدَدَ اَمِنَ العِثَارَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who walks along hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard and level, ground is secure from stumbling"},{"kind":"text","text":"]; (S, TA;) meaning, he who pursues the course marked out by common consent is secure from stumbling. (TA.) And"},{"kind":"arabic","text_bw":"makaAnN jadadN","text_ar":"مَكَانٌ جَدَدٌ"},{"kind":"text","text":"occurs in a trad., meaning"},{"kind":"italic_en","text":"Level ground."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"jadiydN","text_ar":"جَدِيدٌ"},{"kind":"text","text":". ―         -b3-  Also Sand that is"},{"kind":"italic_en","text":"thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and sloping down."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"italic_en","text":"A thing resembling a"},{"kind":"arabic","text_bw":"siloEap","text_ar":"سِلْعَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ganglion"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the neck of a camel."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","TA","ISh"]}]}}