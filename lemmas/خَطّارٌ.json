{"lemma":"خَطّارٌ","slug":"خَطّارٌ","root":"خ.ط.ر","root_slug":"خ-ط-ر","root_link":"/words/roots/خ-ط-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11005","n11007"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B7%D9%91%D8%A7%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plural of خَطَر (ḵaṭar)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11005","headword_ar":"خطار","root":"xTr","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n11007","headword_ar":"خَطَّارٌ","root":"xTr","body":[{"kind":"text","text":"[is probably applied to a he-camel in a sense like that of the fem., here following]."},{"kind":"arabic","text_bw":"xaT~aArapN","text_ar":"خَطَّارَةٌ"},{"kind":"text","text":", applied to a she-camel,"},{"kind":"italic_en","text":"That lashes with the tail to the right and left:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"that moves about her tail, when going, in a brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly, manner:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"that raises her tail, in going along, by reason of briskness, and exceeding sprightliness."},{"kind":"text","text":"(Har p. 557.) [See 1, first sentence.] ―         -b2-  [Hence,] (tropical:)  A spear"},{"kind":"italic_en","text":"that quivers, vibrates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shakes:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"that does so much:"},{"kind":"text","text":"and in like manner, a man. (TA.) And"},{"kind":"arabic","text_bw":"xaT~aArN biAlr~umoHi","text_ar":"خَطَّارٌ بِالرُّمْحِ"},{"kind":"text","text":"(tropical:)  A man"},{"kind":"italic_en","text":"who thrusts much with the spear."},{"kind":"text","text":"(S, K, TA.) ―         -b3-  (assumed tropical:)  A man"},{"kind":"italic_en","text":"who raises his arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"with a stone which he lifts for the purpose of trying his strength,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"to cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"throw,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and who shakes the stone in lifting it."},{"kind":"text","text":"(TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"A sling."},{"kind":"text","text":"(K.) (assumed tropical:) The ["},{"kind":"italic_en","text":"engine of war called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"manojaniyq","text_ar":"مَنْجَنِيق"},{"kind":"text","text":"; (K;) as also ↓"},{"kind":"arabic","text_bw":"xaT~aArapN","text_ar":"خَطَّارَةٌ","orth_type":"arrow"},{"kind":"text","text":": its casting being likened to the action termed"},{"kind":"arabic","text_bw":"xaTaraAnN","text_ar":"خَطَرَانٌ"},{"kind":"text","text":"[inf. n. of 1, q. v.], of the stallion-camel. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"AlxaT~aAru","text_ar":"الخَطَّارُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The lion:"},{"kind":"text","text":"(K:) because of his proud walk, and self-admiration: or because of his shaking himself in his walk. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"misokN xaT~aArN","text_ar":"مِسْكٌ خَطَّارٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Musk that diffuses much odour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fragrance."},{"kind":"text","text":"(A.)"}],"source_refs":["K","A","S","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%B7%D8%A7%D8%B1/","headword_ar":"خطار","entries":[{"lexicon_id":"dictionary_15","lexicon_en":"Ibn Mālik, al-Alfāẓ al-Mukhtalifa fī l-Maʿānī al-Muʾtalifa (d. 1274 CE)","lexicon_ar":"الألفاظ المختلفة في المعاني المؤتلفة لابن مالك","permalink":"https://arabiclexicon.hawramani.com/?p=22517#348e14","body_html":"<span class=\"title1\">بَاب الخطار بِالنَّفسِ</span><br><br><span>أقحم وتردى وتورط وانتظم وانهمك وانهجم وأخطر وَركب الْغرَر</span>"}]}}