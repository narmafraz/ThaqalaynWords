anelexicon.com/?s=%D8%AA%D9%8E%D9%81%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3969","headword_ar":"تَفَلَ","root":"tfl","body":[{"kind":"text","text":", [in the CK, erroneously,"},{"kind":"arabic","text_bw":"tafila","text_ar":"تَفِلَ"},{"kind":"text","text":",] aor."},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tafolN","text_ar":"تَفْلٌ"},{"kind":"text","text":", (T, S, M, Msb,)"},{"kind":"italic_en","text":"He spat;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"baSaqa","text_ar":"بَصَقَ"},{"kind":"text","text":": (M, K:) [or rather,"},{"kind":"italic_en","text":"he spat, emitting a small quantity of saliva,"},{"kind":"text","text":"generally"},{"kind":"italic_en","text":"in scattered portions, as when one spits forth some minute thing:"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Alt~afolu","text_ar":"التَّفْلُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"similar to"},{"kind":"arabic","text_bw":"Albazoqu","text_ar":"البَزْقُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"but less in degree:"},{"kind":"text","text":"(S, Msb: *) the first degree is"},{"kind":"arabic","text_bw":"Albazoqu","text_ar":"البَزْقُ"},{"kind":"text","text":"; then,"},{"kind":"arabic","text_bw":"Alt~afolu","text_ar":"التَّفْلُ"},{"kind":"text","text":"; then,"},{"kind":"arabic","text_bw":"Aln~afovu","text_ar":"النَّفْثُ"},{"kind":"text","text":"; and then,"},{"kind":"arabic","text_bw":"Aln~afoxu","text_ar":"النَّفْخُ"},{"kind":"text","text":": (S:)"},{"kind":"arabic","text_bw":"Alt~afolu","text_ar":"التَّفْلُ"},{"kind":"text","text":"with the mouth is ["},{"kind":"italic_en","text":"an action"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"never without somewhat of spittle:"},{"kind":"text","text":"a blowing without spittle is [said to be] termed"},{"kind":"arabic","text_bw":"nafovN","text_ar":"نَفْثٌ"},{"kind":"text","text":". (T.) Hence,"},{"kind":"arabic","text_bw":"tafolu Alr~aAqiY","text_ar":"تَفْلُ الرَّاقِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The spitting of the charmer, in which he emits a small quantity of saliva at a time, in scattered portions:"},{"kind":"text","text":"see also"},{"kind":"arabic","text_bw":"nafava","text_ar":"نَفَثَ"},{"kind":"text","text":"]. (S.) One says also,"},{"kind":"arabic","text_bw":"*aAqa maA='a AlbaHori fatafalahu","text_ar":"ذَاقَ مَا=ءَ البَحْرِ فَتَفَلَهُ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"He tasted the water of the sea, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"spirted it forth,"},{"kind":"text","text":"by reason of dislike thereof. (TA.)       -A2-"},{"kind":"arabic","text_bw":"tafila","text_ar":"تَفِلَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tafalN","text_ar":"تَفَلٌ"},{"kind":"text","text":", (S, M, Mgh, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, M,)"},{"kind":"italic_en","text":"became altered for the worse in odour, ill-smelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frouzy:"},{"kind":"text","text":"(M, K:)"},{"kind":"italic_en","text":"he neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left off the use of, perfume:"},{"kind":"text","text":"(M:)"},{"kind":"italic_en","text":"he was unperfumed:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"he neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left off the use of, perfume, and so became altered for the worse in odour, ill-smelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frouzy:"},{"kind":"text","text":"(Mgh, TA:) and"},{"kind":"arabic","text_bw":"tafilato","text_ar":"تَفِلَتْ"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"stank, by reason of having neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left off the use of, perfume and ointments:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"she perfumed herself:"},{"kind":"text","text":"thus bearing two contr. significations. (Msb.)"}],"source_refs":["S","M","Msb","K","T","Mgh","TA"]}]},"classical_definitions":null}