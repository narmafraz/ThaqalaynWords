{"lemma":"عَجَّلَ","slug":"عَجَّلَ","root":"ع.ج.ل","root_slug":"ع-ج-ل","root_link":"/words/roots/ع-ج-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَجَّلْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَجَّلْتِ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَجَّلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَجَّلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَجَّلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَجَّلَ","in_corpus":true,"count":8,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَجَّلَت","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَجَّلا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَجَّلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَجَّلُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَجَّلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَجِّل","in_corpus":true,"count":23,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَجِّلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَجِّلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَجِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَجِّلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَجِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَجِّلُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَجِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَجِّل","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَجِّل","in_corpus":true,"count":23,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَجِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَجِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَجِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَجِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَجِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَجِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَجِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُعَجِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَجِّل","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَجَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَجَّلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":96,"cross_references":{"qac":{"found":true,"lemma_key":"عَجَّلَ","root":"عجل","pos":"N","occurrence_count":10},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28192","n28196","n28197","n28198","n28199","n28200"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"calf (young head of cattle)"},{"pos":"verb","gloss":"to hurry"},{"pos":"adj","gloss":"fast, quick"},{"pos":"noun","gloss":"verbal noun of عَجِلَ (ʕajila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"masculine plural of أَعْجَل (ʔaʕjal)","tags":["form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine plural of عَجُول (ʕajūl)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-West Semitic *ʕigl-. Cognate with Hebrew עֵגֶל ('eguèl, “calf”).\n\nCompare عَجِلَ (ʕajila, “to hurry, to rush”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28192","headword_ar":"عَجِلَ","root":"Ejl","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] (S, Mgh, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EajalapN","text_ar":"عَجَلَةٌ"},{"kind":"text","text":", (S, * Mgh, O, * Msb, K, *)"},{"kind":"italic_en","text":"He hasted, hastened, made haste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sped; he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hasty, speedy, quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expeditious;"},{"kind":"text","text":"(S, Mgh, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tEj~l","text_ar":"تعجّل","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Ej~l","text_ar":"عجّل","orth_type":"arrow"},{"kind":"text","text":", [app. for"},{"kind":"arabic","text_bw":"Ej~l nafosahu","text_ar":"عجّل نَفْسَهُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"taEojiylN","text_ar":"تَعْجِيلٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AstEjl","text_ar":"استعجل","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb;) or this last signifies"},{"kind":"italic_en","text":"he required himself to haste,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"constraining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tasking, himself to do so."},{"kind":"text","text":"(Sb, K.) [See also"},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"below.] One says,"},{"kind":"arabic","text_bw":"Eajilotu lahu","text_ar":"عَجِلْتُ لَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I hasted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (O.) And"},{"kind":"arabic","text_bw":"Eajilotu bihi","text_ar":"عَجِلْتُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beforehand, with him"},{"kind":"text","text":"]: see 4. (Mgh.) And"},{"kind":"arabic","text_bw":"Eajilotu A_ilaY Al$~aYo'i","text_ar":"عَجِلْتُ اـِلَى الشَّىْءِ"},{"kind":"italic_en","text":"I"},{"kind":"italic_en","text":"preceded, outwent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got first, to the thing."},{"kind":"text","text":"(Msb.) ―         -b2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready;"},{"kind":"text","text":"said of a price, hire, payment, or the like;"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^ajila","text_ar":"اَجِلَ"},{"kind":"text","text":"]. (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Eajila minohu","text_ar":"عَجِلَ مِنْهُ"},{"kind":"italic_en","text":"He turned aside from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.)       -A2-  [It is also trans., as having, or implying, the meaning of"},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":":] see 4."}],"source_refs":["S","Mgh","O","Msb","K"]},{"entry_id":"n28196","headword_ar":"عُجْلٌ","root":"Ejl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EujaAlapN","text_ar":"عُجَالَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28197","headword_ar":"عِجْلٌ","root":"Ejl","body":[{"kind":"italic_en","text":"A calf"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"young one of the"},{"kind":"arabic","text_bw":"baqarap","text_ar":"بَقَرَة"},{"kind":"text","text":", (Aboo-Kheyreh, S, Mgh, O, Msb, K,) [both"},{"kind":"italic_en","text":"domestic"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wild,"},{"kind":"text","text":"which latter is a bovine antelope,]"},{"kind":"italic_en","text":"from the time when his mother brings him forth"},{"kind":"text","text":"(Aboo-Kheyreh, Mgh, TA)"},{"kind":"italic_en","text":"until a month old;"},{"kind":"text","text":"(Aboo-Kheyreh, Mgh, Msb, TA;) after which [accord. to some] he is called"},{"kind":"arabic","text_bw":"barogazN","text_ar":"بَرْغَزٌ"},{"kind":"text","text":", when about two months old; and then he is called"},{"kind":"arabic","text_bw":"faroqadN","text_ar":"فَرْقَدٌ"},{"kind":"text","text":": (Aboo-Kheyreh, TA:) or he is thus called while"},{"kind":"italic_en","text":"in the first year,"},{"kind":"text","text":"then"},{"kind":"arabic","text_bw":"tabiyEN","text_ar":"تَبِيعٌ"},{"kind":"text","text":", (S and Sgh and K in art."},{"kind":"arabic","text_bw":"slg","text_ar":"سلغ"},{"kind":"text","text":",) or, correctly, accord. to IB, he is called while in the first year"},{"kind":"arabic","text_bw":"EijolN","text_ar":"عِجْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tabiyEN","text_ar":"تَبِيعٌ"},{"kind":"text","text":", (TA in that art.,) then"},{"kind":"arabic","text_bw":"ja*aEN","text_ar":"جَذَعٌ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"vaniY~N","text_ar":"ثَنِىٌّ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"rabaAEK","text_ar":"رَبَاعٍ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"sadiysN","text_ar":"سَدِيسٌ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"saAligu","text_ar":"سَالِغُ"},{"kind":"arabic","text_bw":"sanapK","text_ar":"سَنَةٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saAligu sanatayoni","text_ar":"سَالِغُ سَنَتَيْنِ"},{"kind":"text","text":"and so on: (S and Sgh and K ibid.:) the fem. is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (Abu-l-Jarráh, S, O, Msb:) pl. of the masc."},{"kind":"arabic","text_bw":"EijalapN","text_ar":"عِجَلَةٌ"},{"kind":"text","text":"(Mgh, Msb) and"},{"kind":"arabic","text_bw":"EujuwlN","text_ar":"عُجُولٌ"},{"kind":"text","text":"(Msb, TA) and, of pauc.,"},{"kind":"arabic","text_bw":"A^aEojilapN","text_ar":"اَعْجِلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aEojaAlN","text_ar":"اَعْجَالٌ"},{"kind":"text","text":"; (IB, TA;) [and of the fem."},{"kind":"arabic","text_bw":"EijalN","text_ar":"عِجَلٌ"},{"kind":"text","text":";] but as to"},{"kind":"arabic","text_bw":"EijaAlN","text_ar":"عِجَالٌ"},{"kind":"text","text":"as a pl., [Mtr says,] I have not heard it: (Mgh:) and ↓"},{"kind":"arabic","text_bw":"Eij~awolN","text_ar":"عِجَّوْلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"EijolN","text_ar":"عِجْلٌ"},{"kind":"text","text":"; (S, Mgh, O, K;) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (TA;) and pl."},{"kind":"arabic","text_bw":"EajaAjiylu","text_ar":"عَجَاجِيلُ"},{"kind":"text","text":". (S, Mgh, O, K.)"}],"source_refs":["Mgh","Msb","TA"]},{"entry_id":"n28198","headword_ar":"عَجَلٌ","root":"Ejl","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EajalapN","text_ar":"عَجَلَةٌ","orth_type":"arrow"},{"kind":"text","text":", both inf. ns. of"},{"kind":"arabic","text_bw":"Eajila","text_ar":"عَجِلَ"},{"kind":"text","text":"[q. v.], (Mgh, Msb,) are"},{"kind":"italic_en","text":"Syn. with"},{"kind":"arabic","text_bw":"suroEapN","text_ar":"سُرْعَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"buTo'N","text_ar":"بُطْءٌ"},{"kind":"text","text":": (S, O:) the latter is expl. by Th as signifying the"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"pursuing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavouring after, a thing before its proper time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season;"},{"kind":"text","text":"and as proceeding from the desire of the soul; wherefore it is generally discommended in the Kur-án, so that it is said to be from the Devil. (TA.) It is said in the Kur [xxi. 38],"},{"kind":"arabic","text_bw":"xuliqa","text_ar":"خُلِقَ"},{"kind":"arabic","text_bw":"A@loA_inosaAnu mino EajalK","text_ar":"ا@لْاـِنْسَانُ مِنْ عَجَلٍ"},{"kind":"text","text":", meaning, it is said,"},{"kind":"italic_en","text":"Man is composed of haste;"},{"kind":"text","text":"(O;) so says Fr, and in like manner says Aboo-Is-hák; (T, TA;) to denote the excess of this attribute in him: (T, O, TA:) or, accord. to Th, (TA,) the phrase is inverted, the meaning being,"},{"kind":"italic_en","text":"haste is created from man;"},{"kind":"text","text":"(Msb, TA;) but IJ disapproves this explanation, and also another which will be mentioned in what follows. (TA.)       -A2-"},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"Food that is hastily prepared, and brought, before the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"meal called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"gadaA='","text_ar":"غَدَا=ء"},{"kind":"italic_en","text":"has become matured."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"Euj~aAlN","text_ar":"عُجَّالٌ"},{"kind":"text","text":".]       -A3-  Also"},{"kind":"italic_en","text":"Clay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TiynN","text_ar":"طِينٌ"},{"kind":"text","text":": (IAar, O, K:) or"},{"kind":"italic_en","text":"black mud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"black fetid mud;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HamoA^apN","text_ar":"حَمْاَةٌ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"EajalapN","text_ar":"عَجَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"has both of these meanings, i. e."},{"kind":"arabic","text_bw":"TiynN","text_ar":"طِينٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HamoA^apN","text_ar":"حَمْاَةٌ"},{"kind":"text","text":": (O, * K:) the former of these two significations of"},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"is said by AO to be of the dial. of Himyer; and IAar says that it is what is meant in the phrase in the Kur [xxi. 38] cited above; but Ibn-'Arafeh disapproves this; (O, TA;) and so does Az; and Er-Rághib says that some expl. it as meaning in this instance"},{"kind":"italic_en","text":"stinking black mud,"},{"kind":"text","text":"but that their saying is nought. (TA.)       -A4-  See also"},{"kind":"arabic","text_bw":"EajalapN","text_ar":"عَجَلَةٌ"},{"kind":"text","text":", in four places."}],"source_refs":["Mgh","Msb","S","O","T","TA","IAar","K"]},{"entry_id":"n28199","headword_ar":"عَجُلٌ","root":"Ejl","body":[{"kind":"text","text":": see the next paragraph, in two places."}],"source_refs":[]},{"entry_id":"n28200","headword_ar":"عَجِلٌ","root":"Ejl","body":[{"kind":"text","text":"(S, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EaAjilN","text_ar":"عَاجِلٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb, K) and ↓"},{"kind":"arabic","text_bw":"EajulN","text_ar":"عَجُلٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O, K) and ↓"},{"kind":"arabic","text_bw":"EajuwlN","text_ar":"عَجُولٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O) and ↓"},{"kind":"arabic","text_bw":"EajiylN","text_ar":"عَجِيلٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"EajolaAnu","text_ar":"عَجْلَانُ","orth_type":"arrow"},{"kind":"text","text":"(S, Mgh, O, Msb, K)"},{"kind":"italic_en","text":"Hasting, hastening, making haste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speeding;"},{"kind":"text","text":"[thus more properly the first and second, and often the last; the rest generally signifying]"},{"kind":"italic_en","text":"hasty, speedy, quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expeditious:"},{"kind":"text","text":"(S, Mgh, O, Msb, * K:) pls., (K, TA,) all of ↓"},{"kind":"arabic","text_bw":"EajolaAnu","text_ar":"عَجْلَانُ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"arabic","text_bw":"EajaAlaY","text_ar":"عَجَالَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EujaAlaY","text_ar":"عُجَالَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EijaAlN","text_ar":"عِجَالٌ"},{"kind":"text","text":"; (K, TA;) the first and last of which pls., as pls. of"},{"kind":"arabic","text_bw":"EajolaY","text_ar":"عَجْلَى"},{"kind":"text","text":"[fem. of"},{"kind":"arabic","text_bw":"EajolaAnu","text_ar":"عَجْلَانُ"},{"kind":"text","text":"], are applied to women (S, O, TA) also: (TA:)"},{"kind":"arabic","text_bw":"EajilN","text_ar":"عَجِلٌ"},{"kind":"text","text":"has no broken pl., nor has ↓"},{"kind":"arabic","text_bw":"EajulN","text_ar":"عَجُلٌ","orth_type":"arrow"},{"kind":"text","text":": (Sb, TA:) ISk says that, for the dim. of"},{"kind":"arabic","text_bw":"EajilN","text_ar":"عَجِلٌ"},{"kind":"text","text":", they use ↓"},{"kind":"arabic","text_bw":"EujayolaAnu","text_ar":"عُجَيْلَانُ","orth_type":"arrow"},{"kind":"text","text":", as formed from"},{"kind":"arabic","text_bw":"EajolaAnu","text_ar":"عَجْلَانُ"},{"kind":"text","text":"; though they also form it regularly, saying ↓"},{"kind":"arabic","text_bw":"EujayolN","text_ar":"عُجَيْلٌ","orth_type":"arrow"},{"kind":"text","text":"; but the former is the better. (O, TA.)"}],"source_refs":["S","O","Msb","K","Mgh","TA","Sb"]}]}}