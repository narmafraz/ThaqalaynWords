corpus":true,"count":60,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَمُر","in_corpus":true,"count":60,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَمُور","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَمِير","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَمِر","in_corpus":true,"count":52,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَمُر","in_corpus":true,"count":52,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَمُور","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَمِير","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَمُورا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَمُورا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَمُورُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمُورُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمِيرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمِيرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَمِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَمُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"مِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مِرْتُ","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"مُرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مُرْتُ","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَمُور","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَمُور","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَمِير","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَمِير","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":400,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n39036"],"search_url":"https://lanelexicon.com/?s=%D9%85%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"Lord; Saint; Mar (honorific title for a man of religion, most often a saint)","examples":[{"text":"لَيْسَ كُلُّ مَنْ يَقُولُ لِي: يَا مَار! يَا مَار! يَدْخُلُ مَلَكُوتَ السَّمَاوَاتِ، بَلْ مَنْ يَعْمَلُ بِإِرَادَةِ أَبِي الَّذِي فِي السَّمَاوَاتِ","english":"Not everyone who says to me, O Lord! O Lord! will enter the kingdom of heaven, but only the one who does the will of my Father who is in heaven."}]},{"pos":"adj","gloss":"passing","examples":[{"text":"الْمَارّ ذِكْرُهُ","english":"the above-mentioned, the aforesaid, the above"}]},{"pos":"adj","gloss":"going by, walking past, riding past, going across, walking, transient"},{"pos":"adj","gloss":"going on foot"},{"pos":"noun","gloss":"passer-by, pedestrian, walker, stroller"},{"pos":"verb","gloss":"to budge, to move forth, to rise across the surface, to fluctuate, to undergo commotion","examples":[{"text":"ولا تحدث الأعاصير في العادة بشكل متزامن في المحيطين، فحين يمور المحيط الهادئ بالعاصفة يكون المحيط الأطلسي هادئا\".","english":"Typhoons don’t usually appear simultaneously in the two oceans: When the Pacific Ocean is moved by a storm the Atlantic Ocean is calm."}]}]},"etymology":{"source":"wiktextract","text":"From Classical Syriac ܡܪܝ (mār(ī)), the first-person singular possessed form of ܡܪܐ (mārā, “lord, master”).\n\nDerived from the active participle of مَرَّ (marra, “to pass, to stroll by”)."},"ipa":["/maːr/","/maːrr/","/maː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39036","headword_ar":"مَارَ","root":"mwr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamuwru","text_ar":"يَمُورُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maworN","text_ar":"مَوْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It moved from side to side,"},{"kind":"text","text":"(S, M, A, Msb, K,)"},{"kind":"italic_en","text":"like the knee-pan on the knee;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"to and fro, like as the tall palm-tree moves;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"tmw~r","text_ar":"تموّر","orth_type":"arrow"},{"kind":"text","text":": (S:)"},{"kind":"italic_en","text":"it came and went;"},{"kind":"text","text":"(T;) as also ↓"},{"kind":"arabic","text_bw":"tmw~r","text_ar":"تموّر","orth_type":"arrow"},{"kind":"text","text":". (K.) You say of a camel,"},{"kind":"arabic","text_bw":"tamuwru EaDudaAhu","text_ar":"تَمُورُ عَضُدَاهُ"},{"kind":"italic_en","text":"The upper bones of his two arms move from side to side."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"maAra Als~inaAnu fiY AlmaToEuwni","text_ar":"مَارَ السِّنَانُ فِى المَطْعُونِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The spear-head moved from side to side in the person pierced"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"AlT~aEonapu tamuwru","text_ar":"الطَّعْنَةُ تَمُورُ"},{"kind":"italic_en","text":"The thrust inclines to the right and left."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Aln~ujuwmu tamuwru","text_ar":"النُّجُومُ تَمُورُ"},{"kind":"italic_en","text":"The stars come and go."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maAra AlgubaAru","text_ar":"مَارَ الغُبَارُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maworN","text_ar":"مَوْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The dust moved to and fro:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became raised by the wind."},{"kind":"text","text":"(M, K.) ―         -b2-"},{"kind":"italic_en","text":"It moved round about,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"and to and fro:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"it was in a state of commotion; in a state of tumult:"},{"kind":"text","text":"(S, * M, Msb, K:) said of the sea, (Msb,) &c.: (M:)"},{"kind":"italic_en","text":"it was in a state of quick motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commotion."},{"kind":"text","text":"(Msb.) It is said in a trad., that when the soul, or spirit, was blown into Adam,"},{"kind":"arabic","text_bw":"maAra fiY raA^osihi faEaTasa","text_ar":"مَارَ فِى رَاْسِهِ فَعَطَسَ"},{"kind":"italic_en","text":"It circulated, and moved to and fro, in his head, and he sneezed."},{"kind":"text","text":"(TA.) And in the Kur, [lii. 9,]"},{"kind":"arabic","text_bw":"yawoma tamuwru Als~amaA='u maworFA","text_ar":"يَوْمَ تَمُورُ السَّمَا=ءُ مَوْرًا"},{"kind":"italic_en","text":"On the day when the heaven shall actually be in a state of commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tumult:"},{"kind":"text","text":"so accord. to Ed-Dahhák: or"},{"kind":"italic_en","text":"shall move from side to side:"},{"kind":"text","text":"so accord. to AO and Akh: (S:) or"},{"kind":"italic_en","text":"shall come and go;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"move to and fro;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reel."},{"kind":"text","text":"(T.) And in a trad. of Ibn-Ez-Zubeyr,"},{"kind":"arabic","text_bw":"bikataAy^iba tamuwru karijoli AljaraAdi","text_ar":"بِكَتَايِبَ تَمُورُ كَرِجْلِ الجَرَادِ"},{"kind":"italic_en","text":"With troops moving to and fro, in a state of commotion, like the leg of the locust,"},{"kind":"text","text":"by reason of their multitude. (TA.) You say also,"},{"kind":"arabic","text_bw":"maArati Aln~aAqapu fiY sayorihaA","text_ar":"مَارَتِ النَّاقَةُ فِى سَيْرِهَا"},{"kind":"italic_en","text":"The she-camel was in a state of commotion, and reeled, in her pace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going:"},{"kind":"text","text":"and in like manner you say of a mare. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maA A^adoriY A^agaAra A^amo maAra","text_ar":"مَا اَدْرِى اَغَارَ اَمْ مَارَ"},{"kind":"text","text":", a saying of the Arabs, related by IAar, (TA,)"},{"kind":"italic_en","text":"I know not whether he have come to low country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned and returned to high country"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"najod","text_ar":"نَجْد"},{"kind":"text","text":"): (S, TA:) or"},{"kind":"italic_en","text":"have come to the low country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"come to the high country."},{"kind":"text","text":"(IAar, K, * TA.) ―         -b4-"},{"kind":"arabic","text_bw":"maAra Ald~amu","text_ar":"مَارَ الدَّمُ"},{"kind":"text","text":"(S, &c.)"},{"kind":"italic_en","text":"The blood ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed,"},{"kind":"text","text":"upon the surface of the ground; (T, S, M, Msb, K;) and in like manner you say of tears, meaning they"},{"kind":"italic_en","text":"flowed:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"the blood poured"},{"kind":"text","text":"upon the surface of the ground,"},{"kind":"italic_en","text":"and went hither and thither,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"sideways."},{"kind":"text","text":"(A.) ―         -b5-  See also 4."}],"source_refs":["S","M","A","Msb","K","T","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%A7%D8%B1/","headword_ar":"مار","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=4166#a7b02d","body_html":"مار: مار: (سريانية) تأتي قبل اسم القديس: على سبيل المثال: مار بطرس (بوشر)."},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=4166#fe10aa","body_html":"<p>مار: المِئْرَةُ، بالهمزة: الذَّجْلُ والعَدَاوَةُ، وجمعها مِئَرٌ.</p><p>ومَئِرَ عليه وامْتَأَرَ: اعْتَقَدَ عَداوتَه. ومَأَرَ بينهم يَمْأَرُ</p><p>مَأْراً وماءَرَ بينهم مُماءَرَةً ومِئاراً: أَفسد بينهم وأَغرى وعادى.</p><p>وماءَرْتُهُ مُماءَرَةً، على فاعَلْتُه، وامْتَأَر فلانٌ على فلان أَي احتقد</p><p>عليه. ورجل مَئِرٌ وَمِئَرٌ: مفسد بين الناس.</p><p>وتَمَاءَرُوا: تفاخروا. وماءَرَهُ وماءَرَةً: فاخَرَهُ. وماءَرَهُ في</p><p>فِعْلِه: ساواه؛ قال:</p><p>دَعْتْ ساقَ حُرٍّ، فانْتَحى مِثْلَ صَوْتِها</p><p>يُمائِرُها في فِعْله، وتُمائِرُهْ</p><p>وَتَماءَرَا: تساويا؛ عن ابن الأَعرابي؛ وأَنشد:</p><p>تَماءَرْتُمُ في العِزِّ حَتَّى هَلَكْتُمُ،</p><p>كما أَهْلَكَ الغارُ النِّساءَ الضَّرائِرا</p><p>وَأَمْرٌ مَئِرٌ وَمَئِيرٌ: شديد. يقال: هم في أَمر مَئِرٍ أَي شديد.</p><p>وَمَأَرَ السِّقاءَ مَأْراً: وَسَّعَه.</p>"}]}}