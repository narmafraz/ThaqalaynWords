{"lemma":"مارَ","slug":"مارَ","root":"م.#.ر","root_slug":"م-_-ر","root_link":"/words/roots/م-_-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"مِرْتَ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2ms","form":"مُرْتَ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"مِرْتِ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2fs","form":"مُرْتِ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"مِرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2md","form":"مُرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"مِرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2mp","form":"مُرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"مِرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_2fp","form":"مُرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"مارَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"مارَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"مارا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"مارَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"مارُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"مِرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"past_3fp","form":"مُرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَمِر","in_corpus":tr