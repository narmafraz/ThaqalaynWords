{"lemma":"مُعَدٌّ","slug":"مُعَدٌّ","root":"ع.د.د","root_slug":"ع-د-د","root_link":"/words/roots/ع-د-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","name","noun"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28295","n38727"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%8E%D8%AF%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of أَعْدَى (ʔaʕdā)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"infectious"},{"pos":"name","gloss":"Ma'add (a semi-mythical figure, the son of Adnan)"},{"pos":"name","gloss":"An ethnic identity and nation of ancient and early medieval Arabia."},{"pos":"noun","gloss":"plural of مَعِدَة (maʕida) or مِعْدَة (miʕda)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of مَعِدَة (maʕida) or مِعْدَة (miʕda)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28295","headword_ar":"مَعَدٌّ","root":"Ed","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"(ISd, TA) of a man and of a horse &c.: (L in art."},{"kind":"arabic","text_bw":"mEd","text_ar":"معد"},{"kind":"text","text":"[in which it is fully explained]:)"},{"kind":"arabic","text_bw":"AlmaEad~aAni","text_ar":"المَعَدَّانِ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"places of the two boards of the saddle"},{"kind":"text","text":"(S, * O, * A, K, * TA)"},{"kind":"italic_en","text":"upon the two sides"},{"kind":"text","text":"of the horse. (A, TA.) One says,"},{"kind":"arabic","text_bw":"Eariqa maEad~aAhu","text_ar":"عَرِقَ مَعَدَّاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The parts of his sides beneath the two boards of the saddle sweated"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["ISd","TA"]},{"entry_id":"n38727","headword_ar":"مَعَدٌّ","root":"mEd","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"(L, K) of a man, &c.: (L:) or, in a horse, the"},{"kind":"italic_en","text":"part of each side between the lower portion of the shoulder-blade and the extremity of the ribs, consisting of thick and compact flesh behind the shoulder-blade;"},{"kind":"text","text":"the protuberance whereof is approved, because, when that part is narrow, it compresses the heart: (L:) or, in a horse, the"},{"kind":"italic_en","text":"part between the head of each shoulder-blade and the hinder extremity of the portion of flesh and sinew next the back-bone:"},{"kind":"text","text":"(L, K:) and the"},{"kind":"italic_en","text":"flesh that is beneath the shoulderblade,"},{"kind":"text","text":"(L, K,) or"},{"kind":"italic_en","text":"a little below it;"},{"kind":"text","text":"which is the best of the flesh of the side: (L:) and the"},{"kind":"italic_en","text":"place of the horseman's heel:"},{"kind":"text","text":"(L, K:) or the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of a beast of carriage"},{"kind":"italic_en","text":"which is the place of the rider's leg:"},{"kind":"text","text":"(Lh, L:) and the"},{"kind":"italic_en","text":"belly:"},{"kind":"text","text":"(Aboo-'Alee, L, K:) also,"},{"kind":"italic_en","text":"a vein in the part of a horse called"},{"kind":"arabic","text_bw":"manosij","text_ar":"مَنْسِج"},{"kind":"text","text":". (L, K.) See also art."},{"kind":"arabic","text_bw":"Ed","text_ar":"عد"},{"kind":"text","text":"."}],"source_refs":["L","K","Lh"]}]},"classical_definitions":null}