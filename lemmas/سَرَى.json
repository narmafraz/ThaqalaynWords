{"lemma":"سَرَى","slug":"سَرَى","root":"س.ر.#","root_slug":"س-ر-_","root_link":"/words/roots/س-ر-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَرَيْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَرَيْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَرَيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَرَيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَرَيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَرَى","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَرَت","in_corpus":true,"count":8,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَرَيا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَرَوْا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَرَيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْر","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْرَى","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْرِي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْرِي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْرِيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْرِيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْرِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْر","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْرَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْرِي","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْرَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْرِي","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْرِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْرِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْرِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْرِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْرِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْر","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْرَى","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْرَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَرَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَرَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْرِي","in_corpus":true,"count":25,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْرِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":96,"cross_references":{"qac":{"found":true,"lemma_key":"سَرَى","root":"سري","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n19671"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%B1%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to circulate; to flow"},{"pos":"verb","gloss":"to spread"},{"pos":"verb","gloss":"to come into force"},{"pos":"verb","gloss":"to be valid, effective"},{"pos":"verb","gloss":"to travel by night"},{"pos":"noun","gloss":"verbal noun of سَرَّ (sarra) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/sa.raː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19671","headword_ar":"سَرَى","root":"srY","body":[{"kind":"text","text":", (S, M, K,) or"},{"kind":"arabic","text_bw":"saraY All~ayola","text_ar":"سَرَى اللَّيْلَ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"biAll~ayoli","text_ar":"بِاللَّيْلِ"},{"kind":"text","text":", (Mgh, Msb,) aor."},{"kind":"arabic","text_bw":"yasoriY","text_ar":"يَسْرِى"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"surFY","text_ar":"سُرًى"},{"kind":"text","text":"(S, M, Mgh, K) and"},{"kind":"arabic","text_bw":"masorFY","text_ar":"مَسْرًى"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"saroyapN","text_ar":"سَرْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suroyapN","text_ar":"سُرْيَةٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"siraAyapN","text_ar":"سِرَايَةٌ"},{"kind":"text","text":"; (S, * and TA as from the K, but not in the CK nor in my MS. copy of the K;) the first of a form rare among inf. ns., because it is one of the forms of pls., as is shown by the fact that some of the Arabs make it and"},{"kind":"arabic","text_bw":"hudFY","text_ar":"هُدًى"},{"kind":"text","text":"fem., namely, Benoo-Asad, supposing them to be pls. of"},{"kind":"arabic","text_bw":"suroyapN","text_ar":"سُرْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hudoyapN","text_ar":"هُدْيَةٌ"},{"kind":"text","text":", (S,) and Lh knew not"},{"kind":"arabic","text_bw":"surFY","text_ar":"سُرًى"},{"kind":"text","text":"but as a fem. noun; (M;) or the inf. n. is"},{"kind":"arabic","text_bw":"saroYN","text_ar":"سَرْىٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"suroyapN","text_ar":"سُرْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saroyapN","text_ar":"سَرْيَةٌ"},{"kind":"text","text":"are more special [in meaning, as will be shown below, voce"},{"kind":"arabic","text_bw":"saroyapN","text_ar":"سَرْيَةٌ"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"surFY","text_ar":"سُرًى"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"suroyapN","text_ar":"سُرْيَةٌ"},{"kind":"text","text":"; (Msb;) or"},{"kind":"arabic","text_bw":"saroyapN","text_ar":"سَرْيَةٌ"},{"kind":"text","text":"is an inf. n. un., and"},{"kind":"arabic","text_bw":"suroyapN","text_ar":"سُرْيَةٌ"},{"kind":"text","text":"is a simple subst., and so is"},{"kind":"arabic","text_bw":"surFY","text_ar":"سُرًى"},{"kind":"text","text":", (S, TA,) and so is"},{"kind":"arabic","text_bw":"siraAyapN","text_ar":"سِرَايَةٌ"},{"kind":"text","text":"(Msb, TA) also, as some say; (TA;)"},{"kind":"italic_en","text":"He journeyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travelled, by night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the night,"},{"kind":"text","text":"(S, M, Mgh, Msb, K,)"},{"kind":"italic_en","text":"in a general sense;"},{"kind":"text","text":"(M, K;) accord. to AZ, in the first part part of the night, and in the middle thereof, and in the last part thereof; (Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"AsrY","text_ar":"اسرى","orth_type":"arrow"},{"kind":"text","text":"signifies the same (S, M, Mgh, Msb, K) in the dial. of El-Hijáz, (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"A_isoraA='N","text_ar":"اـِسْرَا=ءٌ"},{"kind":"text","text":"; (M;) as also ↓"},{"kind":"arabic","text_bw":"AstrY","text_ar":"استرى","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) and perhaps ↓"},{"kind":"arabic","text_bw":"tsr~Y","text_ar":"تسرّى","orth_type":"arrow"},{"kind":"text","text":"likewise. (Mgh.) [See also"},{"kind":"arabic","text_bw":"surFY","text_ar":"سُرًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saroyapN","text_ar":"سَرْيَةٌ"},{"kind":"text","text":"below.] It is said in a prov.,"},{"kind":"arabic","text_bw":"qunofu*K","text_ar":"قُنْفُذٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*ahabuwA A_isoraA='a","text_ar":"ذَهَبُوا اـِسْرَا=ءَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They went away in the manner of a hedge-hog's night-travelling;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"they went away by night"},{"kind":"text","text":"]; because the"},{"kind":"arabic","text_bw":"qnf*","text_ar":"قنفذ"},{"kind":"text","text":"goes all the night, not sleeping. (M.) ―         -b2-  [Hence, as denoting unseen progress,] it is said also of the root of a tree, meaning"},{"kind":"italic_en","text":"It crept along beneath the ground;"},{"kind":"text","text":"(Az, M, K;) aor. as above, (M,) inf. n."},{"kind":"arabic","text_bw":"saroYN","text_ar":"سَرْىٌ"},{"kind":"text","text":". (TA.) ―         -b3-  And it is said of ideal things, as being likened to corporeal things; tropically, and by extension of the signification; (Msb, TA;) or metaphorically; [as, for instance,] of calamities, and wars, and anxieties: (M, TA:) and the predominant inf. ns. [in these cases] are"},{"kind":"arabic","text_bw":"siraAyapN","text_ar":"سِرَايَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sarayaAnN","text_ar":"سَرَيَانٌ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"saraY Eiroqu","text_ar":"سَرَى عِرْقُ"},{"kind":"arabic","text_bw":"Als~uwo'i fiY AlA_inosaAni","text_ar":"السُّوْءِ فِى الاـِنْسَانِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strain, of evil crept in the man"},{"kind":"text","text":"]. (Es-Sarakustee, Msb, TA.) And"},{"kind":"arabic","text_bw":"saraY fiyhi Als~am~u","text_ar":"سَرَى فِيهِ السَّمُّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The poison crept in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pervaded him"},{"kind":"text","text":"]; and similarly one says of wine; and of the like of these two things. (El-Fárábee, Msb, TA. [See also"},{"kind":"arabic","text_bw":"dab~a","text_ar":"دَبَّ"},{"kind":"text","text":".]) And the lawyers say,"},{"kind":"arabic","text_bw":"saraY AljuroHu A_ilaY Aln~afosi","text_ar":"سَرَى الجُرْحُ اـِلَى النَّفْسِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The wound extended to the soul"},{"kind":"text","text":"], meaning that the pain of the wound continued until death ensued in consequence thereof: (Mgh, * Msb, TA:) and"},{"kind":"arabic","text_bw":"quTiEa kaf~uhu fasaraY","text_ar":"قُطِعَ كَفُّهُ فَسَرَى"},{"kind":"arabic","text_bw":"A_ilaY saAEidihi","text_ar":"اـِلَى سَاعِدِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His hand was cut off, and it extended to his upper arm"},{"kind":"text","text":"], meaning that the effect of the wound passed by transmission: and"},{"kind":"arabic","text_bw":"saraY","text_ar":"سَرَى"},{"kind":"arabic","text_bw":"Alt~aHoriymu","text_ar":"التَّحْرِيمُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlEitoqu","text_ar":"العِتْقُ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The prohibition,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the emancipation,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"extended,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"passed by transmission:"},{"kind":"text","text":"phrases current among the lawyers, but not mentioned in books of repute, though agreeable with others here preceding and following. (Msb, TA.) One says also,"},{"kind":"arabic","text_bw":"saraY Ealayohi Alham~u","text_ar":"سَرَى عَلَيْهِ الهَمُّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Anxiety came to him"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"upon him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by night:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saraY","text_ar":"سَرَى"},{"kind":"arabic","text_bw":"ham~uhu","text_ar":"هَمُّهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His anxiety went away."},{"kind":"text","text":"(Msb, TA.) And similar to these is the phrase in the Kur [lxxxix. 3],"},{"kind":"arabic","text_bw":"waA@ll~ayoli A_i*aA yasori","text_ar":"وَا@للَّيْلِ اـِذَا يَسْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"And by the night when it goes away:"},{"kind":"text","text":"(Msb, TA:) or, as some say,"},{"kind":"italic_en","text":"when one journeys in it;"},{"kind":"text","text":"like as one says"},{"kind":"arabic","text_bw":"layolN naAy^imN","text_ar":"لَيْلٌ نَايِمٌ"},{"kind":"text","text":"meaning “ night in which one sleeps: ” the [final]"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"[of the verb] is elided because it terminates a verse. (TA.) ―         -b4-  It is made trans. by means of"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":": (Msb:) one says,"},{"kind":"arabic","text_bw":"saraY bihi","text_ar":"سَرَى بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made him to journey,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he transported him, by night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the night;"},{"kind":"text","text":"or it may be rendered"},{"kind":"italic_en","text":"he journeyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travelled, with him, by night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the night"},{"kind":"text","text":"]; (M, Msb, K;) and in like manner, [and more commonly,]"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asoraY","text_ar":"اَسْرَى","orth_type":"arrow"},{"kind":"text","text":"; (S, M, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"A^asoraAhu","text_ar":"اَسْرَاهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, M, K;) like as one says,"},{"kind":"arabic","text_bw":"A^axa*a biAlxiTaAmi","text_ar":"اَخَذَ بِالخِطَامِ"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"Ax* AlxiTaAma","text_ar":"اخذ الخِطَامَ"},{"kind":"text","text":". (S.) As to the saying in the Kur [xvii. 1],"},{"kind":"arabic","text_bw":"suboHaAna A@l~a*iY","text_ar":"سُبْحَانَ ا@لَّذِى"},{"kind":"arabic","text_bw":"biEabodihi layolFA","text_ar":"بِعَبْدِهِ لَيْلًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asoraY","text_ar":"اَسْرَى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Extolled be the glory of Him who transported his servant by night!"},{"kind":"text","text":"], it is an instance of corroboration, (S, K, * TA,) like the saying,"},{"kind":"arabic","text_bw":"sirotu A^amosi nahaArFA","text_ar":"سِرْتُ اَمْسِ نَهَارًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlbaAriHapa layolFA","text_ar":"البَارِحَةَ لَيْلًا"},{"kind":"text","text":": (S, TA:) or the meaning is [simply]"},{"kind":"arabic","text_bw":"say~arahu","text_ar":"سَيَّرَهُ"},{"kind":"text","text":": (K, TA:) accord. to 'Alam-ed-Deen Es-Sakháwee,"},{"kind":"arabic","text_bw":"layolFA","text_ar":"لَيْلًا"},{"kind":"text","text":"is added, although"},{"kind":"arabic","text_bw":"AlA_isoraA='","text_ar":"الاـِسْرَا=ء"},{"kind":"text","text":"is not otherwise than by night, because the space over which he was transported is not to be traversed in less than forty days, but was traversed by him in one night; as though the meaning [intended] were,"},{"kind":"arabic","text_bw":"fiY layolK waAHidK","text_ar":"فِى لَيْلٍ وَاحِدٍ"},{"kind":"text","text":"; and it denotes wonder:"},{"kind":"arabic","text_bw":"layolFA","text_ar":"لَيْلًا"},{"kind":"text","text":"is here used instead of"},{"kind":"arabic","text_bw":"layolapF","text_ar":"لَيْلَةً"},{"kind":"text","text":"because when they say"},{"kind":"arabic","text_bw":"saraY","text_ar":"سَرَى"},{"kind":"arabic","text_bw":"layolapF","text_ar":"لَيْلَةً"},{"kind":"text","text":"the meaning generally is"},{"kind":"italic_en","text":"he occupied the whole of the night in journeying:"},{"kind":"text","text":"Er-Rághib holds the verb in this instance to be from"},{"kind":"arabic","text_bw":"saraApN","text_ar":"سَرَاةٌ"},{"kind":"text","text":"signifying “ a wide tract of land, ” to belong to art."},{"kind":"arabic","text_bw":"srw","text_ar":"سرو"},{"kind":"text","text":", and to be like"},{"kind":"arabic","text_bw":"A^ajobala","text_ar":"اَجْبَلَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^atohama","text_ar":"اَتْهَمَ"},{"kind":"text","text":"; the meaning being,"},{"kind":"italic_en","text":"who transported his servant over a wide tract of land:"},{"kind":"text","text":"but this is strange. (TA.)       -A2-"},{"kind":"arabic","text_bw":"saraY mataAEahu","text_ar":"سَرَى مَتَاعَهُ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"arabic","text_bw":"yasoriY","text_ar":"يَسْرِى"},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"saroYN","text_ar":"سَرْىٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He threw his goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utensils and furniture, upon the back of his beast."},{"kind":"text","text":"(M, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"saraY Ean~iY Alv~awoba","text_ar":"سَرَى عَنِّى الثَّوْبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saroYN","text_ar":"سَرْىٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He removed from over me the garment:"},{"kind":"text","text":"but"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is more approved [as the final radical: see 1 in art,"},{"kind":"arabic","text_bw":"srw","text_ar":"سرو"},{"kind":"text","text":"]. (M, TA.) You say,"},{"kind":"arabic","text_bw":"sarayotu Alv~awoba","text_ar":"سَرَيْتُ الثَّوْبَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sar~ayotuhu","text_ar":"سَرَّيْتُهُ","orth_type":"arrow"},{"kind":"italic_en","text":"I pulled off the garment:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sur~iYa","text_ar":"سُرِّىَ","orth_type":"arrow"},{"kind":"italic_en","text":"It was removed from over him,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"removed from its place:"},{"kind":"text","text":"the teshdeed denotes intensiveness. (TA.)"}],"source_refs":["S","M","K","Msb","Mgh","TA"]}]}}