m":"s"},{"role":"present_1mp","form":"نَرْسُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَسَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَسَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15534"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B3%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to anchor","examples":[{"text":".ميناء بنغازي البحري قد أعيد افتتاحه في الأول من أكتوبر الجاري، بعد أن شهد دخول باخرة “ليدي حلوم” التي كانت أول سفينة شحن ترسو في الميناء، منذ أكتوبر 2014","english":"The port of Banġāzī has been reopened in the 1st of the ongoing October after it has witnessed the entry of the steamer “Lady of Dreams” that has been the first freight ship that has anchored in the harbor, since October 2014."}]},{"pos":"verb","gloss":"to obtain something; to receive the knock down on something","tags":["figuratively"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15534","headword_ar":"رَسَا","root":"rsw","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"arabic","text_bw":"yarosuw","text_ar":"يَرْسُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"rusuw~N","text_ar":"رُسُوٌّ"},{"kind":"text","text":"(M, Msb, K) and"},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stationary, at rest, fixed, fast, firm, steady, steadfast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stable;"},{"kind":"text","text":"(S, M, Msb, K) as also ↓"},{"kind":"arabic","text_bw":"ArsY","text_ar":"ارسى","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"A_irosaA='N","text_ar":"اـِرْسَا=ءٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"trs~Y","text_ar":"ترسّى","orth_type":"arrow"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"Alrsw","text_ar":"الرسو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alrswx","text_ar":"الرسوخ"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"Alr~usuw~u","text_ar":"الرُّسُوُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alr~usuwxu","text_ar":"الرُّسُوخُ"},{"kind":"text","text":"] are nearly the same [in meaning]. (Ham p. 51.) You say,"},{"kind":"arabic","text_bw":"rasaA Aljabalu","text_ar":"رَسَا الجَبَلُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The mountain was firmly based,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firm in its base, upon the ground."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"vabiyrN","text_ar":"ثَبِيرٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^arosaY","text_ar":"مَا اَرْسَى","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"As long as Thebeer"},{"kind":"text","text":"[the mountain so called]"},{"kind":"italic_en","text":"remains"},{"kind":"text","text":"["},{"kind":"italic_en","text":"firm"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in its place."},{"kind":"text","text":"(TA.) [Its being said that this is tropical is app. meant to indicate that the verbs above are properly used only in relation to a ship, in senses explained in what follows; which, however, I doubt.] You say also,"},{"kind":"arabic","text_bw":"rasato qadamuhu","text_ar":"رَسَتْ قَدَمُهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"His foot stood firm in war:"},{"kind":"text","text":"(M:) or"},{"kind":"arabic","text_bw":"rasato A^aqodaAmuhumo fiY AlHarobi","text_ar":"رَسَتْ اَقْدَامُهُمْ فِى الحَرْبِ"},{"kind":"italic_en","text":"Their feet stood firm in war."},{"kind":"text","text":"(S, Msb. *) And"},{"kind":"arabic","text_bw":"rasati Als~afiynapu","text_ar":"رَسَتِ السَّفِينَةُ"},{"kind":"text","text":", (S, M, K,) aor."},{"kind":"arabic","text_bw":"tarosuw","text_ar":"تَرْسُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rusuw~N","text_ar":"رُسُوٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":"(S) [and"},{"kind":"arabic","text_bw":"marosFY","text_ar":"مَرْسًى"},{"kind":"text","text":", as shown below, see 4],"},{"kind":"italic_en","text":"The ship"},{"kind":"text","text":"["},{"kind":"italic_en","text":"anchored; cast anchor; lay at anchor;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"rested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became stationary, upon the anchor:"},{"kind":"text","text":"(T, S, K:) in [some of] the copies of the K [and of the S],"},{"kind":"arabic","text_bw":"EalaY AlbaHori","text_ar":"عَلَى البَحْرِ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"ElY AlA^anojari","text_ar":"على الاَنْجَرِ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"ElY All~anojari","text_ar":"على اللَّنْجَرِ"},{"kind":"text","text":"]: (TA:) or the meaning is, [in some instances,"},{"kind":"italic_en","text":"the ship grounded;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"the lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part of the ship reached the bottom of the water, and she consequently remained stationary."},{"kind":"text","text":"(T, M, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"rasaA AlfaHolu bi$awolihi","text_ar":"رَسَا الفَحْلُ بِشَوْلِهِ"},{"kind":"text","text":"(S, M, K,) (tropical:)"},{"kind":"italic_en","text":"The stallion"},{"kind":"text","text":"["},{"kind":"italic_en","text":"-camel"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaped upon, his"},{"kind":"arabic","text_bw":"$wl","text_ar":"شول"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"she-camels that had passed seven or eight months since the period of their bringing forth"},{"kind":"text","text":"]: (S, TA:) or"},{"kind":"italic_en","text":"brayed to his"},{"kind":"arabic","text_bw":"$wl","text_ar":"شول"},{"kind":"text","text":","},{"kind":"italic_en","text":"and they became motionless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"still:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"brayed to his"},{"kind":"arabic","text_bw":"$wl","text_ar":"شول"},{"kind":"italic_en","text":"when they had dispersed themselves from him, and they turned aside to him, and became motionless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"still."},{"kind":"text","text":"(K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"rasawotu bayona Alqawomi","text_ar":"رَسَوْتُ بَيْنَ القَوْمِ"},{"kind":"text","text":", (S, M, * Msb,) inf. n."},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"I effected an agreement, a harmony, a reconciliation, an accommodation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an adjustment, between the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(S, M, * Msb.)       -A2-"},{"kind":"arabic","text_bw":"rasaA lahu rasowFA","text_ar":"رَسَا لَهُ رَسْوًا"},{"kind":"arabic","text_bw":"mino HadiyvK","text_ar":"مِنْ حَدِيثٍ"},{"kind":"text","text":"(S, * M, K *)"},{"kind":"italic_en","text":"He mentioned to him a part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, of a tradition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"story."},{"kind":"text","text":"(S, M, * K. [See also"},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":"below.]) And"},{"kind":"arabic","text_bw":"rasaA Eanohu","text_ar":"رَسَا عَنْهُ"},{"kind":"arabic","text_bw":"HadiyvFA","text_ar":"حَدِيثًا"},{"kind":"text","text":", (S, M, K,) inf. n."},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He related a tradition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"story, as received from him,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"ascribing it to him."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"rasaA","text_ar":"رَسَا"},{"kind":"arabic","text_bw":"AlHadiyva fiY nafosihi","text_ar":"الحَدِيثَ فِى نَفْسِهِ"},{"kind":"italic_en","text":"He related the tradition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"story, to himself."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"rasaA AlS~awoma","text_ar":"رَسَا الصَّوْمَ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rasowN","text_ar":"رَسْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He intended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed, fasting."},{"kind":"text","text":"(K.)"}],"source_refs":["S","M","Msb","K","T","TA"]}]}}