slations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gin, to tease","examples":[{"text":"نَهَانَا عَنْ كَسْبِ الْأَمَةِ إِلَّا مَا عَمِلَتْ بِيَدِهَا . وَقَالَ هَٰكَذَا بِأَصَابِعِهِ نَحْوَ ٱلْخَبْزِ وَٱلْغَزْلِ وَٱلنَّفْشِ .","english":"He forbade us the earning of a slave-girl save what she obtained by working with her hand. And so he said with his fingers in respect to baking, spinning and ginning."}]},{"pos":"verb","gloss":"to fluff, to ruffle","examples":[{"text":"كان يتكلم بطريقة استغراضية، متباهياً بنفسه وأزيائه وذكائه، فبدا كديك نافش ريشه.","english":"He spoke in a prolix manner, boastful of himself, his outward impression and his intellect, and appeared like a cock ruffling his feathers."}]},{"pos":"verb","gloss":"to pasture at night without a herdsman","tags":["obsolete"]},{"pos":"verb","gloss":"to swell, to expand"},{"pos":"verb","gloss":"to procure, to provide oneself with, to take possession of","tags":["obsolete"]},{"pos":"verb","gloss":"to card, to comb"},{"pos":"noun","gloss":"wool"},{"pos":"noun","gloss":"camels pasturing at night without herdsman","tags":["obsolete"]},{"pos":"noun","gloss":"produce, yield; abundance","tags":["obsolete"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40274","headword_ar":"نَفَشَ","root":"nf$","body":[{"kind":"text","text":", (S, A,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"nafo$N","text_ar":"نَفْشٌ"},{"kind":"text","text":", (S, A, K,)"},{"kind":"italic_en","text":"He separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked asunder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loosened,"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"with his fingers, so that it became spread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sparse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"nf~$","text_ar":"نفّش","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tanofiy$N","text_ar":"تَنْفِيشٌ"},{"kind":"text","text":": (S, K:) or the latter has an intensive signification: and accord. to some, the former signifies"},{"kind":"italic_en","text":"he separated"},{"kind":"text","text":"a thing not difficult to separate, such as cotton and wool: or"},{"kind":"italic_en","text":"he pulled"},{"kind":"page_break","n":2830},{"kind":"text","text":"wool"},{"kind":"italic_en","text":"until its parts became separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked asunder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loosened:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he spread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"a thing. (MF.) You say,"},{"kind":"arabic","text_bw":"nafa$otu AlquTona","text_ar":"نَفَشْتُ القُطْنَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlS~uwfa","text_ar":"الصُّوفَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I separated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked asunder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loosened, with my fingers,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the cotton"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the wool"},{"kind":"text","text":"]. (S, A.)"},{"kind":"arabic","text_bw":"nafo$N","text_ar":"نَفْشٌ"},{"kind":"text","text":"is likewise"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"nadofN","text_ar":"نَدْفٌ"},{"kind":"text","text":"[the"},{"kind":"italic_en","text":"separating and loosening"},{"kind":"text","text":"cotton"},{"kind":"italic_en","text":"by means of a bow and a wooden mallet"},{"kind":"text","text":"]. (TA.) You also say,"},{"kind":"arabic","text_bw":"nafa$a Alr~aTobapa","text_ar":"نَفَشَ الرَّطْبَةَ"},{"kind":"text","text":", inf. n. as above, meaning,"},{"kind":"italic_en","text":"He separated what was collected together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compacted, in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of trefoil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rTbp","text_ar":"رطبة"},{"kind":"text","text":". (TA.) And, of a cock, (T, S, in art."},{"kind":"arabic","text_bw":"bwl","text_ar":"بول"},{"kind":"text","text":".) or of a"},{"kind":"arabic","text_bw":"HubaAraY","text_ar":"حُبَارَى"},{"kind":"text","text":", (K, in that art.,) when about to fight, (T, K. ibid.,)"},{"kind":"arabic","text_bw":"nafa$a buraAy^ilahu","text_ar":"نَفَشَ بُرَايِلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He ruffled the feathers around his neck"},{"kind":"text","text":"]. (T, S, K, ibid.)       -A2-  It is also intrans"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"Antf$","text_ar":"انتفش"},{"kind":"text","text":", q. v. (TA.) ―         -b2-  [And hence,]"},{"kind":"arabic","text_bw":"nafa$ati Alganamu","text_ar":"نَفَشَتِ الغَنَمُ"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":", (S, Msb, K,) accord. to IDrd the former only, but accord. to others the latter also, and in like manner one says of all beasts, though mostly of"},{"kind":"arabic","text_bw":"ganam","text_ar":"غَنَم"},{"kind":"text","text":", (TA,) aor. (S, Msb, K) and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"nafo$N","text_ar":"نَفْشٌ"},{"kind":"text","text":", (Msb, K,) or"},{"kind":"arabic","text_bw":"nufuw$N","text_ar":"نُفُوشٌ"},{"kind":"text","text":", (S,) or both: (TA;) and"},{"kind":"arabic","text_bw":"naf$t","text_ar":"نَفشت"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (IAar. Sgh, K;)"},{"kind":"italic_en","text":"The sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the camels, pastured by night without a pastor:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"without the knowledge of a pastor"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"dispersed themselves"},{"kind":"text","text":"by night: (A:) or"},{"kind":"italic_en","text":"dispersed themselves and pastured by night without knowledge"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the pastor"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats entered among seed-produce:"},{"kind":"text","text":"(TA:) occurring in the Kur, xxi. 78: (S, TA:) the subst. is"},{"kind":"arabic","text_bw":"nafa$N","text_ar":"نَفَشٌ"},{"kind":"text","text":", signifying their"},{"kind":"italic_en","text":"dispersion of themselves and pasturing by night without a pastor."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","A","K","TA","Msb"]}]},"classical_definitions":null}