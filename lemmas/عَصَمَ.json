i","text_ar":"عَصَمَهُ مِنَ الجُوعِ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"The food prevented him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defended him,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"manaEahu","text_ar":"مَنَعَهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"from being hungry."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"EaSamahu A@ll~`hu","text_ar":"عَصَمَهُ ا@للّٰهُ"},{"kind":"text","text":", (Mgh, Msb, TA,) aor. as above, (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"EiSomapN","text_ar":"عِصْمَةٌ"},{"kind":"text","text":", (Mgh,) or this is a simple subst., (Msb,) and the inf. n. is"},{"kind":"arabic","text_bw":"EaSomN","text_ar":"عَصْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"God defended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected, him;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"preserved him;"},{"kind":"text","text":"(Mgh, Msb, TA;)"},{"kind":"arabic","text_bw":"mina Als~uwo'i","text_ar":"مِنَ السُّوْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from evil"},{"kind":"text","text":"], (Mgh,) or"},{"kind":"arabic","text_bw":"mina Almakoruwhi","text_ar":"مِنَ المَكْرُوهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from what was disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"EaSamotuhu","text_ar":"عَصَمْتُهُ"},{"kind":"italic_en","text":"I"},{"kind":"text","text":"["},{"kind":"italic_en","text":"defended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected, him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"preserved him."},{"kind":"text","text":"(S.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"EaSama Alqirobapa","text_ar":"عَصَمَ القِرْبَةَ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaSomN","text_ar":"عَصْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made, to the water-skin, an"},{"kind":"arabic","text_bw":"EiSaAm","text_ar":"عِصَام"},{"kind":"text","text":"; (K, TA;) as also ↓"},{"kind":"arabic","text_bw":"A^aEoSamahaA","text_ar":"اَعْصَمَهَا","orth_type":"arrow"},{"kind":"text","text":": (ISk, S, K, TA:) or the latter signifies, (TA,) or signifies also, (K,)"},{"kind":"italic_en","text":"he bound it with the"},{"kind":"arabic","text_bw":"EiSaAm","text_ar":"عِصَام"},{"kind":"text","text":", (K, TA,) i. e. the ["},{"kind":"italic_en","text":"tie called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"wikaA='","text_ar":"وِكَا=ء"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which is bound round its head to confine the contents"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"EaSama A_ilayohi","text_ar":"عَصَمَ اـِلَيْهِ"},{"kind":"text","text":": see 8.       -A3-"},{"kind":"arabic","text_bw":"EaSama","text_ar":"عَصَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"EaSomN","text_ar":"عَصْمٌ"},{"kind":"text","text":", (S,) signifies also"},{"kind":"arabic","text_bw":"Aikotasaba","text_ar":"اِكْتَسَبَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he sought means of subsistence"},{"kind":"text","text":"]. (S, K.)       -A4-"},{"kind":"arabic","text_bw":"EaSama vaniy~atahu AlgubaAru","text_ar":"عَصَمَ ثَنِيَّتَهُ الغُبَارُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The dust stuck to his central incisor;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EaSaba","text_ar":"عَصَبَ"},{"kind":"text","text":"[q. v.]. (TA.)       -A5-"},{"kind":"arabic","text_bw":"EaSima","text_ar":"عَصِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"EaSamN","text_ar":"عَصَمٌ"},{"kind":"text","text":", (S, * TA,) said of a gazelle, and of a mountain-goat, [and app. of a horse,]"},{"kind":"italic_en","text":"He was such as is termed"},{"kind":"arabic","text_bw":"A^aEoSamu","text_ar":"اَعْصَمُ"},{"kind":"text","text":". (K, TA.)"}],"source_refs":["K","TA","Mgh","Msb","ISk","S"]}]},"classical_definitions":null}