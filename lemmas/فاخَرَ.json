:null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"proud, boasting"},{"pos":"adj","gloss":"outstanding, excellent, prime, superb, magnificent"},{"pos":"adj","gloss":"precious, costly"},{"pos":"adj","gloss":"delightful, delicious"},{"pos":"adj","gloss":"luxurious"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of فَخَرَ (faḵara, “to glory in, to boast, to be proud”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33210","headword_ar":"فَاخِرٌ","root":"fxr","body":[{"kind":"text","text":"an epithet from"},{"kind":"arabic","text_bw":"faxara","text_ar":"فَخَرَ"},{"kind":"text","text":"in the first of the senses expl. above; as also ↓"},{"kind":"arabic","text_bw":"faxuwrN","text_ar":"فَخُورٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) [the former signifies"},{"kind":"italic_en","text":"Glorying; boasting;"},{"kind":"text","text":"&c.: and the latter, the same as] ↓"},{"kind":"arabic","text_bw":"fax~iyrN","text_ar":"فَخِّيرٌ","orth_type":"arrow"},{"kind":"text","text":"one"},{"kind":"italic_en","text":"who glories,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasts, much;"},{"kind":"text","text":"(S, O, TA;) as also ↓"},{"kind":"arabic","text_bw":"fix~iyraA='u","text_ar":"فِخِّيرَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (O, TA:) and ↓"},{"kind":"arabic","text_bw":"fix~iyrapN","text_ar":"فِخِّيرَةٌ","orth_type":"arrow"},{"kind":"text","text":"one"},{"kind":"italic_en","text":"who glories,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasts, very much."},{"kind":"text","text":"(O, * TA.) ―         -b2-  A thing, (S, O, Msb,) or anything, (K,) ["},{"kind":"italic_en","text":"superb, grand;"},{"kind":"text","text":"as though glorying, or boasting;]"},{"kind":"italic_en","text":"good; goodly; excellent; of excellent quality."},{"kind":"text","text":"(S, O, Msb, K.) ―         -b3-  Also (assumed tropical:)  Dates not yet ripe ("},{"kind":"arabic","text_bw":"busorN","text_ar":"بُسْرٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"that grow large, and have no stones:"},{"kind":"text","text":"(S, O, K:) as though they boasted against others. (TA.)"}],"source_refs":["K","O","TA","S","Msb"]}]},"classical_definitions":null}