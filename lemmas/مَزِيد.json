{"lemma":"مَزِيد","slug":"مَزِيد","root":"ز.#.د","root_slug":"ز-_-د","root_link":"/words/roots/ز-_-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَزِيد","root":"زيد","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n18499"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B2%D9%90%D9%8A%D8%AF"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"passive participle of زَادَ (zāda)","tags":["form-of","participle","passive"]},{"pos":"noun","gloss":"more, an extra amount or extent","examples":[{"text":"يَوْمَ نَقُولُ لِجَهَنَّمَ هَلِ ٱمْتَلَأْتِ وَتَقُولُ هَلْ مِن مَزِيدٍ","english":"On the Day We will say to Hell, \"Have you been filled?\" and it will say, \"Are there some more?\""},{"text":"لَهُمْ مَا يَشَاءُونَ فِيهَا وَلَدَيْنَا مَزِيدٌ","english":"They will have whatever they wish therein, and with Us is more."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18499","headword_ar":"مَزِيدٌ","root":"zyd","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":". (S, K.) You say,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"maziyda EalaY maA faEalota","text_ar":"مَزِيدَ عَلَى مَا فَعَلْتَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"laA musotazaAda","text_ar":"لَا مُسْتَزَادَ","orth_type":"arrow"},{"kind":"text","text":", (A, Msb,) both meaning the same [i.e."},{"kind":"italic_en","text":"There is no exceeding what thou hast done:"},{"kind":"text","text":"or rather the latter means"},{"kind":"italic_en","text":"there is no desire for more than thou hast done,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"there is no one of whom is desired more than