m/?s=%D9%85%D9%8E%D8%B1%D9%90%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become sick","examples":[{"text":"وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِ","english":"and when I get sick it is He who cures me"}]},{"pos":"verb","gloss":"to nurse the sick","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of مَرِضَ (mariḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"disease, sickness, illness"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *maraṣ̂- (“to be ill”). Compare Biblical Hebrew נִמְרַץ (nimraṣ, “to be sore”) and Ugaritic 𐎎𐎗𐎕 (mrṣ)."},"ipa":["/ma.ri.dˤa/","/mar.ra.dˤa/","/ma.radˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38477","headword_ar":"مَرِضَ","root":"mrD","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ"},{"kind":"text","text":", (Msb, K,) which latter is a dial. form rarely used, (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, or an animal [of any kind], Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"diseased, disordered, distempered, sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ill;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"in the state termed"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"(S, Msb, K) denoting that change of the constitution or temperament which is described in the explanation of this term below; (K;) as also ↓"},{"kind":"arabic","text_bw":"AmrD","text_ar":"امرض","orth_type":"arrow"},{"kind":"text","text":", expl. by"},{"kind":"arabic","text_bw":"SaAra *aA","text_ar":"صَارَ ذَا"},{"kind":"arabic","text_bw":"maraDK","text_ar":"مَرَضٍ"},{"kind":"text","text":". (K, TA; but not in the CK.) ―         -b2-  [Hence,"},{"kind":"arabic","text_bw":"mariDati AlEayonu","text_ar":"مَرِضَتِ العَيْنُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The eye became languid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languishing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weak:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":":) or, as Golius says, on the authority of Ibn-Maaroof,"},{"kind":"italic_en","text":"was weak from much,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"too much, looking."},{"kind":"text","text":"] ―         -b3-  And"},{"kind":"arabic","text_bw":"mariDati All~ayolapu","text_ar":"مَرِضَتِ اللَّيْلَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The night became dark."},{"kind":"text","text":"(Th, O.) ―         -b4-  [The verb probably has several other tropical significations agreeable with explanations of"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":"which will be found below.]"}],"source_refs":["S","Msb","K"]}]}}