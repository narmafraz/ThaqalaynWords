{"lemma":"ساجِدٌ","slug":"ساجِدٌ","root":"س.ج.د","root_slug":"س-ج-د","root_link":"/words/roots/س-ج-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"ساجِد","root":"سجد","pos":"N","occurrence_count":23},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n18918"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D8%AC%D9%90%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of سَجَدَ (sajada): prostrated","tags":["active","form-of","participle"],"examples":[{"text":"وَعَهِدْنَا إِلَى إِبْرَاهِيمَ وَإِسْمَاعِيلَ أَن طَهِّرَا بَيْتِيَ لِلطَّائِفِينَ وَالْعَاكِفِينَ وَالرُّكَّعِ السُّجُودِ"},{"text":"فَإِذَا سَوَّيْتُهُ وَنَفَخْتُ فِيهِ مِنْ رُوحِي فَقَعُوا لَهُ سَاجِدِينَ"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18918","headword_ar":"سَاجِدٌ","root":"sjd","body":[{"kind":"text","text":"act. part. n. of"},{"kind":"arabic","text_bw":"sajada","text_ar":"سَجَدَ"},{"kind":"text","text":": (L:) ["},{"kind":"italic_en","text":"Being lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive: bending himself down towards the ground:"},{"kind":"text","text":"&c.: and hence,"},{"kind":"italic_en","text":"prostrating himself in prayer; putting his forehead on the ground:"},{"kind":"text","text":"&c.:] pl."},{"kind":"arabic","text_bw":"suj~adN","text_ar":"سُجَّدٌ"},{"kind":"text","text":"(S, A, L) and"},{"kind":"arabic","text_bw":"sujuwdN","text_ar":"سُجُودٌ"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"wa A@doxuluwA A@lobaAba suj~adFA","text_ar":"وَ ا@دْخُلُوا ا@لْبَابَ سُجَّدًا"},{"kind":"text","text":", in the Kur [ii. 55 and vii. 161], means"},{"kind":"italic_en","text":"And enter ye the gate bending down your heads:"},{"kind":"text","text":"(I'Ab, K:) it was a narrow [or low] gate. (I'Ab.) ―         -b3-  And"},{"kind":"arabic","text_bw":"suj~adFA lil~`hi","text_ar":"سُجَّدًا لِلّٰهِ"},{"kind":"text","text":", in the Kur xvi. 50, means (tropical:)"},{"kind":"italic_en","text":"Humbling themselves to God, with subserviency."},{"kind":"text","text":"(TA.) ―         -b4-  You say also"},{"kind":"arabic","text_bw":"$ajarapN saAjidapN","text_ar":"شَجَرَةٌ سَاجِدَةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$ajarN saAjidN","text_ar":"شَجَرٌ سَاجِدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sawaAjidu","text_ar":"سَوَاجِدُ"},{"kind":"text","text":", [this last word being pl. of"},{"kind":"arabic","text_bw":"saAjidapN","text_ar":"سَاجِدَةٌ"},{"kind":"text","text":",] (tropical:)"},{"kind":"italic_en","text":"A tree,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"trees, bending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclining:"},{"kind":"text","text":"(A:) and"},{"kind":"arabic","text_bw":"naxolN sawaAjidu","text_ar":"نَخْلٌ سَوَاجِدُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"palm-trees bending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclining:"},{"kind":"text","text":"(AHn:) and"},{"kind":"arabic","text_bw":"najolapN saAjidapN","text_ar":"نَجْلَةٌ سَاجِدَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"a palm-tree bent by its fruit."},{"kind":"text","text":"(K.) [But it is said that]"},{"kind":"arabic","text_bw":"EulobN sawaAjidu","text_ar":"عُلْبٌ سَوَاجِدُ"},{"kind":"text","text":", occurring in a verse of Lebeed, means (assumed tropical:)"},{"kind":"italic_en","text":"Firmly-rooted"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tall"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"palm-trees."},{"kind":"text","text":"(IAar.) ―         -b5-  And"},{"kind":"arabic","text_bw":"fulaAnN saAjidu","text_ar":"فُلَانٌ سَاجِدُ"},{"kind":"arabic","text_bw":"Almanoxiri","text_ar":"المَنْخِرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one is object, low, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive."},{"kind":"text","text":"(A, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"EayonN saAjidapN","text_ar":"عَيْنٌ سَاجِدَةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A languid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languishing, eye."},{"kind":"text","text":"(A, K.)"}],"source_refs":["L","S","A","AHn"]}]},"classical_definitions":null}