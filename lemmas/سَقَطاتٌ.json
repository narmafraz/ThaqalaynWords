{"lemma":"سَقَطاتٌ","slug":"سَقَطاتٌ","root":"س.ق.ط","root_slug":"س-ق-ط","root_link":"/words/roots/س-ق-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n20084"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%82%D9%8E%D8%B7%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a fall, a tumble; an instance of falling"},{"pos":"noun","gloss":"a slip, a slight mistake"}]},"etymology":{"source":"wiktextract","text":"Instance noun from سَقَطَ (saqaṭa, “to fall”)."},"ipa":["/saq.tˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20084","headword_ar":"سَقْطَةٌ","root":"sqT","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A fall:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a violent fall."},{"kind":"text","text":"(M, TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"A slip, lapse, fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrong action;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"siqaATN","text_ar":"سِقَاطٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"saqoTN","text_ar":"سَقْطٌ","orth_type":"arrow"},{"kind":"text","text":"; which last is also used in a pl. sense: (TA:) or the second ("},{"kind":"arabic","text_bw":"sqAT","text_ar":"سقاط"},{"kind":"text","text":") is pl. of"},{"kind":"arabic","text_bw":"saqoTapN","text_ar":"سَقْطَةٌ"},{"kind":"text","text":": (Msb, K:) as sing., it is an inf. n. of"},{"kind":"arabic","text_bw":"saAqaTa","text_ar":"سَاقَطَ"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"saqoTapN","text_ar":"سَقْطَةٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"a bad word or saying, that swerves from rectitude:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Ewr","text_ar":"عور"},{"kind":"text","text":":) its pl., or one of its pls., is"},{"kind":"arabic","text_bw":"saqaTaAtN","text_ar":"سَقَطَاتٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"laAyaxoluw A^aHadN mino","text_ar":"لَايَخْلُو اَحَدٌ مِنْ"},{"kind":"arabic","text_bw":"saqoTapK","text_ar":"سَقْطَةٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"No one will be free from a slip"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"AlkaAmilu mano Eud~ato saqaTaAtuhu","text_ar":"الكَامِلُ مَنْ عُدَّتْ سَقَطَاتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The perfect is he whose slips are"},{"kind":"text","text":"so few that they may be"},{"kind":"italic_en","text":"counted"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["TA","Msb","K"]}]}}