8%B2%D9%92%D8%A8%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17353","headword_ar":"ازبد","root":"zbd","body":[{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_izobaAdN","text_ar":"اـِزْبَادٌ"},{"kind":"text","text":", (Msb,) said of wine, or beverage, (S,) or of the sea, (A, Msb, K,) &c., (Msb,) or of the sea when in a state of commotion, (S, * A,) and of a cookingpot, and of the mouth of a braying camel, (A,) [&c., see"},{"kind":"arabic","text_bw":"zabadN","text_ar":"زَبَدٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It frothed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast forth froth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam:"},{"kind":"text","text":"(S, * A, Msb, K:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"zb~d","text_ar":"زبّد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tazobiydN","text_ar":"تَزْبِيدٌ"},{"kind":"text","text":", said of milk,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"frothed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foamed;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"had froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, upon it."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,] said of the"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"text","text":"[or lote-tree], (S, A, K,) (tropical:)"},{"kind":"italic_en","text":"It blossomed;"},{"kind":"text","text":"(S, K, TA;) i. e. (TA)"},{"kind":"italic_en","text":"it put forth a white produce like the froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, upon water."},{"kind":"text","text":"(A, TA.) And, said of the"},{"kind":"arabic","text_bw":"qataAdi","text_ar":"قَتَادِ"},{"kind":"text","text":"[or tragacantha], (assumed tropical:)"},{"kind":"italic_en","text":"It put forth its leaf"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xuwSap","text_ar":"خُوصَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and its wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"branch, became strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard, and its rind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outer covering, coalesced, and it blossomed;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"zb~d","text_ar":"زبّد","orth_type":"arrow"},{"kind":"text","text":". (L.) ―         -b3-  Also (tropical:)"},{"kind":"italic_en","text":"It became intensely white."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["S","A","Msb","K","TA"]}]}}