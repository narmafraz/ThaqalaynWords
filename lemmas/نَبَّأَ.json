s_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n39140","n39141","n39146"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%A8%D9%8E%D9%91%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"news, tidings, story","examples":[{"text":"عَمَّ يَتَسَاۤءَلُونَ ۝ عَنِ ٱلنَّبَإِ ٱلۡعَظِيمِ ۝ ٱلَّذِي هُمۡ فِيهِ مُخۡتَلِفُونَ ۝","english":"About what are they asking one another? / About the great news - / That over which they are in disagreement."}]},{"pos":"verb","gloss":"to bark","tags":["obsolete"]},{"pos":"verb","gloss":"to be exalted, to be elevated"},{"pos":"verb","gloss":"to assault, to overwhelm","tags":["obsolete"]},{"pos":"verb","gloss":"to revert, to turn away"},{"pos":"verb","gloss":"to inform, to give news, to notify, to bode, to announce"}]},"etymology":{"source":"wiktextract","text":"Compare نَبَهَ (nabaha), نَبَعَ (nabaʕa), Hebrew נִבֵּא (nibé, “to prophesy, to proclaim”)."},"ipa":["/na.baʔ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39140","headword_ar":"نَبَاَ","root":"nbA^","body":[{"kind":"text","text":". (K,) inf. n."},{"kind":"arabic","text_bw":"nabo'N","text_ar":"نَبْءٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He uttered a low voice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a dog)"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"barked."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"nabaHa","text_ar":"نَبَحَ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"nabaA^a","text_ar":"نَبَاَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nabo'N","text_ar":"نَبْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nubuwo'N","text_ar":"نُبُوْءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated."},{"kind":"text","text":"-A3-"},{"kind":"arabic","text_bw":"nabaA^a Ealayohimo","text_ar":"نَبَاَ عَلَيْهِمْ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"nabo'N","text_ar":"نَبْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nubuwo'N","text_ar":"نُبُوْءٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He assaulted them;"},{"kind":"page_break","n":2753},{"kind":"italic_en","text":"came forth upon them:"},{"kind":"text","text":"(K:) like"},{"kind":"arabic","text_bw":"nabaEa","text_ar":"نَبَعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nabaha","text_ar":"نَبَهَ"},{"kind":"text","text":":"},{"kind":"italic_en","text":"he came upon them."},{"kind":"text","text":"(AZ, S.) [See also"},{"kind":"arabic","text_bw":"naAbiy^N","text_ar":"نَابِيٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"nabaA^a","text_ar":"نَبَاَ"},{"kind":"italic_en","text":"He went forth"},{"kind":"text","text":"from a land to another land. (S, K.) [See"},{"kind":"arabic","text_bw":"naAbiy^N","text_ar":"نَابِيٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"nabaA^ato bihi AlA^aroDu","text_ar":"نَبَاَتْ بِهِ الاَرْضُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jaA='ato bh","text_ar":"جَا=ءَتْ به"},{"kind":"text","text":","},{"kind":"italic_en","text":"The land brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"led him:"},{"kind":"text","text":"(S, L:) [accord. to Golius,"},{"kind":"italic_en","text":"The land brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produced, it:"},{"kind":"text","text":"but it is a phrase well known to the learned among the Arabs in the present day, as similar to"},{"kind":"arabic","text_bw":"naAdaAhu","text_ar":"نَادَاهُ"},{"kind":"arabic","text_bw":"turaAbuhu","text_ar":"تُرَابُهُ"},{"kind":"text","text":"“ his dust, or earth, (i. e. the place of his burial,) called him: ” and the explanation which I have given is confirmed by the citation, in the S, of the following verse, of Hanash Ibn-Málik, immediately after"},{"kind":"arabic","text_bw":"nbA^t bh","text_ar":"نبات به"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"jA't bh","text_ar":"جاءت به"},{"kind":"text","text":":]"},{"kind":"quote","text":"fanafosaka A^aHorizo faA_in~a AlHutuw\n                      \n                     \n                        fa yanobaA^ona biAlmaro'i fiY kul~i waAdo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Then take good care of thyself; for deaths"},{"kind":"text","text":"(of various kinds)"},{"kind":"italic_en","text":"bring"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"lead"},{"kind":"text","text":")"},{"kind":"italic_en","text":"a man into every valley"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"place"},{"kind":"text","text":"): i. e., fate brings him to the place where he is destined to be buried, whereever it be]. (S.) ―         -b4-"},{"kind":"arabic","text_bw":"nabaA^a","text_ar":"نَبَاَ"},{"kind":"text","text":", aor."},{"kind":"text","text":": see 4."}],"source_refs":["K","TA","S","L"]},{"entry_id":"n39141","headword_ar":"نبّا","root":"nbA^","body":[{"kind":"text","text":": see 4."}],"source_refs":[]},{"entry_id":"n39146","headword_ar":"نَبَاٌ","root":"nbA^","body":[{"kind":"italic_en","text":"Information; a piece of information; intelligence; an announcement; news; tidings; a piece of news; an account; a narrative,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narration; a story:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is related from another"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"others:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xabarN","text_ar":"خَبَرٌ"},{"kind":"text","text":": (S, Msb, K:) it is generally held to be syn. with"},{"kind":"arabic","text_bw":"xabarN","text_ar":"خَبَرٌ"},{"kind":"text","text":"; but accord. to Er-Rághib, signifies"},{"kind":"italic_en","text":"an announcement of great utility, from which results either knowledge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a predominance of opinion, and true:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^anobaA='u","text_ar":"اَنْبَا=ءُ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"Aln~abaA^u AlEaZiymu","text_ar":"النَّبَاُ العَظِيمُ"},{"kind":"text","text":"[Kur, lxxviii. 2,] accord. to some,"},{"kind":"italic_en","text":"The Kur-án:"},{"kind":"text","text":"others say,"},{"kind":"italic_en","text":"the resurrection:"},{"kind":"text","text":"and others,"},{"kind":"italic_en","text":"the case of the Prophet."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AlA^anobaA='u","text_ar":"الاَنْبَا=ءُ"},{"kind":"text","text":", in the Kur, xxviii. 66, ("},{"kind":"arabic","text_bw":"faEamiyato Ealayohimu AlA^anobaA='u","text_ar":"فَعَمِيَتْ عَلَيْهِمُ الاَنْبَا=ءُ"},{"kind":"text","text":") signifies"},{"kind":"italic_en","text":"The allegations, pleas,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excuses."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA"]}]}}