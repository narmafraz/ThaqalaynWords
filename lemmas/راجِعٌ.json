{"lemma":"راجِعٌ","slug":"راجِعٌ","root":"ر.ج.ع","root_slug":"ر-ج-ع","root_link":"/words/roots/ر-ج-ع","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"راجِع","root":"رجع","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n14880","n14902"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%AC%D9%90%D8%B9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to review, to reexamine"},{"pos":"adj","gloss":"returning, coming back"},{"pos":"adj","gloss":"traceable (to), ascribable (to)"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb رَجَعَ (rajaʕa, “to return”)."},"ipa":["/raː.d͡ʒiʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14880","headword_ar":"راجع","root":"rjE","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"returned to good"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to evil."},{"kind":"text","text":"(TA.) [See also 6.] ―         -b2-"},{"kind":"arabic","text_bw":"rAjEt Aln~aAqapu","text_ar":"راجعت النَّاقَةُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rijaAEN","text_ar":"رِجَاعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The she-camel returned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reverted, from one kind of pace, which she had been going, to another pace."},{"kind":"text","text":"(K, * TA.) ―         -b3-"},{"kind":"arabic","text_bw":"rAjEhu","text_ar":"راجعهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It returned to him:"},{"kind":"text","text":"said of pain [&c.]. (TA in art."},{"kind":"arabic","text_bw":"Ed","text_ar":"عد"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"rAjE A@moraA^atahu","text_ar":"راجع ا@مْرَاَتَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He returned to his wife,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restored her to himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took her back by marriage"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the marriage-state, after having divorced her;"},{"kind":"text","text":"(see also 6;)]; (S;) and ↓"},{"kind":"arabic","text_bw":"ArtjEhA","text_ar":"ارتجعها","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (TA.) ―         -b5-  [See also a verse cited voce"},{"kind":"arabic","text_bw":"radaAdN","text_ar":"رَدَادٌ"},{"kind":"text","text":"; whence it seems that"},{"kind":"arabic","text_bw":"rAjE","text_ar":"راجع"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He restored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought back,"},{"kind":"text","text":"anything.] ―         -b6-"},{"kind":"arabic","text_bw":"rAjEhu","text_ar":"راجعهُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He endeavoured to turn him"},{"kind":"text","text":"[from, or to, a thing]; syn."},{"kind":"arabic","text_bw":"raAwadahu","text_ar":"رَاوَدَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"raAd~ahu","text_ar":"رَادَّهُ"},{"kind":"text","text":". (L in art."},{"kind":"arabic","text_bw":"rwd","text_ar":"رود"},{"kind":"text","text":".) ―         -b7-"},{"kind":"arabic","text_bw":"rAjEhu AlkalaAma","text_ar":"راجعهُ الكَلَامَ"},{"kind":"text","text":", (S and K in this art., and A and Mgh and Msb in art."},{"kind":"arabic","text_bw":"Hwr","text_ar":"حور"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"fiY AlkalaAmi","text_ar":"فِى الكَلَامِ"},{"kind":"text","text":", (Bd in xviii. 32,) and simply"},{"kind":"arabic","text_bw":"raAjEhu","text_ar":"رَاجعهُ"},{"kind":"text","text":", (Msb in this art., and Jel. in lviii. l,) inf. n."},{"kind":"arabic","text_bw":"muraAjaEapN","text_ar":"مُرَاجَعَةٌ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"rijaAEN","text_ar":"رِجَاعٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He returned him answer for answer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"answers for answers; held a dialogue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"colloquy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conference,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disputation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debate, with him; bandied words with him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAwarahu","text_ar":"حَاوَرَهُ"},{"kind":"text","text":", (A and Mgh and Msb in art."},{"kind":"arabic","text_bw":"Hwr","text_ar":"حور"},{"kind":"text","text":", and Bd in xviii. 32,) [i. e.]"},{"kind":"arabic","text_bw":"HaAwarahu AlkalaAma","text_ar":"حَاوَرَهُ الكَلَامَ"},{"kind":"text","text":"; (TA;) or"},{"kind":"arabic","text_bw":"EaAwadahu","text_ar":"عَاوَدَهُ"},{"kind":"text","text":"; (S and Msb and K in this art.;) or"},{"kind":"arabic","text_bw":"jaAdalahu","text_ar":"جَادَلَهُ"},{"kind":"text","text":". (Jel in lviii. 1.) And"},{"kind":"arabic","text_bw":"rAjEhu","text_ar":"راجعهُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"rAjEhu Alqawola","text_ar":"راجعهُ القَوْلَ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He disputed with him, rebutting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rejecting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repudiating, in reply to him, what he said; he bandied words with him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"raAd~ahu Alqawola","text_ar":"رَادَّهُ القَوْلَ"},{"kind":"text","text":". (A in art."},{"kind":"arabic","text_bw":"rd","text_ar":"رد"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"rAjEhu fiY muhim~aAtihi","text_ar":"راجعهُ فِى مُهِمَّاتِهِ"},{"kind":"italic_en","text":"He held a colloquy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conference,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disputation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debate, with him respecting his affairs of difficulty;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAwarahu","text_ar":"حَاوَرَهُ"},{"kind":"text","text":". (TA.) [And"},{"kind":"arabic","text_bw":"rAjEhu fiY ka*aA","text_ar":"راجعهُ فِى كَذَا"},{"kind":"italic_en","text":"He addressed him repeatedly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time after time, respecting such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"raAjaEuwA Euquwlahumo","text_ar":"رَاجَعُوا عُقُولَهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They consulted their understandings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"minds;"},{"kind":"text","text":"as though they held a colloquy, or conference, or a disputation, or debate, therewith]. (Bd in xxi. 65.) ["},{"kind":"arabic","text_bw":"rAjE","text_ar":"راجع"},{"kind":"text","text":"often signifies"},{"kind":"italic_en","text":"He consulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"referred to,"},{"kind":"text","text":"a person, a book, a passage in a book, &c.]"}],"source_refs":["K","TA","S"]},{"entry_id":"n14902","headword_ar":"رَاجِعٌ","root":"rjE","body":[{"kind":"text","text":"[act. part. n. of 1. Hence the saying,"},{"kind":"arabic","text_bw":"A_in~aA lil~`hi waA_in~aA A_ilayohi raAjiEuwna","text_ar":"اـِنَّا لِلّٰهِ وَاـِنَّا اـِلَيْهِ رَاجِعُونَ"},{"kind":"text","text":", explained above: see 10. ―         -b2-  Also, without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":",] (assumed tropical:)  A woman"},{"kind":"italic_en","text":"who returns to her family in consequence of the death of her husband"},{"kind":"text","text":"(Az, S, Msb, K) or"},{"kind":"italic_en","text":"in consequence of divorcement;"},{"kind":"text","text":"(Az, Msb;) as also ↓"},{"kind":"arabic","text_bw":"muraAjiEN","text_ar":"مُرَاجِعٌ","orth_type":"arrow"},{"kind":"text","text":": (Az, K:) or, accord. to some, (Msb,) she who is divorced [and sent back to her family] is termed"},{"kind":"arabic","text_bw":"maroduwdapN","text_ar":"مَرْدُودَةٌ"},{"kind":"text","text":". (S, Msb.) ―         -b3-  [In like manner without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":",] applied to a she-camel, and to a she-ass, it signifies (assumed tropical:)"},{"kind":"italic_en","text":"That raises her tail, and compresses her two sides"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"quTorayohaA","text_ar":"قُطْرَيْهَا"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and casts forth her urine in repeated discharges, so that she is imagined to be pregnant,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and then fails of fulfilling her"},{"kind":"text","text":"["},{"kind":"italic_en","text":"apparent"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"promise:"},{"kind":"text","text":"(S:) or (assumed tropical:)"},{"kind":"italic_en","text":"that conceives,"},{"kind":"page_break","n":1042},{"kind":"italic_en","text":"and then fails of fulfilling her promise;"},{"kind":"text","text":"because she goes back from what is hoped of her: (TA:) or, applied to a she-camel, (assumed tropical:)"},{"kind":"italic_en","text":"that has appeared to have conceived, and is then found to be not pregnant:"},{"kind":"text","text":"(As:) pl."},{"kind":"arabic","text_bw":"rawaAjiEu","text_ar":"رَوَاجِعُ"},{"kind":"text","text":". (S, TA.) [See also"},{"kind":"arabic","text_bw":"rajaEato","text_ar":"رَجَعَتْ"},{"kind":"text","text":".] ―         -b4-  (assumed tropical:)  A sick man"},{"kind":"italic_en","text":"whose soul"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"health"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"has returned to him after his being debilitated by disease:"},{"kind":"text","text":"and (assumed tropical:)  a man"},{"kind":"italic_en","text":"whose soul"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"health"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"has returned to him after severe and constant illness."},{"kind":"text","text":"(TA.)"}],"source_refs":["Az","S","Msb","K","TA","As"]}]},"classical_definitions":null}