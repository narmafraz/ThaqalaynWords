en":"m","num":"p"},{"role":"present_2mp","form":"تَشْحَذُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْحَذْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْحَذ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْحَذ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْحَذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْحَذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْحَذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْحَذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْحَذُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْحَذُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْحَذْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَحَذْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَحَذْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْحَذ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْحَذ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n21820"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AD%D9%8E%D8%B0%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hone, to grind, to sharpen"},{"pos":"verb","gloss":"to beg on"},{"pos":"verb","gloss":"to hone, to grind, to sharpen","tags":["rare"]},{"pos":"noun","gloss":"verbal noun of شَحَذَ (šaḥaḏa) (form I)","tags":["form-of","noun-from-verb","rare"]}]},"etymology":{"source":"wiktextract","text":"From the root ش ح ذ (š ḥ ḏ). According to Vollers the meaning “to beg” (in Vulgar Arabic often with د (d) and ت (t) for the last consonant) is contaminated from Aramaic שְׁחַד / ܫܗܰܕ (šḥaḏ, “to gift, to bribe”), but Brockelmann deems such a connection impossible as beggars are not bribed and in turn it denotes what they do."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21820","headword_ar":"شَحَذَ","root":"$H*","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$aHo*N","text_ar":"شَحْذٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He sharpened"},{"kind":"text","text":"(S, A, Msb, K) a knife, (S, A, L, K,) and a sword, and the like, (L,) or an iron implement, (Msb), with a whetstone or other similar thing; (TA;) as also ↓"},{"kind":"arabic","text_bw":"A$H*","text_ar":"اشحذ","orth_type":"arrow"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"$H~*","text_ar":"شحّذ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ta$oHiy*N","text_ar":"تَشْحِيذٌ"},{"kind":"text","text":". (KL.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"$aHa*ota EalayonaA lisaAnaka","text_ar":"شَحَذْتَ عَلَيْنَا لِسَانَكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Thou hast sharpened against us thy tongue"},{"kind":"text","text":"]. (A and TA in art."},{"kind":"arabic","text_bw":"rhf","text_ar":"رهف"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Ai$oHa*o lahu garoba *ihonika","text_ar":"اِشْحَذْ لَهُ غَرْبَ ذِهْنِكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Sharpen thou for it the edge of thine intellect"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"$aHa*ahu biEayonihi","text_ar":"شَحَذَهُ بِعَيْنِهِ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"bibaSarihi","text_ar":"بِبَصَرِهِ"},{"kind":"text","text":", (A,) (tropical:)"},{"kind":"italic_en","text":"He looked sharply at him."},{"kind":"text","text":"(K, * TA.) And"},{"kind":"arabic","text_bw":"$aHa*a","text_ar":"شَحَذَ"},{"kind":"arabic","text_bw":"AljuwEu maEidatahu","text_ar":"الجُوعُ مَعِدَتَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Hunger made his stomach keen, and strengthened it,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"and inflamed it."},{"kind":"text","text":"(L, K.) ―         -b3-  Hence also, i. e. from"},{"kind":"arabic","text_bw":"$aHa*a","text_ar":"شَحَذَ"},{"kind":"text","text":"in the sense first expl. above, (Har p. 377,)"},{"kind":"arabic","text_bw":"fulaAnN ya$oHa*u Aln~aAsa","text_ar":"فُلَانٌ يَشْحَذُ النَّاسَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"$aHo*N","text_ar":"شَحْذٌ"},{"kind":"text","text":", K,) (tropical:)"},{"kind":"italic_en","text":"Such a one begs importunately of men:"},{"kind":"text","text":"(A, K, * and Har ubi suprà:) and"},{"kind":"arabic","text_bw":"$aHa*otuhu","text_ar":"شَحَذْتُهُ"},{"kind":"italic_en","text":"I begged importunately of him."},{"kind":"text","text":"(Msb.) ―         -b4-  And"},{"kind":"arabic","text_bw":"$aHa*ahu","text_ar":"شَحَذَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He drove him away;"},{"kind":"text","text":"namely, a man; (K;) as also ↓"},{"kind":"arabic","text_bw":"t$H~*hu","text_ar":"تشحّذهُ","orth_type":"arrow"},{"kind":"text","text":", (CK, and so accord. to the O,) or ↓"},{"kind":"arabic","text_bw":"$H~*hu","text_ar":"شحّذهُ","orth_type":"arrow"},{"kind":"text","text":", (K accord. to the TA,) inf. n."},{"kind":"arabic","text_bw":"ta$oHiy*N","text_ar":"تَشْحِيذٌ"},{"kind":"text","text":". (TA.) [See also 5 below.] And"},{"kind":"arabic","text_bw":"$aHa*otuhu","text_ar":"شَحَذْتُهُ"},{"kind":"text","text":", (O, TA,) inf. n. as above, (K,) (assumed tropical:)"},{"kind":"italic_en","text":"I drove him vehemently."},{"kind":"text","text":"(O, K, * TA.) ―         -b5-"},{"kind":"arabic","text_bw":"$aHo*N","text_ar":"شَحْذٌ"},{"kind":"text","text":"also signifies (assumed tropical:)  The"},{"kind":"italic_en","text":"being angry."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"$aHa*a Ealayohi","text_ar":"شَحَذَ عَلَيْهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was angry with him."},{"kind":"text","text":"(TK.) ―         -b6-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qa$orN","text_ar":"قَشْرٌ"},{"kind":"text","text":"[The act of"},{"kind":"italic_en","text":"paring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peeling,"},{"kind":"text","text":"&c.]. (O, K.) You say,"},{"kind":"arabic","text_bw":"$aHa*ahu","text_ar":"شَحَذَهُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"qa$arahu","text_ar":"قَشَرَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He pared it, peeled it,"},{"kind":"text","text":"&c.]. (TK.)"}],"source_refs":["S","A","Msb","K","L","O","TA"]}]}}