{"lemma":"نَبْشِ","slug":"نَبْشِ","root":"ن.ب.ش","root_slug":"ن-ب-ش","root_link":"/words/roots/ن-ب-ش","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n39234"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%A8%D9%92%D8%B4%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to disinter, to dig up, to claw up, to unearth"},{"pos":"verb","gloss":"to scavenge, to rifle"},{"pos":"noun","gloss":"verbal noun of نَبَشَ (nabaša) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39234","headword_ar":"نَبَشَ","root":"nb$","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"nabo$N","text_ar":"نَبْشٌ"},{"kind":"text","text":", (S, A, Mgh, Msb, K)"},{"kind":"italic_en","text":"He took, drew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulled, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"(Mgh, Msb, K,) a thing, (Msb, TA,) [as] a leguminous plant, (S,) or a thing buried, (Mgh,) or a thing"},{"kind":"italic_en","text":"after burial,"},{"kind":"text","text":"(TA,) [as] a corpse; (S, TA;) whence"},{"kind":"arabic","text_bw":"nab~aA$N","text_ar":"نَبَّاشٌ"},{"kind":"text","text":", q. v.: (S, Mgh:)"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"a thing that was concealed or covered"},{"kind":"italic_en","text":"to come out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to become"},{"kind":"text","text":"apparent. (A, K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"huwa yanobu$u liEiyaAlihi","text_ar":"هُوَ يَنْبُشُ لِعِيَالِهِ"},{"kind":"text","text":", (A, TA,) inf, n. as above, (K, TA,) (tropical:)"},{"kind":"italic_en","text":"He draws forth sustenance hence and thence for his family,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"household:"},{"kind":"text","text":"(A:) or (tropical:)"},{"kind":"italic_en","text":"he gains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeks sustenance, for them."},{"kind":"text","text":"(K, * TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"huwa yanobu$u AlA^asoraAra","text_ar":"هُوَ يَنْبُشُ الاَسْرَارَ"},{"kind":"text","text":", (A, TA,) and"},{"kind":"arabic","text_bw":"AlHadiyva","text_ar":"الحَدِيثَ"},{"kind":"text","text":", inf. n. as above, (K, TA,) (tropical:)"},{"kind":"italic_en","text":"He draws forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elicits, secrets,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"discourse, narration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"information:"},{"kind":"text","text":"(K, * TA:) or"},{"kind":"arabic","text_bw":"naba$otu Als~ir~a","text_ar":"نَبَشْتُ السِّرَّ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"I divulged the secret."},{"kind":"text","text":"(Msb.) ―         -b4-  And"},{"kind":"arabic","text_bw":"AlEuruwqa","text_ar":"العُرُوقَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_inotaba$a","text_ar":"اـِنْتَبَشَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He drew forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extracted, the veins."},{"kind":"text","text":"(A.) ―         -b5-  Also,"},{"kind":"italic_en","text":"He removed,"},{"kind":"text","text":"a thing from over another thing which it covered or concealed; (A, Msb, * K;) and earth from a thing beneath it: (A, Msb: *) whence"},{"kind":"arabic","text_bw":"nab~aA$N","text_ar":"نَبَّاشٌ"},{"kind":"text","text":", q. v. (Msb, K.) ―         -b6-  And hence,"},{"kind":"arabic","text_bw":"naba$a Alqabora","text_ar":"نَبَشَ القَبْرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He uncovered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he rifled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ransacked, the grave"},{"kind":"text","text":"]. (A, Mgh, Msb.)       -A2-  Also,"},{"kind":"italic_en","text":"He dug with the hand;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"nabava","text_ar":"نَبَثَ"},{"kind":"text","text":". (AZ, in S, art."},{"kind":"arabic","text_bw":"nbv","text_ar":"نبث"},{"kind":"text","text":".)"}],"source_refs":["S","Mgh","Msb","A","K","TA"]}]},"classical_definitions":null}