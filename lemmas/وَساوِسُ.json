{"lemma":"وَساوِسُ","slug":"وَساوِسُ","root":"#.س.#.س","root_slug":"_-س-_-س","root_link":"/words/roots/_-س-_-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"وَسْواس","root":"وسوس","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n41912"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%B3%D8%A7%D9%88%D9%90%D8%B3%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of وَسْوَسَ (waswasa) (form Iq)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"temptation, insinuation"},{"pos":"noun","gloss":"Satan, shaitan, the Devil"},{"pos":"noun","gloss":"anxiety, worry"},{"pos":"noun","gloss":"scrupulosity"}]},"etymology":null,"ipa":["/was.waːs/","/wis.waːs/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41912","headword_ar":"وَسْوَاسٌ","root":"ws","body":[{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"wasowasa","text_ar":"وَسْوَسَ"},{"kind":"text","text":"; (S, Msb, K;) signifying, ["},{"kind":"italic_en","text":"Speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talk, that is indistinct:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and confused:"},{"kind":"text","text":"see 1. ―         -b2-  And hence,] The soul's, or mind's, (S, M, Msb, K,) and the devil's, (K,)"},{"kind":"italic_en","text":"prompting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suggestion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talk,"},{"kind":"text","text":"(S, M, Msb, K,)"},{"kind":"italic_en","text":"of what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable, and destitute of good;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"wasowasapN","text_ar":"وَسْوَسَةٌ","orth_type":"arrow"},{"kind":"text","text":"[used as subst., in which case its pl. is"},{"kind":"arabic","text_bw":"wasaAwisu","text_ar":"وَسَاوِسُ"},{"kind":"text","text":", occurring below]. (S, K.) ―         -b3-  [And hence,] (assumed tropical:)"},{"kind":"italic_en","text":"An evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable, idea, imagination,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thought, which bestirs itself in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurs to, the mind."},{"kind":"text","text":"(Msb.) ―         -b4-  And"},{"kind":"page_break","n":2940},{"kind":"text","text":"[by a metonymy,] (assumed tropical:)"},{"kind":"italic_en","text":"A certain disease,"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"melancholia, in which is a doting in the imagination and judgment, a sort of delirium, vulgarly attributed to diabolical prompting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suggestion, but, it is said,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"arising from a predominance of the black bile, attended with confusion of the intellect."},{"kind":"text","text":"(Msb.) ―         -b5-  [And from the primary signification seem to be derived those which here follow.] (assumed tropical:)  The"},{"kind":"italic_en","text":"low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faintly heard, sound of the hunter and the dogs."},{"kind":"text","text":"(S, K.) ―         -b6-  (assumed tropical:)"},{"kind":"italic_en","text":"A low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faint sound"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rustling"},{"kind":"text","text":"] of wind; as also ↓"},{"kind":"arabic","text_bw":"wasowasapN","text_ar":"وَسْوَسَةٌ","orth_type":"arrow"},{"kind":"text","text":". (M.) ―         -b7-  (tropical:)  The"},{"kind":"italic_en","text":"sounds,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"sound,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"of women's ornaments:"},{"kind":"text","text":"(S, M, K:) [the"},{"kind":"italic_en","text":"chinking thereof:"},{"kind":"text","text":"see 1.]       -A2-  Also,"},{"kind":"arabic","text_bw":"AlwasowaAsu","text_ar":"الوَسْوَاسُ"},{"kind":"italic_en","text":"The devil;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"a name of the devil:"},{"kind":"text","text":"(S:) it occurs in verse 4 of the last chap. of the Kur; and is said to mean there"},{"kind":"arabic","text_bw":"*uw AlwasowaAsi","text_ar":"ذُو الوَسْوَاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the prompter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suggester, of what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable, and destitute of good."},{"kind":"text","text":"(M.)"}],"source_refs":["S","M","Msb","K"]}]}}