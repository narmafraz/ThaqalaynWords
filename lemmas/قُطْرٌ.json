: "(KT.) [But this is app. post-classical.]       -A2-"}, {"kind": "arabic", "text_bw": "quTorN", "text_ar": "قُطْرٌ"}, {"kind": "text", "text": "(S, K) and ↓"}, {"kind": "arabic", "text_bw": "quTurN", "text_ar": "قُطُرٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(S)"}, {"kind": "italic_en", "text": "Aloes-wood with which one fumigates."}, {"kind": "text", "text": "(S, K.)"}], "source_refs": ["S", "Msb", "K"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}