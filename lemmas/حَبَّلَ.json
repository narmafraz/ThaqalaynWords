{"lemma":"حَبَّلَ","slug":"حَبَّلَ","root":"ح.ب.ل","root_slug":"ح-ب-ل","root_link":"/words/roots/ح-ب-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَبَّلْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَبَّلْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَبَّلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَبَّلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَبَّلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَبَّلَ","in_corpus":true,"count":17,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَبَّلَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَبَّلا","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَبَّلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَبَّلُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَبَّلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُحَبِّل","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُحَبِّلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُحَبِّلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُحَبِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُحَبِّلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُحَبِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحَبِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَبِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَبِّل","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَبِّل","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَبِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَبِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَبِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَبِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَبِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَبِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَبِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَبَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَبَّلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَبِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَبِّل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":29,"cross_references":{"qac":{"found":true,"lemma_key":"حَبَّلَ","root":"حبل","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n6967","n6968","n6969","n6970"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%A8%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a rope, a cable; a hawser; a cord; a string; a thread","tags":["countable"]},{"pos":"noun","gloss":"a rope, a cable; a hawser; a cord; a string; a thread; something resembling, likened to, or related to a rope (such as a ray, a beam, a jet, a vein, and so on)","tags":["countable"],"examples":[{"text":"وَلَقَدْ خَلَقْنَا ٱلْإِنسَنَ وَنَعْلَمُ مَا تُوَسْوِسُ بِهِۦ نَفْسُهُۥۖ وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنْ حَبْلِ ٱلْوَرِيدِ","english":"We have created man and know what his spirit suggests to him, and We are closer to him than the rope of his [jugular] vein."}]},{"pos":"verb","gloss":"to become pregnant; to conceive","tags":["intransitive"]},{"pos":"verb","gloss":"to make pregnant, to impregnate","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of حَبِلَ (ḥabila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"conception"},{"pos":"noun","gloss":"pregnancy"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ḥabl-."},"ipa":["/ħabl/","/ħa.bi.la/","/ħab.ba.la/","/ħa.bal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6967","headword_ar":"حَبْلٌ","root":"Hbl","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"rasanN","text_ar":"رَسَنٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"A rope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cord"},{"kind":"text","text":"]; (S;)"},{"kind":"italic_en","text":"a certain thing well known;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"a thing with which one ties, binds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"makes fast, a beast &c.;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ribaATN","text_ar":"رِبَاطٌ"},{"kind":"text","text":": (M, K:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"rasanN","text_ar":"رَسَنٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"a halter"},{"kind":"text","text":"]; (M, Msb, K;) as in the Kur cxi. 5; (TA;) and so ↓"},{"kind":"arabic","text_bw":"muHab~alN","text_ar":"مُحَبَّلٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) in the former sense, the pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A^aHobulN","text_ar":"اَحْبُلٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"A^aHobaAlN","text_ar":"اَحْبَالٌ"},{"kind":"text","text":"(M, K) and [of mult.]"},{"kind":"arabic","text_bw":"HibaAlN","text_ar":"حِبَالٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"HubuwlN","text_ar":"حُبُولٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"HibaAlapN","text_ar":"حِبَالَةٌ"},{"kind":"text","text":"(L voce"},{"kind":"arabic","text_bw":"juroHN","text_ar":"جُرْحٌ"},{"kind":"text","text":") [and"},{"kind":"arabic","text_bw":"HubuwlapN","text_ar":"حُبُولَةٌ"},{"kind":"text","text":", agreeably with a usage of the Arabs, which is, to add"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"to any pl. of the measure"},{"kind":"arabic","text_bw":"fiEaAlN","text_ar":"فِعَالٌ"},{"kind":"text","text":"or of that of"},{"kind":"arabic","text_bw":"fuEuwlN","text_ar":"فُعُولٌ"},{"kind":"text","text":", (see"},{"kind":"arabic","text_bw":"HajarN","text_ar":"حَجَرٌ"},{"kind":"text","text":",)] and ↓"},{"kind":"arabic","text_bw":"HabaAy^ilu","text_ar":"حَبَايِلُ","orth_type":"arrow"},{"kind":"text","text":", which is anomalous, as in the phrase"},{"kind":"arabic","text_bw":"HabaAy^ilu All~uw^oluw^i","text_ar":"حَبَايِلُ اللُّوْلُوِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cords of pearls"},{"kind":"text","text":"], occurring in a trad.; or this is a mistranscription for"},{"kind":"arabic","text_bw":"janaAbi*u","text_ar":"جَنَابِذُ"},{"kind":"text","text":", (K, TA, [in the CK"},{"kind":"arabic","text_bw":"HanAy^idu","text_ar":"حَنايِدُ"},{"kind":"text","text":",]) with"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":": (TA:) and in the latter sense, the pl. is"},{"kind":"arabic","text_bw":"HubuwlN","text_ar":"حُبُولٌ"},{"kind":"text","text":". (M, Msb, K.) In a trad. in which it is said that a man's hand is to be cut off for his stealing a"},{"kind":"page_break","n":505},{"kind":"arabic","text_bw":"Habol","text_ar":"حَبْل"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"Hbl","text_ar":"حبل"},{"kind":"text","text":"of a ship may be mean. (Mgh in art."},{"kind":"arabic","text_bw":"byD","text_ar":"بيض"},{"kind":"text","text":".) ―         -b2-  [Hence, (assumed tropical:)"},{"kind":"italic_en","text":"A bond; cause of union;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"link of connexion:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"connexion with another by the bond of love"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friendship"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(S, K, TA;) pl."},{"kind":"arabic","text_bw":"HibaAlN","text_ar":"حِبَالٌ"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"mutual connexion by such a bond."},{"kind":"text","text":"(ISd, Msb, K.) You say,"},{"kind":"arabic","text_bw":"waSala","text_ar":"وَصَلَ"},{"kind":"arabic","text_bw":"fulaAnN fiY Haboli fulaAnK","text_ar":"فُلَانٌ فِى حَبْلِ فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one married his daughter to such a one."},{"kind":"text","text":"(Har p. 223.) And"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"yaxoTubu fiY Haboli fulaAni","text_ar":"يَخْطُبُ فِى حَبْلِ فُلَانِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He aids such a one in seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding, a woman in marriage."},{"kind":"text","text":"(TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a bayonanaA wa bayona","text_ar":"اـِنَّ بَيْنَنَا وَ بَيْنَ"},{"kind":"arabic","text_bw":"Alqawomi HibaAlFA wa naHonu qaATiEuwhaA","text_ar":"القَوْمِ حِبَالًا وَ نَحْنُ قَاطِعُوهَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Verily there is between us and the party a connexion by the bond of love"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friendship"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and we are severing it."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"A_in~ahu lawaAsiEu AlHaboli","text_ar":"اـِنَّهُ لَوَاسِعُ الحَبْلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Verily he is large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liberal, in disposition;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"in the scope of his friendship;"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Day~iqu AlHaboli","text_ar":"ضَيِّقُ الحَبْلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"narrow therein."},{"kind":"text","text":"(TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"A covenant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact:"},{"kind":"text","text":"(S, Msb, K, TA:) (tropical:)"},{"kind":"italic_en","text":"a covenant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an obligation, by which one becomes responsible for the safety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safe-keeping, of a person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing:"},{"kind":"text","text":"(K, TA:) and (tropical:)"},{"kind":"italic_en","text":"a promise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an assurance, of security,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety;"},{"kind":"text","text":"(A 'Obeyd, S, Msb, K, TA;)"},{"kind":"italic_en","text":"such as a man, desiring to make a journey, used"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and still uses"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to take from the chief of a tribe:"},{"kind":"text","text":"(A 'Obeyd, TA:) pl."},{"kind":"arabic","text_bw":"HibaAlN","text_ar":"حِبَالٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"kaAnato bayonahumo HibaAlN faqaTaEuwhaA","text_ar":"كَانَتْ بَيْنَهُمْ حِبَالٌ فَقَطَعُوهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"There were between them covenants, and obligations whereby they were responsible for one another's safety, and they broke them."},{"kind":"text","text":"(TA.) And it is said in the Kur [iii. 108],"},{"kind":"arabic","text_bw":"A_il~aA biHabolK mina A@ll~`hi wa HabolK mina Aln~aAsi","text_ar":"اـِلَّا بِحَبْلٍ مِنَ ا@للّٰهِ وَ حَبْلٍ مِنَ النَّاسِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Unless"},{"kind":"text","text":"[they have]"},{"kind":"italic_en","text":"a covenant from God and a covenant from men:"},{"kind":"text","text":"(Ibn-'Arafeh, TA:) for the unbeliever requires a covenant from God, which consists in his being of those who have a revealed scripture without which he cannot retain his religion nor enjoy protection, and a covenant granted to him by men. (Er-Rághib, TA.) And it is also said in the Kur [iii. 98],"},{"kind":"arabic","text_bw":"waA@EotaSimuwA biHaboli A@ll~`hi","text_ar":"وَا@عْتَصِمُوا بِحَبْلِ ا@للّٰهِ"},{"kind":"text","text":"i. e. (tropical:)  ["},{"kind":"italic_en","text":"And hold ye fast"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the covenant of God:"},{"kind":"text","text":"(TA:) or (tropical:)"},{"kind":"italic_en","text":"the means of approach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"access, unto God;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"the Kur-án, and the Prophet, and intelligence, &c.,"},{"kind":"text","text":"which are the means of obtaining the protection of God; for"},{"kind":"arabic","text_bw":"HabolN","text_ar":"حَبْلٌ"},{"kind":"text","text":"is metaphorically applied to (tropical:)"},{"kind":"italic_en","text":"any means of access to a thing:"},{"kind":"text","text":"(Er-Rághib, TA:) or these words of the Kur mean (tropical:)"},{"kind":"italic_en","text":"and follow ye the Kur-án, and abstain from schism."},{"kind":"text","text":"(A'Obeyd, TA.) And in like manner, the saying of Ibn-Mes'ood,"},{"kind":"arabic","text_bw":"Ealayokumo biHaboli A@ll~`hi","text_ar":"عَلَيْكُمْ بِحَبْلِ ا@للّٰهِ"},{"kind":"text","text":", means (tropical:)"},{"kind":"italic_en","text":"Keep ye to the Book of God;"},{"kind":"text","text":"for it is a security for you, and a covenant, against the punishment of God. (A'Obeyd, TA.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"An elongated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended, tract of sand,"},{"kind":"text","text":"(T, S, M, Mgh, K,)"},{"kind":"italic_en","text":"collected together, abundant, and high:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"arabic","text_bw":"HabolN mina Alr~amoli","text_ar":"حَبْلٌ مِنَ الرَّمْلِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"a long, extended, tract of sand, collected together, and elevated:"},{"kind":"text","text":"(Msb:) [or simply"},{"kind":"italic_en","text":"a long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long and elevated, tract of sand;"},{"kind":"text","text":"likened to a rope, as is indicated in the Mgh:] pl."},{"kind":"arabic","text_bw":"HibaAlN","text_ar":"حِبَالٌ"},{"kind":"text","text":". (TA.) ―         -b5-  [(assumed tropical:)"},{"kind":"italic_en","text":"A long, creeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"twining, stalk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shoot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"branch;"},{"kind":"text","text":"likened to a rope or cord: pl."},{"kind":"arabic","text_bw":"HibaAlN","text_ar":"حِبَالٌ"},{"kind":"text","text":": often occurring in descriptions of plants by AHn and others.] ―         -b6-  See also"},{"kind":"arabic","text_bw":"HabalapN","text_ar":"حَبَلَةٌ"},{"kind":"text","text":". ―         -b7-"},{"kind":"arabic","text_bw":"AlHabolu","text_ar":"الحَبْلُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"wariyd","text_ar":"وَرِيد"},{"kind":"text","text":"; [a name applied to"},{"kind":"italic_en","text":"each of the two carotid arteries,"},{"kind":"text","text":"and sometimes to"},{"kind":"italic_en","text":"each of the two external jugular veins;"},{"kind":"text","text":"] also called"},{"kind":"arabic","text_bw":"Habolu Alwariydi","text_ar":"حَبْلُ الوَرِيدِ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"a vein between the windpipe and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"two sinews called the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EilobaAwaAni","text_ar":"عِلْبَاوَانِ"},{"kind":"text","text":"; (Fr, TA;)"},{"kind":"italic_en","text":"a certain vein in the neck,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"Haloq","text_ar":"حَلْق"},{"kind":"text","text":". (Msb.) ―         -b8-  (assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"EaAtiq","text_ar":"عَاتِق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"part between the shoulder-joint and the neck"},{"kind":"text","text":"]: (K:) or"},{"kind":"arabic","text_bw":"AlHabolu","text_ar":"الحَبْلُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"Habolu AlEaAtiqi","text_ar":"حَبْلُ العَاتِقِ"},{"kind":"text","text":", (TA,) signifies"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"Tariyqap","text_ar":"طَرِيقَة"},{"kind":"text","text":"[app. here meaning, as it does in some other instances,"},{"kind":"italic_en","text":"oblong muscle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is between the neck and the head of the shoulder-blade:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a sinew between the neck and the shoulderjoint:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"Habolu AlEaAtiqi","text_ar":"حَبْلُ العَاتِقِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a bond,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ligament, between the"},{"kind":"arabic","text_bw":"EAtq","text_ar":"عاتق"},{"kind":"italic_en","text":"and the neck;"},{"kind":"text","text":"(T, Msb, TA;) or"},{"kind":"italic_en","text":"between the neck and the shoulderjoint:"},{"kind":"text","text":"(Lth, TA:) or"},{"kind":"italic_en","text":"certain sinews."},{"kind":"text","text":"(S.) ―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"A certain vein,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nerve,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eiroq","text_ar":"عِرْق"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in the fore arm,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"extending from the wrist until it becomes concealed in the shoulder-joint:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"Habolu Al*~iraAEi","text_ar":"حَبْلُ الذِّرَاعِ"},{"kind":"text","text":"is ["},{"kind":"italic_en","text":"a vein,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nerve,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the arm:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"HibaAlu Al*~iraAEayoni","text_ar":"حِبَالُ الذِّرَاعَيْنِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the sinews that appear upon the two fore arms;"},{"kind":"text","text":"and in like manner,"},{"kind":"italic_en","text":"those of a horse."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"huwa EalaY Haboli *iraAEika","text_ar":"هُوَ عَلَى حَبْلِ ذِرَاعِكَ"},{"kind":"text","text":", (S, TA,) a prov., (S,) meaning (tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is near to thee:"},{"kind":"text","text":"(T, S, Sgh:) or"},{"kind":"italic_en","text":"within thy power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reach;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"practicable, to thee;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy to thee."},{"kind":"text","text":"(ISd, Z, TA.) ―         -b10-  Also, (K,) or"},{"kind":"arabic","text_bw":"Habolu AlfaqaAri","text_ar":"حَبْلُ الفَقَارِ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"A certain vein,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nerve,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eiroq","text_ar":"عِرْق"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in the back,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"extending from the beginning thereof to its end."},{"kind":"text","text":"(TA.) ―         -b11-"},{"kind":"arabic","text_bw":"AlHibaAlu fiY Als~aAqi","text_ar":"الحِبَالُ فِى السَّاقِ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"HibaAlu","text_ar":"حِبَالُ"},{"kind":"arabic","text_bw":"Als~aAqayoni","text_ar":"السَّاقَيْنِ"},{"kind":"text","text":", (M,) (assumed tropical:)"},{"kind":"italic_en","text":"The sinews of the two shanks."},{"kind":"text","text":"(M, K.) ―         -b12-"},{"kind":"arabic","text_bw":"AlHibaAlu fiY Al*~akari","text_ar":"الحِبَالُ فِى الذَّكَرِ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"HabaAy^ilu","text_ar":"حَبَايِلُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al*~akari","text_ar":"الذَّكَرِ"},{"kind":"text","text":", (M,) (assumed tropical:)"},{"kind":"italic_en","text":"The veins"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Euruwq","text_ar":"عُرُوق"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the penis."},{"kind":"text","text":"(M, K.) ―         -b13-"},{"kind":"arabic","text_bw":"AlHabolu","text_ar":"الحَبْلُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"The station of the horses collected for a race, before they are let go."},{"kind":"text","text":"(K.) [Probably it was marked by an extended rope; and for that reason was thus called.]       -A2-  Also"},{"kind":"italic_en","text":"Heaviness; weight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weightiness; ponderousness;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"viqalN","text_ar":"ثِقَلٌ"},{"kind":"text","text":". (Az, K.)"}],"source_refs":["M","K","S","Msb","TA","T","Mgh","Lth","Sgh"]},{"entry_id":"n6968","headword_ar":"حُبْلٌ","root":"Hbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HubolapN","text_ar":"حُبْلَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n6969","headword_ar":"حِبْلٌ","root":"Hbl","body":[{"kind":"italic_en","text":"A calamity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortune;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"HabuwlN","text_ar":"حَبُولٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) pl."},{"kind":"arabic","text_bw":"HubuwlN","text_ar":"حُبُولٌ"},{"kind":"text","text":". (S, K.) ISd cites as an ex. the saying of El-Akhtal,"},{"kind":"quote","text":"wa kunotu saliyma Alqalobi Hat~aY A^aSaAbaniY\n                      \n                     \n                        mina All~aAmiEaAti AlmuboriqaAti Hubuwlu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I was sound of heart until calamities befell me from the resplendent females, exhibiting their beauty"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"rajulN HibolN","text_ar":"رَجُلٌ حِبْلٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A learned, sagacious, intelligent man."},{"kind":"text","text":"(IAar, K. *) [And"},{"kind":"arabic","text_bw":"HibolN","text_ar":"حِبْلٌ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"Very intelligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very cunning."},{"kind":"text","text":"Pl."},{"kind":"arabic","text_bw":"A^aHobaAlN","text_ar":"اَحْبَالٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"A_in~ahu laHibolN mino A^aHobaAlihaA","text_ar":"اـِنَّهُ لَحِبْلٌ مِنْ اَحْبَالِهَا"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Verily he is one who possesses much intelligence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much cunning:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"verily he is a gentle manager of cattle."},{"kind":"text","text":"(ISd, K, TA.)"}],"source_refs":["K"]},{"entry_id":"n6970","headword_ar":"حَبَلٌ","root":"Hbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HabalapN","text_ar":"حَبَلَةٌ"},{"kind":"text","text":".       -A2-  It is also an inf. n.; i. e., of"},{"kind":"arabic","text_bw":"Habilato","text_ar":"حَبِلَتْ"},{"kind":"text","text":". (S, Mgh, Msb, K.)       -A3-  And it is also a simple subst.: (K, TA: [in the CK,"},{"kind":"arabic","text_bw":"wAsomu jamoEK","text_ar":"واسْمُ جَمْعٍ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"wA@somN","text_ar":"وا@سْمٌ"},{"kind":"text","text":":]) [i. e.] it also signifies The"},{"kind":"italic_en","text":"fœtus in the womb:"},{"kind":"text","text":"(Mgh:) pl."},{"kind":"arabic","text_bw":"A^aHobaAlN","text_ar":"اَحْبَالٌ"},{"kind":"text","text":". (K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"nahaY Eano Habali","text_ar":"نَهَى عَنْ حَبَلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHabalapi","text_ar":"الحَبَلَةِ","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh,) or"},{"kind":"arabic","text_bw":"nahaY Eano bayoEi Habali AlHabalapi","text_ar":"نَهَى عَنْ بَيْعِ حَبَلِ الحَبَلَةِ"},{"kind":"text","text":", (Msb, K,) i. e."},{"kind":"italic_en","text":"He forbade the selling of the offspring of the offspring"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"in the belly"},{"kind":"text","text":"(Msb, TA) of the she-camel &c.; (Msb;) [i. e.,]"},{"kind":"italic_en","text":"the offspring of the fœtus"},{"kind":"text","text":"(A'Obeyd, S, Msb)"},{"kind":"italic_en","text":"in the belly"},{"kind":"text","text":"of the she-camel [&c.]; (A'Obeyd, Msb;) [i. e.,]"},{"kind":"italic_en","text":"what the fœtus will bring forth, if it be a female;"},{"kind":"text","text":"(Mgh;) the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"AlHblp","text_ar":"الحبلة"},{"kind":"text","text":"being the sign of the fem. gender; (A'Obeyd, Mgh, Msb;) or a sign of intensiveness of the signification: (IAmb, TA:) for the Arabs in the Time of Ignorance used to sell the offspring of the offspring in the bellies (T, M, Msb, TA) of pregnant beasts, (T, Msb,) or of sheep or goats: (M, TA:) or the meaning is,"},{"kind":"italic_en","text":"what is in the belly of the she-camel:"},{"kind":"text","text":"(A'Obeyd, Esh-Sháfi'ee, K:) or"},{"kind":"italic_en","text":"the produce of the grape-vine before it has attained to maturity:"},{"kind":"text","text":"(M, K:) but Suh disapproves of this last explanation, as a mistake occasioned by the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"AlHblp","text_ar":"الحبلة"},{"kind":"text","text":". (TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"Anything that is in another thing:"},{"kind":"text","text":"thus, for instance, the pearl is the"},{"kind":"arabic","text_bw":"Habal","text_ar":"حَبَل"},{"kind":"text","text":"of the oyster-shell; and the wine is the"},{"kind":"arabic","text_bw":"Habal","text_ar":"حَبَل"},{"kind":"text","text":"of the glass bottle. (A, TA.)       -A4-  (tropical:)"},{"kind":"italic_en","text":"Fulness;"},{"kind":"text","text":"(ISd, K, TA; [see"},{"kind":"arabic","text_bw":"Habila","text_ar":"حَبِلَ"},{"kind":"text","text":";]) as also ↓"},{"kind":"arabic","text_bw":"HubaAlN","text_ar":"حُبَالٌ","orth_type":"arrow"},{"kind":"text","text":". (IAar, K.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"Anger:"},{"kind":"text","text":"(K, TA:) (tropical:)"},{"kind":"italic_en","text":"anger and grief;"},{"kind":"text","text":"as in the saying"},{"kind":"arabic","text_bw":"bihi HabalN","text_ar":"بِهِ حَبَلٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"In him is anger and grief:"},{"kind":"text","text":"(Az, ISd, K, TA:) from the same word as meaning the “ pregnancy ” of a woman. (Az, TA.)       -A5-"},{"kind":"arabic","text_bw":"Habalo Habalo","text_ar":"حَبَلْ حَبَلْ"},{"kind":"italic_en","text":"A cry by which sheep or goats are chidden."},{"kind":"text","text":"(Sgh, K.)"}],"source_refs":["Mgh","S","Msb","K","TA","IAmb","T","M","Az","ISd"]}]}}