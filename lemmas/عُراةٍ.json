{"lemma":"عُراةٍ","slug":"عُراةٍ","root":"ع.ر.#","root_slug":"ع-ر-_","root_link":"/words/roots/ع-ر-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n28872","n28880"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D8%B1%D8%A7%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28872","headword_ar":"عَرَاهُ","root":"Erw","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaEoruwhu","text_ar":"يَعْرُوهُ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EarowN","text_ar":"عَرْوٌ"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"AEtrAhu","text_ar":"اعتراهُ","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"He came to him,"},{"kind":"text","text":"(S, Mgh, K,) syn."},{"kind":"arabic","text_bw":"A^ataAhu","text_ar":"اَتَاهُ"},{"kind":"text","text":", (S, Mgh,) and"},{"kind":"arabic","text_bw":"A^alam~a bihi","text_ar":"اَلَمَّ بِهِ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"ga$iyahu","text_ar":"غَشِيَهُ"},{"kind":"text","text":", (K,) or"},{"kind":"italic_en","text":"he repaired to him,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSadahu","text_ar":"قَصَدَهُ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"seeking"},{"kind":"text","text":"(S, Mgh, K)"},{"kind":"italic_en","text":"his beneficence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounty,"},{"kind":"text","text":"(Mgh, K,) or"},{"kind":"italic_en","text":"for the purpose of seeking his gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aid:"},{"kind":"text","text":"(Msb:) or both signify [simply]"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jaA='ahu","text_ar":"جَا=ءَهُ"},{"kind":"text","text":": (Ham pp. 24 and 109:) or"},{"kind":"arabic","text_bw":"Earawotuhu","text_ar":"عَرَوْتُهُ"},{"kind":"text","text":", also, signifies [simply]"},{"kind":"italic_en","text":"I came to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ga$iytuhu","text_ar":"غَشِيتُهُ"},{"kind":"text","text":"; and so"},{"kind":"arabic","text_bw":"Earayotuhu","text_ar":"عَرَيْتُهُ"},{"kind":"text","text":": (K in art."},{"kind":"arabic","text_bw":"ErY","text_ar":"عرى"},{"kind":"text","text":":) and one says,"},{"kind":"arabic","text_bw":"EaraY Alrjl ErypF $adiydapF","text_ar":"عَرَى الرجل عريةً شَدِيدَةً"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ErwpF $dydpF","text_ar":"عروةً شديدةً"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"He came to the man,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon him, with a vehement coming;"},{"kind":"text","text":"for it seems that"},{"kind":"arabic","text_bw":"Alr~ajula","text_ar":"الرَّجُلَ"},{"kind":"text","text":"is meant, and that"},{"kind":"arabic","text_bw":"Earoyap","text_ar":"عَرْيَة"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earowap","text_ar":"عَرْوَة"},{"kind":"text","text":"are inf. ns. of un.]: (TA, immediately after what here next precedes:) and"},{"kind":"arabic","text_bw":"EaraA","text_ar":"عَرَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEoruw","text_ar":"يَعْرُو"},{"kind":"text","text":", also signifies [simply]"},{"kind":"italic_en","text":"he sought"},{"kind":"text","text":"[&c.]: and hence the saying of Lebeed in a verse cited in art."},{"kind":"arabic","text_bw":"vA^r","text_ar":"ثار"},{"kind":"text","text":"[q. v., conj. 8]: (S, * TA:) the pass. part. n. is ↓"},{"kind":"arabic","text_bw":"maEoruw~N","text_ar":"مَعْرُوٌّ","orth_type":"arrow"},{"kind":"text","text":". (S, Msb.) One says also,"},{"kind":"arabic","text_bw":"fulaAnN taEoruwhu AlA^aDoyaAfu","text_ar":"فُلَانٌ تَعْرُوهُ الاَضْيَافُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taEotariyhi","text_ar":"تَعْتَرِيهِ","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Such a one, guests come to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tago$aAhu","text_ar":"تَغْشَاهُ"},{"kind":"text","text":". (S, TA.) And"},{"kind":"arabic","text_bw":"EaraAniY h`*aA AlA^amoru","text_ar":"عَرَانِى هٰذَا الاَمْرُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AiEotaraAniY","text_ar":"اِعْتَرَانِى","orth_type":"arrow"},{"kind":"italic_en","text":"This affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, came upon me;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ga$iyaniY","text_ar":"غَشِيَنِى"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"EaraAhu AlA^amoru","text_ar":"عَرَاهُ الاَمْرُ"},{"kind":"text","text":", (Msb, TA,) aor."},{"kind":"arabic","text_bw":"yaEoruwhu","text_ar":"يَعْرُوهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, came upon him"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ga$iyahu","text_ar":"غَشِيَهُ"},{"kind":"text","text":"), (TA,) and"},{"kind":"italic_en","text":"befell him;"},{"kind":"text","text":"(Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"AEtrAhu","text_ar":"اعتراهُ","orth_type":"arrow"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"EaraAhu Almuhim~u","text_ar":"عَرَاهُ المُهِمُّ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AEtrAhu","text_ar":"اعتراهُ","orth_type":"arrow"},{"kind":"italic_en","text":"The hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult, affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, befell him."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"Ear~ahu","text_ar":"عَرَّهُ"},{"kind":"text","text":"signifies the same. (Ksh in xlviii. 25.) [And in like manner ↓"},{"kind":"arabic","text_bw":"AEtrAhu","text_ar":"اعتراهُ","orth_type":"arrow"},{"kind":"text","text":"said of a malady, and of diabolical possession, &c.,"},{"kind":"italic_en","text":"It befell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betided, him; attacked him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was incident"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incidental, to him."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"EaraAhu Albarodu","text_ar":"عَرَاهُ البَرْدُ"},{"kind":"italic_en","text":"The cold smote him."},{"kind":"text","text":"(TA.)       -A2-        -A3-  See also 2.       -A4-"},{"kind":"arabic","text_bw":"EuriYa","text_ar":"عُرِىَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with what is termed the"},{"kind":"arabic","text_bw":"EurawaA='","text_ar":"عُرَوَا=ء"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"of fever:"},{"kind":"text","text":"(S, K, TA:) and ElFárábee has mentioned, in the “ Deewán el-Adab, ” among verbs of the class of"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoEulu","text_ar":"يَفْعُلُ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"EaraA","text_ar":"عَرَا"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"AlEurawaA='u","text_ar":"العُرَوَا=ءُ"},{"kind":"text","text":": (Har p. 406:) ISd says that the verb mostly used is the former, and its part. n. is ↓"},{"kind":"arabic","text_bw":"maEoruw~N","text_ar":"مَعْرُوٌّ","orth_type":"arrow"},{"kind":"text","text":": but some say that the verb [i. e."},{"kind":"arabic","text_bw":"Euriyat","text_ar":"عُرِيَت"},{"kind":"text","text":"; imperfectly written in my copy of the TA, but cleared from doubt by its being there added that the part. n. is"},{"kind":"arabic","text_bw":"maEoruw~apN","text_ar":"مَعْرُوَّةٌ"},{"kind":"text","text":",] is said of a fever, as meaning"},{"kind":"italic_en","text":"it came with a shivering,"},{"kind":"page_break","n":2028},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trembling."},{"kind":"text","text":"(TA.) ―         -b2-  Also,"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with the tremour of fear."},{"kind":"text","text":"(TA.) ―         -b3-  One says also,"},{"kind":"arabic","text_bw":"EuriYa A_ilaY Al$~aYo'i","text_ar":"عُرِىَ اـِلَى الشَّىْءِ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"He felt a want of the thing"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AisotawoHa$a A_ilayohi","text_ar":"اِسْتَوْحَشَ اـِلَيْهِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"after having sold it."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"Euriytu A_ilaY","text_ar":"عُرِيتُ اـِلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maAlK liY A^a$ad~a AlEurawaA='i","text_ar":"مَالٍ لِى اَشَدَّ العُرَوَا=ءِ","orth_type":"arrow"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"My soul followed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"most vehemently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I felt a most vehement yearning towards,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"property that belonged to me after having sold it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"EuriYa huwaAhu A_ilaY","text_ar":"عُرِىَ هُوَاهُ اـِلَى"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He yearned towards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longed for, such a thing."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","Msb","K","TA"]},{"entry_id":"n28880","headword_ar":"عَرَاةٌ","root":"Erw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EarFA","text_ar":"عَرًا"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"Vehemence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intenseness, of cold:"},{"kind":"text","text":"(S, K; mentioned in the latter in art."},{"kind":"arabic","text_bw":"ErY","text_ar":"عرى"},{"kind":"text","text":":) originally"},{"kind":"arabic","text_bw":"EarowapN","text_ar":"عَرْوَةٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":[]}]},"classical_definitions":null}