"V","occurrence_count":39},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n39003","n39049"],"search_url":"https://lanelexicon.com/?s=%D9%85%D8%A7%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to die"},{"pos":"verb","gloss":"to die","tags":["archaic","dialectal"],"examples":[{"text":"فَأَجَاءَهَا الْمَخَاضُ إِلَىٰ جِذْعِ النَّخْلَةِ قَالَتْ يَا لَيْتَنِي مِتُّ قَبْلَ هَٰذَا وَكُنتُ نَسْيًا مَّنسِيًّا"}]},{"pos":"verb","gloss":"to be empty, to be or become unoccupied (of land, a city, etc.)"},{"pos":"verb","gloss":"to dead end, to have no outlet (of a road)"},{"pos":"verb","gloss":"to be unused, to be untrodden (of a road)"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *mawut-. Cognate with Hebrew מֵת (mét), Aramaic מית (mīt), Tigrinya ሞተ (motä), Egyptian mwt."},"ipa":["/maː.ta/","/moːt/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39003","headword_ar":"مَاتَ","root":"mwt","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamuwtu","text_ar":"يَمُوتُ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"mawotN","text_ar":"مَوْتٌ"},{"kind":"text","text":"; Msb,) and"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":", (originally"},{"kind":"arabic","text_bw":"mawita","text_ar":"مَوِتَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"xaAfa","text_ar":"خَافَ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"xawifa","text_ar":"خَوِفَ"},{"kind":"text","text":", MF) [sec. per."},{"kind":"arabic","text_bw":"mit~a","text_ar":"مِتَّ"},{"kind":"text","text":",] aor."},{"kind":"arabic","text_bw":"yamaAtu","text_ar":"يَمَاتُ"},{"kind":"text","text":", (S, K,) which latter is of the dial. of Teiyi; (TA;) and"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":", (in which the medial radical letter is originally"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"baAEa","text_ar":"بَاعَ"},{"kind":"text","text":", MF) aor."},{"kind":"arabic","text_bw":"yamiytu","text_ar":"يَمِيتُ"},{"kind":"text","text":", (K,) a form which some have disapproved; (MF;) and"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":", (originally"},{"kind":"arabic","text_bw":"mawita","text_ar":"مَوِتَ"},{"kind":"text","text":", Kr,) sec. pers."},{"kind":"arabic","text_bw":"mit~a","text_ar":"مِتَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamuwtu","text_ar":"يَمُوتُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":", (originally"},{"kind":"arabic","text_bw":"dawima","text_ar":"دَوِمَ"},{"kind":"text","text":", Kr,) aor."},{"kind":"arabic","text_bw":"yaduwmu","text_ar":"يَدُومُ"},{"kind":"text","text":", (Kr, Msb, &c.,) and like the sound verbs"},{"kind":"arabic","text_bw":"naEima","text_ar":"نَعِمَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yanoEumu","text_ar":"يَنْعُمُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoDulu","text_ar":"يَفْضُلُ"},{"kind":"text","text":", (TA,) of the class of words in which two dial. forms are intermixed; (Msb;)"},{"kind":"italic_en","text":"He died;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"HayiY","text_ar":"حَيِى"},{"kind":"text","text":". (K,) ―         -b2-  ["},{"kind":"arabic","text_bw":"maAta Eano baniyna wabanaAtK","text_ar":"مَاتَ عَنْ بَنِينَ وَبَنَاتٍ"},{"kind":"italic_en","text":"He died having passed away from,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"leaving behind him, sons and daughters."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"maAta Eano vamaAniyna","text_ar":"مَاتَ عَنْ ثَمَانِينَ"},{"kind":"arabic","text_bw":"sanFp","text_ar":"سَنًة"},{"kind":"italic_en","text":"He died having passed beyond eighty years;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"being eighty years old."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"All~abanu laA yamuwtu","text_ar":"اللَّبَنُ لَا يَمُوتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The milk will not die"},{"kind":"text","text":"], in a saying of 'Omar, in a trad., means, that if a child sucks the milk of a dead woman, it becomes unlawful for him afterwards to marry any of her relations who would be unlawful to him if he sucked her milk while she was living: or it means, that, if milk taken from the breast of a woman is given to a child to drink, and he drinks it, the consequence is the same; that the effect of the milk in producing this consequence is not annulled by its separation from the breast; for whatever is separated from a living being is termed"},{"kind":"arabic","text_bw":"myt","text_ar":"ميت"},{"kind":"text","text":", or dead, except the milk and hair and wool on account of the necessity of making use of these. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"maAtati AlA^aroDu","text_ar":"مَاتَتِ الاَرْضُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mawataAnN","text_ar":"مَوَتَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mawaAtN","text_ar":"مَوَاتٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The land became destitute of cultivation and of inhabitants."},{"kind":"text","text":"(Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(soil)"},{"kind":"italic_en","text":"became deprived of vegetable life."},{"kind":"text","text":"Hence an expression in the Kur, xxx. 18. (Az, Er-Rághib.) ―         -b6-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became deprived of sensation;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"dead as to the senses"},{"kind":"text","text":"]. So in the Kur, xix. 23: [but this appears to me doubtful]. (Az, Er-Rághib.) ―         -b7-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became deprived of the intellectual faculty;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"intellectually dead;"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"ignorant."},{"kind":"text","text":"Hence an expression in the Kur, vi. 122; and another in the Kur, xxvii. 82; and xxx. 51. (Az, Er-Rághib.) ―         -b8-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He became as though dead with grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow, and fear;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he experienced grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow, and fear, that disturbed his life."},{"kind":"text","text":"Hence what is said in the Kur, xiv. 20. (Az, Er-Rághib.) ―         -b9-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still, quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless."},{"kind":"text","text":"(K.) ―         -b10-"},{"kind":"arabic","text_bw":"mAtati Alr~iyH","text_ar":"ماتَتِ الرِّيح"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The wind became still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm."},{"kind":"text","text":"(TA.) ―         -b11-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He slept."},{"kind":"text","text":"(AA, K.) ―         -b12-"},{"kind":"arabic","text_bw":"maAtati Aln~aAru","text_ar":"مَاتَتِ النَّارُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mawotN","text_ar":"مَوْتٌ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"The fire died away;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the ashes of the fire became cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool, and none of its live coals remained."},{"kind":"text","text":"(TA.) ―         -b13-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(heat or cold)"},{"kind":"italic_en","text":"became assuaged."},{"kind":"text","text":"(TA.) ―         -b14-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became dried up by the earth."},{"kind":"text","text":"(TA.) ―         -b15-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(and ↓"},{"kind":"arabic","text_bw":"AstmAt","text_ar":"استمات","orth_type":"arrow"},{"kind":"text","text":", TA.) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a garment, TA,)"},{"kind":"italic_en","text":"wore out; became worn out."},{"kind":"text","text":"(A, K.) ―         -b16-"},{"kind":"arabic","text_bw":"mAt","text_ar":"مات"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a road)"},{"kind":"italic_en","text":"ceased to be passed along."},{"kind":"text","text":"(TA.) ―         -b17-"},{"kind":"arabic","text_bw":"baladN tamuwtu fiyhi Alr~iyHu","text_ar":"بَلَدٌ تَمُوتُ فِيهِ الرِّيحُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country, &c., in which the wind becomes broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loses its force"},{"kind":"text","text":"]. (TA.) ―         -b18-"},{"kind":"arabic","text_bw":"maAta fuwqu Alr~ajuli","text_ar":"مَاتَ فُوقُ الرَّجُلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man slept heavily; became heavy in his sleep."},{"kind":"text","text":"(TA.) ―         -b19-"},{"kind":"arabic","text_bw":"yamuwtu mina AlHasadi","text_ar":"يَمُوتُ مِنَ الحَسَدِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He dies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will die, of envy"},{"kind":"text","text":"]. (TA.) ―         -b20-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became poor; was reduced to poverty: he became a beggar."},{"kind":"text","text":"(TA.) ―         -b21-  (tropical:)"},{"kind":"italic_en","text":"He became base, abject, vile, despicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominious."},{"kind":"text","text":"(TA.) ―         -b22-  (tropical:)"},{"kind":"italic_en","text":"He became extremely aged, old and weak,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decrepit."},{"kind":"text","text":"(TA.) ―         -b23-  (tropical:)"},{"kind":"italic_en","text":"He became disobedient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellious."},{"kind":"text","text":"Iblees is said, in a trad., to be"},{"kind":"arabic","text_bw":"A^aw~alu mano maAta","text_ar":"اَوَّلُ مَنْ مَاتَ"},{"kind":"text","text":"because he was"},{"kind":"italic_en","text":"the first who became disobedient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellious."},{"kind":"text","text":"(TA.) ―         -b24-"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"became lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive, to the truth."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n39049","headword_ar":"مَاتَ","root":"myt","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamiytu","text_ar":"يَمِيتُ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"mwt","text_ar":"موت"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}