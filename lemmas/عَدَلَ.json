{"lemma":"عَدَلَ","slug":"عَدَلَ","root":"ع.د.ل","root_slug":"ع-د-ل","root_link":"/words/roots/ع-د-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَدَلْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَدَلْتِ","in_corpus":true,"count":11,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَدَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَدَلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَدَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَدَلَ","in_corpus":true,"count":8,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَدَلَت","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَدَلا","in_corpus":true,"count":17,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَدَلَتا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَدَلُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَدَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْدِل","in_corpus":true,"count":25,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْدِلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْدِلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْدِلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْدِلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْدِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْدِلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْدِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْدِل","in_corpus":true,"count":17,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْدِل","in_corpus":true,"count":25,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْدِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْدِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْدِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْدِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْدِلُونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْدِلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْدِلْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْدِل","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْدِل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَدَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَدَلْتُ","in_corpus":true,"count":11,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":142,"cross_references":{"qac":{"found":true,"lemma_key":"عَدَلَ","root":"عدل","pos":"V","occurrence_count":14},"wiktextract":{"found":true,"entry_count":13,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":44},"lanes":{"found":true,"entry_ids":["n28317"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AF%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to act justly"},{"pos":"verb","gloss":"to make (someone) equal (بِ (bi) to)"},{"pos":"verb","gloss":"to be equal to, to be equivalent to","tags":["transitive"]},{"pos":"verb","gloss":"to balance","tags":["transitive"]},{"pos":"verb","gloss":"to deviate, to turn away (عَن (ʕan) from)"},{"pos":"verb","gloss":"to make deviate, to cause to turn away"},{"pos":"verb","gloss":"to be just"},{"pos":"verb","gloss":"to act wrongfully"},{"pos":"verb","gloss":"to give judgment according to the right"},{"pos":"verb","gloss":"to make just"},{"pos":"verb","gloss":"to make equal in size or weight, to declare to be equal"},{"pos":"verb","gloss":"to set into the right proportion"},{"pos":"verb","gloss":"to straighten"},{"pos":"verb","gloss":"to lead straight"},{"pos":"verb","gloss":"to weigh rightly","tags":["transitive"]},{"pos":"verb","gloss":"to balance, to adjust, to fix, to rectify"},{"pos":"verb","gloss":"to adapt","tags":["transitive"]},{"pos":"verb","gloss":"to change, to improve","tags":["transitive"]},{"pos":"verb","gloss":"to place (a balance) in equilibrium"},{"pos":"verb","gloss":"to admit (a witness) as lawful"},{"pos":"verb","gloss":"to drink to excess"},{"pos":"verb","gloss":"to grow thick or stout","tags":["Arabic","Modern","Standard"]},{"pos":"verb","gloss":"to modulate"},{"pos":"noun","gloss":"verbal noun of عَدَلَ (ʕadala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"justice, equity","examples":[{"text":"مِنَ الْعَدْلِ","english":"fair"}]},{"pos":"noun","gloss":"righteousness, uprightness, honesty"},{"pos":"noun","gloss":"right measure"},{"pos":"noun","gloss":"compensation"},{"pos":"noun","gloss":"reward"},{"pos":"noun","gloss":"ransom"},{"pos":"noun","gloss":"deviation from what is right, anomaly"},{"pos":"adj","gloss":"just, upright, honest","tags":["invariable"]},{"pos":"adj","gloss":"lawful, admissible","tags":["invariable"]},{"pos":"adj","gloss":"of equal value","tags":["invariable"]},{"pos":"noun","gloss":"verbal noun of عَدِلَ (ʕadila) (form I)","tags":["form-of","invariable","noun-from-verb"]},{"pos":"noun","gloss":"equilibration of the two side loads","tags":["invariable"]},{"pos":"noun","gloss":"equal","tags":["invariable"]},{"pos":"noun","gloss":"of equal weight","tags":["invariable"]},{"pos":"noun","gloss":"of equal value","tags":["invariable"]},{"pos":"noun","gloss":"similar, corresponding","tags":["invariable"]},{"pos":"noun","gloss":"balanced bale of merchandise, half of a counterbalanced load","tags":["invariable"]},{"pos":"noun","gloss":"sack, back","tags":["invariable"]},{"pos":"noun","gloss":"plural of عَادِل (ʕādil)","tags":["form-of","invariable","plural"]},{"pos":"adj","gloss":"masculine plural of عَادِل (ʕādil)","tags":["form-of","invariable","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28317","headword_ar":"عَدَلَ","root":"Edl","body":[{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"(S, * O, * Msb, K, * TA) and"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ"},{"kind":"text","text":"(S, * O, * Msb, K *) and"},{"kind":"arabic","text_bw":"maEodalapN","text_ar":"مَعْدَلَةٌ"},{"kind":"text","text":"(S, * Msb, K *) and"},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuduwlapN","text_ar":"عُدُولَةٌ"},{"kind":"text","text":", (K, * TK,)"},{"kind":"italic_en","text":"He acted equitably, justly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly."},{"kind":"text","text":"(S, O, Msb, K.) So in the phrase"},{"kind":"arabic","text_bw":"Eadala fiY A^amorihi","text_ar":"عَدَلَ فِى اَمْرِهِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his affair,"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":". (Msb.) And so in the phrase"},{"kind":"arabic","text_bw":"Eadala Ealayohi fiY AlqaDiy~api","text_ar":"عَدَلَ عَلَيْهِ فِى القَضِيَّةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"towards him in the judgment"},{"kind":"text","text":"]: (S, O:) and"},{"kind":"arabic","text_bw":"Eadala EalaY Alqawomi","text_ar":"عَدَلَ عَلَى القَوْمِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"he acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"towards the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEodalapN","text_ar":"مَعْدَلَةٌ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"lano tasotaTiyEuwA A^ano","text_ar":"لَنْ تَسْتَطِيعُوا اَنْ"},{"kind":"arabic","text_bw":"taEodiluwA bayona Aln~isaA='i","text_ar":"تَعْدِلُوا بَيْنَ النِّسَا=ءِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"Ye will not be able to act with"},{"kind":"text","text":"perfect"},{"kind":"italic_en","text":"equity between women"},{"kind":"text","text":"], in the Kur [iv. 128], is said to mean, in respect of love, and of"},{"kind":"arabic","text_bw":"jimaAE","text_ar":"جِمَاع"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"below.] ―         -b2-"},{"kind":"arabic","text_bw":"waA_ino","text_ar":"وَاـِنْ"},{"kind":"arabic","text_bw":"taEodilo kul~a EadolK","text_ar":"تَعْدِلْ كُلَّ عَدْلٍ"},{"kind":"text","text":", in the Kur [vi. 69], means"},{"kind":"italic_en","text":"And if it would ransom with every"},{"kind":"text","text":"[degree of]"},{"kind":"italic_en","text":"ransoming:"},{"kind":"text","text":"(T, S, O, Msb, TA:) AO used to say,"},{"kind":"italic_en","text":"and if it would act equitably with every"},{"kind":"text","text":"[degree of]"},{"kind":"italic_en","text":"equitable acting;"},{"kind":"text","text":"but Az says that this is a blunder. (TA.) [See, again,"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"below.] ―         -b3-  ["},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He declined, deviated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away;"},{"kind":"text","text":"and particularly from the right course: thus having a meaning nearly agreeing with that assigned to"},{"kind":"arabic","text_bw":"Eadila","text_ar":"عَدِلَ"},{"kind":"text","text":"in the last sentence of this paragraph.]"},{"kind":"arabic","text_bw":"balo humo qawomN yaEodiluwna","text_ar":"بَلْ هُمْ قَوْمٌ يَعْدِلُونَ"},{"kind":"text","text":", in the Kur [xxvii. 61], means ["},{"kind":"italic_en","text":"Nay but they are a people"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who decline,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviate,"},{"kind":"text","text":"from the truth, and from the right course; i. e., who disbelieve. (O.) And one says,"},{"kind":"arabic","text_bw":"Eadala Eanohu","text_ar":"عَدَلَ عَنْهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and [more com-"},{"kind":"page_break","n":1973},{"kind":"text","text":"monly]"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He declined, deviated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"Eani AlT~ariyqi","text_ar":"عَنِ الطَّرِيقِ"},{"kind":"text","text":", (S, O, Msb,) inf. n."},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He declined,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way;"},{"kind":"text","text":"(S, O, Msb;) as also"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnEdl","text_ar":"انعدل","orth_type":"arrow"},{"kind":"text","text":". (S, O, K. *) And"},{"kind":"arabic","text_bw":"Eadala AlT~ariyqu","text_ar":"عَدَلَ الطَّرِيقُ"},{"kind":"italic_en","text":"The road declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deflected."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eadala AlfaHolu","text_ar":"عَدَلَ الفَحْلُ"},{"kind":"text","text":"(S, O, K)"},{"kind":"arabic","text_bw":"Eani AlA_ibili","text_ar":"عَنِ الاـِبِلِ"},{"kind":"text","text":"(S, O)"},{"kind":"italic_en","text":"The stallion left, left off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desisted from, covering the she-camels;"},{"kind":"text","text":"(S, O, K; *) and so"},{"kind":"arabic","text_bw":"Eani AlD~iraAbi","text_ar":"عَنِ الضِّرَابِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnEdl","text_ar":"انعدل","orth_type":"arrow"},{"kind":"text","text":". (TA.) ["},{"kind":"arabic","text_bw":"Eadala AlfaHola","text_ar":"عَدَلَ الفَحْلَ"},{"kind":"text","text":"see in what follows.] And"},{"kind":"arabic","text_bw":"Eadala A_ilayohi","text_ar":"عَدَلَ اـِلَيْهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He returned to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"Eadalahu","text_ar":"عَدَلَهُ"},{"kind":"text","text":": see 2, in two places. ―         -b2-"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"fulaAnFA bifulaAnK","text_ar":"فُلَانًا بِفُلَانٍ"},{"kind":"italic_en","text":"He made such a one to be equal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"like, to such a one;"},{"kind":"text","text":"(K;) [and] so"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":": (S:) or, accord. to some,"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the rating"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as equal"},{"kind":"text","text":"to a thing of another kind"},{"kind":"italic_en","text":"so as to make"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"the latter. (TA.) One says,"},{"kind":"arabic","text_bw":"Eadalotu h`*aA bih`*aA","text_ar":"عَدَلْتُ هٰذَا بِهٰذَا"},{"kind":"italic_en","text":"I made this to be like"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to stand in the stead of, this."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"birab~ihi","text_ar":"بِرَبِّهِ"},{"kind":"text","text":", (El-Ahmar, TA,) aor."},{"kind":"text","text":", (S, O, TA,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":", ["},{"kind":"arabic","text_bw":"gayorahu","text_ar":"غَيْرَهُ"},{"kind":"text","text":"being understood,]"},{"kind":"italic_en","text":"He made another to be equal with his Lord, and worshipped him."},{"kind":"text","text":"(El-Ahmar, TA.)"},{"kind":"arabic","text_bw":"birab~ihimo yaEodiluwna","text_ar":"بِرَبِّهِمْ يَعْدِلُونَ"},{"kind":"text","text":", in the Kur [vi. 151, and accord. to some in vi. 1], means"},{"kind":"italic_en","text":"Attributing a copartner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copartners, to their Lord."},{"kind":"text","text":"(O. [And the like is said in the S and Msb and TA.]) ―         -b3-"},{"kind":"arabic","text_bw":"Eadalotu A^amotiEapa Albayoti","text_ar":"عَدَلْتُ اَمْتِعَةَ البَيْتِ"},{"kind":"italic_en","text":"I made the goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"furniture, of the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, into equal loads,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to counterbalance one another,"},{"kind":"text","text":"] on the day of departure, or removal. (TA.) And"},{"kind":"arabic","text_bw":"bayona Al$~ayoy^ayoni","text_ar":"بَيْنَ الشَّيْيَيْنِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaAdala","text_ar":"عَادَلَ","orth_type":"arrow"},{"kind":"text","text":"(S, O, TA)"},{"kind":"italic_en","text":"He made an equiponderance to subsist between the two things."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"fulaAnN yaEodilu fulaAnFA","text_ar":"فُلَانٌ يَعْدِلُ فُلَانًا"},{"kind":"italic_en","text":"Such a one is equal to such a one."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"yaEodiluhu","text_ar":"يَعْدِلُهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is like him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Fr, S, O.) [Hence] one says,"},{"kind":"arabic","text_bw":"maA yaEodiluka EinodanaA $aYo'N","text_ar":"مَا يَعْدِلُكَ عِنْدَنَا شَىْءٌ"},{"kind":"italic_en","text":"Nothing stands with us in thy stead."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eadalahu","text_ar":"عَدَلَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, equiponderant to it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"muEaAdalapN","text_ar":"مُعَادَلَةٌ"},{"kind":"text","text":". (TA.) And [hence]"},{"kind":"arabic","text_bw":"Eadalahu fiY AlmaHomili","text_ar":"عَدَلَهُ فِى المَحْمِلِ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He rode with him in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"vehicle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"mHml","text_ar":"محمل"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to counterbalance him"},{"kind":"text","text":"]. (K, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", signifies also"},{"kind":"italic_en","text":"He turned"},{"kind":"text","text":"a thing from its course, direction, or manner of being. (TA.) You say,"},{"kind":"arabic","text_bw":"Eadalotu fulaAnFA Eano Tariyqihi","text_ar":"عَدَلْتُ فُلَانًا عَنْ طَرِيقِهِ"},{"kind":"italic_en","text":"I turned such a one from his road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"laA tuEodalu saAriHatukumo","text_ar":"لَا تُعْدَلُ سَارِحَتُكُمْ"},{"kind":"italic_en","text":"Your pasturing cattle shall not be turned away, nor prevented, from pasturing."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"Eadala AlfaHola","text_ar":"عَدَلَ الفَحْلَ"},{"kind":"text","text":"(K, TA)"},{"kind":"arabic","text_bw":"Eani AlD~iraAbi","text_ar":"عَنِ الضِّرَابِ"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"He removed the stallion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him to withdraw"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desist"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"from covering."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"Eadalotu Ald~aAb~apa A_ilaY mawoDiEi ka*aA","text_ar":"عَدَلْتُ الدَّابَّةَ اـِلَى مَوْضِعِ كَذَا"},{"kind":"italic_en","text":"I turned the beast to such a place."},{"kind":"text","text":"(TA.) [See also two meanings assigned to this verb in the next paragraph, third sentence.]       -A3-"},{"kind":"arabic","text_bw":"Eadula","text_ar":"عَدُلَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ"},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"arabic","text_bw":"EuduwlapN","text_ar":"عُدُولَةٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, O, i. e. a witness, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"text","text":"[q. v.]. (S, O, Msb.)       -A4-"},{"kind":"arabic","text_bw":"Eadila","text_ar":"عَدِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadalN","text_ar":"عَدَلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He acted wrongfully, unjustly, injuriously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tyrannically."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","O","Msb","K","T","TA"]}]}}