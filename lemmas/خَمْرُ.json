{"lemma":"خَمْرُ","slug":"خَمْرُ","root":"خ.م.ر","root_slug":"خ-م-ر","root_link":"/words/roots/خ-م-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَمْر","root":"خمر","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n11469","","n11475","n11476","n11477","n11483"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%85%D9%92%D8%B1%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cover, to hide, to conceal; to veil, to screen, to shroud","tags":["transitive"]},{"pos":"verb","gloss":"to brew, to ferment, to leaven, to cause to rise chemically"},{"pos":"verb","gloss":"to give or serve wine to","tags":["transitive"]},{"pos":"verb","gloss":"to cover, to hide, to conceal; to enveil, to enshroud"},{"pos":"verb","gloss":"to ferment, to leaven, to cause to rise chemically"},{"pos":"noun","gloss":"verbal noun of خَمَرَ (ḵamara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wine"},{"pos":"noun","gloss":"an intoxicating drink, an alcoholic beverage; liquor, spirits","tags":["broadly"]},{"pos":"noun","gloss":"plural of خِمَار (ḵimār)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11469","headword_ar":"خَمَرَ","root":"xmr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"page_break","n":808},{"kind":"italic_en","text":"veiled, covered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed,"},{"kind":"text","text":"a thing; (K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxomiyrN","text_ar":"تَخْمِيرٌ"},{"kind":"text","text":", (Mgh, Msb,) which also signifies"},{"kind":"italic_en","text":"he covered over"},{"kind":"text","text":"a thing; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"A_ixomaArN","text_ar":"اـِخْمَارٌ"},{"kind":"text","text":". (K.) [Hence,]"},{"kind":"arabic","text_bw":"xamarahaA","text_ar":"خَمَرَهَا"},{"kind":"text","text":"[and app. ↓"},{"kind":"arabic","text_bw":"xm~rhA","text_ar":"خمّرها","orth_type":"arrow"},{"kind":"text","text":"also, for the quasi-pass. is"},{"kind":"arabic","text_bw":"txm~rt","text_ar":"تخمّرت"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"Axtmrt","text_ar":"اختمرت"},{"kind":"text","text":","},{"kind":"italic_en","text":"He veiled her with a muffler;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put on her a"},{"kind":"arabic","text_bw":"ximaAr","text_ar":"خِمَار"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"A_inaA='ahu","text_ar":"اـِنَا=ءَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"wajohahu","text_ar":"وَجْهَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He covered over his vessel,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his face."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"bayotahu","text_ar":"بَيْتَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"italic_en","text":"He concealed his house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chamber,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent,"},{"kind":"text","text":"[meaning its interior,]"},{"kind":"italic_en","text":"and ordered it aright."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"AlA^aroDu Ean~iY","text_ar":"الاَرْضُ عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axomaratohu","text_ar":"اَخْمَرَتْهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"min~iY","text_ar":"مِنِّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, concealed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, from me."},{"kind":"text","text":"(K.) And ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He concealed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceived it, in him mind."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"fulaAnN EalaY~a Zin~apF","text_ar":"فُلَانٌ عَلَىَّ ظِنَّةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceived, in his mind a suspicion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil opinion, of me."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"xamara $ahaAdatahu","text_ar":"خَمَرَ شَهَادَتَهُ"},{"kind":"text","text":", (S, Msb,) and ↓"},{"kind":"arabic","text_bw":"xm~rhA","text_ar":"خمّرها","orth_type":"arrow"},{"kind":"text","text":", (A, Mgh,) and ↓"},{"kind":"arabic","text_bw":"AxmrhA","text_ar":"اخمرها","orth_type":"arrow"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He concealed his testimony."},{"kind":"text","text":"(S, A, Mgh, Msb, TA.) And"},{"kind":"arabic","text_bw":"Alxamoru taxomuru AlEaqola","text_ar":"الخَمْرُ تَخْمُرُ العَقْلَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Wine veils"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"obscures"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the intellect;"},{"kind":"text","text":"(K;) and so ↓"},{"kind":"arabic","text_bw":"tuxaAmiruhu","text_ar":"تُخَامِرُهُ","orth_type":"arrow"},{"kind":"text","text":", lit."},{"kind":"italic_en","text":"covers it:"},{"kind":"text","text":"(Msb:) or the latter signifies (assumed tropical:)"},{"kind":"italic_en","text":"Infects it;"},{"kind":"text","text":"[as though acting like leaven; and if so, from"},{"kind":"arabic","text_bw":"xamara AlEajiyna","text_ar":"خَمَرَ العَجِينَ"},{"kind":"text","text":", which see in what follows; nearly the same as “ intoxicates, ” which properly signifies “ empoisons, ” or “ infects with poison; ”] syn."},{"kind":"arabic","text_bw":"tuxaAliTuhu","text_ar":"تُخَالِطُهُ"},{"kind":"text","text":". (S, * K. [See"},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"xamira","text_ar":"خَمِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xamarN","text_ar":"خَمَرٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He became concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hidden;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid, himself;"},{"kind":"text","text":"(S, K;)"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"italic_en","text":"from me;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"xAmr","text_ar":"خامر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"muxaAmarapN","text_ar":"مُخَامَرَةٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":": (K:) or this last signifies"},{"kind":"italic_en","text":"he concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid, himself in a"},{"kind":"arabic","text_bw":"xamar","text_ar":"خَمَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"covert of trees"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"xamira Ean~iY Alxabaru","text_ar":"خَمِرَ عَنِّى الخَبَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The news,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"story, became concealed from me."},{"kind":"text","text":"(S.) And one says to the hyena,"},{"kind":"arabic","text_bw":"A^um~a EaAmirK","text_ar":"اُمَّ عَامِرٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAmiriY","text_ar":"خَامِرِى","orth_type":"arrow"},{"kind":"italic_en","text":"Hide thyself, O Umm-'Ámir:"},{"kind":"text","text":"(S, K:) which is a prov.: (TA:) and is said to be also a phrase used as a surname of the hyena, in the manner of"},{"kind":"arabic","text_bw":"taA^ab~aTa $ar~FA","text_ar":"تَاَبَّطَ شَرًّا"},{"kind":"text","text":". (Ham p. 242.) And"},{"kind":"arabic","text_bw":"HaDaAjiro A^ataAki maA tuHaA*iro","text_ar":"حَضَاجِرْ اَتَاكِ مَا تُحَاذِرْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAmiriY","text_ar":"خَامِرِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Hide thyself, O hyena: what thou fearest has come to thee"},{"kind":"text","text":"]: thus we have found it: (K:) and this is the reading commonly obtaining accord. to the authors on proverbs: (TA:) but it should properly be"},{"kind":"arabic","text_bw":"xaAmirN","text_ar":"خَامِرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"A^ataAka","text_ar":"اَتَاكَ"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"tuHaA*iryna","text_ar":"تُحَاذِرينَ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"xamarN","text_ar":"خَمَرٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"becoming changed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altered, from a former state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"xamira Al$~aYo'u","text_ar":"خَمِرَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing became changed,"},{"kind":"text","text":"&c. (TK.)       -A3-"},{"kind":"arabic","text_bw":"xamara AlEajiyna","text_ar":"خَمَرَ العَجِينَ"},{"kind":"text","text":", (Ks, S, A, Msb, K,) aor."},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (S, Msb, K,) ["},{"kind":"italic_en","text":"He leavened the dough;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"text","text":", (Ks, A,) or"},{"kind":"arabic","text_bw":"xamiyr","text_ar":"خَمِير"},{"kind":"text","text":", (S, A, Msb,)"},{"kind":"italic_en","text":"into the dough;"},{"kind":"text","text":"(Ks, S, A, Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"xm~rhu","text_ar":"خمّرهُ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"he left the dough until it became good"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mature"},{"kind":"text","text":"]; (K;) and in like manner, accord. to the K,"},{"kind":"arabic","text_bw":"AlT~iyna","text_ar":"الطِّينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the clay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mud"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faTara","text_ar":"فَطَرَ"},{"kind":"text","text":"]: or, as in other lexicons,"},{"kind":"arabic","text_bw":"AlT~iyba","text_ar":"الطِّيبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the perfume"},{"kind":"text","text":"]; (TA;) and the like; as also ↓"},{"kind":"arabic","text_bw":"xm~rhu","text_ar":"خمّرهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxomiyrN","text_ar":"تَخْمِيرٌ"},{"kind":"text","text":", in relation to any of these things; and ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"in relation to the first [and probably to the others also]: (K:) and"},{"kind":"arabic","text_bw":"xamara Aln~abiy*a","text_ar":"خَمَرَ النَّبِيذَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he fermented the beverage called"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"he put"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"italic_en","text":"into the"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":". (A.) [Mtr says, in the Mgh,"},{"kind":"arabic","text_bw":"AlEaSiyra","text_ar":"العَصِيرَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xam~ara","text_ar":"خَمَّرَ","orth_type":"arrow"},{"kind":"text","text":"I have not found, nor ↓"},{"kind":"arabic","text_bw":"txm~r","text_ar":"تخمّر","orth_type":"arrow"},{"kind":"text","text":"as its quasi-pass.] ―         -b2-"},{"kind":"arabic","text_bw":"xamarahu","text_ar":"خَمَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"; (Mgh;)"},{"kind":"italic_en","text":"He gave him"},{"kind":"text","text":"(namely, a man, and a beast, such as a horse and the like, TA)"},{"kind":"italic_en","text":"wine"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to drink."},{"kind":"text","text":"(K, * Mgh, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xumira","text_ar":"خُمِرَ"},{"kind":"text","text":", (Mgh, TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He suffered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was affected with,"},{"kind":"arabic","text_bw":"xumaAr","text_ar":"خُمَار"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the remains of intoxication"},{"kind":"text","text":"]. (Mgh, TA.) [See also 5.]       -A4-"},{"kind":"arabic","text_bw":"xamarahu","text_ar":"خَمَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (AA, S,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was ashamed for himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was bashful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy, with respect to him; was abashed at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy of him."},{"kind":"text","text":"(AA, S, K. *)"}],"source_refs":["TA","K","Mgh","Msb","S","A","Ks","AA"]},{"entry_id":"n11475","headword_ar":"خَمْرٌ","root":"xmr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Wine:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grape-wine"},{"kind":"text","text":":]"},{"kind":"italic_en","text":"what intoxicates, of the expressed juice of grapes:"},{"kind":"text","text":"(ISd, K:) or the"},{"kind":"italic_en","text":"juice of grapes when it has effervesced, and thrown up froth, and become freed therefrom, and still:"},{"kind":"text","text":"(Mgh:) or it has a common application to"},{"kind":"italic_en","text":"intoxicating expressed juice of anything:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"any intoxicating thing, that clouds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obscures,"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"covers,"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the intellect;"},{"kind":"text","text":"as some say: (Mgh, * Msb: [but see what follows:]) and the general application is the more correct, because"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":"was forbidden when there was not in El-Medeeneh any"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":"of grapes; the beverage of its inhabitants being prepared only from dates in their green and small state, or full-grown but unripe, or fresh and ripe, or dried: (K, * TA:) or the arguing thus, from this fact alone, requires consideration: (MF:) AHn says, it is (assumed tropical:)"},{"kind":"italic_en","text":"sometimes prepared from grains:"},{"kind":"text","text":"but ISd holds this to be an improper signification: (TA:) it is also sometimes applied to the (assumed tropical:)"},{"kind":"italic_en","text":"beverage called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":"is sometimes applied to wine expressed from grapes: (L in art."},{"kind":"arabic","text_bw":"nb*","text_ar":"نبذ"},{"kind":"text","text":":) applied to (tropical:)"},{"kind":"italic_en","text":"expressed juice from which"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":"["},{"kind":"italic_en","text":"properly so called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is made,"},{"kind":"text","text":"[i. e., to"},{"kind":"italic_en","text":"must,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfermented"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":",] it is tropical: it is so used in a trad. in which"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":"is said to have been sold by [a companion of Mohammad named] Samurah:"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":"[in its proper acceptation] is so called because it veils ("},{"kind":"arabic","text_bw":"taxomuru","text_ar":"تَخْمُرُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"tasoturu","text_ar":"تَسْتُرُ"},{"kind":"text","text":",) the intellect: (K:) or because it infects ("},{"kind":"arabic","text_bw":"tuxaAmiru","text_ar":"تُخَامِرُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"tuxaAliTu","text_ar":"تُخَالِطُ"},{"kind":"text","text":",) the intellect: (S, K:) [as though acting like leaven: (see 1:)] so said 'Omar: (TA:) or because it is left until it has become mature [and fermented]; (K;) or until its odour has changed: (IAar, S:) [see 8:] the proper application of the root is to denote “ covering, ” and “ commingling in a hidden manner: ” (Sgh, Er-Rághib, TA:) it is of the fem. gender, and sometimes masc.: (Msb, K:) you say"},{"kind":"arabic","text_bw":"huwa Alxamoru","text_ar":"هُوَ الخَمْرُ"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"hiYa Alxamoru","text_ar":"هِىَ الخَمْرُ"},{"kind":"text","text":":"},{"kind":"page_break","n":809},{"kind":"text","text":"but As does not allow it to be masc.: (Msb:) and ↓"},{"kind":"arabic","text_bw":"xamorapN","text_ar":"خَمْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) [or"},{"kind":"italic_en","text":"a kind of wine:"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xamorapN","text_ar":"خَمْرَةٌ"},{"kind":"text","text":"are like"},{"kind":"arabic","text_bw":"tamorN","text_ar":"تَمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"text","text":"; [the former a coll. gen. n., and the latter its n. un.;] (S;) and"},{"kind":"arabic","text_bw":"xamorapN","text_ar":"خَمْرَةٌ"},{"kind":"text","text":"[thus] signifies"},{"kind":"italic_en","text":"some wine;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"a portion of"},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":": (Msb:) the pl. of"},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"xumuwrN","text_ar":"خُمُورٌ"},{"kind":"text","text":". (S, Msb.) You say [also]"},{"kind":"arabic","text_bw":"SirofN","text_ar":"صِرْفٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xamorapN","text_ar":"خَمْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Some pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, wine;"},{"kind":"text","text":"using a masc. epithet, contr. to rule]. (S.) ―         -b2-  [Hence the saying,]"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"Einoda fulaAnK xal~N walaA xamorN","text_ar":"عِنْدَ فُلَانٍ خَلٌّ وَلَا خَمْرٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"maA huwa bixal~K walaA xamorK","text_ar":"مَا هُوَ بِخَلٍّ وَلَا خَمْرٍ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"Such a one,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"possesses neither good nor evil:"},{"kind":"text","text":"(S, K:) [or"},{"kind":"italic_en","text":"neither evil nor good:"},{"kind":"text","text":"for] AA says that some of the Arabs make"},{"kind":"arabic","text_bw":"Alxamoru","text_ar":"الخَمْرُ"},{"kind":"text","text":"to be"},{"kind":"italic_en","text":"good,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alxal~u","text_ar":"الخَلُّ"},{"kind":"text","text":"to be"},{"kind":"italic_en","text":"evil;"},{"kind":"text","text":"and some of them make"},{"kind":"arabic","text_bw":"Alxmr","text_ar":"الخمر"},{"kind":"text","text":"to be"},{"kind":"italic_en","text":"evil,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alxl~","text_ar":"الخلّ"},{"kind":"text","text":"to be"},{"kind":"italic_en","text":"good."},{"kind":"text","text":"(Har p. 153.) ―         -b3-"},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"Grapes;"},{"kind":"text","text":"(AHn, M, K;) in the dial. of ElYemen:) (M:) like as"},{"kind":"arabic","text_bw":"EinabN","text_ar":"عِنَبٌ"},{"kind":"text","text":"signifies “ wine ” in that dial. (AHn, TA in art."},{"kind":"arabic","text_bw":"Enb","text_ar":"عنب"},{"kind":"text","text":".) It is said in the Kur [xii. 36],"},{"kind":"arabic","text_bw":"A_in~iY A^araAniY A^aEoSiru xamorFA","text_ar":"اـِنِّى اَرَانِى اَعْصِرُ خَمْرًا"},{"kind":"italic_en","text":"Verily I thought myself pressing grapes:"},{"kind":"text","text":"(ISd:) or the meaning is,"},{"kind":"italic_en","text":"pressing out wine"},{"kind":"text","text":"from grapes. (Ibn- 'Arafeh.)"}],"source_refs":["ISd","K","Mgh","TA","MF","S","IAar","Msb","M"]},{"entry_id":"n11476","headword_ar":"خَمَرٌ","root":"xmr","body":[{"kind":"italic_en","text":"A covert of trees &c."},{"kind":"text","text":": (ISk, S, Mgh, K:) or"},{"kind":"italic_en","text":"a place where the ground is eaten away by a torrent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an oblong tract of sand collected together and elevated, forming a place for concealment:"},{"kind":"text","text":"(ISk, S:) and"},{"kind":"italic_en","text":"a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavity, in which a wolf conceals himself:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"tangled trees."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"tawaAraY AlS~ayodu min~iY fiY xamari AlwaAdiY","text_ar":"تَوَارَى الصَّيْدُ مِنِّى فِى خَمَرِ الوَادِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The game,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wild animal"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"animals, concealed itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"themselves, from me in the covert,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of the valley"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"huwa yadib~u lahu AlD~araA='a wa yamo$iY","text_ar":"هُوَ يَدِبُّ لَهُ الضَّرَا=ءَ وَ يَمْشِى"},{"kind":"arabic","text_bw":"lahu Alxamara","text_ar":"لَهُ الخَمَرَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He creeps to him in the thicket,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place overgrown with trees; and he walks to him in the covert of trees,"},{"kind":"text","text":"&c.: see Freytag's Arab. Prov. 913]: speaking of a man when he deceives, or circumvents, his companion. (S.) And"},{"kind":"arabic","text_bw":"jaA='anaA","text_ar":"جَا=ءَنَا"},{"kind":"arabic","text_bw":"EalaY xamorK","text_ar":"عَلَى خَمْرٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"ElY ximorapK","text_ar":"على خِمْرَةٍ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He came to us secretly; unexpectedly; clandestinely."},{"kind":"text","text":"(K.) ―         -b2-  Hence, (S,)"},{"kind":"arabic","text_bw":"xamarN","text_ar":"خَمَرٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xumaArN","text_ar":"خُمَارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xamaArN","text_ar":"خَمَارٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"xamorapN","text_ar":"خَمْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) (assumed tropical:)"},{"kind":"italic_en","text":"A crowding,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"congregation,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and multitude,"},{"kind":"text","text":"of men or people. (S, K.) You say,"},{"kind":"arabic","text_bw":"Aln~aAsi","text_ar":"النَّاسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"daxala fiY xamaAri","text_ar":"دَخَلَ فِى خَمَارِ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xamaArihimo","text_ar":"خَمَارِهِمْ","orth_type":"arrow"},{"kind":"text","text":", dial. vars. of"},{"kind":"arabic","text_bw":"gumaAr","text_ar":"غُمَار"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gamaAr","text_ar":"غَمَار"},{"kind":"text","text":", i. e. (tropical:)"},{"kind":"italic_en","text":"He entered among the crowding and multitude of the men"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people;"},{"kind":"text","text":"(S;) and in like manner,"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xamarotihimo","text_ar":"خَمَرْتِهِمْ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gamarotihimo","text_ar":"غَمَرْتِهِمْ"},{"kind":"text","text":"; (TA;) as also"},{"kind":"arabic","text_bw":"fY xamarihimo","text_ar":"فى خَمَرِهِمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gamarihimo","text_ar":"غَمَرِهِمْ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"gmr","text_ar":"غمر"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"among such"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a crowd"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the people as hid him."},{"kind":"text","text":"(ISk, S.)"}],"source_refs":["ISk","S","Mgh","K"]},{"entry_id":"n11477","headword_ar":"خَمِرٌ","root":"xmr","body":[{"kind":"text","text":"A place"},{"kind":"italic_en","text":"abounding with coverts of the description termed"},{"kind":"arabic","text_bw":"xamar","text_ar":"خَمَر"},{"kind":"text","text":"; (IAar, S, K;) a place"},{"kind":"italic_en","text":"concealing by dense trees."},{"kind":"text","text":"(TA.)       -A2-  (assumed tropical:)  A man"},{"kind":"italic_en","text":"infected,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"muxaAmarN","text_ar":"مُخَامَرٌ"},{"kind":"text","text":", (Sh, IAar, S,)"},{"kind":"italic_en","text":"by a disease:"},{"kind":"text","text":"(TA:) thought by ISd to be a possessive epithet: (TA:) or"},{"kind":"italic_en","text":"in the last stage of the remains of intoxication."},{"kind":"text","text":"(S.) [See also"},{"kind":"arabic","text_bw":"maxomuwrN","text_ar":"مَخْمُورٌ"},{"kind":"text","text":".])"}],"source_refs":["Sh","IAar","S","TA"]},{"entry_id":"n11483","headword_ar":"خِمِرٌّ","root":"xmr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ximaArN","text_ar":"خِمَارٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}