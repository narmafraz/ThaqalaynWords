:true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n40616"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%87%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"breast"}]},"etymology":{"source":"wiktextract","text":"From Middle Persian ʾnʾhyt' (anāhīd, “Anahita, Venus, a goddess of fertility in the Iranian pantheon”). نَاهِد (nāhid, “buxom, full, swelling (said of a female breast)”) is the original within this root formula."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40616","headword_ar":"نَهَدَ","root":"nhd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, Msb, K,) and"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"nuhuwdN","text_ar":"نُهُودٌ"},{"kind":"text","text":", (S, L, &c.,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a girl's or woman's breast)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, swelling, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant:"},{"kind":"text","text":"(S, L, Msb, K:) or"},{"kind":"italic_en","text":"became full."},{"kind":"text","text":"(Munjid of Kr.) [See also"},{"kind":"arabic","text_bw":"kaEaba","text_ar":"كَعَبَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"faluka","text_ar":"فَلُكَ"},{"kind":"text","text":";"},{"kind":"page_break","n":2857},{"kind":"text","text":"and see also"},{"kind":"arabic","text_bw":"naAhidN","text_ar":"نَاهِدٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"nahadato","text_ar":"نَهَدَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"nh~dt","text_ar":"نهّدت","orth_type":"arrow"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"tanohiydN","text_ar":"تَنْهِيدٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman [or girl])"},{"kind":"italic_en","text":"came to have swelling, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant, breasts."},{"kind":"text","text":"(L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"nahadati Alqirobapu","text_ar":"نَهَدَتِ القِرْبَةُ"},{"kind":"italic_en","text":"The skin became nearly full."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"nahadati Ald~alowu","text_ar":"نَهَدَتِ الدَّلْوُ"},{"kind":"arabic","text_bw":"Almilo'a","text_ar":"المِلْءَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nahodN","text_ar":"نَهْدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The bucket became nearly full."},{"kind":"text","text":"(A 'Obeyd, L, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"nahada","text_ar":"نَهَدَ"},{"kind":"text","text":", (M, L, K,) aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"nuhuwdN","text_ar":"نُهُودٌ"},{"kind":"text","text":", (M, L,) and"},{"kind":"arabic","text_bw":"nahodN","text_ar":"نَهْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"rose;"},{"kind":"text","text":"(M, L;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nahaDa","text_ar":"نَهَضَ"},{"kind":"text","text":"; (K;) or the latter signifies “ he rose from sitting; ” whereas the former signifies “ he rose under any circumstances. ” (M, L.) ―         -b6-"},{"kind":"arabic","text_bw":"nahada lahu","text_ar":"نَهَدَ لَهُ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (Th, L,)"},{"kind":"italic_en","text":"He rose to him."},{"kind":"text","text":"(Th, L.) ―         -b7-"},{"kind":"arabic","text_bw":"nahada","text_ar":"نَهَدَ"},{"kind":"arabic","text_bw":"liloEaduw~i","text_ar":"لِلْعَدُوِّ"},{"kind":"text","text":", (A 'Obeyd, L, K,) and"},{"kind":"arabic","text_bw":"A_ilaY AlEaduw~i","text_ar":"اـِلَى العَدُوِّ"},{"kind":"text","text":", (S, L, Msb,) aor."},{"kind":"text","text":", (S, L, Msb,) and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"nahodN","text_ar":"نَهْدٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"nahadN","text_ar":"نَهَدٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He attacked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assaulted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rose and hastened and went forth to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, the enemy;"},{"kind":"text","text":"(S, * L, Msb;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nahaDa","text_ar":"نَهَضَ"},{"kind":"text","text":": (S, L:)"},{"kind":"italic_en","text":"he directed his course towards the enemy, and commenced fighting with them."},{"kind":"text","text":"(A 'Obeyd, L, K.) ―         -b8-"},{"kind":"arabic","text_bw":"nahada","text_ar":"نَهَدَ"},{"kind":"text","text":", (IKtt,) inf. n."},{"kind":"arabic","text_bw":"nuhuwdN","text_ar":"نُهُودٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, IKtt)"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"text","text":",) in any case. (IKtt, K.)       -A2-"},{"kind":"arabic","text_bw":"nuhuwdN","text_ar":"نُهُودٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"being strong."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"nahuda","text_ar":"نَهُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nuhuwdapN","text_ar":"نُهُودَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, large and tall:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"bulky and strong:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly in body and limbs, and tall:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"goodly, large in body and limbs, fleshy and tall."},{"kind":"text","text":"(K.)       -A3-"},{"kind":"arabic","text_bw":"nahada","text_ar":"نَهَدَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Anhd","text_ar":"انهد","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He honoured"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EaZ~ama","text_ar":"عَظَّمَ"},{"kind":"text","text":") a gift. (IKtt, K.)"}],"source_refs":["S","L","Msb","K","M","Th","IKtt"]}]},"classical_definitions":null}