:"liyudoHiDuwA bihi AlHaq~a","text_ar":"لِيُدْحِضُوا بِهِ الحَقَّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"That they may,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"might, rebut thereby the truth."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","TA","S","Msb","K"]}]},"classical_definitions":null}