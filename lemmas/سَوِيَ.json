m","num":"s"},{"role":"present_1ms","form":"أَسْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":115,"cross_references":{"qac":{"found":true,"lemma_key":"سَوِيَ","root":"سوي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n21346","n21355","n21356","n21359","n21360"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%88%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to equalize"},{"pos":"verb","gloss":"to make even, to straighten"},{"pos":"verb","gloss":"to settle (a dispute)"},{"pos":"verb","gloss":"to smooth"},{"pos":"verb","gloss":"to reconcile (بَيْنَ (bayna))"},{"pos":"verb","gloss":"to regularize"},{"pos":"verb","gloss":"to restore","examples":[{"text":"أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ (٣) بَلَىٰ قَـٰدِرِینَ عَلَىٰۤ أَن نُّسَوِّیَ بَنَانَهُۥ (٤)","english":"3. Thinketh man that We shall not assemble his bones? 4. Yea, verily. We are Able to restore his very fingers!"}]},{"pos":"noun","gloss":"verbal noun of سَوِيَ (sawiya) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"used in the construct state in ways which are translated into Standard Average European languages as prepositions like except, but, short of; of very frequent occurrence (followed by genitive)","examples":[{"text":"لَا أُحِبُّ سِوَى تِلْكَ الْمَرْأَةِ.","english":"I love no one but that woman."},{"text":"مَن سَيَفْتَدِي طُهْرَ الْعِرَاقِ سِوَانَا؟","english":"Who will save the purity of the Iraq if not us?"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21346","headword_ar":"سَوِىَ","root":"swY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasowaY","text_ar":"يَسْوَى"},{"kind":"text","text":": see 3, in two places.       -A2-  [Accord. to Golius,"},{"kind":"arabic","text_bw":"sawaY","text_ar":"سَوَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"siwFY","text_ar":"سِوًى"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"He intended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proposed to himself:"},{"kind":"text","text":"this he says as on the authority of the KL, in which only the inf. n. is mentioned with the explanation"},{"kind":"arabic","text_bw":"qSd","text_ar":"قصد"},{"kind":"arabic","text_bw":"wA=hnG krdn","text_ar":"وا=هنگ كردن"},{"kind":"text","text":": and to this, Freytag adds the authority of Meyd; and also that the verb governs the thing which is its objective complement in the accus. case. In the S and other lexicons of good repute, I find the meaning of"},{"kind":"arabic","text_bw":"qaSada","text_ar":"قَصَدَ"},{"kind":"text","text":"assigned to"},{"kind":"arabic","text_bw":"AisotawaY","text_ar":"اِسْتَوَى"},{"kind":"text","text":"followed by"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"; but in none to"},{"kind":"arabic","text_bw":"sawaY","text_ar":"سَوَى"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n21355","headword_ar":"سُوًى","root":"swY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sawaA='N","text_ar":"سَوَا=ءٌ"},{"kind":"text","text":", in seven places: ―         -b2-  and see also"},{"kind":"arabic","text_bw":"siwFY","text_ar":"سِوًى"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n21356","headword_ar":"سِوًى","root":"swY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sawaA'N","text_ar":"سَوَاءٌ"},{"kind":"text","text":", in seven places. ―         -b2-  Also, and likewise ↓"},{"kind":"arabic","text_bw":"suwFY","text_ar":"سُوًى","orth_type":"arrow"},{"kind":"text","text":", (Akh, S, Msb, Mughnee, K,) and ↓"},{"kind":"arabic","text_bw":"sawaA='N","text_ar":"سَوَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (Akh, S, M, Mughnee, K,) and ↓"},{"kind":"arabic","text_bw":"siwaA='N","text_ar":"سِوَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (Mughnee,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"makaAnN","text_ar":"مَكَانٌ"},{"kind":"text","text":", (Mughnee,) or"},{"kind":"arabic","text_bw":"gayorN","text_ar":"غَيْرٌ"},{"kind":"text","text":", (Akh, S, M, Msb, Mughnee, K,) accord. to different authorities: each used as an epithet, and as denoting exception, like"},{"kind":"arabic","text_bw":"gayor","text_ar":"غَيْر"},{"kind":"text","text":"; accord. to Ez-Zejjájee and Ibn-Málik, used in the same sense and manner as"},{"kind":"arabic","text_bw":"gayor","text_ar":"غَيْر"},{"kind":"text","text":": but accord. to Sb and the generality of authorities, an adv. n. of place, always in the accus. case, except in instances of necessity: (Mughnee:) one says,"},{"kind":"arabic","text_bw":"EinodiY rajulN siwaY zayodK","text_ar":"عِنْدِى رَجُلٌ سِوَى زَيْدٍ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"badala zayodK","text_ar":"بَدَلَ زَيْدٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"makaAna zayodK","text_ar":"مَكَانَ زَيْدٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I have with me a man instead of Zeyd"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the place of Zeyd"},{"kind":"text","text":"]: (Ham p. 570, and TA: *) [but] one says [also]"},{"kind":"arabic","text_bw":"mararotu birajulK siwaAka","text_ar":"مَرَرْتُ بِرَجُلٍ سِوَاكَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"suwaAka","text_ar":"سُوَاكَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sawaAy^ika","text_ar":"سَوَايِكَ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"gayorika","text_ar":"غَيْرِكَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I passed by a man other than thee"},{"kind":"text","text":"]: (S:) and ↓"},{"kind":"arabic","text_bw":"jaA='aniY sawaAw^uka","text_ar":"جَا=ءَنِى سَوَاوُكَ","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"siwaAk","text_ar":"سِوَاك"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"Other than thou came to me"},{"kind":"text","text":"], using it as an agent; and ↓"},{"kind":"arabic","text_bw":"raA^ayotu sawaA='aka","text_ar":"رَاَيْتُ سَوَا=ءَكَ","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"siwaAka","text_ar":"سِوَاكَ"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"I saw other than thee"},{"kind":"text","text":"], using it as an objective complement: and ↓"},{"kind":"arabic","text_bw":"maA jaA='aniY A^aHadN sawaA='aka","text_ar":"مَا جَا=ءَنِى اَحَدٌ سَوَا=ءَكَ","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"siwaAka","text_ar":"سِوَاكَ"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"None except thou came to me"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"maA jaA='aniY A^aHadN","text_ar":"مَا جَا=ءَنِى اَحَدٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sawaAw^uka","text_ar":"سَوَاوُكَ","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"siwaAka","text_ar":"سِوَاكَ"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"None other than thou came to me"},{"kind":"text","text":"]: (Mughnee:) and"},{"kind":"arabic","text_bw":"qaSadotu Alqawoma siwaY","text_ar":"قَصَدْتُ القَوْمَ سِوَى"},{"kind":"arabic","text_bw":"zayodK","text_ar":"زَيْدٍ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"gayora zayodK","text_ar":"غَيْرَ زَيْدٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I betook myself to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, others than Zeyd,"},{"kind":"text","text":"which is virtually the same as"},{"kind":"italic_en","text":"except Zeyd"},{"kind":"text","text":"]: (Msb:) and"},{"kind":"arabic","text_bw":"lay^ino faEalota *aAka waA^anaA siwaAka layaA^otiyan~aka min~iY","text_ar":"لَيِنْ فَعَلْتَ ذَاكَ وَاَنَا سِوَاكَ لَيَاْتِيَنَّكَ مِنِّى"},{"kind":"arabic","text_bw":"maA takorahu","text_ar":"مَا تَكْرَهُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"If thou do that"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when I am in a land other than thy land,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what thou dislikest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatest, shall assuredly come to thee from me."},{"kind":"text","text":"] (Ibn-Buzurj, TA.) ―         -b3-  The Arabs also said,"},{"kind":"arabic","text_bw":"Eaqoluka","text_ar":"عَقْلُكَ"},{"kind":"arabic","text_bw":"siwaAka","text_ar":"سِوَاكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Thine intellect has departed from thee."},{"kind":"text","text":"(IAar, M.)       -A2-  The strangest of the meanings of"},{"kind":"arabic","text_bw":"siwaY","text_ar":"سِوَى"},{"kind":"text","text":", in this sense with the short alif and with kesr, is"},{"kind":"arabic","text_bw":"qaSodN","text_ar":"قَصْدٌ"},{"kind":"text","text":". (Mughnee.)"},{"kind":"arabic","text_bw":"siwaY Al$~aYo'i","text_ar":"سِوَى الشَّىْءِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"qaSoduhu","text_ar":"قَصْدُهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The tendency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"direction, of the thing"},{"kind":"text","text":"]. (M.) And one says,"},{"kind":"arabic","text_bw":"qaSadotu siwaY","text_ar":"قَصَدْتُ سِوَى"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"qaSadotu qaSodahu","text_ar":"قَصَدْتُ قَصْدَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I tended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook myself, in the direction of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, such a one"},{"kind":"text","text":"]. (S, K. * [In the CK, and in my MS. copy of the K,"},{"kind":"arabic","text_bw":"sawaAhu","text_ar":"سَوَاهُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"siwaAhu","text_ar":"سِوَاهُ"},{"kind":"text","text":".]) And hence, (Mughnee,) a poet says, (namely, Keys Ibn-El-Khateem, TA,)"},{"kind":"quote","text":"walaA^aSorifan~a siwaY Hu*ayofapa midoHatiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I will surely turn towards Hodheyfeh my eulogy"},{"kind":"text","text":"]. (S, Mughnee.)"}],"source_refs":["S","Msb"]},{"entry_id":"n21359","headword_ar":"سَوِىٌّ","root":"swY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sawaA='N","text_ar":"سَوَا=ءٌ"},{"kind":"text","text":", in the former half of the paragraph, in six places."}],"source_refs":[]},{"entry_id":"n21360","headword_ar":"سُوَىٌّ","root":"swY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sawaA='N","text_ar":"سَوَا=ءٌ"},{"kind":"text","text":", in the middle of the paragraph."}],"source_refs":[]}]}}