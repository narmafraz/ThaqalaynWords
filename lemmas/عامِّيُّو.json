{"lemma":"عامِّيُّو","slug":"عامِّيُّو","root":"ع.م.م","root_slug":"ع-م-م","root_link":"/words/roots/ع-م-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n30470","n31091"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%85%D9%90%D9%91%D9%8A%D9%8F%D9%91%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"public, concerning all"},{"pos":"adj","gloss":"general"},{"pos":"adj","gloss":"common, vulgar"},{"pos":"adj","gloss":"colloquial"},{"pos":"adj","gloss":"plebeian"},{"pos":"adj","gloss":"ignorant"}]},"etymology":{"source":"wiktextract","text":"عَامَّة (ʕāmma, “common people, the public”) + ـِيّ (-iyy), from the root ع م م (ʕ m m); compare عَامّ (ʕāmm, “general”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30470","headword_ar":"عَامِّىٌّ","root":"Em","body":[{"kind":"italic_en","text":"Of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to, the"},{"kind":"arabic","text_bw":"EaAm~ap","text_ar":"عَامَّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"common people; common;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vulgar;"},{"kind":"text","text":"often applied to a word, or phrase]. (Msb.)"}],"source_refs":[]},{"entry_id":"n31091","headword_ar":"عَامِيٌّ","root":"Ewm","body":[{"kind":"text","text":"a rel. n., from"},{"kind":"arabic","text_bw":"EaAmN","text_ar":"عَامٌ"},{"kind":"text","text":"; (Msb, TA;)"},{"kind":"italic_en","text":"A year old."},{"kind":"text","text":"(TA in arts."},{"kind":"arabic","text_bw":"Hwl","text_ar":"حول"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dwl","text_ar":"دول"},{"kind":"text","text":", &c.) And applied to a plant as meaning"},{"kind":"italic_en","text":"A year old, and therefore dry."},{"kind":"text","text":"(Msb, TA. *) It is also applied to a [vestige, or relic, of a dwelling, such as is termed]"},{"kind":"arabic","text_bw":"rasom","text_ar":"رَسْم"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Talal","text_ar":"طَلَل"},{"kind":"text","text":", as meaning"},{"kind":"italic_en","text":"Over which a year has passed."},{"kind":"text","text":"(TA.) And it is applied, in a trad., as an epithet to the"},{"kind":"arabic","text_bw":"HanoZal","text_ar":"حَنْظَل"},{"kind":"text","text":"[or colocynth, meaning"},{"kind":"italic_en","text":"That is of service in the year of drought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"barrenness"},{"kind":"text","text":"]; because it is procured, or prepared [as an article of food], in the year of drought, or barrenness. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}