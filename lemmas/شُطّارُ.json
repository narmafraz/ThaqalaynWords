{"lemma":"شُطّارُ","slug":"شُطّارُ","root":"ش.ط.ر","root_slug":"ش-ط-ر","root_link":"/words/roots/ش-ط-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n22364"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8F%D8%B7%D9%91%D8%A7%D8%B1%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22364","headword_ar":"شَاطِرٌ","root":"$Tr","body":[{"kind":"text","text":"[One"},{"kind":"italic_en","text":"who withdraws far away from his family;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breaks off from them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quits them, in anger:"},{"kind":"text","text":"(see 1, last sentence:) or] one"},{"kind":"italic_en","text":"who disagrees with his family,"},{"kind":"text","text":"(Msb,) and"},{"kind":"italic_en","text":"who wearies them by his wickedness"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"and baseness"},{"kind":"text","text":"(Msb)"},{"kind":"italic_en","text":"and guile:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xaliyEN","text_ar":"خَلِيعٌ"},{"kind":"text","text":"[meaning as above, and having other similar meanings; generally"},{"kind":"italic_en","text":"vitious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"immoral; bad, evil, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischievous"},{"kind":"text","text":"]: (A:) accord. to some, it is post-classical: Aboo-Is-hák says that it signifies one"},{"kind":"italic_en","text":"who takes a wrong course:"},{"kind":"text","text":"it is also expl. as signifying one"},{"kind":"italic_en","text":"who outstrips;"},{"kind":"text","text":"like the [messenger called]"},{"kind":"arabic","text_bw":"bariyd","text_ar":"بَرِيد"},{"kind":"text","text":", who takes a long journey in a short space of time: and hence, [as a conventional term of the mystics,] it is applied to one"},{"kind":"italic_en","text":"who outstrips, and is quick, in attaining nearness to God:"},{"kind":"text","text":"or as meaning one"},{"kind":"italic_en","text":"who has wearied his family, and withdrawn far from them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"n spirit"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"though with them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"bodily"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"because of their inviting him to carnal lusts, and accustomed ways"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the world"},{"kind":"text","text":"]: (TA:) [in the present day, it is applied to"},{"kind":"italic_en","text":"a sharper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clever thief:"},{"kind":"text","text":"and to"},{"kind":"italic_en","text":"any clever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning, person:"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"$uT~aArN","text_ar":"شُطَّارٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb","S","K","TA","A"]}]}}