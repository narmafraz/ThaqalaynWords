:["n18582","n21316"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%88%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to entice, to tempt, to make covet"},{"pos":"name","gloss":"Seoul (the capital city of South Korea)"}]},"etymology":{"source":"wiktextract","text":"From Korean 서울 (seoul)."},"ipa":["/soːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18582","headword_ar":"سُوْلٌ","root":"sA^l","body":[{"kind":"text","text":", (S, M, K;) also pronounced"},{"kind":"arabic","text_bw":"suwlN","text_ar":"سُولٌ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (S, K,) ["},{"kind":"italic_en","text":"A petition;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a request;"},{"kind":"text","text":"meaning]"},{"kind":"italic_en","text":"a thing that people ask"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beg;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"a thing that one has asked"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begged;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"suw^olapN","text_ar":"سُوْلَةٌ","orth_type":"arrow"},{"kind":"text","text":", (IJ, M, K,) which is likewise pronounced"},{"kind":"arabic","text_bw":"suwlapN","text_ar":"سُولَةٌ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"suw^uwlN","text_ar":"سُوُولٌ","orth_type":"arrow"},{"kind":"text","text":"; (Har p. 422; [or this is app. pl. of"},{"kind":"arabic","text_bw":"suw^olN","text_ar":"سُوْلٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"buruwjN","text_ar":"بُرُوجٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"burojN","text_ar":"بُرْجٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"buruwdN","text_ar":"بُرُودٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"burodN","text_ar":"بُرْدٌ"},{"kind":"text","text":", &c.;]) [and ↓"},{"kind":"arabic","text_bw":"saA^olapN","text_ar":"سَاْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"saA^alapN","text_ar":"سَاَلَةٌ"},{"kind":"text","text":", as will be shown by what follows;] and ↓"},{"kind":"arabic","text_bw":"masow^uwlN","text_ar":"مَسْوُولٌ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) [and ↓"},{"kind":"arabic","text_bw":"masoA^alapN","text_ar":"مَسْاَلَةٌ","orth_type":"arrow"},{"kind":"text","text":":] see 4: the first of these said by Z to be of the measure"},{"kind":"arabic","text_bw":"fuEolN","text_ar":"فُعْلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"EurofN","text_ar":"عُرْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nukorN","text_ar":"نُكْرٌ"},{"kind":"text","text":". (TA.) Thus in the Kur [xx. 36],"},{"kind":"arabic","text_bw":"qado A^uwtiyta suw^olaka yaA muwsaY","text_ar":"قَدْ اُوتِيتَ سُوْلَكَ يَا مُوسَى"},{"kind":"italic_en","text":"Thou hast been granted thy petition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the thing that thou hast asked, O Moses."},{"kind":"text","text":"(S, M, TA.) In the saying ↓"},{"kind":"arabic","text_bw":"Aall~`hum~a A^aEoTinaA saA^alaAtinaA","text_ar":"اَللّٰهُمَّ اَعْطِنَا سَاَلَاتِنَا","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O God, grant Thou us our petitions"},{"kind":"text","text":"], mentioned by Aboo- 'Alee on the authority of AZ, the inf. n. is used as a subst., properly so termed, and is therefore pluralized. (M.)"}],"source_refs":["S","K","IJ","M"]},{"entry_id":"n21316","headword_ar":"سُولٌ","root":"swl","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"masoA^alapN","text_ar":"مَسْاَلَةٌ"},{"kind":"text","text":"[as signifying"},{"kind":"italic_en","text":"A petition;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a request;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"a thing that is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has been, asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begged;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"suw^olN","text_ar":"سُوْلٌ"},{"kind":"text","text":"]; (TA;) as also ↓"},{"kind":"arabic","text_bw":"suwlapN","text_ar":"سُولَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;) each, (TA,) a dial. var. of the word with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (K, TA: [but it is also said in the latter that"},{"kind":"arabic","text_bw":"suw^olN","text_ar":"سُوْلٌ"},{"kind":"text","text":"is the original of"},{"kind":"arabic","text_bw":"suwlN","text_ar":"سُولٌ"},{"kind":"text","text":"because the readers of the Kur-án read the word with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"in chap. xx. verse 36:]) or"},{"kind":"italic_en","text":"an object of desire"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wish"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^umoniy~apN","text_ar":"اُمْنِيَّةٌ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"which one asks;"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"an object"},{"kind":"page_break","n":1474},{"kind":"italic_en","text":"of want, which the soul eagerly desires:"},{"kind":"text","text":"(Er-Rághib, TA:) or"},{"kind":"italic_en","text":"an object of"},{"kind":"text","text":"a man's"},{"kind":"italic_en","text":"desire"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^umoniy~apN","text_ar":"اُمْنِيَّةٌ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"which embellishes to the seeker thereof that which is false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain, and other things of the deceptions of the present world:"},{"kind":"text","text":"but there is a difference between"},{"kind":"arabic","text_bw":"suwlN","text_ar":"سُولٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"suwlapN","text_ar":"سُولَةٌ","orth_type":"arrow"},{"kind":"text","text":"on the one hand and"},{"kind":"arabic","text_bw":"A^umoniy~apN","text_ar":"اُمْنِيَّةٌ"},{"kind":"text","text":"on the other hand, in that the former relate to what is sought, or demanded, and"},{"kind":"arabic","text_bw":"Amny~p","text_ar":"امنيّة"},{"kind":"text","text":"relates to what is meditated ("},{"kind":"arabic","text_bw":"qud~ira","text_ar":"قُدِّرَ"},{"kind":"text","text":"); (TA;) [for] this last primarily signifies “ a thing that a man meditates ("},{"kind":"arabic","text_bw":"yuqad~iruhu","text_ar":"يُقَدِّرُهُ"},{"kind":"text","text":") in his mind, ” from"},{"kind":"arabic","text_bw":"manaY","text_ar":"مَنَى"},{"kind":"text","text":"signifying"},{"kind":"arabic","text_bw":"qad~ara","text_ar":"قَدَّرَ"},{"kind":"text","text":"; (Bd in ii. 73;) so that the ↓"},{"kind":"arabic","text_bw":"suwlap","text_ar":"سُولَة","orth_type":"arrow"},{"kind":"text","text":"seems to be after the"},{"kind":"arabic","text_bw":"A^umoniy~ap","text_ar":"اُمْنِيَّة"},{"kind":"text","text":": (TA:)"},{"kind":"arabic","text_bw":"suwlN","text_ar":"سُولٌ"},{"kind":"text","text":"may be from"},{"kind":"arabic","text_bw":"saw~alato lahu nafosuhu ka*aA","text_ar":"سَوَّلَتْ لَهُ نَفْسُهُ كَذَا"},{"kind":"text","text":"in the first of the senses assigned to it above, and [from]"},{"kind":"arabic","text_bw":"saw~ala","text_ar":"سَوَّلَ"},{"kind":"text","text":"said of the Devil in the last of the senses assigned to it above. (Ham p. 748.) [See also"},{"kind":"arabic","text_bw":"suwaAlN","text_ar":"سُوَالٌ"},{"kind":"text","text":", below.]"}],"source_refs":["TA"]}]},"classical_definitions":null}