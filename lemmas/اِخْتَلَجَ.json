تَلِجُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْتَلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْتَلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْتَلِج","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْتَلِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْتَلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْتَلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْتَلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْتَلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْتَلِجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْتَلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْتَلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِخْتَلَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِخْتَلَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْتَلِج","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْتَلِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n11224"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AE%D9%92%D8%AA%D9%8E%D9%84%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to quiver, to tremble, to dither, to twitch","examples":[{"text":"جلبتُ ماءً مُثلجًا ومنفضة سجائر للمحامي الذي بدأ يقطف أوراق القات والسيجارة مشتعلة في فمه. أخذ ملء قبضته من الأغصان ورماها أمامي: «خزّن». أعدتها إليه: «ليس اليوم، سأخرج بعد قليل مع تاتيانا». اختلج فمه بانحراف لليمين.","english":"I fetched cold water and a tray for cigarettes for the lawyer who began to pluck the leaves of the qat with a cigarette in his mouth. He took a bunch of twigs and threw it before me: “Take.” I returned it: “Not today, Imma go out with Tatyana in a bit.” His mouth twitched with a tilt to the right."}]},{"pos":"verb","gloss":"to preoccupy, to possess, to cause concern","tags":["figuratively"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11224","headword_ar":"اختلج","root":"xlj","body":[{"kind":"text","text":", as a trans. v.: see 1, in three places.       -A2-  Also (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation; it quivered, quaked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"throbbed;"},{"kind":"text","text":"(Sh, TA;) and so ↓"},{"kind":"arabic","text_bw":"txl~j","text_ar":"تخلّج","orth_type":"arrow"},{"kind":"text","text":"(Sh, K) [and ↓"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ","orth_type":"arrow"},{"kind":"text","text":", as will be seen from what follows]. You say"},{"kind":"arabic","text_bw":"Axtlj HaAjibaAhu","text_ar":"اختلج حَاجِبَاهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His eyebrows quivered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"were in a state of commotion."},{"kind":"text","text":"(Lth.) And"},{"kind":"arabic","text_bw":"Axtljt Eayonuhu","text_ar":"اختلجت عَيْنُهُ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"txl~jt","text_ar":"تخلّجت","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"xalajato","text_ar":"خَلَجَتْ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuluwjN","text_ar":"خُلُوجٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"xalajaAnN","text_ar":"خَلَجَانٌ"},{"kind":"text","text":"; (Sh;) (assumed tropical:)"},{"kind":"italic_en","text":"His eye quivered, throbbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was in a state of commotion;"},{"kind":"text","text":"(Sh, L;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"TaArato","text_ar":"طَارَتْ"},{"kind":"text","text":", (S, K,) i. e.,"},{"kind":"italic_en","text":"throbbed."},{"kind":"text","text":"(PS, TK.) And"},{"kind":"arabic","text_bw":"Axtlj AlEuDowu","text_ar":"اختلج العُضْوُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The member"},{"kind":"text","text":"(i. e. any member, L)"},{"kind":"italic_en","text":"quivered,"},{"kind":"text","text":"&c. (Mgh, L, Msb.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"He trembled, quivered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quaked."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Axtlj biwajohihi","text_ar":"اختلج بِوَجْهِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He moved about his lips and his chin, mocking and imitating a person talking."},{"kind":"text","text":"(TA, from a trad.) ―         -b3-"},{"kind":"arabic","text_bw":"Axtlj fiY SadoriY ham~N","text_ar":"اختلج فِى صَدْرِى هَمٌّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Anxious thought fluttered in my bosom"},{"kind":"text","text":"]. (TA.) See also 6."}],"source_refs":["Sh","K","S"]}]}}