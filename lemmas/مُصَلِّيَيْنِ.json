{"lemma":"مُصَلِّيَيْنِ","slug":"مُصَلِّيَيْنِ","root":"ص.ل.#","root_slug":"ص-ل-_","root_link":"/words/roots/ص-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُصَلِّي","root":"صلو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n24823","n24836"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B5%D9%8E%D9%84%D9%90%D9%91%D9%8A%D9%8E%D9%8A%D9%92%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a place of prayer, prayer hall, prayer room, oratory"}]},"etymology":{"source":"wiktextract","text":"Noun of place from the verb صَلَّى (ṣallā, “to pray”)."},"ipa":["/mu.sˤal.lan/","/msˤal.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24823","headword_ar":"مُصَلًّى","root":"Slw","body":[{"kind":"italic_en","text":"A place of"},{"kind":"arabic","text_bw":"AlS~alaAp","text_ar":"الصَّلَاة"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"the performance of the divinely-appointed act of prayer"},{"kind":"text","text":"]; (Mgh, Msb, K;) or"},{"kind":"italic_en","text":"of any prayer"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supplication:"},{"kind":"text","text":"(Mgh:) [and particularly]"},{"kind":"italic_en","text":"a place of the performance of the divinely-appointed prayer on the occasion of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"festival termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Eiyd","text_ar":"عِيد"},{"kind":"text","text":": (MA:) [and also"},{"kind":"italic_en","text":"such a place at a burial-ground:"},{"kind":"text","text":"the place for this purpose is particularly termed"},{"kind":"arabic","text_bw":"muSal~aY AlA^amowaAti","text_ar":"مُصَلَّى الاَمْوَاتِ"},{"kind":"text","text":": see De Sacy's Chrest. Arabe, sec. ed., i. 192.] ―         -b2-  And"},{"kind":"italic_en","text":"A carpet upon which one performs the divinely-appointed act of prayer."},{"kind":"text","text":"(MA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"SalaApN","text_ar":"صَلَاةٌ"},{"kind":"text","text":", former half, in two places."}],"source_refs":["Mgh","MA"]},{"entry_id":"n24836","headword_ar":"مَصْلِىٌّ","root":"SlY","body":[{"kind":"italic_en","text":"Roasted, broiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fried;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"SaliY~N","text_ar":"صَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":". (Ham pp. 13-14. [Both of these words are there without any syll. signs.]) It is said in a trad.,"},{"kind":"arabic","text_bw":"A^utiYa bi$aApK maSoliy~apK","text_ar":"اُتِىَ بِشَاةٍ مَصْلِيَّةٍ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"A roasted sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat, was brought."},{"kind":"text","text":"(S, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"SayoHaAniy~apN","text_ar":"صَيْحَانِيَّةٌ"},{"kind":"arabic","text_bw":"maSoliy~apN","text_ar":"مَصْلِيَّةٌ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"A date of the sort called"},{"kind":"arabic","text_bw":"SayoHaAniY~","text_ar":"صَيْحَانِىّ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"dried in the sun."},{"kind":"text","text":"(A, TA.)"}],"source_refs":[]}]},"classical_definitions":null}