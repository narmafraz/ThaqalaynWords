um":"s"},{"role":"present_2md","form":"تَنْضِحانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْضِحا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْضَحانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْضَحا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَنْضِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْضِحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْضَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْضَحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْضِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَنْضَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْضِح","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَنْضَح","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْضِح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَنْضَح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْضِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْضِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْضَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْضَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْضِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْضِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْضَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْضَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْضِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْضِحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْضَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْضَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْضِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْضَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْضِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْضِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَضَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَضَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْضَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْضَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n39961"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B6%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wet, to sprinkle, to subject to moisture","examples":[{"text":"وقيل إن نضح بقدر جرة من ماء الزيتون قدر مائة جرة من الطعام لم يفسد ولم تصبه آفة وإن نضح عليه ماء الأفسنتين بقي ولم يفسد.","english":"It is said that when a jar of wheat is dampened with a jar of amurca it does not suffer decay nor damage, and if it is dampened with absinthe water, it stays and does not rot."},{"text":"كَانَ قَمِيصُهُ ٱلْأَزْرَقُ يُنْضَحُ بِٱلْعَرَقِ","english":"His blue shirt was damp with sweat."}]},{"pos":"verb","gloss":"to defend; to protect, to shield"},{"pos":"verb","gloss":"to defend; to justify, to vindicate"},{"pos":"noun","gloss":"verbal noun of نَضَحَ (naḍaḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"reservoir to draw water for sprinkling"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39961","headword_ar":"نَضَحَ","root":"nDH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) and"},{"kind":"text","text":", (Msb, MF,) inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He sprinkled"},{"kind":"text","text":"a house, or chamber, [with water]: (S, K:) or"},{"kind":"italic_en","text":"he sprinkled"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"lightly:"},{"kind":"text","text":"(TA:)"},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"naDoxN","text_ar":"نَضْخٌ"},{"kind":"text","text":"; and sometimes these two words agree, and sometimes they differ: (Lth:) some say that they both signify any sprinkling: (TA:) or the former signifies what is intentional; and the latter, what is unintentional. (IAar.) [See"},{"kind":"arabic","text_bw":"naDaxa","text_ar":"نَضَخَ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"naDaHotu Ealayohi AlmaA='a","text_ar":"نَضَحْتُ عَلَيْهِ المَا=ءَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I sprinkled water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the water, upon him"},{"kind":"text","text":"]. (As.) ―         -b3-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He moistened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprinkled,"},{"kind":"text","text":"a garment, or piece of cloth. (Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"A^aSaAbahu naDoHN mino ka*aA","text_ar":"اَصَابَهُ نَضْحٌ مِنْ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A sprinkling of such a thing came upon him"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"naDaHato","text_ar":"نَضَحَتْ"},{"kind":"arabic","text_bw":"biyawolihaA","text_ar":"بِيَوْلِهَا"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"sprinkled her urine."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"naDaHa EaTa$ahu","text_ar":"نَضَحَ عَطَشَهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":", (S,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water, TA,)"},{"kind":"italic_en","text":"moistened"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"allayed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his thirst,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"and allayed it:"},{"kind":"text","text":"(K. TA:)"},{"kind":"italic_en","text":"took it away:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"almost took it away:"},{"kind":"text","text":"(TA;) also (K) or"},{"kind":"arabic","text_bw":"naDaHa Alr~iYa","text_ar":"نَضَحَ الرِّىَ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"he satisfied his thirst with drink:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he drank less than what would satisfy his thirst."},{"kind":"text","text":"(S, K.) ―         -b7-"},{"kind":"arabic","text_bw":"naDaHa AlmaA='u","text_ar":"نَضَحَ المَا=ءُ"},{"kind":"arabic","text_bw":"AlmaAla","text_ar":"المَالَ"},{"kind":"italic_en","text":"The water took away the thirst of the camels &c.:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nearly did so."},{"kind":"text","text":"(T.) ―         -b8-"},{"kind":"arabic","text_bw":"naDaHa AlmaA='a","text_ar":"نَضَحَ المَا=ءَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"carried water from a river"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"canal"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"well to irrigate standing corn"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(Msb.) ―         -b9-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"italic_en","text":"He moistened"},{"kind":"text","text":"a skin, in order that it might not break. ―         -b10-"},{"kind":"arabic","text_bw":"naDaHa Aljul~apa","text_ar":"نَضَحَ الجُلَّةَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He sprinkled the palm-leaf date-basket with water, in order that its dates might stick together:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he scattered forth its contents."},{"kind":"text","text":"(L, K.) ―         -b11-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"text","text":"(inf. n."},{"kind":"arabic","text_bw":"naSoHN","text_ar":"نَصْحٌ"},{"kind":"text","text":", S,)"},{"kind":"italic_en","text":"He watered"},{"kind":"text","text":"palm-trees, (K,) and standing corn &c., (TA,)"},{"kind":"italic_en","text":"by means of a camel carrying the water."},{"kind":"text","text":"(K.) ―         -b12-"},{"kind":"arabic","text_bw":"suqiY Alz~aroEu naDoHA","text_ar":"سُقِى الزَّرْعُ نَضْحا"},{"kind":"italic_en","text":"The standing corn &c. was watered by means of buckets,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dilaA='a","text_ar":"دِلَا=ءَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"guruwb","text_ar":"غُرُوب"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and camels carrying the water;"},{"kind":"text","text":"not by means of a channel opened for that purpose. (TA.) ―         -b13-"},{"kind":"arabic","text_bw":"h`*ihi naxolu tunoDaHu","text_ar":"هٰذِهِ نَخْلُ تُنْضَحُ"},{"kind":"italic_en","text":"These are palm-trees that are watered"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by the means above mentioned"},{"kind":"text","text":"]. (S.) ―         -b14-"},{"kind":"arabic","text_bw":"fulaAnN yasoqiY biAln~aDoH","text_ar":"فُلَانٌ يَسْقِى بِالنَّضْح"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one waters"},{"kind":"text","text":"palm-trees &c."},{"kind":"italic_en","text":"by the means above mentioned"},{"kind":"text","text":"]. (S.) ―         -b15-"},{"kind":"arabic","text_bw":"yanoDiHu EalaY AlbaEiyri","text_ar":"يَنْضِحُ عَلَى البَعِيرِ"},{"kind":"italic_en","text":"He drives the camel that carries the water for irrigation, watering palm-trees"},{"kind":"text","text":"["},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"] (S) ―         -b16-"},{"kind":"arabic","text_bw":"naDaHuwhumo","text_ar":"نَضَحُوهُمْ"},{"kind":"arabic","text_bw":"biAln~aboli","text_ar":"بِالنَّبْلِ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":", TA.) (tropical:)"},{"kind":"italic_en","text":"They shot at them"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sprinkled them"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with arrows:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"they scattered arrows among them."},{"kind":"text","text":"like as water is sprinkled. (TA.) Mohammad said to the archers at the battle of Ohod,"},{"kind":"arabic","text_bw":"AinoDiHuwA Ean~aA Alxayola","text_ar":"اِنْضِحُوا عَنَّا الخَيْلَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Shoot ye at the horses and their riders with arrows"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and so repel them from us"},{"kind":"text","text":"]. (S, * TA.) ―         -b17-"},{"kind":"arabic","text_bw":"naDaHa farojahu","text_ar":"نَضَحَ فَرْجَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (TA;) and ↓"},{"kind":"arabic","text_bw":"AntDH","text_ar":"انتضح","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstnDH","text_ar":"استنضح","orth_type":"arrow"},{"kind":"text","text":"[both of which are thus used as intrans.]: (K;)"},{"kind":"italic_en","text":"He sprinkled some water upon his pudendum after the ablution called"},{"kind":"arabic","text_bw":"AlwuDuwo'","text_ar":"الوُضُوْء"},{"kind":"text","text":": (K:) as also"},{"kind":"arabic","text_bw":"AinotafaDa","text_ar":"اِنْتَفَضَ"},{"kind":"text","text":". (TA.) ―         -b18-"},{"kind":"arabic","text_bw":"naDaHa biAlbawoli","text_ar":"نَضَحَ بِالبَوْلِ"},{"kind":"arabic","text_bw":"EalaY faxi*ayohi","text_ar":"عَلَى فَخِذَيْهِ"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a little sprinkling of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"urine to fall upon his thighs."},{"kind":"text","text":"(K.) Hence the saying in a trad.,"},{"kind":"arabic","text_bw":"Aln~aDoxu mina Aln~aDoHi","text_ar":"النَّضْخُ مِنَ النَّضْحِ"},{"kind":"text","text":", meaning, that he upon whom falls a little sprinkling of urine, like the heads of needles, as explained by Z, must sprinkle the part with water, and is not required to wash it. (TA.) ―         -b19-"},{"kind":"arabic","text_bw":"naDaHatonaA Als~amaA='u","text_ar":"نَضَحَتْنَا السَّمَا=ءُ"},{"kind":"italic_en","text":"The sky rained upon us."},{"kind":"text","text":"(L.) ―         -b20-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"sweated."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"naDaHa biAlEaraqi","text_ar":"نَضَحَ بِالعَرَقِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"naDaHaAnN","text_ar":"نَضَحَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, and a horse,)"},{"kind":"italic_en","text":"broke out with sweat:"},{"kind":"text","text":"and in like manner, the protuberance behind a camel's ear ; and the arm-pit or the like. (L) [See an ex. in a verse cited in art."},{"kind":"arabic","text_bw":"Edw","text_ar":"عدو"},{"kind":"text","text":", conj. 3.] ―         -b21-"},{"kind":"arabic","text_bw":"yanoDaHu TybFA","text_ar":"يَنْضَحُ طيبًا"},{"kind":"italic_en","text":"He diffuses the odour of perfume:"},{"kind":"text","text":"lit., sweats it. (L, from a trad.) ―         -b22-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(sweat)"},{"kind":"italic_en","text":"exuded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came forth."},{"kind":"text","text":"(Msb.) ―         -b23-"},{"kind":"arabic","text_bw":"naDaHati Alqrobapu","text_ar":"نَضَحَتِ القرْبَةُ"},{"kind":"text","text":". (S, K,) and"},{"kind":"arabic","text_bw":"AlxaAbiyapu","text_ar":"الخَابِيَةُ"},{"kind":"text","text":", (S,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tan~aDaAHN","text_ar":"تَنَّضَاحٌ"},{"kind":"text","text":", (S, K,) [the latter of an intensive form,"},{"kind":"italic_en","text":"The water-skin,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the jar."},{"kind":"text","text":"("},{"kind":"italic_en","text":"being thin,"},{"kind":"text","text":"TA,)"},{"kind":"italic_en","text":"sweated,"},{"kind":"text","text":"(ISk, S, K,) or"},{"kind":"italic_en","text":"exuded its water."},{"kind":"text","text":"(TA.) ―         -b24-"},{"kind":"arabic","text_bw":"naDaHa Aljabalu","text_ar":"نَضَحَ الجَبَلُ"},{"kind":"italic_en","text":"The mountain sweated water between its masses of rock."},{"kind":"text","text":"(TA) ―         -b25-"},{"kind":"arabic","text_bw":"naDaH","text_ar":"نَضَح"},{"kind":"arabic","text_bw":"Al$~ajaru","text_ar":"الشَّجَرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"The trees began to break out with leaves."},{"kind":"text","text":"(As, S, K.) ―         -b26-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"arabic","text_bw":"Alz~aroEu","text_ar":"الزَّرْعُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AnDH","text_ar":"انضح","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The standing corn became thick in its body,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and began to have the farinaceous substance in its grains, yet moist,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender."},{"kind":"text","text":"(K.) ―         -b27-"},{"kind":"arabic","text_bw":"taDaHati AlEayonu","text_ar":"تَضَحَتِ العَيْنُ"},{"kind":"text","text":", (L, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naDoHN","text_ar":"نَضْحٌ"},{"kind":"text","text":": (L.;) and ↓"},{"kind":"arabic","text_bw":"AntDHt","text_ar":"انتضحت","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"nnD~Ht","text_ar":"ننضّحت","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"The eye overflowed with tears:"},{"kind":"text","text":"(L, K:)"},{"kind":"italic_en","text":"the eye filled with tears and the overflowed without stopping."},{"kind":"text","text":"(L.) ―         -b28-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"text","text":", aor."},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a sea, or great river,)"},{"kind":"italic_en","text":"flowed."},{"kind":"text","text":"(TA, art."},{"kind":"arabic","text_bw":"tbr","text_ar":"تبر"},{"kind":"text","text":".) ―         -b29-"},{"kind":"arabic","text_bw":"AinoDaHuwA Alr~aHima bibilaAlihaA","text_ar":"اِنْضَحُوا الرَّحِمَ بِبِلَالِهَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bilaAlN","text_ar":"بِلَالٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"naDaHa","text_ar":"نَضَحَ"},{"kind":"arabic","text_bw":"Eano fulaAnK","text_ar":"عَنْ فُلَانٍ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"bADH","text_ar":"باضح","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"munaADaHapu","text_ar":"مُنَاضَحَةُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"niDaAHN","text_ar":"نِضَاحٌ"},{"kind":"text","text":"; (TA;) (tropical:)"},{"kind":"italic_en","text":"He repelled from, and defended, such a one:"},{"kind":"text","text":"(S, K:) as also"},{"kind":"arabic","text_bw":"maDaHa","text_ar":"مَضَحَ"},{"kind":"text","text":": (Shujáa:) and"},{"kind":"arabic","text_bw":"naDHa Alr~ajula","text_ar":"نَضحَ الرَّجُلَ"},{"kind":"italic_en","text":"he repelled from the man."},{"kind":"text","text":"(Kr.) ―         -b2-"},{"kind":"arabic","text_bw":"naDaHa Eano nafosihi","text_ar":"نَضَحَ عَنْ نَفْسِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He defended himself with an argument. a pled."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an allegation."},{"kind":"text","text":"(S.)"}],"source_refs":["S","K","Msb","MF","TA","Lth","L","ISk"]}]}}