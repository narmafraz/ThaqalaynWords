{"lemma":"مَعْهَدَيْ","slug":"مَعْهَدَيْ","root":"ع.ه.د","root_slug":"ع-ه-د","root_link":"/words/roots/ع-ه-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30871"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B9%D9%92%D9%87%D9%8E%D8%AF%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"institute"}]},"etymology":{"source":"wiktextract","text":"Noun of place from the root ع ه د (ʕ h d)."},"ipa":["/maʕ.had/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30871","headword_ar":"مَعْهَدٌ","root":"Ehd","body":[{"kind":"italic_en","text":"A place in which one used to know,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be acquainted with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meet with, a thing;"},{"kind":"text","text":"(S, A, O;)"},{"kind":"italic_en","text":"a place in which a thing is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has been, known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"met with;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) the latter originally an inf. n.: (TA:)"},{"kind":"italic_en","text":"an abode in which one used to know love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desire:"},{"kind":"text","text":"(TA:) and, as also ↓"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"a place of abode to which people return:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"a place of abode to which people, when they have gone far away from it, always return:"},{"kind":"text","text":"(S, O:) pl. of the former"},{"kind":"arabic","text_bw":"maEaAhidu","text_ar":"مَعَاهِدُ"},{"kind":"text","text":". (A.) One says,"},{"kind":"arabic","text_bw":"AlA^aHib~api","text_ar":"الاَحِبَّةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aisotawoqafa Alr~akoba EalaY Eahodi","text_ar":"اِسْتَوْقَفَ الرَّكْبَ عَلَى عَهْدِ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaY maEohadihimo","text_ar":"عَلَى مَعْهَدِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He asked the company of riders to stop at the place where he used to know,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meet, the objects of love;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"at the abode to which the objects of love used to return."},{"kind":"text","text":"(A.)"}],"source_refs":["TA","A","S","O"]}]}}