{"lemma":"وُهَدُ","slug":"وُهَدُ","root":"#.ه.د","root_slug":"_-ه-د","root_link":"/words/roots/_-ه-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n42414"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8F%D9%87%D9%8E%D8%AF%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42414","headword_ar":"وَهْدٌ","root":"whd","body":[{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"wahodapN","text_ar":"وَهْدَةٌ"},{"kind":"text","text":"(As, S, A, L)"},{"kind":"italic_en","text":"A low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, place;"},{"kind":"text","text":"(As, S, A L;)"},{"kind":"italic_en","text":"as though it were a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavity, dug,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excavated,"},{"kind":"text","text":"for which the latter is also a name: (L:) and both words,"},{"kind":"italic_en","text":"low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, ground:"},{"kind":"text","text":"(L, K:) pl."},{"kind":"arabic","text_bw":"A^awohudN","text_ar":"اَوْهُدٌ"},{"kind":"text","text":", (L, K,) a pl. [of pauc.] of the former, (TA,) and"},{"kind":"arabic","text_bw":"wihaAdN","text_ar":"وِهَادٌ"},{"kind":"text","text":"(S, A, L, K) and"},{"kind":"arabic","text_bw":"wuhodaAnN","text_ar":"وُهْدَانٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"wihodaAnN","text_ar":"وِهْدَانٌ"},{"kind":"text","text":", (as in different copies of the K, the former being the reading in the TA,) and"},{"kind":"arabic","text_bw":"wahodN","text_ar":"وَهْدٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"wahodapN","text_ar":"وَهْدَةٌ"},{"kind":"text","text":": (S, L:) [or rather this last is a coll. gen. n., of which"},{"kind":"arabic","text_bw":"wahodapN","text_ar":"وَهْدَةٌ"},{"kind":"text","text":"is the n. un.:] also"},{"kind":"arabic","text_bw":"wahodapN","text_ar":"وَهْدَةٌ"},{"kind":"italic_en","text":"a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deep hollow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavity,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"huw~apN","text_ar":"هُوَّةٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in the ground;"},{"kind":"text","text":"(L, K;) and so"},{"kind":"arabic","text_bw":"makaAnN wahodN","text_ar":"مَكَانٌ وَهْدٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^aroDN wahodapN","text_ar":"اَرْضٌ وَهْدَةٌ"},{"kind":"text","text":": (L:) and"},{"kind":"italic_en","text":"a round hollow excavated in the ground, deeper than what is called"},{"kind":"arabic","text_bw":"gaAy^iTN","text_ar":"غَايِطٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"not having abrupt sides, in width two and three spear's lengths, and not producing any herbage."},{"kind":"text","text":"(L.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"wahodapN","text_ar":"وَهْدَةٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"hollow, in the ground, in which the weaver puts his legs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feet."},{"kind":"text","text":"(Mgh.) ―         -b3-  Also,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xunoEubapN","text_ar":"خُنْعُبَةٌ"},{"kind":"text","text":", (IAar, L,) which latter, says Lth, signifies The"},{"kind":"italic_en","text":"part where the mustaches divide."}],"source_refs":["L","As","S","A","K","TA","IAar"]}]}}