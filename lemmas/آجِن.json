{"lemma":"آجِن","slug":"آجِن","root":"#.ج.ن","root_slug":"_-ج-ن","root_link":"/words/roots/_-ج-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n320","n321","n322",""],"search_url":"https://lanelexicon.com/?s=%D8%A2%D8%AC%D9%90%D9%86"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"foul water"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of أَجَنَ (ʔajana, “to be foul”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n320","headword_ar":"اَجَنَ","root":"Ajn","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"A^ajina","text_ar":"اَجِنَ"},{"kind":"text","text":", (S, Mgh, &c.,) aor."},{"kind":"text","text":", (S, Msb,) mentioned by Yz; (S;) inf. n. of the former"},{"kind":"arabic","text_bw":"A^ujuwnN","text_ar":"اُجُونٌ"},{"kind":"text","text":"(S, Mgh, Msb, K *) and"},{"kind":"arabic","text_bw":"A^ajonN","text_ar":"اَجْنٌ"},{"kind":"text","text":"; (S, Msb, K; *) and of the latter"},{"kind":"arabic","text_bw":"A^ajanN","text_ar":"اَجَنٌ"},{"kind":"text","text":"; (S, Mgh, Msb, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became altered for the worse"},{"kind":"text","text":"(S, Mgh, Msb, K)"},{"kind":"italic_en","text":"in taste and colour,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"from some such cause as long standing,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"but was drinkable:"},{"kind":"text","text":"(Mgh, Msb:) or"},{"kind":"italic_en","text":"became altered for the worse in its odour by oldness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became covered with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the green substance called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TuHolub","text_ar":"طُحْلُب"},{"kind":"italic_en","text":"and with leaves:"},{"kind":"text","text":"(Mgh:)"},{"kind":"arabic","text_bw":"A^ajuna","text_ar":"اَجُنَ"},{"kind":"text","text":", also, said of water, signifies"},{"kind":"italic_en","text":"it became altered for the worse:"},{"kind":"text","text":"(Th:) and in the Iktitáf occurs"},{"kind":"arabic","text_bw":"A^ajana","text_ar":"اَجَنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", which is unknown, but may be a mixture of two dial. vars. [namely of"},{"kind":"arabic","text_bw":"A^ajana","text_ar":"اَجَنَ"},{"kind":"text","text":"having for its aor."},{"kind":"text","text":"and"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"yaA^ojanu","text_ar":"يَاْجَنُ"},{"kind":"text","text":"having for its pret."},{"kind":"arabic","text_bw":"A^ajina","text_ar":"اَجِنَ"},{"kind":"text","text":"]. (MF)       -A2-"},{"kind":"arabic","text_bw":"A^ajana","text_ar":"اَجَنَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a"},{"kind":"arabic","text_bw":"qaS~aAra","text_ar":"قَصَّارَ"},{"kind":"text","text":", or whitener of cloth)"},{"kind":"italic_en","text":"beat"},{"kind":"text","text":"a piece of cloth or a garment [in washing it]. (S, K.)"}],"source_refs":["S","Mgh","Msb","K","TA","Th","MF"]},{"entry_id":"n321","headword_ar":"اَجْنٌ","root":"Ajn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=jinN","text_ar":"ا=جِنٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n322","headword_ar":"اَجِنٌ","root":"Ajn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=jinN","text_ar":"ا=جِنٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}