{"lemma":"صَدْرُ","slug":"صَدْرُ","root":"ص.د.ر","root_slug":"ص-د-ر","root_link":"/words/roots/ص-د-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"صَدْر","root":"صدر","pos":"N","occurrence_count":44},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":17},"lanes":{"found":true,"entry_ids":["n23929","n23935","n23936"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AF%D9%92%D8%B1%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise","tags":["intransitive"],"examples":[{"text":"يَوْمَئِذٍ يَصْدُرُ النَّاسُ أَشْتَاتًا لِّيُرَوْا أَعْمَالَهُمْ","english":"On that Day people will proceed in separate groups to be shown [the consequences of] their deeds."}]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to materialize, to happen, to occur","tags":["intransitive"]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to emerge as if from a source, to proceed, to emanate, to arise, to originate, to stem, to spring","tags":["intransitive"]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to be released; to be public or available, to be out; to come out; to circulate","tags":["intransitive"],"examples":[{"text":"صَدَرَ الْكِتَابُ مِنْ دَارِ النَّشْرِ يَوْمَ الْأَرْبِعَاء.","english":"The book issued from the publisher on Wednesday."}]},{"pos":"verb","gloss":"to send, to send off, to send out; to export","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to send, to send off, to send out; to dispatch; to forward; to transport","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to send, to send off, to send out; to publish, to issue, to promulgate","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to preface; to introduce","tags":["intransitive","transitive"]},{"pos":"noun","gloss":"verbal noun of صَدَرَ (ṣadara, “to emerge; to materialize; to be released publicly”) (form I)","tags":["form-of","intransitive","noun-from-verb","transitive","uncountable"]},{"pos":"noun","gloss":"verbal noun of صَدَرَ (ṣadara, “to hit in the chest”) (form I)","tags":["form-of","intransitive","noun-from-verb","transitive","uncountable"]},{"pos":"noun","gloss":"a chest, a breast; a bust, a bosom","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a chest, a breast; something resembling, likened to, or related to chests (such as a center, a core, a heart, and so on)","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a front","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a front; a person at the front, a leader, a commander","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a beginning, a start, an outset, a commencement; an inception; a dawn, a rise","tags":["countable","intransitive","transitive"]},{"pos":"verb","gloss":"to hurt the chest of; to hit in the chest","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to have a chest complaint","tags":["intransitive","transitive"]}]},"etymology":null,"ipa":["/sˤa.da.ra/","/sˤad.da.ra/","/sˤadr/","/sˤu.di.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23929","headword_ar":"صَدَرَ","root":"Sdr","body":[{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":"(S, M, A, Msb, K) and"},{"kind":"arabic","text_bw":"SuduwrN","text_ar":"صُدُورٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"maSodarN","text_ar":"مَصْدَرٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"mazodarN","text_ar":"مَزْدَرٌ"},{"kind":"text","text":"because of the similarity [of the letters"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":"], (M,)"},{"kind":"italic_en","text":"He returned, went back;"},{"kind":"text","text":"(S, M, A, Msb, K;) and"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned, away;"},{"kind":"text","text":"(Msb;) from ("},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":") water, (S, M, A,) and a country, (S, M,) or a place, (Msb,) and (assumed tropical:)  any affair. (Lth.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"Sadara Alqawolu","text_ar":"صَدَرَ القَوْلُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SuduwrN","text_ar":"صُدُورٌ"},{"kind":"text","text":", (assumed tropical:)  ["},{"kind":"italic_en","text":"The saying issued, proceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emanated,"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"italic_en","text":"from him."},{"kind":"text","text":"] (Msb.) [And"},{"kind":"arabic","text_bw":"Sadara Eanohu AlfiEolu","text_ar":"صَدَرَ عَنْهُ الفِعْلُ"},{"kind":"text","text":", with the same aor. and inf. n., (assumed tropical:)"},{"kind":"italic_en","text":"The action proceeded from him."},{"kind":"text","text":"] ―         -b3-  And"},{"kind":"arabic","text_bw":"Sadara A_ilayohi","text_ar":"صَدَرَ اـِلَيْهِ"},{"kind":"italic_en","text":"He went to it;"},{"kind":"text","text":"namely, a place: (TA:)"},{"kind":"italic_en","text":"he came to it."},{"kind":"text","text":"(Kull. p. 228.)       -A2-"},{"kind":"arabic","text_bw":"Sadarahu","text_ar":"صَدَرَهُ"},{"kind":"text","text":": see 4.       -A3-  Also, (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He hit, struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, his"},{"kind":"arabic","text_bw":"Sador","text_ar":"صَدْر"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"breast"},{"kind":"text","text":"]. (M, K.) You say,"},{"kind":"arabic","text_bw":"Darabotuhu faSadarotuhu","text_ar":"ضَرَبْتُهُ فَصَدَرْتُهُ"},{"kind":"italic_en","text":"I struck him and hit his breast."},{"kind":"text","text":"(A.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Sadira","text_ar":"صَدِرَ"},{"kind":"italic_en","text":"He had a complaint of the"},{"kind":"arabic","text_bw":"Sador","text_ar":"صَدْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"chest"},{"kind":"text","text":"]. (M, K.) [See its part. n., below.]"}],"source_refs":["S","M","A","Msb","K","TA"]},{"entry_id":"n23935","headword_ar":"صَدْرٌ","root":"Sdr","body":[{"kind":"italic_en","text":"Anything that fronts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faces, one."},{"kind":"text","text":"(M, K.) ―         -b2-  And hence, (M,) The"},{"kind":"arabic","text_bw":"Sador","text_ar":"صَدْر"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bosom,"},{"kind":"text","text":"] of a man, [often meaning his"},{"kind":"italic_en","text":"mind,"},{"kind":"text","text":"] (M, Msb, K,) and of other than man: (Msb:) of the masc. gender: (Lh, S, M, K:) pl."},{"kind":"arabic","text_bw":"SuduwrN","text_ar":"صُدُورٌ"},{"kind":"text","text":", (S, M, Msb,) the only pl. form. (M.) [See also"},{"kind":"arabic","text_bw":"SudorapN","text_ar":"صُدْرَةٌ"},{"kind":"text","text":".] As to the saying of the poet, (S, M,) El-Aashà, (S,)"},{"kind":"quote","text":"wata$oraqu biAlqawoli Al~a*iY qado A^a*aEotuhu\n                      \n                     \n                        kamaA $ariqato Sadoru AlqanaApi mina Ald~ami"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And thou becomest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wilt become, red by reason of the saying that I have published, like as the fore part of the spear becomes red from blood"},{"kind":"text","text":"], (S, * M,) he has made"},{"kind":"arabic","text_bw":"Sdr","text_ar":"صدر"},{"kind":"text","text":"fem. because the"},{"kind":"arabic","text_bw":"Sdr","text_ar":"صدر"},{"kind":"text","text":"of the"},{"kind":"arabic","text_bw":"qnAp","text_ar":"قناة"},{"kind":"text","text":"is a part of the"},{"kind":"arabic","text_bw":"qnAp","text_ar":"قناة"},{"kind":"text","text":"; for they [sometimes] make a noun fem. when it is prefixed to a fem. noun: (S:) or if you will, you may say that he has made"},{"kind":"arabic","text_bw":"Sdr","text_ar":"صدر"},{"kind":"text","text":"fem. because he meant [thereby] the"},{"kind":"arabic","text_bw":"qnAp","text_ar":"قناة"},{"kind":"text","text":"; and if you will, you may say that the"},{"kind":"arabic","text_bw":"Sdr","text_ar":"صدر"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"qnAp","text_ar":"قناة"},{"kind":"text","text":"is a"},{"kind":"arabic","text_bw":"qnAp","text_ar":"قناة"},{"kind":"text","text":". (M.) [Hence,]"},{"kind":"arabic","text_bw":"banaAtu","text_ar":"بَنَاتُ"},{"kind":"arabic","text_bw":"AlS~adori","text_ar":"الصَّدْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The spaces between the bones of the breast."},{"kind":"text","text":"(M, TA.) [And also] (assumed tropical:)"},{"kind":"italic_en","text":"Anxieties."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"bnY","text_ar":"بنى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"*aAtu AlS~uduwri","text_ar":"ذَاتُ الصُّدُورِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"What is in the minds."},{"kind":"text","text":"(Ksh and Bd and Jel in iii. 115, &c.) And"},{"kind":"arabic","text_bw":"DaAqa Sadoruhu","text_ar":"ضَاقَ صَدْرُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His bosom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, became strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted."},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"Dyq","text_ar":"ضيق"},{"kind":"text","text":". [See the Kur xv. 97 and xxvi. 12.]) And"},{"kind":"arabic","text_bw":"$araHa biAlkufori SadorFA","text_ar":"شَرَحَ بِالكُفْرِ صَدْرًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He opened and dilated his bosom,"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"was pleased, with infidelity."},{"kind":"text","text":"(Jel in xvi. 108. [See also the similar phrases"},{"kind":"arabic","text_bw":"$araHa A@ll~`hu Sadorahu liloA_isolaAmi","text_ar":"شَرَحَ ا@للّٰهُ صَدْرَهُ لِلْاـِسْلَامِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"liqabuwli Alxayori","text_ar":"لِقَبُولِ الخَيْرِ"},{"kind":"text","text":"expl. in art."},{"kind":"arabic","text_bw":"$rH","text_ar":"شرح"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Aino$araHa","text_ar":"اِنْشَرَحَ"},{"kind":"arabic","text_bw":"Sadoruhu","text_ar":"صَدْرُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His bosom became dilated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enlarged"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with joy"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"$rH","text_ar":"شرح"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"waAsiEu AlS~adori","text_ar":"وَاسِعُ الصَّدْرِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raHiybu AlS~adori","text_ar":"رَحِيبُ الصَّدْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dilated, in the breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bosom;"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"free-minded; free from distress of mind; without care:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"free from narrowness of mind; liberal, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous."},{"kind":"text","text":"] (S and TA in art."},{"kind":"arabic","text_bw":"rHb","text_ar":"رحب"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"Day~iqu AlS~adori","text_ar":"ضَيِّقُ الصَّدْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Having the bosom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"rajulN baEiydu AlS~adori","text_ar":"رَجُلٌ بَعِيدُ الصَّدْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A man who is not to be turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined."},{"kind":"text","text":"(M.) In the saying"},{"kind":"arabic","text_bw":"halo yasotaTiyEu mano bihi SadorN A_il~aA","text_ar":"هَلْ يَسْتَطِيعُ مَنْ بِهِ صَدْرٌ اـِلَّا"},{"kind":"arabic","text_bw":"A^ano yanofiva","text_ar":"اَنْ يَنْفِثَ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Is he who has the disease of the chest"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"daA='u AlS~adori","text_ar":"دَا=ءُ الصَّدْرِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"able to do without spitting?"},{"kind":"text","text":"], if it be correct, the prefixed noun ["},{"kind":"arabic","text_bw":"dA='","text_ar":"دا=ء"},{"kind":"text","text":"] is suppressed. (Mgh.) ["},{"kind":"arabic","text_bw":"Sadoru Ald~ajaAjapi","text_ar":"صَدْرُ الدَّجَاجَةِ"},{"kind":"text","text":", as said by Freytag, is the name of (assumed tropical:)"},{"kind":"italic_en","text":"The star"},{"kind":"arabic","text_bw":"γ","text_ar":"γ","orth_type":"plain"},{"kind":"italic_en","text":"of Cygnus."},{"kind":"text","text":"] ―         -b3-  Also (assumed tropical:)  The"},{"kind":"italic_en","text":"upper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uppermost, part of the front"},{"kind":"text","text":"of anything. (M, K.) [Hence,]"},{"kind":"arabic","text_bw":"Suduwru","text_ar":"صُدُورُ"},{"kind":"arabic","text_bw":"AlwaAdiY","text_ar":"الوَادِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The higher,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upper, parts,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"fronts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fore parts, of the valley;"},{"kind":"text","text":"(M, K;) as also"},{"kind":"arabic","text_bw":"SadaAy^iruhu","text_ar":"صَدَايِرُهُ"},{"kind":"text","text":", which is pl. of ↓"},{"kind":"arabic","text_bw":"SadaArapN","text_ar":"صَدَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"SidaArapN","text_ar":"صِدَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", (as in a copy of the M,) or ↓"},{"kind":"arabic","text_bw":"SaAdirapN","text_ar":"صَادِرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (as in the L,) or of ↓"},{"kind":"arabic","text_bw":"SadiyrapN","text_ar":"صَدِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (M, L, K.) And"},{"kind":"arabic","text_bw":"Sadoru Almajolisi","text_ar":"صَدْرُ المَجْلِسِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The upper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest, part"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"end"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the sitting-room,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sitting-place:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"the elevated part thereof."},{"kind":"text","text":"(Msb.) ―         -b4-  [(assumed tropical:)  The"},{"kind":"italic_en","text":"fore part"},{"kind":"text","text":"of anything. (assumed tropical:)  The"},{"kind":"italic_en","text":"prow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fore part,"},{"kind":"text","text":"of a ship.] (assumed tropical:)  The"},{"kind":"italic_en","text":"fore part"},{"kind":"text","text":"of the foot,"},{"kind":"italic_en","text":"between the toes and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"protuberant part called the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"HimaArap","text_ar":"حِمَارَة"},{"kind":"text","text":". (M.) (assumed tropical:)  The"},{"kind":"italic_en","text":"fore part"},{"kind":"text","text":"of the sandal,"},{"kind":"italic_en","text":"before the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hole through which is put the thong called the"},{"kind":"arabic","text_bw":"$iraAk","text_ar":"شِرَاك"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"the hole called the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xurot","text_ar":"خُرْت"},{"kind":"text","text":". (M.) (tropical:)  The"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of the arrow"},{"kind":"italic_en","text":"that is above the middle, as far as the"},{"kind":"arabic","text_bw":"mrA$","text_ar":"مراش"},{"kind":"text","text":": (so in a copy of the A: [an evident mistranscription for"},{"kind":"arabic","text_bw":"raA^os","text_ar":"رَاْس"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"head:"},{"kind":"text","text":"]) or the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of the arrow"},{"kind":"italic_en","text":"that is beyond the middle, as far as the slender part,"},{"kind":"text","text":"(S, M, Msb, K,)"},{"kind":"italic_en","text":"which is next the head;"},{"kind":"text","text":"(M;) so called because it is the fore part when it is shot: (S, Msb, K:) and likewise of the spear [as in the verse cited above in this paragraph]. (M.)"},{"kind":"arabic","text_bw":"yawomN kaSadori Alr~umoHi","text_ar":"يَوْمٌ كَصَدْرِ الرُّمْحِ"},{"kind":"text","text":"[lit. (assumed tropical:)"},{"kind":"italic_en","text":"A day like the fore part of the spear"},{"kind":"text","text":"] means (assumed tropical:)"},{"kind":"italic_en","text":"a day of straitness and distress:"},{"kind":"text","text":"accord. to Th, it is a day by which war, or battle, is peculiarly distinguished. (M, L.) ―         -b5-  (assumed tropical:)  The"},{"kind":"italic_en","text":"first, first part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commencement,"},{"kind":"text","text":"of anything; (S, M, K;) even (assumed tropical:)  of the day, (M, Msb,) and (assumed tropical:)  of the night, and (assumed tropical:)  of the winter, and (assumed tropical:)  of the summer, and (assumed tropical:)  the like, (M,) and (tropical:)  of an affair. (A. [See an ex. voce"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":".]) (tropical:)  The"},{"kind":"italic_en","text":"title"},{"kind":"text","text":"of a book or writing: and the"},{"kind":"italic_en","text":"first part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commencement,"},{"kind":"text","text":"thereof. (TA.) [(assumed tropical:)  The"},{"kind":"italic_en","text":"first foot of the first hemistich"},{"kind":"text","text":"of a verse.] And The"},{"kind":"italic_en","text":"first hemistich"},{"kind":"text","text":"(altogether) of a verse. (O voce"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":".) [And (assumed tropical:)  The"},{"kind":"italic_en","text":"first verse"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"qaSiydap","text_ar":"قَصِيدَة"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"Sadoru AlT~ariyqi","text_ar":"صَدْرُ الطَّرِيقِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"widening, part of the road."},{"kind":"text","text":"(Msb.) ―         -b7-"},{"kind":"arabic","text_bw":"Sadoru Alqawomi","text_ar":"صَدْرُ القَوْمِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AlmaSodaru","text_ar":"المَصْدَرُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And hence,"},{"kind":"arabic","text_bw":"Sadoru AlS~uduwri","text_ar":"صَدْرُ الصُّدُورِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The chief of the chiefs;"},{"kind":"text","text":"a title applied to"},{"kind":"italic_en","text":"the prime minister of the king;"},{"kind":"text","text":"and also to the"},{"kind":"italic_en","text":"chief judge;"},{"kind":"text","text":"app., in the earlier times, to the former;]"},{"kind":"italic_en","text":"he who performs the onerous duties of the king,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the state."},{"kind":"text","text":"(TA.) ―         -b8-  And (assumed tropical:)"},{"kind":"italic_en","text":"A part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"of a thing. (S, K.)"}],"source_refs":["M","Msb","K","Lh","S","TA"]},{"entry_id":"n23936","headword_ar":"صَدَرٌ","root":"Sdr","body":[{"kind":"text","text":"a subst. signifying"},{"kind":"italic_en","text":"Return,"},{"kind":"text","text":"(S, M, Msb, K,) from ("},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":") water, (S, M,) and a country, (S,) or a place, (Msb,) and (assumed tropical:)  any affair: (Lth:) as some say, from anything. (M.) Hence,"},{"kind":"arabic","text_bw":"TawaAfu","text_ar":"طَوَافُ"},{"kind":"arabic","text_bw":"AlS~adari","text_ar":"الصَّدَرِ"},{"kind":"text","text":", (K, TA, in the CK"},{"kind":"arabic","text_bw":"AlS~adori","text_ar":"الصَّدْرِ"},{"kind":"text","text":",) i. e."},{"kind":"italic_en","text":"The compassing"},{"kind":"text","text":"of the Kaabeh"},{"kind":"italic_en","text":"on the occasion of the return"},{"kind":"text","text":"of the pilgrims"},{"kind":"italic_en","text":"from ' Arafát."},{"kind":"text","text":"(TA.) [Hence also,]"},{"kind":"arabic","text_bw":"AlS~adaru","text_ar":"الصَّدَرُ"},{"kind":"italic_en","text":"The fourth day of the days of the sacrifice"},{"kind":"text","text":"["},{"kind":"italic_en","text":"performed by the pilgrims"},{"kind":"text","text":"]: (M, K:) so called because the people then return from Mekkeh to their abodes. (M.) [And hence the saying,]"},{"kind":"arabic","text_bw":"tarakotuhu EalaY mivoli layolapi AlS~adari","text_ar":"تَرَكْتُهُ عَلَى مِثْلِ لَيْلَةِ الصَّدَرِ"},{"kind":"italic_en","text":"I left him as in the night preceding the fourth day of the days of the sacrifice:"},{"kind":"text","text":"(A:) or ["},{"kind":"italic_en","text":"as in the night preceding the day"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when the people return from their pilgrimage;"},{"kind":"text","text":"(S;) meaning, (assumed tropical:)"},{"kind":"italic_en","text":"possessing nothing."},{"kind":"text","text":"(M.)       -A2-  Also quasi-pl. n. of"},{"kind":"arabic","text_bw":"SaAdirN","text_ar":"صَادِرٌ"},{"kind":"text","text":", q. v. (M, K.)"}],"source_refs":["S","M","Msb","K","Lth","A"]}]}}