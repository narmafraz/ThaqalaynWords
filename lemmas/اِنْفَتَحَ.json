. another thing,)"},{"kind":"italic_en","text":"so as to disclose it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expose it to view."},{"kind":"text","text":"(TA.) [And ↓"},{"kind":"arabic","text_bw":"tft~H","text_ar":"تفتّح","orth_type":"arrow"},{"kind":"text","text":"has a similar meaning, but is properly said of a number of things.]"}],"source_refs":["S","A","Msb","TA"]}]},"classical_definitions":null}