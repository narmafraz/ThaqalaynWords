{"lemma":"عَلَوِيّانِ","slug":"عَلَوِيّانِ","root":"ع.ل.#","root_slug":"ع-ل-_","root_link":"/words/roots/ع-ل-_","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n30412","n30415"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"upper"},{"pos":"adj","gloss":"high, lofty"},{"pos":"adj","gloss":"roof, upstairs, overhead"},{"pos":"adj","gloss":"sublime, exalted"},{"pos":"adj","gloss":"heavenly, divine, celestial, astral, ethereal, empyreal"},{"pos":"adj","gloss":"Alawi"},{"pos":"noun","gloss":"Alawite"}]},"etymology":{"source":"wiktextract","text":"عُلُوّ (ʕuluww, “height, grandeur”) + ـِيّ (-iyy), with a modified version of عُلُوّ (ʕuluww).\n\nRelative adjective (nisba) composed of عَلِيّ (ʕaliyy, “high, exalted; Ali”) + ـَوـ (-aw-) + ـِيّ (-iyy), from the root ع ل ي (ʕ l y)."},"ipa":["/ʕul.wijj/","/ʕa.la.wijj/"]}