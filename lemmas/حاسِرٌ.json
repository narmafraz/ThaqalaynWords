{"lemma":"حاسِرٌ","slug":"حاسِرٌ","root":"ح.س.ر","root_slug":"ح-س-ر","root_link":"/words/roots/ح-س-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n7975"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D8%A7%D8%B3%D9%90%D8%B1%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7975","headword_ar":"حَاسِرٌ","root":"Hsr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"having no"},{"kind":"arabic","text_bw":"migofar","text_ar":"مِغْفَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"covering for the head, made of mail,"},{"kind":"text","text":"&c.,] (S, K,)"},{"kind":"italic_en","text":"upon him;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"nor a coat of mail;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"daAriEN","text_ar":"دَارِعٌ"},{"kind":"text","text":"; (Mgh;)"},{"kind":"italic_en","text":"nor a helmet upon his head;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"muqan~aEN","text_ar":"مُقَنَّعٌ"},{"kind":"text","text":": (Mgh:) or"},{"kind":"italic_en","text":"having no"},{"kind":"arabic","text_bw":"jun~ap","text_ar":"جُنَّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"defensive covering,"},{"kind":"text","text":"&c.]: (K:) a man"},{"kind":"italic_en","text":"having no turban on his head:"},{"kind":"text","text":"(TA:) a man"},{"kind":"italic_en","text":"having his head uncovered:"},{"kind":"text","text":"(A:) pl."},{"kind":"arabic","text_bw":"Hus~arN","text_ar":"حُسَّرٌ"},{"kind":"text","text":", and pl. pl."},{"kind":"arabic","text_bw":"Hus~aruwna","text_ar":"حُسَّرُونَ"},{"kind":"text","text":"; the latter a form used by one of the poets; the former pl. applied to"},{"kind":"italic_en","text":"foot-soldiers in war,"},{"kind":"text","text":"because they uncover their arms and legs, or because they have not upon them coats of mail nor helmets; occurring in this sense in a trad. (TA.) Also, without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", A woman"},{"kind":"italic_en","text":"who has taken off her shift from her person:"},{"kind":"text","text":"(ISd, Msb, TA:)"},{"kind":"italic_en","text":"who has taken off her clothes from her person: who has uncovered her head and her fore arms: who has taken off her head-covering:"},{"kind":"text","text":"and, with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", a woman"},{"kind":"italic_en","text":"having her face uncovered:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"Hus~arN","text_ar":"حُسَّرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HawaAsiru","text_ar":"حَوَاسِرُ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AibonuwA AlmasaAjida Hus~arFA","text_ar":"اِبْنُوا المَسَاجِدَ حُسَّرًا"},{"kind":"text","text":"in a trad. of 'Alee, means"},{"kind":"italic_en","text":"Build ye mosques,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oratories, with bare walls, with no"},{"kind":"arabic","text_bw":"$uraf","text_ar":"شُرَف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"acroterial ornaments"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crestings"},{"kind":"text","text":"]. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"HasiyrN","text_ar":"حَسِيرٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","Mgh","TA","A","ISd","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AD%D8%A7%D8%B3%D8%B1/","headword_ar":"حاسرين","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https