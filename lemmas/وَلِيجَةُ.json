{"lemma":"وَلِيجَةُ","slug":"وَلِيجَةُ","root":"#.ل.ج","root_slug":"_-ل-ج","root_link":"/words/roots/_-ل-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"وَلِيجَة","root":"ولج","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n42336"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%84%D9%90%D9%8A%D8%AC%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42336","headword_ar":"وَلِيجَةٌ","root":"wlj","body":[{"kind":"italic_en","text":"Anything that is introduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inserted, into a thing, and that does not belong to it:"},{"kind":"text","text":"any such thing is termed a"},{"kind":"arabic","text_bw":"wlyjp","text_ar":"وليجة"},{"kind":"text","text":"of a thing. (A'Obeyd.) ―         -b2-"},{"kind":"arabic","text_bw":"huwa waliyjatuhumo","text_ar":"هُوَ وَلِيجَتُهُمْ"},{"kind":"italic_en","text":"He is an adherent to them;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"one who has entered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become introduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"included, among them,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and not belonging to them."},{"kind":"text","text":"(TA.) Pl."},{"kind":"arabic","text_bw":"walaAy^iju","text_ar":"وَلَايِجُ"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"waliyjapN","text_ar":"وَلِيجَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimate, friend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associate,"},{"kind":"text","text":"of a man; syn."},{"kind":"arabic","text_bw":"xaAS~apN","text_ar":"خَاصَّةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"biTaAnapN","text_ar":"بِطَانَةٌ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"daxiylapN","text_ar":"دَخِيلَةٌ"},{"kind":"text","text":": (K:) by these syns. A'Obeyd explains it in the Kur. ix. 16: and it is applied to one and to more than one: (TA:) or"},{"kind":"italic_en","text":"one whom a person takes to rely upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to place confidence in, not being of his family:"},{"kind":"text","text":"(K:) and so some explain the word in the verse above referred to: (TA:) or it there signifies"},{"kind":"italic_en","text":"an intimate friend who is one of the polytheists."},{"kind":"text","text":"(Fr.)"}],"source_refs":["S","K","TA"]}]},"classical_definitions":null}