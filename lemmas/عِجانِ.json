{"lemma":"عِجانِ","slug":"عِجانِ","root":"ع.ج.ن","root_slug":"ع-ج-ن","root_link":"/words/roots/ع-ج-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28261","n28266"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%90%D8%AC%D8%A7%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"perineum"}]},"etymology":null,"ipa":["/ʕi.d͡ʒaːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28261","headword_ar":"عِجَانٌ","root":"Ejn","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"perinæum;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"what is between the anus and the scrotum:"},{"kind":"text","text":"(S, Msb:) or the ["},{"kind":"italic_en","text":"protion of the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qaDiyb","text_ar":"قَضِيب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"virga"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is extended from the scrotum to the anus;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"the kinder portion of the penis, extended within the skin:"},{"kind":"text","text":"and that of a woman is the"},{"kind":"arabic","text_bw":"watarap","text_ar":"وَتَرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"intervening part,"},{"kind":"text","text":"perhaps so called as being likened to the partition between the nostrils,]"},{"kind":"italic_en","text":"that is between the vulva and the anus:"},{"kind":"text","text":"(TA:) and the"},{"kind":"arabic","text_bw":"Aisot","text_ar":"اِسْت"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"anus"},{"kind":"text","text":"itself]: (K:) [see also"},{"kind":"arabic","text_bw":"EaDoraTN","text_ar":"عَضْرَطٌ"},{"kind":"text","text":":] pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEojinFpN","text_ar":"اَعْجِنًةٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"EujunN","text_ar":"عُجُنٌ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"Aibonu HamoraA='i","text_ar":"اِبْنُ حَمْرَا=ءِ"},{"kind":"arabic","text_bw":"AlEijaAni","text_ar":"العِجَانِ"},{"kind":"text","text":"is an appellation used in reviling, applied to one who is not an Arab; (TA in this art.;) or meaning"},{"kind":"italic_en","text":"Son of the female slave."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Hmr","text_ar":"حمر"},{"kind":"text","text":".) ―         -b2-  Also The"},{"kind":"italic_en","text":"neck,"},{"kind":"text","text":"(K, TA,) in the dial. of El-Yemen: or, as in the “ Nawádir ” of El- Kálee, the"},{"kind":"italic_en","text":"part beneath the chin."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","TA","K"]},{"entry_id":"n28266","headword_ar":"عَجَّانٌ","root":"Ejn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajiynN","text_ar":"عَجِينٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}