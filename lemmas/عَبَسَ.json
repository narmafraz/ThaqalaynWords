n":"m","num":"p"},{"role":"present_2mp","form":"تَعْبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْبِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْبِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْبِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَبَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَبَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْبِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْبِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"عَبَسَ","root":"عبس","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["name","noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27849"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%A8%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to frown, scowl, to show a crabbed face"},{"pos":"verb","gloss":"to become dirty or filthy, or have muck or urine dried upon oneself","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of عَبِسَ (ʕabisa) (form I)","tags":["form-of","noun-from-verb","obsolete"]},{"pos":"noun","gloss":"dried urine or dung upon the tail, muck, soil","tags":["obsolete"],"examples":[{"text":"يَا كَرَوَانًا ضُكَّ فَأَكْبَأَنَّا\nفَشَنَّ بِٱلسَلْخِ فَلَمَّا شَنَّا … بَلَّ ٱلذُنَابَى عَبَسًا مُبِنَّا","english":"You thick-knee! Which when bumped will clew and toss dung and having hurled … moistens the tail with sticky soil!"}]},{"pos":"name","gloss":"The 80th sura (chapter) of the Qur'an.","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of عَبَسَ (ʕabasa) (form I)","tags":["form-of","noun-from-verb","obsolete"]},{"pos":"noun","gloss":"synonym of بُرْنُوف (burnūf)","tags":["obsolete"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27849","headword_ar":"عَبَسَ","root":"Ebs","body":[{"kind":"text","text":", (S, L, Msb,) or"},{"kind":"arabic","text_bw":"Eabasa wajohahu","text_ar":"عَبَسَ وَجْهَهُ"},{"kind":"text","text":", (A, O, K, TA,) or"},{"kind":"arabic","text_bw":"wajohuhu","text_ar":"وَجْهُهُ"},{"kind":"text","text":", (Bd in lxxvi. 10,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EubuwsN","text_ar":"عُبُوسٌ"},{"kind":"text","text":"[app. properly used only when the verb is intrans.] (S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"EabosN","text_ar":"عَبْسٌ"},{"kind":"text","text":"[app. only when the verb is trans.]; (A, O, K;) and ↓"},{"kind":"arabic","text_bw":"Eb~s","text_ar":"عبّس","orth_type":"arrow"},{"kind":"text","text":", (L, K, TA,) inf. n."},{"kind":"arabic","text_bw":"taEobiysN","text_ar":"تَعْبِيسٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He frowned;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"looked sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely;"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"contracted his face:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he contracted the part between his eyes:"},{"kind":"text","text":"(L, TA:) or"},{"kind":"italic_en","text":"he grinned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"displayed his teeth, frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracting his face,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looking sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kalaHa","text_ar":"كَلَحَ"},{"kind":"text","text":": (S, A, O, K:) or ↓"},{"kind":"arabic","text_bw":"Eb~s","text_ar":"عبّس","orth_type":"arrow"},{"kind":"text","text":"has an intensive signification; (S, O, TA;)"},{"kind":"arabic","text_bw":"Eb~s wajohahu","text_ar":"عبّس وَجْهَهُ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he did so much:"},{"kind":"text","text":"(S, O:) or"},{"kind":"arabic","text_bw":"Eb~s","text_ar":"عبّس"},{"kind":"text","text":"[alone],"},{"kind":"italic_en","text":"he had"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"made"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a hateful face:"},{"kind":"text","text":"but when one displays his teeth, or grins, the epithet"},{"kind":"arabic","text_bw":"kaAliHN","text_ar":"كَالِحٌ"},{"kind":"text","text":"is applied to him: (TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"tEb~s","text_ar":"تعبّس","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"tajah~ama","text_ar":"تَجَهَّمَ"},{"kind":"text","text":", (S, O, K,) i. e."},{"kind":"italic_en","text":"he showed a sour, a crabbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an austere, face;"},{"kind":"text","text":"(TK;) and"},{"kind":"arabic","text_bw":"taqaT~aba","text_ar":"تَقَطَّبَ"},{"kind":"text","text":"[which is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"Eabasa","text_ar":"عَبَسَ"},{"kind":"text","text":"]. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Eabasa Alyawomu","text_ar":"عَبَسَ اليَوْمُ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"Eabasa mino $ahida Alyawoma","text_ar":"عَبَسَ مِنْ شَهِدَ اليَوْمَ"},{"kind":"italic_en","text":"He who witnessed the day frowned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted his face,"},{"kind":"text","text":"&c., (see"},{"kind":"arabic","text_bw":"yuwomN","text_ar":"يُوْمٌ"},{"kind":"arabic","text_bw":"EabuwsN","text_ar":"عَبُوسٌ"},{"kind":"text","text":",)] means (assumed tropical:)"},{"kind":"italic_en","text":"the day was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distressful, afflictive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calamitous."},{"kind":"text","text":"(Msb.)       -A2-"},{"kind":"arabic","text_bw":"Eabisato","text_ar":"عَبِسَتْ"},{"kind":"text","text":"said of camels: see 4. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Eabisa","text_ar":"عَبِسَ"},{"kind":"text","text":"said of a man,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"(TA.) ―         -b3-  And said of a garment,"},{"kind":"italic_en","text":"It had dirt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth, that had dried upon it."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Eabisa Alwasaxu fiY yadihi","text_ar":"عَبِسَ الوَسَخُ فِى يَدِهِ"},{"kind":"text","text":"(S, K, TA) and"},{"kind":"arabic","text_bw":"EalaY yadihi","text_ar":"عَلَى يَدِهِ"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"The dirt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth, dried upon his hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm."},{"kind":"text","text":"(S, K, TA.) ―         -b5-  And [the inf. n.]"},{"kind":"arabic","text_bw":"EabasN","text_ar":"عَبَسٌ"},{"kind":"text","text":"signifies A slave's"},{"kind":"italic_en","text":"voiding his urine in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on, his bed, when he has a habit of doing so and the effect thereof appears upon his person,"},{"kind":"text","text":"(O, TA,)"},{"kind":"italic_en","text":"by reason of its muchness,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"and upon his bed:"},{"kind":"text","text":"(TA:) for doing this he may be returned; (O, TA;) but not if it is little and rare. (O.)"}],"source_refs":["S","L","Msb","A","O","K","TA"]}]},"classical_definitions":null}