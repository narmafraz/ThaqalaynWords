{"lemma":"بادِياتٌ","slug":"بادِياتٌ","root":"ب.د.#","root_slug":"ب-د-_","root_link":"/words/roots/ب-د-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n1967","n2059"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D8%A7%D8%AF%D9%90%D9%8A%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"desert"},{"pos":"noun","gloss":"peasantry"},{"pos":"noun","gloss":"nomads"}]},"etymology":null,"ipa":["/baː.di.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1967","headword_ar":"بَادِيَةٌ","root":"bdA^","body":[{"kind":"text","text":": see 1, in two places."}],"source_refs":[]},{"entry_id":"n2059","headword_ar":"بَادِيَةٌ","root":"bdw","body":[{"kind":"text","text":"(T, S, &c.)"},{"kind":"italic_en","text":"A desert;"},{"kind":"text","text":"so called because of its being open, or uncovered; (TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HaDarN","text_ar":"حَضَرٌ"},{"kind":"text","text":"; (M, K;) as also ↓"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ","orth_type":"arrow"},{"kind":"text","text":", (S, * M, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"baAdaApN","text_ar":"بَادَاةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) or ↓"},{"kind":"arabic","text_bw":"badaApN","text_ar":"بَدَاةٌ","orth_type":"arrow"},{"kind":"text","text":", (TA, [thought by SM to be the correct form because found by him in the M, in which I find"},{"kind":"arabic","text_bw":"bAdAp","text_ar":"باداة"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"badiY~N","text_ar":"بَدِىٌّ","orth_type":"arrow"},{"kind":"text","text":", said to be used as syn. with"},{"kind":"arabic","text_bw":"baAdiyapN","text_ar":"بَادِيَةٌ"},{"kind":"text","text":"in a verse of Lebeed cited among the exs. of the preposition"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":", p. 142, (TA,) and ↓"},{"kind":"arabic","text_bw":"bdaAwapN","text_ar":"بدَاوَةٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"bidaAwapN","text_ar":"بِدَاوَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (M;) [of which the last two and the second (namely,"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":",) seem to be originally inf. ns.; see 1:] or"},{"kind":"italic_en","text":"a land in which are no towns or villages or cultivated soil:"},{"kind":"text","text":"(Lth, T:) or the"},{"kind":"italic_en","text":"places to which people migrate from the constant sources of water, when they go forth to the desert, seeking the vicinity of herbage;"},{"kind":"text","text":"also termed"},{"kind":"arabic","text_bw":"mabaAdK","text_ar":"مَبَادٍ"},{"kind":"text","text":", which is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"manaAjiEu","text_ar":"مَنَاجِعُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"maHaADiru","text_ar":"مَحَاضِرُ"},{"kind":"text","text":", and pl. of ↓"},{"kind":"arabic","text_bw":"mabodFY","text_ar":"مَبْدًى","orth_type":"arrow"},{"kind":"text","text":", (T,) this last signifying the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"maHoDarN","text_ar":"مَحْضَرٌ"},{"kind":"text","text":": (S:) the pl. of"},{"kind":"arabic","text_bw":"baAdiyapN","text_ar":"بَادِيَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"bawaAdK","text_ar":"بَوَادٍ"},{"kind":"text","text":". (T, Msb.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"baAdK","text_ar":"بَادٍ"},{"kind":"text","text":"."}],"source_refs":["M","K","TA","Lth","T","S"]}]}}