{"lemma":"غابَ","slug":"غابَ","root":"غ.#.ب","root_slug":"غ-_-ب","root_link":"/words/roots/غ-_-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"غِبْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"غِبْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"غِبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"غِبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"غِبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"غابَ","in_corpus":true,"count":52,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"غابَت","in_corpus":true,"count":39,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"غابا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"غابَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"غابُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"غِبْنَ","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَغِب","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَغِيب","in_corpus":true,"count":49,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَغِيبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَغِيبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَغِيبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَغِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَغِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَغِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَغِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَغِب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَغِيب","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَغِب","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَغِيب","in_corpus":true,"count":49,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَغِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَغِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَغِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَغِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَغِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَغِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَغِبْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"غِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غِبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَغِيب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":230,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n31321","n32678","n32683"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be absent"},{"pos":"verb","gloss":"to become absent; to vanish, to disappear"},{"pos":"verb","gloss":"to set; to go down (of the sun, the moon, etc.)","examples":[{"text":"الإِمْبْرَاطُورِيَّة اَلَّتِي لَا تَغِيبُ عَنْهَا الشَمْس","english":"the empire on which the sun never sets"}]},{"pos":"verb","gloss":"to backbite, to speak badly of an absent person."}]},"etymology":null,"ipa":["/ɣaː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31321","headword_ar":"غَابٌّ","root":"gb","body":[{"kind":"text","text":"[part. n. of"},{"kind":"arabic","text_bw":"gab~a","text_ar":"غَبَّ"},{"kind":"text","text":"]. You say"},{"kind":"arabic","text_bw":"A_ibilN gaAb~apN","text_ar":"اـِبِلٌ غَابَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gawaAb~u","text_ar":"غَوَابُّ"},{"kind":"italic_en","text":"Camels coming to water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drinking, on alternate days."},{"kind":"text","text":"(As, S, O, K.) ―         -b2-  And Flesh-meat"},{"kind":"italic_en","text":"that has remained throughout a night:"},{"kind":"text","text":"(S, O:) or"},{"kind":"italic_en","text":"stinking"},{"kind":"text","text":"flesh-meat: (TA:) or food, and dates, and, as also ↓"},{"kind":"arabic","text_bw":"gabiybN","text_ar":"غَبِيبٌ","orth_type":"arrow"},{"kind":"text","text":", flesh-meat,"},{"kind":"italic_en","text":"that has remained throughout a night,"},{"kind":"text","text":"whether it have become corrupt or not: (L:) and applied also to bread. (S and K in art."},{"kind":"arabic","text_bw":"byt","text_ar":"بيت"},{"kind":"text","text":".) ―         -b3-  And"},{"kind":"arabic","text_bw":"najomN","text_ar":"نَجْمٌ"},{"kind":"arabic","text_bw":"gaAb~N","text_ar":"غَابٌّ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A fixed star"},{"kind":"text","text":"[app. because of its twinkling, or shining with intermitted light]. (A.)"}],"source_refs":["S","O","TA","L"]},{"entry_id":"n32678","headword_ar":"غَابَ","root":"gyb","body":[{"kind":"text","text":", (S, O, Mgh, Msb, TA,) aor."},{"kind":"arabic","text_bw":"yagiybu","text_ar":"يَغِيبُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"gayobapN","text_ar":"غَيْبَةٌ"},{"kind":"text","text":"[the most common form] (S, O, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"gayobN","text_ar":"غَيْبٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"gayaAbN","text_ar":"غَيَابٌ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"giyaAbN","text_ar":"غِيَابٌ"},{"kind":"text","text":", (Msb, K,) and"},{"kind":"arabic","text_bw":"guyuwbN","text_ar":"غُيُوبٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"guyuwbapN","text_ar":"غُيُوبَةٌ"},{"kind":"text","text":"(O, K) and"},{"kind":"arabic","text_bw":"gayobuwbapN","text_ar":"غَيْبُوبَةٌ"},{"kind":"text","text":", (O, K,) accord. to some of the measure"},{"kind":"arabic","text_bw":"faEoluwlapN","text_ar":"فَعْلُولَةٌ"},{"kind":"text","text":", but accord. to others of the measure"},{"kind":"arabic","text_bw":"fayoEaluwlapN","text_ar":"فَيْعَلُولَةٌ"},{"kind":"text","text":"i. e. originally"},{"kind":"arabic","text_bw":"gay~abuwbapN","text_ar":"غَيَّبُوبَةٌ"},{"kind":"text","text":", (MF,) and"},{"kind":"arabic","text_bw":"magiybN","text_ar":"مَغِيبٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"magaAbN","text_ar":"مَغَابٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"tgy~b","text_ar":"تغيّب","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, absent;"},{"kind":"arabic","text_bw":"gaAba","text_ar":"غَابَ"},{"kind":"text","text":"being the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":"; (S and K in art."},{"kind":"arabic","text_bw":"HDr","text_ar":"حضر"},{"kind":"text","text":";) or"},{"kind":"italic_en","text":"distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote;"},{"kind":"text","text":"(Mgh;) or"},{"kind":"italic_en","text":"hidden, concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unapparent;"},{"kind":"text","text":"(TA;) [or"},{"kind":"italic_en","text":"absent from the range,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beyond the reach, of perception by sense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of mental perception:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"gayobN","text_ar":"غَيْبٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"gAb Eanohu","text_ar":"غاب عَنْهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gayobapN","text_ar":"غَيْبَةٌ"},{"kind":"text","text":"(S, Mgh, TA) &c., as above, (S, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"absent from him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, from him;"},{"kind":"text","text":"(Mgh;) or"},{"kind":"italic_en","text":"hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, from him;"},{"kind":"text","text":"[&c.;] as also ↓"},{"kind":"arabic","text_bw":"tgy~b","text_ar":"تغيّب","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"A^awoHa$atoniY gayobapu fulaAnK","text_ar":"اَوْحَشَتْنِى غَيْبَةُ فُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The absence of such a one has made me to feel lonely"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"A^aTalota","text_ar":"اَطَلْتَ"},{"kind":"arabic","text_bw":"gayobataka","text_ar":"غَيْبَتَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou hast made thine absence to be long"},{"kind":"text","text":"]. (A.) And ↓"},{"kind":"arabic","text_bw":"A^anaA maEakumo laA A^ugaAyibukumo","text_ar":"اَنَا مَعَكُمْ لَا اُغَايِبُكُمْ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I am with you: I will not be absent from you"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"banuw","text_ar":"بَنُو"},{"kind":"arabic","text_bw":"A^aHoyaAnFA","text_ar":"اَحْيَانًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fulaAnK ya$ohaduwna A^aHoyaAnFA wayatagaAyabuwna","text_ar":"فُلَانٍ يَشْهَدُونَ اَحْيَانًا وَيَتَغَايَبُونَ","orth_type":"arrow"},{"kind":"text","text":"(ISk, S, TA) i. e. ["},{"kind":"italic_en","text":"The sons of such a one are present sometimes"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and are absent"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yagiybuwna","text_ar":"يَغِيبُونَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"sometimes:"},{"kind":"text","text":"but one does not say ↓"},{"kind":"arabic","text_bw":"yatagay~abuwna","text_ar":"يَتَغَيَّبُونَ","orth_type":"arrow"},{"kind":"text","text":"[unless with"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"following it]: (TA:) [it seems, however, that"},{"kind":"arabic","text_bw":"ytgy~bwn","text_ar":"يتغيّبون"},{"kind":"text","text":", here, is a mistranscription for"},{"kind":"arabic","text_bw":"yatagay~abuwnanaA","text_ar":"يَتَغَيَّبُونَنَا"},{"kind":"text","text":"or the like; for] one says,"},{"kind":"arabic","text_bw":"Ean~iY fulaAnN","text_ar":"عَنِّى فُلَانٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tgy~b","text_ar":"تغيّب","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, absent from me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"absented himself from me"},{"kind":"text","text":"]; (S, K, * TA;) and ↓"},{"kind":"arabic","text_bw":"tagay~abaniY","text_ar":"تَغَيَّبَنِى","orth_type":"arrow"},{"kind":"text","text":"also in a case of necessity in verse, (S, K, TA,) but not in any other case, (K, TA,) accord. to the generality of authorities except the Koofees: (TA:) Imra-el-Keys says,"},{"kind":"quote","text":"faZal~a lanaA yawomN la*iy*N binaEomapK\n                      \n                     \n                        faqulo fiY maqiylK naHosuhu mutagay~ibiY"},{"kind":"text","text":"[thus in my copies of the S and in the TA; but we should read"},{"kind":"arabic","text_bw":"mutagay~ibi","text_ar":"مُتَغَيِّبِ"},{"kind":"text","text":", whether it mean"},{"kind":"arabic","text_bw":"mutagay~ibiY","text_ar":"مُتَغَيِّبِى"},{"kind":"text","text":"or not, as is shown by what follows: the verse may be rendered,"},{"kind":"italic_en","text":"So a delightful day, with ease and comfort, betided us: and say thou, of a place of midday-sleep whereof the ill luck was absent from me,"},{"kind":"text","text":". . .]: but Fr says that the word"},{"kind":"arabic","text_bw":"mtgy~b","text_ar":"متغيّب"},{"kind":"text","text":"is marfooa, [i. e. that the right reading is"},{"kind":"arabic","text_bw":"mutagay~ibu","text_ar":"مُتَغَيِّبُ"},{"kind":"text","text":", meaning simply"},{"kind":"italic_en","text":"absent,"},{"kind":"text","text":"] that the verse is"},{"kind":"arabic","text_bw":"mukofaA^","text_ar":"مُكْفَا"},{"kind":"text","text":"[or made faulty in the termination], and that it is not allowable to make that word refer to"},{"kind":"arabic","text_bw":"maqiylK","text_ar":"مَقِيلٍ"},{"kind":"text","text":", like as it is not allowable to say"},{"kind":"arabic","text_bw":"mararotu","text_ar":"مَرَرْتُ"},{"kind":"arabic","text_bw":"birajulK A^abuwhu qaAy^imK","text_ar":"بِرَجُلٍ اَبُوهُ قَايِمٍ"},{"kind":"text","text":". (S, TA. [One might be tempted to suppose that we should read"},{"kind":"arabic","text_bw":"faqilo","text_ar":"فَقِلْ"},{"kind":"text","text":"; but this would not suit the context, which see in Ahlwardt's “ Divans of the six ancient Arabic poets, ” p. 119.]) ―         -b2-  ["},{"kind":"arabic","text_bw":"gAb","text_ar":"غاب"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gayobapN","text_ar":"غَيْبَةٌ"},{"kind":"text","text":", is also said of the mind ("},{"kind":"arabic","text_bw":"Alqalob","text_ar":"القَلْب"},{"kind":"text","text":"), meaning (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, absent."},{"kind":"text","text":"The inf. n. ("},{"kind":"arabic","text_bw":"gayobapN","text_ar":"غَيْبَةٌ"},{"kind":"text","text":") is often used as meaning (assumed tropical:)"},{"kind":"italic_en","text":"Absence of mind;"},{"kind":"text","text":"and particularly,"},{"kind":"italic_en","text":"from self and others by its being exclusively occupied by the contemplation of divine things:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"$awFY","text_ar":"شَوًى"},{"kind":"text","text":"; and another voce"},{"kind":"arabic","text_bw":"sakiynapN","text_ar":"سَكِينَةٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"maA gaAba Eanohu","text_ar":"مَا غَابَ عَنْهُ"},{"kind":"arabic","text_bw":"A@bonu A^abiY quHaAfapa","text_ar":"ا@بْنُ اَبِى قُحَافَةَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Ibn-Abee-Koháfeh was not a stranger to it,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"was not unacquainted with it,"},{"kind":"text","text":"] occurs in a trad. respecting a satirical saying of Hassán against [the tribe of] Kureysh; meaning that Aboo-Bekr [the son of Aboo-Koháfeh] was skilled in genealogies and traditions, and that it was he who instructed Hassán. (TA.) ―         -b4-  And one says also,"},{"kind":"arabic","text_bw":"gAb Alr~ajulu","text_ar":"غاب الرَّجُلُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gayobN","text_ar":"غَيْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"magiybN","text_ar":"مَغِيبٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tgy~b","text_ar":"تغيّب","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The man journeyed;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far away."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"gAbt Al$~amosu","text_ar":"غابت الشَّمْسُ"},{"kind":"text","text":", (S, Mgh, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"giyaAbN","text_ar":"غِيَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gayobuwbapN","text_ar":"غَيْبُوبَةٌ"},{"kind":"text","text":"(Mgh, Msb, TA) and"},{"kind":"arabic","text_bw":"gayobapN","text_ar":"غَيْبَةٌ"},{"kind":"text","text":"(Mgh) and"},{"kind":"arabic","text_bw":"guyuwbN","text_ar":"غُيُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"guyuwbapN","text_ar":"غُيُوبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"magiybN","text_ar":"مَغِيبٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"tgy~bt","text_ar":"تغيّبت","orth_type":"arrow"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"The sun set:"},{"kind":"text","text":"(S, Msb, TA:) and the like is also said of the moon, (Msb,) and of other celestial bodies. (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"gAb Al$~aYo'u fiY Al$~aYo'i","text_ar":"غاب الشَّىْءُ فِى الشَّىْءِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"giyaAbapN","text_ar":"غِيَابَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"guyuwbapN","text_ar":"غُيُوبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"giyaAbN","text_ar":"غِيَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gayaAbN","text_ar":"غَيَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"giybapN","text_ar":"غِيبَةٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The thing became hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, in the thing."},{"kind":"text","text":"] (K.)       -A2-  See also 8, in two places."}],"source_refs":["S","O","Mgh","Msb","TA","K","MF","ISk"]},{"entry_id":"n32683","headword_ar":"غَابٌ","root":"gyb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gaAbapN","text_ar":"غَابَةٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]}]}}