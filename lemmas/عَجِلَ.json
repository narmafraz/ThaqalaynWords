,{"role":"present_2mp","form":"تَعْجَلُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْجَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْجَل","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْجَل","in_corpus":true,"count":23,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْجَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْجَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْجَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْجَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْجَلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْجَلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْجَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَجِلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَجِلْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْجَل","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْجَل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":115,"cross_references":{"qac":{"found":true,"lemma_key":"عَجِلَ","root":"عجل","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28192"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%90%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"calf (young head of cattle)"},{"pos":"verb","gloss":"to hurry"},{"pos":"adj","gloss":"fast, quick"},{"pos":"noun","gloss":"verbal noun of عَجِلَ (ʕajila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"masculine plural of أَعْجَل (ʔaʕjal)","tags":["form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine plural of عَجُول (ʕajūl)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-West Semitic *ʕigl-. Cognate with Hebrew עֵגֶל ('eguèl, “calf”).\n\nCompare عَجِلَ (ʕajila, “to hurry, to rush”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28192","headword_ar":"عَجِلَ","root":"Ejl","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] (S, Mgh, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EajalapN","text_ar":"عَجَلَةٌ"},{"kind":"text","text":", (S, * Mgh, O, * Msb, K, *)"},{"kind":"italic_en","text":"He hasted, hastened, made haste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sped; he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hasty, speedy, quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expeditious;"},{"kind":"text","text":"(S, Mgh, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tEj~l","text_ar":"تعجّل","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Ej~l","text_ar":"عجّل","orth_type":"arrow"},{"kind":"text","text":", [app. for"},{"kind":"arabic","text_bw":"Ej~l nafosahu","text_ar":"عجّل نَفْسَهُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"taEojiylN","text_ar":"تَعْجِيلٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AstEjl","text_ar":"استعجل","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb;) or this last signifies"},{"kind":"italic_en","text":"he required himself to haste,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"constraining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tasking, himself to do so."},{"kind":"text","text":"(Sb, K.) [See also"},{"kind":"arabic","text_bw":"EajalN","text_ar":"عَجَلٌ"},{"kind":"text","text":"below.] One says,"},{"kind":"arabic","text_bw":"Eajilotu lahu","text_ar":"عَجِلْتُ لَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I hasted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (O.) And"},{"kind":"arabic","text_bw":"Eajilotu bihi","text_ar":"عَجِلْتُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beforehand, with him"},{"kind":"text","text":"]: see 4. (Mgh.) And"},{"kind":"arabic","text_bw":"Eajilotu A_ilaY Al$~aYo'i","text_ar":"عَجِلْتُ اـِلَى الشَّىْءِ"},{"kind":"italic_en","text":"I"},{"kind":"italic_en","text":"preceded, outwent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got first, to the thing."},{"kind":"text","text":"(Msb.) ―         -b2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready;"},{"kind":"text","text":"said of a price, hire, payment, or the like;"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^ajila","text_ar":"اَجِلَ"},{"kind":"text","text":"]. (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Eajila minohu","text_ar":"عَجِلَ مِنْهُ"},{"kind":"italic_en","text":"He turned aside from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.)       -A2-  [It is also trans., as having, or implying, the meaning of"},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":":] see 4."}],"source_refs":["S","Mgh","O","Msb","K"]}]}}