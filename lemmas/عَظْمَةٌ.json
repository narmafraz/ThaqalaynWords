: "and] it is not to be specified by the ascription of its quality, nor defined, nor likened to anything. (TA.) ―         -b3-  Also The"}, {"kind": "italic_en", "text": "thick part"}, {"kind": "text", "text": "of the fore arm; (S;) the"}, {"kind": "italic_en", "text": "half next the elbow,"}, {"kind": "text", "text": "of the fore arm,"}, {"kind": "italic_en", "text": "in which is the"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "main"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "muscle;"}, {"kind": "text", "text": "the half next the hand being called the"}, {"kind": "arabic", "text_bw": "A^asalap", "text_ar": "اَسَلَة"}, {"kind": "text", "text": ". (Lh, K.) ―         -b4-  And The"}, {"kind": "italic_en", "text": "thick part"}, {"kind": "text", "text": "of the tongue, (K, TA,)"}, {"kind": "italic_en", "text": "above the"}, {"kind": "arabic", "text_bw": "Eakadap", "text_ar": "عَكَدَة"}, {"kind": "text", "text": ", which is the"}, {"kind": "italic_en", "text": "root"}, {"kind": "text", "text": "thereof. (TA.) ―         -b5-"}, {"kind": "arabic", "text_bw": "EaZamaAtu", "text_ar": "عَظَمَاتُ"}, {"kind": "arabic", "text_bw": "Alqawomi", "text_ar": "القَوْمِ"}, {"kind": "italic_en", "text": "The chiefs,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "nobles, of the people,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "party."}, {"kind": "text", "text": "(K, * TA.) ―         -b6-  See also"}, {"kind": "arabic", "text_bw": "A_iEoZaAmapN", "text_ar": "اـِعْظَامَةٌ"}, {"kind": "text", "text": "."}], "source_refs": ["S", "K", "Az", "TA"]}, {"entry_id": "n29678", "headword_ar": "عَظِمَةٌ", "root": "EZm", "body": [{"kind": "text", "text": "A female"}, {"kind": "italic_en", "text": "that desires great"}, {"kind": "arabic", "text_bw": "A^uyuwr", "text_ar": "اُيُور"}, {"kind": "text", "text": "[pl. of"}, {"kind": "arabic", "text_bw": "A^ayorN", "text_ar": "اَيْرٌ"}, {"kind": "text", "text": ", q. v.]; as