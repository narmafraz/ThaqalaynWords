,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْزِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْزِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْزُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْزُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْزِمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْزِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْزُمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْزُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْزِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرْزُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رَزَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَزَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْزِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْزِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْزُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْزُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n15406"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B2%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15406","headword_ar":"رَزَمَ","root":"rzm","body":[{"kind":"text","text":", said of a camel, (Lh, K,) and of a man, &c.; (Lh, TA;) or"},{"kind":"arabic","text_bw":"razamato","text_ar":"رَزَمَتْ"},{"kind":"text","text":", said of a she-camel; (S;) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ruzuwmN","text_ar":"رُزُومٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruzaAmN","text_ar":"رُزَامٌ"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He was unable to rise,"},{"kind":"text","text":"(Lh, K, TA,)"},{"kind":"italic_en","text":"in consequence of his having fallen down by reason of fatigue and emaciation,"},{"kind":"text","text":"(Lh, TA,) or"},{"kind":"italic_en","text":"in consequence of emaciation"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"arising from hunger or disease:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"she stood still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped from journeying, in consequence of fatigue and emaciation, and was motionless."},{"kind":"text","text":"(S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"razama","text_ar":"رَزَمَ"},{"kind":"text","text":", (K, TA,) said of a man, inf. n."},{"kind":"arabic","text_bw":"razomN","text_ar":"رَزْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He died."},{"kind":"text","text":"(K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"razama EalaY qironihi","text_ar":"رَزَمَ عَلَى قِرْنِهِ"},{"kind":"italic_en","text":"He overcame his adversary, and kneeled upon him,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and quitted not his place."},{"kind":"text","text":"(TA.) One says of a lion"},{"kind":"arabic","text_bw":"razama EalaY firiysatihi","text_ar":"رَزَمَ عَلَى فِرِيسَتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He lay upon his breast on his prey, not quitting it"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Airozimo bihi","text_ar":"اِرْزِمْ بِهِ"},{"kind":"arabic","text_bw":"maA razama","text_ar":"مَا رَزَمَ"},{"kind":"italic_en","text":"Be thou firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steadfast, with it as long as it is firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steadfast:"},{"kind":"text","text":"referring to fortune when it is severe, or rigorous. (Ham p. 362.) ―         -b5-  And"},{"kind":"arabic","text_bw":"razama biAl$~aYo'i","text_ar":"رَزَمَ بِالشَّىْءِ"},{"kind":"italic_en","text":"He laid hold upon the thing."},{"kind":"text","text":"(K.) ―         -b6-"},{"kind":"arabic","text_bw":"$adiydapF","text_ar":"شَدِيدَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"razama Al$~itaA='u razomapF","text_ar":"رَزَمَ الشِّتَا=ءُ رَزْمَةً","orth_type":"arrow"},{"kind":"italic_en","text":"The winter was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, intensely cold."},{"kind":"text","text":"(K, * TA.) Hence ↓"},{"kind":"arabic","text_bw":"nawo'u Almirozami","text_ar":"نَوْءُ المِرْزَمِ","orth_type":"arrow"},{"kind":"text","text":"[q. v. infrà]. (K, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"razamati AlA^um~u bihi","text_ar":"رَزَمَتِ الاُمُّ بِهِ"},{"kind":"italic_en","text":"The mother brought him forth:"},{"kind":"text","text":"(K:) and so"},{"kind":"arabic","text_bw":"zaramato bihi","text_ar":"زَرَمَتْ بِهِ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"razama Al$~aYo'a","text_ar":"رَزَمَ الشَّىْءَ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"razomN","text_ar":"رَزْمٌ"},{"kind":"text","text":", (Msb, TA,)"},{"kind":"italic_en","text":"He collected together the thing"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"in a garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth."},{"kind":"text","text":"(K. [See 2.])       -A3-  See also 4."}],"source_refs":["Lh","K","TA","S","Msb"]}]},"classical_definitions":null}