{"lemma":"أَمِيرٌ","slug":"أَمِيرٌ","root":"#.م.ر","root_slug":"_-م-ر","root_link":"/words/roots/_-م-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n1221",""],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%90%D9%8A%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"prince"},{"pos":"noun","gloss":"commander"}]},"etymology":{"source":"wiktextract","text":"From ء م ر (ʔ m r), meaning to command, to order."},"ipa":["/ʔa.miːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1221","headword_ar":"اَمِيرٌ","root":"Amr","body":[{"kind":"italic_en","text":"One having, holding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possessing, command;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"a commander; a governor; a lord;"},{"kind":"text","text":"(M, * Msb;)"},{"kind":"italic_en","text":"a prince,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"king:"},{"kind":"text","text":"(M, K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, K:) pl."},{"kind":"arabic","text_bw":"A_umaraA='u","text_ar":"اـُمَرَا=ءُ"},{"kind":"text","text":". (M, Msb, K.) ―         -b2-"},{"kind":"italic_en","text":"A leader of the blind."},{"kind":"text","text":"(M, K.) So in the saying of El-Aashà:"},{"kind":"quote","text":"A_i*aAkaAna haAdiY AlfataY fiY AlbilaA\n                      \n                      \n                        diSadora AlqanaApi A^aTaAEa AlA^amiyraA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When the young man's guide in the countries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, is the top of the cane, he obeys the leader of the blind"},{"kind":"text","text":"]. (M.) ―         -b3-  A woman's"},{"kind":"italic_en","text":"husband."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"italic_en","text":"A neighbour."},{"kind":"text","text":"(K.) ―         -b5-"},{"kind":"italic_en","text":"A person with whom one consults:"},{"kind":"text","text":"(A, K:)"},{"kind":"italic_en","text":"any one of whom one begs counsel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advice, in a case of fear."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"huwa A^amiyriY","text_ar":"هُوَ اَمِيرِى"},{"kind":"italic_en","text":"He is the person with whom I consult."},{"kind":"text","text":"(A.)"}],"source_refs":["M","K","S","A"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%85%D9%8A%D8%B1/","headword_ar":"أميرون","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=49857#088ba7","body_html":"أميرون: (مأخوذة من النعت اللاتيني amarus لأن هذا النبات مر الطعم (سيمونه 250 وهو بالأسبانية almir?n و amarg?n) هندباء بري، (معجم الأسبانية 166، ابن العوام 2: 365).<br>عشبة الأَمَيْرُون مذكورة أيضاً في المعجم اللاتيني، (بعد كلمتين من كلمة arundo غير ان اللفظة اللاتينية التي تقابلها قد أصبحت غير واضحة لتقرأ)."}]}}