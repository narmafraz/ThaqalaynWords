s_definition": {"source": "lanes", "entries": [{"entry_id": "n27340", "headword_ar": "تطاول", "root": "Twl", "body": [{"kind": "text", "text": ": see 1, former half. ―         -b2-  Also"}, {"kind": "italic_en", "text": "It became high by degrees;"}, {"kind": "text", "text": "said of a building. (L in art."}, {"kind": "arabic", "text_bw": "$yd", "text_ar": "شيد"}, {"kind": "text", "text": ".) ―         -b3-  And"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "taTaAl~a", "text_ar": "تَطَالَّ"}, {"kind": "text", "text": "or"}, {"kind": "arabic", "text_bw": "taTaAlala", "text_ar": "تَطَالَلَ"}, {"kind": "text", "text": ", (S, K, TA,) meaning"}, {"kind": "italic_en", "text": "He"}, {"kind": "text", "text": "(a man, S, TA)"}, {"kind": "italic_en", "text": "stood upon his toes, and stretched his stature, to look at a thing:"}, {"kind": "text", "text": "(TA:) or"}, {"kind": "arabic", "text_bw": "taTaAwalotu fiY qiyaAmiY", "text_ar": "تَطَاوَلْتُ فِى قِيَامِى"}, {"kind": "italic_en", "text": "I stretched my legs, in my standing, to look."}, {"kind": "text", "text": "(O.) One says,"}, {"kind": "arabic", "text_bw": "yataTaAwalu liloA^afonaAni wayajota*ibuhaA biAlmiHojani", "text_ar": "يَتَطَاوَلُ لِلْاَفْنَانِ وَيَجْتَذِبُهَا بِالمِحْجَنِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He stretches himself up towards the branches, and draws them to him with the hooked-headed stick"}, {"kind": "text", "text": "]. (S in art."}, {"kind": "arabic", "text_bw": "Hrq", "text_ar": "حرق"}, {"kind": "text", "text": ".) And it is said in a trad.,"}, {"kind": "arabic", "text_bw": "tTAwl Ealayohimu", "text_ar": "تطاول عَلَيْهِمُ"}, {"kind": "arabic", "text_bw": "Alr~ab~u bifaDolihi", "text_ar": "الرَّبُّ بِفَضْلِهِ"}, {"kind": "italic_en", "text": "The Lord looked down upon them,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regarded them compassionately,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "A^a$orafa", "text_ar": "اَشْرَفَ"}, {"kind": "text", "text": ",)"}, {"kind": "italic_en", "text": "with his favour"}, {"kind": "text", "text": "(O.) ―         -b4-  Also"}, {"kind": "italic_en", "text": "He made a show of"}, {"kind": "arabic", "text_bw": "AlT~uwl", "text_ar": "الطُّول"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "tallness"}, {"kind": "text", "text": "], or"}, {"kind": "arabic", "text_bw": "AlT~awol", "text_ar": "الطَّوْل"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "beneficence,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "excellence,"}, {"kind": "text", "text": "&c.]. (TA.) ―         -b5-"}, {"kind": "arabic", "text_bw": "tTAwl Ealayohi", "text_ar": "تطاول عَلَيْهِ"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "AstTAl", "text_ar": "استطال", "orth_type": "arrow"}, {"kind": "text", "text": "signify the same; (Az, S, O, Msb, K, TA;)"}, {"kind": "italic_en", "text": "He held up his head with a show of superiority over him;"}, {"kind": "text", "text": "(Az, TA;) [i. e."}, {"kind": "italic_en", "text": "he behaved haughtily, arrogantly, overweeningly, overbearingly, domineeringly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "proudly, towards him; domineered over him;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "exalted himself above him;"}, {"kind": "text", "text": "] or"}, {"kind": "italic_en", "text": "he overbore, overpowered, subdued,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "oppressed, him:"}, {"kind": "text", "text": "(Msb:)"}, {"kind": "arabic", "text_bw": "Elyh", "text_ar": "عليه"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "AstTAl", "text_ar": "استطال", "orth_type": "arrow"}, {"kind": "text", "text": "is also expl. as meaning"}, {"kind": "italic_en", "text": "he arrogated to himself excellence over him,"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "tafaD~ala", "text_ar": "تَفَضَّلَ"}, {"kind": "text", "text": "; (K, TA;)"}, {"kind": "italic_en", "text": "and exalted himself above him:"}, {"kind": "text", "text": "(TA:) and"}, {"kind": "arabic", "text_bw": "Ealayohimo", "text_ar": "عَلَيْهِمْ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "AstTAlwA", "text_ar": "استطالوا", "orth_type": "arrow"}, {"kind": "text", "text": "as meaning"}, {"kind": "italic_en", "text": "they slew of them more than they"}, {"kind": "text", "text": "[the latter]"}, {"kind": "italic_en", "text": "had slain"}, {"kind": "text", "text": "(S, O, K)"}, {"kind": "italic_en", "text": "of them"}, {"kind": "text", "text": "[the former]: (O:) and"}, {"kind": "arabic", "text_bw": "fiY EiroDi Aln~aAsi", "text_ar": "فِى عِرْضِ النَّاسِ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "AlAisotiTaAlapu", "text_ar": "الاِسْتِطَالَةُ", "orth_type": "arrow"}, {"kind": "text", "text": "occurs in a trad. as meaning"}, {"kind": "italic_en", "text": "the contemning of men,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "exalting oneself above them,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "reviling them, vilifying them,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "detracting from their reputation."}, {"kind": "text", "text": "(TA.) One says also"}, {"kind": "arabic", "text_bw": "tTAwl bimaA Einodahu", "text_ar": "تطاول بِمَا عِنْدَهُ"}, {"kind": "italic_en", "text": "He exalted,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "magnified,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "boasted, himself in,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "he boasted of, what he possessed."}, {"kind": "text", "text": "(TA in art."}, {"kind": "arabic", "text_bw": "ftH", "text_ar": "فتح"}, {"kind": "text", "text": ".) And"}, {"kind": "arabic", "text_bw": "AlfaHolu yataTaAwalu EalaY A_ibilihi", "text_ar": "الفَحْلُ يَتَطَاوَلُ عَلَى اـِبِلِهِ"}, {"kind": "italic_en", "text": "The stallion"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "overbears,"}, {"kind": "text", "text": "or]"}, {"kind": "italic_en", "text": "drives as he pleases, and repels the other stallions from, his she-camels."}, {"kind": "text", "text": "(O.) ―         -b6-  And"}, {"kind": "arabic", "text_bw": "taTaAwalaA", "text_ar": "تَطَاوَلَا"}, {"kind": "italic_en", "text": "They vied, competed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "contended for superiority, each with the other"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "in"}, {"kind": "arabic", "text_bw": "AlT~uwl", "text_ar": "الطُّول"}, {"kind": "text", "text": "i. e."}, {"kind": "italic_en", "text": "tallness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in"}, {"kind": "arabic", "text_bw": "AlT~awol", "text_ar": "الطَّوْل"}, {"kind": "text", "text": "i. e."}, {"kind": "italic_en", "text": "beneficence,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "excel-lence,"}, {"kind": "text", "text": "&c.: see 3]. (TA.)"}], "source_refs": ["S", "K", "TA", "Msb", "O"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}