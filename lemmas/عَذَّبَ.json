{"lemma":"عَذَّبَ","slug":"عَذَّبَ","root":"ع.ذ.ب","root_slug":"ع-ذ-ب","root_link":"/words/roots/ع-ذ-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَذَّبْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَذَّبْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَذَّبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَذَّبْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَذَّبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَذَّبَ","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَذَّبَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَذَّبا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَذَّبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَذَّبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَذَّبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَذِّب","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَذِّبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَذِّبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَذِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَذِّبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَذِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَذِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَذِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَذِّب","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَذِّب","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَذِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَذِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَذِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَذِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَذِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَذِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَذِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَذَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَذَّبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَذِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَذِّب","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":50,"cross_references":{"qac":{"found":true,"lemma_key":"عَذَّبَ","root":"عذب","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n28405","n28411","n28412","n28413"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B0%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to torment, afflict, torture"},{"pos":"verb","gloss":"to cause one to be deterred, to beat or chase away"},{"pos":"adj","gloss":"fresh, potable"},{"pos":"adj","gloss":"dulcet, sweet"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28405","headword_ar":"عَذُبَ","root":"E*b","body":[{"kind":"text","text":", (S, O, Msb, K, TA,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"Eu*uwbapN","text_ar":"عُذُوبَةٌ"},{"kind":"text","text":", said of water, (S, O, Msb, K, TA,) [and app. of wine or other beverage, and of food, (see"},{"kind":"arabic","text_bw":"Ea*obN","text_ar":"عَذْبٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sweet:"},{"kind":"text","text":"(S, O, * TA:) or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy and agreeable to be drunk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swallowed."},{"kind":"text","text":"(Msb.) [See also 12. ―         -b2-  Freytag has also assigned to it a meaning belonging to"},{"kind":"arabic","text_bw":"A^aEo*aba","text_ar":"اَعْذَبَ"},{"kind":"text","text":", q. v.]       -A2-"},{"kind":"arabic","text_bw":"Ea*aba","text_ar":"عَذَبَ"},{"kind":"text","text":": see 4, in two places.       -A3-  And see also 2, last sentence.       -A4-  ["},{"kind":"arabic","text_bw":"Ea*iba","text_ar":"عَذِبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":", is mentioned by Golius as signifying “"},{"kind":"italic_en","text":"Quisquiliis"},{"kind":"text","text":"aut"},{"kind":"italic_en","text":"lente palustri obducta fuit,"},{"kind":"text","text":"” and in a similar manner by Freytag; by both as said of water, and as on the authority of the K: but I find, in the K, no ground for this, except an explanation of"},{"kind":"arabic","text_bw":"Ea*ibN","text_ar":"عَذِبٌ"},{"kind":"text","text":", q.v., of which ISd knew not a verb.]"}],"source_refs":["S","O","Msb","K","TA"]},{"entry_id":"n28411","headword_ar":"عَذْبٌ","root":"E*b","body":[{"kind":"italic_en","text":"Sweet"},{"kind":"text","text":"water: (S, O:) or water, (Msb,) or wine, or beverage, and food, (K,)"},{"kind":"italic_en","text":"that is easy and agreeable to be drunk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swallowed:"},{"kind":"text","text":"(Msb, K:) pl."},{"kind":"arabic","text_bw":"Ei*aAbN","text_ar":"عِذَابٌ"},{"kind":"text","text":"(O, Msb, TA) and"},{"kind":"arabic","text_bw":"Eu*uwbN","text_ar":"عُذُوبٌ"},{"kind":"text","text":". (TA.) You say"},{"kind":"arabic","text_bw":"rakiy~apN Ea*obapN","text_ar":"رَكِيَّةٌ عَذْبَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A well of sweet water"},{"kind":"text","text":"] : and"},{"kind":"arabic","text_bw":"maA='N Ea*obN","text_ar":"مَا=ءٌ عَذْبٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sweet water"},{"kind":"text","text":"]: and also"},{"kind":"arabic","text_bw":"maA='apN Ea*obapN","text_ar":"مَا=ءَةٌ عَذْبَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a sweet water"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"maA='N Ei*aAbN","text_ar":"مَا=ءٌ عِذَابٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sweet water"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waters"},{"kind":"text","text":"], using a pl. epithet in this last case because"},{"kind":"arabic","text_bw":"maA='N","text_ar":"مَا=ءٌ"},{"kind":"text","text":"is a coll. gen. n., of which"},{"kind":"arabic","text_bw":"maA='apN","text_ar":"مَا=ءَةٌ"},{"kind":"text","text":"is the n. un. (TA.) And Aboo-Heiyeh En-Nemeree says, describing water,"},{"kind":"quote","text":"lahu galalN bayona AlA_ijaAmi Eu*uwbu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Having sweet water permeating amid the reedbeds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the thickets"},{"kind":"text","text":"]: he uses"},{"kind":"arabic","text_bw":"galalN","text_ar":"غَلَلٌ"},{"kind":"text","text":"as a coll. gen. n., and therefore pluralizes the epithet. (L,"},{"kind":"page_break","n":1982},{"kind":"text","text":"TA.) ―         -b2-  One says also"},{"kind":"arabic","text_bw":"nis=A'N Ei*aAbu Alv~anaAyaA","text_ar":"نِس=اءٌ عِذَابُ الثَّنَايَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Women sweet in respect of the front teeth"},{"kind":"text","text":"]. (A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A_in~ahu laEa*obu All~isaAni","text_ar":"اـِنَّهُ لَعَذْبُ اللِّسَانِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Verily he is sweet in respect of the tongue"},{"kind":"text","text":"]; likening his tongue to the water that is termed"},{"kind":"arabic","text_bw":"Ea*ob","text_ar":"عَذْب"},{"kind":"text","text":". (Lh, TA.)       -A2-  Also"},{"kind":"italic_en","text":"A sort of trees;"},{"kind":"text","text":"(K, TA;) the same that is called"},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":"[q. v.]. (TA.)"}],"source_refs":["S","O","Msb","K","TA"]},{"entry_id":"n28412","headword_ar":"عَذَبٌ","root":"E*b","body":[{"kind":"text","text":", (S, O, K,) [a coll. gen. n.] of which, in all its senses, the n. un. is darr;"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"Motes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"particles of rubbish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"floating upon water."},{"kind":"text","text":"(TA.) [In this sense, it is said in the S and O that"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ"},{"kind":"text","text":"is its sing. or n. un.] One says"},{"kind":"arabic","text_bw":"maA='N *uw Ea*abK","text_ar":"مَا=ءٌ ذُو عَذَبٍ"},{"kind":"italic_en","text":"Water abounding with such motes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"particles."},{"kind":"text","text":"(S, O. See also"},{"kind":"arabic","text_bw":"Ea*ibN","text_ar":"عَذِبٌ"},{"kind":"text","text":".) And ↓"},{"kind":"arabic","text_bw":"Ea*ibapN","text_ar":"عَذِبَةٌ","orth_type":"arrow"},{"kind":"text","text":"has the same meaning as the n. un. of"},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":"in this sense: (K:) and signifies likewise, as also ↓"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ea*obapN","text_ar":"عَذْبَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) this last mentioned by IAar, (L,) [the"},{"kind":"italic_en","text":"green substance called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TuHolub","text_ar":"طُحْلُب"},{"kind":"text","text":"(L, K, TA)"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"EaromaD","text_ar":"عَرْمَض"},{"kind":"italic_en","text":"and the like,"},{"kind":"text","text":"(L, TA,) or"},{"kind":"arabic","text_bw":"TuHolub","text_ar":"طُحْلُب"},{"kind":"italic_en","text":"and dung"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dimon","text_ar":"دِمْن"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"floating upon water."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"What comes forth next after the fœtus from the womb."},{"kind":"text","text":"(O, K.)       -A2-  Also"},{"kind":"italic_en","text":"A sort of trees,"},{"kind":"text","text":"(AHn, O, K,)"},{"kind":"italic_en","text":"of the shrub-kind:"},{"kind":"text","text":"(AHn, O:) the same that is called"},{"kind":"arabic","text_bw":"Ea*obN","text_ar":"عَذْبٌ"},{"kind":"text","text":". (TA.)       -A3-  And The"},{"kind":"italic_en","text":"pieces of rag that women hold when wailing for the dead;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"maEaA*ibu","text_ar":"مَعَاذِبُ"},{"kind":"text","text":", (O, K,) pl. of ↓"},{"kind":"arabic","text_bw":"maEo*abapN","text_ar":"مَعْذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"[or probably"},{"kind":"arabic","text_bw":"miEo*abapN","text_ar":"مِعْذَبَةٌ"},{"kind":"text","text":", like its syn."},{"kind":"arabic","text_bw":"miy^olaApN","text_ar":"مِيْلَاةٌ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"miy^olawapN","text_ar":"مِيْلَوَةٌ"},{"kind":"text","text":"], or , accord. to AA, an anomalous pl. of [the n. un. of"},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":", i. e.]"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ"},{"kind":"text","text":": (O:) one of such pieces of rag is also called"},{"kind":"arabic","text_bw":"miEowazN","text_ar":"مِعْوَزٌ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Straps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thongs:"},{"kind":"text","text":"(S, O:) or the"},{"kind":"italic_en","text":"extremities thereof;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ea*abaAtN","text_ar":"عَذَبَاتٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) So in the saying of Dhu-r-Rummeh, (S, O, TA,) describing dogs of the chase, (O,)"},{"kind":"quote","text":"guDofN muhar~atapu AlA^a$odaAqi DaAriyapN\n                      \n                     \n                        mivolu Als~araAHiyni fiY A^aEonaAqihaA AlEa*abu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Having pendulous ears, wide in the sides of the mouth, habituated to the chase, resembling wolves, with straps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thongs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the extremities thereof, upon their necks"},{"kind":"text","text":"]. (S, O, TA.) ―         -b3-  Also, (K,) or ↓"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", in this and other senses following, (S, O, Msb, &c.,) [the former evidently wrong, the latter (as is said in the K) being its n. un. in all its senses,] The"},{"kind":"italic_en","text":"string with which a balance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pair of scales, is raised."},{"kind":"text","text":"(S, O, Msb, K.) ―         -b4-  And The"},{"kind":"italic_en","text":"end,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extremity,"},{"kind":"text","text":"of a whip; (Mgh in art."},{"kind":"arabic","text_bw":"vmr","text_ar":"ثمر"},{"kind":"text","text":", and Msb;) its"},{"kind":"italic_en","text":"tail;"},{"kind":"text","text":"also called its"},{"kind":"arabic","text_bw":"vamarap","text_ar":"ثَمَرَة"},{"kind":"text","text":": (Mgh ubi suprà:) or its"},{"kind":"arabic","text_bw":"EilaAqap","text_ar":"عِلَاقَة"},{"kind":"text","text":", (TA in the present art.,) which means the ["},{"kind":"italic_en","text":"suspensory"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thong in the handle"},{"kind":"text","text":"thereof: (TA in art."},{"kind":"arabic","text_bw":"Elq","text_ar":"علق"},{"kind":"text","text":":) or [it may have both of these significations, for it is said that it is]"},{"kind":"italic_en","text":"one of the"},{"kind":"arabic","text_bw":"Ea*abataAni","text_ar":"عَذَبَتَانِ"},{"kind":"text","text":"of a whip. (S, O.) ―         -b5-  The"},{"kind":"italic_en","text":"end,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extremity"},{"kind":"text","text":"of anything. (A, K.) ―         -b6-  The"},{"kind":"italic_en","text":"extremity"},{"kind":"text","text":"of the tongue; (S, O, Msb;) its ["},{"kind":"italic_en","text":"tip"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"narrow extremity:"},{"kind":"text","text":"(TA:) pl. ↓"},{"kind":"arabic","text_bw":"Ea*abaAtN","text_ar":"عَذَبَاتٌ","orth_type":"arrow"},{"kind":"text","text":". (Msb.) One says,"},{"kind":"arabic","text_bw":"A^alosinatihimo","text_ar":"اَلْسِنَتِهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHaq~u EalaY Ea*abaAti","text_ar":"الحَقُّ عَلَى عَذَبَاتِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Truth is on the tips of their tongues"},{"kind":"text","text":"]. (A, TA.) ―         -b7-  The"},{"kind":"italic_en","text":"extremity of the penis"},{"kind":"text","text":"of a camel: (ISd, K, TA:) or the"},{"kind":"italic_en","text":"extremity of a"},{"kind":"text","text":"camel's"},{"kind":"italic_en","text":"penis thin in the fore part."},{"kind":"text","text":"(TA.) ―         -b8-  The"},{"kind":"italic_en","text":"part that hangs down"},{"kind":"text","text":"of the [thong called]"},{"kind":"arabic","text_bw":"$iraAk","text_ar":"شِرَاك"},{"kind":"text","text":"[q. v.] of a sandal. (O, TA. [See also"},{"kind":"arabic","text_bw":"*uw^aAbapN","text_ar":"ذُوَابَةٌ"},{"kind":"text","text":".]) ―         -b9-"},{"kind":"italic_en","text":"A piece of skin which is hung behind the hinder part"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muw^oxirap","text_ar":"مُوْخِرَة"},{"kind":"text","text":", O, K, or"},{"kind":"arabic","text_bw":"muw^ax~arap","text_ar":"مُوَخَّرَة"},{"kind":"text","text":", CK)"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"camel's saddle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"from its upper portion;"},{"kind":"text","text":"(O;) also termed"},{"kind":"arabic","text_bw":"*uw^aAbapN","text_ar":"ذُوَابَةٌ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"*A^b","text_ar":"ذاب"},{"kind":"text","text":".) ―         -b10-  And"},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":"[accord. to the TA, but correctly ↓"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", (see 8,)] The"},{"kind":"italic_en","text":"portion"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"end"},{"kind":"text","text":"] of a turban,"},{"kind":"italic_en","text":"that is made to hang down between the shoulders."},{"kind":"text","text":"(TA.) ―         -b11-  And the same, [correctly ↓"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", as is shown by what follows,]"},{"kind":"italic_en","text":"A piece of rag"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"strip of linen or the like,"},{"kind":"text","text":"called in French"},{"kind":"italic_en","text":"cravate,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is bound upon the head of a spear."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"xafaqato EalaY raA^osihi","text_ar":"خَفَقَتْ عَلَى رَاْسِهِ"},{"kind":"arabic","text_bw":"AlEa*abu","text_ar":"العَذَبُ"},{"kind":"text","text":"(A, TA) i. e."},{"kind":"arabic","text_bw":"xiraqu AlA^alowiyapi","text_ar":"خِرَقُ الاَلْوِيَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The cravates fluttered over his head"},{"kind":"text","text":"]. (A.) ―         -b12-  And ↓"},{"kind":"arabic","text_bw":"Ea*abapN","text_ar":"عَذَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"A branch"},{"kind":"text","text":"of a tree; (S, O, Msb;) and so ↓"},{"kind":"arabic","text_bw":"Ea*ibapN","text_ar":"عَذِبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","O","K","TA","L","AHn","ISd","A"]},{"entry_id":"n28413","headword_ar":"عَذِبٌ","root":"E*b","body":[{"kind":"text","text":"(K, TA) and ↓"},{"kind":"arabic","text_bw":"*uw Ea*abK","text_ar":"ذُو عَذَبٍ","orth_type":"arrow"},{"kind":"text","text":"(TA) Water"},{"kind":"italic_en","text":"overspread by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the green substance termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TuHolub","text_ar":"طُحْلُب"},{"kind":"text","text":": (K, TA:) or"},{"kind":"italic_en","text":"abounding therewith, and with motes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"particles of rubbish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(TA:) [or the latter signifies as expl. before: see"},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":", third sentence:]"},{"kind":"arabic","text_bw":"Ea*ibN","text_ar":"عَذِبٌ"},{"kind":"text","text":"is thought by ISd to be a possessive epithet, [meaning"},{"kind":"arabic","text_bw":"*uw Ea*abK","text_ar":"ذُو عَذَبٍ"},{"kind":"text","text":",] because he found no verb belonging to it. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Ea*ibN","text_ar":"عَذِبٌ"},{"kind":"text","text":"is also syn. with"},{"kind":"arabic","text_bw":"EaZibN","text_ar":"عَظِبٌ"},{"kind":"text","text":"meaning A man"},{"kind":"italic_en","text":"alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding, in places of dried-up herbage, and in a waterless desert."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"EZb","text_ar":"عظب"},{"kind":"text","text":".)"}],"source_refs":["K","TA"]}]}}