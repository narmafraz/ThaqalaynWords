":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُخْفِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُخْفِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُخْفِق","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُخْفِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُخْفِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخْفِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخْفِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخْفِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخْفِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُخْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَخْفَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَخْفَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11125"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%92%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fail, result in fiasco"}]},"etymology":null,"ipa":["/ʔax.fa.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11125","headword_ar":"اخفق","root":"xfq","body":[{"kind":"text","text":", said of a bird,"},{"kind":"italic_en","text":"It beat with"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flapped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its wings:"},{"kind":"text","text":"(S, K:) and"},{"kind":"arabic","text_bw":"bijinaAHayohi","text_ar":"بِجِنَاحَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xafaqa","text_ar":"خَفَقَ","orth_type":"arrow"},{"kind":"text","text":"[signifies the same]. (S and K in art."},{"kind":"arabic","text_bw":"rnq","text_ar":"رنق"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Axfq bivawobihi","text_ar":"اخفق بِثَوْبِهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"made a sign with his garment, by raising it, and waving it."},{"kind":"text","text":"(S, Z, Sgh, K.) ―         -b2-  Said of the heart, and of lightning, and of a sword, &c.: see 1. ―         -b3-  And said of a drowsy, or dozing, man: see 1. ―         -b4-  Also"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man who had gone on a warring and plundering expedition)"},{"kind":"italic_en","text":"failed of obtaining any spoil:"},{"kind":"text","text":"(A'Obeyd, S, Mgh, K, and Ham p. 157, and Har p. 26:) because he becomes in a shaky, or unsteady, condition, at that time: or because his travelling-bags become unsteady, or shake about, by reason of their lightness and emptiness: so that the verb is of the same category as"},{"kind":"arabic","text_bw":"A^aEoTa$a","text_ar":"اَعْطَشَ"},{"kind":"text","text":"[meaning “ his camels thirsted ”] and"},{"kind":"arabic","text_bw":"A^ajoraba","text_ar":"اَجْرَبَ"},{"kind":"text","text":"[meaning “ he had his camels affected with the mange, or scab]: (Har ubi suprà:) or the proper signification is,"},{"kind":"italic_en","text":"he found the spoil to be not stationary:"},{"kind":"text","text":"(TA:) or it means"},{"kind":"italic_en","text":"he returned disappointed of spoil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of predatory warfare:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"he was disappointed of that for which he hoped."},{"kind":"text","text":"(Ham p. 157.) And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a hunter or fowler)"},{"kind":"italic_en","text":"returned without having taken any game."},{"kind":"text","text":"(S, K.) And"},{"kind":"italic_en","text":"His property became little."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"Axfq fiY zaAdihi","text_ar":"اخفق فِى زَادِهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had his travelling-provisions all spent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consumed,"},{"kind":"text","text":"[so that his provision-bags, being empty, shook about.] (JK.) and"},{"kind":"arabic","text_bw":"Talaba HaAjapF faA^axofaqa","text_ar":"طَلَبَ حَاجَةً فَاَخْفَقَ"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"He sought an object of want, and failed of obtaining it."},{"kind":"text","text":"(K.) ―         -b5-"},{"kind":"arabic","text_bw":"Axfq Aln~ajomu","text_ar":"اخفق النَّجْمُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Axfqt","text_ar":"اخفقت"},{"kind":"arabic","text_bw":"Aln~ujuwmu","text_ar":"النُّجُومُ"},{"kind":"text","text":": see 1.       -A2-"},{"kind":"arabic","text_bw":"Axfq fulaAnFA","text_ar":"اخفق فُلَانًا"},{"kind":"italic_en","text":"He threw down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prostrated, such a one on the ground."},{"kind":"text","text":"(AA, K.)"}],"source_refs":["S","K","TA","JK"]}]},"classical_definitions":null}