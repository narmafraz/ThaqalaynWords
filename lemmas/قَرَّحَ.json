,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُقَرِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُقَرِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُقَرِّح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُقَرِّح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُقَرِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُقَرِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُقَرِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُقَرِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُقَرِّحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُقَرِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُقَرِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"قَرَّحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَرَّحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُقَرِّح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُقَرِّح","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":true,"lemma_key":"قَرَّحَ","root":"قرح","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n35441","n35442","n35443","n35444"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B1%D9%8E%D9%91%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wound"},{"pos":"verb","gloss":"to ulcerate"},{"pos":"verb","gloss":"to wound"},{"pos":"noun","gloss":"ulcer"},{"pos":"noun","gloss":"plural of قُرْحَة (qurḥa)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35441","headword_ar":"قَرْحٌ","root":"qrH","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"quroHN","text_ar":"قُرْحٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A wound;"},{"kind":"text","text":"(L;) the"},{"kind":"italic_en","text":"bite of a weapon,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a similar thing that wounds the body:"},{"kind":"text","text":"(L, K: [but in some copies of the K, for"},{"kind":"arabic","text_bw":"EaD~u Als~ilaAHi wanaHowihi mim~aA yajoraHu Albadana","text_ar":"عَضُّ السِّلَاحِ وَنَحْوِهِ مِمَّا يَجْرَحُ البَدَنَ"},{"kind":"text","text":"(which is the reading in the CK), we find"},{"kind":"arabic","text_bw":"ED~ AlslAH wanaHowuhu","text_ar":"عضّ السلاح وَنَحْوُهُ"},{"kind":"arabic","text_bw":"mm~A yaxoruju biAlbadani","text_ar":"ممّا يَخْرُجُ بِالبَدَنِ"},{"kind":"text","text":", and the L and TA combine the two readings, the latter whereof gives a second signification, which will be found below:])"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"juroHN","text_ar":"جُرْحٌ"},{"kind":"text","text":"[with which"},{"kind":"arabic","text_bw":"jaroHN","text_ar":"جَرْحٌ"},{"kind":"text","text":"is held by many to be syn.]: (TA:) they are two dial. vars., (S, Msb,) like"},{"kind":"arabic","text_bw":"DaEofN","text_ar":"ضَعْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DuEofN","text_ar":"ضُعْفٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"jahodN","text_ar":"جَهْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"juhodN","text_ar":"جُهْدٌ"},{"kind":"text","text":", (Fr, Msb, TA,) and"},{"kind":"arabic","text_bw":"wajodN","text_ar":"وَجْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wujodN","text_ar":"وُجْدٌ"},{"kind":"text","text":"; (Fr, TA;) the former of the dial. of El-Hijáz: (Msb:) or the former is an inf. n. and the latter is a simple subst.: (L, Msb:) or the former signifies as above; and the latter signifies"},{"kind":"italic_en","text":"its pain:"},{"kind":"text","text":"(A:) or the latter seems to bear this latter signification; and the former, to signify"},{"kind":"italic_en","text":"wounds"},{"kind":"text","text":"themselves: (Yaakoob, TA:) [and the like is said in the L and K:]) [and thus used in a pl. sense, the former is a coll. gen. n.;] and its n. un. is ↓"},{"kind":"arabic","text_bw":"qaroHapN","text_ar":"قَرْحَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and pl."},{"kind":"arabic","text_bw":"quruwHN","text_ar":"قُرُوحٌ"},{"kind":"text","text":": (L:) one says,"},{"kind":"arabic","text_bw":"bihi quroHN mino qaroHK","text_ar":"بِهِ قُرْحٌ مِنْ قَرْحٍ"},{"kind":"italic_en","text":"In him is pain from a wound;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"from wounds."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"qaroHN","text_ar":"قَرْحٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Pustules,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small swellings, when they have become corrupt;"},{"kind":"text","text":"(L, K;) [i. e."},{"kind":"italic_en","text":"purulent pustules;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"imposthumes, ulcers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sores:"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"quroHN","text_ar":"قُرْحٌ","orth_type":"arrow"},{"kind":"text","text":"accord. to the L and some copies of the K, as shown above; but this seems to be of doubtful authority:"},{"kind":"arabic","text_bw":"qaroHN","text_ar":"قَرْحٌ"},{"kind":"text","text":"in this sense is a coll. gen. n.:] its n. un. is ↓"},{"kind":"arabic","text_bw":"qaroHapN","text_ar":"قَرْحَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and pl."},{"kind":"arabic","text_bw":"quruwHN","text_ar":"قُرُوحٌ"},{"kind":"text","text":". (S.) Imra-el-Keys (the poet, TA) was called"},{"kind":"arabic","text_bw":"*uw AlquruwHi","text_ar":"ذُو القُرُوحِ"},{"kind":"text","text":"because the King of the Greeks sent to him a poisoned shirt, from the wearing of which his body became affected with purulent pustules, or ulcers, or sores, ("},{"kind":"arabic","text_bw":"taqar~aHa","text_ar":"تَقَرَّحَ"},{"kind":"text","text":",) and he died: (S, K, * TA:) or, as some say, he was called"},{"kind":"arabic","text_bw":"*uw AlfuruwjK","text_ar":"ذُو الفُرُوجٍ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":"; because he left only daughters. (Es-Suyootee, TA.) ―         -b3-  Also, (accord. to the K,) or ↓"},{"kind":"arabic","text_bw":"quroHN","text_ar":"قُرْحٌ","orth_type":"arrow"},{"kind":"text","text":", (as in the L,)"},{"kind":"italic_en","text":"A severe scab"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mange, that destroys young weaned camels;"},{"kind":"text","text":"(L, K;) or"},{"kind":"italic_en","text":"that attacks young weaned camels, and from which they scarcely ever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"never, recover:"},{"kind":"text","text":"so says Lth: Az, however, says that this is a mistake; but that"},{"kind":"arabic","text_bw":"quroHapN","text_ar":"قُرْحَةٌ"},{"kind":"text","text":"signifies a certain disease that attacks camels, expl. below. (L.)       -A2-  See also"},{"kind":"arabic","text_bw":"qariyHN","text_ar":"قَرِيحٌ"},{"kind":"text","text":"."},{"kind":"page_break","n":2511}],"source_refs":["TA","S","Msb","Fr","L","A"]},{"entry_id":"n35442","headword_ar":"قُرْحٌ","root":"qrH","body":[{"kind":"text","text":": see the next preceding paragraph, in three places.       -A2-  See also"},{"kind":"arabic","text_bw":"qariyHapN","text_ar":"قَرِيحَةٌ"},{"kind":"text","text":"in two places. [Hence] one says,"},{"kind":"arabic","text_bw":"huwa fiY quroHi sin~ihi","text_ar":"هُوَ فِى قُرْحِ سِنِّهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is in the first part of his age."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"A^anaA fiY quroHi Alv~alaAviyna","text_ar":"اَنَا فِى قُرْحِ الثَّلَاثِينَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I am in the beginning of the thirtieth"},{"kind":"text","text":"[year] was said by an Arab of the desert to IAar, who had asked him his age. (TA.) And"},{"kind":"arabic","text_bw":"AlquroHu","text_ar":"القُرْحُ"},{"kind":"text","text":", (K,) by some written"},{"kind":"arabic","text_bw":"AlquraHu","text_ar":"القُرَحُ"},{"kind":"text","text":"[pl. of ↓"},{"kind":"arabic","text_bw":"AlquroHapu","text_ar":"القُرْحَةُ","orth_type":"arrow"},{"kind":"text","text":"], (MF, TA,) signifies"},{"kind":"italic_en","text":"Three nights"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"of the first part"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"of the month."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["K","MF","TA"]},{"entry_id":"n35443","headword_ar":"قَرَحٌ","root":"qrH","body":[{"kind":"text","text":"a subst. signifying The"},{"kind":"italic_en","text":"state"},{"kind":"text","text":"(in a camel)"},{"kind":"italic_en","text":"of having never had the mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab:"},{"kind":"text","text":"and (in a child)"},{"kind":"italic_en","text":"of having never been attacked by the small-pox."},{"kind":"text","text":"(S.)"}],"source_refs":[]},{"entry_id":"n35444","headword_ar":"قَرِحٌ","root":"qrH","body":[{"kind":"text","text":"A man, (Msb,) or a man's skin, (S,)"},{"kind":"italic_en","text":"breaking out with"},{"kind":"arabic","text_bw":"quruwH","text_ar":"قُرُوح"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"purulent pustules"},{"kind":"text","text":"]. (S, Msb.)"}],"source_refs":["Msb","S"]}]}}