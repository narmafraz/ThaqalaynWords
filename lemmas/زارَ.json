iktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n17324","n18384"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to incline towards, to repair to the direction of"},{"pos":"verb","gloss":"to visit","examples":[{"text":"هَلْ زُرْتَ أُسْتُرَالِيَا؟","english":"Have you been to Australia?"},{"text":"هَلْ زُرْتِ أُسْتُرَالِيَا؟","english":"Have you been to Australia?"}]}]},"etymology":null,"ipa":["/zaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17324","headword_ar":"زَاَرَ","root":"zA^r","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, K) and"},{"kind":"text","text":"; (A, K;) and"},{"kind":"arabic","text_bw":"zay^ira","text_ar":"زَيِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, K;) inf. n."},{"kind":"arabic","text_bw":"zay^iyrN","text_ar":"زَيِيرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zaA^orN","text_ar":"زَاْرٌ"},{"kind":"text","text":"; (S, A, K;) said of a lion,"},{"kind":"italic_en","text":"He roared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"growled;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"made his cry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voice, to be heard"},{"kind":"text","text":"(S, A, K)"},{"kind":"italic_en","text":"in his chest,"},{"kind":"text","text":"(S, A,) or"},{"kind":"italic_en","text":"from his chest;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"tzA^~r","text_ar":"تزاّر","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"AzA^r","text_ar":"ازار","orth_type":"arrow"},{"kind":"text","text":": (K:)"},{"kind":"italic_en","text":"he cried out, and was angry."},{"kind":"text","text":"(TA.) ―         -b2-  And [hence], said of a stallion-camel, as also ↓"},{"kind":"arabic","text_bw":"AzA^r","text_ar":"ازار","orth_type":"arrow"},{"kind":"text","text":", (K, by implication,) or"},{"kind":"arabic","text_bw":"zaA^ara","text_ar":"زَاَرَ"},{"kind":"text","text":"[only], (TA,) or"},{"kind":"arabic","text_bw":"zaA^ara fiY hadiyrahi","text_ar":"زَاَرَ فِى هَدِيرَهِ"},{"kind":"text","text":", (A,) (tropical:)"},{"kind":"italic_en","text":"He reiterated his voice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry, in his chest, and then prolonged it,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"in his braying:"},{"kind":"text","text":"(A:) or"},{"kind":"arabic","text_bw":"zaA^ara","text_ar":"زَاَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"he threatened"},{"kind":"text","text":"in his braying. (TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"samiEa zay^iyra AlHarobi faTaAra A_ilayohaA","text_ar":"سَمِعَ زَيِيرَ الحَرْبِ فَطَارَ اـِلَيْهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He heard the roaring of the war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battle, and flew to it"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","A","K","TA"]},{"entry_id":"n18384","headword_ar":"زَارٌ","root":"zwr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zaArapN","text_ar":"زَارَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B2%D8%A7%D8%B1/","headword_ar":"زار","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=73615#416736","body_html":"زار<br>حفلة راقصة تقام لطرد الأرواح الشريرة.<br>زار<br>عن الفارسية زار بمعنى ضيف ونحيف وعاجز. يستخدم للإناث."},{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=73615#31b35e","body_html":"زار:<br>بعد الألف راء، قال أبو سعد: قرية من قرى إشتيخن من نواحي سمرقند، ينسب إليها يحيى بن خزيمة الزاري الإشتيخي، سمع عبد الله بن عبد الرحمن السمرقندي، روى عن الطيب بن محمد ابن حشوية السمرقندي، قال الإدريسي: والزار موضع في قول عدي بن زيد العبادي:<br>كلّا يمينا بذات الروع لو حدثت ... فيكم وقابل قبر الماجد الزّارا<br>قيل في تفسير الزار: إنّه موضع كانوا يقبرون فيه."}]}}