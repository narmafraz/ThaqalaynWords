{"lemma":"أَمَّنَ","slug":"أَمَّنَ","root":"#.م.ن","root_slug":"_-م-ن","root_link":"/words/roots/_-م-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَمَّنْتَ","in_corpus":true,"count":34,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَمَّنْتِ","in_corpus":true,"count":34,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَمَّنْتُما","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَمَّنْتُم","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَمَّنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَمَّنَ","in_corpus":true,"count":95,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَمَّنَت","in_corpus":true,"count":34,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَمَّنا","in_corpus":true,"count":38,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَمَّنَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَمَّنُوا","in_corpus":true,"count":105,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَمَّنَّ","in_corpus":true,"count":95,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُؤَمِّن","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُؤَمِّنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤَمِّنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُؤَمِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُؤَمِّنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُؤَمِّنُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُؤَمِّنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُؤَمِّنَّ","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُؤَمِّن","in_corpus":true,"count":62,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُؤَمِّن","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُؤَمِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُؤَمِّنا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤَمِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَمِّنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤَمِّنُونَ","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَمِّنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤَمِّنَّ","in_corpus":true,"count":62,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَمَّنّا","in_corpus":true,"count":38,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَمَّنْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَمِّن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَمِّن","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":643,"cross_references":{"qac":{"found":true,"lemma_key":"أَمَّنَ","root":"أمن","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":18},"lanes":{"found":true,"entry_ids":["n1255","n1259","n1260","n1261","n1262"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%8E%D9%91%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be faithful, to be reliable"},{"pos":"verb","gloss":"to be safe from"},{"pos":"verb","gloss":"to feel secure, to feel safe from","examples":[{"text":"أَفَأَمِنَ أَهْلُ الْقُرَى أَن يَأْتِيَهُم بَأْسُنَا بَيَاتًا وَهُمْ نَائِمُونَ","english":"Did the people of those societies feel secure that Our punishment would not come upon them by night while they were asleep?"}]},{"pos":"verb","gloss":"to trust, to find reliable/trustworthy"},{"pos":"verb","gloss":"to have peace of mind"},{"pos":"verb","gloss":"to entrust","examples":[{"text":"قَالَ هَلْ ءَامَنُكُمْ عَلَيْهِ إِلَّا كَمَآ أَمِنتُكُمْ عَلَىٰٓ أَخِيهِ مِن قَبْلُ ۖ فَٱللَّهُ خَيْرٌ حَـٰفِظًۭا ۖ وَهُوَ أَرْحَمُ ٱلرَّٰحِمِينَ","english":"He said, \"Should I entrust you with him except [under coercion] as I entrusted you with his brother before? But Allāh is the best guardian, and He is the most merciful of the merciful.\""}]},{"pos":"verb","gloss":"to reassure"},{"pos":"verb","gloss":"to ensure"},{"pos":"verb","gloss":"to secure","examples":[{"text":"كيف سنُؤمِّن لقمة عيشنا.","english":"How will we secure our livelihood?"}]},{"pos":"verb","gloss":"to provide"},{"pos":"verb","gloss":"to insure"},{"pos":"verb","gloss":"to entrust"},{"pos":"verb","gloss":"to say \"آمِين\" (ʔāmīn, “amen”)"},{"pos":"noun","gloss":"verbal noun of أَمِنَ (ʔamina) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"safety, security"},{"pos":"noun","gloss":"peace"},{"pos":"noun","gloss":"protection"},{"pos":"adj","gloss":"safe, protected","examples":[{"text":"التقرير أكد، بان لقاءات مع قادة محليين سوريين، أكراد وعراقيين، أوضحت، بان هؤلاء الأجانب، لجئوا الى الصحراء في محاولة للهرب من القتل او الاعتقال الذي قد يطالهم على المناطق الحدودية، حيث وجدوا في عمق الصحاري ملاجئ امنة مؤقتة لهم، فيما يحاولون يائسين الوصول الى الحدود التركية، ومنها العودة إلى بلدانهم.","english":"The report affirmed that meetings with local Syrian leaders, Kurds, and Iraqis showed that these foreigners took shelter in the desert in the attempt to escape their being killed or arrested that reached out to them in the border zones where they encountered in the desert depths temporary safe shelters for them while they desperately sought the link to the Turkish borders, and with it the return to their homelands."}]}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1255","headword_ar":"اَمِنَ","root":"Amn","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"text","text":", (T, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A_imonN","text_ar":"اـِمْنٌ"},{"kind":"text","text":"(Zj, M, K) and"},{"kind":"arabic","text_bw":"A^amanN","text_ar":"اَمَنٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"A^amanapN","text_ar":"اَمَنَةٌ"},{"kind":"text","text":"(T, S, M, K) and"},{"kind":"arabic","text_bw":"A_imonapN","text_ar":"اـِمْنَةٌ"},{"kind":"text","text":"(T) and"},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ"},{"kind":"text","text":"(M, K) [and app."},{"kind":"arabic","text_bw":"A^amaAnapN","text_ar":"اَمَانَةٌ"},{"kind":"text","text":", for it is said in the S that this is syn. with"},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"A=mnN","text_ar":"ا=منٌ"},{"kind":"text","text":", an instance of an inf. n. of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":", which is strange, (MF,) or this is a subst. like"},{"kind":"arabic","text_bw":"faAlijN","text_ar":"فَالِجٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"felt, secure, safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety;"},{"kind":"text","text":"originally,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tranquil, in heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear;"},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":"signifying the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"xawofN","text_ar":"خَوْفٌ"},{"kind":"text","text":", (S, M, K,) and so"},{"kind":"arabic","text_bw":"A^amanapN","text_ar":"اَمَنَةٌ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"A=minN","text_ar":"ا=مِنٌ"},{"kind":"text","text":"[&c.]: (M, K:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"felt, free from expectation of evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of an object of dislike"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred, in the coming time;"},{"kind":"text","text":"originally,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy in mind, and free from fear."},{"kind":"text","text":"(El-Munáwee, TA.) [See"},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":", below.] You say also,"},{"kind":"arabic","text_bw":"yaA_omanu EalaY nafosihi","text_ar":"يَاـْمَنُ عَلَى نَفْسِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear, for himself"},{"kind":"text","text":"]. (M.) And"},{"kind":"arabic","text_bw":"A^amina Albaladu","text_ar":"اَمِنَ البَلَدُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The inhabitants of the country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town, were in a state of security,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confidence, therein."},{"kind":"text","text":"(Msb.) The verb is trans. by itself, and by means of the particle"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":"; as in"},{"kind":"arabic","text_bw":"A^amana zayodN AlA^asada","text_ar":"اَمَنَ زَيْدٌ الاَسَدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amina mina","text_ar":"اَمِنَ مِنَ"},{"kind":"arabic","text_bw":"AlA^asadi","text_ar":"الاَسَدِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Zeyd was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"felt, secure from, safe from,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"free from fear of,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the lion."},{"kind":"text","text":"(Msb.) You say also,"},{"kind":"arabic","text_bw":"A^amina ka*iba mano","text_ar":"اَمِنَ كَذِبَ مَنْ"},{"kind":"arabic","text_bw":"A^axobarahu","text_ar":"اَخْبَرَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was secure from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear of, the lying of him who informed him"},{"kind":"text","text":"]. (M.) And"},{"kind":"arabic","text_bw":"laA A=nanu A^ano yakuwna ka*lika","text_ar":"لَا ا=نَنُ اَنْ يَكُونَ كَذلِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I am not free from fear of its being so; I am not sure but that it may be so"},{"kind":"text","text":"]. (Mgh in art."},{"kind":"arabic","text_bw":"nb*","text_ar":"نبذ"},{"kind":"text","text":"; and other lexicons passim.) And, of a strong-made she camel,"},{"kind":"arabic","text_bw":"A^aminato","text_ar":"اَمِنَتْ"},{"kind":"arabic","text_bw":"A^ano takuwna DaEayfapF","text_ar":"اَنْ تَكُونَ ضَعَيفَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She was secure from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear of, being weak"},{"kind":"text","text":"]: (M: [in a copy of the S"},{"kind":"arabic","text_bw":"A^uminato","text_ar":"اُمِنَتْ"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"A^aminati AlEivaAra waAlA_aEoyaA='K","text_ar":"اَمِنَتِ العِثَارَ وَالاـَعْيَا=ءٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She was secure from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear of, stumbling, and becoming jaded"},{"kind":"text","text":"]: (M:) and"},{"kind":"arabic","text_bw":"A^umina EivaAruhaA","text_ar":"اُمِنَ عِثَارُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Her stumbling was not feared"},{"kind":"text","text":"]. (So in a copy of the S.) And, of a highly-prized camel,"},{"kind":"arabic","text_bw":"A^umina A^ano yunoHara","text_ar":"اُمِنَ اَنْ يُنْحَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was not feared that he would be slaughtered;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his being slaughtered was not feared"},{"kind":"text","text":"]. (M.) ["},{"kind":"arabic","text_bw":"A^amnahu","text_ar":"اَمنَهُ"},{"kind":"text","text":"sometimes means"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from fear, though having cause for fear, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he thought himself secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safe, from him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(See Kur vii. 97.)] ―         -b2-"},{"kind":"arabic","text_bw":"A^minahu","text_ar":"امِنَهُ"},{"kind":"text","text":"(inf. n."},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":"TK) [and accord. to some copies of the K ↓"},{"kind":"arabic","text_bw":"A=manahu","text_ar":"ا=مَنَهُ","orth_type":"arrow"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"A^m~nhu","text_ar":"امّنهُ","orth_type":"arrow"},{"kind":"text","text":"(inf. n."},{"kind":"arabic","text_bw":"taA^omiynN","text_ar":"تَاْمِينٌ"},{"kind":"text","text":"K) and ↓"},{"kind":"arabic","text_bw":"Ay^tmnhu","text_ar":"ايتمنهُ","orth_type":"arrow"},{"kind":"text","text":"([written with the disjunctive alif"},{"kind":"arabic","text_bw":"Aiytamanahu","text_ar":"اِيتَمَنَهُ"},{"kind":"text","text":", and] also written"},{"kind":"arabic","text_bw":"Ait~amanahu","text_ar":"اِتَّمَنَهُ"},{"kind":"text","text":", on the authority of Th, which is extr., like"},{"kind":"arabic","text_bw":"Ait~ahala","text_ar":"اِتَّهَلَ"},{"kind":"text","text":"[&c.], M) and ↓"},{"kind":"arabic","text_bw":"AstA^mnhu","text_ar":"استامنهُ","orth_type":"arrow"},{"kind":"text","text":"all signify the same (M, K, TA) ["},{"kind":"italic_en","text":"He trusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided, in him;"},{"kind":"text","text":"(as also"},{"kind":"arabic","text_bw":"A=mn bihi","text_ar":"ا=من بِهِ"},{"kind":"text","text":", q. v.;)"},{"kind":"italic_en","text":"he intrusted him with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided to him, power, authority, control,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a charge; he gave him charge"},{"kind":"text","text":"over a thing or person: these meanings are vaguely indicated in the M and K and TA.]. You say,"},{"kind":"arabic","text_bw":"yaA^omanuhu Aln~aAsu walaA yaxaAfuwna gaAy^ilatahu","text_ar":"يَاْمَنُهُ النَّاسُ وَلَا يَخَافُونَ غَايِلَتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Men,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people, trust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confide, in him, and do not fear his malevolence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischievousness"},{"kind":"text","text":"]. (T, M.) And"},{"kind":"arabic","text_bw":"A^aminahu EalaY ka*aA","text_ar":"اَمِنَهُ عَلَى كَذَا"},{"kind":"text","text":"(S, Mgh, * Msb *) and ↓"},{"kind":"arabic","text_bw":"Ay^tmnhu","text_ar":"ايتمنهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (S, Msb, K,) ["},{"kind":"italic_en","text":"He trusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided, in him with respect to such a thing; he intrusted him with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided to him, power, authority, control,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a charge, over it; he gave him charge over it;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took him as,"},{"kind":"arabic","text_bw":"A^amiyn","text_ar":"اَمِين"},{"kind":"italic_en","text":"over such a thing."},{"kind":"text","text":"(Mgh.) Hence, in a trad., the"},{"kind":"arabic","text_bw":"muw^a*~in","text_ar":"مُوَذِّن"},{"kind":"text","text":"is said to be"},{"kind":"arabic","text_bw":"muw^otamanN","text_ar":"مُوْتَمَنٌ"},{"kind":"text","text":"; i. e."},{"kind":"arabic","text_bw":"Aln~aAsu Eala AlA^awoqaAti Al~atiY yuw^a*~anu fiyhaA","text_ar":"النَّاسُ عَلَ الاَوْقَاتِ الَّتِى يُوَذَّنُ فِيهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yaA^otaminuhu","text_ar":"يَاْتَمِنُهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Men trust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confide, in him with respect to the times in which he calls to prayer"},{"kind":"text","text":"], and know, by his calling to prayer, what they are commanded to do, as to praying and fasting and breaking fast. (Mgh.) It is said in the Kur [xii. 11],"},{"kind":"arabic","text_bw":"maA laka","text_ar":"مَا لَكَ"},{"kind":"arabic","text_bw":"laA taA^omanunaA EalaY yuwsufa","text_ar":"لَا تَاْمَنُنَا عَلَى يُوسُفَ"},{"kind":"text","text":"and ["},{"kind":"arabic","text_bw":"taA^oman~aA","text_ar":"تَاْمَنَّا"},{"kind":"text","text":"] with idghám [i. e."},{"kind":"italic_en","text":"What aileth thee that thou dost not trust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confide, in us with respect to Joseph?"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"that thou dost not give us charge over Joseph?"},{"kind":"text","text":"]; (S;) meaning, why dost thou fear us for him? (Bd;) some pronouncing the verb in a manner between those of the former and the latter modes of writing it; but Akh says that the latter is better: (S:) some read"},{"kind":"arabic","text_bw":"tiyman~aA","text_ar":"تِيمَنَّا"},{"kind":"text","text":". (Bd.) You say also, ↓"},{"kind":"arabic","text_bw":"Auwtumina","text_ar":"اُوتُمِنَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one was trusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided, in"},{"kind":"text","text":"&c.;] when it begins a sentence, changing the second"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"; in like manner as you change it into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"when the first is with kesr, as in"},{"kind":"arabic","text_bw":"Aiytamanahu","text_ar":"اِيتَمَنَهُ"},{"kind":"text","text":"; and into"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"when the first is with fet-h, as in"},{"kind":"arabic","text_bw":"A=mana","text_ar":"ا=مَنَ"},{"kind":"text","text":". (S.) The phrase"},{"kind":"arabic","text_bw":"A^amaAnapF","text_ar":"اَمَانَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Auwtumina","text_ar":"اُوتُمِنَ","orth_type":"arrow"},{"kind":"text","text":", in a saying of Mohammad, if it be not correctly"},{"kind":"arabic","text_bw":"EalaY A^amaAnapK","text_ar":"عَلَى اَمَانَةٍ"},{"kind":"text","text":", may be explained as implying the meaning of"},{"kind":"arabic","text_bw":"AusotuHofiZa A^amaAnapF","text_ar":"اُسْتُحْفِظَ اَمَانَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was asked to take care of a deposite;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was intrusted with it"},{"kind":"text","text":"]. (Mgh.) [You also say,"},{"kind":"arabic","text_bw":"A^aminahu bika*aA","text_ar":"اَمِنَهُ بِكَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He intrusted him with such a thing;"},{"kind":"text","text":"as, for instance, money or other property: see two exs. in the Kur iii. 68.]       -A2-"},{"kind":"arabic","text_bw":"A^amuna","text_ar":"اَمُنَ"},{"kind":"text","text":", (M, Mgh, K,) or"},{"kind":"arabic","text_bw":"A^amina","text_ar":"اَمِنَ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"A^amaAnapN","text_ar":"اَمَانَةٌ"},{"kind":"text","text":", (M, Mgh, Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, trusted in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confided in:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, trusty, trustworthy, trustful, confidential,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faithful:"},{"kind":"text","text":"said of a man. (Mgh.)"}],"source_refs":["T","Msb","K","S","M","Zj","MF","TA","Mgh"]},{"entry_id":"n1259","headword_ar":"اَمْنٌ","root":"Amn","body":[{"kind":"text","text":"[an inf. n. of"},{"kind":"arabic","text_bw":"A^amini","text_ar":"اَمِنِ"},{"kind":"text","text":": as a simple subst. it signifies"},{"kind":"italic_en","text":"Security,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"A^amina","text_ar":"اَمِنَ"},{"kind":"text","text":":) or]"},{"kind":"italic_en","text":"security"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"freedom from fear;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"xawofN","text_ar":"خَوْفٌ"},{"kind":"text","text":"; (S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A_imonN","text_ar":"اـِمْنٌ","orth_type":"arrow"},{"kind":"text","text":"(Zj, M, K) and ↓"},{"kind":"arabic","text_bw":"A^aminN","text_ar":"اَمِنٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"A^amanahu","text_ar":"اَمَنَهُ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K) [and ↓"},{"kind":"arabic","text_bw":"A_imonapN","text_ar":"اـِمْنَةٌ","orth_type":"arrow"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"A^amina","text_ar":"اَمِنَ"},{"kind":"text","text":")] and ↓"},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A=minN","text_ar":"ا=مِنٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) which last is an inf. n. of"},{"kind":"arabic","text_bw":"A^amina","text_ar":"اَمِنَ"},{"kind":"text","text":"[like the rest], (MF,) or a subst. like"},{"kind":"arabic","text_bw":"faAlijN","text_ar":"فَالِجٌ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"A^amaAnapN","text_ar":"اَمَانَةٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ"},{"kind":"text","text":", (S,) both of these signifying"},{"kind":"italic_en","text":"security,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"freedom from fear:"},{"kind":"text","text":"(PS:) or"},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"freedom from expectation of evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of an object of dislike"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred, in the coming time;"},{"kind":"text","text":"originally,"},{"kind":"italic_en","text":"ease of mind, and freedom from fear."},{"kind":"text","text":"(El-Munáwee, TA.) You say,"},{"kind":"arabic","text_bw":"A^anota fiY A^amonK","text_ar":"اَنْتَ فِى اَمْنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou art in a state of security"},{"kind":"text","text":"], (T, M,)"},{"kind":"arabic","text_bw":"mino *aAka","text_ar":"مِنْ ذَاكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from that"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"fY A^amaAnK","text_ar":"فى اَمَانٍ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (T;) and so ↓"},{"kind":"arabic","text_bw":"fY A=minK","text_ar":"فى ا=مِنٍ","orth_type":"arrow"},{"kind":"text","text":". (M.) And"},{"kind":"arabic","text_bw":"nuEaAsFA","text_ar":"نُعَاسًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^amanapF","text_ar":"اَمَنَةً","orth_type":"arrow"},{"kind":"text","text":", in the Kur [iii. 148], means"},{"kind":"italic_en","text":"Security"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^amonFA","text_ar":"اَمْنًا"},{"kind":"text","text":") [and"},{"kind":"italic_en","text":"slumber"},{"kind":"text","text":"]. (S.) ↓"},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Protection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard:"},{"kind":"text","text":"and [very frequently]"},{"kind":"italic_en","text":"a promise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an assurance, of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety; indemnity;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter:"},{"kind":"text","text":"in Pers."},{"kind":"arabic","text_bw":"PanaAho","text_ar":"پَنَاهْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zinohaArN","text_ar":"زِنْهَارٌ"},{"kind":"text","text":": (KL:) syn."},{"kind":"arabic","text_bw":"A_il~u","text_ar":"اـِلُّ"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":".) You say, ↓"},{"kind":"arabic","text_bw":"daxala fiY A^amaAnihi","text_ar":"دَخَلَ فِى اَمَانِهِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He entered within the pale of his protection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard"},{"kind":"text","text":"]. (S, Msb.) [And"},{"kind":"arabic","text_bw":"All~`hi","text_ar":"اللّٰهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kunN fiY A^amaAni","text_ar":"كُنٌ فِى اَمَانِ","orth_type":"arrow"},{"kind":"italic_en","text":"Be thou in the protection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard, of God."},{"kind":"text","text":"] And ↓"},{"kind":"arabic","text_bw":"A^aEoTayotuhu AlA^amaAna","text_ar":"اَعْطَيْتُهُ الاَمَانَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted, to him security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the promise"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assurance of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indemnity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter"},{"kind":"text","text":"]; namely, a captive. (Msb.) And"},{"kind":"arabic","text_bw":"Talaba","text_ar":"طَلَبَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"minohu AlA^amaAna","text_ar":"مِنْهُ الاَمَانَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, of him security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard,"},{"kind":"text","text":"&c., as in the next preceding ex.]. (Msb, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^amonFA","text_ar":"اَمْنًا"},{"kind":"text","text":"in the Kur ii. 119 means"},{"kind":"arabic","text_bw":"*aA A^amon","text_ar":"ذَا اَمْن"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Possessed of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety"},{"kind":"text","text":"]: (Aboo-Is-hák, M:) or"},{"kind":"arabic","text_bw":"mawoDiEa A^amonK","text_ar":"مَوْضِعَ اَمْنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a place of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"maA^omanFA","text_ar":"مَاْمَنًا"},{"kind":"text","text":"]. (Bd.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"A=minN","text_ar":"ا=مِنٌ"},{"kind":"text","text":". ―         -b4-  You say also,"},{"kind":"arabic","text_bw":"maA A^aHosana A^amonaka","text_ar":"مَا اَحْسَنَ اَمْنَكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A^amanaka","text_ar":"اَمَنَكَ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"How good is thy religion!"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"thy natural disposition!"},{"kind":"text","text":"(M, K.)"}],"source_refs":["Zj","M","K","S","MF","PS","T","KL"]},{"entry_id":"n1260","headword_ar":"اـِمْنٌ","root":"Amn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1261","headword_ar":"اَمَنٌ","root":"Amn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^amonN","text_ar":"اَمْنٌ"},{"kind":"text","text":", first and last sentences."}],"source_refs":[]},{"entry_id":"n1262","headword_ar":"اَمِنٌ","root":"Amn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=minN","text_ar":"ا=مِنٌ"},{"kind":"text","text":". ―         -b2-  Also, (K, [there said to be like"},{"kind":"arabic","text_bw":"katifN","text_ar":"كَتِفٌ"},{"kind":"text","text":",]) or ↓"},{"kind":"arabic","text_bw":"A=minN","text_ar":"ا=مِنٌ","orth_type":"arrow"},{"kind":"text","text":", (M, [so written in a copy of that work,)]"},{"kind":"italic_en","text":"Asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking, protection, in order to be secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from fear, for himself:"},{"kind":"text","text":"(M, K:) so says IAar. (M.)"}],"source_refs":["M","K"]}]}}