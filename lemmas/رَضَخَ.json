,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْضَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْضَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْضِخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْضِخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْضَخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْضَخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْضِخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْضِخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْضَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرْضِخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"رَضَخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَضَخْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَرْضَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْضَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْضِخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْضِخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n15730"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B6%D9%8E%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bring to knees"}]},"etymology":null,"ipa":["/radˤ.dˤa.xa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15730","headword_ar":"رَضَخَ","root":"rDx","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":"(A, Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"raDoxN","text_ar":"رَضْخٌ"},{"kind":"text","text":", (JK, S, Msb,)"},{"kind":"italic_en","text":"He broke,"},{"kind":"text","text":"(JK, S, Msb, K,) and"},{"kind":"italic_en","text":"bruised, brayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crushed,"},{"kind":"text","text":"(Msb, TA,) pebbles, (S, K,) and date-stones, (S, Msb, TA,) and a bone, (TA,) and other things, (Msb, TA,) of such as were dry, (TA,) or datestones and the like; (JK;) like"},{"kind":"arabic","text_bw":"raDaHa","text_ar":"رَضَحَ"},{"kind":"text","text":"; (S Msb;) as also ↓"},{"kind":"arabic","text_bw":"rD~x","text_ar":"رضّخ","orth_type":"arrow"},{"kind":"text","text":"[app. in an intensive sense]. (A.)"},{"kind":"italic_en","text":"He broke"},{"kind":"text","text":"(S A, Mgh, Msb) another's head, (Mgh, Msb,) or the head of a serpent, (S, TA,) &c., (TA,) with stones; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"rD~x","text_ar":"رضّخ","orth_type":"arrow"},{"kind":"text","text":"[app. in an intensive sense]. (A.) And"},{"kind":"arabic","text_bw":"raDaxati Alt~uyuwsu","text_ar":"رَضَخَتِ التُّيُوسُ"},{"kind":"italic_en","text":"The he-goats betook themselves to striking one another with their horns,"},{"kind":"text","text":"(JK, K, TA,)"},{"kind":"italic_en","text":"so that some of them broke the heads of others."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"raA^ayotuhumo yaroDaxuwna Alxuboza","text_ar":"رَاَيْتُهُمْ يَرْضَخُونَ الخُبْزَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"yuraD~ixuwnahu","text_ar":"يُرَضِّخُونَهُ","orth_type":"arrow"},{"kind":"italic_en","text":"I saw them breaking in pieces the bread and eating it:"},{"kind":"text","text":"(A:) and ↓"},{"kind":"arabic","text_bw":"Zal~uwA yataraD~axuwna","text_ar":"ظَلُّوا يَتَرَضَّخُونَ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"They passed the time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the day-time,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"breaking in pieces bread and eating it and taking it with their hands:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"kun~aA nataraD~axu","text_ar":"كُنَّا نَتَرَضَّخُ","orth_type":"arrow"},{"kind":"italic_en","text":"We were eating."},{"kind":"text","text":"(JK.) ―         -b2-"},{"kind":"arabic","text_bw":"raDaxa bihi AlA^aroDa","text_ar":"رَضَخَ بِهِ الاَرْضَ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"jaladahu bihaA","text_ar":"جَلَدَهُ بِهَا"},{"kind":"text","text":"[app. for"},{"kind":"arabic","text_bw":"jalada bihi AlA^aroDa","text_ar":"جَلَدَ بِهِ الاَرْضَ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He threw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"italic_en","text":"down upon the ground"},{"kind":"text","text":"]. (JK, K.) ―         -b3-"},{"kind":"arabic","text_bw":"raDaxa lahu","text_ar":"رَضَخَ لَهُ"},{"kind":"text","text":", (S, A, Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"raDaxahu","text_ar":"رَضَخَهُ"},{"kind":"text","text":", (S, Msb,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"raDoxN","text_ar":"رَضْخٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He gave him what was not much;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"he gave him little;"},{"kind":"text","text":"(A, Mgh, TA;)"},{"kind":"arabic","text_bw":"mino maAlihi","text_ar":"مِنْ مَالِهِ"},{"kind":"italic_en","text":"of his property:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"raDaxotu lahumo mino maAliY raDoxapF","text_ar":"رَضَخْتُ لَهُمْ مِنْ مَالِى رَضْخَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I gave them, of my property, a small gift"},{"kind":"text","text":"]: (A:) and"},{"kind":"arabic","text_bw":"lilr~ajuli","text_ar":"لِلرَّجُلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aroDaxotu","text_ar":"اَرْضَخْتُ","orth_type":"arrow"},{"kind":"text","text":"[if not a mistranscription for"},{"kind":"arabic","text_bw":"raDaxotu","text_ar":"رَضَخْتُ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I gave the man a little out of much."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"A^amarotu lahu biraDoxK waraDaxotuhu","text_ar":"اَمَرْتُ لَهُ بِرَضْخٍ وَرَضَخْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I ordered the giving of a small gift to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I ordered a small gift to him, and I gave him a small gift"},{"kind":"text","text":"] occurs in a tradition. (S.)"}],"source_refs":["S","A","Msb","K","JK","TA","Mgh"]}]},"classical_definitions":null}