tions":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sweat"},{"pos":"verb","gloss":"to filter, to strain"},{"pos":"noun","gloss":"rheum"},{"pos":"noun","gloss":"cold, runny nose"},{"pos":"noun","gloss":"sweat, secretion, perspiration"},{"pos":"noun","gloss":"oozing, moisture, flow of moisture"},{"pos":"noun","gloss":"filtering"},{"pos":"verb","gloss":"to raise, to rear (a child)"},{"pos":"verb","gloss":"to train, to prepare"},{"pos":"verb","gloss":"to nominate (to be a candidate)"}]},"etymology":null,"ipa":["/ra.ʃa.ħa/","/raʃħ/","/raʃ.ʃa.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15558","headword_ar":"رَشَحَ","root":"r$H","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"ra$oHN","text_ar":"رَشْحٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(the forehead, or the side thereof above the temple, A, TA, or the body, Msb,)"},{"kind":"italic_en","text":"sweated; exuded sweat;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Ar$H","text_ar":"ارشح","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"Ar$H EaraqoA","text_ar":"ارشح عَرَقْا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EaraqFA","text_ar":"عَرَقًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tr$~H","text_ar":"ترشّح","orth_type":"arrow"},{"kind":"text","text":". (Fr, TA.) And"},{"kind":"arabic","text_bw":"ra$iHa","text_ar":"رَشِحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ra$aHN","text_ar":"رَشَحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ra$aHaAnN","text_ar":"رَشَحَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"page_break","n":1088},{"kind":"italic_en","text":"moist with sweat."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"ra$aHati","text_ar":"رَشَحَتِ"},{"kind":"arabic","text_bw":"Alqirobapu biAlmaA='i","text_ar":"القِرْبَةُ بِالمَا=ءِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The water-skin sweated with the water"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"ra$aHa bimaA fiyhi","text_ar":"رَشَحَ بِمَا فِيهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It sweated with what was in it"},{"kind":"text","text":"] is said of a [porous] mug, and of any [porous] vessel. (A.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"lamo yaro$aHo lahu bi$aYo'K","text_ar":"لَمْ يَرْشَحْ لَهُ بِشَىْءٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He gave him not anything."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"ra$aHa jalomaduhu","text_ar":"رَشَحَ جَلْمَدُهُ"},{"kind":"text","text":", said of one known to be a niggard, (assumed tropical:)"},{"kind":"italic_en","text":"He gave something."},{"kind":"text","text":"(Har p. 95.) ―         -b4-"},{"kind":"arabic","text_bw":"ra$aHa","text_ar":"رَشَحَ"},{"kind":"text","text":"is also said of a young gazelle, meaning (tropical:)"},{"kind":"italic_en","text":"He walked, being trained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accustomed, to do so by his mother:"},{"kind":"text","text":"[because the training him to walk causes him to sweat: see 2: and see also 5.] (A.) Also, said of a gazelle, (assumed tropical:)"},{"kind":"italic_en","text":"He leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounded, and exulted"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"was brisk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lively"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly"},{"kind":"text","text":"]. (K.) Also, inf. n."},{"kind":"arabic","text_bw":"ru$awHN","text_ar":"رُشَوحٌ"},{"kind":"text","text":", said of a young weaned camel, (assumed tropical:)"},{"kind":"italic_en","text":"He became strong:"},{"kind":"text","text":"[see, again, 5:] and the inf. n. is metaphorically used in relation to small clouds [app. when they collect together to give rain]. (L.)       -A2-  See also 2, as said of a she-camel."}],"source_refs":["S","A","Msb","K"]}]},"classical_definitions":null}