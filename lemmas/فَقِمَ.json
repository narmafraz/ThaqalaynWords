:"p"},{"role":"present_2mp","form":"تَفْقَمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْقَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْقَم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْقَم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْقَما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْقَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْقَما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْقَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْقَمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْقَمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْقَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فَقِمْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَقِمْتُ","in_corpus":true,"count":24,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْقَم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْقَم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":115,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n34352"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D9%82%D9%90%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become full, to reach a state of overstuffing; to protrude"},{"pos":"verb","gloss":"to be aggravated, to reach a critical mass or point, to go the wrong course"},{"pos":"verb","gloss":"synonym of فَقِمَ (faqima)"},{"pos":"noun","gloss":"lateral portion of the jaw, maxilla"},{"pos":"noun","gloss":"a muzzle of a dog or canine, jawbone with similar features"},{"pos":"noun","gloss":"verbal noun of فَقِمَ (faqima) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"prognathism"},{"pos":"noun","gloss":"seal (marine animal of the family Phocidae)","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"Most likely just an international word from Ancient Greek φώκη (phṓkē, “seal”), perhaps with this form in Arabic potentially influenced by فُقْم (fuqm) in the sense of a dog's muzzle. Compare the by-name كَلْبُ البَحْرِ (kalbu l-baḥri, “sea lion, seal”, literally “dog of the sea”) as the Arabs, among other cultures, connect pinnipeds visually with canines."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34352","headword_ar":"فَقِمَ","root":"fqm","body":[{"kind":"text","text":", (S, K, * TA,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"faqamN","text_ar":"فَقَمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, full:"},{"kind":"text","text":"(S, K, TA:) it is said of a vessel: (TA:) and one says [also]"},{"kind":"arabic","text_bw":"A^aSaAba mina AlmaA='i Hat~aY faqima","text_ar":"اَصَابَ مِنَ المَا=ءِ حَتَّى فَقِمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took, of the water until he became full"},{"kind":"text","text":"]; mentioned by IDrd. (S, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"A^akala Hat~aY faqima","text_ar":"اَكَلَ حَتَّى فَقِمَ"},{"kind":"italic_en","text":"He ate until he became affected with indigestion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oppressed by much eating."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"faqima maAluhu","text_ar":"فَقِمَ مَالُهُ"},{"kind":"italic_en","text":"His property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth, became much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant:"},{"kind":"text","text":"or it has the contr. meaning, i. e.,"},{"kind":"italic_en","text":"passed away; came to an end;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became spent, exhausted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consumed."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"faqima","text_ar":"فَقِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"faqamN","text_ar":"فَقَمٌ"},{"kind":"text","text":"(S, K, TA) and"},{"kind":"arabic","text_bw":"faqomN","text_ar":"فَقْمٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"He had the lower central incisors prominent,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"so that they did not close against the upper,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"so that the upper did not close against them when he"},{"kind":"text","text":"(the man)"},{"kind":"italic_en","text":"closed his mouth:"},{"kind":"text","text":"so in the L: or"},{"kind":"italic_en","text":"he had the lower jaw long and the upper short:"},{"kind":"text","text":"but accord. to the K,"},{"kind":"italic_en","text":"he had the upper central incisors prominent, so that they did not close against the lower:"},{"kind":"text","text":"(TA:) the epithet applied to him is ↓"},{"kind":"arabic","text_bw":"A^afoqamu","text_ar":"اَفْقَمُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K, TA;) fem."},{"kind":"arabic","text_bw":"faqomaA='u","text_ar":"فَقْمَا=ءُ"},{"kind":"text","text":". (TA [in which it is added that one says"},{"kind":"arabic","text_bw":"rjl fuqomN","text_ar":"رجل فُقْمٌ"},{"kind":"text","text":"; but"},{"kind":"arabic","text_bw":"rjl","text_ar":"رجل"},{"kind":"text","text":"is app. here a mistranscription for"},{"kind":"arabic","text_bw":"rijaAlN","text_ar":"رِجَالٌ"},{"kind":"text","text":"].) ―         -b2-  And [hence]"},{"kind":"arabic","text_bw":"faqima falaAnN","text_ar":"فَقِمَ فَلَانٌ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"baTira","text_ar":"بَطِرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^a$ira","text_ar":"اَشِرَ"},{"kind":"text","text":"(tropical:)  [i. e."},{"kind":"italic_en","text":"Such a one exulted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulted greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively; and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"&c.]: (K, TA:) because"},{"kind":"arabic","text_bw":"AlbaTaru","text_ar":"البَطَرُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA^a$aru","text_ar":"الاَشَرُ"},{"kind":"text","text":"are departure from the limit of rectitude. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faqima AlA^amoru","text_ar":"فَقِمَ الاَمْرُ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"faqamN","text_ar":"فَقَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faqomN","text_ar":"فَقْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuquwmN","text_ar":"فُقُومٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The affair did not proceed in a right course."},{"kind":"text","text":"(K, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"faqima","text_ar":"فَقِمَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faquma","text_ar":"فَقُمَ"},{"kind":"text","text":"are"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"tfAqm","text_ar":"تفاقم"},{"kind":"text","text":", q. v. (K.) ―         -b5-  And"},{"kind":"arabic","text_bw":"faquma","text_ar":"فَقُمَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ample."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"faqama AlmaroA^apa","text_ar":"فَقَمَ المَرْاَةَ"},{"kind":"text","text":": see 3.       -A4-"},{"kind":"arabic","text_bw":"faqama Atkaloba","text_ar":"فَقَمَ اتكَلْبَ"},{"kind":"italic_en","text":"He took hold of the"},{"kind":"arabic","text_bw":"fuqom","text_ar":"فُقْم"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"muzzle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the dog;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"tfq~mhu","text_ar":"تفقّمهُ","orth_type":"arrow"},{"kind":"text","text":". (Z, K.)"}],"source_refs":["TA","S","K"]}]}}