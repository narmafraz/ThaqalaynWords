":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n18562","n18563","n19403","n21163"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be master, to have power, to rule","tags":["ambitransitive"],"examples":[{"text":"بينما ذهب بعض من مستخدمي مواقع التواصل الاجتماعي إلى أن فتح الصندوق ورفع الغطاء سيصيب العالم بلعنة، حيث سيؤدي ذلك إلى أن يسود الظلام العالم، وسيغطي على ضوء الشمس مما سيجعل الأرض تعيش في ظلام دامس لمدة 1000 عام تقريبا."}]}]},"etymology":null,"ipa":["/saː.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18562","headword_ar":"سَاْدٌ","root":"sA^d","body":[{"kind":"text","text":"[an inf. n. of which the verb is not mentioned,] The act of"},{"kind":"italic_en","text":"walking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going any pace on foot."},{"kind":"text","text":"(M.)"}],"source_refs":[]},{"entry_id":"n18563","headword_ar":"سَاَدٌ","root":"sA^d","body":[{"kind":"text","text":": see 4, above."}],"source_refs":[]},{"entry_id":"n19403","headword_ar":"سَادٍ","root":"sdw and sdY","body":[{"kind":"italic_en","text":"Stretching forth the arms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fore legs, in going along,"},{"kind":"text","text":"(M, * TA,)"},{"kind":"italic_en","text":"and wide in step;"},{"kind":"text","text":"(TA;) applied to a camel: (M, TA:) and so"},{"kind":"arabic","text_bw":"sawaAdK","text_ar":"سَوَادٍ"},{"kind":"text","text":", [pl. of the fem."},{"kind":"arabic","text_bw":"saAdiyapN","text_ar":"سَادِيَةٌ"},{"kind":"text","text":",] applied to she-camels: (S, K, * TA:) [see also"},{"kind":"arabic","text_bw":"saduw~N","text_ar":"سَدُوٌّ"},{"kind":"text","text":":] or, accord. to the T, the Arabs apply the term"},{"kind":"arabic","text_bw":"sawaAdK","text_ar":"سَوَادٍ"},{"kind":"text","text":"as a name for the"},{"kind":"italic_en","text":"fore legs of camels,"},{"kind":"text","text":"because of their stretching them forth in going along; and then as a name for the camels themselves. (TA.) And"},{"kind":"arabic","text_bw":"saAdK","text_ar":"سَادٍ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"Good in pace"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going;"},{"kind":"text","text":"applied to a camel; and so"},{"kind":"arabic","text_bw":"zaAdK","text_ar":"زَادٍ"},{"kind":"text","text":". (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"sudFY","text_ar":"سُدًى"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"Als~aAdiY","text_ar":"السَّادِى"},{"kind":"text","text":"is also used for"},{"kind":"arabic","text_bw":"Als~aAdisu","text_ar":"السَّادِسُ"},{"kind":"text","text":"; (S, K, TA;) the"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN saAdisFA","text_ar":"جَا=ءَ فُلَانٌ سَادِسًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saAdiyFA","text_ar":"سَادِيًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one came sixth"},{"kind":"text","text":"]. (ISk, S voce"},{"kind":"arabic","text_bw":"saAt~N","text_ar":"سَاتٌّ"},{"kind":"text","text":", q. v.)"}],"source_refs":["M","TA"]},{"entry_id":"n21163","headword_ar":"سَادَ","root":"swd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasuwdu","text_ar":"يَسُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"siyaAdapN","text_ar":"سِيَادَةٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"suwdN","text_ar":"سُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suwdadN","text_ar":"سُودَدٌ"},{"kind":"text","text":"[and its vars. mentioned in the next sentence] and"},{"kind":"arabic","text_bw":"sayoduwdapN","text_ar":"سَيْدُودَةٌ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"suwdadN","text_ar":"سُودَدٌ"},{"kind":"text","text":"is a simple subst. signifying as expl. below, (Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"say~id","text_ar":"سَيِّد"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"chief, lord, master,"},{"kind":"text","text":"&c.; or]"},{"kind":"italic_en","text":"possessed of glory, honour, dignity, eminence, exalted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility."},{"kind":"text","text":"(Msb, TA.) ―         -b2-  [It is also trans.:] you say,"},{"kind":"arabic","text_bw":"saAda qawomahu","text_ar":"سَادَ قَوْمَهُ"},{"kind":"text","text":", (S, M, * A,) aor."},{"kind":"arabic","text_bw":"yasuwduhumo","text_ar":"يَسُودُهُمْ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"siyaAdapN","text_ar":"سِيَادَةٌ"},{"kind":"text","text":"(S, M, K *) and"},{"kind":"arabic","text_bw":"suwdN","text_ar":"سُودٌ"},{"kind":"text","text":"(M, K *) and"},{"kind":"arabic","text_bw":"suwdadN","text_ar":"سُودَدٌ"},{"kind":"text","text":", (S, M, A, K *) in which last the [final]"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":"is added to render the word quasi-coordinate to words of the measure"},{"kind":"arabic","text_bw":"fuEolalN","text_ar":"فُعْلَلٌ"},{"kind":"text","text":", as"},{"kind":"arabic","text_bw":"junodabN","text_ar":"جُنْدَبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buroqaEN","text_ar":"بُرْقَعٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"suwdudN","text_ar":"سُودُدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suw^odadN","text_ar":"سُوْدَدٌ"},{"kind":"text","text":"(M, TA *) and"},{"kind":"arabic","text_bw":"suw^odudN","text_ar":"سُوْدُدٌ"},{"kind":"text","text":", (M, K, *) of the dial. of Teiyi, (M,) and"},{"kind":"arabic","text_bw":"sayoduwdapN","text_ar":"سَيْدُودَةٌ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, the"},{"kind":"arabic","text_bw":"say~id","text_ar":"سَيِّد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"chief, lord, master,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"of his people;"},{"kind":"text","text":"(S;) ["},{"kind":"italic_en","text":"he ruled his people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held dominion over them;"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"AisotaAdahumo","text_ar":"اِسْتَادَهُمْ","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (M, L.) And"},{"kind":"arabic","text_bw":"saAdahu","text_ar":"سَادَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"siyaAdapN","text_ar":"سِيَادَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"siyaAdN","text_ar":"سِيَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suwdadN","text_ar":"سُودَدٌ"},{"kind":"text","text":"[&c.],"},{"kind":"italic_en","text":"He exercised rule,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dominion, over him."},{"kind":"text","text":"(MA.) [See also"},{"kind":"arabic","text_bw":"suwdadN","text_ar":"سُودَدٌ"},{"kind":"text","text":"below.] ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"saAdato naAqatiY AlmaTaAyaA","text_ar":"سَادَتْ نَاقَتِى المَطَايَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"My she-camel left behind the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beasts."},{"kind":"text","text":"(A, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"saAwadaniY fasudotuhu","text_ar":"سَاوَدَنِى فَسُدْتُهُ"},{"kind":"text","text":": see 3.       -A2-"},{"kind":"arabic","text_bw":"sawida","text_ar":"سَوِدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saAda","text_ar":"سَادَ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"Aisowad~a","text_ar":"اِسْوَدَّ"},{"kind":"text","text":": see this last, in three places.       -A3-"},{"kind":"arabic","text_bw":"saAdahu","text_ar":"سَادَهُ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"saAwadahu","text_ar":"سَاوَدَهُ"},{"kind":"text","text":": see this latter.       -A4-"},{"kind":"arabic","text_bw":"saAda","text_ar":"سَادَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasuwdu","text_ar":"يَسُودُ"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"He drank water such as is termed"},{"kind":"arabic","text_bw":"masowadap","text_ar":"مَسْوَدَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"which occasions a disease termed"},{"kind":"arabic","text_bw":"suwaAdi","text_ar":"سُوَادِ"},{"kind":"text","text":". (M, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"siyda","text_ar":"سِيدَ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"suy^ida","text_ar":"سُيِدَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with"},{"kind":"arabic","text_bw":"Als~uwaAd","text_ar":"السُّوَاد"},{"kind":"text","text":". (M, K. [In the former, the context indicates that this means here a disease that attacks the liver from eating dates: in the latter, that it here means a disease incident to sheep or goats.])"}],"source_refs":["Msb","TA","S","A","M","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D8%AF/","headword_ar":"سادان","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=109382#5baace","body_html":"سادان<br>عن العبرية بمعنى سندان الحداد، وجذع شجرة، ومؤخرة البندقية يستخدم للذكور."}]}}