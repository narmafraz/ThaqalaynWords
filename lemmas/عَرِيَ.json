{"role":"past_1ms","form":"عَرِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَرِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n28884","n28891","","n28895","n28897"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B1%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be naked, nude, bare, au naturel","examples":[{"text":"إِنَّ لَكَ أَلَّا تَجُوعَ فِيهَا وَلَا تَعْرَىٰ","english":"In it you will never go hungry, nor be naked."}]},{"pos":"verb","gloss":"to disrobe, to undress"},{"pos":"verb","gloss":"to be free of, to be devoid of, to be completely without"},{"pos":"noun","gloss":"verbal noun of عَرِيَ (ʕariya) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"bareness, nakedness, nudity"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ع ر ي (ʕ r y).\n\nPossibly cognate with Hebrew עירום (eróm, “nakedness, nudity”). Morphologically from the root ع ر ي (ʕ r y)."},"ipa":["/ʕa.ri.ja/","/ʕurj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28884","headword_ar":"عَرِىٌّ","root":"Erw","body":[{"kind":"text","text":"an epithet applied to a palm-tree such as is termed"},{"kind":"arabic","text_bw":"Eariy~apN","text_ar":"عَرِيَّةٌ"},{"kind":"text","text":"[q. v.]: one says"},{"kind":"arabic","text_bw":"naxolapN EariY~N","text_ar":"نَخْلَةٌ عَرِىٌّ"},{"kind":"text","text":", (S, Msb,) the latter word without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; like as one says"},{"kind":"arabic","text_bw":"AimoraA^apN qatiylN","text_ar":"اِمْرَاَةٌ قَتِيلٌ"},{"kind":"text","text":". (Msb.)       -A2-  And"},{"kind":"arabic","text_bw":"riyHN Eariy~apN","text_ar":"رِيحٌ عَرِيَّةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"EariY~N","text_ar":"عَرِىٌّ"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"A cold wind."},{"kind":"text","text":"(S, K: mentioned in the K in this art. and also in art."},{"kind":"arabic","text_bw":"ErY","text_ar":"عرى"},{"kind":"text","text":") And one says also,"},{"kind":"arabic","text_bw":"A_in~a Ea$iy~atanaA h`*ihi laEariy~apN","text_ar":"اـِنَّ عَشِيَّتَنَا هٰذِهِ لَعَرِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily this our evening is cold"},{"kind":"text","text":"]. (El-Kilábee, S.) And"},{"kind":"arabic","text_bw":"layolapN Eariy~apN","text_ar":"لَيْلَةٌ عَرِيَّةٌ"},{"kind":"italic_en","text":"A cold night."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n28891","headword_ar":"عَرِىَ","root":"ErY","body":[{"kind":"text","text":"(S, MA, Mgh, Msb, K)"},{"kind":"arabic","text_bw":"mino viyaAbihi","text_ar":"مِنْ ثِيَابِهِ"},{"kind":"text","text":", (S, MA, Mgh, Msb,) aor."},{"kind":"arabic","text_bw":"yaEoraY","text_ar":"يَعْرَى"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"EuroYN","text_ar":"عُرْىٌ"},{"kind":"text","text":"(Mgh, Msb, K, and so in some copies of the S, accord. to other copies of which it is"},{"kind":"arabic","text_bw":"EuriY~N","text_ar":"عُرِىٌّ"},{"kind":"text","text":", and also with kesr to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", as stated in the TA, ["},{"kind":"arabic","text_bw":"AlEur`Y","text_ar":"العُرٰى"},{"kind":"text","text":"commencing the art. in the CK is a mistake for"},{"kind":"arabic","text_bw":"AlEuroYu","text_ar":"العُرْىُ"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"EuroyapN","text_ar":"عُرْيَةٌ"},{"kind":"text","text":", (Msb, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Msb, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, naked, nude, bare,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without clothing;"},{"kind":"text","text":"(K, TA;) or"},{"kind":"italic_en","text":"bare of his clothes:"},{"kind":"text","text":"(MA:) and ↓"},{"kind":"arabic","text_bw":"tEr~Y","text_ar":"تعرّى","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (MA, K:) [or rather] the latter is quasipass. of"},{"kind":"arabic","text_bw":"Er~Ahu","text_ar":"عرّاهُ"},{"kind":"text","text":"[and therefore is more correctly rendered"},{"kind":"italic_en","text":"he was made naked,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"made bare of his clothes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denuded thereof,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divested;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he made himself naked,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"denuded himself of his clothes"},{"kind":"text","text":"]. (S.) [And sometimes it means"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bare of clothing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his clothes, except one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more, of his inner garments:"},{"kind":"text","text":"and in like manner, ↓"},{"kind":"arabic","text_bw":"tEr~Y","text_ar":"تعرّى","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he made himself, bare of clothing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his clothes, except one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more, of his inner garments."},{"kind":"text","text":"] ―         -b2-  And [hence] one says also,"},{"kind":"arabic","text_bw":"EariYa Albadanu mina All~aHomi","text_ar":"عَرِىَ البَدَنُ مِنَ اللَّحْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The body was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bare of flesh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lean"},{"kind":"text","text":"]. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EariYa mina AlEayobi","text_ar":"عَرِىَ مِنَ العَيْبِ"},{"kind":"text","text":", aor. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from fault, defect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blemish:"},{"kind":"text","text":"part. n. ↓"},{"kind":"arabic","text_bw":"EarK","text_ar":"عَرٍ","orth_type":"arrow"},{"kind":"text","text":"[if not a mistranscription for"},{"kind":"arabic","text_bw":"EaArK","text_ar":"عَارٍ"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"EariYa mina","text_ar":"عَرِىَ مِنَ"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from the affair:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA yaEoraY mino h`*aA AlA^amori","text_ar":"مَا يَعْرَى مِنْ هٰذَا الاَمْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He is not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"does not become, free from this affair:"},{"kind":"text","text":"and hence,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"yaEoraY mina Almawoti A^aHadN","text_ar":"يَعْرَى مِنَ المَوْتِ اَحَدٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"No one will be exempt from death"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Earayotuhu","text_ar":"عَرَيْتُهُ"},{"kind":"italic_en","text":"I came to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ga$iytuhu","text_ar":"غَشِيتُهُ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"Earawotuhu","text_ar":"عَرَوْتُهُ"},{"kind":"text","text":"[q. v.]. (K.)"}],"source_refs":["S","MA","Mgh","Msb","K"]},{"entry_id":"n28895","headword_ar":"عَرًى","root":"ErY","body":[{"kind":"italic_en","text":"A hard and elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an elevated and plain, part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract,"},{"kind":"text","text":"of the earth,"},{"kind":"italic_en","text":"that is apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aEoraA='N","text_ar":"اَعْرَا=ءٌ"},{"kind":"text","text":". (TA.) ["},{"kind":"arabic","text_bw":"EaraA='N","text_ar":"عَرَا=ءٌ"},{"kind":"text","text":", also, (q. v.,) has a similar meaning, and the same pl.] ―         -b2-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HaAy^iTN","text_ar":"حَايِطٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A wall;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a wall of enclosure;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one that surrounds a garden:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a garden,"},{"kind":"text","text":"in general; or"},{"kind":"italic_en","text":"a garden of palm-trees, surrounded by a wall"},{"kind":"text","text":"]. (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"EarFA","text_ar":"عَرًا"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"Erw","text_ar":"عرو"},{"kind":"text","text":": and in the same paragraph see its syn."},{"kind":"arabic","text_bw":"EaraApN","text_ar":"عَرَاةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28897","headword_ar":"عُرْىٌ","root":"ErY","body":[{"kind":"text","text":"A horse"},{"kind":"italic_en","text":"not having a saddle upon him;"},{"kind":"text","text":"(S, Msb, K;) and so ↓"},{"kind":"arabic","text_bw":"muEoraworK","text_ar":"مُعْرَوْرٍ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEoraworFY","text_ar":"مُعْرَوْرًى","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"not having upon him a saddle nor a saddle-cloth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"housing;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muEoraworFY","text_ar":"مُعْرَوْرًى","orth_type":"arrow"},{"kind":"text","text":"; but ↓"},{"kind":"arabic","text_bw":"muEoraworK","text_ar":"مُعْرَوْرٍ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"riding without a saddle and without a saddle-cloth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"housing:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"arabic","text_bw":"EuroYN","text_ar":"عُرْىٌ"},{"kind":"text","text":"[as also ↓"},{"kind":"arabic","text_bw":"muEoraworFY","text_ar":"مُعْرَوْرًى","orth_type":"arrow"},{"kind":"text","text":"] signifies"},{"kind":"italic_en","text":"not having upon him a saddle nor any furniture:"},{"kind":"text","text":"(TA:) ↓"},{"kind":"arabic","text_bw":"EuroyaAnN","text_ar":"عُرْيَانٌ","orth_type":"arrow"},{"kind":"text","text":"is not applied as an epithet to a horse, nor is"},{"kind":"arabic","text_bw":"EuroYN","text_ar":"عُرْىٌ"},{"kind":"text","text":"to a man: (Mgh, Msb, TA:) the latter is an inf. n. used as an epithet, and then made a subst., having a pl., (Msb, TA,) which is"},{"kind":"arabic","text_bw":"A^aEoraA='N","text_ar":"اَعْرَا=ءٌ"},{"kind":"text","text":". (S, Mgh, Msb, TA.)"}],"source_refs":["TA","Mgh","Msb"]}]},"classical_definitions":null}