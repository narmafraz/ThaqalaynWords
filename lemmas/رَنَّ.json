{"lemma":"رَنَّ","slug":"رَنَّ","root":"ر.ن.ن","root_slug":"ر-ن-ن","root_link":"/words/roots/ر-ن-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"رَنَنْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"رَنَنْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"رَنَنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"رَنَنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"رَنَنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"رَنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"رَنَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"رَنّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"رَنَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"رَنُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"رَنَنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَرِنّ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَرْنِن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَرِنِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَرِنِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَرْنِنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَرْنِنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَرِنّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَرِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَرْنِنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَرْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَرِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْنِنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْنِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرِنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَرْنِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرِنّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرْنِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْنِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْنِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْنِنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْنِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَرِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n16749"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sound, to resound"},{"pos":"verb","gloss":"to ring","examples":[{"text":"رَنَّ الْهَاتِفُ.","english":"The phone rang."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16749","headword_ar":"رَنَّ","root":"rn","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yarin~u","text_ar":"يَرِنُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"raniynN","text_ar":"رَنِينٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Arn~","text_ar":"ارنّ","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"emitted a sound:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he cried aloud;"},{"kind":"text","text":"(K;) or"},{"kind":"arabic","text_bw":"ran~ato","text_ar":"رَنَّتْ"},{"kind":"text","text":", aor. and inf. n. as above; and ↓"},{"kind":"arabic","text_bw":"Arn~t","text_ar":"ارنّت","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"she cried aloud,"},{"kind":"text","text":"said of a woman: (S:) or"},{"kind":"arabic","text_bw":"ran~a","text_ar":"رَنَّ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Arn~","text_ar":"ارنّ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"he raised his voice in weeping:"},{"kind":"text","text":"(Ham p. 11:) or"},{"kind":"arabic","text_bw":"raniynN","text_ar":"رَنِينٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"crying aloud in weeping;"},{"kind":"text","text":"(Lth, T;) or the"},{"kind":"italic_en","text":"uttering a plaintive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mournful, voice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry:"},{"kind":"text","text":"(M:) and ↓"},{"kind":"arabic","text_bw":"A_ironaAnN","text_ar":"اـِرْنَانٌ","orth_type":"arrow"},{"kind":"text","text":", [inf. n. of"},{"kind":"arabic","text_bw":"Arn~","text_ar":"ارنّ"},{"kind":"text","text":",] the"},{"kind":"italic_en","text":"uttering a loud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry;"},{"kind":"text","text":"(Lth, T, M;) or the"},{"kind":"italic_en","text":"uttering of the sound of reiterating the breath with weeping:"},{"kind":"text","text":"(IAar, T:) or"},{"kind":"arabic","text_bw":"raniynN","text_ar":"رَنِينٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_ironaAnN","text_ar":"اـِرْنَانٌ","orth_type":"arrow"},{"kind":"text","text":"signify the"},{"kind":"italic_en","text":"crying out loudly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"uttering a plaintive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mournful, voice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry, in singing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in weeping:"},{"kind":"text","text":"(M:) you say of a woman,"},{"kind":"arabic","text_bw":"ran~ato","text_ar":"رَنَّتْ"},{"kind":"text","text":", inf. n. as above; and ↓"},{"kind":"arabic","text_bw":"Arn~t","text_ar":"ارنّت","orth_type":"arrow"},{"kind":"text","text":"; (T, M;) and ↓"},{"kind":"arabic","text_bw":"rn~nt","text_ar":"رنّنت","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taroniynN","text_ar":"تَرْنِينٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taroniyapN","text_ar":"تَرْنِيَةٌ"},{"kind":"text","text":"[which is properly inf. n. of"},{"kind":"arabic","text_bw":"ran~ato","text_ar":"رَنَّتْ"},{"kind":"text","text":"as belonging to art."},{"kind":"arabic","text_bw":"rnw","text_ar":"رنو"},{"kind":"text","text":"]; all meaning"},{"kind":"italic_en","text":"she cried out loudly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"she uttered a plaintive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mournful, voice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry, in singing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in weeping:"},{"kind":"text","text":"(M:) and"},{"kind":"arabic","text_bw":"Aln~isaA='u","text_ar":"النِّسَا=ءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aran~ati","text_ar":"اَرَنَّتِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fiY niyaA Hatihin~a","text_ar":"فِى نِيَا حَتِهِنَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the women cried loudly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently, in their wailing"},{"kind":"text","text":"]. (T.) See also 4.       -A2-"},{"kind":"arabic","text_bw":"ran~a A_ilayohi","text_ar":"رَنَّ اـِلَيْهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Arn~","text_ar":"ارنّ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He gave ear, hearkened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listened, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.)"}],"source_refs":["Msb","S","M","IAar","T"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D9%86/","headword_ar":"رن","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10830#29c046","body_html":"<div>رن: الرَّنَّةُ: الصَّيْحَةُ الحَزِيْنَةُ، يُقال: عُوْدٌ ذُوْ رَنَّةٍ. والرَّنِيْنُ: الصِّيَاحُ عِنْدَ البُكَاءِ.</div><div>والإِرْنَانُ: الصَّوْتُ الشَّدِيْدُ كإرْنَانِ الحِمَارِ. وأرَنَّتِ القَوْسُ في إنْبَاضِها، والنِّسَاءُ في نِيَاحَتِها. وسَحَابَةٌ مِرْنَانَةٌ.</div><div>وأرَنَّ فلانٌ لكذا: أصْغَى إليه.</div><div>والرُّنَنُ: دُوَيْبَّةٌ تَكُونُ في الماءِ تَصِيْحُ أيّامَ الصَّيْفِ.</div><div>ويُقال لجُمَادى الأُوْلى: رُنّى، وجَمْعُه رُنَنٌ.</div>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10830#8cfcfc","body_html":"<span class=\"title1\">باب الراء</span><span> والنّون ر ن مستعمل فقط</span><br><br><span>رن: الرَّنّةُ: الصَّيْحةُ الحَزِينةُ، يُقالُ: عُودٌ ذو رنّةٍ. والرَّنينُ: الصِّياحُ عند البُكاء. والإِرْنانُ: الصَّوْتُ الشَّديد، يُقال: أَرَنَّ الحِمارُ في نَهيقِهِ، وأَرَنَّتِ القَوْسُ في أنباضِها، وأَرَنَّتِ النِّساء في مناحتهن، والشاء في نِتاجها، وسَحابةٌ مِرنانٌ، أي: مُصَوِّتة، قال العجّاجُ يَصِفُ قَوْساً:</span><br><br><span>تُرِنُّ إرْنانا إذا ما أَنْضِبا </span><span class=\"red\">...</span><span> إرْنانَ مَحْزُون إذا تَحَوَّبا</span><br><br><span>أراد: أُنْبِضَ فقَلَب.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10830#4dfc43","body_html":"<h3>رن</h3><span class=\"sense\">1</span> رَنَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> رَنِينٌ; and ↓ ارنّ; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) It (a thing) emitted a sound: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) or he cried aloud; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) or رَنَّتْ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> and <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> as above; and ↓ ارنّت; she cried aloud, said of a woman: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) or رَنَّ and ↓ ارنّ signify he raised his voice in weeping: (<abbr title=\"Sharḥ Dīwān al-Ḥamāsah by al-Tabrīzī\">Ham</abbr> p. 11:) or رَنِينٌ signifies the crying aloud in weeping; (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>;) or the uttering a plaintive, or mournful, voice or sound or cry: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) and ↓ إِرْنَانٌ, [<abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of ارنّ,] the uttering a loud, or vehement, sound or cry; (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) or the uttering of the sound of reiterating the breath with weeping: (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) or رَنِينٌ and ↓ إِرْنَانٌ signify the crying out loudly, or vehemently; and the uttering a plaintive, or mournful, voice or sound or cry, in singing, or in weeping: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) you say of a woman, رَنَّتْ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> as above; and ↓ ارنّت; (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) and ↓ رنّنت, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَرْنِينٌ and تَرْنِيَةٌ [which is properly <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of رَنَّتْ as belonging to art. رنو]; all meaning she cried out loudly, or vehemently; and she uttered a plaintive, or mournful, voice or sound or cry, in singing or in weeping: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) and النِّسَآءُ ↓ أَرَنَّتِ فِى نِيَا حَتِهِنَّ [the women cried loudly, or vehemently, in their wailing]. (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>.) See also 4.<br><br><span class=\"sub-sense\">A2:</span> رَنَّ إِلَيْهِ, and ↓ ارنّ, He gave ear, hearkened, or listened, to him, or it. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 2 رَنَّنْتُ القَوْسَ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَرْنِينٌ, [I twanged the bow;] I made the bow to produce a sound [by pulling the string and letting it go suddenly]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">A2:</span> See also 1.<span class=\"sense\">4</span> ارنّ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> إِرْنَانٌ: see 1, in seven places.<br><br>أَرَنَّتْ is said of a woman in her wailing [as <abbr title=\"explained\">expl.</abbr> above]; and of a pigeon (حَمَامَة) in its cooing [<abbr title=\"apparently\">app.</abbr> as meaning It uttered plaintive sounds]; (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) and of a bow (قَوْس), (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) on the occasion of its string's being pulled and let go, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>,) <abbr title=\"according\">accord.</abbr> to the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> ↓ رَنَّتْ, but this is a mistake, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) meaning it [twanged, or] produced a sound, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"according\">accord.</abbr> to <abbr title=\"Abū Ḥanīfah al-Dīnawarī, author of the Book of Plants\">AHn</abbr>, above what is termed حَنِينٌ; (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) and of a cloud (سَحَابَة) in its thundering [<abbr title=\"apparently\">app.</abbr> as meaning it resounded]. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) And ارنّ is also said of an ass in his braying; (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) and of water in its murmuring, or gurgling, or running vehemently. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) <span class=\"sub-sense\">A2:</span> ارنّ فُلَانٌ لِكَذَا Such a one was cheered, or delighted, and pleased, or was diverted, by reason of such a thing; as also أَرَمَّ لَهُ, and رَنَا له, and استرنى. (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>.) <span class=\"sub-sense\">A3:</span> ارنّ إِلَيْهِ: see 1, last sentence.<br><br>رَنَّهٌ A sound, voice, or cry, (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) [in an absolute sense, or] in joy or sorrow: (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) or a plaintive, or mournful, cry; whence one says عُودٌ ذُو رَنَّةٍ [a lute having a plaintive sound]: (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) [or a moaning:] or a cry; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) or a loud cry: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>: *) and also a plaintive, or mournful, voice or sound or cry, in singing, or in weeping: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> رَنَّاتٌ. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>.) رَنَنٌ A certain thing that utters a cry [or sound]<br><br>يَصِيحُ [in one of my copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> يَطِيحُ]) in the water, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or in still water, (so in one copy of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) in the صَيْف [i. e. spring or summer], (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or in winter. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) A poet says, وَلَمْ يَصْدَحْ لَهُ الرَّنَنُ [And the رنن did not raise its voice at him, or it]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b2:</span> Also A small quantity of water. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) رَنِينٌ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of 1. (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, &amp;c.) <span class=\"sub-sense\">b2:</span> [<abbr title=\"according\">Accord.</abbr> to Golius, El-<abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>ánee explains it also as meaning A woman afflicted and oppressed by misfortune; and Golius adds, as though moaning, or lamenting.]<br><br>الرُّنَّى Mankind, or all created beings. (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) One says, مَا فِى الرُّنَّى مِثْلُهُ [There is not among mankind, or all created beings, the like of him]. (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>.) <span class=\"sub-sense\">A2:</span> Also, (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>,) or رُنَّى, without ال, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) The month Jumádà: (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) or a name of Jumádà-l-Ákhireh; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and so رُنَةُ, [said to be from رُونَةٌ, (see art. رون,) though <abbr title=\"apparently\">app.</abbr> belonging to art. رنو, being] without teshdeed: <abbr title=\"plural, جَمْعٌ\">pl.</abbr> رُنَنٌ: Aboo-' Amr Ez-<abbr title=\"al-Zamakhsharī\">Z</abbr>áhid disallowed رُبَّى, and pronounced it to be a mistranscription: but <abbr title=\"according\">accord.</abbr> to <abbr title=\"Kutrub (al-Quṭrub)\">Ktr</abbr> and <abbr title=\"Ibn-El-Ambáree (Abū al-Barakāt Kamāl al-Dīn ibn al-Anbārī)\">IAmb</abbr> and Abu-t-Teiyib 'AbdEl-<abbr title=\"al-Wāḥidī's exposition of the Dīwān of al-Mutanabbī, edited by Dr. Dieterici\">W</abbr>áhid and Abu-l-<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>ásim Ez-Zejjájee, it is رُبَّى<br><br>only; because in it were known the results of their wars; from رُبَّى applied to a ewe or she-goat: and الحَنِينُ was a name of Jumádà-l-Oolà: see also art. رب, in which is said what somewhat differs from the statement here. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) رُنَّآءٌ, like رُمَّانٌ, with teshdeed, <abbr title=\"according\">accord.</abbr> to <abbr title=\"Thaʿlab, author of the Faṣīḥ\">Th</abbr>, <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> طَرَبٌ: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or so رُنَآءٌ, without teshdeed, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"according\">accord.</abbr> to A 'Obeyd: the latter is mentioned in its proper place [in art. رنو, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) أَرْوَنَانٌ, an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> applied to a day, meaning Vehement in respect of anything, is of the measure أَفْوَعَالٌ, from الرَّنِينُ, <abbr title=\"according\">accord.</abbr> to <abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>; but <abbr title=\"according\">accord.</abbr> to <abbr title=\"Sibawayh\">Sb</abbr>, of the measure أَفْعَلَالٌ, from رُونَةٌ, meaning “ hardness,” and “ grievousness,” of a thing, or an affair, or event: it is mentioned in art. رون. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) مُرِنَّةٌ is applied as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> to birds [<abbr title=\"apparently\">app.</abbr> as meaning Uttering plaintive sounds]: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) and, as also ↓ مِرْنَانٌ, as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> to a bow [as meaning twanging], and so to a cloud (سَحَابَة) [<abbr title=\"apparently\">app.</abbr> as meaning resounding with thunder]: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) and each is applied to a bow [itself]; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and the latter, to a cloud [itself]; as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> in which the quality of a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr> is predominant [so as to imply, <abbr title=\"apparently\">app.</abbr>, the meaning of resounding with thunder, or because it is hoped that it will resound with thunder, or because it often does so]. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) مِرْنَانٌ: see the next preceding paragraph."}]}}