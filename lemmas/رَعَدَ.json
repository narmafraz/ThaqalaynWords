und":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n15879"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B9%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to thunder"},{"pos":"verb","gloss":"to appall"},{"pos":"noun","gloss":"verbal noun of رَعَدَ (raʕada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thunder","examples":[{"text":"أَوْ كَصَيِّبٍ مِنَ ٱلسَّمَاءِ فِيهِ ظُلُمَاتٌ وَرَعْدٌ وَبَرْقٌ يَجْعَلُونَ أَصَابِعَهُمْ فِي آذَانِهِمْ حَذَرَ ٱلْمَوْتِ […] ۝ يَكَادُ ٱلْبَرْقُ يَخْطَفُ أَبْصَارَهُمْ ۖ كُلَّمَا أَضَاءَ لَهُمْ مَشَوْا فِيهِ وَإِذَا أَظْلَمَ عَلَيْهِمْ قَامُوا"},{"text":"هُوَ ٱلَّذِي يُرِيكُمُ ٱلْبَرْقَ خَوْفًا وَطَمَعًا وَيُنْشِئُ ٱلسَّحَابَ ٱلثِّقَالَ ۝ وَيُسَبِّحُ ٱلرَّعْدُ بِحَمْدِهِ وَٱلْمَلَائِكَةُ مِنْ خِيفَتِهِ وَيُرْسِلُ ٱلصَّوَاعِقَ فَيُصِيبُ بِهَا مَنْ يَشَاءُ وَهُمْ يُجَادِلُونَ فِي ٱللّٰهِ وَهُوَ شَدِيدُ ٱلْمِحَالِ"}]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew רעד (raʕád, “shake”).\n\nFrom Proto-Semitic *raʕd-."},"ipa":["/raʕd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15879","headword_ar":"رَعْدٌ","root":"rEd","body":[{"kind":"italic_en","text":"Thunder;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"sound that is heard from the clouds,"},{"kind":"text","text":"(S, K, *) or"},{"kind":"italic_en","text":"from the sky:"},{"kind":"text","text":"(A:) so say the people of the desert: (Akh, TA:) [thus termed as being supposed to be a trembling, or state of agitation, of the clouds, as is implied in the Ksh and the Expos. of Bd in ii. 18, where it is said to be from"},{"kind":"arabic","text_bw":"AlAirotiEaAd","text_ar":"الاِرْتِعَاد"},{"kind":"text","text":", or as being a cause of trembling:] originally an inf. n., and therefore [it is said that] it has no pl.: (Bd ubi suprà:) [but see what follows, in which"},{"kind":"arabic","text_bw":"ruEuwdN","text_ar":"رُعُودٌ"},{"kind":"text","text":"occurs, perhaps as its pl.:] or"},{"kind":"arabic","text_bw":"Alr~aEodu","text_ar":"الرَّعْدُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the name of an angel who drives the clouds"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with his voice"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like as a man drives camels with singing."},{"kind":"text","text":"(I'Ab, Z, K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"jaA='a bi*aAti Alr~aEodi waAlS~aliyli","text_ar":"جَا=ءَ بِذَاتِ الرَّعْدِ وَالصَّلِيلِ"},{"kind":"text","text":"i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"He brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought to pass, that which had thunder and noise;"},{"kind":"text","text":"meaning,] (tropical:)"},{"kind":"italic_en","text":"war:"},{"kind":"text","text":"(S, K, TA:) or"},{"kind":"italic_en","text":"calamity:"},{"kind":"text","text":"(A, TA:) and"},{"kind":"arabic","text_bw":"bi*awaAti","text_ar":"بِذَوَاتِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Alr~awaAEidi","text_ar":"الرَّوَاعِدِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"calamities:"},{"kind":"text","text":"(A:) [for] ↓"},{"kind":"arabic","text_bw":"*aAtu Alr~awaAEidi","text_ar":"ذَاتُ الرَّوَاعِدِ","orth_type":"arrow"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"*awAtu","text_ar":"ذَواتُ"},{"kind":"text","text":"] signifies"},{"kind":"italic_en","text":"calamity."},{"kind":"text","text":"(S, K, TA.) And"},{"kind":"arabic","text_bw":"fiY kitaAbihi ruEuwdN waburuwqN","text_ar":"فِى كِتَابِهِ رُعُودٌ وَبُرُوقٌ"},{"kind":"text","text":"[which may be rendered"},{"kind":"italic_en","text":"In his letter are thunders and lightnings;"},{"kind":"text","text":"] meaning, (tropical:)"},{"kind":"italic_en","text":"words of threatening."},{"kind":"text","text":"(A.)"}],"source_refs":["A","Akh","TA","S","K"]}]}}