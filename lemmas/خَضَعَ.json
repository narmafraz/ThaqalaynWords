"per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخْضَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخْضَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْضَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْضَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخْضَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخْضَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْضَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْضَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخْضَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَخْضَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخْضَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخْضَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَضَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَضَعْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْضَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْضَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n10905"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B6%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be submissive, be humble"},{"pos":"verb","gloss":"to submit"},{"pos":"verb","gloss":"to be near setting"},{"pos":"verb","gloss":"to rest"},{"pos":"verb","gloss":"to bring to rest, to quiet"},{"pos":"verb","gloss":"to bend"},{"pos":"verb","gloss":"to incite (to something bad)"},{"pos":"verb","gloss":"to walk along vigorously"},{"pos":"verb","gloss":"to undergo (a test or treatment)"},{"pos":"adj","gloss":"masculine plural of خَضُوع (ḵaḍūʕ)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"Inflected form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10905","headword_ar":"خَضَعَ","root":"xDE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuDuwEN","text_ar":"خُضُوعٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"xaDoEN","text_ar":"خَضْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuDoEaAnN","text_ar":"خُضْعَانٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"xiDoEaAnN","text_ar":"خِضْعَانٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"(Msb, TA,) [for instance,] to his creditor, (Msb,) or to God; (TA;) as also ↓"},{"kind":"arabic","text_bw":"AxtDE","text_ar":"اختضع","orth_type":"arrow"},{"kind":"text","text":", (S, K,) [and ↓"},{"kind":"arabic","text_bw":"AnxDE","text_ar":"انخضع","orth_type":"arrow"},{"kind":"text","text":", (K in art."},{"kind":"arabic","text_bw":"x*A^","text_ar":"خذا"},{"kind":"text","text":",)] and ↓"},{"kind":"arabic","text_bw":"AixoDawoDaEa","text_ar":"اِخْضَوْضَعَ","orth_type":"arrow"},{"kind":"text","text":": (Sgh, K:)"},{"kind":"arabic","text_bw":"xuDuwEN","text_ar":"خُضُوعٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"nearly the same as"},{"kind":"arabic","text_bw":"xu$uwEN","text_ar":"خُشُوعٌ"},{"kind":"text","text":", except that the latter is mostly used in relation to the voice [or the eyes]; but the former is used as meaning"},{"kind":"italic_en","text":"in the necks:"},{"kind":"text","text":"(Msb:) or the former is"},{"kind":"italic_en","text":"in the body,"},{"kind":"text","text":"('Eyn and K in art."},{"kind":"arabic","text_bw":"x$E","text_ar":"خشع"},{"kind":"text","text":",) and signifies the acknowledgment of humility and submission; ('Eyn;) and the latter is in the voice and in the eyes. ('Eyn and K ubi suprà.) It is said in a trad. respecting the [devils'] hearing [the words of the angels] by stealth,"},{"kind":"arabic","text_bw":"xuDoEaAnFA liqawolihi","text_ar":"خُضْعَانًا لِقَوْلِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"With submissiveness to his saying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to what he said"},{"kind":"text","text":"]; or, accord. to one relation,"},{"kind":"arabic","text_bw":"xiDoEaAnFA","text_ar":"خِضْعَانًا"},{"kind":"text","text":"; but it may be a pl. of"},{"kind":"arabic","text_bw":"xaADiEN","text_ar":"خَاضِعٌ"},{"kind":"text","text":"; and accord. to another relation, it is"},{"kind":"arabic","text_bw":"xuD~aEFA","text_ar":"خُضَّعًا"},{"kind":"text","text":", which is a pl. of"},{"kind":"arabic","text_bw":"xaADiEN","text_ar":"خَاضِعٌ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and tractable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"italic_en","text":"He made his words soft"},{"kind":"text","text":"to a woman; as also ↓"},{"kind":"arabic","text_bw":"AxDE","text_ar":"اخضع","orth_type":"arrow"},{"kind":"text","text":": (L:) or the latter signifies"},{"kind":"italic_en","text":"his speech was soft"},{"kind":"text","text":"to a woman. (O, K.) It is said in the Kur [xxxiii. 32],"},{"kind":"arabic","text_bw":"falaA taxoDaEona","text_ar":"فَلَا تَخْضَعْنَ"},{"kind":"arabic","text_bw":"biAlqawoli","text_ar":"بِالقَوْلِ"},{"kind":"italic_en","text":"Then be ye not soft in speech."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"xaDaEa lahaA bikalaAmihi waxaDaEato lahu wataTam~aEa","text_ar":"خَضَعَ لَهَا بِكَلَامِهِ وَخَضَعَتْ لَهُ وَتَطَمَّعَ"},{"kind":"arabic","text_bw":"fiyhaA","text_ar":"فِيهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was soft to her in speech, and she was soft to him, and he became excited to feel an eager desire for her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to lust after her"},{"kind":"text","text":"]; (TA;) and in like manner, ↓"},{"kind":"arabic","text_bw":"xaADaEahA","text_ar":"خَاضَعَها","orth_type":"arrow"},{"kind":"text","text":", (K, * TA,) inf. n."},{"kind":"arabic","text_bw":"muxaADaEapN","text_ar":"مُخَاضَعَةٌ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"he was soft in his speech to her, she being soft in her speech to him."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xaDaEaA","text_ar":"خَضَعَا"},{"kind":"arabic","text_bw":"bayonahumaA HadiyvFA","text_ar":"بَيْنَهُمَا حَدِيثًا"},{"kind":"italic_en","text":"They two"},{"kind":"text","text":"(a man and a woman)"},{"kind":"italic_en","text":"made soft discourse together, saying that which excited each to feel an eager desire for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to lust after, the other."},{"kind":"text","text":"(TA from a trad.) ―         -b4-"},{"kind":"arabic","text_bw":"xaDaEa","text_ar":"خَضَعَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xaDoEN","text_ar":"خَضْعٌ"},{"kind":"text","text":", [or, as in two copies of the S,"},{"kind":"arabic","text_bw":"xaDaEN","text_ar":"خَضَعٌ"},{"kind":"text","text":", though it seems that the verb is correctly"},{"kind":"arabic","text_bw":"xaDaEa","text_ar":"خَضَعَ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"xaDiEa","text_ar":"خَضِعَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He had a natural stooping of the neck:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"he bent himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became bent;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AxDE","text_ar":"اخضع","orth_type":"arrow"},{"kind":"text","text":". (Zj.) And ↓"},{"kind":"arabic","text_bw":"AxtDE","text_ar":"اختضع","orth_type":"arrow"},{"kind":"text","text":", said of a hawk,"},{"kind":"italic_en","text":"He lowered his head to make a stoop,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to pounce down."},{"kind":"text","text":"(Z, TA.) ―         -b5-  [Hence,]"},{"kind":"arabic","text_bw":"xaDaEati","text_ar":"خَضَعَتِ"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The camels strove, or exerted themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastened, in their pace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going;"},{"kind":"text","text":"(K;) because, when they do so, they lower their necks. (TA.) And ↓"},{"kind":"arabic","text_bw":"AxtDE","text_ar":"اختضع","orth_type":"arrow"},{"kind":"text","text":", (K,) said of a horse, (IAar,) [for the same reason,] (assumed tropical:)"},{"kind":"italic_en","text":"He went quickly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swiftly."},{"kind":"text","text":"(IAar, K.) ―         -b6-"},{"kind":"arabic","text_bw":"xaDaEa Aln~ajomu","text_ar":"خَضَعَ النَّجْمُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The star,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asterism, inclined"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"to the place of setting,"},{"kind":"text","text":"(S, TA,) or"},{"kind":"italic_en","text":"to setting:"},{"kind":"text","text":"(K, TA:) and in like manner,"},{"kind":"arabic","text_bw":"xaDaEati Al$~amosu","text_ar":"خَضَعَتِ الشَّمْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"the sun inclined"},{"kind":"page_break","n":758},{"kind":"text","text":"&c.; like"},{"kind":"arabic","text_bw":"xadaEat","text_ar":"خَدَعَت"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"xaDaEato A^ayodiY","text_ar":"خَضَعَتْ اَيْدِى"},{"kind":"arabic","text_bw":"AlkawaAkibi","text_ar":"الكَوَاكِبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"the stars inclined to setting."},{"kind":"text","text":"(Aboo- 'Adnán, TA in art."},{"kind":"arabic","text_bw":"x$E","text_ar":"خشع"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"xaDaEahu","text_ar":"خَضَعَهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, rendered him still"},{"kind":"text","text":"(K, TA) ["},{"kind":"italic_en","text":"and submissive:"},{"kind":"text","text":"see 1]: the verb being both intrans. and trans. (TA.) [See also 4.] ―         -b2-  Also, (K,) inf. n."},{"kind":"arabic","text_bw":"xaDoEN","text_ar":"خَضْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuDuwEN","text_ar":"خُضُوعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, caused him to have a stooping neck;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AxDEhu","text_ar":"اخضعهُ","orth_type":"arrow"},{"kind":"text","text":"; (K;) i. e.,"},{"kind":"italic_en","text":"bent him:"},{"kind":"text","text":"(TA:) said of old age. (TK.) Jereer says,"},{"kind":"quote","text":"A^aEad~a A@ll~`hu lil$~uEaraA='i min~iY\n                      \n                     \n                        SawaAEiqa yaxoDaEuwna lahu Alr~iqaAbaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God hath prepared, for the poets, from me, thunderbolts which make the necks to stoop to Him"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xaDaEa fulaAnFA A_ilaY Als~awo'api","text_ar":"خَضَعَ فُلَانًا اـِلَى السَّوْءَةِ"},{"kind":"text","text":"; in the K"},{"kind":"arabic","text_bw":"AlY Als~uw'i","text_ar":"الى السُّوءِ"},{"kind":"text","text":", but the former is the right; inf. n."},{"kind":"arabic","text_bw":"xuDuwEN","text_ar":"خُضُوعٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, invited such a one to that which was foul, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","Msb","K","TA","Sgh","L","IAar"]}]}}