le":"present_2mp","form":"تَثِبُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَثِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَثِب","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَثِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَثِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَثِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَثِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَثِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَثِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَثِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَثِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَثِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَثِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"وَثَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَثَبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":36,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n41617"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%AB%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to jump, to leap"},{"pos":"verb","gloss":"to jump, to pounce"},{"pos":"verb","gloss":"to rush"},{"pos":"verb","gloss":"to rise, to stand up"},{"pos":"verb","gloss":"to sit","tags":["rare"]}]},"etymology":{"source":"wiktextract","text":"Compare with Hebrew י־שׁ־ב (y-š-v) and Assyrian Neo-Aramaic ܘ ܬ ܒ (w t b)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41617","headword_ar":"وَثَبَ","root":"wvb","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yavibu","text_ar":"يَثِبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wavobN","text_ar":"وَثْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wuvuwbN","text_ar":"وُثُوبٌ"},{"kind":"text","text":"(the latter agreeable with analogy, TA,) and"},{"kind":"arabic","text_bw":"wavabaAnN","text_ar":"وَثَبَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waviybN","text_ar":"وَثِيبٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"wivAabN","text_ar":"وِثاَبٌ"},{"kind":"text","text":"(K; but this is generally affirmed to be an inf. n. of"},{"kind":"arabic","text_bw":"waAvaba","text_ar":"وَاثَبَ"},{"kind":"text","text":", TA;) and"},{"kind":"arabic","text_bw":"vibapN","text_ar":"ثِبَةٌ"},{"kind":"text","text":", (Ibn-Málik and others)"},{"kind":"italic_en","text":"He leaped; jumped; sprang; bounded:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"he leaped down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"downwards."},{"kind":"text","text":"(Mgh, Msb, art."},{"kind":"arabic","text_bw":"Tfr","text_ar":"طفر"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"wavaba AlmawoDiEa","text_ar":"وَثَبَ المَوْضِعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jumped, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over the place"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"wavaba A_ilaY Al$~arafi wavobapF","text_ar":"وَثَبَ اـِلَى الشَّرَفِ وَثْبَةً"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He made a single leap to eminence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"wavaba A_ilayohi","text_ar":"وَثَبَ اـِلَيْهِ"},{"kind":"text","text":"[app.,"},{"kind":"italic_en","text":"He leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprang up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he hastened, to him"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Alwuvuwbu","text_ar":"الوُثُوبُ"},{"kind":"text","text":", except in the dial. of Himyer, signifies"},{"kind":"italic_en","text":"The act of rising,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"standing up."},{"kind":"text","text":"(TA.) ―         -b6-  It is also much used by the vulgar as signifying"},{"kind":"italic_en","text":"The act of hastening to a thing;"},{"kind":"text","text":"as observed by MF, who is wrong in saying that there is nothing in the lexicons that favours its being so used. (TA.)       -A2-"},{"kind":"arabic","text_bw":"wavaba","text_ar":"وَثَبَ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yavibu","text_ar":"يَثِبُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"wavobN","text_ar":"وَثْبٌ"},{"kind":"text","text":", in the dial. of Himyer signifies"},{"kind":"italic_en","text":"He sat; sat down."},{"kind":"text","text":"(K, TA, from a trad.)"},{"kind":"arabic","text_bw":"vibo","text_ar":"ثِبْ"},{"kind":"text","text":"in that dial. signifies"},{"kind":"italic_en","text":"Sit; sit down."},{"kind":"text","text":"(S.) It is related that Zeyd Ibn-Abd-Allah Ibn-Dárim came as an envoy to one of the kings of Himyer, and found him at a hunting-place belonging to him, on a high mountain, and he saluted him, and mentioned to him his lineage, or relationship; whereupon the king said to him"},{"kind":"arabic","text_bw":"vibo","text_ar":"ثِبْ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"A_ijoliso","text_ar":"اـِجْلِسْ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Sit;"},{"kind":"text","text":"but the man thought that he commanded him to leap from the mountain; and he said, “ Thou shalt find me, O king, very obedient: ” then he leaped from the mountain, and perished. So the king said, “ What ailed him? ” And they explained to him his case, and his mistake respecting the word: upon which he said"},{"kind":"arabic","text_bw":"layosato EinodanaA Earabiy~ato mano","text_ar":"لَيْسَتْ عِنْدَنَا عَرَبِيَّتْ مَنْ"},{"kind":"arabic","text_bw":"daxala ZafaAri Ham~ara","text_ar":"دَخَلَ ظَفَارِ حَمَّرَ"},{"kind":"text","text":"i. e., [“ Arabic is not current with us: ” (for, probably, in the time of this king, the term"},{"kind":"arabic","text_bw":"Earabiy~ap","text_ar":"عَرَبِيَّة"},{"kind":"text","text":"was only applied to the general language of Arabia:) “ whoso entereth Dhafári,] let him learn [or, rather, speak, as MF says,] the Himyeree language. ” (Mz., 16th"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":".) [The principal facts of this anecdote are also mentioned in the S, on the authority of As.] By the king's saying"},{"kind":"arabic","text_bw":"Earabiy~ato","text_ar":"عَرَبِيَّتْ"},{"kind":"text","text":"was meant"},{"kind":"arabic","text_bw":"AlEarabiy~apu","text_ar":"العَرَبِيَّةُ"},{"kind":"text","text":": the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is pronounced"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"in the case of a pause (which is the case here) in their dialect. (S.) Or, accord. to another relation of the above anecdote, the king said"},{"kind":"arabic","text_bw":"layosa EinodanaA Earabiy~ato kaEarabiy~atokumo","text_ar":"لَيْسَ عِنْدَنَا عَرَبِيَّتْ كَعَرَبِيَّتْكُمْ"},{"kind":"text","text":"[“ Arabic like"},{"kind":"page_break","n":2920},{"kind":"text","text":"your Arabic is not current with us: ”] and this, says ISd, is the right reading in my opinion: for the king did not mean to exclude himself from the Arabs. (MF.)"}],"source_refs":["S","K"]}]}}