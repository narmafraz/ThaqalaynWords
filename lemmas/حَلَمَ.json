{"lemma":"حَلَمَ","slug":"حَلَمَ","root":"ح.ل.م","root_slug":"ح-ل-م","root_link":"/words/roots/ح-ل-م","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَلَمْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَلَمْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَلَمْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَلَمْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَلَمْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَلَمَ","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَلَمَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَلَما","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَلَمَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَلَمُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَلَمْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْلُم","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْلُمِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْلُمِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْلُمانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْلُما","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْلُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْلُمُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْلُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْلُم","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْلُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْلُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْلُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْلُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْلُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْلُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْلُمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْلُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْلُم","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْلُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَلَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَلَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":true,"lemma_key":"حَلَمَ","root":"حلم","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":19},"lanes":{"found":true,"entry_ids":["n8927"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%84%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dream (something) or about [with بِ (bi)] (something) while asleep","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to dream (something) or about [with بِ (bi)] (something) while asleep; to muse, reflect, or meditate on [with بِ (bi)]; to vision, to image","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to experience the first seminal ejaculation; to mature physically or sexually; to attain puberty","tags":["intransitive"]},{"pos":"verb","gloss":"to experience the first seminal ejaculation; to become a legal adult or to be perceived as such","tags":["archaic","intransitive"]},{"pos":"verb","gloss":"to mature mentally or to be perceived as such; to act or think like an adult","tags":["intransitive"]},{"pos":"verb","gloss":"to be gentle, forgiving, merciful, or lenient; to be mild-mannered","tags":["intransitive"]},{"pos":"verb","gloss":"to restrain oneself or to be restrained or checked (especially emotionally and psychologically); to forbear, to refrain, to abstain, to withhold; to be long-suffering, to be patient or enduring; to mellow","tags":["intransitive"]},{"pos":"noun","gloss":"verbal noun of حَلَمَ (ḥalama) (form I): dreaming","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"a dream (something experienced during sleep); vision"},{"pos":"noun","gloss":"a wish, a desire, an aspiration; a daydream (something fantasised about or desired)"},{"pos":"noun","gloss":"utopia"},{"pos":"noun","gloss":"verbal noun of حَلَمَ (ḥalama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"sexual maturity; puberty","examples":[{"text":"وَإِذَا بَلَغَ ٱلْأَطْفَالُ مِنْكُمُ ٱلْحُلُمَ فَلْيَسْتَأْذِنُوا كَمَا ٱسْتَأْذَنَ ٱلَّذِينَ مِنْ قَبْلِهِمْ","english":"And if the children among you reach puberty, they shall ask for permission as those who did before them."}]},{"pos":"noun","gloss":"verbal noun of حَلُمَ (ḥaluma) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"mental, psychological, or comportmental maturity; prudence; rationality; discretion"},{"pos":"noun","gloss":"being long-suffering, self-restraint; forbearance, longanimity","examples":[{"text":"أَنْتَ أَكْثَرُ مِنِّي حِلْمًا.","english":"You are more patient than me."},{"text":"لَا يَغُرَّنَّكَ حِلْمِي فَصَبْرِي بَدَأَ يَنْفَدُ.","english":"Let not my forbearance deceive you, for my patience is running out."}]},{"pos":"noun","gloss":"tick(s), mite(s)","tags":["collective"]},{"pos":"noun","gloss":"nipple(s), teat(s)","tags":["collective"]},{"pos":"noun","gloss":"callous-leaved gromwell (Moltkiopsis ciliata)","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"Akin to Aramaic חֶלְמָא (ḥelmā), Classical Syriac ܚܠܡܐ (ḥelmā), Hebrew חֲלוֹם (ḥalóm), Amharic ሕልም (ḥəlm), Ugaritic 𐎈𐎍𐎎 (ḥlm). For the significations of the root in Arabic, compare م ن ي (m n y), whence أُمْنِيَة (ʔumniya, “a wish”) and مَنِيّ (maniyy, “a fluid considered conceptive; semen”)."},"ipa":["/ħulm/","/ħu.lum/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8927","headword_ar":"حَلَمَ","root":"Hlm","body":[{"kind":"text","text":", (S, Msb, K, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"Haluma","text_ar":"حَلُمَ"},{"kind":"text","text":",]) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HulomN","text_ar":"حُلْمٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"HulumN","text_ar":"حُلُمٌ"},{"kind":"text","text":", of which the former is a contraction, (Msb,) [both used also as simple substs.,]"},{"kind":"italic_en","text":"He dreamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw a dream"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vision"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"arabic","text_bw":"fiY nawomihi","text_ar":"فِى نَوْمِهِ"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"in his sleep;"},{"kind":"text","text":"(S, * Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AHtlm","text_ar":"احتلم","orth_type":"arrow"},{"kind":"text","text":"(S, ISd, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"AnHlm","text_ar":"انحلم","orth_type":"arrow"},{"kind":"text","text":", (ISd, K,) and ↓"},{"kind":"arabic","text_bw":"tHl~m","text_ar":"تحلّم","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Halama bihi","text_ar":"حَلَمَ بِهِ"},{"kind":"text","text":", (S, K, [in the CK, again, erroneously,"},{"kind":"arabic","text_bw":"Haluma","text_ar":"حَلُمَ"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", (K,)"},{"kind":"page_break","n":632},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHl~m","text_ar":"تحلّم","orth_type":"arrow"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"Halamahu","text_ar":"حَلَمَهُ"},{"kind":"text","text":"also, (S,)"},{"kind":"italic_en","text":"He dreamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw a dream"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vision, of it:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"he saw it in sleep."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"Halama","text_ar":"حَلَمَ"},{"kind":"arabic","text_bw":"biAlmaroA^api","text_ar":"بِالمَرْاَةِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"dreamed in his sleep that he was compressing the woman."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HulomN","text_ar":"حُلْمٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AiHotilaAmN","text_ar":"اِحْتِلَامٌ","orth_type":"arrow"},{"kind":"text","text":"signify [The"},{"kind":"italic_en","text":"dreaming of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"copulation in sleep:"},{"kind":"text","text":"(K:) and the verbs are"},{"kind":"arabic","text_bw":"Halama","text_ar":"حَلَمَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHtlm","text_ar":"احتلم","orth_type":"arrow"},{"kind":"text","text":". (TA.) And [hence,] both signify The"},{"kind":"italic_en","text":"experiencing an emission of the seminal fluid;"},{"kind":"text","text":"properly,"},{"kind":"italic_en","text":"in dreaming;"},{"kind":"text","text":"and tropically if meaning,"},{"kind":"italic_en","text":"without dreaming, whether awake or in sleep,"},{"kind":"text","text":"or by extension of the signification. (TA.) And hence, (Mgh,)"},{"kind":"arabic","text_bw":"Halama","text_ar":"حَلَمَ"},{"kind":"text","text":", (Mgh, Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HulomN","text_ar":"حُلْمٌ"},{"kind":"text","text":"; (Mgh;) and ↓"},{"kind":"arabic","text_bw":"AHtlm","text_ar":"احتلم","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a boy)"},{"kind":"italic_en","text":"attained to puberty,"},{"kind":"text","text":"(Msb,) [or]"},{"kind":"italic_en","text":"to virility."},{"kind":"text","text":"(Mgh, Msb.)       -A2-"},{"kind":"arabic","text_bw":"Haluma","text_ar":"حَلُمَ"},{"kind":"text","text":", with damm [to the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"HilomN","text_ar":"حِلْمٌ"},{"kind":"text","text":", (S, Msb, K,) ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, forbearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clement;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he forgave and concealed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"offences"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, moderate, gentle, deliberate, leisurely in his manner of proceeding"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of deportment &c., patient"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"contr. of hasty, grave, staid, sedate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm;"},{"kind":"text","text":"(S, K;) and (assumed tropical:)"},{"kind":"italic_en","text":"intelligent:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he managed his soul and temper on the occasion of excitement of anger."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"HilomN","text_ar":"حِلْمٌ"},{"kind":"text","text":"below.] You say,"},{"kind":"arabic","text_bw":"Haloma Eanohu","text_ar":"حَلْمَ عَنْهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tHl~m","text_ar":"تحلّم","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He treated him with forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency, &c."},{"kind":"text","text":"]: both signify the same. (TA.) And"},{"kind":"arabic","text_bw":"yaHolumu Eam~ano yasub~uhu","text_ar":"يَحْلُمُ عَمَّنْ يَسُبُّهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He treats with forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"him who reviles him"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"Hml","text_ar":"حمل"},{"kind":"text","text":".)       -A3-"},{"kind":"arabic","text_bw":"Halima","text_ar":"حَلِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HalamN","text_ar":"حَلَمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"many ticks, such as are termed"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"text","text":". (K.) ―         -b2-  Also the same verb, (S, K,) with the same inf. n., (S,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a hide, or skin,)"},{"kind":"italic_en","text":"had in it worms, such as are termed"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"text","text":", (S, K, TA,)"},{"kind":"italic_en","text":"whereby it was spoilt and perforated,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"so that it became useless."},{"kind":"text","text":"(TA.) A poet says, (S,) namely, El-Weleed Ibn-'Okbeh, TA,)"},{"kind":"quote","text":"faA_in~aka waAlkitaAba A_ilaY EaliY~K\n                      \n                     \n                        ka*aAbigapK waqado Halima AlA^adiymu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"For verily thou, as to the letter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"writing, to 'Alee, art like a woman tanning when the hide has become spoilt and perforated by worms"},{"kind":"text","text":"]: (S, TA:) he was urging Mo'áwiyeh to contend in battle with 'Alee, [as though] saying to him, Thou labourest to rectify a matter that has become completely corrupt, like this woman who tans the hide that has become perforated and spoilt by the"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"text","text":". (TA.) [The latter hemistich of this verse is a prov.: see Freytag's Arab. Prov. ii. 346.]       -A4-"},{"kind":"arabic","text_bw":"Halamahu","text_ar":"حَلَمَهُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HalomN","text_ar":"حَلْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He plucked the"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"italic_en","text":"from it;"},{"kind":"text","text":"[app., accord. to the K, the worms thus called from a hide, or skin;] as also ↓"},{"kind":"arabic","text_bw":"Hl~mhu","text_ar":"حلّمهُ","orth_type":"arrow"},{"kind":"text","text":": (K:) or, accord. to Az,"},{"kind":"italic_en","text":"he took from him,"},{"kind":"text","text":"namely, a camel,"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ticks called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb","TA","S","K","ISd","Mgh"]}]}}