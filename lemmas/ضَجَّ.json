],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n25537"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be noisy, to be boisterous","tags":["intransitive"]},{"pos":"verb","gloss":"to cause an uproar","tags":["intransitive"]},{"pos":"verb","gloss":"to raise a hue and cry","tags":["intransitive"]},{"pos":"verb","gloss":"to make a noise","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25537","headword_ar":"ضَجَّ","root":"Dj","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":"(L, Msb, TA) and"},{"kind":"arabic","text_bw":"Daj~N","text_ar":"ضَجٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DajaAjN","text_ar":"ضَجَاجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DujaAjN","text_ar":"ضُجَاجٌ"},{"kind":"text","text":", the last on the authority of Lh, (L, TA,) [and the last but one is said in one place in the L and TA to be a subst. from"},{"kind":"arabic","text_bw":"DaAj~ahu","text_ar":"ضَاجَّهُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, calling for aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour:"},{"kind":"text","text":"(AA:) or"},{"kind":"italic_en","text":"he cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, and raised a clamour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises, being frightened at a thing:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"crying out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferating, on the occasion of some disagreeable occurrence, and in difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress, and inability to bear"},{"kind":"italic_en","text":"what has befallen one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impatience:"},{"kind":"text","text":"(Kitáb el-Ghareebeyn:) or ↓"},{"kind":"arabic","text_bw":"A^aDaj~uwA","text_ar":"اَضَجُّوا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iDojaAjN","text_ar":"اـِضْجَاجٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"they cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, and raised a clamour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Daj~uwA","text_ar":"ضَجُّوا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":", [as meaning"},{"kind":"italic_en","text":"they did so"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when unable to bear a thing that had befallen them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impatient, and overcome,"},{"kind":"text","text":"(A'Obeyd, S, K, TA,)"},{"kind":"italic_en","text":"and frightened."},{"kind":"text","text":"(TA.) And one says also,"},{"kind":"arabic","text_bw":"Daj~a","text_ar":"ضَجَّ"},{"kind":"arabic","text_bw":"AlbaEiyru","text_ar":"البَعِيرُ"},{"kind":"text","text":", (A, L,) inf. n."},{"kind":"arabic","text_bw":"DjiyjN","text_ar":"ضجِيجٌ"},{"kind":"text","text":", (L,) ["},{"kind":"italic_en","text":"The camel uttered a cry,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"grumbled,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"mina AlHimoli","text_ar":"مِنَ الحِمْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in consequence of the load"},{"kind":"text","text":"]. (A. [See 1 in art."},{"kind":"arabic","text_bw":"rgw","text_ar":"رغو"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"A_ino Daj~a fazidohu wiqorFA","text_ar":"اـِنْ ضَجَّ فَزِدْهُ وِقْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If he grumble, add to him a load"},{"kind":"text","text":"]: a prov. (A.) The poet El-Kanánee uses the phrase"},{"kind":"arabic","text_bw":"faDaj~aD~aj~apF","text_ar":"فَضَجَّضَّجَّةً"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"faDaj~ato Daj~apF","text_ar":"فَضَجَّتْ ضَجَّةً"},{"kind":"text","text":"; and it is cited by Sb as an ex. of the incorporation of"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":". (O.)"}],"source_refs":["L","Msb","TA","AA","A"]}]},"classical_definitions":null}