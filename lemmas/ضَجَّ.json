"role":"present_2mp","form":"تَضِجُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَضِجُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضْجِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضِجّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَضْجِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضِجّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَضْجِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضِجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضِجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضِجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضِجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضِجُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضِجُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضْجِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَضِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ضَجَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَجَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n25537"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be noisy, to be boisterous","tags":["intransitive"]},{"pos":"verb","gloss":"to cause an uproar","tags":["intransitive"]},{"pos":"verb","gloss":"to raise a hue and cry","tags":["intransitive"]},{"pos":"verb","gloss":"to make a noise","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25537","headword_ar":"ضَجَّ","root":"Dj","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":"(L, Msb, TA) and"},{"kind":"arabic","text_bw":"Daj~N","text_ar":"ضَجٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DajaAjN","text_ar":"ضَجَاجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DujaAjN","text_ar":"ضُجَاجٌ"},{"kind":"text","text":", the last on the authority of Lh, (L, TA,) [and the last but one is said in one place in the L and TA to be a subst. from"},{"kind":"arabic","text_bw":"DaAj~ahu","text_ar":"ضَاجَّهُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, calling for aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour:"},{"kind":"text","text":"(AA:) or"},{"kind":"italic_en","text":"he cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, and raised a clamour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises, being frightened at a thing:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"crying out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferating, on the occasion of some disagreeable occurrence, and in difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress, and inability to bear"},{"kind":"italic_en","text":"what has befallen one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impatience:"},{"kind":"text","text":"(Kitáb el-Ghareebeyn:) or ↓"},{"kind":"arabic","text_bw":"A^aDaj~uwA","text_ar":"اَضَجُّوا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iDojaAjN","text_ar":"اـِضْجَاجٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"they cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated, and raised a clamour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Daj~uwA","text_ar":"ضَجُّوا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"DajiyjN","text_ar":"ضَجِيجٌ"},{"kind":"text","text":", [as meaning"},{"kind":"italic_en","text":"they did so"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when unable to bear a thing that had befallen them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impatient, and overcome,"},{"kind":"text","text":"(A'Obeyd, S, K, TA,)"},{"kind":"italic_en","text":"and frightened."},{"kind":"text","text":"(TA.) And one says also,"},{"kind":"arabic","text_bw":"Daj~a","text_ar":"ضَجَّ"},{"kind":"arabic","text_bw":"AlbaEiyru","text_ar":"البَعِيرُ"},{"kind":"text","text":", (A, L,) inf. n."},{"kind":"arabic","text_bw":"DjiyjN","text_ar":"ضجِيجٌ"},{"kind":"text","text":", (L,) ["},{"kind":"italic_en","text":"The camel uttered a cry,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"grumbled,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"mina AlHimoli","text_ar":"مِنَ الحِمْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in consequence of the load"},{"kind":"text","text":"]. (A. [See 1 in art."},{"kind":"arabic","text_bw":"rgw","text_ar":"رغو"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"A_ino Daj~a fazidohu wiqorFA","text_ar":"اـِنْ ضَجَّ فَزِدْهُ وِقْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If he grumble, add to him a load"},{"kind":"text","text":"]: a prov. (A.) The poet El-Kanánee uses the phrase"},{"kind":"arabic","text_bw":"faDaj~aD~aj~apF","text_ar":"فَضَجَّضَّجَّةً"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"faDaj~ato Daj~apF","text_ar":"فَضَجَّتْ ضَجَّةً"},{"kind":"text","text":"; and it is cited by Sb as an ex. of the incorporation of"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":". (O.)"}],"source_refs":["L","Msb","TA","AA","A"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D8%AC/","headword_ar":"ضج","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10568#77c543","body_html":"ضج<br>ضَجَّ الرجُلُ يَضِجُّ ضَجّاً وضَجَاجاً وضَجِيْجاً وضَجَجاً: من الصِّيَاح، وكذلك البَعِيْرُ. وأضَجَّ القَوْمُ: صاحُوا. وفي المَثَل: \" إنْ ضَجَّ فَزِدْهُ وَقْراً \".<br>والتَّضْجِيْجُ: الذَّهَابُ، ضَجَّجَ تَضْجِيْجاً. وقيل ضَجَّجَ: مالَ. والضَّجَاجُ: ضَرْبٌ من الخَرَز. وماءٌ مِلْحٌ شَدِيدُ المُلُوحَة."},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10568#329e85","body_html":"<span class=\"title1\">باب الجيم مع الضاد ض ج، ج ض مستعملان</span><br><br><span>ضج: يقال: هو ضَجيجُ البَعير، وضَجاجُ القَومِ وهو لجَبُهم، وقد ضج</span><span> </span><a></a><span>يضج ضَجَاً، قال العجاج:</span><br><br><span>وأغشَتَ الناسُ الضَّجاجَ الأَضجَجا </span><br><br><span>أظهر التَّضعيف.</span><br><br><span>جض: جَضَّ عن الشَّيء أي حادَ عنه، وجاضَ مِثلهُ.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10568#b02e42","body_html":"<h3>ضج</h3><span class=\"sense\">1</span> ضَجَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> ضَجِيجٌ (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) and ضَجٌّ and ضَجَاجٌ and ضُجَاجٌ, the last on the authority of <abbr title=\"El-Lihyanee (Abu al-Ḥasan al-Liḥyānī)\">Lh</abbr>, (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) [and the last but one is said in one place in the <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> to be a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr> from ضَاجَّهُ,] He cried out, or vociferated: (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>:) or he cried out, or vociferated, calling for aid, or succour: (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>:) or he cried out, or vociferated, and raised a clamour, or confused cries or shouts or noises, being frightened at a thing: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) or ضَجِيجٌ signifies the crying out, or vociferating, on the occasion of some disagreeable occurrence, and in difficulty, or distress, and inability to bear what has befallen one, or impatience: (Kitáb el-Ghareebeyn:) or ↓ أَضَجُّوا, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> إِضْجَاجٌ, signifies they cried out, or vociferated, and raised a clamour, or confused cries or shouts or noises: and ضَجُّوا, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> ضَجِيجٌ, [as meaning they did so] when unable to bear a thing that had befallen them, or impatient, and overcome, (<abbr title=\"Abu ʿUbayd (al-Qāsim bin Salām)\">A'Obeyd</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and frightened. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And one says also, ضَجَّ البَعِيرُ, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> ضجِيجٌ, (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>,) [The camel uttered a cry, i. e. grumbled,] مِنَ الحِمْلِ [in consequence of the load]. (A. [See 1 in art. رغو.]) And إِنْ ضَجَّ فَزِدْهُ وِقْرًا [If he grumble, add to him a load]: a <abbr title=\"proverb, مَثَلٌ\">prov.</abbr> (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) The poet El-Kanánee uses the phrase فَضَجَّضَّجَّةً for فَضَجَّتْ ضَجَّةً; and it is cited by <abbr title=\"Sibawayh\">Sb</abbr> as an <abbr title=\"example\">ex.</abbr> of the incorporation of ت into ض. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>.) 2 ضجّج, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَضْجِيجٌ, He went away: or he inclined, or declined. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">A2:</span> And He poisoned a bird, or a beast of prey. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 3 ضاجّهُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مُضَاجَّةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and ضِجَاجٌ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) He acted with him in an evil manner; treated him with enmity, or hostility; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) and contended in altercation with him. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 4 أَضْجَ3َ see 1.<br><br><span class=\"sub-sense\">A2:</span> [Reiske, as mentioned by Freytag, explains اضجّ also as a <abbr title=\"transitive, مَتَعَدٌّ and وَاقِعٌ\">trans.</abbr> verb, meaning “ Fatigavit, molestia affecit. ”]<br><br>ضَجَّةٌ, a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>, signifying A crying out, or vociferating: (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>:) or a clamour, or confusion of cries or shouts or noises, of a people or party. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) ضَجَاجٌ a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr> from ضَاجَّهُ; [as such signifying Evil, or inimical, conduct; and contention:] (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) [and] compulsion. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> [Also] an <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of 1, sometimes used as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr>, [meaning That cries out, or vociferates, &amp;c.,] applied to a man: <abbr title=\"plural, جَمْعٌ\">pl.</abbr> ضُجُجٌ. (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.) [Freytag explains it, from the Deewán of Jereer, as meaning “ Vanus, nefas. ”]<br><br><span class=\"sub-sense\">A2:</span> Also <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> عَاجٌ [as meaning A kind of bracelet]; (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) which is like the سِوَار of a woman. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> And A kind of bead (خَرَزَةٌ), (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) used by women in their attracting [of men]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> See also the next paragraph.<br><br>ضِجَاجٌ A certain gum which is eaten (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) in its moist state: when it has become dry, it is pounded, then formed into lumps, and made potent with potash, and one washed with it the garment, or piece of cloth, which it cleanses like soap. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And The fruit of a certain plant; or a gum; with which women wash their heads: written by <abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr> with fet-h [i. e. ↓ ضَجَاجٌ], but by <abbr title=\"Abū Ḥanīfah al-Dīnawarī, author of the Book of Plants\">AHn</abbr> with kesr. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> And (as <abbr title=\"Abū Ḥanīfah al-Dīnawarī, author of the Book of Plants\">AHn</abbr> says in one place, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) Any tree with which birds, or beasts of prey, are poisoned. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) ضَجُوجٌ A she-camel that cries out when being milked, and is impatient. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) ضَجَاجٌ أَضَجُّ, and, by poetic license أَضْجَجُ, [meaning Very evil or inimical conduct &amp;c.,] is a phrase like شِعْرٌ شَاعِرٌ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"}]}}