orm": "رَكَدْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "رَكَدْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 4, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 1}, "lanes": {"found": true, "entry_ids": ["n16483"], "search_url": "https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%83%D9%8E%D8%AF%D9%8E"}}, "translations": {"en": "to stagnate", "fa": "سکون گرفتن", "ur": "سکون پانا", "tr": "durgunlaşmak", "id": "mengendap", "bn": "স্থির হওয়া", "es": "estancarse", "fr": "stagner", "de": "stagnieren", "ru": "застаиваться", "zh": "停滞"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to stagnate, quiet down, calm down"}]}, "etymology": null, "ipa": ["/ra.ka.da/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n16483", "headword_ar": "رَكَدَ", "root": "rkd", "body": [{"kind": "text", "text": ", (S, A, Msb,) aor."}, {"kind": "text", "text": ", (Msb,) inf. n."}, {"kind": "arabic", "text_bw": "rukuwdN", "text_ar": "رُكُودٌ"}, {"kind": "text", "text": ", (S Msb, K,)"}, {"kind": "italic_en", "text": "It was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, still,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "motionless;"}, {"kind": "text", "text": "(S, A, Msb, K;) said of water: (S, A, Msb:) and"}, {"kind": "italic_en", "text": "fixed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stationary."}, {"kind": "text", "text": "(K.) And in like manner, using the verb in the former sense, one says of the wind: (S, A:) [whence] one says also,"}, {"kind": "arabic", "text_bw": "rakudato riyHuhumo", "text_ar": "رَكُدَتْ رِيحُهُمْ"}, {"kind": "text", "text": "[lit."}, {"kind": "italic_en", "text": "Their wind became still,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "calm"}, {"kind": "text", "text": "] meaning (tropical:)"}, {"kind": "italic_en", "text": "their good fortune ceased, and their affairs,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "circumstances, began to retrograde by degrees:"}, {"kind": "text", "text": "and [in like manner,] ↓"}, {"kind": "arabic", "text_bw": "Tafiqato riyHuhumo tataraAkadu", "text_ar": "طَفِقَتْ رِيحُهُمْ تَتَرَاكَدُ", "orth_type": "arrow"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "their good fortune began to cease by degrees"}, {"kind": "text", "text": "]. (A.) So too one says of the expressed juice of grapes, meaning"}, {"kind": "italic_en", "text": "It ceased to estuate."}, {"kind": "text", "text": "(L.) And of the heat, i. e."}, {"kind": "italic_en", "text": "It remitted,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "subsided."}, {"kind": "text", "text": "(L. [See also"}, {"kind": "arabic", "text_bw": "raqada", "text_ar": "رَقَدَ"}, {"kind": "text", "text": ".]) And"}, {"kind": "arabic", "text_bw": "rakadati Als~afiynapu", "text_ar": "رَكَدَتِ السَّفِينَةُ"}, {"kind": "italic_en", "text": "The ship became still,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "motionless,"}, {"kind": "text", "text": "(S, * A, * Msb, TA,) or"}, {"kind": "italic_en", "text": "aground."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "rakada AlmiyzaAnu", "text_ar": "رَكَدَ المِيزَانُ"}, {"kind": "italic_en", "text": "The balance was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, in a state of equilibrium."}, {"kind": "text", "text": "(S, A, K.) And"}, {"kind": "arabic", "text_bw": "rakadati Albakorapu", "text_ar": "رَكَدَتِ البَكْرَةُ"}, {"kind": "italic_en", "text": "The sheave of the pulley was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, fixed:"}, {"kind": "text", "text": "and also"}, {"kind": "italic_en", "text": "the sheave of the pulley turned,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "revolved:"}, {"kind": "text", "text": "thus bearing two contr. significations. (L.) And"}, {"kind": "arabic", "text_bw": "rakadati Al$~amosu", "text_ar": "رَكَدَتِ الشَّمْسُ"}, {"kind": "italic_en", "text": "The sun was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, at its midday-height:"}, {"kind": "text", "text": "(S:) or"}, {"kind": "italic_en", "text": "continued overhead; as though not quitting its place."}, {"kind": "text", "text": "(A.) And"}, {"kind": "arabic", "text_bw": "rakada Alqawomu", "text_ar": "رَكَدَ القَوْمُ"}, {"kind": "italic_en", "text": "The people were,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, still, motionless,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "silent."}, {"kind": "text", "text": "(S, A.)"}], "source_refs": ["S", "A", "Msb"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}