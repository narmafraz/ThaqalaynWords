{"lemma":"مُسْتَمِرِّي","slug":"مُسْتَمِرِّي","root":"م.ر.ر","root_slug":"م-ر-ر","root_link":"/words/roots/م-ر-ر","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُسْتَمِرّ","root":"مرر","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n38390"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B3%D9%92%D8%AA%D9%8E%D9%85%D9%90%D8%B1%D9%90%D9%91%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"lasting, permanent, enduring"},{"pos":"adj","gloss":"unbroken, continuous"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of اِسْتَمَرَّ (istamarra, “to endure”), from the root م ر ر (m r r); compare مَرَّ (marra, “to pass”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38390","headword_ar":"مُسْتَمِرٌّ","root":"mr","body":[{"kind":"text","text":"act. part. n. of 10, q. v. ―         -b2-"},{"kind":"arabic","text_bw":"EaAdapN musotamir~apN","text_ar":"عَادَةٌ مُسْتَمِرَّةٌ"},{"kind":"italic_en","text":"A custom constantly obtaining; unvarying."},{"kind":"text","text":"(A, Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"siHorN musotamir~N","text_ar":"سِحْرٌ مُسْتَمِرٌّ"},{"kind":"text","text":"[in the Kur, liv. 2,]"},{"kind":"italic_en","text":"En-chantment going on:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having one continuous course:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuing in the same manner:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuing in a regular, uniform,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, course:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"passing away, and vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ineffectual:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"strong:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"bitter."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"fiY yawomi naHosK musotamir~K","text_ar":"فِى يَوْمِ نَحْسٍ مُسْتَمِرٍّ"},{"kind":"text","text":"[in the Kur, liv. 19,]"},{"kind":"italic_en","text":"In a day of ill fortune that was lasting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continual:"},{"kind":"text","text":"(Zj, K:) or"},{"kind":"italic_en","text":"of which the evil,"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"ill luck,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"was continual;"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"effective,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"with respect to that which it was ordered and constrained to accomplish:"},{"kind":"text","text":"(K:) or (assumed tropical:)"},{"kind":"italic_en","text":"potent in its evil fortune:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bitter:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a Wednesday that did not come round again in the month:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"in the last Wednesday of the month of Safar."},{"kind":"text","text":"(TA.)"}],"source_refs":["Mgh","K","Zj","TA"]}]},"classical_definitions":null}