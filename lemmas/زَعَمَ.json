{"lemma":"زَعَمَ","slug":"زَعَمَ","root":"ز.ع.م","root_slug":"ز-ع-م","root_link":"/words/roots/ز-ع-م","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"زَعَمْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"زَعَمْتِ","in_corpus":true,"count":9,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"زَعَمْتُما","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"زَعَمْتُم","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"زَعَمْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"زَعَمَ","in_corpus":true,"count":68,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"زَعَمَت","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"زَعَما","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"زَعَمَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"زَعَمُوا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"زَعَمْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَزْعُم","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَزْعُمِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَزْعُمِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَزْعُمانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَزْعُما","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَزْعُمُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَزْعُمُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَزْعُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَزْعُم","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَزْعُم","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَزْعُمانِ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَزْعُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَزْعُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَزْعُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَزْعُمُونَ","in_corpus":true,"count":26,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَزْعُمُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَزْعُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"زَعَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زَعَمْتُ","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَزْعُم","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَزْعُم","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":173,"cross_references":{"qac":{"found":true,"lemma_key":"زَعَمَ","root":"زعم","pos":"V","occurrence_count":13},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n17795"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%B9%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to claim"},{"pos":"verb","gloss":"to say, pretend, assert"},{"pos":"verb","gloss":"to be of the opinion"},{"pos":"verb","gloss":"to talk over, give one's opinion on (a subject)"},{"pos":"verb","gloss":"to impart one's opinion to another (construed with two direct objects)"},{"pos":"noun","gloss":"verbal noun of زَعَمَ (zaʕama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of زَعَمَ (zaʕama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of زَعَمَ (zaʕama) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17795","headword_ar":"زَعَمَ","root":"zEm","body":[{"kind":"text","text":", (S, Msb,) aor."},{"kind":"text","text":", (Msb, MS, JM, [not mentioned in the S nor in the K, app. because well known,]) inf. n."},{"kind":"arabic","text_bw":"zaEomN","text_ar":"زَعْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zuEomN","text_ar":"زُعْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zEomN","text_ar":"زعْمٌ"},{"kind":"text","text":", (S, Msb, K,) the first of the dial. of El-Hijáz, (Msb, TA,) the second of the dial. of [the tribe of] Asad, (Msb,) or Benoo-Temeem, (TA,) and the third of the dial. of some of [the tribe of] Keys; (Msb;) [generally best rendered"},{"kind":"italic_en","text":"He asserted;"},{"kind":"text","text":"for it mostly relates to a thing not certainly known: or]"},{"kind":"italic_en","text":"he said;"},{"kind":"text","text":"(S, Msb, K;) as in the phrases"},{"kind":"arabic","text_bw":"zaEamati","text_ar":"زَعَمَتِ"},{"kind":"arabic","text_bw":"AlHanafiy~apN","text_ar":"الحَنَفِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The Hanafees said"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have said"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted,"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"zaEama siybawayohi","text_ar":"زَعَمَ سِيبَوَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Seebaweyh said"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has said"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted"},{"kind":"text","text":"]; (Msb;) [and"},{"kind":"arabic","text_bw":"zaEama A^an~ahu ka*aA","text_ar":"زَعَمَ اَنَّهُ كَذَا"},{"kind":"italic_en","text":"He said,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted, that it was thus;"},{"kind":"text","text":"] either truly or falsely: (K:) mostly used in relation to a thing respecting which there is doubt, (Sh, Az, Msb, K,) and which is not certainly known: (Sh, Az, Msb:) or it is mostly used in relation to that which is false, or that respecting which there is doubt, or suspicion: (El-Marzookee, Msb:) or, as those skilled in the language of the Arabs say, in relation to a thing of which the speaker doubts, and does not know whether it may not be false: (Lth:) or"},{"kind":"arabic","text_bw":"zaEama zaEomFA","text_ar":"زَعَمَ زَعْمًا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he related a piece of information not knowing whether it were true or false."},{"kind":"text","text":"(IKoot, Msb.) Hence the saying,"},{"kind":"arabic","text_bw":"zaEama maTiy~apu Alka*ibi","text_ar":"زَعَمَ مَطِيَّةُ الكَذِبِ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"arabic","text_bw":"zaEama","text_ar":"زَعَمَ"},{"kind":"italic_en","text":"is the conveyer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehicle,"},{"kind":"text","text":"(properly"},{"kind":"italic_en","text":"the camel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beast, that serves as the conveyer,"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of lying"},{"kind":"text","text":"]. (Msb.) It is said in a trad.,"},{"kind":"arabic","text_bw":"biy^osa maTiy~apu Alr~ajuli zaEamuwA","text_ar":"بِيْسَ مَطِيَّةُ الرَّجُلِ زَعَمُوا"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"Very evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bad, is the man's conveyer"},{"kind":"arabic","text_bw":"zaEamuwA","text_ar":"زَعَمُوا"},{"kind":"text","text":"]: i. e., when a man desires to journey to a country, or town, he mounts his camel, or beast, that serves to convey him, and journeys until he accomplishes the object of his want: therefore, that with which the speaker prefaces his speech, and by means of which he attains the object of his desire, when he says"},{"kind":"arabic","text_bw":"zaEamuwA ka*aA waka*aA","text_ar":"زَعَمُوا كَذَا وَكَذَا"},{"kind":"text","text":", is likened to the camel, or beast, by means of which he attains the object of want: for"},{"kind":"arabic","text_bw":"zaEamuwA","text_ar":"زَعَمُوا"},{"kind":"text","text":"is [generally] said only in the case of a narration that has no authority whereon to rest, and that contains no proof. (TA.) IKh says that"},{"kind":"arabic","text_bw":"Alz~aEomu","text_ar":"الزَّعْمُ"},{"kind":"text","text":"is used in relation to that which is discommended; and that its primary signification is said by some of the expositors of the Kur-án to be The act of"},{"kind":"italic_en","text":"lying:"},{"kind":"text","text":"(TA: [this signification is also given in the K, as being contr. to the first:]) some say that it is metonymically used in this sense: (Msb:) and it is expl. as having this meaning in the Kur [vi. 137], where it is said,"},{"kind":"arabic","text_bw":"faqaAluwA h`*aA lil~`hi bizaEomihimo","text_ar":"فَقَالُوا هٰذَا لِلّٰهِ بِزَعْمِهِمْ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"And they have said,"},{"kind":"text","text":"“"},{"kind":"italic_en","text":"This"},{"kind":"text","text":"belongeth"},{"kind":"italic_en","text":"unto God,"},{"kind":"text","text":"”]"},{"kind":"italic_en","text":"with their lying."},{"kind":"text","text":"(Lth, TA.) ―         -b2-  [Sometimes]"},{"kind":"arabic","text_bw":"zaEamahu","text_ar":"زَعَمَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He described him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Har p. 204.) ―         -b3-  And sometimes"},{"kind":"arabic","text_bw":"zaEama","text_ar":"زَعَمَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He promised:"},{"kind":"text","text":"whence the saying of ' Amr Ibn-Sha-s,"},{"kind":"quote","text":"taquwlu halakonaA A_ino halakota waA_in~amaA\n                      \n                     \n                        EalaYA@ll~`hu A^arozaAqu AlEibaAdi kamaA zaEamo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou sayest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she says,"},{"kind":"text","text":"“"},{"kind":"italic_en","text":"We perish if thou perish:"},{"kind":"text","text":"”"},{"kind":"italic_en","text":"but verily upon God lie the means of subsistence of mankind,"},{"kind":"text","text":"i. e. it lies upon Him to supply these,"},{"kind":"italic_en","text":"as He has promised"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Alz~aEomu","text_ar":"الزَّعْمُ"},{"kind":"text","text":"is used also in the sense of"},{"kind":"arabic","text_bw":"AlZ~an~u","text_ar":"الظَّنُّ"},{"kind":"text","text":": (Msb, TA:) one says,"},{"kind":"arabic","text_bw":"fiY zaEomiY ka*aA","text_ar":"فِى زَعْمِى كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In my opinion"},{"kind":"text","text":"it is"},{"kind":"italic_en","text":"thus"},{"kind":"text","text":"]. (Msb.) [Hence, likewise,]"},{"kind":"arabic","text_bw":"zaEamotaniY","text_ar":"زَعَمْتَنِى"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"tazoEumuniY","text_ar":"تَزْعُمُنِى"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"Thou thoughtest me to be thus."},{"kind":"text","text":"(K, TA.) Aboo-Dhu-eyb says,"},{"kind":"quote","text":"faA_ino tuzoEumiyniY kunotu A^ajohalu fiykumu\n                      \n                     \n                        faA_in~iY $arayotu AlHiloma baEodaki biAljaholi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And if thou think me"},{"kind":"text","text":"such"},{"kind":"italic_en","text":"that I used to be ignorant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to act ignorantly, among you,"},{"kind":"text","text":"know"},{"kind":"page_break","n":1233},{"kind":"text","text":"that"},{"kind":"italic_en","text":"I have purchased intelligence since I was with thee"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"baEodaki","text_ar":"بَعْدَكِ"},{"kind":"text","text":"being for"},{"kind":"arabic","text_bw":"baEoda EahodiY biki","text_ar":"بَعْدَ عَهْدِى بِكِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in exchange for ignorance"},{"kind":"text","text":"]. (TA. [The meaning of"},{"kind":"arabic","text_bw":"tzEmynY","text_ar":"تزعمينى"},{"kind":"text","text":"is there indicated by the context.]) ―         -b5-  It is also used in the sense of"},{"kind":"arabic","text_bw":"AlAiEotiqaAdu","text_ar":"الاِعْتِقَادُ"},{"kind":"text","text":": whence the saying in the Kur [lxiv. 7],"},{"kind":"arabic","text_bw":"zaEama A@l~a*iyna kafaruw A^ano","text_ar":"زَعَمَ ا@لَّذِينَ كَفَرُو اَنْ"},{"kind":"arabic","text_bw":"lano yuboEavuwA","text_ar":"لَنْ يُبْعَثُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They who have disbelieved"},{"kind":"text","text":"our revelations"},{"kind":"italic_en","text":"have believed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firmly believed, that they shall not be raised from the dead"},{"kind":"text","text":"]. (Msb.) ―         -b6-  Sometimes, also,"},{"kind":"arabic","text_bw":"zaEama","text_ar":"زَعَمَ"},{"kind":"text","text":"is used in the sense of"},{"kind":"arabic","text_bw":"$ahida","text_ar":"شَهِدَ"},{"kind":"text","text":": as in the saying of En-Nábighah,"},{"kind":"quote","text":"zaEama AlhumaAmu biA^an~a faAhaA baAridN"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"The magnanimous chief bore witness that her mouth was cool"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"zaEama bihi","text_ar":"زَعَمَ بِهِ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(S, Msb) and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"zaEomN","text_ar":"زَعْمٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"zaEaAmapN","text_ar":"زَعَامَةٌ"},{"kind":"text","text":", (S, K,) or the latter is a simple subst., (Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, responsible, answerable, amenable, surety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarantee, for it;"},{"kind":"text","text":"(S, Msb, K;) namely, property. (Msb.) ―         -b2-  And"},{"kind":"arabic","text_bw":"zaEama","text_ar":"زَعَمَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qatala","text_ar":"قَتَلَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"zaEuma","text_ar":"زَعُمَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"karuma","text_ar":"كَرُمَ"},{"kind":"text","text":", (TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zaEaAmapN","text_ar":"زَعَامَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, chief, lord, master,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prince,"},{"kind":"text","text":"(Msb, TA,) of a people, (TA,) or"},{"kind":"arabic","text_bw":"EalaY qawomK","text_ar":"عَلَى قَوْمٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"over a people"},{"kind":"text","text":"]; (Msb;) or"},{"kind":"italic_en","text":"spokesman"},{"kind":"text","text":"of a people. (TA.)       -A3-  See also 4, in two places.       -A4-"},{"kind":"arabic","text_bw":"zaEima","text_ar":"زَعِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"zaEamN","text_ar":"زَعَمٌ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"zaEomN","text_ar":"زَعْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He coveted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerly desired."},{"kind":"text","text":"(S, K.) [Like its syn."},{"kind":"arabic","text_bw":"TamiEa","text_ar":"طَمِعَ"},{"kind":"text","text":", it is trans. by means of"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"text","text":".] One says, ↓"},{"kind":"arabic","text_bw":"zaEima fulaAnN fiY gayori mazoEamK","text_ar":"زَعِمَ فُلَانٌ فِى غَيْرِ مَزْعَمٍ","orth_type":"arrow"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"TamiEa fY gayori","text_ar":"طَمِعَ فى غَيْرِ"},{"kind":"arabic","text_bw":"maToEamK","text_ar":"مَطْعَمٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one coveted a thing not to be coveted;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"a thing of which the attainment was remote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"improbable:"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"TmE","text_ar":"طمع"},{"kind":"text","text":"]. (TA.) And ' Antarah says,"},{"kind":"quote","text":"Eul~iqotuhaA EaraDFA waA^aqotulu qawomahaA\n                      \n                     \n                        zaEamFA laEamoru A^abiyka layosa bimazoEami"},{"kind":"text","text":"(S,) i. e."},{"kind":"italic_en","text":"I became enamoured of her unintentionally,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"accidentally,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"while I was slaying her people; eagerly desiring"},{"kind":"text","text":"her love:"},{"kind":"italic_en","text":"by the life of thy father,"},{"kind":"text","text":"I swear,"},{"kind":"italic_en","text":"this is not a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fit"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"occasion for eager desire:"},{"kind":"text","text":"i. e. I can not attain to holding communion of love with thee, [or with her,] any day, while there is this conflict and hostility between the two tribes: (EM p. 222:)"},{"kind":"arabic","text_bw":"layosa bimazoEamK","text_ar":"لَيْسَ بِمَزْعَمٍ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"layosa bimaTomaEK","text_ar":"لَيْسَ بِمَطْمَعٍ"},{"kind":"text","text":": (S:) or, [as some relate it,]"},{"kind":"quote","text":"zaEomFA warab~i Albayoti layosa bimazoEami"},{"kind":"text","text":"["},{"kind":"italic_en","text":"eagerly desiring: by the Lord of the House"},{"kind":"text","text":"(i. e. the Kaabeh), &c.]. (TA. ["},{"kind":"arabic","text_bw":"zaEomFA","text_ar":"زَعْمًا"},{"kind":"text","text":"is there expressly said to be thus: but the measure does not require its being so.])"}],"source_refs":["S","Msb","K","TA","Sh","Az","Lth"]}]}}