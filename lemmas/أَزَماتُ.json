{"lemma":"أَزَماتُ","slug":"أَزَماتُ","root":"#.ز.م","root_slug":"_-ز-م","root_link":"/words/roots/_-ز-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n697","n698","n699"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B2%D9%8E%D9%85%D8%A7%D8%AA%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dearth, scarcity"},{"pos":"noun","gloss":"crisis"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n697","headword_ar":"اَزْمَةٌ","root":"Azm","body":[{"kind":"text","text":"[inf. n. of un. of 1: and hence,]"},{"kind":"italic_en","text":"A single act of eating;"},{"kind":"text","text":"(K, TA;) i. e."},{"kind":"italic_en","text":"an eating but once in the course of the day;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b2-  Also, (Fr, S, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"A^azamapN","text_ar":"اَزَمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A=zimapN","text_ar":"ا=زِمَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Fr, K, [the last in the CK like the first,])"},{"kind":"italic_en","text":"Straitness, hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"drought, dearth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sterility:"},{"kind":"text","text":"(S, Msb:) pl. (of the first, TA) ↓"},{"kind":"arabic","text_bw":"A^azomN","text_ar":"اَزْمٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [or rather this is a coll. gen. n.,] like as"},{"kind":"arabic","text_bw":"tamorN","text_ar":"تَمْرٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"text","text":", (TA,) [but originally an inf. n. of"},{"kind":"arabic","text_bw":"A^azama","text_ar":"اَزَمَ"},{"kind":"text","text":". q. v.,] and"},{"kind":"arabic","text_bw":"A_izamN","text_ar":"اـِزَمٌ"},{"kind":"text","text":", (K,) like as"},{"kind":"arabic","text_bw":"bidarN","text_ar":"بِدَرٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"badorapN","text_ar":"بَدْرَةٌ"},{"kind":"text","text":". (TA.) Hence the trad.,"},{"kind":"arabic","text_bw":"A$otad~iY A^azomapN","text_ar":"اشْتَدِّى اَزْمَةٌ"},{"kind":"arabic","text_bw":"tanofarijiY","text_ar":"تَنْفَرِجِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Become severe, O year of drought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sterility:"},{"kind":"text","text":"then"},{"kind":"italic_en","text":"thou wilt pass away:"},{"kind":"text","text":"though it has been strangely asserted that"},{"kind":"arabic","text_bw":"Azmp","text_ar":"ازمة"},{"kind":"text","text":"is here the proper name of a woman, to whom, on an occasion of her being taken with the pains of labour, these words were said by the Prophet. (TA.) You also say"},{"kind":"arabic","text_bw":"sanapN A^azomapN","text_ar":"سَنَةٌ اَزْمَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^azimapN","text_ar":"اَزِمَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) so in the copies of the K, there said to be like"},{"kind":"arabic","text_bw":"fariHapN","text_ar":"فَرِحَةٌ"},{"kind":"text","text":", but correctly ↓"},{"kind":"arabic","text_bw":"A=zimapN","text_ar":"ا=زِمَةٌ","orth_type":"arrow"},{"kind":"text","text":", as in the M &c., (TA,) [or both are correct, being part. ns., respectively, of"},{"kind":"arabic","text_bw":"A^azima","text_ar":"اَزِمَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^azama","text_ar":"اَزَمَ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"A^azuwmapN","text_ar":"اَزُومَةٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A distressful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an afflictive, year;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"a year of vehement drought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sterility."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^awaAzimu","text_ar":"اَوَازِمُ"},{"kind":"text","text":"[pl. of ↓"},{"kind":"arabic","text_bw":"A=zimapN","text_ar":"ا=زِمَةٌ","orth_type":"arrow"},{"kind":"text","text":", used as a subst.,] signifies"},{"kind":"italic_en","text":"Distressful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afflictive, years."},{"kind":"text","text":"(TA.) ↓"},{"kind":"arabic","text_bw":"A^azaAmi","text_ar":"اَزَامِ","orth_type":"arrow"},{"kind":"text","text":", also, (K,) or, accord. to Aboo-'Alee, ↓"},{"kind":"arabic","text_bw":"A^azuwmu","text_ar":"اَزُومُ","orth_type":"arrow"},{"kind":"text","text":", (IB,) [each a proper name, as denoting a kind of personification,] signifies"},{"kind":"italic_en","text":"The year of drought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sterility."},{"kind":"text","text":"(K.) And you say, ↓"},{"kind":"arabic","text_bw":"nazalato bihimo A^azaAm","text_ar":"نَزَلَتْ بِهِمْ اَزَام","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^azuwmu","text_ar":"اَزُومُ","orth_type":"arrow"},{"kind":"italic_en","text":"Severe straitness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress, befell them."},{"kind":"text","text":"(S, TA. *)"}],"source_refs":["Fr","S","Msb","K","TA","IB"]},{"entry_id":"n698","headword_ar":"اَزَمَةٌ","root":"Azm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^azomapN","text_ar":"اَزْمَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n699","headword_ar":"اَزِمَةٌ","root":"Azm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^azomapN","text_ar":"اَزْمَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}