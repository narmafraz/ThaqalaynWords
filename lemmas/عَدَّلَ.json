{"lemma":"عَدَّلَ","slug":"عَدَّلَ","root":"ع.د.ل","root_slug":"ع-د-ل","root_link":"/words/roots/ع-د-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَدَّلْتَ","in_corpus":true,"count":11,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَدَّلْتِ","in_corpus":true,"count":11,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَدَّلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَدَّلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَدَّلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَدَّلَ","in_corpus":true,"count":41,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَدَّلَت","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَدَّلا","in_corpus":true,"count":17,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَدَّلَتا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَدَّلُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَدَّلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَدِّل","in_corpus":true,"count":25,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَدِّلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَدِّلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَدِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَدِّلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَدِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَدِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَدِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَدِّل","in_corpus":true,"count":17,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَدِّل","in_corpus":true,"count":25,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَدِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَدِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَدِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَدِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَدِّلُونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَدِّلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَدِّلْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَدَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَدَّلْتُ","in_corpus":true,"count":11,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَدِّل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَدِّل","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":185,"cross_references":{"qac":{"found":true,"lemma_key":"عَدَّلَ","root":"عدل","pos":"N","occurrence_count":14},"wiktextract":{"found":true,"entry_count":13,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":44},"lanes":{"found":true,"entry_ids":["n28317","n28322","n28323","n28324"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AF%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to act justly"},{"pos":"verb","gloss":"to make (someone) equal (بِ (bi) to)"},{"pos":"verb","gloss":"to be equal to, to be equivalent to","tags":["transitive"]},{"pos":"verb","gloss":"to balance","tags":["transitive"]},{"pos":"verb","gloss":"to deviate, to turn away (عَن (ʕan) from)"},{"pos":"verb","gloss":"to make deviate, to cause to turn away"},{"pos":"verb","gloss":"to be just"},{"pos":"verb","gloss":"to act wrongfully"},{"pos":"verb","gloss":"to give judgment according to the right"},{"pos":"verb","gloss":"to make just"},{"pos":"verb","gloss":"to make equal in size or weight, to declare to be equal"},{"pos":"verb","gloss":"to set into the right proportion"},{"pos":"verb","gloss":"to straighten"},{"pos":"verb","gloss":"to lead straight"},{"pos":"verb","gloss":"to weigh rightly","tags":["transitive"]},{"pos":"verb","gloss":"to balance, to adjust, to fix, to rectify"},{"pos":"verb","gloss":"to adapt","tags":["transitive"]},{"pos":"verb","gloss":"to change, to improve","tags":["transitive"]},{"pos":"verb","gloss":"to place (a balance) in equilibrium"},{"pos":"verb","gloss":"to admit (a witness) as lawful"},{"pos":"verb","gloss":"to drink to excess"},{"pos":"verb","gloss":"to grow thick or stout","tags":["Arabic","Modern","Standard"]},{"pos":"verb","gloss":"to modulate"},{"pos":"noun","gloss":"verbal noun of عَدَلَ (ʕadala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"justice, equity","examples":[{"text":"مِنَ الْعَدْلِ","english":"fair"}]},{"pos":"noun","gloss":"righteousness, uprightness, honesty"},{"pos":"noun","gloss":"right measure"},{"pos":"noun","gloss":"compensation"},{"pos":"noun","gloss":"reward"},{"pos":"noun","gloss":"ransom"},{"pos":"noun","gloss":"deviation from what is right, anomaly"},{"pos":"adj","gloss":"just, upright, honest","tags":["invariable"]},{"pos":"adj","gloss":"lawful, admissible","tags":["invariable"]},{"pos":"adj","gloss":"of equal value","tags":["invariable"]},{"pos":"noun","gloss":"verbal noun of عَدِلَ (ʕadila) (form I)","tags":["form-of","invariable","noun-from-verb"]},{"pos":"noun","gloss":"equilibration of the two side loads","tags":["invariable"]},{"pos":"noun","gloss":"equal","tags":["invariable"]},{"pos":"noun","gloss":"of equal weight","tags":["invariable"]},{"pos":"noun","gloss":"of equal value","tags":["invariable"]},{"pos":"noun","gloss":"similar, corresponding","tags":["invariable"]},{"pos":"noun","gloss":"balanced bale of merchandise, half of a counterbalanced load","tags":["invariable"]},{"pos":"noun","gloss":"sack, back","tags":["invariable"]},{"pos":"noun","gloss":"plural of عَادِل (ʕādil)","tags":["form-of","invariable","plural"]},{"pos":"adj","gloss":"masculine plural of عَادِل (ʕādil)","tags":["form-of","invariable","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28317","headword_ar":"عَدَلَ","root":"Edl","body":[{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"(S, * O, * Msb, K, * TA) and"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ"},{"kind":"text","text":"(S, * O, * Msb, K *) and"},{"kind":"arabic","text_bw":"maEodalapN","text_ar":"مَعْدَلَةٌ"},{"kind":"text","text":"(S, * Msb, K *) and"},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuduwlapN","text_ar":"عُدُولَةٌ"},{"kind":"text","text":", (K, * TK,)"},{"kind":"italic_en","text":"He acted equitably, justly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly."},{"kind":"text","text":"(S, O, Msb, K.) So in the phrase"},{"kind":"arabic","text_bw":"Eadala fiY A^amorihi","text_ar":"عَدَلَ فِى اَمْرِهِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his affair,"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":". (Msb.) And so in the phrase"},{"kind":"arabic","text_bw":"Eadala Ealayohi fiY AlqaDiy~api","text_ar":"عَدَلَ عَلَيْهِ فِى القَضِيَّةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"towards him in the judgment"},{"kind":"text","text":"]: (S, O:) and"},{"kind":"arabic","text_bw":"Eadala EalaY Alqawomi","text_ar":"عَدَلَ عَلَى القَوْمِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"he acted equitably,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"towards the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEodalapN","text_ar":"مَعْدَلَةٌ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"lano tasotaTiyEuwA A^ano","text_ar":"لَنْ تَسْتَطِيعُوا اَنْ"},{"kind":"arabic","text_bw":"taEodiluwA bayona Aln~isaA='i","text_ar":"تَعْدِلُوا بَيْنَ النِّسَا=ءِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"Ye will not be able to act with"},{"kind":"text","text":"perfect"},{"kind":"italic_en","text":"equity between women"},{"kind":"text","text":"], in the Kur [iv. 128], is said to mean, in respect of love, and of"},{"kind":"arabic","text_bw":"jimaAE","text_ar":"جِمَاع"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"below.] ―         -b2-"},{"kind":"arabic","text_bw":"waA_ino","text_ar":"وَاـِنْ"},{"kind":"arabic","text_bw":"taEodilo kul~a EadolK","text_ar":"تَعْدِلْ كُلَّ عَدْلٍ"},{"kind":"text","text":", in the Kur [vi. 69], means"},{"kind":"italic_en","text":"And if it would ransom with every"},{"kind":"text","text":"[degree of]"},{"kind":"italic_en","text":"ransoming:"},{"kind":"text","text":"(T, S, O, Msb, TA:) AO used to say,"},{"kind":"italic_en","text":"and if it would act equitably with every"},{"kind":"text","text":"[degree of]"},{"kind":"italic_en","text":"equitable acting;"},{"kind":"text","text":"but Az says that this is a blunder. (TA.) [See, again,"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"below.] ―         -b3-  ["},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He declined, deviated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away;"},{"kind":"text","text":"and particularly from the right course: thus having a meaning nearly agreeing with that assigned to"},{"kind":"arabic","text_bw":"Eadila","text_ar":"عَدِلَ"},{"kind":"text","text":"in the last sentence of this paragraph.]"},{"kind":"arabic","text_bw":"balo humo qawomN yaEodiluwna","text_ar":"بَلْ هُمْ قَوْمٌ يَعْدِلُونَ"},{"kind":"text","text":", in the Kur [xxvii. 61], means ["},{"kind":"italic_en","text":"Nay but they are a people"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who decline,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviate,"},{"kind":"text","text":"from the truth, and from the right course; i. e., who disbelieve. (O.) And one says,"},{"kind":"arabic","text_bw":"Eadala Eanohu","text_ar":"عَدَلَ عَنْهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and [more com-"},{"kind":"page_break","n":1973},{"kind":"text","text":"monly]"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He declined, deviated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"Eani AlT~ariyqi","text_ar":"عَنِ الطَّرِيقِ"},{"kind":"text","text":", (S, O, Msb,) inf. n."},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He declined,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way;"},{"kind":"text","text":"(S, O, Msb;) as also"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnEdl","text_ar":"انعدل","orth_type":"arrow"},{"kind":"text","text":". (S, O, K. *) And"},{"kind":"arabic","text_bw":"Eadala AlT~ariyqu","text_ar":"عَدَلَ الطَّرِيقُ"},{"kind":"italic_en","text":"The road declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deflected."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eadala AlfaHolu","text_ar":"عَدَلَ الفَحْلُ"},{"kind":"text","text":"(S, O, K)"},{"kind":"arabic","text_bw":"Eani AlA_ibili","text_ar":"عَنِ الاـِبِلِ"},{"kind":"text","text":"(S, O)"},{"kind":"italic_en","text":"The stallion left, left off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desisted from, covering the she-camels;"},{"kind":"text","text":"(S, O, K; *) and so"},{"kind":"arabic","text_bw":"Eani AlD~iraAbi","text_ar":"عَنِ الضِّرَابِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnEdl","text_ar":"انعدل","orth_type":"arrow"},{"kind":"text","text":". (TA.) ["},{"kind":"arabic","text_bw":"Eadala AlfaHola","text_ar":"عَدَلَ الفَحْلَ"},{"kind":"text","text":"see in what follows.] And"},{"kind":"arabic","text_bw":"Eadala A_ilayohi","text_ar":"عَدَلَ اـِلَيْهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He returned to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"Eadalahu","text_ar":"عَدَلَهُ"},{"kind":"text","text":": see 2, in two places. ―         -b2-"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"fulaAnFA bifulaAnK","text_ar":"فُلَانًا بِفُلَانٍ"},{"kind":"italic_en","text":"He made such a one to be equal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"like, to such a one;"},{"kind":"text","text":"(K;) [and] so"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":": (S:) or, accord. to some,"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the rating"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as equal"},{"kind":"text","text":"to a thing of another kind"},{"kind":"italic_en","text":"so as to make"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"the latter. (TA.) One says,"},{"kind":"arabic","text_bw":"Eadalotu h`*aA bih`*aA","text_ar":"عَدَلْتُ هٰذَا بِهٰذَا"},{"kind":"italic_en","text":"I made this to be like"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to stand in the stead of, this."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"arabic","text_bw":"birab~ihi","text_ar":"بِرَبِّهِ"},{"kind":"text","text":", (El-Ahmar, TA,) aor."},{"kind":"text","text":", (S, O, TA,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":", ["},{"kind":"arabic","text_bw":"gayorahu","text_ar":"غَيْرَهُ"},{"kind":"text","text":"being understood,]"},{"kind":"italic_en","text":"He made another to be equal with his Lord, and worshipped him."},{"kind":"text","text":"(El-Ahmar, TA.)"},{"kind":"arabic","text_bw":"birab~ihimo yaEodiluwna","text_ar":"بِرَبِّهِمْ يَعْدِلُونَ"},{"kind":"text","text":", in the Kur [vi. 151, and accord. to some in vi. 1], means"},{"kind":"italic_en","text":"Attributing a copartner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copartners, to their Lord."},{"kind":"text","text":"(O. [And the like is said in the S and Msb and TA.]) ―         -b3-"},{"kind":"arabic","text_bw":"Eadalotu A^amotiEapa Albayoti","text_ar":"عَدَلْتُ اَمْتِعَةَ البَيْتِ"},{"kind":"italic_en","text":"I made the goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"furniture, of the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, into equal loads,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to counterbalance one another,"},{"kind":"text","text":"] on the day of departure, or removal. (TA.) And"},{"kind":"arabic","text_bw":"bayona Al$~ayoy^ayoni","text_ar":"بَيْنَ الشَّيْيَيْنِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaAdala","text_ar":"عَادَلَ","orth_type":"arrow"},{"kind":"text","text":"(S, O, TA)"},{"kind":"italic_en","text":"He made an equiponderance to subsist between the two things."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"fulaAnN yaEodilu fulaAnFA","text_ar":"فُلَانٌ يَعْدِلُ فُلَانًا"},{"kind":"italic_en","text":"Such a one is equal to such a one."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"yaEodiluhu","text_ar":"يَعْدِلُهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is like him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Fr, S, O.) [Hence] one says,"},{"kind":"arabic","text_bw":"maA yaEodiluka EinodanaA $aYo'N","text_ar":"مَا يَعْدِلُكَ عِنْدَنَا شَىْءٌ"},{"kind":"italic_en","text":"Nothing stands with us in thy stead."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eadalahu","text_ar":"عَدَلَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, equiponderant to it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"muEaAdalapN","text_ar":"مُعَادَلَةٌ"},{"kind":"text","text":". (TA.) And [hence]"},{"kind":"arabic","text_bw":"Eadalahu fiY AlmaHomili","text_ar":"عَدَلَهُ فِى المَحْمِلِ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"EAdlhu","text_ar":"عادلهُ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He rode with him in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"vehicle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"mHml","text_ar":"محمل"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to counterbalance him"},{"kind":"text","text":"]. (K, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Eadala","text_ar":"عَدَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", signifies also"},{"kind":"italic_en","text":"He turned"},{"kind":"text","text":"a thing from its course, direction, or manner of being. (TA.) You say,"},{"kind":"arabic","text_bw":"Eadalotu fulaAnFA Eano Tariyqihi","text_ar":"عَدَلْتُ فُلَانًا عَنْ طَرِيقِهِ"},{"kind":"italic_en","text":"I turned such a one from his road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"laA tuEodalu saAriHatukumo","text_ar":"لَا تُعْدَلُ سَارِحَتُكُمْ"},{"kind":"italic_en","text":"Your pasturing cattle shall not be turned away, nor prevented, from pasturing."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"Eadala AlfaHola","text_ar":"عَدَلَ الفَحْلَ"},{"kind":"text","text":"(K, TA)"},{"kind":"arabic","text_bw":"Eani AlD~iraAbi","text_ar":"عَنِ الضِّرَابِ"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"He removed the stallion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him to withdraw"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desist"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"from covering."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"Eadalotu Ald~aAb~apa A_ilaY mawoDiEi ka*aA","text_ar":"عَدَلْتُ الدَّابَّةَ اـِلَى مَوْضِعِ كَذَا"},{"kind":"italic_en","text":"I turned the beast to such a place."},{"kind":"text","text":"(TA.) [See also two meanings assigned to this verb in the next paragraph, third sentence.]       -A3-"},{"kind":"arabic","text_bw":"Eadula","text_ar":"عَدُلَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ"},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"arabic","text_bw":"EuduwlapN","text_ar":"عُدُولَةٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, O, i. e. a witness, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"text","text":"[q. v.]. (S, O, Msb.)       -A4-"},{"kind":"arabic","text_bw":"Eadila","text_ar":"عَدِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EadalN","text_ar":"عَدَلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He acted wrongfully, unjustly, injuriously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tyrannically."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","O","Msb","K","T","TA"]},{"entry_id":"n28322","headword_ar":"عَدْلٌ","root":"Edl","body":[{"kind":"italic_en","text":"Equity, justice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rectitude; contr. of"},{"kind":"arabic","text_bw":"jaworN","text_ar":"جَوْرٌ"},{"kind":"text","text":"; (S, O, Msb, K, TA;) i. e."},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaSodN","text_ar":"قَصْدٌ"},{"kind":"text","text":", in affairs; (Msb;) and"},{"kind":"arabic","text_bw":"qisoTN","text_ar":"قِسْطٌ"},{"kind":"text","text":"; (S, M, Mgh, &c., in art."},{"kind":"arabic","text_bw":"qsT","text_ar":"قسط"},{"kind":"text","text":";) and"},{"kind":"arabic","text_bw":"sawiy~apN","text_ar":"سَوِيَّةٌ"},{"kind":"text","text":"; (O, K;) and"},{"kind":"arabic","text_bw":"AisotiqaAmapN","text_ar":"اِسْتِقَامَةٌ"},{"kind":"text","text":"; (IAar, K;) and"},{"kind":"italic_en","text":"a thing that is established in the minds as being right;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"maEodalapN","text_ar":"مَعْدَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuduwlapN","text_ar":"عُدُولَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or, as some say, it is the"},{"kind":"italic_en","text":"mean between excess and falling short:"},{"kind":"text","text":"and Er-Rághib says, it is of two sorts: one is"},{"kind":"italic_en","text":"absolute, such that reason requires the inference of its goodness;"},{"kind":"text","text":"and this will not at any time be abrogated, nor described as a mode of transgression; as the doing good to him who does good to thee, and the abstaining from harming him who abstains from harming thee: and the other is"},{"kind":"italic_en","text":"such as is known to be"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"italic_en","text":"by the law;"},{"kind":"text","text":"and this may be abrogated sometimes; as retaliation, and fines for wounds and maimings, and the taking the property of the apostate; and this is what is meant by the saying in the Kur [xvi. 92],"},{"kind":"arabic","text_bw":"A_in~a A@ll~`ha","text_ar":"اـِنَّ ا@للّٰهَ"},{"kind":"arabic","text_bw":"yaA^omuru biA@loEadoli waA@loA_iHosaAni","text_ar":"يَاْمُرُ بِا@لْعَدْلِ وَا@لْاـِحْسَانِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"Verily God commandeth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"equality in recompensing, if good, with good, and if evil, with evil, and the requiting of good with more good, and of evil with less evil:"},{"kind":"text","text":"[see also 4 in art."},{"kind":"arabic","text_bw":"Hsn","text_ar":"حسن"},{"kind":"text","text":":] and he says of ↓"},{"kind":"arabic","text_bw":"EadaAlapN","text_ar":"عَدَالَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEodilapN","text_ar":"مَعْدِلَةٌ","orth_type":"arrow"},{"kind":"text","text":", that each is a term requiring the inference of equality, and is used with a regard to correlation. (TA.) One says,"},{"kind":"arabic","text_bw":"basaTa AlwaAliY Eadolahu","text_ar":"بَسَطَ الوَالِى عَدْلَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEodilatahu","text_ar":"مَعْدِلَتَهُ","orth_type":"arrow"},{"kind":"text","text":"(S, O) and ↓"},{"kind":"arabic","text_bw":"maEodalatahu","text_ar":"مَعْدَلَتَهُ","orth_type":"arrow"},{"kind":"text","text":"(S) ["},{"kind":"italic_en","text":"The governor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruler, largely extended his equity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"justice"},{"kind":"text","text":"]. And ↓"},{"kind":"arabic","text_bw":"fulaAnN mino A^aholi AlmaEodalapi","text_ar":"فُلَانٌ مِنْ اَهْلِ المَعْدَلَةِ","orth_type":"arrow"},{"kind":"text","text":", (S,) or ↓"},{"kind":"arabic","text_bw":"AlmaEodilapi","text_ar":"المَعْدِلَةِ","orth_type":"arrow"},{"kind":"text","text":", (O,) i. e."},{"kind":"arabic","text_bw":"mn Ahl AlEadoli","text_ar":"من اهل العَدْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is of the people of equity,"},{"kind":"text","text":"&c.]. (S, O.)"},{"kind":"arabic","text_bw":"waA^a$ohiduwA","text_ar":"وَاَشْهِدُوا"},{"kind":"arabic","text_bw":"*awaYo EadolK minokumo","text_ar":"ذَوَىْ عَدْلٍ مِنْكُمْ"},{"kind":"text","text":", in the Kur [lxv. 2], is said by Sa'eed Ibn-El-Museiyib to mean"},{"kind":"arabic","text_bw":"*awaYo EaqolK","text_ar":"ذَوَىْ عَقْلٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"And make ye to be witnesses two persons of intelligence from among you:"},{"kind":"text","text":"but this rendering I think questionable]. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Repayment, requital, compensation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompense."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"Ransom,"},{"kind":"text","text":"(S, O, Msb, K, TA,)"},{"kind":"italic_en","text":"when regard is had therein to the meaning of equality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"equivalence."},{"kind":"text","text":"(TA.) This is [said to be] the meaning in the phrase of the Kur [v. 96],"},{"kind":"arabic","text_bw":"A^awo Eadolu *`lika SiyaAmFA","text_ar":"اَوْ عَدْلُ ذٰلِكَ صِيَامًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Or the ransom thereof by fasting:"},{"kind":"text","text":"but this is generally expl. as meaning"},{"kind":"italic_en","text":"or the like thereof of fasting;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":";) i. e., in lieu of feeding a number of poor men, one shall fast the like number of days]. (S, O.) And so [accord. to some] in the saying, occurring in a trad.,"},{"kind":"arabic","text_bw":"laA yuqobalu","text_ar":"لَا يُقْبَلُ"},{"kind":"arabic","text_bw":"minohu SarofN walaA EadolN","text_ar":"مِنْهُ صَرْفٌ وَلَا عَدْلٌ"},{"kind":"text","text":"[of which see various explanations (including three renderings here following) in art."},{"kind":"arabic","text_bw":"Srf","text_ar":"صرف"},{"kind":"text","text":"]. (O, Msb.) ―         -b4-  And"},{"kind":"italic_en","text":"Measure;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kayolN","text_ar":"كَيْلٌ"},{"kind":"text","text":". (K.) So in the phrase"},{"kind":"arabic","text_bw":"A^aEoTaAhu biAlEadoli","text_ar":"اَعْطَاهُ بِالعَدْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He gave him by measure"},{"kind":"text","text":"]. (TK.) ―         -b5-  And"},{"kind":"italic_en","text":"An obligatory act"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divine ordinance."},{"kind":"text","text":"(En-Nadr, O, K.) ―         -b6-  And"},{"kind":"italic_en","text":"A supererogatory act."},{"kind":"text","text":"(O, K.)       -A2-  Also One"},{"kind":"italic_en","text":"who acts equitably, justly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"EaAdilN","text_ar":"عَادِلٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) or the latter signifies thus: (S, O:) and the former [particularly] signifies a man"},{"kind":"italic_en","text":"approved and satisfactory in testimony;"},{"kind":"text","text":"originally an inf. n.; (S, O, TA;)"},{"kind":"italic_en","text":"whose testimony is approved and available;"},{"kind":"text","text":"(Msb;) a man"},{"kind":"italic_en","text":"whose testimony is allowable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"legally admissible,"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaAdilN","text_ar":"عَادِلٌ","orth_type":"arrow"},{"kind":"text","text":"; a man"},{"kind":"italic_en","text":"whose saying, and whose judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judicial decision, are approved;"},{"kind":"text","text":"and, accord. to Ibráheem, one"},{"kind":"italic_en","text":"from whom a thing occasioning doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil opinion, has not appeared:"},{"kind":"text","text":"being originally an inf. n., it means"},{"kind":"arabic","text_bw":"*uw EadolK","text_ar":"ذُو عَدْلٍ"},{"kind":"text","text":": or, accord. to IJ, it is an intensive epithet, as though meaning"},{"kind":"italic_en","text":"possessing every kind of"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"text","text":": (TA:) one says"},{"kind":"arabic","text_bw":"rajulN EadolN","text_ar":"رَجُلٌ عَدْلٌ"},{"kind":"text","text":", (S, O, Msb, * K,) and"},{"kind":"arabic","text_bw":"AimoraA^apN EadolN","text_ar":"اِمْرَاَةٌ عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EadolapN","text_ar":"عَدْلَةٌ"},{"kind":"text","text":", (Msb, K,) the latter mentioned by IJ, (TA,) and"},{"kind":"arabic","text_bw":"rajulaAni EadolN","text_ar":"رَجُلَانِ عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EadolaAni","text_ar":"عَدْلَانِ"},{"kind":"text","text":", (Msb, * TA,) and"},{"kind":"arabic","text_bw":"qawomN EadolN","text_ar":"قَوْمٌ عَدْلٌ"},{"kind":"text","text":"(S, O, Msb, * K) and"},{"kind":"arabic","text_bw":"nisowapN EadolN","text_ar":"نِسْوَةٌ عَدْلٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"qawomN EuduwlN","text_ar":"قَوْمٌ عُدُولٌ"},{"kind":"text","text":", (S, O, Msb, * K,)"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":"being pl. of"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", (S, O, Msb,) or of"},{"kind":"arabic","text_bw":"EaAdilN","text_ar":"عَادِلٌ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"used in a pl. sense being a quasi-pl. n. of"},{"kind":"arabic","text_bw":"EaAdilN","text_ar":"عَادِلٌ"},{"kind":"text","text":", (M, K,) like"},{"kind":"arabic","text_bw":"tajorN","text_ar":"تَجْرٌ"},{"kind":"text","text":"[of"},{"kind":"arabic","text_bw":"taAjirN","text_ar":"تَاجِرٌ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"$arobN","text_ar":"شَرْبٌ"},{"kind":"text","text":"[of"},{"kind":"arabic","text_bw":"$aAribN","text_ar":"شَارِبٌ"},{"kind":"text","text":"]; (M, TA;) or"},{"kind":"arabic","text_bw":"rijaAlN EadolN","text_ar":"رِجَالٌ عَدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nisowapN EadolN","text_ar":"نِسْوَةٌ عَدْلٌ"},{"kind":"text","text":"mean"},{"kind":"arabic","text_bw":"rijaAlN *awuw EadolK","text_ar":"رِجَالٌ ذَوُو عَدْلٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nisowaAnN *awaAtu EadolK","text_ar":"نِسْوَانٌ ذَوَاتُ عَدْلٍ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ"},{"kind":"text","text":"as one of the names of God means"},{"kind":"italic_en","text":"He whom desire does not cause to incline,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decline, so that he should deviate from the right course in judgment."},{"kind":"text","text":"(TA.) ―         -b3-  And one says,"},{"kind":"arabic","text_bw":"h`*aA EadolN","text_ar":"هٰذَا عَدْلٌ"},{"kind":"arabic","text_bw":"bayonahumaA","text_ar":"بَيْنَهُمَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"This is intermediate in quality between them two, not in the utmost degree of goodness nor in the extreme degree of badness."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"makaAnN EadolN bayona fariyqayoni","text_ar":"مَكَانٌ عَدْلٌ بَيْنَ فَرِيقَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A place equidistant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"midway, between two parties"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"swY","text_ar":"سوى"},{"kind":"text","text":".) ―         -b4-  See also"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":", throughout the greater part of the paragraph.       -A3-"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"is also the name of a certain chief of the [body of armed men called]"},{"kind":"arabic","text_bw":"$uraT","text_ar":"شُرَط"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"$uroTap","text_ar":"شُرْطَة"},{"kind":"text","text":", (K,) of a"},{"kind":"arabic","text_bw":"tub~aE","text_ar":"تُبَّع"},{"kind":"text","text":"[or King of El-Yemen], who, when he desired the slaughter of a man, delivered him to this person; (S, O, K;) whereupon the people said,"},{"kind":"arabic","text_bw":"wuDiEa EalaY","text_ar":"وُضِعَ عَلَى"},{"kind":"arabic","text_bw":"yadaYo EadolK","text_ar":"يَدَىْ عَدْلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has been consigned to the hands of 'Adl"},{"kind":"text","text":"]; (S, O;) and this was afterwards said of anything of which one despaired. (S, O, K.) [Meyd mentions"},{"kind":"arabic","text_bw":"EalaY yadaYo EadolK","text_ar":"عَلَى يَدَىْ عَدْلٍ"},{"kind":"text","text":", as a prov., without"},{"kind":"arabic","text_bw":"wuDiEa","text_ar":"وُضِعَ"},{"kind":"text","text":": see Freytag's Arab. Prov. ii. 80.]"}],"source_refs":["S","O","Msb","K","TA","M"]},{"entry_id":"n28323","headword_ar":"عِدْلٌ","root":"Edl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"(IAar, Zj, O, K) of a thing; (IAar, O;) as also ↓"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ","orth_type":"arrow"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":"; (IAar, Zj, O, K;) and"},{"kind":"arabic","text_bw":"naZiyrN","text_ar":"نَظِيرٌ"},{"kind":"text","text":"[which signifies the same, or the"},{"kind":"italic_en","text":"equal"},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"EadiylN","text_ar":"عَدِيلٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or, accord. to Er-Rághib, ↓"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":"are nearly the same; but the former is used in relation to what is perceived mentally, as in the phrase of the Kur [v. 96],"},{"kind":"arabic","text_bw":"A^awo Eadolu *`lika SiyaAmFA","text_ar":"اَوْ عَدْلُ ذٰلِكَ صِيَامًا"},{"kind":"text","text":"[mentioned voce"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EadiylN","text_ar":"عَدِيلٌ","orth_type":"arrow"},{"kind":"text","text":", in relation to what is perceived by the sense, as things weighed and things numbered and things measured: Ibn-'Ámir, however, read"},{"kind":"arabic","text_bw":"Aw Eidolu *lk","text_ar":"او عِدْلُ ذلك"},{"kind":"text","text":"; and Ks and the people of El-Medeeneh, with fet-h [i. e."},{"kind":"arabic","text_bw":"Eadolu","text_ar":"عَدْلُ"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"Eidolu Al$~aYo'i","text_ar":"عِدْلُ الشَّىْءِ"},{"kind":"text","text":", with kesr, signifies"},{"kind":"italic_en","text":"the like of the thing in kind,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"measure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(Msb,) or also"},{"kind":"italic_en","text":"in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"measure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(Mgh,) and IF says,"},{"kind":"italic_en","text":"in weight;"},{"kind":"text","text":"(Msb;) and ↓"},{"kind":"arabic","text_bw":"Eadoluhu","text_ar":"عَدْلُهُ","orth_type":"arrow"},{"kind":"text","text":", with fet-h, (Mgh, Msb,)"},{"kind":"italic_en","text":"its like,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"what will stand in its stead,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"of a thing different in kind,"},{"kind":"text","text":"(Mgh, Msb;) whence the phrase of the Kur"},{"kind":"arabic","text_bw":"A^awo Eadolu *`lika","text_ar":"اَوْ عَدْلُ ذٰلِكَ"},{"kind":"arabic","text_bw":"SiyaAmFA","text_ar":"صِيَامًا"},{"kind":"text","text":"[mentioned above];"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"text","text":"being originally an inf. n.: (Msb:) Akh says,"},{"kind":"arabic","text_bw":"AlEidolu","text_ar":"العِدْلُ"},{"kind":"text","text":", with kesr, signifies"},{"kind":"arabic","text_bw":"Almivolu","text_ar":"المِثْلُ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ","orth_type":"arrow"},{"kind":"text","text":", with fet-h, is originally an inf. n., but is made a subst. to denote"},{"kind":"arabic","text_bw":"Almivolu","text_ar":"المِثْلُ"},{"kind":"text","text":"in order to distinguish it from the"},{"kind":"arabic","text_bw":"Eidol","text_ar":"عِدْل"},{"kind":"text","text":"of goods or commodities [which will be expl. in what follows]: Fr says,"},{"kind":"arabic","text_bw":"AlEidolu","text_ar":"العِدْلُ"},{"kind":"text","text":", with kesr, is"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Almivolu","text_ar":"المِثْلُ"},{"kind":"text","text":"), as in the saying"},{"kind":"arabic","text_bw":"EinodiY Eidolu gulaAmika","text_ar":"عِنْدِى عِدْلُ غُلَامِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have the like of thy boy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Eidolu $aAtika","text_ar":"عِدْلُ شَاتِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the like of thy sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat"},{"kind":"text","text":"]; but you say ↓"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ","orth_type":"arrow"},{"kind":"text","text":", with nasb [i. e. fet-h] to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", when you mean"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"equal in"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"value, of what is different in kind;"},{"kind":"text","text":"though sometimes it is pronounced with kesr by some of the Arabs, app. by an error on their part: (S, O:) or some allow one's saying"},{"kind":"arabic","text_bw":"EinodiY Eidolu gulaAmika","text_ar":"عِنْدِى عِدْلُ غُلَامِكَ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"I have the like of thy boy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man,"},{"kind":"text","text":"[and app. ↓"},{"kind":"arabic","text_bw":"Eadoluhu","text_ar":"عَدْلُهُ","orth_type":"arrow"},{"kind":"text","text":"also,] and"},{"kind":"arabic","text_bw":"Eadoluhu","text_ar":"عَدْلُهُ"},{"kind":"text","text":"with fet-h only as meaning"},{"kind":"italic_en","text":"his value:"},{"kind":"text","text":"(TA:) but Zj says that"},{"kind":"arabic","text_bw":"AlEadolu","text_ar":"العَدْلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlEidolu","text_ar":"العِدْلُ"},{"kind":"text","text":"both signify"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"whether it be"},{"kind":"italic_en","text":"of the same kind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a different kind;"},{"kind":"text","text":"and if one make a mistake, he should not say that some of the Arabs have erred: (O:) the pl. (S, O, K) of"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":", by common consent, (S, O,) is"},{"kind":"arabic","text_bw":"A^aEodaAlN","text_ar":"اَعْدَالٌ"},{"kind":"text","text":", (S, O, K,) and [that of ↓"},{"kind":"arabic","text_bw":"EadiylN","text_ar":"عَدِيلٌ","orth_type":"arrow"},{"kind":"text","text":"is]"},{"kind":"arabic","text_bw":"EudalaA='u","text_ar":"عُدَلَا=ءُ"},{"kind":"text","text":". (K.) ―         -b2-  Also The"},{"kind":"italic_en","text":"half of a load,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"such as is on either of the two sides of the camel;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"a burden"},{"kind":"text","text":"["},{"kind":"italic_en","text":"borne on one side of a beast, counterbalancing another on the other side,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"made equiponderant to another burden:"},{"kind":"text","text":"(Az, TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEodaAlN","text_ar":"اَعْدَالٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"EuduwlN","text_ar":"عُدُولٌ"},{"kind":"text","text":": (Sb, K:) and ↓"},{"kind":"arabic","text_bw":"EadiylN","text_ar":"عَدِيلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"equal"},{"kind":"text","text":"of a person"},{"kind":"italic_en","text":"in weight and measure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"size"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"(S, K, * TA) in the [vehicle called]"},{"kind":"arabic","text_bw":"maHomil","text_ar":"مَحْمِل"},{"kind":"text","text":": (TA:) Sb says that it signifies"},{"kind":"italic_en","text":"a human being that is the equal"},{"kind":"text","text":"of another ["},{"kind":"italic_en","text":"in weight"},{"kind":"text","text":"]; distinguishing it from"},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":", which, he says, is applied only to goods, or commodities: (IB, TA:) [but] ↓"},{"kind":"arabic","text_bw":"EadiylataAni","text_ar":"عَدِيلَتَانِ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"two sacks"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"giraArataAni","text_ar":"غِرَارَتَانِ"},{"kind":"text","text":"); because each counter balances, or is equiponderant to, the other. (TA.) Hence one says of the"},{"kind":"arabic","text_bw":"Euduwl","text_ar":"عُدُول"},{"kind":"text","text":"of an evil judicial decision,"},{"kind":"arabic","text_bw":"maA humo EuduwlN wal`kino EuduwlN","text_ar":"مَا هُمْ عُدُولٌ وَلٰكِنْ عُدُولٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"They are not witnesses whose testimony is approvable, but equalized loads of merchandise"},{"kind":"text","text":"]. (TA.) And [hence also] one says,"},{"kind":"arabic","text_bw":"waqaEa AlmuSoTariEaAni EidolaYo baEiyrK","text_ar":"وَقَعَ المُصْطَرِعَانِ عِدْلَىْ بَعِيرٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The two"},{"kind":"text","text":"["},{"kind":"italic_en","text":"men wrestling"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"fell together, neither of them having thrown down the other."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"EikomN","text_ar":"عِكْمٌ"},{"kind":"text","text":".])"}],"source_refs":["IAar","Zj","O","K","TA","Mgh","Msb","S","Az","Sb","IB"]},{"entry_id":"n28324","headword_ar":"عَدَلٌ","root":"Edl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"equalizing of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"two burdens,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"half-loads, called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EidolaAni","text_ar":"عِدْلَانِ"},{"kind":"text","text":". (IAar, O, K.)"}],"source_refs":[]}]}}