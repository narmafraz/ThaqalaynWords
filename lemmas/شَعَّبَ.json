{"lemma":"شَعَّبَ","slug":"شَعَّبَ","root":"ش.ع.ب","root_slug":"ش-ع-ب","root_link":"/words/roots/ش-ع-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَعَّبْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَعَّبْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَعَّبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَعَّبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَعَّبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَعَّبَ","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَعَّبَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَعَّبا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَعَّبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَعَّبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَعَّبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُشَعِّب","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُشَعِّبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُشَعِّبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُشَعِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشَعِّبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُشَعِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشَعِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشَعِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشَعِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشَعِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشَعِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشَعِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشَعِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشَعِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشَعِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشَعِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشَعِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُشَعِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشَعِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"شَعَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَعَّبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":true,"lemma_key":"شَعَّبَ","root":"شعب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":29},"lanes":{"found":true,"entry_ids":["n22424","n22425","n22429","n22430","n22431","n22432"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B9%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gather, unite"},{"pos":"verb","gloss":"to mend"},{"pos":"verb","gloss":"to disperse"},{"pos":"verb","gloss":"to split, cut"},{"pos":"verb","gloss":"to spoil, injure"},{"pos":"verb","gloss":"to get separated"},{"pos":"verb","gloss":"to leave one's people"},{"pos":"verb","gloss":"to appear"},{"pos":"verb","gloss":"to be broad in the shoulders"},{"pos":"verb","gloss":"to have a large space between the horns"},{"pos":"verb","gloss":"to split, divide, ramify"},{"pos":"verb","gloss":"to beat the tail to the right and left"},{"pos":"noun","gloss":"verbal noun of شَعَبَ (šaʕaba, “to gather, unite”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"tribe, race","examples":[{"text":"يَا أَيُّهَا ٱلنَّاسُ إِنَّا خَلَقْنَاكُم مِنْ ذَكَرٍ وَأُنْثَىٰ وَجَعَلْنَاكُمْ شُعُوبًا وَقَبَائِلَ لِتَعَارَفُوا","english":"O humanity! Indeed, We created you from a male and a female, and made you into peoples and tribes so that you may ˹get to˺ know one another."}]},{"pos":"noun","gloss":"a people, nation"},{"pos":"noun","gloss":"distance"},{"pos":"noun","gloss":"split, cleft"},{"pos":"noun","gloss":"gathering, uniting"},{"pos":"noun","gloss":"mending"},{"pos":"noun","gloss":"dispersing"},{"pos":"noun","gloss":"splitting, cutting"},{"pos":"noun","gloss":"spoiling, injury"},{"pos":"noun","gloss":"getting separated"},{"pos":"noun","gloss":"leaving one's people"},{"pos":"noun","gloss":"appearance (act of appearing)"},{"pos":"noun","gloss":"mountain path, path"},{"pos":"noun","gloss":"cleft, narrow path, valley, watercourse"},{"pos":"noun","gloss":"plural of شعبَة","tags":["form-of","plural"]},{"pos":"noun","gloss":"verbal noun of شَعِبَ (šaʕiba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ʃaʕb/","/ʃiʕb/","/ʃu.ʕab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22424","headword_ar":"شَعَبَ","root":"$Eb","body":[{"kind":"text","text":", (S, Msb,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":", (A, Msb, K,)"},{"kind":"italic_en","text":"He collected; brought, gathered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, together;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"united;"},{"kind":"text","text":"(S, A, Msb, K;) a thing, (S,) any thing or things, and a people or party: (Msb:) and"},{"kind":"italic_en","text":"he separated; put apart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asunder; divided; disunited;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattered;"},{"kind":"text","text":"(S, A, Msb, K;) a thing, (S,) any thing or things, and a people or party: (Msb:) thus having two contr. significations: (S:) so expressly state A'Obeyd and Aboo-Ziyád: (TA:) but accord. to IDrd, it has not two contr. significations [in one and the same dial.]: he says that the two meanings are peculiar to the dials. of two peoples, (Msb, TA, *) each meaning belonging to the dial. of one people exclusively. (TA.) [Hence, as it seems to be indicated in the S and A, or from"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":"meaning “ a tribe, ” as it seems to be indicated in the Ham p. 538,] one says,"},{"kind":"arabic","text_bw":"tafar~aqa $aEobuhumo","text_ar":"تَفَرَّقَ شَعْبُهُمْ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"$at~a $aEobuhumo","text_ar":"شَتَّ شَعْبُهُمْ"},{"kind":"text","text":", (A, Ham,) (tropical:)  ["},{"kind":"italic_en","text":"Their union became dissolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broken up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their tribe became separated;"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"they became separated after being congregated:"},{"kind":"text","text":"(S, Ham:) and"},{"kind":"arabic","text_bw":"AilotaA^ama $aEobuhumo","text_ar":"اِلْتَاَمَ شَعْبُهُمْ"},{"kind":"text","text":"(S, A, Ham) (tropical:)  ["},{"kind":"italic_en","text":"Their separation became closed up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their tribe drew together;"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"they drew together after being separated."},{"kind":"text","text":"(S, Ham.) And"},{"kind":"arabic","text_bw":"$aEabatohumu Almaniy~apu","text_ar":"شَعَبَتْهُمُ المَنِيَّةُ"},{"kind":"italic_en","text":"Death separated them:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"$aEabatohu $aEuwbu","text_ar":"شَعَبَتْهُ شَعُوبُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Death separated him"},{"kind":"text","text":"from his companions]; (TA;) said of a man when he has died. (O in art."},{"kind":"arabic","text_bw":"Ebl","text_ar":"عبل"},{"kind":"text","text":": in the K, in that art., ↓"},{"kind":"arabic","text_bw":"Ai$otaEabatohu","text_ar":"اِشْتَعَبَتْهُ","orth_type":"arrow"},{"kind":"text","text":"[perhaps a mistranscription].) And it is said in a trad.,"},{"kind":"arabic","text_bw":"maA h`*ihi","text_ar":"مَا هٰذِهِ"},{"kind":"arabic","text_bw":"AlfutoyaA A@l~atiY $aEabota bihaA Aln~aAsa","text_ar":"الفُتْيَا ا@لَّتِى شَعَبْتَ بِهَا النَّاسَ"},{"kind":"text","text":"i. e, ["},{"kind":"italic_en","text":"What is this judicial decision"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with which thou hast divided the people?"},{"kind":"text","text":"(S. [In the TA, on the authority of IAth,"},{"kind":"arabic","text_bw":"AltY $agabato fiY Aln~aAsi","text_ar":"التى شَغَبَتْ فِى النَّاسِ"},{"kind":"text","text":", which means, “ which has excited evil among the people. ”]) One says also,"},{"kind":"arabic","text_bw":"$aEaba Alr~ajulu A^amorahu","text_ar":"شَعَبَ الرَّجُلُ اَمْرَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The man broke up, discomposed, deranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorganized,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rendered unsound, impaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred,"},{"kind":"text","text":"(agreeably with another explanation of the verb in what follows,)]"},{"kind":"italic_en","text":"his state of affairs:"},{"kind":"text","text":"(As, A'Obeyd, TA:) whence the saying of 'Alee Ibn-El-'Adheer El-Ghanawee,"},{"kind":"quote","text":"waA_i*aA raA^ayota Almaro'a ya$oEabu A^amorahu\n                      \n                     \n                        $aEoba AlEaSaA wayalaj~u fiY AlEiSoyaAni"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"And when thou seest the man break up his state of affairs as with the breaking up of the staff, and persevere in disobedience,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellion"},{"kind":"text","text":"]. (A'Obeyd, TA.) ―         -b2-  Also, aor, as above, (Msb,) and so the inf. n., (S, A, Msb, K,)"},{"kind":"italic_en","text":"He repaired"},{"kind":"text","text":"a cracked thing [such as a wooden bowl or some other vessel,"},{"kind":"italic_en","text":"by closing up its crack"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cracks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by piecing it:"},{"kind":"text","text":"see 2, which has a similar signification, but implying muchness]: (S, Msb:) and [in a general sense,]"},{"kind":"italic_en","text":"he repaired, mended, amended, adjusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put into a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, state:"},{"kind":"text","text":"(A, K, TA:) and it signifies the contr. also [of the former meaning and] of this, in the same, or in another, dial.: (TA:) [i. e.]"},{"kind":"italic_en","text":"he cracked"},{"kind":"text","text":"a thing [such as a wooden bowl &c.]: (A, Msb:) and"},{"kind":"italic_en","text":"he corrupted, rendered unsound, impaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred."},{"kind":"text","text":"(A, K, TA.)"},{"kind":"arabic","text_bw":"$aEobN SagiyrN mino $aEobK kabiyrK","text_ar":"شَعْبٌ صَغِيرٌ مِنْ شَعْبٍ كَبِيرٍ"},{"kind":"text","text":", occurring in a trad. of 'Omar, means"},{"kind":"italic_en","text":"A little repairing, of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amid, much impairing."},{"kind":"text","text":"(TA.) ―         -b3-  ["},{"kind":"italic_en","text":"He gave"},{"kind":"text","text":"a portion of property; as though he broke it off.] One says,"},{"kind":"arabic","text_bw":"Ai$oEabo liY $uEobapF mina AlmaAli","text_ar":"اِشْعَبْ لِى شُعْبَةً مِنَ المَالِ"},{"kind":"italic_en","text":"Give thou to me a portion of the property."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the commander, or prince, S)"},{"kind":"italic_en","text":"sent"},{"kind":"text","text":"a messenger (S, K)"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to him"},{"kind":"text","text":"], (K,) or"},{"kind":"arabic","text_bw":"A_ilaY mawoDiEi ka*aA","text_ar":"اـِلَى مَوْضِعِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to such a place"},{"kind":"text","text":"]. (S.) ―         -b5-"},{"kind":"italic_en","text":"He turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent,"},{"kind":"text","text":"him, or it,"},{"kind":"italic_en","text":"away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back:"},{"kind":"text","text":"(K, TA:) aor. and inf.n. as above. (TA.) And"},{"kind":"arabic","text_bw":"$aEaba All~ijaAmu Alfarasa","text_ar":"شَعَبَ اللِّجَامُ الفَرَسَ"},{"kind":"italic_en","text":"The bridle turned away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restrained, the horse from the direction towards which he was going."},{"kind":"text","text":"(K.) ―         -b6-"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, diverted"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"by occupying him, busying him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"engaging his attention."},{"kind":"text","text":"(K, TA.) One says,"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"$aEabaka Ean~iY","text_ar":"شَعَبَكَ عَنِّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What diverted thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what has diverted thee,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from me?"},{"kind":"text","text":"]. (TA.)       -A2-  It is also intrans.: see 4. ―         -b2-  [Thus it signifies"},{"kind":"italic_en","text":"He quitted his companions, desiring others."},{"kind":"text","text":"] One says,"},{"kind":"arabic","text_bw":"$aEaba A_ilayohimo","text_ar":"شَعَبَ اـِلَيْهِمْ"},{"kind":"text","text":"(K, TA)"},{"kind":"arabic","text_bw":"fiY Eadadi ka*aA","text_ar":"فِى عَدَدِ كَذَا"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"He yearned towards them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with such a number"},{"kind":"text","text":"of men],"},{"kind":"italic_en","text":"and quitted his companions."},{"kind":"text","text":"(K, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, appeared"},{"kind":"text","text":"[distinct from others]: (K, TA:) whence the month ["},{"kind":"arabic","text_bw":"$aEobaAn","text_ar":"شَعْبَان"},{"kind":"text","text":", q. v.,] is [said to be] named. (TA.)       -A3-  Also, (K, TA,) aor. and inf. n. as above, (TA,) said of a camel,"},{"kind":"italic_en","text":"He cropped"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AihotaDama","text_ar":"اِهْتَضَمَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the upper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uppermost, parts of trees"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shrubs"},{"kind":"text","text":"]. (K, TA.)       -A4-"},{"kind":"arabic","text_bw":"$aEiba","text_ar":"شَعِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"$aEabN","text_ar":"شَعَبٌ"},{"kind":"text","text":", (S, * K, * TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a goat, S, TA, and a gazelle, TA)"},{"kind":"italic_en","text":"was wide,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"very wide,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"between the horns,"},{"kind":"text","text":"(S, K,) and"},{"kind":"italic_en","text":"between the shoulders."},{"kind":"text","text":"(K, * TA.) [See also"},{"kind":"arabic","text_bw":"$aEabN","text_ar":"شَعَبٌ"},{"kind":"text","text":", below.]"}],"source_refs":["S","Msb","A","K","TA","Ham"]},{"entry_id":"n22425","headword_ar":"شعّب","root":"$Eb","body":[{"kind":"text","text":"[app. signifies"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"several things; or"},{"kind":"italic_en","text":"he collected much:"},{"kind":"text","text":"and]"},{"kind":"italic_en","text":"he separated"},{"kind":"text","text":"several things; or"},{"kind":"italic_en","text":"he separated much."},{"kind":"text","text":"(O.) ―         -b2-  Also"},{"kind":"italic_en","text":"He repaired"},{"kind":"text","text":"a cracked wooden bowl [or some other vessel]"},{"kind":"italic_en","text":"in several places"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by closing up its cracks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by piecing it"},{"kind":"text","text":"]: (S, O:) [and app., in a general sense,"},{"kind":"italic_en","text":"he repaired, mended, amended, adjusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put into a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, state,"},{"kind":"text","text":"several things; or"},{"kind":"italic_en","text":"he repaired,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"much:"},{"kind":"text","text":"and it seems to signify also the contr. of these two meanings: i. e."},{"kind":"italic_en","text":"he cracked"},{"kind":"text","text":"several things; or"},{"kind":"italic_en","text":"he cracked in several places:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he corrupted, rendered unsound, impaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred,"},{"kind":"text","text":"several things; or"},{"kind":"italic_en","text":"he corrupted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"much."},{"kind":"text","text":"]       -A2-  It is also intrans.: see 4. ―         -b2-  Thus, said of seed-produce,"},{"kind":"italic_en","text":"It branched forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forked, after being in leaf,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blade;"},{"kind":"text","text":"(TA;) like ↓"},{"kind":"arabic","text_bw":"t$E~b","text_ar":"تشعّب","orth_type":"arrow"},{"kind":"text","text":". (K, * TA.) [Hence,] one says,"},{"kind":"arabic","text_bw":"A_in~iY A^araY Al$~ar~a $aE~aba","text_ar":"اـِنِّى اَرَى الشَّرَّ شَعَّبَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Verily I see the evil to have grown like seed-produce when it branches forth"},{"kind":"text","text":"]; like as one says,"},{"kind":"arabic","text_bw":"qaS~aba","text_ar":"قَصَّبَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"nab~aba","text_ar":"نَبَّبَ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"nb","text_ar":"نب"},{"kind":"text","text":".)"}],"source_refs":["S","O"]},{"entry_id":"n22429","headword_ar":"شَعْبٌ","root":"$Eb","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"$aEaba","text_ar":"شَعَبَ"},{"kind":"text","text":"[q. v.]. (Msb.) ―         -b2-  [Used as a simple subst., it signifies"},{"kind":"italic_en","text":"Collection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"union:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"separation, division,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunion;"},{"kind":"text","text":"and]"},{"kind":"italic_en","text":"a state of separation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"division"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunion;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"$uEobapN","text_ar":"شُعْبَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, TA:) pl. of the former"},{"kind":"arabic","text_bw":"$uEuwbN","text_ar":"شُعُوبٌ"},{"kind":"text","text":". (TA.) ―         -b3-  And [hence, perhaps, as implying both union and division,]"},{"kind":"italic_en","text":"Such as is divided"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into sub-tribes"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"of the tribes of the Arabs and foreigners:"},{"kind":"text","text":"(S: [in my copy of the Msb,"},{"kind":"arabic","text_bw":"mA Anqsmt fyh qbAy^l AlErb","text_ar":"ما انقسمت فيه قبايل العرب"},{"kind":"text","text":", as though it meant the tribes of the Arabs collectively, agreeably with another explanation to be mentioned below; but I think that there may be a mistranscription in this case:]) pl."},{"kind":"arabic","text_bw":"$uEuwbN","text_ar":"شُعُوبٌ"},{"kind":"text","text":": (S, Msb:) or it signifies, as some say, (Msb,) or signifies also, (S,)"},{"kind":"italic_en","text":"a great tribe;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qabiylapN EaZiymapN","text_ar":"قَبِيلَةٌ عَظِيمَةٌ"},{"kind":"text","text":", (S, A, K,) or"},{"kind":"arabic","text_bw":"HaY~N EaZiymN","text_ar":"حَىٌّ عَظِيمٌ"},{"kind":"text","text":"; (Msb;) the"},{"kind":"italic_en","text":"parent of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tribes called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qabaAy^il","text_ar":"قَبَايِل"},{"kind":"text","text":","},{"kind":"italic_en","text":"to which they refer their origin, and which comprises them:"},{"kind":"text","text":"(S:) or, as some say,"},{"kind":"italic_en","text":"a great tribe"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"HaY~N EaZiymN","text_ar":"حَىٌّ عَظِيمٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"forming a branch of a"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"italic_en","text":"itself:"},{"kind":"text","text":"(TA:) A' Obeyd says, on the authority of Ibn-El-Kelbee, on the authority of his father, that the"},{"kind":"arabic","text_bw":"$aEob","text_ar":"شَعْب"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"greater than the"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"text","text":"; next to which is the"},{"kind":"arabic","text_bw":"faSiylap","text_ar":"فَصِيلَة"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"EamaArap","text_ar":"عَمَارَة"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"faxi*","text_ar":"فَخِذ"},{"kind":"text","text":": (S, TA:) but IB says that the true order is that which Ez-Zubeyr Ibn-Bekkár has stated, and is as follows: (TA:) [i. e.] the genealogies of the Arabs consist of six degrees; (Msb;) first, the"},{"kind":"arabic","text_bw":"$aEob","text_ar":"شَعْب"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"EamaArap","text_ar":"عَمَارَة"},{"kind":"text","text":", (Msb, TA,) with fet-h and with kesr, to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"; (Msb;) then, the"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"text","text":"; then, the"},{"kind":"arabic","text_bw":"faxi*","text_ar":"فَخِذ"},{"kind":"text","text":"; and then, the"},{"kind":"arabic","text_bw":"faSylap","text_ar":"فَصيلَة"},{"kind":"text","text":": thus, Khuzeymeh is a"},{"kind":"arabic","text_bw":"$Eb","text_ar":"شعب"},{"kind":"text","text":"; and Kináneh, a"},{"kind":"arabic","text_bw":"qbylap","text_ar":"قبيلَة"},{"kind":"text","text":"; and Kureysh, an"},{"kind":"arabic","text_bw":"EmArp","text_ar":"عمارة"},{"kind":"text","text":"; and Kuseí, a"},{"kind":"arabic","text_bw":"bTn","text_ar":"بطن"},{"kind":"text","text":"; and Háshim, a"},{"kind":"arabic","text_bw":"fx*","text_ar":"فخذ"},{"kind":"text","text":"; and El-'Abbás, a"},{"kind":"arabic","text_bw":"fSylp","text_ar":"فصيلة"},{"kind":"text","text":": (Msb, TA:) and Aboo-Usámeh says that these classes are agreeable with the order obtaining in the structure of man; the"},{"kind":"arabic","text_bw":"$Eb","text_ar":"شعب"},{"kind":"text","text":"is the greatest of them, derived from the"},{"kind":"arabic","text_bw":"$aEob","text_ar":"شَعْب"},{"kind":"text","text":"[or suture] of the head; next is the"},{"kind":"arabic","text_bw":"qbylp","text_ar":"قبيلة"},{"kind":"text","text":", from the"},{"kind":"arabic","text_bw":"qbylp","text_ar":"قبيلة"},{"kind":"text","text":"[which is a term applied to any one of the four principal bones] of the head; then, the"},{"kind":"arabic","text_bw":"EmArp","text_ar":"عمارة"},{"kind":"text","text":", which is the breast; then, the"},{"kind":"arabic","text_bw":"bTn","text_ar":"بطن"},{"kind":"text","text":"[or belly]; then, the"},{"kind":"arabic","text_bw":"fx*","text_ar":"فخذ"},{"kind":"text","text":"[or thigh]; and then, the"},{"kind":"arabic","text_bw":"fSylp","text_ar":"فصيلة"},{"kind":"text","text":", which is the shank: to these some add the"},{"kind":"arabic","text_bw":"Ea$ityrap","text_ar":"عَشِتيرَة"},{"kind":"text","text":", which consists of few in comparison with what are before mentioned: (TA:) and some add after this the"},{"kind":"arabic","text_bw":"rahoT","text_ar":"رَهْط"},{"kind":"text","text":": some also add the"},{"kind":"arabic","text_bw":"ji*om","text_ar":"جِذْم"},{"kind":"text","text":"before the"},{"kind":"arabic","text_bw":"$Eb","text_ar":"شعب"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"bTn","text_ar":"بطن"},{"kind":"text","text":":) the pl. is as above. (TA.) It signifies also"},{"kind":"italic_en","text":"A nation, people, race,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"family of mankind;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jiylN","text_ar":"جِيلٌ"},{"kind":"text","text":"; as expl. by IM and others: in the K, [and in a copy of the A,] erroneously,"},{"kind":"arabic","text_bw":"jabal","text_ar":"جَبَل"},{"kind":"text","text":"[a mountain]: (TA:) but it is [strangely] said by Aboo-'Obeyd El-Bekree that accord. to all except Bundár, the word in this sense is ↓"},{"kind":"arabic","text_bw":"$iEobN","text_ar":"شِعْبٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr. (MF.) And the pl.,"},{"kind":"arabic","text_bw":"$uEuwbN","text_ar":"شُعُوبٌ"},{"kind":"text","text":", is [said to be] especially applied to denote the"},{"kind":"italic_en","text":"foreigners"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlEajam","text_ar":"العَجَم"},{"kind":"text","text":"): (TA:) [thus it is said that] the phrase, in a trad.,"},{"kind":"arabic","text_bw":"A_in~a rajulFA mina Al$~uEuwbi","text_ar":"اـِنَّ رَجُلًا مِنَ الشُّعُوبِ"},{"kind":"arabic","text_bw":"A^asolama","text_ar":"اَسْلَمَ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"Verily a man"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the foreigners"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlEajam","text_ar":"العَجَم"},{"kind":"text","text":") ["},{"kind":"italic_en","text":"became a Muslim:"},{"kind":"text","text":"but see"},{"kind":"arabic","text_bw":"Al$~uEuwbiy~apu","text_ar":"الشُّعُوبِيَّةُ"},{"kind":"text","text":"]. (S.) ―         -b4-  Also, [as implying separation,]"},{"kind":"italic_en","text":"Distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remoteness."},{"kind":"text","text":"(A, K.) So in the phrase"},{"kind":"arabic","text_bw":"$aEobu","text_ar":"شَعْبُ"},{"kind":"arabic","text_bw":"Ald~aAri","text_ar":"الدَّارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remoteness, of the abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling"},{"kind":"text","text":"]. (TA.) ―         -b5-  And"},{"kind":"italic_en","text":"A crack"},{"kind":"text","text":"(S, A, K, TA) in a thing, (S,) which the"},{"kind":"arabic","text_bw":"$aE~aAb","text_ar":"شَعَّاب"},{"kind":"text","text":"repairs. (S, * TA.) ―         -b6-  And The"},{"kind":"italic_en","text":"place of junction"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"suture"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"qabaAy^il","text_ar":"قَبَايِل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"principal bones"},{"kind":"text","text":"] of the head; (K;) the"},{"kind":"arabic","text_bw":"$aA^on","text_ar":"شَاْن"},{"kind":"italic_en","text":"which conjoins the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":"of the head: the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":"in the head being [the frontal bone, the occipital bone, and the two parietal bones; in all,] four in number. (S.) ―         -b7-  [Hence, perhaps,]"},{"kind":"arabic","text_bw":"humaA $aEobaAni","text_ar":"هُمَا شَعْبَانِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They two are likes"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"like each other"},{"kind":"text","text":"]. (S.) ―         -b8-  See also"},{"kind":"arabic","text_bw":"$iEobN","text_ar":"شِعْبٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"Distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote;"},{"kind":"text","text":"(K;) as in the phrase"},{"kind":"arabic","text_bw":"maA='N","text_ar":"مَا=ءٌ"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, water"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"$uEuwbN","text_ar":"شُعُوبٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","TA","Msb","A","K"]},{"entry_id":"n22430","headword_ar":"شُعْبٌ","root":"$Eb","body":[{"kind":"text","text":": see the dual"},{"kind":"arabic","text_bw":"$uEobaAni","text_ar":"شُعْبَانِ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"$uEobapN","text_ar":"شُعْبَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n22431","headword_ar":"شِعْبٌ","root":"$Eb","body":[{"kind":"italic_en","text":"A road:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a road in a mountain:"},{"kind":"text","text":"(S, A, O, L, Msb, K:) primarily"},{"kind":"italic_en","text":"a road in a mountain"},{"kind":"text","text":"(Har p. 29) and"},{"kind":"italic_en","text":"in valleys:"},{"kind":"text","text":"(Id. p. 72:) afterwards applied to"},{"kind":"italic_en","text":"any road:"},{"kind":"text","text":"(Id. p. 29:) [see also"},{"kind":"arabic","text_bw":"ma$oEabN","text_ar":"مَشْعَبٌ"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"$iEaAbN","text_ar":"شِعَابٌ"},{"kind":"text","text":". (S, O, Msb.) And"},{"kind":"italic_en","text":"A water-course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place in which water flows, in"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, tract, such as is called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"italic_en","text":"of land,"},{"kind":"text","text":"(ISh, A, O, K,)"},{"kind":"italic_en","text":"having two elevated borders, and in width equal to the stature of a man lying down, and sometimes between the two faces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acclivities, of two mountains."},{"kind":"text","text":"(ISh, O.) Or it signifies, (K,) or signifies also, (A,)"},{"kind":"italic_en","text":"A ravine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gap,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pass,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between two mountains."},{"kind":"text","text":"(A, K.) ―         -b2-  Also ["},{"kind":"italic_en","text":"A reef of rocks in the sea:"},{"kind":"text","text":"so in the present day: or]"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"zirobap","text_ar":"زِرْبَة"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"zarabap","text_ar":"زَرَبَة"},{"kind":"text","text":"(accord. to different copies of the K in art."},{"kind":"arabic","text_bw":"jhn","text_ar":"جهن"},{"kind":"text","text":"[but neither of these two words do I find in their proper art. in any Lex.])"},{"kind":"italic_en","text":"in the sea, such as is connected with the shore:"},{"kind":"text","text":"if not connected with the shore, a bowshot distant, it is called"},{"kind":"arabic","text_bw":"juhonN","text_ar":"جُهْنٌ"},{"kind":"text","text":". (K and TA in art."},{"kind":"arabic","text_bw":"jhn","text_ar":"جهن"},{"kind":"text","text":".) ―         -b3-  And"},{"kind":"italic_en","text":"A brand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mark made with a hot iron,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"upon camels,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"peculiar to the Benoo-Minkar, in form resembling the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hooked stick called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"miHojan","text_ar":"مِحْجَن"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"a brand upon the thigh, lengthwise,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"consisting of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"two lines meeting at the top and separated at the bottom:"},{"kind":"text","text":"(ISh, TA:) or"},{"kind":"italic_en","text":"a brand united"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at the upper part and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"at the lower part separated:"},{"kind":"text","text":"(Aboo-' Alee in the “ Tedhkireh, ” TA: [but there is an omission here, so that the reverse may perhaps be meant:]) or"},{"kind":"italic_en","text":"a brand upon the neck, like the"},{"kind":"arabic","text_bw":"miHojan","text_ar":"مِحْجَن"},{"kind":"text","text":": (Suh in the R, TA:) in a marginal note in the copy of the L, it is said that"},{"kind":"arabic","text_bw":"$Eb","text_ar":"شعب"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"a brand"},{"kind":"text","text":"is with kesr to the"},{"kind":"arabic","text_bw":"$","text_ar":"ش"},{"kind":"text","text":"and with fet-h [i. e."},{"kind":"arabic","text_bw":"$iEobN","text_ar":"شِعْبٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ","orth_type":"arrow"},{"kind":"text","text":"]. (TA.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":". ―         -b5-  [And see the pl."},{"kind":"arabic","text_bw":"$iEaAbN","text_ar":"شِعَابٌ"},{"kind":"text","text":"below.]"}],"source_refs":["Msb","S","A","O","L","K","ISh","TA"]},{"entry_id":"n22432","headword_ar":"شَعَبٌ","root":"$Eb","body":[{"kind":"italic_en","text":"Width,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distance,"},{"kind":"text","text":"(A, K,) or"},{"kind":"italic_en","text":"great width"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distance,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"between the horns"},{"kind":"text","text":"(S, A, K) of a goat (S, TA) and of a gazelle, (TA,) and"},{"kind":"italic_en","text":"between the shoulders,"},{"kind":"text","text":"(A, K,) and"},{"kind":"italic_en","text":"between two branches."},{"kind":"text","text":"(A.) [See also 1, last signification.]"}],"source_refs":["A","K","S","TA"]}]}}