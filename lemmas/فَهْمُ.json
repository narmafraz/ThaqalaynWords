ntrinsic"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"things:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a condition of the mind whereby it ascertains what is approvable:"},{"kind":"text","text":"or, as in the “ Ahkám ” of El- Ámidee,"},{"kind":"italic_en","text":"excellence of intelligence in respect of its readiness to apprehend quickly subjects of inquiry that present themselves to it."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb"]},{"entry_id":"n34742","headword_ar":"فَهِمٌ","root":"fhm","body":[{"kind":"text","text":", an epithet applied to a man, (S,)"},{"kind":"italic_en","text":"Quick of understanding;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sariyEu Alfahomi","text_ar":"سَرِيعُ الفَهْمِ"},{"kind":"text","text":". (K.)"}],"source_refs":["S"]}]}}