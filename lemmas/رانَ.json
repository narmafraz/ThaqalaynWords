": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "present_1ms", "form": "أَرِين", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَرِين", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 24, "cross_references": {"qac": {"found": true, "lemma_key": "رانَ", "root": "رين", "pos": "V", "occurrence_count": 1}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 3}, "lanes": {"found": true, "entry_ids": ["n17151", "n17307", "n17309"], "search_url": "https://lanelexicon.com/?s=%D8%B1%D8%A7%D9%86%D9%8E"}}, "translations": {"en": "to cover", "fa": "پوشاند", "ur": "ڈھکنا", "tr": "örtmek", "id": "menutupi", "bn": "ঢাকা", "es": "cubrir", "fr": "couvrir", "de": "bedecken", "ru": "покрывать", "zh": "覆盖"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to take possession of"}, {"pos": "verb", "gloss": "to seize, to overcome [with عَلَى (ʕalā) or بِ (bi) or accusative ‘someone’] (of passion or other intense emotion)"}, {"pos": "verb", "gloss": "to prevail [with عَلَى (ʕalā) ‘somewhere’] (e.g. of silence)"}]}, "etymology": null, "ipa": ["/raː.na/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n17151", "headword_ar": "رَانَ", "root": "rwn", "body": [{"kind": "text", "text": ", [aor."}, {"kind": "arabic", "text_bw": "yaruwnu", "text_ar": "يَرُونُ"}, {"kind": "text", "text": ",] inf. n."}, {"kind": "arabic", "text_bw": "rawonN", "text_ar": "رَوْنٌ"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(an affair, or event,)"}, {"kind": "italic_en", "text": "was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, hard, difficult,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "severe."}, {"kind": "text", "text": "(TA.) ―         -b2-  And"}, {"kind": "arabic", "text_bw": "raAnato layolatunaA", "text_ar": "رَانَتْ لَيْلَتُنَا"}, {"kind": "italic_en", "text": "Our night was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, very cloudy and hot."}, {"kind": "text", "text": "(Th, M, TA.)       -A2-  See also"}, {"kind": "arabic", "text_bw": "raAna", "text_ar": "رَانَ"}, {"kind": "text", "text": "in art."}, {"kind": "arabic", "text_bw": "ryn", "text_ar": "رين"}, {"kind": "text", "text": "."}], "source_refs": []}, {"entry_id": "n17307", "headword_ar": "رَانَ", "root": "ryn", "body": [{"kind": "text", "text": ", [aor."}, {"kind": "arabic", "text_bw": "yariynu", "text_ar": "يَرِينُ"}, {"kind": "text", "text": ",] inf. n."}, {"kind": "arabic", "text_bw": "rayonN", "text_ar": "رَيْنٌ"}, {"kind": "text", "text": ", [in its primary acceptation, app. signifies"}, {"kind": "italic_en", "text": "It was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, rusty,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "covered with rust."}, {"kind": "text", "text": "And hence,]"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a garment, or piece of cloth,)"}, {"kind": "italic_en", "text": "was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, dirty,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "filthy;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "taTab~aEa", "text_ar": "تَطَبَّعَ"}, {"kind": "text", "text": ". (M, TA.) ―         -b2-  [Hence also,]"}, {"kind": "arabic", "text_bw": "rAnt", "text_ar": "رانت"}, {"kind": "arabic", "text_bw": "nafosahu", "text_ar": "نَفْسَهُ"}, {"kind": "text", "text": ", (S, M, K, *) aor."}, {"kind": "arabic", "text_bw": "tariynu", "text_ar": "تَرِينُ"}, {"kind": "text", "text": ", inf. n. as above, (S,)"}, {"kind": "italic_en", "text": "His soul"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "stomach"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "became heavy;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "heaved,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became agitated by a tendency to vomit;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "gavato", "text_ar": "غَثَتْ"}, {"kind": "text", "text": ", (S, M, K,) and"}, {"kind": "arabic", "text_bw": "xabuvato", "text_ar": "خَبُثَتْ"}, {"kind": "text", "text": ". (S, K.) ―         -b3-  And"}, {"kind": "arabic", "text_bw": "rAn", "text_ar": "ران"}, {"kind": "arabic", "text_bw": "Ealayohi", "text_ar": "عَلَيْهِ"}, {"kind": "text", "text": ", (A'Obeyd, T, S, M, Mgh, Msb, K,) aor. and inf. n. as above, (Msb,)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(anything)"}, {"kind": "italic_en", "text": "covered it;"}, {"kind": "text", "text": "namely, a thing: (M:) or"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(anything)"}, {"kind": "italic_en", "text": "overcame him;"}, {"kind": "text", "text": "(A'Obeyd, T, S, M, * Mgh, Msb, K;) as also"}, {"kind": "arabic", "text_bw": "rAn bihi", "text_ar": "ران بِهِ"}, {"kind": "text", "text": "; (A'Obeyd, T, S, Mgh, K;) and"}, {"kind": "arabic", "text_bw": "raAnahu", "text_ar": "رَانَهُ"}, {"kind": "text", "text": ". (A'Obeyd, S, Mgh, K.) [And"}, {"kind": "arabic", "text_bw": "raAna", "text_ar": "رَانَ"}, {"kind": "text", "text": "with"}, {"kind": "arabic", "text_bw": "yaruwnu", "text_ar": "يَرُونُ"}, {"kind": "text", "text": "for its aor. signifies the same; as will be seen from a verse cited below.] You say of a sin, misdeed, or transgression, ("}, {"kind": "arabic", "text_bw": "*anob", "text_ar": "ذَنْب"}, {"kind": "text", "text": ",)"}, {"kind": "arabic", "text_bw": "rAn EalaY qalobihi", "text_ar": "ران عَلَى قَلْبِهِ"}, {"kind": "text", "text": ", (Zj, T, S, Mgh, K,) aor. as above, (Zj, T, S,) inf. n."}, {"kind": "arabic", "text_bw": "rayonN", "text_ar": "رَيْنٌ"}, {"kind": "text", "text": "(Zj, T, S, M, K) and"}, {"kind": "arabic", "text_bw": "ruyuwnN", "text_ar": "رُيُونٌ"}, {"kind": "text", "text": ", (S, M, K,)"}, {"kind": "italic_en", "text": "It covered his heart:"}, {"kind": "text", "text": "(Zj, T, M:) or"}, {"kind": "italic_en", "text": "it overcame his heart."}, {"kind": "text", "text": "(S, Mgh, K.)"}, {"kind": "arabic", "text_bw": "raAna EalaY quluwbihimo maA kaAnuwA yakosibwuna", "text_ar": "رَانَ عَلَى قُلُوبِهِمْ مَا كَانُوا يَكْسِبوُنَ"}, {"kind": "text", "text": ", in the Kur [lxxxiii. 14], means ["}, {"kind": "italic_en", "text": "What they used to do"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "hath become like rust upon the clearness of their hearts,"}, {"kind": "text", "text": "so as to make the knowledge of good from evil to be obscured to them: (Er-Rághib, TA:) or"}, {"kind": "italic_en", "text": "hath covered their hearts:"}, {"kind": "text", "text": "(Zj, T:) or"}, {"kind": "italic_en", "text": "hath overcome their hearts:"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "hath spread a blackness upon their hearts;"}, {"kind": "text", "text": "for,] accord. to El-Hasan, it means that sin has followed upon sin so that the heart has become black: (S:) and accord. to Aboo-Mo'adh the Grammarian, and a saying of the Prophet,"}, {"kind": "arabic", "text_bw": "Alr~ayonu", "text_ar": "الرَّيْنُ"}, {"kind": "text", "text": "means the heart's"}, {"kind": "italic_en", "text": "becoming black in consequence of sins."}, {"kind": "text", "text": "(T.) You say also,"}, {"kind": "arabic", "text_bw": "riyna EalY qalobihi", "text_ar": "رِينَ عَلى قَلْبِهِ"}, {"kind": "italic_en", "text": "His heart became covered"}, {"kind": "text", "text": "[&c.]. (M.) And"}, {"kind": "arabic", "text_bw": "riyna bihi", "text_ar": "رِينَ بِهِ"}, {"kind": "italic_en", "text": "He was overcome:"}, {"kind": "text", "text": "(T, Mgh:) or"}, {"kind": "italic_en", "text": "his property was beset by debt:"}, {"kind": "text", "text": "(T:) or"}, {"kind": "italic_en", "text": "he fell into grief, by reason of debt:"}, {"kind": "text", "text": "(M:) or"}, {"kind": "italic_en", "text": "he fell into that from which he could not escape,"}, {"kind": "text", "text": "(AZ, T, S, Mgh, K,)"}, {"kind": "italic_en", "text": "and with which he had not power to cope:"}, {"kind": "text", "text": "(AZ, T, S:) or"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "AunoquTiEa bihi", "text_ar": "اُنْقُطِعَ بِهِ"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "he became disabled from prosecuting his journey, his means having failed him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "his beast breaking down with him"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "perishing"}, {"kind": "text", "text": "]; (T, S, M;) so says El-Kanánee El-Aarábee: (T, S:) and"}, {"kind": "italic_en", "text": "he died."}, {"kind": "text", "text": "(M.) And"}, {"kind": "arabic", "text_bw": "raAnato bihi Alxamoru", "text_ar": "رَانَتْ بِهِ الخَمْرُ"}, {"kind": "text", "text": ", (T,) or"}, {"kind": "arabic", "text_bw": "rAnt Ealayohi Alxamoru", "text_ar": "رانت عَلَيْهِ الخَمْرُ"}, {"kind": "text", "text": ", (S, M, [in one copy of the S"}, {"kind": "arabic", "text_bw": "AlHum~aY", "text_ar": "الحُمَّى"}, {"kind": "text", "text": ",])"}, {"kind": "italic_en", "text": "The wine overcame him;"}, {"kind": "text", "text": "(S, M;) and"}, {"kind": "italic_en", "text": "overwhelmed him:"}, {"kind": "text", "text": "(M:) or"}, {"kind": "italic_en", "text": "overcame his heart and his reason:"}, {"kind": "text", "text": "(T:) and in like manner one says of drowsiness, and of anxiety; by way of comparison. (M.) And"}, {"kind": "arabic", "text_bw": "rAn Aln~uEaAsu fiY AlEayoni", "text_ar": "ران النُّعَاسُ فِى العَيْنِ"}, {"kind": "italic_en", "text": "Drowsiness overcame the eye:"}, {"kind": "text", "text": "(S, TA: *) or"}, {"kind": "italic_en", "text": "infected,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pervaded, the eye."}, {"kind": "text", "text": "(Msb.) Et-Tirimmáh says,"}, {"kind": "quote", "text": "maxaAfapa A^ano yaruwna Aln~awomu fiyhimo\n                      \n                     \n                        bisukori sinaAtihimo kul~a Alr~uyuwni"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "In fear that sleep might overcome them, by reason of the intoxication of their sensations of drowsiness, with every degree of overcoming"}, {"kind": "text", "text": "]. (TA. [This, together with a signification assigned to"}, {"kind": "arabic", "text_bw": "maruwna", "text_ar": "مَرُونَ"}, {"kind": "text", "text": "in art."}, {"kind": "arabic", "text_bw": "rwn", "text_ar": "رون"}, {"kind": "text", "text": "in the K, shows that"}, {"kind": "arabic", "text_bw": "raAna", "text_ar": "رَانَ"}, {"kind": "text", "text": "signifying “ he, or it, overcame, ” &c., has"}, {"kind": "arabic", "text_bw": "yaruwna", "text_ar": "يَرُونَ"}, {"kind": "text", "text": "as well as"}, {"kind": "arabic", "text_bw": "yariynu", "text_ar": "يَرِينُ"}, {"kind": "text", "text": "for its aor.]) And you say also,"}, {"kind": "arabic", "text_bw": "rAn Ealayohi Almawotu", "text_ar": "ران عَلَيْهِ المَوْتُ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "rAn bihi", "text_ar": "ران بِهِ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "Death took him away."}, {"kind": "text", "text": "(M.)"}], "source_refs": ["S", "M", "K", "Msb", "Zj", "T", "Mgh", "AZ"]}, {"entry_id": "n17309", "headword_ar": "رَانٌ", "root": "ryn", "body": [{"kind": "text", "text": ": see the next paragraph.       -A2-  Also ["}, {"kind": "italic_en", "text": "A kind of legging;"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "a thing like a"}, {"kind": "arabic", "text_bw": "xuf~", "text_ar": "خُفّ"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "boot"}, {"kind": "text", "text": "],"}, {"kind": "italic_en", "text": "but longer, and without 