per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُقْضَى","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُقْضَى","in_corpus":true,"count":21,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"قَضَيْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَضَيْتُ","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَقْضِي","in_corpus":true,"count":17,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقْضِي","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":668,"cross_references":{"qac":{"found":true,"lemma_key":"قَضَى","root":"قضي","pos":"V","occurrence_count":59},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n42704"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B6%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of قَضَى (qaḍā) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42704","headword_ar":"قَضَى","root":"qDY","body":[{"kind":"italic_en","text":"He finished"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"entirely, by word,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by deed."},{"kind":"text","text":"This is the primary meaning. (Bd, ii. 111.)"},{"kind":"italic_en","text":"By word, as in"},{"kind":"arabic","text_bw":"waqaDaY rab~uka","text_ar":"وَقَضَى رَبُّكَ"},{"kind":"text","text":"(Idem, ibid.)"},{"kind":"italic_en","text":"And thy Lord hath commanded decisively."},{"kind":"text","text":"(Idem, xvii. 24.) And"},{"kind":"italic_en","text":"by deed, as in"},{"kind":"arabic","text_bw":"faqaDaAhun~a","text_ar":"فَقَضَاهُنَّ"},{"kind":"arabic","text_bw":"saboEa sam`waAtK","text_ar":"سَبْعَ سَمٰوَاتٍ"},{"kind":"text","text":"[Kur, xli. 11,"},{"kind":"italic_en","text":"And he completed them seven heavens"},{"kind":"text","text":"]. (Idem, ii. 11.) ―         -b2-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"desired"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"so as to necessitate its being."},{"kind":"text","text":"(Idem, ii. 11.) ―         -b3-"},{"kind":"arabic","text_bw":"A_i*aA qaDaY A^amorFA","text_ar":"اـِذَا قَضَى اَمْرًا"},{"kind":"text","text":", [Kur, ii. 111,]"},{"kind":"italic_en","text":"When He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"desireth a thing to be."},{"kind":"text","text":"(Bd, Jel.) ―         -b4-  [Thus it signifies"},{"kind":"italic_en","text":"He decreed"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"ordained it; pronounced"},{"kind":"text","text":"it; or"},{"kind":"italic_en","text":"decided"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"judicially."},{"kind":"text","text":"] ―         -b5-"},{"kind":"arabic","text_bw":"qaDaY Ealayohi","text_ar":"قَضَى عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaDaA='N","text_ar":"قَضَا=ءٌ"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"He decided judicially,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judged, against him;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bayona AlxaSomayoni","text_ar":"بَيْنَ الخَصْمَيْنِ"},{"kind":"italic_en","text":"between the two litigants."},{"kind":"text","text":"(TA.) See"},{"kind":"arabic","text_bw":"qadorN","text_ar":"قَدْرٌ"},{"kind":"text","text":". ―         -b6-  ["},{"kind":"italic_en","text":"He completed; accomplished;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fully performed;"},{"kind":"text","text":"a thing.] ―         -b7-"},{"kind":"arabic","text_bw":"qaDaY","text_ar":"قَضَى"},{"kind":"italic_en","text":"He attained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished,"},{"kind":"text","text":"his want. (Msb.) ―         -b8-  ["},{"kind":"italic_en","text":"He paid, discharged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied,"},{"kind":"text","text":"a debt, due, claim, or demand.] ―         -b9-"},{"kind":"arabic","text_bw":"qaDayotuhu Haq~ahu","text_ar":"قَضَيْتُهُ حَقَّهُ"},{"kind":"italic_en","text":"I gave him"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"paid him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his due,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"fully."},{"kind":"text","text":"(Har, p. 22.) ―         -b10-"},{"kind":"arabic","text_bw":"qaDaY Eanohu","text_ar":"قَضَى عَنْهُ"},{"kind":"text","text":"(S, K, in art."},{"kind":"arabic","text_bw":"jzY","text_ar":"جزى"},{"kind":"text","text":", &c.)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, payed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, satisfaction; for him."},{"kind":"text","text":"(TK in that art.) And followed by"},{"kind":"arabic","text_bw":"$ayoy^FA","text_ar":"شَيْيًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He paid a thing for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in his stead; gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, it as a satisfaction;"},{"kind":"text","text":"lit. and fig.] (S, TA in that art., and Bd in ii. 45.) See"},{"kind":"arabic","text_bw":"jazaY Eanohu","text_ar":"جَزَى عَنْهُ"},{"kind":"text","text":"; and see a verse cited voce"},{"kind":"arabic","text_bw":"daAna","text_ar":"دَانَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"dyn","text_ar":"دين"},{"kind":"text","text":". ―         -b11-"},{"kind":"italic_en","text":"He finished doing a"},{"kind":"text","text":"thing:"},{"kind":"italic_en","text":"he finished"},{"kind":"text","text":"his prayer. (TA.)"},{"kind":"italic_en","text":"He performed, fulfilled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished,"},{"kind":"text","text":"the pilgrimage, syn."},{"kind":"arabic","text_bw":"A^ad~aY","text_ar":"اَدَّى"},{"kind":"text","text":", (Msb,) and the religions rites and ceremonies of the pilgrimage, (Bd, Jel in ii. 196,) syn."},{"kind":"arabic","text_bw":"qaDaYa bihi","text_ar":"قَضَىَ بِهِ"},{"kind":"text","text":". (Jel, ibid, Msb.) ―         -b12-  You also say,"},{"kind":"arabic","text_bw":"Hakama bihi","text_ar":"حَكَمَ بِهِ"},{"kind":"italic_en","text":"He decreed it;"},{"kind":"text","text":"&c.; like"},{"kind":"arabic","text_bw":"Hakama bihi","text_ar":"حَكَمَ بِهِ"},{"kind":"text","text":": see an ex. voce"},{"kind":"arabic","text_bw":"suloTaAnN","text_ar":"سُلْطَانٌ"},{"kind":"text","text":". ―         -b13-"},{"kind":"arabic","text_bw":"qawoluhu","text_ar":"قَوْلُهُ"},{"kind":"arabic","text_bw":"mam~aA yaqoDiY AlEajaba","text_ar":"مَمَّا يَقْضِى العَجَبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His saying"},{"kind":"text","text":"such a thing"},{"kind":"italic_en","text":"is of the things that induce wonder in the utmost degree"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"jlb","text_ar":"جلب"},{"kind":"text","text":".) See Har, p. 22. ―         -b14-"},{"kind":"arabic","text_bw":"waqaDayonaA A_ilaY baniY A_isrAy^iyla","text_ar":"وَقَضَيْنَا اـِلَى بَنِى اـِسرايِيلَ"},{"kind":"text","text":"(Kur, xvii. 4): see"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":". ―         -b15-"},{"kind":"arabic","text_bw":"qaDuwa","text_ar":"قَضُوَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gazuwa","text_ar":"غَزُوَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"hayuw^a","text_ar":"هَيُوَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"buTuA=na","text_ar":"بُطُا=نَ"},{"kind":"text","text":"; and see"},{"kind":"arabic","text_bw":"TamuEa","text_ar":"طَمُعَ"},{"kind":"text","text":"in the S."}],"source_refs":["God","Msb"]}]}}