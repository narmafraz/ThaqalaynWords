/lanelexicon.com/?s=%D9%84%D9%8E%D8%B9%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to play","examples":[{"text":"الْأَطْفَالُ يَلْعَبُونَ فِي الْحَدِيقَةِ مَعَ أَصْدِقَائِهِم.","english":"The children play in the park with their friends."}]},{"pos":"verb","gloss":"to trick, to cheat"},{"pos":"verb","gloss":"to cause to play, to set in motion"},{"pos":"verb","gloss":"to wag"},{"pos":"noun","gloss":"verbal noun of لَعَبَ (laʕaba) (form I)","tags":["collective","form-of","noun-from-verb"]},{"pos":"noun","gloss":"game","tags":["collective"]},{"pos":"noun","gloss":"sport, amusement, diversion","tags":["collective"]},{"pos":"noun","gloss":"verbal noun of لَعِبَ (laʕiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of لَعِبَ (laʕiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of لَعِبَ (laʕiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"funny, amusing"},{"pos":"noun","gloss":"plural of لُعْبَة (luʕba, “toy”)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to slobber, to drool"},{"pos":"noun","gloss":"verbal noun of لَعَبَ (laʕaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of لَعِبَ (laʕiba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/la.ʕi.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37779","headword_ar":"لَعِبَ","root":"lEb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"laEibN","text_ar":"لَعِبٌ"},{"kind":"text","text":"(which is the original [and most common] form, TA) and"},{"kind":"arabic","text_bw":"liEobN","text_ar":"لِعْبٌ"},{"kind":"text","text":"(S, K: the latter of these inf. ns. contracted from the former, Msb) and"},{"kind":"arabic","text_bw":"laEobN","text_ar":"لَعْبٌ"},{"kind":"text","text":"(K: also contracted from the first: not heard by IKt; but authorized by Mekkee, and, accord. to him,"},{"kind":"page_break","n":2662},{"kind":"text","text":"agreeable with a constant rule, applicable in the case of any word of a similar measure having a guttural letter as its medial radical, whether a noun or verb: (TA:) and"},{"kind":"arabic","text_bw":"A^uloEuwbapN","text_ar":"اُلْعُوبَةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"taloEaAbN","text_ar":"تَلْعَابٌ"},{"kind":"text","text":"; (K; but this last has an intensive, or a frequentative, signification; S;) and ↓"},{"kind":"arabic","text_bw":"lE~b","text_ar":"لعّب","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"tlE~b","text_ar":"تلعّب","orth_type":"arrow"},{"kind":"text","text":"(S, K: but this last has a frequentative [or an intensive] signification; S; [and so too has that immediately preceding it;]) and ↓"},{"kind":"arabic","text_bw":"tlAEb","text_ar":"تلاعب","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He played, sported, gamed, jested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joked: contr. of"},{"kind":"arabic","text_bw":"jad~a","text_ar":"جَدَّ"},{"kind":"text","text":", which signifies “ he was serious, or in earnest. ” (K.) [You say]"},{"kind":"arabic","text_bw":"bayonahumo A^uloEuwbapN","text_ar":"بَيْنَهُمْ اُلْعُوبَةٌ"},{"kind":"italic_en","text":"Between them is playing, sporting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(K.) [And so] ↓"},{"kind":"arabic","text_bw":"laAEabahaA","text_ar":"لَاعَبَهَا","orth_type":"arrow"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"mulaAEabapN","text_ar":"مُلَاعَبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"liEaAbN","text_ar":"لِعَابٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He played, sported, gamed, jested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joked, with her:"},{"kind":"text","text":"(K:) ["},{"kind":"italic_en","text":"he toyed, dallied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wantoned, with her:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"laAEabotu Alr~ajula","text_ar":"لَاعَبْتُ الرَّجُلَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mlAEbp","text_ar":"ملاعبة"},{"kind":"text","text":","},{"kind":"italic_en","text":"I played, &c., with the man."},{"kind":"text","text":"(S) ―         -b2-"},{"kind":"arabic","text_bw":"laEibati Alr~iyHu biAlmanozili","text_ar":"لَعِبَتِ الرِّيحُ بِالمَنْزِلِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"talaAEabat","text_ar":"تَلَاعَبَت","orth_type":"arrow"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"The wind sported with the lighting-place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of abode"},{"kind":"text","text":"]: i. e.,"},{"kind":"italic_en","text":"obliterated the traces of it."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"laEiba","text_ar":"لَعِبَ"},{"kind":"arabic","text_bw":"binaA Almawoju","text_ar":"بِنَا المَوْجُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The waves sported with us"},{"kind":"text","text":"]: the commotion of the waves is called “ sporting ” because it does not convey the voyagers to the quarter whither they desire to go. (TA, from a trad.)       -A2-"},{"kind":"arabic","text_bw":"laEaba","text_ar":"لَعَبَ"},{"kind":"text","text":", (and"},{"kind":"arabic","text_bw":"laEiba","text_ar":"لَعِبَ"},{"kind":"text","text":", K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"laEobN","text_ar":"لَعْبٌ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"AlEb","text_ar":"العب","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child, S)"},{"kind":"italic_en","text":"slavered; drivelled; emitted a flow of slaver"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drivel from his mouth."},{"kind":"text","text":"(S, K.) The first word is the most approved: (TA:) or"},{"kind":"arabic","text_bw":"AlS~abiY~u","text_ar":"الصَّبِىُّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlEb","text_ar":"العب","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the child became slavering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drivelling."},{"kind":"text","text":"(S.)"}],"source_refs":["TA","S","K"]}]}}