=%D8%B9%D9%8E%D8%B7%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lack (مِن (min) something)"},{"pos":"verb","gloss":"to be unemployed, to be idle"},{"pos":"verb","gloss":"to be unadorned"},{"pos":"verb","gloss":"to be tall"},{"pos":"verb","gloss":"to be spoiled, to be no longer of use","tags":["modern"]},{"pos":"verb","gloss":"to neglect"},{"pos":"verb","gloss":"to make unemployed, to leave idle"},{"pos":"verb","gloss":"to damage, to destroy, to devastate, to ruin, to render inoperable"},{"pos":"verb","gloss":"to deprive of one's property"},{"pos":"verb","gloss":"to deprive of adornments"},{"pos":"verb","gloss":"to empty"},{"pos":"verb","gloss":"to free"},{"pos":"verb","gloss":"to hinder"},{"pos":"verb","gloss":"to obstruct"},{"pos":"verb","gloss":"to interrupt"},{"pos":"verb","gloss":"to suspend (a publication)"},{"pos":"verb","gloss":"to turn off (an engine, etc.)"},{"pos":"verb","gloss":"to close (a store, an office, etc.)"},{"pos":"verb","gloss":"to injure, to cause loss (عَلَى (ʕalā) to)","tags":["modern"]},{"pos":"verb","gloss":"to lend at interest","tags":["modern"]},{"pos":"noun","gloss":"verbal noun of عَطِلَ (ʕaṭila, “to lack, to be unemployed, to be unadorned, etc.”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"unemployment"},{"pos":"noun","gloss":"inactivity"},{"pos":"noun","gloss":"inefficiency"},{"pos":"noun","gloss":"lack"},{"pos":"noun","gloss":"absence of adornment, simplicity"},{"pos":"noun","gloss":"holiday, vacation"},{"pos":"noun","gloss":"malfunction, breakdown, failure, damage"}]},"etymology":{"source":"wiktextract","text":"Causative of عَطِلَ (ʕaṭila)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29604","headword_ar":"عُطْلٌ","root":"ETl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":", last sentence."}],"source_refs":[]},{"entry_id":"n29605","headword_ar":"عَطَلٌ","root":"ETl","body":[{"kind":"text","text":"inf. n. of 1 [q. v.]. (S, O, K.)       -A2-  Also The"},{"kind":"italic_en","text":"denuded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unclad, part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, of the body;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jurodapN","text_ar":"جُرْدَةٌ"},{"kind":"text","text":": so in the saying"},{"kind":"arabic","text_bw":"AimoraA^apN Hasanapu","text_ar":"اِمْرَاَةٌ حَسَنَةُ"},{"kind":"arabic","text_bw":"AlEaTali","text_ar":"العَطَلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A woman beautiful in respect of the denuded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unclad, part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, of the body"},{"kind":"text","text":"]. (TA.) ―         -b2-  And The"},{"kind":"italic_en","text":"body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"person;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$axoSN","text_ar":"شَخْصٌ"},{"kind":"text","text":"; (S, O, K, TA;) particularly, as some say, of a human being; (TA;) like"},{"kind":"arabic","text_bw":"TalalN","text_ar":"طَلَلٌ"},{"kind":"text","text":": (S, O, TA:) pl."},{"kind":"arabic","text_bw":"A^aEoTaAlN","text_ar":"اَعْطَالٌ"},{"kind":"text","text":". (K.) And one says,"},{"kind":"arabic","text_bw":"maA A^aHosana EaTalahu","text_ar":"مَا اَحْسَنَ عَطَلَهُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"How beautiful is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his tallness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"justness of stature, and his perfectness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of make"},{"kind":"text","text":"]! (S, O.) ―         -b3-  And The"},{"kind":"italic_en","text":"neck."},{"kind":"text","text":"(K.) ―         -b4-  And"},{"kind":"italic_en","text":"Beauty of body."},{"kind":"text","text":"(TA.)       -A3-  Also"},{"kind":"italic_en","text":"A stalk of a raceme of a palmtree;"},{"kind":"text","text":"(S, O;) as also ↓"},{"kind":"arabic","text_bw":"EaTiylN","text_ar":"عَطِيلٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to IDrd: (O:) or the former, (TA,) and ↓ the latter, accord. to IDrd, and accord. to Az, who says that he heard it from the cultivators of palm-trees ("},{"kind":"arabic","text_bw":"mina Aln~axoliy~iyna","text_ar":"مِنَ النَّخْلِيِّينَ"},{"kind":"text","text":") in El-Ahsà, (O,) the"},{"kind":"italic_en","text":"stalk of a raceme of a male palm-tree,"},{"kind":"text","text":"(O, TA,) to which Az adds,"},{"kind":"italic_en","text":"with which the female palm-tree is fecundated:"},{"kind":"text","text":"(O:) or ↓"},{"kind":"arabic","text_bw":"EaTiylN","text_ar":"عَطِيلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EayoTalN","text_ar":"عَيْطَلٌ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"a stalk of a"},{"kind":"arabic","text_bw":"TaloE","text_ar":"طَلْع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"spadix"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a male palm-tree"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with the flowers upon it"},{"kind":"text","text":"]. (K, TA.)"}],"source_refs":["S","O","TA"]},{"entry_id":"n29606","headword_ar":"عَطِلٌ","root":"ETl","body":[{"kind":"text","text":"["},{"kind":"text","text":"is an epithet of which only the fem. (with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":") is mentioned.] ―         -b2-"},{"kind":"arabic","text_bw":"EaTilapN","text_ar":"عَطِلَةٌ"},{"kind":"text","text":"is applied to a she-camel as meaning"},{"kind":"italic_en","text":"Goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"EaTilaAtN","text_ar":"عَطِلَاتٌ"},{"kind":"text","text":": (S, O:) which is expl. by A 'Obeyd in this sense, and not derived by him: held by ISd to be a possessive epithet: (TA:) or the sing., thus applied,"},{"kind":"italic_en","text":"goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful, in body:"},{"kind":"text","text":"(K:) or thus as applied to a woman: and, applied to a she-camel,"},{"kind":"italic_en","text":"perfect in body and tallness."},{"kind":"text","text":"(TA.) ―         -b3-  Also, applied to a she-camel,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SafiY~N","text_ar":"صَفِىٌّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Abounding in milk;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whose milk lasts throughout the year"},{"kind":"text","text":"]. (K.) And, applied to a ewe or she-goat,"},{"kind":"italic_en","text":"Abounding much in milk:"},{"kind":"text","text":"(K:) or, accord. to Lth,"},{"kind":"italic_en","text":"that is known in"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the appearance of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"her neck to be one abounding in milk."},{"kind":"text","text":"(O.)       -A2-  And, applied to A"},{"kind":"arabic","text_bw":"dalow","text_ar":"دَلْو"},{"kind":"text","text":"[or leathern bucket],"},{"kind":"italic_en","text":"Having its"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thongs called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"wa*am","text_ar":"وَذَم"},{"kind":"italic_en","text":"broken,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"so that it has become exempted from"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taEaT~alato","text_ar":"تَعَطَّلَتْ"},{"kind":"page_break","n":2083},{"kind":"arabic","text_bw":"min","text_ar":"مِن"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"unused for"},{"kind":"text","text":"])"},{"kind":"italic_en","text":"the drawing of water therewith:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"that has been left for a time unused, and of which the thongs above mentioned, and the loop-shaped handles, have been broken."},{"kind":"text","text":"(IAth, TA.) Hence the saying of 'Áïsheh, describing her father,"},{"kind":"arabic","text_bw":"raA^aba Alt~aA^oYa waA^aw*ama AlEaTilapa","text_ar":"رَاَبَ التَّاْىَ وَاَوذَمَ العَطِلَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He repaired the rending, and put"},{"kind":"arabic","text_bw":"wa*m","text_ar":"وَذم"},{"kind":"italic_en","text":"to that"},{"kind":"text","text":"bucket"},{"kind":"italic_en","text":"of which the"},{"kind":"arabic","text_bw":"wa*am","text_ar":"وَذَم"},{"kind":"italic_en","text":"were broken"},{"kind":"text","text":"]; meaning that he restored the affairs to their state of order, and strengthened the condition of El-Islám after the apostatizing of men. (O, TA.)"}],"source_refs":["S","O","TA","K"]},{"entry_id":"n29607","headword_ar":"عُطُلٌ","root":"ETl","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaATilN","text_ar":"عَاطِلٌ","orth_type":"arrow"},{"kind":"text","text":", applied to a woman, (S, O, Msb, K,)"},{"kind":"italic_en","text":"Having no women's ornaments upon her;"},{"kind":"text","text":"(Msb, K;) [and] so ↓"},{"kind":"arabic","text_bw":"EaTolaA='u","text_ar":"عَطْلَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (IDrd, O:) or"},{"kind":"italic_en","text":"whose neck is destitute of necklaces or the like;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"miEoTaAlN","text_ar":"مِعْطَالٌ","orth_type":"arrow"},{"kind":"text","text":": (S, O:) or ↓ this last signifies"},{"kind":"italic_en","text":"usually having no women's ornaments upon her:"},{"kind":"text","text":"(K:) the pl. (of"},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":", TA) is"},{"kind":"arabic","text_bw":"A^aEoTaAlN","text_ar":"اَعْطَالٌ"},{"kind":"text","text":"and (of ↓"},{"kind":"arabic","text_bw":"EaATilN","text_ar":"عَاطِلٌ","orth_type":"arrow"},{"kind":"text","text":", TA)"},{"kind":"arabic","text_bw":"EawaATilu","text_ar":"عَوَاطِلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuT~alN","text_ar":"عُطَّلٌ"},{"kind":"text","text":". (K, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^aEoTaAlN","text_ar":"اَعْطَالٌ"},{"kind":"text","text":"applied to camels, (S, O, K,)"},{"kind":"italic_en","text":"Having no halters upon them:"},{"kind":"text","text":"(S, O:) or"},{"kind":"italic_en","text":"having no collars upon them, nor halters;"},{"kind":"text","text":"and so as applied to horses: (K:) and, (Th, K,) applied to camels, (Th, TA,)"},{"kind":"italic_en","text":"having upon them no brands:"},{"kind":"text","text":"(Th, K:) sing."},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":". (K.) [See also"},{"kind":"arabic","text_bw":"EuluTN","text_ar":"عُلُطٌ"},{"kind":"text","text":".] ―         -b3-  And, applied to men,"},{"kind":"italic_en","text":"Having no weapons with them:"},{"kind":"text","text":"(S, O, K:) in this sense, also, pl. of"},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":". (K.) ―         -b4-"},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":"applied to a bow,"},{"kind":"italic_en","text":"Having no string upon it:"},{"kind":"text","text":"(S, O, Msb, K:) pl."},{"kind":"arabic","text_bw":"A^aEoTaAlN","text_ar":"اَعْطَالٌ"},{"kind":"text","text":". (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"EuTulN","text_ar":"عُطُلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuTolN","text_ar":"عُطْلٌ","orth_type":"arrow"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"ETl mina AlmaAli","text_ar":"عطل مِنَ المَالِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mina","text_ar":"مِنَ"},{"kind":"arabic","text_bw":"AlA^adabi","text_ar":"الاَدَبِ"},{"kind":"text","text":"(see 1)] signify, applied to a man,"},{"kind":"italic_en","text":"Destitute of property"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of discipline,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good qualities and attributes, of the mind,"},{"kind":"text","text":"&c. (S, O, K.)"}],"source_refs":["S","O","Msb","K","IDrd","Th","TA"]}]}}