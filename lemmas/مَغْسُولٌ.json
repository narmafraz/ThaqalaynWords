{"lemma":"مَغْسُولٌ","slug":"مَغْسُولٌ","root":"غ.س.ل","root_slug":"غ-س-ل","root_link":"/words/roots/غ-س-ل","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31870"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%BA%D9%92%D8%B3%D9%8F%D9%88%D9%84%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"washed, rinsed"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of غَسَلَ (ḡasala, “to wash”)."},"ipa":["/maɣ.suːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31870","headword_ar":"مَغْسُولٌ","root":"gsl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gasiylN","text_ar":"غَسِيلٌ"},{"kind":"text","text":". ―         -b2-  Hence one says,"},{"kind":"arabic","text_bw":"kalaAmuhu","text_ar":"كَلَامُهُ"},{"kind":"arabic","text_bw":"magosuwlN","text_ar":"مَغْسُولٌ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"His speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, is devoid of nice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"subtile, expressions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allusions;"},{"kind":"text","text":"as though it were washed from such; or deserving to be washed and obliterated: or it may mean (tropical:)"},{"kind":"italic_en","text":"trimmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pruned."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":null}