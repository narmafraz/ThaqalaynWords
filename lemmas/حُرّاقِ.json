f the camels to burn;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"quEaAEN","text_ar":"قُعَاعٌ"},{"kind":"text","text":". (IAar, TA.)       -A2-  Also, (S, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"HuraAqapN","text_ar":"حُرَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Mgh, K) and ↓"},{"kind":"arabic","text_bw":"Hur~aAqN","text_ar":"حُرَّاقٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or this is vulgar, (O, TA,) and ↓"},{"kind":"arabic","text_bw":"Hur~aAqapN","text_ar":"حُرَّاقَةٌ","orth_type":"arrow"},{"kind":"text","text":", or this is incorrect, (K,) or vulgar, (S, O,) and ↓"},{"kind":"arabic","text_bw":"HaruwqN","text_ar":"حَرُوقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Har~uwqN","text_ar":"حَرُّوقٌ","orth_type":"arrow"},{"kind":"text","text":"(Fr, O, K) and ↓"},{"kind":"arabic","text_bw":"HaruwqaA='u","text_ar":"حَرُوقَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (Fr, S, O, K,) ["},{"kind":"italic_en","text":"Tinder;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"a thing,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"burnt rag,"},{"kind":"text","text":"(AHn, ISd, TA,)"},{"kind":"italic_en","text":"into which fire falls when it is struck:"},{"kind":"text","text":"(AHn, S, ISd, K, TA:) or"},{"kind":"italic_en","text":"what remains of burnt cloth:"},{"kind":"text","text":"(Mgh:) [and"},{"kind":"italic_en","text":"any substance used for receiving fire that is struck;"},{"kind":"text","text":"as, for instance, the pith of the"},{"kind":"arabic","text_bw":"Eu$ar","text_ar":"عُشَر"},{"kind":"text","text":".]"}],"source_refs":["K","TA","S","Mgh","O","Fr","AHn","ISd"]},{"entry_id":"n7716","headword_ar":"حِرَاقٌ","root":"Hrq","body":[{"kind":"text","text":", applied to fire, ("},{"kind":"arabic","text_bw":"naArN","text_ar":"نَارٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"That burns everything;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HuraAqN","text_ar":"حُرَاقٌ","orth_type":"arrow"},{"kind":"text","text":": (Aboo-Málik, TA:)"},{"kind":"italic_en","text":"that spares,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaves, nothing."},{"kind":"text","text":"(IAar, K.) ―         -b2-  (assumed tropical:)  A man"},{"kind":"italic_en","text":"that spoils, mars, destroys,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consumes, everything;"},{"kind":"text","text":"(IAar, K;)"},{"kind":"italic_en","text":"sparing nothing; like the fire thus termed;"},{"kind":"text","text":"(IAar, TA;) as also ↓"},{"kind":"arabic","text_bw":"HuraAqN","text_ar":"حُرَاقٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) In some copies of the K,"},{"kind":"arabic","text_bw":"mano yufosidu fiY kul~i $aYo'K","text_ar":"مَنْ يُفْسِدُ فِى كُلِّ شَىْءٍ"},{"kind":"text","text":"; but correctly, without"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"ramoYN HiraAqN","text_ar":"رَمْىٌ حِرَاقٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A vehement throwing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"casting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shooting."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n7724","headword_ar":"حُرَّاقٌ","root":"Hrq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HuraAqN","text_ar":"حُرَاقٌ"},{"kind":"text","text":", in two places:       -A2-  and see also"},{"kind":"arabic","text_bw":"maHoruwqN","text_ar":"مَحْرُوقٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}