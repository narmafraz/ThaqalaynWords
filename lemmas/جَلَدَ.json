{"lemma":"جَلَدَ","slug":"جَلَدَ","root":"ج.ل.د","root_slug":"ج-ل-د","root_link":"/words/roots/ج-ل-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَلَدْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَلَدْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَلَدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَلَدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَلَدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَلَدَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَلَدَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَلَدا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَلَدَتا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَلَدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَلَدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْلِد","in_corpus":true,"count":12,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْلِدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْلِدِي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْلِدانِ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْلِدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْلِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْلِدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْلِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْلِد","in_corpus":true,"count":104,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْلِد","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْلِدانِ","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْلِدا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْلِدانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْلِدُونَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْلِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْلِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْلِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَلَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَلَدْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":173,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n6102","n6106","n6107","n6108","n6109"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"skin, hide"},{"pos":"noun","gloss":"leather, hide as a material"},{"pos":"noun","gloss":"volume of a book or journal"},{"pos":"verb","gloss":"to hit (someone) on the skin, to lash, to whip, to flog","examples":[{"text":"ٱَلزَّانِيَةُ وَٱلزَّانِي فَٱجْلِدُوا كُلَّ وَاحِدٍ مِنْهُمَا مِئَةَ جَلْدَةٍ","english":"The [unmarried] woman or [unmarried] man found guilty of sexual intercourse - lash each one of them with a hundred lashes …"}]},{"pos":"verb","gloss":"to be tough, to be hardy; to be steadfast"},{"pos":"verb","gloss":"to bind (a book)"},{"pos":"noun","gloss":"verbal noun of جَلَدَ (jalada, “to whip, to flog”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of جَلُدَ (jaluda, “to be tough, to be steadfast”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to be frozen, to freeze","tags":["intransitive"]},{"pos":"verb","gloss":"to freeze","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of جَلِدَ (jalida, “to be frozen; to freeze”) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *gild-. Compare Aramaic 𐡂𐡋𐡃𐡀 (gldʾ), Classical Syriac ܓܠܕܐ (geldā), Jewish Babylonian Aramaic גלדא (geldā), Hebrew גֶּלֶד (géleḏ)."},"ipa":["/d͡ʒild/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6102","headword_ar":"جلّد","root":"jld","body":[{"kind":"text","text":", (IAar, T, S, Mgh,) inf. n."},{"kind":"arabic","text_bw":"tajoliydN","text_ar":"تَجْلِيدٌ"},{"kind":"text","text":", (T, S, Mgh, K,)"},{"kind":"italic_en","text":"He skinned"},{"kind":"text","text":"a camel (IAar, T, S, Mgh, K) that had been slaughtered: (S, K:) one seldom uses"},{"kind":"arabic","text_bw":"salaxa","text_ar":"سَلَخَ"},{"kind":"text","text":"thus [in relation to a camel]. (S.) ―         -b2-  Also"},{"kind":"italic_en","text":"He covered"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with skin;"},{"kind":"text","text":"as, for instance, a pair of socks, or stockings: (Mgh:) and in like manner, ["},{"kind":"italic_en","text":"he bound"},{"kind":"text","text":"] a book: (A, K: *) and"},{"kind":"italic_en","text":"he clad"},{"kind":"text","text":"a young camel"},{"kind":"italic_en","text":"in the skin of another young camel:"},{"kind":"text","text":"(L: [see"},{"kind":"arabic","text_bw":"jaladN","text_ar":"جَلَدٌ"},{"kind":"text","text":":]) thus the verb bears two contr. significations. (Mgh.)       -A2-  ["},{"kind":"italic_en","text":"He ordered to be flogged."},{"kind":"text","text":"(Freytag's Lex.: but without any indication of an authority.)]       -A3-  ["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, rendered"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"hardy, strong, sturdy, and enduring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patient:"},{"kind":"text","text":"so in the present day.]"}],"source_refs":["IAar","T","S","Mgh","K"]},{"entry_id":"n6106","headword_ar":"جَلْدٌ","root":"jld","body":[{"kind":"text","text":"(sometimes pronounced"},{"kind":"arabic","text_bw":"jaDodN","text_ar":"جَضْدٌ"},{"kind":"text","text":", S) and ↓"},{"kind":"arabic","text_bw":"jaliydN","text_ar":"جَلِيدٌ","orth_type":"arrow"},{"kind":"text","text":", (applied to a man, S, A, Mgh,)"},{"kind":"italic_en","text":"Hardy, strong, sturdy,"},{"kind":"text","text":"(S, * A, * L, K, *)"},{"kind":"italic_en","text":"and enduring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patient:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"not"},{"kind":"arabic","text_bw":"baliyd","text_ar":"بَلِيد"},{"kind":"text","text":"[q. v.]: (Mgh:) pl. [of either]"},{"kind":"arabic","text_bw":"julodN","text_ar":"جُلْدٌ"},{"kind":"text","text":", (S, L, K,) or"},{"kind":"arabic","text_bw":"juludN","text_ar":"جُلُدٌ"},{"kind":"text","text":", (so in some copies of the K,) and"},{"kind":"arabic","text_bw":"juladaA='u","text_ar":"جُلَدَا=ءُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ajolaAdN","text_ar":"اَجْلَادٌ"},{"kind":"text","text":"[a pl. of pauc.] (S, L, K) and"},{"kind":"arabic","text_bw":"jilaAdN","text_ar":"جِلَادٌ"},{"kind":"text","text":". (K.) And [the fem.]"},{"kind":"arabic","text_bw":"jalodapN","text_ar":"جَلْدَةٌ"},{"kind":"text","text":"A"},{"kind":"italic_en","text":"hardy and strong"},{"kind":"text","text":"she-camel;"},{"kind":"italic_en","text":"strong to labour and to journey; that heeds not the cold:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"swift:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"jalodaAtN","text_ar":"جَلْدَاتٌ"},{"kind":"text","text":": (L:) and a she-camel"},{"kind":"italic_en","text":"that yields a copious flow of milk:"},{"kind":"text","text":"(Th, TA:) sing. of"},{"kind":"arabic","text_bw":"jilaAdN","text_ar":"جِلَادٌ"},{"kind":"text","text":", (S,) which signifies she-camels"},{"kind":"italic_en","text":"abounding with milk;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"majaAliydu","text_ar":"مَجَالِيدُ"},{"kind":"text","text":", (K,) pl. of ↓"},{"kind":"arabic","text_bw":"mijolaAdN","text_ar":"مِجْلَادٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) or she-camels"},{"kind":"italic_en","text":"having neither milk nor young:"},{"kind":"text","text":"(K:) [see also"},{"kind":"arabic","text_bw":"jaladN","text_ar":"جَلَدٌ"},{"kind":"text","text":":] or she-camels"},{"kind":"italic_en","text":"that yield the most greasy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unctuous, sort of milk:"},{"kind":"text","text":"and so the sing.,"},{"kind":"arabic","text_bw":"jldp","text_ar":"جلدة"},{"kind":"text","text":", applied to a ewe or a she-goat. (S.)"},{"kind":"arabic","text_bw":"jilaAdN","text_ar":"جِلَادٌ"},{"kind":"text","text":"(pl. of"},{"kind":"arabic","text_bw":"jalodapN","text_ar":"جَلْدَةٌ"},{"kind":"text","text":", TA) is also applied to palm-trees, meaning"},{"kind":"italic_en","text":"Large, hard, hardy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong:"},{"kind":"text","text":"(S, K, TA:) or"},{"kind":"italic_en","text":"such as are not affected by drought."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"arabic","text_bw":"jalodapN","text_ar":"جَلْدَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A tough-skinned, excellent, date;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jilodapN","text_ar":"جِلْدَةٌ","orth_type":"arrow"},{"kind":"text","text":": and"},{"kind":"italic_en","text":"a hard, compact, date."},{"kind":"text","text":"(L.)"}],"source_refs":["L","Mgh","S","K","Th","TA"]},{"entry_id":"n6107","headword_ar":"جِلْدٌ","root":"jld","body":[{"kind":"text","text":", (S, Msb, K, &c.,) the only form of the word mentioned by the generality of the lexicographers; (TA;) occurring at the end of a verse with kesr to the second as well as the first letter, ↓"},{"kind":"arabic","text_bw":"jilidN","text_ar":"جِلِدٌ","orth_type":"arrow"},{"kind":"text","text":", agreeably with a license allowed to a poet in such a case, to give to a quiescent letter in a rhyme the same vowel as that which the preceding letter has; (S;) and ↓"},{"kind":"arabic","text_bw":"jaladN","text_ar":"جَلَدٌ","orth_type":"arrow"},{"kind":"text","text":", (IAar, S, K,) like"},{"kind":"arabic","text_bw":"$ibohN","text_ar":"شِبْهٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$abahN","text_ar":"شَبَهٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mavalN","text_ar":"مَثَلٌ"},{"kind":"text","text":"; but this is said by ISk to be unknown; (S;) The"},{"kind":"italic_en","text":"skin"},{"kind":"text","text":"of any animal; (K;) the"},{"kind":"italic_en","text":"integument of the body and limbs"},{"kind":"text","text":"of an animal: (Az, Msb:) or the"},{"kind":"italic_en","text":"exterior of the"},{"kind":"arabic","text_bw":"ba$arapN","text_ar":"بَشَرَةٌ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"upper skin"},{"kind":"text","text":"] of an animal: (Msb: [but this is a strange explanation:]) pl."},{"kind":"arabic","text_bw":"juluwdN","text_ar":"جُلُودٌ"},{"kind":"text","text":"(S, Msb, K) and (sometimes, Msb)"},{"kind":"arabic","text_bw":"A^ajolaAdN","text_ar":"اَجْلَادٌ"},{"kind":"text","text":"[a pl. of pauc.]. (Msb, K.) ―         -b2-  [The pl.]"},{"kind":"arabic","text_bw":"A^ajolaAdN","text_ar":"اَجْلَادٌ"},{"kind":"text","text":"signifies also, and ↓"},{"kind":"arabic","text_bw":"tajaAliydu","text_ar":"تَجَالِيدُ","orth_type":"arrow"},{"kind":"text","text":"likewise, The"},{"kind":"italic_en","text":"body and limbs"},{"kind":"text","text":"(S, A, L) of a man; (S;) the"},{"kind":"italic_en","text":"whole person,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body and limbs,"},{"kind":"text","text":"of a human being; (L, K;) and his"},{"kind":"italic_en","text":"self:"},{"kind":"text","text":"(L:) so called because enclosed by the skin: pl. of the former,"},{"kind":"arabic","text_bw":"A^ajaAlidu","text_ar":"اَجَالِدُ"},{"kind":"text","text":". (L.) You say,"},{"kind":"arabic","text_bw":"maA A^a$obaha","text_ar":"مَا اَشْبَهَ"},{"kind":"arabic","text_bw":"A^ajolaAdahu biA^ajolaAdi A^abiyhi","text_ar":"اَجْلَادَهُ بِاَجْلَادِ اَبِيهِ"},{"kind":"italic_en","text":"How like are his person and body to the person and body of his father!"},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"fulaAnN EaZiymu AlA^ajolaAdi","text_ar":"فُلَانٌ عَظِيمُ الاَجْلَادِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Alt~ajaAliydi","text_ar":"التَّجَالِيدِ","orth_type":"arrow"},{"kind":"text","text":"(A, L)"},{"kind":"italic_en","text":"Such a one is large and strong"},{"kind":"text","text":"(L)"},{"kind":"italic_en","text":"in respect of the body and limbs."},{"kind":"text","text":"(A, L.) And"},{"kind":"arabic","text_bw":"rud~uwA AlA^ayomaAna","text_ar":"رُدُّوا الاَيْمَانَ"},{"kind":"arabic","text_bw":"EalaY A^ajolaAdihimo","text_ar":"عَلَى اَجْلَادِهِمْ"},{"kind":"italic_en","text":"Repeat ye the oaths to the persons, themselves:"},{"kind":"text","text":"occurring in a trad.: said on the occasion of a man's entering among others of whom an oath had been demanded. (L.) ―         -b3-"},{"kind":"arabic","text_bw":"Aljilodu","text_ar":"الجِلْدُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"The penis."},{"kind":"text","text":"(Fr, L, K: but in the CK, in this sense, it is written"},{"kind":"arabic","text_bw":"Aljalodu","text_ar":"الجَلْدُ"},{"kind":"text","text":".) Agreeably with this explanation, its pl."},{"kind":"arabic","text_bw":"juluwd","text_ar":"جُلُود"},{"kind":"text","text":"is said by Fr to be used in the Kur xli. 20: (L:) or as meaning the"},{"kind":"italic_en","text":"pudenda:"},{"kind":"text","text":"(L, K:) but ISd holds that this word there means the"},{"kind":"italic_en","text":"skins,"},{"kind":"text","text":"with which, as in manual operations, acts of disobedience are performed. (L.)"}],"source_refs":["IAar","S","K","Az","Msb","A","L"]},{"entry_id":"n6108","headword_ar":"جَلَدٌ","root":"jld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jilodN","text_ar":"جِلْدٌ"},{"kind":"text","text":". ―         -b2-  Also The"},{"kind":"italic_en","text":"skin of a camel,"},{"kind":"page_break","n":443},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other beast, with which another beast is clothed:"},{"kind":"text","text":"(L:) the"},{"kind":"italic_en","text":"skin of a young camel, which"},{"kind":"text","text":"("},{"kind":"italic_en","text":"being stripped off,"},{"kind":"text","text":"S)"},{"kind":"italic_en","text":"is put over the body of another young camel, in order that the mother of the skinned young one"},{"kind":"text","text":"("},{"kind":"italic_en","text":"smelling it,"},{"kind":"text","text":"S)"},{"kind":"italic_en","text":"may conceive an affection for it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and suckle it"},{"kind":"text","text":"]: (S, K:) or the"},{"kind":"italic_en","text":"skin of a young camel, which is stuffed with panic grass"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":"), (K, TA,)"},{"kind":"italic_en","text":"or some other plant,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and put before a she-camel, in order that she may be induced thereby to affect that which is not her young one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and so yield her milk"},{"kind":"text","text":"], (K, TA,) or,"},{"kind":"italic_en","text":"to affect the young one of another."},{"kind":"text","text":"(L, TA.)       -A2-  A ewe or she-goat"},{"kind":"italic_en","text":"whose young one dies at the time of her bringing it forth;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jaladapN","text_ar":"جَلَدَةٌ","orth_type":"arrow"},{"kind":"text","text":": pl. [of the former]"},{"kind":"arabic","text_bw":"jilaAdN","text_ar":"جِلَادٌ"},{"kind":"text","text":"and [of the latter]"},{"kind":"arabic","text_bw":"jaladaAtN","text_ar":"جَلَدَاتٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also, [as a coll. gen. n.,]"},{"kind":"italic_en","text":"Great"},{"kind":"text","text":"she-camels,"},{"kind":"italic_en","text":"having neither young ones nor milk;"},{"kind":"text","text":"n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S:) [see also"},{"kind":"arabic","text_bw":"jalodN","text_ar":"جَلْدٌ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"great"},{"kind":"text","text":"camels,"},{"kind":"italic_en","text":"among which are no little ones;"},{"kind":"text","text":"(K;) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (TA:) and (app. as a quasipl. n., TA) sheep or goats, and camels,"},{"kind":"italic_en","text":"having neither young ones nor milk;"},{"kind":"text","text":"(K;) app. meaning"},{"kind":"italic_en","text":"having no little ones to which they give such:"},{"kind":"text","text":"(Mohammad Ibn-El-Mukarram, TA:) or she-camels"},{"kind":"italic_en","text":"having no young ones with them, so that they endure patiently the heat and cold:"},{"kind":"text","text":"(Fr, TA:) or she-camels"},{"kind":"italic_en","text":"having no milk, and the young ones of which have gone away from them;"},{"kind":"text","text":"including what are called"},{"kind":"arabic","text_bw":"banaAtu All~abuwni","text_ar":"بَنَاتُ اللَّبُونِ"},{"kind":"text","text":", and such as are above these in age; and also such as are called"},{"kind":"arabic","text_bw":"maxaASN","text_ar":"مَخَاصٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ei$aArN","text_ar":"عِشَارٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HiyaAlN","text_ar":"حِيَالٌ"},{"kind":"text","text":"; but when they have given birth to their young, they cease to be termed"},{"kind":"arabic","text_bw":"jaladN","text_ar":"جَلَدٌ"},{"kind":"text","text":", and are called"},{"kind":"arabic","text_bw":"Ei$aArN","text_ar":"عِشَارٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"liqaAHN","text_ar":"لِقَاحٌ"},{"kind":"text","text":": the pl. is"},{"kind":"arabic","text_bw":"A^ajolaAdN","text_ar":"اَجْلَادٌ"},{"kind":"text","text":"and [pl. pl.]"},{"kind":"arabic","text_bw":"A^ajaAliydu","text_ar":"اَجَالِيدُ"},{"kind":"text","text":". (Az, TA.)       -A3-"},{"kind":"italic_en","text":"Hard ground;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^ajoladu","text_ar":"اَجْلَدُ","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"hard and level ground;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jaladapN","text_ar":"جَلَدَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"level but rough ground;"},{"kind":"text","text":"(L;) as also ↓"},{"kind":"arabic","text_bw":"A^ajoladu","text_ar":"اَجْلَدُ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl. (of the former, TA)"},{"kind":"arabic","text_bw":"A^ajolaAdN","text_ar":"اَجْلَادٌ"},{"kind":"text","text":"and (of the latter, TA)"},{"kind":"arabic","text_bw":"A^ajaAlidu","text_ar":"اَجَالِدُ"},{"kind":"text","text":". (S, TA.) You also say"},{"kind":"arabic","text_bw":"A^aroDN jaladN","text_ar":"اَرْضٌ جَلَدٌ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"; (AHn, TA;) and ↓"},{"kind":"arabic","text_bw":"jalodapN","text_ar":"جَلْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", with a quiescent"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"; (Lth, AHn, TA;) and"},{"kind":"arabic","text_bw":"ArD","text_ar":"ارض"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jaladapN","text_ar":"جَلَدَةٌ","orth_type":"arrow"},{"kind":"text","text":"also; and"},{"kind":"arabic","text_bw":"makaAnN jaladN","text_ar":"مَكَانٌ جَلَدٌ"},{"kind":"text","text":". (Lth, TA.)       -A4-  Also, as a subst. or an inf. n., (L, [see"},{"kind":"arabic","text_bw":"jaluda","text_ar":"جَلُدَ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"Hardiness, strength, sturdiness,"},{"kind":"text","text":"(S, * A, * L, K, *)"},{"kind":"italic_en","text":"and endurance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patience."},{"kind":"text","text":"(T.)"}],"source_refs":["L","S","K","TA","Fr"]},{"entry_id":"n6109","headword_ar":"جِلِدٌ","root":"jld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jilodN","text_ar":"جِلْدٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}