 "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "present_1ms", "form": "أُوسِف", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 3, "cross_references": {"qac": {"found": true, "lemma_key": "آسَفَ", "root": "أسف", "pos": "N", "occurrence_count": 2}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["adj", "verb"], "has_etymology": true, "sense_count": 2}, "lanes": {"found": true, "entry_ids": ["n756", "n758", "n759", "n19888"], "search_url": "https://lanelexicon.com/?s=%D8%A2%D8%B3%D9%8E%D9%81%D9%8E"}}, "translations": {"en": "to grieve", "fa": "اندوهگرفتن", "ur": "غمگین ہونا", "tr": "üzülmek", "id": "bersedih", "bn": "দুঃখিত হওয়া", "es": "entristecer", "fr": "s'affliger", "de": "trauern", "ru": "печалиться", "zh": "悲伤"}, "definition": {"source": "wiktextract", "senses": [{"pos": "adj", "gloss": "sorry"}, {"pos": "verb", "gloss": "to make regret, sadden, distress"}]}, "etymology": {"source": "wiktextract", "text": "Derived from the active participle of the verb أَسِفَ (ʔasifa)."}, "ipa": ["/ʔaː.sif/", "/ʔaː.sa.fa/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n756", "headword_ar": "اَسِفَ", "root": "Asf", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^asafN", "text_ar": "اَسَفٌ"}, {"kind": "text", "text": ", (M, Msb, K,)"}, {"kind": "italic_en", "text": "He grieved, lamented,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regretted:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "he was angry:"}, {"kind": "text", "text": "(Msb:) or"}, {"kind": "italic_en", "text": "he grieved exceedingly:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "he was exceedingly angry:"}, {"kind": "text", "text": "(M:) or"}, {"kind": "italic_en", "text": "he grieved most intensely:"}, {"kind": "text", "text": "(K:) some say that"}, {"kind": "arabic", "text_bw": "A^asafN", "text_ar": "اَسَفٌ"}, {"kind": "text", "text": "signifies the"}, {"kind": "italic_en", "text": "grieving"}, {"kind": "text", "text": "for a thing that has escaped; not in an absolute sense: (MF:) or it properly signifies the"}, {"kind": "italic_en", "text": "rising,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "swelling,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "mantling, of the blood of the heart,"}, {"kind": "text", "text": "from desire of vengeance; and when this is against an inferior, it is"}, {"kind": "italic_en", "text": "anger;"}, {"kind": "text", "text": "but when against a superior, it is"}, {"kind": "italic_en", "text": "grief."}, {"kind": "text", "text": "(Er-Rághib.) Mo- hammad, being asked respecting sudden death, answered, saying,"}, {"kind": "arabic", "text_bw": "raAHapN lilomuw^omini waA^axo*apu A^asafK lilokaAfiri", "text_ar": "رَاحَةٌ لِلْمُوْمِنِ وَاَخْذَةُ اَسَفٍ لِلْكَافِرِ"}, {"kind": "text", "text": ", or accord. to one recital, ↓"}, {"kind": "arabic", "text_bw": "A^asifK", "text_ar": "اَسِفٍ", "orth_type": "arrow"}, {"kind": "text", "text": ", i. e. ["}, {"kind": "italic_en", "text": "Rest,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ease, to the believer, and an act of punishment"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "of anger"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "to the unbeliever"}, {"kind": "text", "text": "], or"}, {"kind": "italic_en", "text": "of one who is angry."}, {"kind": "text", "text": "(K.) You say,"}, {"kind": "arabic", "text_bw": "A^asifa EalaY maA faAtahu", "text_ar": "اَسِفَ عَلَى مَا فَاتَهُ"}, {"kind": "text", "text": ", inf. n. as above; (S;) and ↓"}, {"kind": "arabic", "text_bw": "tA^s~f", "text_ar": "تاسّف", "orth_type": "arrow"}, {"kind": "text", "text": "; (S, M, * K; *)"}, {"kind": "italic_en", "text": "He grieved,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lamented, for,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "at,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regretted, most intensely, what had escaped him:"}, {"kind": "text", "text": "(S, M, * K:) and"}, {"kind": "arabic", "text_bw": "A^asifa Ealayohi", "text_ar": "اَسِفَ عَلَيْهِ"}, {"kind": "text", "text": ", (S, K,) inf. n. as above, (S,)"}, {"kind": "italic_en", "text": "he was angry with him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "at it:"}, {"kind": "text", "text": "(S, K:) or"}, {"kind": "arabic", "text_bw": "A^asifa fulaAnN EalaY ka*aA", "text_ar": "اَسِفَ فُلَانٌ عَلَى كَذَا"}, {"kind": "arabic", "text_bw": "waka*aA", "text_ar": "وَكَذَا"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "tA^s~f", "text_ar": "تاسّف", "orth_type": "arrow"}, {"kind": "text", "text": ", signify, accord. to some,"}, {"kind": "italic_en", "text": "such a one grieved,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lamented, for,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "at, such and such things"}, {"kind": "text", "text": "which had escaped him: or, accord. to others,"}, {"kind": "italic_en", "text": "grieved,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lamented, most intensely."}, {"kind": "text", "text": "(IAmb.)"}, {"kind": "arabic", "text_bw": "A^asafFA", "text_ar": "اَسَفًا"}, {"kind": "text", "text": "in the Kur xviii. 5 means, accord. to Ed-Dahhák,"}, {"kind": "arabic", "text_bw": "jazaEFA", "text_ar": "جَزَعًا"}, {"kind": "text", "text": "[i.e."}, {"kind": "italic_en", "text": "In grief,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in most violent grief,"}, {"kind": "text", "text": "&c.]: or, accord. to Katádeh,"}, {"kind": "italic_en", "text": "in anger."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "yaA A^asafaA EalaY yuwsufi", "text_ar": "يَا اَسَفَا عَلَى يُوسُفِ"}, {"kind": "text", "text": ", in the Kur [xii. 84], means"}, {"kind": "arabic", "text_bw": "yaA jazaEaAhu", "text_ar": "يَا جَزَعَاهُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "O my grief for Joseph:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "O my most violent grief"}, {"kind": "text", "text": "]. (TA.)"}], "source_refs": ["M", "Msb", "K", "MF", "S"]}, {"entry_id": "n758", "headword_ar": "اَسَفٌ", "root": "Asf", "body": [{"kind": "text", "text": "inf. n. of 1, which see throughout. [Used as a subst.,"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "A^asaAfpN", "text_ar": "اَسَافةٌ"}, {"kind": "text", "text": ".]"}], "source_refs": []}, {"entry_id": "n759", "headword_ar": "اَسِفٌ", "root": "Asf", "body": [{"kind": "text", "text": "(M, Mgh, Msb) and ↓"}, {"kind": "arabic", "text_bw": "AsifN", "text_ar": "اسِفٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "A^asofaAnu", "text_ar": "اَسْفَانُ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "A^asiyfN", "text_ar": "اَسِيفٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(M, TA) and ↓"}, {"kind": "arabic", "text_bw": "A^asuwfN", "text_ar": "اَسُوفٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(M)"}, {"kind": "italic_en", "text": "Angry:"}, {"kind": "text", "text": "(Mgh, Msb, TA:) or"}, {"kind": "italic_en", "text": "exceedingly angry."}, {"kind": "text", "text": "(M.) For an ex. of the first, see 1. See also"}, {"kind": "arabic", "text_bw": "A^asiyfN", "text_ar": "اَسِيفٌ"}, {"kind": "text", "text": ", in two places."}], "source_refs": ["M", "Mgh", "Msb", "TA"]}, {"entry_id": "n19888", "headword_ar": "اسفّ", "root": "sf", "body": [{"kind": "text", "text": ": see 1, first sentence. ―         -b2-  [Hence,]"}, {"kind": "arabic", "text_bw": "A^asofafotu Al$~aYo'a", "text_ar": "اَسْفَفْتُ الشَّىْءَ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A_isofaAfN", "text_ar": "اـِسْفَافٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "I stuck one part of the thing to another."}, {"kind": "text", "text": "(Yz, TA.) ―         -b3-  [And from the same signification, as is indicated in the O and TA,]"}, {"kind": "arabic", "text_bw": "As~f Aln~aZara", "text_ar": "اسّف النَّظَرَ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "He looked sharply,"}, {"kind": "text", "text": "(S, M, A, O, K,)"}, {"kind": "italic_en", "text": "and hardly,"}, {"kind": "text", "text": "(S, O,)"}, {"kind": "italic_en", "text": "and minutely,"}, {"kind": "text", "text": "(A,) towards, or at, ("}, {"kind": "arabic", "text_bw": "A_ilaY", "text_ar": "اـِلَى"}, {"kind": "text", "text": ",) a person, (S, A, O,) and an affair, (A,) and AAF adds,"}, {"kind": "italic_en", "text": "and inclined towards the ground."}, {"kind": "text", "text": "(M.)       -A2-  Also"}, {"kind": "italic_en", "text": "He fed"}, {"kind": "text", "text": "a camel"}, {"kind": "italic_en", "text": "with dry herbage."}, {"kind": "text", "text": "(K.) ―         -b2-  [Hence,]"}, {"kind": "arabic", "text_bw": "Asf~", "text_ar": "اسفّ"}, {"kind": "arabic", "text_bw": "Alfarasa AllijaAma", "text_ar": "الفَرَسَ اللِجَامَ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He put the bit into the mouth of the horse."}, {"kind": "text", "text": "(Moheet, L, K.) ―         -b3-  And"}, {"kind": "arabic", "text_bw": "Asf~ Ald~awaA='a", "text_ar": "اسفّ الدَّوَا=ءَ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He stuffed the wound with the medicament:"}, {"kind": "text", "text": "(M:) or"}, {"kind": "arabic", "text_bw": "Asf~ AljuroHa dawaA='F", "text_ar": "اسفّ الجُرْحَ دَوَا=ءً"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "he put a medicament into the wound;"}, {"kind": "text", "text": "(K, TA;) as though he put"}, {"kind": "arabic", "text_bw": "safuwf", "text_ar": "سَفُوف"}, {"kind": "text", "text": "to it. (TA.) ―         -b4-  And"}, {"kind": "arabic", "text_bw": "Asf~ Alwa$oma naw^uwrFA", "text_ar": "اسفّ الوَشْمَ نَوُورًا"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He filled in the tattoo with"}, {"kind": "arabic", "text_bw": "nw^wr", "text_ar": "نوور"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "smoke-black of fat"}, {"kind": "text", "text": "]. (M.) ―         -b5-  And"}, {"kind": "arabic", "text_bw": "A^usif~a wajohuhu Aln~aw^uwra", "text_ar": "اُسِفَّ وَجْهُهُ النَّوُورَ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "His face was sprinkled with"}, {"kind": "arabic", "text_bw": "nw^wr", "text_ar": "نوور"}, {"kind": "text", "text": ". (S.) It is said in a trad.,"}, {"kind": "arabic", "text_bw": "fakaA^an~amaA A^usif~a wajohuhu", "text_ar": "فَكَاَنَّمَا اُسِفَّ وَجْهُهُ"}, {"kind": "text", "text": ", meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "His face was altered,"}, {"kind": "text", "text": "(S, K, *)"}, {"kind": "italic_en", "text": "as though something that altered it had been sprinkled upon it."}, {"kind": "text", "text": "(S.) You say also,"}, {"kind": "arabic", "text_bw": "kaA^an~a wajohahu A^usif~a ramaAdFA", "text_ar": "كَاَنَّ وَجْهَهُ اُسِفَّ رَمَادًا"}, {"kind": "text", "text": ", meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "His face became of a blackish,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an ashy, hue, altered, as though ashes had been sprinkled upon it:"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "suf~a", "text_ar": "سُفَّ", "orth_type": "arrow"}, {"kind": "arabic", "text_bw": "Alr~amaAdu fiY wajohihi", "text_ar": "الرَّمَادُ فِى وَجْهِهِ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "Ashes were sprinkled upon his face"}, {"kind": "text", "text": "], meaning"}, {"kind": "italic_en", "text": "his face became altered."}, {"kind": "text", "text": "(Har p. 626.)       -A3-  Also"}, {"kind": "italic_en", "text": "It approached the earth,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ground;"}, {"kind": "text", "text": "(S, M, K;) said of a bird in its flight; (S, K;) or of a bird &c.: (M:) or"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(a bird)"}, {"kind": "italic_en", "text": "flew over the ground so near that its feet almost reached it."}, {"kind": "text", "text": "(A.) And"}, {"kind": "arabic", "text_bw": "Asf~t Als~aHaAbapu", "text_ar": "اسفّت السَّحَابَةُ"}, {"kind": "italic_en", "text": "The cloud approached the earth."}, {"kind": "text", "text": "(S, K.) ―         -b2-  Said of a stallion,"}, {"kind": "italic_en", "text": "He stooped his head to bite."}, {"kind": "text", "text": "(M, K.) And one says of man,"}, {"kind": "arabic", "text_bw": "Asf~ mina AlA^aroDi", "text_ar": "اسفّ مِنَ الاَرْضِ"}, {"kind": "text", "text": "[and"}, {"kind": "arabic", "text_bw": "A_ilaY AlArD", "text_ar": "اـِلَى الارض"}, {"kind": "italic_en", "text": "He stooped towards the ground"}, {"kind": "text", "text": "]. (O in art."}, {"kind": "arabic", "text_bw": "$b", "text_ar": "شب"}, {"kind": "text", "text": ".) ―         -b3-  And, said of a man, (S,) (assumed tropical:)"}, {"kind": "italic_en", "text": "He pursued small,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "little, things:"}, {"kind": "text", "text": "(S, K:) and (assumed tropical:)"}, {"kind": "italic_en", "text": "he followed after low,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "mean, things:"}, {"kind": "text", "text": "(K:) [(assumed tropical:)"}, {"kind": "italic_en", "text": "he stooped to such things:"}, {"kind": "text", "text": "] or"}, {"kind": "arabic", "text_bw": "Asf~ A_ilaY madaAqi AlA^umuwri wa A^alaAy^imihaA", "text_ar": "اسفّ اـِلَى مَدَاقِ الاُمُورِ وَ اَلَايِم