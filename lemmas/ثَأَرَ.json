{"lemma":"ثَأَرَ","slug":"ثَأَرَ","root":"ث.#.ر","root_slug":"ث-_-ر","root_link":"/words/roots/ث-_-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ثَأَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ثَأَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ثَأَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ثَأَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ثَأَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ثَأَرَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ثَأَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ثَأَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ثَأَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ثَأَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ثَأَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَثْأَر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَثْأَرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَثْأَرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَثْأَرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَثْأَرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَثْأَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَثْأَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَثْأَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَثْأَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَثْأَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَثْأَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَثْأَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَثْأَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَثْأَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَثْأَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَثْأَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَثْأَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"ثَأَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ثَأَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَثْأَر","in_corpus":true,"count":23,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَثْأَر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":26,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n4290","n4820","n4823"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D8%A3%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take revenge upon or for","tags":["transitive"]},{"pos":"verb","gloss":"to seek revenge upon"},{"pos":"noun","gloss":"verbal noun of ثَأَرَ (ṯaʔara, “to take revenge upon”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"revenge"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4290","headword_ar":"ثَاْرٌ","root":"vA^r","body":[{"kind":"text","text":", (S, M, A, Mgh, Msb, K,) which may be also pronounced"},{"kind":"arabic","text_bw":"vaArN","text_ar":"ثَارٌ"},{"kind":"text","text":", i. e., with the"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"suppressed, (Msb,) and ↓"},{"kind":"arabic","text_bw":"vaA^orapN","text_ar":"ثَاْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"vuw^orapN","text_ar":"ثُوْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) which last is a subst. [from"},{"kind":"arabic","text_bw":"vaA^ara","text_ar":"ثَاَرَ"},{"kind":"text","text":"], as also ↓"},{"kind":"arabic","text_bw":"vuw^uwrapN","text_ar":"ثُوُورَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, M, K,)"},{"kind":"italic_en","text":"Blood-revenge;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation of murder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"homicide:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a seeking to revenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliate, blood:"},{"kind":"text","text":"[see 1, of which"},{"kind":"arabic","text_bw":"vaA^orN","text_ar":"ثَاْرٌ"},{"kind":"text","text":"is an inf. n. :] or"},{"kind":"italic_en","text":"a desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking, for retaliation of a crime"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of enmity:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retention of enmity in the heart, with watchfulness for an opportunity to indulge it:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"*aHolN","text_ar":"ذَحْلٌ"},{"kind":"text","text":": (S, A, Msb:) or"},{"kind":"arabic","text_bw":"Talaba","text_ar":"طَلَبَ"},{"kind":"arabic","text_bw":"biAld~ami","text_ar":"بِالدَّمِ"},{"kind":"text","text":": (M, K:) or"},{"kind":"arabic","text_bw":"HiqodN","text_ar":"حِقْدٌ"},{"kind":"text","text":": (Mgh:) or (so accord. to the M; but accord. to the K, “ and ”)"},{"kind":"italic_en","text":"blood"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"itself:"},{"kind":"text","text":"(M:) pl."},{"kind":"arabic","text_bw":"A^avoA=rN","text_ar":"اَثْا=رٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":"; the latter formed by transposition. (Yaakoob, M.) You say,"},{"kind":"arabic","text_bw":"A^adoraka vaA^orahu","text_ar":"اَدْرَكَ ثَاْرَهُ"},{"kind":"text","text":"(S, Mgh, K) and ↓"},{"kind":"arabic","text_bw":"vuw^oratahu","text_ar":"ثُوْرَتَهُ","orth_type":"arrow"},{"kind":"text","text":"(As, T, S) ["},{"kind":"italic_en","text":"He obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took, his bloodrevenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he attained the object of his pursuit [for blood-revenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation"},{"kind":"text","text":"]; from"},{"kind":"arabic","text_bw":"vaA^arahu","text_ar":"ثَاَرَهُ"},{"kind":"text","text":": (As, T:) or"},{"kind":"italic_en","text":"he slew the slayer of his relation."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"Talaba bivaA^orihi","text_ar":"طَلَبَ بِثَاْرِهِ"},{"kind":"italic_en","text":"He sought to obtain his blood-revenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Talaba bi*aHolihi","text_ar":"طَلَبَ بِذَحْلِهِ"},{"kind":"text","text":". (S and Msb in art."},{"kind":"arabic","text_bw":"*Hl","text_ar":"ذحل"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A^anaA A^aTolubu vaA^oriY Einodahu","text_ar":"اَنَا اَطْلُبُ ثَاْرِى عِنْدَهُ"},{"kind":"italic_en","text":"I seek my blood-revenge of him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"*aHoliY","text_ar":"ذَحْلِى"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"vaA^oriY Einoda fulaAnK","text_ar":"ثَاْرِى عِنْدَ فُلَانٍ"},{"kind":"italic_en","text":"My blood-revenge is a debt owed to me by such a one;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"*aHoliY","text_ar":"ذَحْلِى"},{"kind":"text","text":": meaning"},{"kind":"italic_en","text":"such a one is the slayer of my relation."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"vaA^orN","text_ar":"ثَاْرٌ"},{"kind":"text","text":"also signifies, (A,) or ↓"},{"kind":"arabic","text_bw":"vaAy^irN","text_ar":"ثَايِرٌ","orth_type":"arrow"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"One who seeks blood-revenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation of the slaughter of his relation:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"one of whom is sought blood-revenge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation of the slaughter of a relation:"},{"kind":"text","text":"(T, A:) the latter primarily signifies"},{"kind":"italic_en","text":"a slayer;"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"a slayer of a person's relation in vengeance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retribution:"},{"kind":"text","text":"(Ham p. 637:) and the former,"},{"kind":"italic_en","text":"one who is sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursued, for blood-revenge;"},{"kind":"text","text":"an inf. n. used as a subst.: (Ham p. 87:) the"},{"kind":"italic_en","text":"slayer of a"},{"kind":"text","text":"person's"},{"kind":"italic_en","text":"relation;"},{"kind":"text","text":"(S, M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"vaAy^irN","text_ar":"ثَايِرٌ","orth_type":"arrow"},{"kind":"text","text":": (A:) pl. of the former"},{"kind":"arabic","text_bw":"A^avoA=rN","text_ar":"اَثْا=رٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":"[as above] (K) and"},{"kind":"arabic","text_bw":"vaA^oraAtN","text_ar":"ثَاْرَاتٌ"},{"kind":"text","text":": (S, A, K:) the first of which three is [also] pl. of"},{"kind":"arabic","text_bw":"vaAy^irN","text_ar":"ثَايِرٌ"},{"kind":"text","text":". (T.) You say,"},{"kind":"arabic","text_bw":"huwa vaA^oruhu","text_ar":"هُوَ ثَاْرُهُ"},{"kind":"italic_en","text":"He is the slayer of his relation."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"yaA vaA^oraAti fulaAnK","text_ar":"يَا ثَاْرَاتِ فُلَانٍ"},{"kind":"italic_en","text":"O slayers of such a one."},{"kind":"text","text":"(T, S, K.)"},{"kind":"arabic","text_bw":"yaA vaA^oraAti EuvomaAna","text_ar":"يَا ثَاْرَاتِ عُثْمَانَ"},{"kind":"text","text":", occurring in a trad., which is also related with the substitution of"},{"kind":"arabic","text_bw":"taAraAt","text_ar":"تَارَات"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"vA^rAt","text_ar":"ثارات"},{"kind":"text","text":", may be explained in the same manner; or it may mean"},{"kind":"italic_en","text":"O ye"},{"kind":"text","text":"seekers of"},{"kind":"italic_en","text":"the blood-revenge of 'Othmán,"},{"kind":"text","text":"aid me to obtain it; the prefixed noun"},{"kind":"arabic","text_bw":"TaAlibiY","text_ar":"طَالِبِى"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^ahol","text_ar":"اَهْل"},{"kind":"text","text":", being understood. (Nh, TA. [See also"},{"kind":"arabic","text_bw":"taArapN","text_ar":"تَارَةٌ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"twr","text_ar":"تور"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"vaA^orN muniymN","text_ar":"ثَاْرٌ مُنِيمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A slayer of one's relation who causes"},{"kind":"text","text":"his slayer"},{"kind":"italic_en","text":"to sleep,"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"one with whom the seeker [of blood-revenge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retaliation] is contented, if he find him [and slay him], so that he sleeps after;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"one who, if slain, causes the pursuer of blood-revenge to cease from the pursuit:"},{"kind":"text","text":"(Ham p. 87:) or"},{"kind":"italic_en","text":"a person who is an equivalent for the blood of one's relation [and who therefore, by his being slain in retaliation, makes the avenger to sleep"},{"kind":"text","text":"]: (T:) or"},{"kind":"italic_en","text":"a person of rank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"note, in whom"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"by the slaughter of whom] one has his full desire accomplished."},{"kind":"text","text":"(A.) In a trad. of Mohammad Ibn-Selemeh, relating to the day of Kheyber, occur the words,"},{"kind":"arabic","text_bw":"A^anaA lahu yaA","text_ar":"اَنَا لَهُ يَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rasuwlu A@ll~`hi Almawotuwru lilv~aAy^iri","text_ar":"رَسُولُ ا@للّٰهِ المَوْتُورُ لِلثَّايِرِ","orth_type":"arrow"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I am for him,"},{"kind":"text","text":"i. e. I am he who should slay him,"},{"kind":"italic_en","text":"O Apostle of God:] the seeker of blood-revenge [is for him of whom blood-revenge is sought"},{"kind":"text","text":"]. (L. [The explanation there given is clearly shown to relate to"},{"kind":"arabic","text_bw":"Almwtwr","text_ar":"الموتور"},{"kind":"text","text":".]) ―         -b2-"},{"kind":"arabic","text_bw":"vaA^orN","text_ar":"ثَاْرٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"An enemy:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^avoA=rN","text_ar":"اَثْا=رٌ"},{"kind":"text","text":": so explained as occurring in the following words of a trad.;"},{"kind":"arabic","text_bw":"laA tugomiduwA suyuwfakumo Eano A^aHodaAvikumo fatuwtiruwA","text_ar":"لَا تُغْمِدُوا سُيُوفَكُمْ عَنْ اَحْدَاثِكُمْ فَتُوتِرُوا"},{"kind":"arabic","text_bw":"A^avoA=rakumo","text_ar":"اَثْا=رَكُمْ"},{"kind":"italic_en","text":"Do not sheathe your swords from your young ones,"},{"kind":"text","text":"[neglecting to teach them the use thereof,]"},{"kind":"italic_en","text":"and so make your enemies to attain their desire of blood-revenge."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","A","Mgh","Msb","K","Lh","As","T"]},{"entry_id":"n4820","headword_ar":"ثَارَ","root":"vwr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yavuwru","text_ar":"يَثُورُ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vuw^uwrN","text_ar":"ثُوُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, M)"},{"kind":"italic_en","text":"became raised, roused, excited, stirred up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"provoked;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"haAja","text_ar":"هَاجَ"},{"kind":"text","text":"; (M;) syn. of the inf. n."},{"kind":"arabic","text_bw":"hayajaAnN","text_ar":"هَيَجَانٌ"},{"kind":"text","text":": (K:) as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":". (M, K.) ―         -b2-  Said of dust, (S, M, A, Mgh, Msb,) and of smoke, (M, A,) and of other things, (M, TA,) inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vuw^uwrN","text_ar":"ثُوُورٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"It became raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stirred up;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"italic_en","text":"and spread:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"rose,"},{"kind":"text","text":"(S, M, A, K,)"},{"kind":"italic_en","text":"and appeared;"},{"kind":"text","text":"(M;) as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":": (K:) also said of the redness in the sky after sunset, inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"it spread upon the horizon, and rose:"},{"kind":"text","text":"(TA: [see"},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"vAr","text_ar":"ثار"},{"kind":"text","text":", said of anything, means (assumed tropical:)"},{"kind":"italic_en","text":"it appeared and spread."},{"kind":"text","text":"(Mgh.) ―         -b3-  Said of a camel lying upon his breast,"},{"kind":"italic_en","text":"He became roused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b4-  Said of the bird called"},{"kind":"arabic","text_bw":"AlqaT~A","text_ar":"القَطّا"},{"kind":"text","text":", (M, A,) inf. ns. as first mentioned above, (K,) or"},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"It rose"},{"kind":"text","text":"(M, A, K) from the place where it lay; (M, A;) as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":": (K:) and of a swarm of locusts,"},{"kind":"italic_en","text":"it rose;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"appeared;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AnvAr","text_ar":"انثار","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b5-  Also, (S, M,) inf. ns. as first mentioned above, (M, K,)"},{"kind":"italic_en","text":"He leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprang;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"vAr A_ilayohi","text_ar":"ثار اـِلَيْهِ"},{"kind":"italic_en","text":"He leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprang, to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"vArbihi Aln~aAsu","text_ar":"ثاربِهِ النَّاسُ"},{"kind":"italic_en","text":"The people leaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprang, upon him."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"vAr A_ilaY Al$~ar~i","text_ar":"ثار اـِلَى الشَّرِّ"},{"kind":"italic_en","text":"He rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastened, to do evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief."},{"kind":"text","text":"(Msb.) ―         -b6-"},{"kind":"arabic","text_bw":"vAr AlmaA='u","text_ar":"ثار المَا=ءُ"},{"kind":"italic_en","text":"The water flowed forth with force; gushed forth."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"vAr bihi","text_ar":"ثار بِهِ"},{"kind":"arabic","text_bw":"Ald~amu","text_ar":"الدَّمُ"},{"kind":"text","text":", (TA,) inf. ns. as first mentioned above, (K,) (tropical:)"},{"kind":"italic_en","text":"The blood appeared in him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tvw~r","text_ar":"تثوّر","orth_type":"arrow"},{"kind":"text","text":". (K, * TA.) And"},{"kind":"arabic","text_bw":"vAr Ald~amu fiY wajohahi","text_ar":"ثار الدَّمُ فِى وَجْهَهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The blood appeared in"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mantled in"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted into"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his face;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AnvAr","text_ar":"انثار","orth_type":"arrow"},{"kind":"text","text":". (M.) ―         -b8-"},{"kind":"arabic","text_bw":"vArt bihi AlHaSobapu","text_ar":"ثارت بِهِ الحَصْبَةُ"},{"kind":"text","text":", (S, M, A,) inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vuw^uwrN","text_ar":"ثُوُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaArN","text_ar":"ثَوَارٌ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"vuwaArN","text_ar":"ثُوَارٌ"},{"kind":"text","text":"?] and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", (M,) (tropical:)"},{"kind":"italic_en","text":"The measles spread"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"broke out"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in him:"},{"kind":"text","text":"(M:) and in like manner one says of anything that appears: (M:) one says,"},{"kind":"arabic","text_bw":"vAr","text_ar":"ثار"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"it appeared."},{"kind":"text","text":"(T.) And accord. to Lh, one says,"},{"kind":"arabic","text_bw":"vAr Alr~ajulu","text_ar":"ثار الرَّجُلُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vawaraAnN","text_ar":"ثَوَرَانٌ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"The man had the measles appearing in him."},{"kind":"text","text":"(M.) ―         -b9-"},{"kind":"arabic","text_bw":"vAr biAlmaHomuwmi Alv~aworu","text_ar":"ثار بِالمَحْمُومِ الثَّوْرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Pimples,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small pustules, breaking out in the mouth, appeared in the fevered man."},{"kind":"text","text":"(A.) ―         -b10-"},{"kind":"arabic","text_bw":"vArt AlHum~aY","text_ar":"ثارت الحُمَّى"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The fever rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became excited"},{"kind":"text","text":"]. (TA from a trad.) ―         -b11-"},{"kind":"arabic","text_bw":"vArt nafosuhu","text_ar":"ثارت نَفْسُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His soul"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stomach"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"heaved;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became agitated by a tendency to vomit;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ja$aA^atN","text_ar":"جَشَاَتٌ"},{"kind":"text","text":", (T, S,) i. e."},{"kind":"arabic","text_bw":"AirotafaEato","text_ar":"اِرْتَفَعَتْ"},{"kind":"text","text":"; (T;) or"},{"kind":"arabic","text_bw":"jaA$ato","text_ar":"جَاشَتْ"},{"kind":"text","text":", (TA,) i. e."},{"kind":"arabic","text_bw":"faAratN","text_ar":"فَارَتٌ"},{"kind":"text","text":". (T.) ―         -b12-"},{"kind":"arabic","text_bw":"vAr","text_ar":"ثار"},{"kind":"arabic","text_bw":"AlgaDabu","text_ar":"الغَضَبُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"vaworN","text_ar":"ثَوْرٌ"},{"kind":"text","text":", (M,) (assumed tropical:)  ["},{"kind":"italic_en","text":"Anger became roused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflamed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became roused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited in the utmost degree:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boiled:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"vaAy^rN","text_ar":"ثَايرٌ"},{"kind":"text","text":", below:) or]"},{"kind":"italic_en","text":"became sharp."},{"kind":"text","text":"(M, Msb.) ―         -b13-"},{"kind":"arabic","text_bw":"vArt bayonahumo fitonapN wa$ar~N","text_ar":"ثارت بَيْنَهُمْ فِتْنَةٌ وَشَرٌّ"},{"kind":"text","text":"(A, Msb *) (tropical:)"},{"kind":"italic_en","text":"Discord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissension,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief, became excited among them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between them."},{"kind":"text","text":"(Msb.)"}],"source_refs":["M","K","S","A","Mgh","Msb","TA","T"]},