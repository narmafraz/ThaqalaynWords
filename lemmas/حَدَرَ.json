url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7340","headword_ar":"حَدَرَ","root":"Hdr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(M, Msb, K, &c.) and"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"HuduwrN","text_ar":"حُدُورٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":", (T, M, K,)"},{"kind":"italic_en","text":"He made to descend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to go down"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"downwards"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"down a declivity; sent, let,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from a higher to a lower place"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"position;"},{"kind":"text","text":"(T, S, M, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AHdr","text_ar":"احدر","orth_type":"arrow"},{"kind":"text","text":": (Msb:) [or this latter is not chaste; for, accord. to J,] one says,"},{"kind":"arabic","text_bw":"Hadara Als~afiynapa","text_ar":"حَدَرَ السَّفِينَةَ"},{"kind":"italic_en","text":"he lowered the ship;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent it to a lower place,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"from a higher to a lower part of a river;"},{"kind":"text","text":"(A;) but one should not say,"},{"kind":"arabic","text_bw":"AHdrhA","text_ar":"احدرها"},{"kind":"text","text":". (S.) You say also,"},{"kind":"arabic","text_bw":"Hadara AlHajara","text_ar":"حَدَرَ الحَجَرَ"},{"kind":"arabic","text_bw":"mina Aljabali","text_ar":"مِنَ الجَبَلِ"},{"kind":"italic_en","text":"He rolled down the stone from the mountain."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"Hadaratohumu Als~anapu","text_ar":"حَدَرَتْهُمُ السَّنَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Dearth, scarcity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drought, made them to descend"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the desert"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"brought them to a descent;"},{"kind":"text","text":"(T, S;)"},{"kind":"italic_en","text":"brought them,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"brought them down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made them to descend,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"to the towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages."},{"kind":"text","text":"(A, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Hadara All~ivaAma Eano Hanakihi","text_ar":"حَدَرَ اللِّثَامَ عَنْ حَنَكِهِ"},{"kind":"italic_en","text":"He turned down the"},{"kind":"arabic","text_bw":"lvAm","text_ar":"لثام"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"muffler"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the part beneath his chin."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Hadara Ald~amoEa","text_ar":"حَدَرَ الدَّمْعَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HuduwrN","text_ar":"حُدُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He shed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let fall, tears;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Hd~rhu","text_ar":"حدّرهُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"AlEayonu taHoduru Ald~amoEa","text_ar":"العَيْنُ تَحْدُرُ الدَّمْعَ"},{"kind":"text","text":", (A, K, *) and"},{"kind":"arabic","text_bw":"taHodiruhu","text_ar":"تَحْدِرُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadarN","text_ar":"حَدَرٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The eye sheds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lets fall, tears;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"flows with tears."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Ald~amoEu yaHoduru AlkuHola","text_ar":"الدَّمْعُ يَحْدُرُ الكُحْلَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The tears make the collyrium to flow down"},{"kind":"text","text":"]. (A.) ―         -b5-"},{"kind":"arabic","text_bw":"Hadara Ald~awaA='u baTonahu","text_ar":"حَدَرَ الدَّوَا=ءُ بَطْنَهُ"},{"kind":"text","text":", (A,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The medicine made his belly to discharge itself."},{"kind":"text","text":"(A, K.) [And"},{"kind":"arabic","text_bw":"AlT~amova","text_ar":"الطَّمْثَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hd~r","text_ar":"حدّر","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a medicine)"},{"kind":"italic_en","text":"caused the menstrual flux to descend:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"muHad~irN","text_ar":"مُحَدِّرٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"Hadara","text_ar":"حَدَرَ"},{"kind":"text","text":", (T, S, Mgh, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":"; (S, Mgh, K;) and ↓"},{"kind":"arabic","text_bw":"AHdr","text_ar":"احدر","orth_type":"arrow"},{"kind":"text","text":", (T, S, A, K,) inf. n."},{"kind":"arabic","text_bw":"A_iHodaArN","text_ar":"اـِحْدَارٌ"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"the skin"},{"kind":"italic_en","text":"to swell,"},{"kind":"text","text":"(T, S, A, Mgh, K,)"},{"kind":"italic_en","text":"and to become thick,"},{"kind":"text","text":"(A,) by beating. (T, S, A, Mgh.)       -A3-"},{"kind":"arabic","text_bw":"Hadara Alv~awoba","text_ar":"حَدَرَ الثَّوْبَ"},{"kind":"text","text":", (A, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AHdrhu","text_ar":"احدرهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"A_iHodaArN","text_ar":"اـِحْدَارٌ"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"He twisted the unwoven warp,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"the extremities of the unwoven warp,"},{"kind":"text","text":"(S, A,)"},{"kind":"italic_en","text":"of the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth;"},{"kind":"text","text":"(S, A, K;)"},{"kind":"italic_en","text":"like as is done with the ends of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garments of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akosiyap","text_ar":"اَكْسِيَة"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"kisaA='","text_ar":"كِسَا=ء"},{"kind":"text","text":"]: (S:) because its length is thus diminished. (A.)       -A4-  See 7. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Hadara fiY AlqiraA='api","text_ar":"حَدَرَ فِى القِرَا=ءَةِ"},{"kind":"text","text":", (S, Mgh, Msb, K, *) and"},{"kind":"arabic","text_bw":"fiY AlA^a*aAni","text_ar":"فِى الاَذَانِ"},{"kind":"text","text":", (S, Mgh, Msb,) and"},{"kind":"arabic","text_bw":"fiY AlA_iqaAmapi","text_ar":"فِى الاـِقَامَةِ"},{"kind":"text","text":", (Msb,) aor."},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":"; (S, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Hd~r","text_ar":"حدّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHodiyrN","text_ar":"تَحْدِيرٌ"},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"Hadara AlqiraA='apa","text_ar":"حَدَرَ القِرَا=ءَةَ"},{"kind":"text","text":", (A, Msb,) and"},{"kind":"arabic","text_bw":"AlA^a*aAna","text_ar":"الاَذَانَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlA_iqaAmapa","text_ar":"الاـِقَامَةَ"},{"kind":"text","text":"; (Msb;) (tropical:)"},{"kind":"italic_en","text":"He hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick, in the reading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recitation,"},{"kind":"text","text":"(S, A, Mgh, Msb, K, *) and"},{"kind":"italic_en","text":"in the call to prayer,"},{"kind":"text","text":"(S, Mgh, Msb,) and"},{"kind":"italic_en","text":"in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"form of words called the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AqAmp","text_ar":"اقامة"},{"kind":"text","text":"; (Msb;) and"},{"kind":"italic_en","text":"he hastened the reading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recitation,"},{"kind":"text","text":"&c. (Msb.)       -A5-"},{"kind":"arabic","text_bw":"Hadara","text_ar":"حَدَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hadura","text_ar":"حَدُرَ"},{"kind":"text","text":", inf. n. [of the latter, accord. to analogy,]"},{"kind":"arabic","text_bw":"HuduwrapN","text_ar":"حُدُورَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a bow-string)"},{"kind":"italic_en","text":"was thick and strong."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"HaAdirN","text_ar":"حَادِرٌ"},{"kind":"text","text":".]) ―         -b2-  And [hence, app.,] (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a boy)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"HaAdirN","text_ar":"حَادِرٌ"},{"kind":"text","text":"[q. v.]: (TA:) [or]"},{"kind":"arabic","text_bw":"Hadura","text_ar":"حَدُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Lth, As, S, A, K;) and"},{"kind":"arabic","text_bw":"Hadara","text_ar":"حَدَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (ISd, K;) inf. n. [of the former]"},{"kind":"arabic","text_bw":"HadaArapN","text_ar":"حَدَارَةٌ"},{"kind":"text","text":"(A, K) and"},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":"; (S, K;) (tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, compact in make,"},{"kind":"text","text":"(As, S, K,)"},{"kind":"italic_en","text":"and thick:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"short and fleshy:"},{"kind":"text","text":"(A:) and"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fat, with thickness,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and shortness."},{"kind":"text","text":"(TA. [See"},{"kind":"arabic","text_bw":"HaAdirN","text_ar":"حَادِرٌ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"arabic","text_bw":"Hadara","text_ar":"حَدَرَ"},{"kind":"text","text":", (T, S, A, K,) aor."},{"kind":"text","text":"(T, S, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HuduwrN","text_ar":"حُدُورٌ"},{"kind":"text","text":"(T, S, A) and"},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AHdr","text_ar":"احدر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iHodaArN","text_ar":"اـِحْدَارٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Hd~r","text_ar":"حدّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHodiyrN","text_ar":"تَحْدِيرٌ"},{"kind":"text","text":"; (K, TA;) or tho first form only; (T;) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the skin)"},{"kind":"italic_en","text":"became swollen,"},{"kind":"text","text":"(T, S, TA,) as also ↓"},{"kind":"arabic","text_bw":"AnHdr","text_ar":"انحدر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) by reason of beating: (T, S, TA:) or"},{"kind":"italic_en","text":"became swollen and thick,"},{"kind":"text","text":"by reason thereof. (A, K.) ―         -b4-"},{"kind":"arabic","text_bw":"Hadurati AlEayonu","text_ar":"حَدُرَتِ العَيْنُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadaArapN","text_ar":"حَدَارَةٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The eye was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, large and wide:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","K","T","S","Msb","TA","A","Mgh","As"]}]},"classical_definitions":null}