{"lemma":"واجِدُ","slug":"واجِدُ","root":"#.ج.د","root_slug":"_-ج-د","root_link":"/words/roots/_-ج-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n41698"],"search_url":"https://lanelexicon.com/?s=%D9%88%D8%A7%D8%AC%D9%90%D8%AF%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41698","headword_ar":"وَاجِدٌ","root":"wjd","body":[{"kind":"text","text":", act. part. n of 1,"},{"kind":"italic_en","text":"Finding;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a finder; &c."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"italic_en","text":"Rich; possessing competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency; in no need; without wants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with few wants;"},{"kind":"text","text":"(L;)"},{"kind":"italic_en","text":"solvent; one who finds that wherewith to pay what he owes."},{"kind":"text","text":"(A 'Obeyd, L.) Ex."},{"kind":"arabic","text_bw":"laY~u AlwaAjidi yuHil~u Euquwbatahu","text_ar":"لَىُّ الوَاجِدِ يُحِلُّ عُقُوبَتَهُ"},{"kind":"italic_en","text":"The solvent man's putting off the payment of his debt with promises repeated time after time makes his punishment allowable."},{"kind":"text","text":"(L, from a trad. See Mgh art."},{"kind":"arabic","text_bw":"lwY","text_ar":"لوى"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"AlwaAjidu","text_ar":"الوَاجِدُ"},{"kind":"text","text":", as an epithet applied to God,"},{"kind":"italic_en","text":"He who has no wants."},{"kind":"text","text":"(IAth, L.)       -A2-"},{"kind":"arabic","text_bw":"huwa waAjidN EalaY SaAHibihi","text_ar":"هُوَ وَاجِدٌ عَلَى صَاحِبِهِ"},{"kind":"italic_en","text":"He is angry with his companion."},{"kind":"text","text":"(A.)       -A3-"},{"kind":"arabic","text_bw":"A^anaA","text_ar":"اَنَا"},{"kind":"arabic","text_bw":"waAjidN lil$~aYo'i","text_ar":"وَاجِدٌ لِلشَّىْءِ"},{"kind":"italic_en","text":"I am able to do the thing."},{"kind":"text","text":"(Msb.)       -A4-"},{"kind":"arabic","text_bw":"huwa waAjidN bifulaAnapa","text_ar":"هُوَ وَاجِدٌ بِفُلَانَةَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mutawaj~idN","text_ar":"مُتَوَجِّدٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He is in love"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"passionately in love"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with such a female."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"wujudN","text_ar":"وُجُدٌ"},{"kind":"text","text":"is mentioned in the Towsheeh as a pl. of"},{"kind":"arabic","text_bw":"waAjidN","text_ar":"وَاجِدٌ"},{"kind":"text","text":"; but this is strange. (TA.)"}],"source_refs":[]}]}}