ns":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to move [with مِنْ (min) ‘from inside’] (somewhere) to outside; to leave; to exit; to get out","tags":["intransitive"],"examples":[{"text":"خَرَجْتُ مَعَهَا","english":"I went out with her."},{"text":"خَرَجَ مِنَ الْبَيْتِ","english":"He left the house."}]},{"pos":"verb","gloss":"to go or come [with مِنْ (min) ‘out of’] somewhere physically or otherwise (depending on whether the view is from inside or outside); to go out or come out","tags":["intransitive"],"examples":[{"text":"خَرَجَ مِنَ الْبَوَّابَة","english":"He went out/came out through the gate."}]},{"pos":"verb","gloss":"to go or come [with مِنْ (min) ‘out of’] somewhere physically or otherwise (depending on whether the view is from inside or outside); to go out or come out; to go forth or come forth; to issue; to emerge","tags":["intransitive"],"examples":[{"text":"خَرَجَ مِنَ الْيَنْبُوعِ مَاءٌ كَثِير","english":"There gushed forth from the spring plenty of water."},{"text":"خُرُوجُ يَأْجُوجَ وَمَأْجُوج","english":"the issuing of Gog and Magog"}]},{"pos":"verb","gloss":"to get","tags":["intransitive"],"examples":[{"text":"خَرَجَ مِنَ الْمُشْكِلَةِ","english":"He got out of the problem."}]},{"pos":"verb","gloss":"to deviate","tags":["intransitive"],"examples":[{"text":"خَرَجَ الْقِطَارُ عَنِ الْخَطِّ","english":"The train ran off the rails."}]},{"pos":"verb","gloss":"to deviate; to depart or drift away","tags":["intransitive"]},{"pos":"verb","gloss":"to march [with عَلَى (ʕalā) ‘against’], to take up arms against, to fight or rebel against","tags":["intransitive"],"examples":[{"text":"خَرَجَ عَلَى الْحَاكِمِ","english":"He took to open rebellion against the sovereign."}]},{"pos":"verb","gloss":"to make go out or come out (depending on whether the view is from inside or outside)","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to make go out or come out (depending on whether the view is from inside or outside); to make leave; to push out; to turn out; to force out","tags":["intransitive","transitive"],"examples":[{"text":"خَرَّجَهُ مِنْ بَيْتِهِ مُرْغَماً","english":"He forcibly turned him out of his home."}]},{"pos":"verb","gloss":"to draw out or extract the essence or meaning of; to explicate; to distill; to decompose","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to extract the chains of narrators of (a tradition)","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to train","tags":["intransitive","transitive"]},{"pos":"noun","gloss":"expenditure, outlay, expense, costs","tags":["intransitive","transitive"],"examples":[{"text":"فَهَلْ نَجْعَلُ لَكَ خَرْجًا عَلَىٰ أَن تَجْعَلَ بَيْنَنَا وَبَيْنَهُمْ سَدًّا","english":"Should we pay you tribute, provided that you build a wall between us and them?"}]},{"pos":"noun","gloss":"saddlebag","tags":["intransitive","transitive"]},{"pos":"noun","gloss":"portmanteau","tags":["intransitive","transitive"]}]},"etymology":{"source":"wiktextract","text":"From the root خ ر ج (ḵ r j), ultimately from Iranian; see خَرَاج (ḵarāj, “poll-tax”).\n\nUltimately from Iranian; see كُرْز (kurz, “satchel”)."},"ipa":["/xa.ra.d͡ʒa/","/xa.raɡ/","/xard͡ʒ/","/xurd͡ʒ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10271","headword_ar":"خَرَجَ","root":"xrj","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"xuruwjN","text_ar":"خُرُوجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maxorajN","text_ar":"مَخْرَجٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went, came, passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth; issued, emanated, proceeded, went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed; contr. of"},{"kind":"arabic","text_bw":"daxala","text_ar":"دَخَلَ"},{"kind":"text","text":"; (TA;)"},{"kind":"arabic","text_bw":"mina AlmawoDiEi","text_ar":"مِنَ المَوْضِعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the place"},{"kind":"text","text":"]. (Msb.) One says,"},{"kind":"arabic","text_bw":"xaraja maxorajFA HasanFA","text_ar":"خَرَجَ مَخْرَجًا حَسَنًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went, came, passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"well:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it turned out well"},{"kind":"text","text":"]. (S.) [And"},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"arabic","text_bw":"mino TaAEatihi","text_ar":"مِنْ طَاعَتِهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TaAy^iEN","text_ar":"طَايِعٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"TwE","text_ar":"طوع"},{"kind":"text","text":". When"},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"It was disbursed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expended,"},{"kind":"text","text":"the inf. n. is"},{"kind":"arabic","text_bw":"xarojN","text_ar":"خَرْجٌ"},{"kind":"text","text":".]"},{"kind":"arabic","text_bw":"xaraja bihi","text_ar":"خَرَجَ بِهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He went out,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]: see 4. (TA.)"},{"kind":"arabic","text_bw":"yawomu Alxuruwji","text_ar":"يَوْمُ الخُرُوجِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The day of going forth"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"the day of the"},{"kind":"arabic","text_bw":"Eiyd","text_ar":"عِيد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"festival"},{"kind":"text","text":"]. (A, TA, from a trad.) And [as used in the Kur l. 41]"},{"kind":"italic_en","text":"The day when men shall come forth from their graves;"},{"kind":"text","text":"(TA;) a name of"},{"kind":"italic_en","text":"the day of resurrection."},{"kind":"text","text":"(AO, K.) ―         -b2-  [(assumed tropical:)"},{"kind":"italic_en","text":"It became excluded"},{"kind":"text","text":"by a definition or a rule or the like, or by a portion thereof.]"},{"kind":"arabic","text_bw":"manoSuwbN EalaY Alxuruwji","text_ar":"مَنْصُوبٌ عَلَى الخُرُوجِ"},{"kind":"text","text":"is a phrase of the Basree grammarians, said of the objective complement of a verb, meaning (assumed tropical:)"},{"kind":"italic_en","text":"Put in the accus. case as being out of the predicament of the subject and that of the attribute."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xaraja mino A^amorK","text_ar":"خَرَجَ مِنْ اَمْرٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He got out of, escaped from, extricated himself from, evaded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became quit of, affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a state"},{"kind":"text","text":"]. (ISh, TA in art."},{"kind":"arabic","text_bw":"nks","text_ar":"نكس"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"xarajamino HaAlK A_ilaY HaAlK","text_ar":"خَرَجَمِنْ حَالٍ اـِلَى حَالٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He passed from"},{"kind":"text","text":"one"},{"kind":"italic_en","text":"state to"},{"kind":"text","text":"another"},{"kind":"italic_en","text":"state."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"xaraja mino diynihi","text_ar":"خَرَجَ مِنْ دِينِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He quitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsook, his religion."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"arabic","text_bw":"mino dayonihi","text_ar":"مِنْ دَيْنِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mn maraDihi","text_ar":"من مَرَضِهِ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He became quit of his debt,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of his disease."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xaraja A_ilaY fulaAnK mino","text_ar":"خَرَجَ اـِلَى فُلَانٍ مِنْ"},{"kind":"arabic","text_bw":"dayonihi","text_ar":"دَيْنِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He paid such a one his debt:"},{"kind":"text","text":"a phrase used in law. (TA.) [And"},{"kind":"arabic","text_bw":"xaraja EalaY Als~uloTaAni","text_ar":"خَرَجَ عَلَى السُّلْطَانِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eano A^amori Als~uloTaAni","text_ar":"عَنْ اَمْرِ السُّلْطَانِ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He rebelled against the Sultán."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xarajato EalaY xiloqapi Aljamali","text_ar":"خَرَجَتْ عَلَى خِلْقَةِ الجَمَلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"She became formed like the he-camel"},{"kind":"text","text":"]; said of a she-camel that is termed ↓"},{"kind":"arabic","text_bw":"muxotarajapN","text_ar":"مُخْتَرَجَةٌ","orth_type":"arrow"},{"kind":"text","text":". (S, A, K.) And"},{"kind":"arabic","text_bw":"xaraja A_ilaY Alba*aA='a","text_ar":"خَرَجَ اـِلَى البَذَا=ءَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He became foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obscene, in his language"},{"kind":"text","text":"]. (L and K in art."},{"kind":"arabic","text_bw":"xn*","text_ar":"خنذ"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"xaraja fiY AlEilomi waAlS~inaAEapi","text_ar":"خَرَجَ فِى العِلْمِ وَالصِّنَاعَةِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuruwjN","text_ar":"خُرُوجٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, conspicuous in science and art."},{"kind":"text","text":"(A, TA. [See also 5.]) ―         -b4-"},{"kind":"arabic","text_bw":"maA A^aHosana xuruwjahaA","text_ar":"مَا اَحْسَنَ خُرُوجَهَا"},{"kind":"text","text":", said of a cloud ("},{"kind":"arabic","text_bw":"saHaAbap","text_ar":"سَحَابَة"},{"kind":"text","text":"), (tropical:)"},{"kind":"italic_en","text":"How good is its first rising from the horizon!"},{"kind":"text","text":"(A.) [You say also,"},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"arabic","text_bw":"Als~aHaAbu","text_ar":"السَّحَابُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuruwjN","text_ar":"خُرُوجٌ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"The clouds became extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expanded:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"xarojN","text_ar":"خَرْجٌ"},{"kind":"text","text":".] And"},{"kind":"arabic","text_bw":"xarajati Als~amaA='u","text_ar":"خَرَجَتِ السَّمَا=ءُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The sky became clear, after having been cloudy."},{"kind":"text","text":"(T, A.)"}],"source_refs":["L","S","Msb","K"]}]}}