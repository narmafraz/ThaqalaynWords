{"lemma":"وَدِيعَةٌ","slug":"وَدِيعَةٌ","root":"#.د.ع","root_slug":"_-د-ع","root_link":"/words/roots/_-د-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n44503"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%AF%D9%90%D9%8A%D8%B9%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"deposit"}]},"etymology":null,"ipa":["/wa.diː.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44503","headword_ar":"وَدِيعَةٌ","root":"wdE","body":[{"kind":"italic_en","text":"A thing committed to the trust and care of a person; a trust; a deposit."},{"kind":"text","text":"(Mgh, Msb.) See 10."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%88%D8%AF%D9%8A%D8%B9%D8%A9/","headword_ar":"وديعة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23823#50ae55","body_html":"<span>الوديعة: هي أمانة تركت عند الغير للحفظ قصدًا. واحترز بالقيد الأخير من الأمانة، وهي ما وقع في يده من غير قصد، كإلقاء الريح ثوبًا في حجر غيره، وكالعبد الآبق في يد آخذه، واللقطة في يد واجدها، وغير ذلك، والفرق بينهما بالعموم والخصوص، فالوديعة خاصة والأمانة عامة، وحمل العام على الخاص صحيح دون عكسه، ويبرأ في الوديعة عن الضمان إذا عاد إلى الوفاق، ولا يبرأ في الأمانة. </span>"}]}}