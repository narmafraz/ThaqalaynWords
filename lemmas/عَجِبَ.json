{"lemma":"عَجِبَ","slug":"عَجِبَ","root":"ع.ج.ب","root_slug":"ع-ج-ب","root_link":"/words/roots/ع-ج-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَجِبْتَ","in_corpus":true,"count":12,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَجِبْتِ","in_corpus":true,"count":12,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَجِبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَجِبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَجِبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَجِبَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَجِبَت","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَجِبا","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَجِبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَجِبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَجِبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْجَب","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْجَبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْجَبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْجَبا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْجَبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْجَبُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْجَبُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْجَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْجَب","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْجَب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْجَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْجَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْجَبا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْجَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْجَبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْجَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْجَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْجَب","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْجَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَجِبْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَجِبْتُ","in_corpus":true,"count":12,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":83,"cross_references":{"qac":{"found":true,"lemma_key":"عَجِبَ","root":"عجب","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28096","n28097","n28098","n28099"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wonder, to marvel, to be astonished, to be amazed"},{"pos":"verb","gloss":"to strike with wonder, to strike with astonishment, to surprise"},{"pos":"noun","gloss":"pride, vanity, conceit"},{"pos":"noun","gloss":"verbal noun of عَجِبَ (ʕajiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wonder, marvel, astonishment, amazement"},{"pos":"adj","gloss":"wonderful, marvelous","examples":[{"text":"قُلْ أُوحِيَ إِلَيَّ أَنَّهُ ٱسْتَمَعَ نَفَرٌ مِّنَ الْجِنِّ فَقَالُوا إِنَّا سَمِعْنَا قُرْآنًا عَجَبًا","english":"Say, \"It has been revealed to me that a team of the jinn listened [to the Qurʾān] and they said, 'We have indeed heard a wonderful Qurʾān.'\""}]}]},"etymology":null,"ipa":["/ʕa.d͡ʒi.ba/","/ʕad͡ʒ.d͡ʒa.ba/","/ʕud͡ʒb/","/ʕa.d͡ʒab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28096","headword_ar":"عَجْبٌ","root":"Ejb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":", in two places:       -A2-  and see also"},{"kind":"arabic","text_bw":"EujobN","text_ar":"عُجْبٌ"},{"kind":"text","text":".       -A3-  Also The"},{"kind":"italic_en","text":"root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"base, of the tail:"},{"kind":"text","text":"(S, O, K:) or the"},{"kind":"italic_en","text":"part of the root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"base, of the tail,"},{"kind":"text","text":"of any beast,"},{"kind":"italic_en","text":"which the haunch encloses,"},{"kind":"text","text":"(Msb, TA,)"},{"kind":"italic_en","text":"and which is inserted in the hinder part of the rump:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"base, and bone, of the tail:"},{"kind":"text","text":"(Lh, TA:) also called the"},{"kind":"arabic","text_bw":"EuSoEuS","text_ar":"عُصْعُص"},{"kind":"text","text":"[q. v.]: (Msb, TA:) or it is the"},{"kind":"italic_en","text":"head of the"},{"kind":"arabic","text_bw":"EuSoEuS","text_ar":"عُصْعُص"},{"kind":"text","text":": (TA:) or the"},{"kind":"italic_en","text":"upper part of the"},{"kind":"arabic","text_bw":"EuSoEuS","text_ar":"عُصْعُص"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"external extremity of the spine;"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"EuSoEuS","text_ar":"عُصْعُص"},{"kind":"text","text":"is its internal extremity: (Az, L voce"},{"kind":"arabic","text_bw":"quHoquHN","text_ar":"قُحْقُحٌ"},{"kind":"text","text":":) it is said in a trad., that every part of a man will become consumed, except the"},{"kind":"arabic","text_bw":"Eajob","text_ar":"عَجْب"},{"kind":"text","text":", (TA,) or the"},{"kind":"arabic","text_bw":"Eajob","text_ar":"عَجْب"},{"kind":"text","text":"of the tail, (O, TA,) accord. to different relations; (TA;) from which [as a rudiment] he was created, and upon which he will [at the resurrection] be put together: (O:) i. e. the"},{"kind":"italic_en","text":"bone at the lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part of the spine, at the rump;"},{"kind":"text","text":"which is the"},{"kind":"arabic","text_bw":"Easiyb","text_ar":"عَسِيب"},{"kind":"text","text":"of beasts: it is said to be"},{"kind":"italic_en","text":"like a grain of mustard-seed:"},{"kind":"text","text":"or, as Z says in the “ Fáïk, ” it is the"},{"kind":"italic_en","text":"bone that is between the buttocks:"},{"kind":"text","text":"it is also pronounced ↓"},{"kind":"arabic","text_bw":"EujobN","text_ar":"عُجْبٌ","orth_type":"arrow"},{"kind":"text","text":"; and accord. to MF, ↓"},{"kind":"arabic","text_bw":"EijobN","text_ar":"عِجْبٌ","orth_type":"arrow"},{"kind":"text","text":", but no one else says this: and, as El-Khafájee says, it is also called"},{"kind":"arabic","text_bw":"EajomN","text_ar":"عَجْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EujomN","text_ar":"عُجْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EijomN","text_ar":"عِجْمٌ"},{"kind":"text","text":", in this case with the three vowel-sounds. (TA.) ―         -b2-  Also (tropical:)  The"},{"kind":"italic_en","text":"hinder part"},{"kind":"text","text":"(S, O, K, TA) of a tract of sand, (S, O,) or of anything: (K, TA:) and hence,"},{"kind":"arabic","text_bw":"Eajobu kaviybK","text_ar":"عَجْبُ كَثِيبٍ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"the thin hinder portion"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a sand-hill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of an extended and gibbous sand-hill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a collection of sand that has poured down"},{"kind":"text","text":"]: (TA:) pl."},{"kind":"arabic","text_bw":"EujuwbN","text_ar":"عُجُوبٌ"},{"kind":"text","text":", (S, O,) and perhaps"},{"kind":"arabic","text_bw":"A^aEojaAbN","text_ar":"اَعْجَابٌ"},{"kind":"text","text":"also in the former sense [and therefore in this likewise]. (TA.)"}],"source_refs":["S","O","K","Msb","TA","Lh"]},{"entry_id":"n28097","headword_ar":"عُجْبٌ","root":"Ejb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":". ―         -b2-  Also a subst. from the phrase"},{"kind":"arabic","text_bw":"A^uEojiba binafosihi","text_ar":"اُعْجِبَ بِنَفْسِهِ"},{"kind":"text","text":", (S,) or from"},{"kind":"arabic","text_bw":"AlA_iEojaAbu","text_ar":"الاـِعْجَابُ"},{"kind":"text","text":"; (O;) [i. e. it signifies"},{"kind":"italic_en","text":"Self-admiration;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selfconceitedness;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"vanity;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"pride:"},{"kind":"text","text":"(K:) it is said to be [a result, or an offspring, of stupidity, or folly; or] a redundance of stupidity, or folly, which one has turned to what is thus termed. (TA.) [Er-Rághib makes a distinction between"},{"kind":"arabic","text_bw":"EujobN","text_ar":"عُجْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tiyhN","text_ar":"تِيهٌ"},{"kind":"text","text":"; as will be seen below, voce"},{"kind":"arabic","text_bw":"muEojabN","text_ar":"مُعْجَبٌ"},{"kind":"text","text":".]       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"EajobN","text_ar":"عَجْبٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"EijobN","text_ar":"عِجْبٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"A man who is pleased to sit with women,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"and to converse with them, without his doing what induces doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil opinion:"},{"kind":"text","text":"(O:) or"},{"kind":"italic_en","text":"with whom women are pleased:"},{"kind":"text","text":"(K, TA:) the pl. is perhaps"},{"kind":"arabic","text_bw":"A^aEojaAbN","text_ar":"اَعْجَابٌ"},{"kind":"text","text":". (TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"EajobN","text_ar":"عَجْبٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","O","TA"]},{"entry_id":"n28098","headword_ar":"عِجْبٌ","root":"Ejb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EujobN","text_ar":"عُجْبٌ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"EajobN","text_ar":"عَجْبٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28099","headword_ar":"عَجَبٌ","root":"Ejb","body":[{"kind":"text","text":"[originally an int. n.] (S, O, K) and ↓"},{"kind":"arabic","text_bw":"EujobN","text_ar":"عُجْبٌ","orth_type":"arrow"},{"kind":"text","text":", (accord. to the K,) or ↓"},{"kind":"arabic","text_bw":"EajobN","text_ar":"عَجْبٌ","orth_type":"arrow"},{"kind":"text","text":", (accord. to the TA,)"},{"kind":"italic_en","text":"Wonder;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"a deeming strange, extraordinary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"improbable, what occurs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"presents itself, to one,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"on account of being little accustomed to it;"},{"kind":"text","text":"(TA;) or [the"},{"kind":"italic_en","text":"effect, upon the mind, of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the consideration of a thing with which one is not familiar, and to which one is not accustomed:"},{"kind":"text","text":"(IAar, TA:) for a distinction between"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EajobN","text_ar":"عَجْبٌ","orth_type":"arrow"},{"kind":"text","text":", see 1, in the middle of the paragraph: the pl. of"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"[in this sense] is [said to be]"},{"kind":"arabic","text_bw":"A^aEojaAbN","text_ar":"اَعْجَابٌ"},{"kind":"text","text":"; (K;) or it has no pl.: (S, O, K:) [this statement correctly applies to"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"as an epithet; for as such it is app. used as sing. and pl., being originally an inf. n.:] but El-'Ajjáj has pluralized it, [regarding it in the sense expl. above,] saying,"},{"kind":"quote","text":"*akarona A^a$ojaAbFA limano ta$aj~abaA\n                      \n                     \n                        wahijona A^aEojaAbFA limano taEaj~abaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They mentioned griefs to him who grieved, and they excited wonder to him who wondered"},{"kind":"text","text":"]. (O.)"},{"kind":"arabic","text_bw":"yaA laloEajabi","text_ar":"يَا لَلْعَجَبِ"},{"kind":"text","text":"[may be rendered"},{"kind":"italic_en","text":"O case of wonder!"},{"kind":"text","text":"but properly] means"},{"kind":"italic_en","text":"O wonder come,"},{"kind":"text","text":"for this is thy time: and"},{"kind":"arabic","text_bw":"yaA liloEajabi","text_ar":"يَا لِلْعَجَبِ"},{"kind":"text","text":"[may also be rendered"},{"kind":"italic_en","text":"O case of wonder!"},{"kind":"text","text":"but properly] means"},{"kind":"italic_en","text":"O"},{"kind":"text","text":"[people, or the like, come]"},{"kind":"italic_en","text":"to wonder;"},{"kind":"text","text":"the noun signifying the invoked being suppressed. (Har p. 27.)       -A2-  It is also an epithet applied to a thing, an affair, an event, or a case; one says"},{"kind":"arabic","text_bw":"A^amorN EajabN","text_ar":"اَمْرٌ عَجَبٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A wonderful thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair"},{"kind":"text","text":"&c.]; and so ↓"},{"kind":"arabic","text_bw":"EajiybN","text_ar":"عَجِيبٌ","orth_type":"arrow"},{"kind":"text","text":"[which is more common in this sense], and ↓"},{"kind":"arabic","text_bw":"EujaAbN","text_ar":"عُجَابٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Euj~aAbN","text_ar":"عُجَّابٌ","orth_type":"arrow"},{"kind":"text","text":": or ↓"},{"kind":"arabic","text_bw":"EajiybN","text_ar":"عَجِيبٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"; but ↓"},{"kind":"arabic","text_bw":"EujaAbN","text_ar":"عُجَابٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"more than"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":": (K:) or ↓"},{"kind":"arabic","text_bw":"EujaAbN","text_ar":"عُجَابٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EajiybN","text_ar":"عَجِيبٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O,) which signifies a thing, (S, O, Msb,) or an affair, or event, or a case, (S, O,)"},{"kind":"italic_en","text":"wondered at;"},{"kind":"text","text":"(S, O, Msb, TA;) or"},{"kind":"italic_en","text":"inducing wonder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admiration, and pleasure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rejoicing;"},{"kind":"text","text":"syn. ↓"},{"kind":"arabic","text_bw":"muEojibN","text_ar":"مُعْجِبٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Euj~aAbN","text_ar":"عُجَّابٌ","orth_type":"arrow"},{"kind":"text","text":"; signifies"},{"kind":"italic_en","text":"more than"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":": (S, O, TA:) [it is said that]"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":"has no pl.; [app. meaning when it is used as an epithet, as observed above;] nor has ↓"},{"kind":"arabic","text_bw":"EajiybN","text_ar":"عَجِيبٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, O, K;) or the pl. of this is"},{"kind":"arabic","text_bw":"EajaAy^ibu","text_ar":"عَجَايِبُ"},{"kind":"text","text":"[respecting which see"},{"kind":"arabic","text_bw":"EajiybapN","text_ar":"عَجِيبَةٌ"},{"kind":"text","text":"]; (S, O, K;) like as"},{"kind":"arabic","text_bw":"A^afaAy^ilu","text_ar":"اَفَايِلُ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"A^afiylN","text_ar":"اَفِيلٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"tabaAy^iEu","text_ar":"تَبَايِعُ"},{"kind":"text","text":", of"},{"kind":"arabic","text_bw":"tabiyEN","text_ar":"تَبِيعٌ"},{"kind":"text","text":". (S, O.) [Being originally an inf. n., it is used alike as masc. and fem.:] one says"},{"kind":"arabic","text_bw":"qiS~apN EajabN","text_ar":"قِصَّةٌ عَجَبٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"A wonderful story:"},{"kind":"text","text":"and for the same reason, it may, as an epithet, be also used alike as sing. and pl.: like"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"&c.]. (O.) ―         -b2-  [It is also used as a subst. in a pl. sense, signifying"},{"kind":"italic_en","text":"Wonders,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"wonderful things;"},{"kind":"text","text":"like the pl."},{"kind":"arabic","text_bw":"EajaAy^ibu","text_ar":"عَجَايِبُ"},{"kind":"text","text":", &c.; and it may be similarly used in a sing. sense for"},{"kind":"arabic","text_bw":"$aYo'N EajabN","text_ar":"شَىْءٌ عَجَبٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A^amorN EajabN","text_ar":"اَمْرٌ عَجَبٌ"},{"kind":"text","text":": but when used as a subst. in the pl. sense expl. above, it seems to be regarded by some as a coll. gen. n., of which ↓"},{"kind":"arabic","text_bw":"EajabapN","text_ar":"عَجَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"is the n. un.; for] one says,"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"fulaAnN A_il~aA EajabapN mina AlEajabi","text_ar":"فُلَانٌ اـِلَّا عَجَبَةٌ مِنَ العَجَبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is none other than a wonder of wonders"},{"kind":"text","text":"]. (A, TA.) [Hence, also,]"},{"kind":"arabic","text_bw":"A^abuw AlEajabi","text_ar":"اَبُو العَجَبِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"The father of wonders"},{"kind":"text","text":"] is a surname of"},{"kind":"italic_en","text":"Fortune."},{"kind":"text","text":"(TA.) And it signifies also"},{"kind":"italic_en","text":"The practiser of legerdemain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sleight-of-hand;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Al$~aEowa*iY~u","text_ar":"الشَّعْوَذِىُّ"},{"kind":"text","text":", (A, TA,) or"},{"kind":"arabic","text_bw":"Almu$aEowi*u","text_ar":"المُشَعْوِذُ"},{"kind":"text","text":": (Eth-Tha'álibee, TA in"},{"kind":"arabic","text_bw":"$E*","text_ar":"شعذ"},{"kind":"text","text":":) and"},{"kind":"italic_en","text":"any one who does wonderful things."},{"kind":"text","text":"(A, TA.) And a poet says,"},{"kind":"quote","text":"yaA EajabFA lild~ahori *iY AlA^aEojaAbi"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"yaA A^aEojabu EajabFA","text_ar":"يَا اَعْجَبُ عَجَبًا"},{"kind":"text","text":"O,"},{"kind":"italic_en","text":"I wonder greatly,"},{"kind":"text","text":"lit."},{"kind":"italic_en","text":"with wondering, at fortune that is"},{"kind":"text","text":"ever"},{"kind":"italic_en","text":"attended with wonders"},{"kind":"text","text":"]. (TA.) [See also"},{"kind":"arabic","text_bw":"EajiybapN","text_ar":"عَجِيبَةٌ"},{"kind":"text","text":".]       -A3-  Also The"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"in a she-camel,"},{"kind":"italic_en","text":"that is denoted by the epithet"},{"kind":"arabic","text_bw":"EajobaA='u","text_ar":"عَجْبَا=ءُ"},{"kind":"text","text":"[fem. of"},{"kind":"arabic","text_bw":"A^aEojabu","text_ar":"اَعْجَبُ"},{"kind":"text","text":", q. v.]; and so ↓"},{"kind":"arabic","text_bw":"EujobapN","text_ar":"عُجْبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (O.)"}],"source_refs":["S","O","K","TA","IAar","Msb","A"]}]}}