ing:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"fr$","text_ar":"فرش"},{"kind":"text","text":":) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a bird)"},{"kind":"italic_en","text":"expanded his wings;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"raf~a","text_ar":"رَفَّ","orth_type":"arrow"},{"kind":"text","text":"; but this latter is not used. (O, K.) One says also, of an ostrich,"},{"kind":"arabic","text_bw":"yuraforifu bijanaAHayohi vum~a yaEoduw","text_ar":"يُرَفْرِفُ بِجَنَاحَيْهِ ثُمَّ يَعْدُو"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He flaps his wings, then runs"},{"kind":"text","text":"]. (T, S, O.) ―         -b2-  [See also R. Q. 1 in art."},{"kind":"arabic","text_bw":"zf","text_ar":"زف"},{"kind":"text","text":", last sentence.] ―         -b3-"},{"kind":"arabic","text_bw":"rfrf EalaY Alqawomi","text_ar":"رفرف عَلَى القَوْمِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affectionate, favourable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind, to the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taHad~aba","text_ar":"تَحَدَّبَ"},{"kind":"text","text":". (M.) ―         -b4-"},{"kind":"arabic","text_bw":"raforafapN","text_ar":"رَفْرَفَةٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"making a sound:"},{"kind":"text","text":"(K:) its verb,"},{"kind":"arabic","text_bw":"raforafa","text_ar":"رَفْرَفَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"made a sound."},{"kind":"text","text":"(TK.)"}],"source_refs":["T","S","M","K","O"]}]},"classical_definitions":null}