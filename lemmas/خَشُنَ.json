ole":"present_2mp","form":"تَخْشُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْشُنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْشُن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْشُن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْشُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْشُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْشُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْشُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْشُنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْشُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْشُنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْشُن","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْشُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَشُنّا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَشُنْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n10712"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B4%D9%8F%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be coarse, to be rude, to be uncouth, to be rough, to be hoarse"},{"pos":"verb","gloss":"to make coarse, to render rough"},{"pos":"adj","gloss":"rough (not smooth), hard to the touch; coarse (not fine)","examples":[{"text":"وَٱلشَّكْوَسُ قَالَ أَبُو ٱلْخَيْرِ وَغَيْرِهِ هُوَ ٱلْوَرْدُ ٱلْفَحْصِيُّ وَقِيلَ ٱلْبَرِيُّ وَهُوَ نَوْعَانِ أَحَدُهُمَا يُسَمَّى بِٱلْعَجَمِيَّةِ ٱلرَّحْبَلُ وَرَقُهُ فِي قَدْرِ وَرَقِ ٱلزَّيْتُونِ وَأَطْوَلُ وَأَعْرَضُ أََغْبَرُ أَحْرَشُ وَأَغْصَانُهُ خَشِنَةٌ صُلْبَةٌ إِلَى ٱلْبَيَاضِ مَا هِيَ تَطْلَعُ فِي زَمَنِ ٱلرَّبِيعِ نُوْرُهُ كَٱلْوَرْدِ حَمْرَاءُ فَائِتَةٌ وَفِي وَسَطِهَا صُفْرَةٌ وَهَذَا هُوَ ٱلْمُسَمَّى ٱلْوَرْدُ ٱلْفَحْصِيُّ وَيُقَالُ إِنَّ ٱلْوَرْدَ إِنْ رَكِبَ فِيهِ فَيَنْجِبُ وَٱلنَّوْعُ ٱلثَّانِي مِنَ ٱلشَّكْوَسِ وَرَقُهُ أَصْغَرُ مِنْ وَرَقِ ٱلْأَوَّلِ وَأَشَدُّ خُضْرَةً وَهًوَ أَحْرَشُ بَيْنَ ٱلْاِسْتِدَارِ وَٱلطُّولِ وَأَغْصَانِهِ إِلَى ٱلْحَمْرَاءِ مَا هِيَ تَطْلَعُ وَرْدًا أَبْيَضَا نَاصِعَةً فِي وَسَطِهَا وَكِلَاهُمَا لَاحِقٌ بِٱلْأَشْجَارِ.","english":"And the rockrose, say Abū al-Ḵayr and others, is the field rose, and also the land rose, it is said, and there are two kinds: One is called in Berber raḥbal and its leaves are of the dimensions of the leaves of the olive but longer and wider, more gray and rugged, and its branches are rough, stiff and lean into white, and in spring it blossoms in roses of a red hue you almost miss, and in their mid there is yellow and this is called field rose, and it is said that if a rose is grafted onto it it will prevail. The second kind of rockrose has smaller leaves than the first, of a more intense green, and it is more rugged around and along, and its branches lean into red and spawn white roses, vivid in the middle. And both liaise with trees."}]},{"pos":"adj","gloss":"rude, uncouth, rough of manners"},{"pos":"adj","gloss":"tough (life)"},{"pos":"adj","gloss":"hoarse, gruff, raspy, gravelly"}]},"etymology":null,"ipa":["/xa.ʃin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10712","headword_ar":"خَشُنَ","root":"x$n","body":[{"kind":"text","text":", aor"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xu$uwnapN","text_ar":"خُشُونَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xu$onapN","text_ar":"خُشْنَةٌ"},{"kind":"text","text":"(S, Msb, K, KL) and"},{"kind":"arabic","text_bw":"xa$aAnapN","text_ar":"خَشَانَةٌ"},{"kind":"text","text":"(CK, TA, but omitted in some copies of the K) and"},{"kind":"arabic","text_bw":"xa$onN","text_ar":"خَشْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maxo$anapN","text_ar":"مَخْشَنَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rough, harsh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse;"},{"kind":"text","text":"(K, * KL, PS;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"laAna","text_ar":"لَانَ"},{"kind":"text","text":", (S, K,) or"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"naEuma","text_ar":"نَعُمَ"},{"kind":"text","text":"; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"tx$~n","text_ar":"تخشّن","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"huwa *uw xa$onapK","text_ar":"هُوَ ذُو خَشْنَةٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xu$uwnapK","text_ar":"خُشُونَةٍ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"maxo$anapK","text_ar":"مَخْشَنَةٍ"},{"kind":"text","text":"(TA) (tropical:)"},{"kind":"italic_en","text":"He is difficult, refractory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stubborn; not to be coped with."},{"kind":"text","text":"(K, TA. [See also"},{"kind":"arabic","text_bw":"xa$inN","text_ar":"خَشِنٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"xa$una Ealayohi Sadorihi","text_ar":"خَشُنَ عَلَيْهِ صَدْرِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Elyh Sdrh","text_ar":"عليه صدره"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ax$w$n","text_ar":"اخشوشن","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, angry with him."},{"kind":"text","text":"(Sh, TA.) See also 3."}],"source_refs":["S","Msb","K","KL","TA"]}]}}