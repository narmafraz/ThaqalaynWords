,"per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُبَوِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُبَوِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُبَوِّل","in_corpus":true,"count":68,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُبَوِّل","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُبَوِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُبَوِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبَوِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبَوِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبَوِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبَوِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبَوِّلْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُبَوِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبَوِّل","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَوَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَوَّلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":172,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n3570"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%88%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of بَالَ (bāla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"urine"},{"pos":"verb","gloss":"to urinate","tags":["intransitive"]},{"pos":"verb","gloss":"to cause to urinate","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Related in some way to وَبْل (wabl, “a heavy, large-dropped rain”). The exact mechanism is left to guess, claiming a metathesis or univerbation of بِ (bi) would be schematic, perhaps it is just expressive as later بَقْبَقَ (baqbaqa, “to gargle”), whence standard Egyptian Arabic بق (buʔʔ, “mouth”), and Moroccan Arabic بواقة (buwwāqa, “bubble”), English bubble and Arabic بَاسَ (bāsa, “to kiss”) or even قَبَّلَ (qabbala, “to kiss”), in spite of its formal derivation, assuming that ideophony reinforces certain meanings being borne by certain sounds.\nThe verb is a denominal verb from the noun, in view of the latter’s frequency and pertinence to basic vocabulary, though it be formally possible that one of the verbs in the root is original and hence “to urinate” came before “urine” – which isn’t the usual case comparatively however, Latin ūrīna and German Harn etc. are original nouns from which technical language later formed verbs."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3570","headword_ar":"بَوْلٌ","root":"bwl","body":[{"kind":"text","text":", originally an inf. n., (Msb,) ["},{"kind":"italic_en","text":"Urine; stale:"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"A^abowaAlN","text_ar":"اَبْوَالٌ"},{"kind":"text","text":". (S, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A^abowaAlu AlbigaAli","text_ar":"اَبْوَالُ البِغَالِ"},{"kind":"italic_en","text":"The seminal fluid of mules."},{"kind":"text","text":"(As, TA.) And hence, as being likened thereto, because it is fruitless, (As, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"saraAb","text_ar":"سَرَاب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mirage:"},{"kind":"text","text":"in the CK"},{"kind":"arabic","text_bw":"Al$~arAbu","text_ar":"الشَّرابُ"},{"kind":"text","text":"]. (As, K, TA.) It is also applied to the road of El-Yemen, which is not travelled but by mules: see also art."},{"kind":"arabic","text_bw":"bgl","text_ar":"بغل"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"bawolu AlEajuwzi","text_ar":"بَوْلُ العَجُوزِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Cow's milk."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"bawolN","text_ar":"بَوْلٌ"},{"kind":"text","text":"signifies also (tropical:)"},{"kind":"italic_en","text":"Offspring."},{"kind":"text","text":"(M, K, TA.) ―         -b5-  And (tropical:)"},{"kind":"italic_en","text":"A large number."},{"kind":"text","text":"(K, TA.) ―         -b6-  See also"},{"kind":"arabic","text_bw":"A^abowalu","text_ar":"اَبْوَلُ"},{"kind":"text","text":"."}],"source_refs":["Msb","As","TA"]}]}}