{"lemma":"عَرْشٌ","slug":"عَرْشٌ","root":"ع.ر.ش","root_slug":"ع-ر-ش","root_link":"/words/roots/ع-ر-ش","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"عَرْش","root":"عرش","pos":"N","occurrence_count":29},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n28662"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B1%D9%92%D8%B4%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pull up, to build up"},{"pos":"noun","gloss":"throne"},{"pos":"noun","gloss":"booth, shed, any building made of sticks"},{"pos":"noun","gloss":"verbal noun of عَرَشَ (ʕaraša) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28662","headword_ar":"عَرْشٌ","root":"Er$","body":[{"kind":"italic_en","text":"A booth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing constructed for shade,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"miZal~apN","text_ar":"مِظَلَّةٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"mostly made of canes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reeds;"},{"kind":"text","text":"(K;) and sometimes, (TA,)"},{"kind":"italic_en","text":"made of palm-sticks, over which is thrown"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a species of panic grass"},{"kind":"text","text":"]; (Mgh, TA:) as described by Az, on the authority of the Arabs; (TA;) and such is meant by the"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":"of Moses: (Mgh:)"},{"kind":"italic_en","text":"a thing resembling a house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, made of palm-sticks, over which is put"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb:)"},{"kind":"italic_en","text":"a booth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shed,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xayomapN","text_ar":"خَيْمَةٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"made of wood and"},{"kind":"arabic","text_bw":"vmAn","text_ar":"ثمان"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, * O, K;) and such is meant by the ↓"},{"kind":"arabic","text_bw":"Eariy$","text_ar":"عَرِيش","orth_type":"arrow"},{"kind":"text","text":"of Moses; (A;) and sometimes the ↓"},{"kind":"arabic","text_bw":"Eariy$","text_ar":"عَرِيش","orth_type":"arrow"},{"kind":"text","text":"was"},{"kind":"italic_en","text":"made of palm-sticks, with"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"italic_en","text":"thrown over them:"},{"kind":"text","text":"(TA:) both signify"},{"kind":"italic_en","text":"a thing,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"a house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"used for shade:"},{"kind":"text","text":"(S, O, K:) pl. of the former,"},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":"(ISd, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"Euru$N","text_ar":"عُرُشٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aEoraA$N","text_ar":"اَعْرَاشٌ"},{"kind":"text","text":"[which is a pl. of pauc.] and"},{"kind":"arabic","text_bw":"Eira$apN","text_ar":"عِرَشَةٌ"},{"kind":"text","text":": (K:) or"},{"kind":"arabic","text_bw":"Euru$N","text_ar":"عُرُشٌ"},{"kind":"text","text":"is pl. of ↓"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ","orth_type":"arrow"},{"kind":"text","text":", (S, ISd, O, Msb,) not of"},{"kind":"arabic","text_bw":"Earo$N","text_ar":"عَرْشٌ"},{"kind":"text","text":": (ISd:) or it is also pl. of ↓"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) and"},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":"is also a pl. of ↓"},{"kind":"arabic","text_bw":"Euro$N","text_ar":"عُرْشٌ","orth_type":"arrow"},{"kind":"text","text":", which is a pl. of ↓"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ","orth_type":"arrow"},{"kind":"text","text":". (L.) Hence"},{"kind":"italic_en","text":"The houses of Mekkeh,"},{"kind":"text","text":"(S, A, Mgh, O, Msb,)"},{"kind":"italic_en","text":"in which the needy of its inhabitants dwelt,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"its ancient houses,"},{"kind":"text","text":"(K,) were called"},{"kind":"arabic","text_bw":"AlEuruw$u","text_ar":"العُرُوشُ"},{"kind":"text","text":", (S, A, Mgh, O, Msb, K,) and"},{"kind":"arabic","text_bw":"AlEuru$u","text_ar":"العُرُشُ"},{"kind":"text","text":", (S, Msb,) and ↓"},{"kind":"arabic","text_bw":"AlEuro$u","text_ar":"العُرْشُ","orth_type":"arrow"},{"kind":"text","text":"; (O, K;) because they were of poles, or sticks, set up, and shaded over: (S, O, Msb:) or"},{"kind":"italic_en","text":"Mekkeh"},{"kind":"text","text":"itself was called ↓"},{"kind":"arabic","text_bw":"AlEuro$u","text_ar":"العُرْشُ","orth_type":"arrow"},{"kind":"text","text":": (Az, O, L, K:) or it was called"},{"kind":"arabic","text_bw":"AlEaro$u","text_ar":"العَرْشُ"},{"kind":"text","text":", with fet-h, and ↓"},{"kind":"arabic","text_bw":"AlEariy$u","text_ar":"العَرِيشُ","orth_type":"arrow"},{"kind":"text","text":": (Az, L, K:) and"},{"kind":"italic_en","text":"its houses"},{"kind":"text","text":"were called ↓"},{"kind":"arabic","text_bw":"AlEuro$u","text_ar":"العُرْشُ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlEuruw$u","text_ar":"العُرُوشُ"},{"kind":"text","text":". (K.) And hence, (S, O, Msb,) the saying in a trad., (S, O,) i. e., the saying of Saad, (K, TA,) when he heard that Mo'áwiyeh forbade the performing conjointly the greater and minor pilgrimages, (TA,)"},{"kind":"arabic","text_bw":"tamat~aEonaA maEa","text_ar":"تَمَتَّعْنَا مَعَ"},{"kind":"arabic","text_bw":"rasuwli A@ll~`hi Sal~aY A@ll~`hu Ealayohi wasal~ama wafulaAnN kaAfirN biAloEuru$i","text_ar":"رَسُولِ ا@للّٰهِ صَلَّى ا@للّٰهُ عَلَيْهِ وَسَلَّمَ وَفُلَانٌ كَافِرٌ بِالْعُرُشِ"},{"kind":"text","text":", (S, O, K, *) or"},{"kind":"arabic","text_bw":"biAloEuruw$i","text_ar":"بِالْعُرُوشِ"},{"kind":"text","text":", (S, TA,) i. e., ["},{"kind":"italic_en","text":"We performed conjointly the greater and minor pilgrimages with the Apostle of God,"},{"kind":"text","text":"("},{"kind":"italic_en","text":"God bless and save him,"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"when such a one,"},{"kind":"text","text":"meaning Mo'áwiyeh,"},{"kind":"italic_en","text":"was abiding"},{"kind":"text","text":"(O, L, K)"},{"kind":"italic_en","text":"in his state of unbelief,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"in Mekkeh;"},{"kind":"text","text":"(L, K;) i. e."},{"kind":"italic_en","text":"in the houses thereof:"},{"kind":"text","text":"(O, L:) or, as some say,"},{"kind":"italic_en","text":"was hiding himself in the houses of Mekkeh."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"italic_en","text":"A house"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an absolute sense"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"a dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of abode:"},{"kind":"text","text":"(Kr, TA:) pl."},{"kind":"arabic","text_bw":"Euru$N","text_ar":"عُرُشٌ"},{"kind":"text","text":"(TA) [and"},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":"]. ―         -b3-"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"building of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qaSor","text_ar":"قَصْر"},{"kind":"text","text":". (K.) ―         -b4-  The"},{"kind":"italic_en","text":"wood upon which stands the drawer of water:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a structure of wood built at the head of the well, forming a shade:"},{"kind":"text","text":"[pl."},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":":] when the props are pulled away, the"},{"kind":"arabic","text_bw":"Euruw$","text_ar":"عُرُوش"},{"kind":"text","text":"fall down. (TA.) ["},{"kind":"arabic","text_bw":"Earo$N","text_ar":"عَرْشٌ"},{"kind":"text","text":"in relation to a well has also another meaning; which see below.] ―         -b5-  The"},{"kind":"italic_en","text":"wooden thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"trellis"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which serves for the propping"},{"kind":"text","text":"of a grape-vine. (TA.) [But this is more commonly called"},{"kind":"arabic","text_bw":"Eariy$N","text_ar":"عَرِيشٌ"},{"kind":"text","text":", q. v.] ―         -b6-  The"},{"kind":"italic_en","text":"roof"},{"kind":"text","text":"of a house or the like: (S, Mgh, O, Msb, K:) pl."},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":". (A.) So in a trad., where a lamp is mentioned as suspended to the"},{"kind":"arabic","text_bw":"Er$","text_ar":"عرش"},{"kind":"text","text":": (O, TA:) and in another, in which a man relates that he used, when upon his"},{"kind":"arabic","text_bw":"Er$","text_ar":"عرش"},{"kind":"text","text":", to hear the Prophet's reciting [of the Kur-án]. (TA.) And so it has been expl. as occurring in the phrase of the Kur [ii. 261 and xxii. 44],"},{"kind":"arabic","text_bw":"xaAwiyapN EalaY Euruw$ihaA","text_ar":"خَاوِيَةٌ عَلَى عُرُوشِهَا"},{"kind":"italic_en","text":"Having fallen down upon its roofs:"},{"kind":"text","text":"meaning that its walls were standing when their roofs had become demolished and had fallen to the foundations, and the walls fell down upon the roofs demolished before them: (O, TA:) but some consider"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"text","text":"as here meaning"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"[from]. (TA.) ―         -b7-  [Hence, app.,]"},{"kind":"arabic","text_bw":"AlEaro$u","text_ar":"العَرْشُ"},{"kind":"text","text":"is applied to"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"italic_en","text":"of God, which is not definable:"},{"kind":"text","text":"(A, K:) I'Ab is related to have said that the"},{"kind":"arabic","text_bw":"kurosiY~","text_ar":"كُرْسِىّ"},{"kind":"text","text":"is the place of the feet and the"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":"is immeasurable: and it is said in the Mufradát of Er-Rághib that the"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":"of God is"},{"kind":"italic_en","text":"one of the things which mankind know not in reality, but only by name;"},{"kind":"text","text":"and it is not as the imaginations of the vulgar hold it to be; [namely,"},{"kind":"italic_en","text":"the throne of God;"},{"kind":"text","text":"] for were it so, it would be a support to Him; not supported; whereas God saith [in the Kur., xxxv. 39], “ Verily God holdeth the heavens and the earth, lest they should move from their place; and if they should move from their place, no one would hold them after Him: ” or, as some say, it is"},{"kind":"italic_en","text":"the highest sphere;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the empyrean;"},{"kind":"text","text":"] and the"},{"kind":"arabic","text_bw":"krsY~","text_ar":"كرسىّ"},{"kind":"text","text":"is the sphere of the stars: and they adduce as an indication thereof the saying of Mohammad, that the seven heavens and earths, by the side of the"},{"kind":"arabic","text_bw":"krsY~","text_ar":"كرسىّ"},{"kind":"text","text":", are nought but as a ring thrown down in a desert land; and such is the"},{"kind":"arabic","text_bw":"krsY~","text_ar":"كرسىّ"},{"kind":"text","text":"with respect to the"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":": and this assertion is mentioned in the B, but without approval: (TA:) [it appears, however, to be most commonly accepted:] or"},{"kind":"italic_en","text":"a red sapphire, which glistens with the light of the Supreme."},{"kind":"text","text":"(A, K.) [Hence the saying,]"},{"kind":"arabic","text_bw":"mina","text_ar":"مِنَ"},{"kind":"arabic","text_bw":"AlEaro$i A_ilaY Alfaro$i","text_ar":"العَرْشِ اـِلَى الفَرْشِ"},{"kind":"text","text":"meaning, ["},{"kind":"italic_en","text":"From the highest sphere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the empyrean, to"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the earth."},{"kind":"text","text":"(A.) ―         -b8-  Also"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"sariyr","text_ar":"سَرِير"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"throne"},{"kind":"text","text":"] (S, A, O, Msb, K)"},{"kind":"italic_en","text":"of a king;"},{"kind":"text","text":"(S, A, O, K;) the"},{"kind":"italic_en","text":"seat of a sultán;"},{"kind":"text","text":"[perhaps as being likened to the"},{"kind":"arabic","text_bw":"Er$","text_ar":"عرش"},{"kind":"text","text":"of God; or, more probably, from its being generally surmounted by a canopy; or] because of its height. (Er-Rághib.) [Hence,] the phrase"},{"kind":"arabic","text_bw":"AisotawaY EalaY","text_ar":"اِسْتَوَى عَلَى"},{"kind":"arabic","text_bw":"Earo$ihi","text_ar":"عَرْشِهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He reigned as king."},{"kind":"text","text":"(A, TA.) ―         -b9-  And [hence, also,]"},{"kind":"italic_en","text":"Certain stars in advance of"},{"kind":"arabic","text_bw":"Als~imaAk AlA^aEozal","text_ar":"السِّمَاك الاَعْزَل"},{"kind":"text","text":"[which is"},{"kind":"italic_en","text":"Spica Virginis"},{"kind":"text","text":"]; (TA;) [app. those meant by what here follows;]"},{"kind":"arabic","text_bw":"Earo$u","text_ar":"عَرْشُ"},{"kind":"arabic","text_bw":"Als~imaAki","text_ar":"السِّمَاكِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"four small stars"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"γ, δ, ε,","text_ar":"γ, δ, ε,","orth_type":"plain"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"η","text_ar":"η","orth_type":"plain"},{"kind":"text","text":","},{"kind":"italic_en","text":"of Virgo,"},{"kind":"text","text":"regarded as"},{"kind":"italic_en","text":"the seat of Bootes,"},{"kind":"text","text":"the principal star of which is called"},{"kind":"arabic","text_bw":"Als~imaAku Alr~aAmiHu","text_ar":"السِّمَاكُ الرَّامِحُ"},{"kind":"text","text":", being described as]"},{"kind":"italic_en","text":"beneath"},{"kind":"arabic","text_bw":"AlEaw~aA='","text_ar":"العَوَّا=ء"},{"kind":"text","text":"[which is a name of Bootes and also of the four stars mentioned above],"},{"kind":"italic_en","text":"and also called"},{"kind":"arabic","text_bw":"Eajuzu AlA^asadi","text_ar":"عَجُزُ الاَسَدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the rump of Leo,"},{"kind":"text","text":"the figure of which was extended by the Arabs far beyond the limits which we assign to it]. (S, O, K.) ―         -b10-  And"},{"kind":"arabic","text_bw":"Earo$u AljawozaA='i","text_ar":"عَرْشُ الجَوْزَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The seat of Orion;"},{"kind":"text","text":"applied by our astronomers to"},{"kind":"arabic","text_bw":"α","text_ar":"α","orth_type":"plain"},{"kind":"italic_en","text":"of Lepus;"},{"kind":"text","text":"but described as]"},{"kind":"italic_en","text":"four stars, of which two are on the fore legs and two on the hind legs, of Lepus."},{"kind":"text","text":"(Kzw.) ―         -b11-  And"},{"kind":"arabic","text_bw":"Eamo$u Alv~aray~aA","text_ar":"عَمْشُ الثَّرَيَّا"},{"kind":"italic_en","text":"Certain stars near"},{"kind":"arabic","text_bw":"Alv~uray~aA","text_ar":"الثُّرَيَّا"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the Pleiades"},{"kind":"text","text":"]. (T, TA.) ―         -b12-"},{"kind":"arabic","text_bw":"Earo$N","text_ar":"عَرْشٌ"},{"kind":"text","text":"also signifies The"},{"kind":"arabic","text_bw":"jamaAzap","text_ar":"جَمَازَة"},{"kind":"text","text":"; (O, K, TA;) i. e., the"},{"kind":"italic_en","text":"bier of a corpse."},{"kind":"text","text":"(O, TA.) And hence, as some say, the expression in a trad.,"},{"kind":"arabic","text_bw":"Aihotaz~a AlEaro$u limawoti saEodi boni muEaA*K","text_ar":"اِهْتَزَّ العَرْشُ لِمَوْتِ سَعْدِ بْنِ مُعَاذٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The bier rejoiced"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"shook"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"at the death of Saad Ibn-Mo'ádh;"},{"kind":"text","text":"i. e., at carrying him upon it to his place of burial: (O, K, * TA:) but there are other explanations, for which see art."},{"kind":"arabic","text_bw":"hz","text_ar":"هز"},{"kind":"text","text":". (TA.) ―         -b13-  The"},{"kind":"italic_en","text":"wood with which a well is cased after it has been cased with stones"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"in its lowest part"},{"kind":"text","text":"(S, O)"},{"kind":"italic_en","text":"to the height of the stature of a man:"},{"kind":"text","text":"(S, O, K:) pl."},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":". (S, O.) [Another meaning of the same word in relation to a well has been mentioned before.] ―         -b14-  (assumed tropical:)  The"},{"kind":"italic_en","text":"nest"},{"kind":"text","text":"of a bird,"},{"kind":"italic_en","text":"such as is built in a tree,"},{"kind":"text","text":"(K,) [app. as being likened to a booth.] ―         -b15-  The"},{"kind":"italic_en","text":"angle, or corner, or strongest side,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"rukon","text_ar":"رُكْن"},{"kind":"text","text":", (Ks, Zj, K,) of a house, (Ks, Zj,) or [other] thing: (K:) pl."},{"kind":"arabic","text_bw":"Euruw$N","text_ar":"عُرُوشٌ"},{"kind":"text","text":". (Ks, Zj.) Accord. to some, the phrase in the Kur [ii. 261, mentioned above],"},{"kind":"arabic","text_bw":"xaAwiyapN EalaY Euruw$ihaA","text_ar":"خَاوِيَةٌ عَلَى عُرُوشِهَا"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"Empty, and fallen to ruin upon its"},{"kind":"arabic","text_bw":"A^arokaAn","text_ar":"اَرْكَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"angles,"},{"kind":"text","text":"&c.]. (Ks, Zj, O.) ―         -b16-  [Hence,] (tropical:)  The"},{"kind":"italic_en","text":"head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, who is the manager"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regulator of the affairs,"},{"kind":"text","text":"of a people, or company of men: (K:) likened to the"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":"of a house. (TA.) ―         -b17-  [Hence also,] (assumed tropical:)  The"},{"kind":"italic_en","text":"means of support of a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair."},{"kind":"text","text":"(A, O, K.) Hence the saying,"},{"kind":"arabic","text_bw":"vul~a Earo$uhu","text_ar":"ثُلَّ عَرْشُهُ"},{"kind":"text","text":", (O, K,) meaning (tropical:)"},{"kind":"italic_en","text":"His means of support became taken away:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he perished:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"he was slain;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"vul~a Euro$uhu","text_ar":"ثُلَّ عُرْشُهُ","orth_type":"arrow"},{"kind":"text","text":": (IDrd, in M, art."},{"kind":"arabic","text_bw":"vl","text_ar":"ثل"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"his might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, departed:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"his affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state, became weak, and his might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, departed."},{"kind":"text","text":"(S, O. [See also art."},{"kind":"arabic","text_bw":"vl","text_ar":"ثل"},{"kind":"text","text":".] [For"},{"kind":"arabic","text_bw":"Earo$N","text_ar":"عَرْشٌ"},{"kind":"text","text":"also signifies] ―         -b18-  (tropical:)"},{"kind":"italic_en","text":"Might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power:"},{"kind":"text","text":"(Er-Rághib, K:)"},{"kind":"italic_en","text":"regal power; sovereignty; dominion:"},{"kind":"text","text":"(IAar, Er-Rághib, K:) from the same word as signifying the throne, or seat, of a king. (Er-Rághib.) ―         -b19-  And The"},{"kind":"italic_en","text":"protuberant part"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"the upper surface"},{"kind":"text","text":"of the foot, (S, O, K,)"},{"kind":"italic_en","text":"in which are the toes;"},{"kind":"text","text":"(S, O, TA;) as also ↓"},{"kind":"arabic","text_bw":"Euro$N","text_ar":"عُرْشٌ","orth_type":"arrow"},{"kind":"text","text":": pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEoraA$N","text_ar":"اَعْرَاشٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"Eira$apN","text_ar":"عِرَشَةٌ"},{"kind":"text","text":": (O, TA:) and the"},{"kind":"italic_en","text":"part between the"},{"kind":"arabic","text_bw":"Eayor","text_ar":"عَيْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"prominent bone"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the toes, of the upper surface"},{"kind":"text","text":"of the foot; as also ↓"},{"kind":"arabic","text_bw":"Euro$N","text_ar":"عُرْشٌ","orth_type":"arrow"},{"kind":"text","text":": (Ibn- 'Abbád, O, K:) pls. the same as last mentioned above: (K:) or ↓"},{"kind":"arabic","text_bw":"Euro$N","text_ar":"عُرْشٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"upper surface"},{"kind":"text","text":"of the foot; and its lower surface is called the"},{"kind":"arabic","text_bw":"A^axomaS","text_ar":"اَخْمَص"},{"kind":"text","text":". (IAar.)"}],"source_refs":["TA","Mgh","Msb","K","S","O","ISd","A","Az","L","Kr","Ks","Zj"]}]},"classical_definitions":null}