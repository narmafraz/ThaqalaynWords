l,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plural of رُخْصَة (ruḵṣa)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of رُخُصَة (ruḵuṣa)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15124","headword_ar":"رَخُصَ","root":"rxS","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ruxoSN","text_ar":"رُخْصٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb, or a price, S, A)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cheap, low-priced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low."},{"kind":"text","text":"(S, A, Msb, K, TA.) [Accord. to all of these authorities, this seems to be the primary signification: but Et-Tebreezee (Ham p. 47) thinks it to be from"},{"kind":"arabic","text_bw":"raxoSapN","text_ar":"رَخْصَةٌ"},{"kind":"text","text":"applied to a woman, as meaning “ soft, or tender. ”] Some say"},{"kind":"arabic","text_bw":"raxaSa","text_ar":"رَخَصَ"},{"kind":"text","text":"also; but this is not of established authority. (MF.) ―         -b2-"},{"kind":"arabic","text_bw":"raxuSa","text_ar":"رَخُصَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (M, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"raxaASapN","text_ar":"رَخَاصَةٌ"},{"kind":"text","text":"(S, M, A, Msb, K) and"},{"kind":"arabic","text_bw":"ruxuwSapN","text_ar":"رُخُوصَةٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"ruxoSaAnu","text_ar":"رُخْصَانُ"},{"kind":"text","text":", (Lth, TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, K, or the body, S, Msb, or flesh, A)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender;"},{"kind":"text","text":"(S, M, A, Msb, K, TA;) and"},{"kind":"italic_en","text":"soft to the feel:"},{"kind":"text","text":"(Msb:) and in like manner"},{"kind":"arabic","text_bw":"raxuSato","text_ar":"رَخُصَتْ"},{"kind":"text","text":"said of a girl: (A:) or, said of a woman, inf. n."},{"kind":"arabic","text_bw":"ruxoSaAnN","text_ar":"رُخْصَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"she was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender, and delicate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thin, in her external skin:"},{"kind":"text","text":"and said of a woman's fingers,"},{"kind":"italic_en","text":"they were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender:"},{"kind":"text","text":"but when said of a plant, inf. n."},{"kind":"arabic","text_bw":"raxaASapN","text_ar":"رَخَاصَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft, flaccid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easily"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quickly broken:"},{"kind":"text","text":"(Lth:) [and said of a twig, or rod,"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fresh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succulent, and soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"raxoSN","text_ar":"رَخْصٌ"},{"kind":"text","text":".]"}],"source_refs":["M","A","Msb","K","S","Lth","TA"]}]}}