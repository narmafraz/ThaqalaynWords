n":"m","num":"p"},{"role":"present_2mp","form":"تَهْمِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَهْمِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَهْمِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَهْمِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَهْمِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَهْمِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَهْمِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْمِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهْمِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْمِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْمِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"هَمَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَمَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَهْمِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْمِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"هَمَسَ","root":"همس","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n41335"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D9%85%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to whisper","examples":[{"text":"فِي يَوْمٍ هَمَسَتْ فِي أُذْنِي / مَنْ يَمْسَحُ عَنْ قَلْبِي حُزْنِي / يُرْجِعُنِي خَضْرَاءَ اللَّوْنِ / أَعْشَاشًا لِلْأَطْيَار"}]},{"pos":"verb","gloss":"to mumble"},{"pos":"noun","gloss":"verbal noun of هَمَسَ (hamasa)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ha.ma.sa/","/hams/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41335","headword_ar":"هَمَس","root":"hms","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (A, TA,) inf. n."},{"kind":"arabic","text_bw":"hamos","text_ar":"هَمْس"},{"kind":"text","text":"(AHeyth, L, TA) and"},{"kind":"arabic","text_bw":"hamiysN","text_ar":"هَمِيسٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"humuwsN","text_ar":"هُمُوسٌ"},{"kind":"text","text":", (L, TA,)"},{"kind":"italic_en","text":"He spoke inaudibly:"},{"kind":"text","text":"(AHeyth, TA:) or"},{"kind":"italic_en","text":"in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, manner,"},{"kind":"text","text":"(AHeyth, TA,)"},{"kind":"italic_en","text":"so as to be hardly intelligible."},{"kind":"text","text":"(TA.) It is said in a trad."},{"kind":"arabic","text_bw":"fajaEala baEoDunaA yahomisu A_ilaY baEoDK","text_ar":"فَجَعَلَ بَعْضُنَا يَهْمِسُ اـِلَى بَعْضٍ"},{"kind":"italic_en","text":"And some of us began to speak to others in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, manner, so as to be hardly intelligible."},{"kind":"text","text":"(TA.) And in another trad.,"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"arabic","text_bw":"*aA A_iSal~aY AlEaSora hamasa bi$aYo'K laA nafohamuhu","text_ar":"ذَا اـِصَلَّى العَصْرَ هَمَسَ بِشَىْءٍ لَا نَفْهَمُهُ"},{"kind":"italic_en","text":"He used, when he performed the afternoon-prayer, to utter something in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft manner, we not understanding it."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"hamasa A_ilaY~a biHadiyvihi","text_ar":"هَمَسَ اـِلَىَّ بِحَدِيثِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He uttered his discourse to me inaudibly:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, manner."},{"kind":"text","text":"] (A.) And"},{"kind":"arabic","text_bw":"Al$~ayoTaAnu yahomisu biwasowasatihi Sadora","text_ar":"الشَّيْطَانُ يَهْمِسُ بِوَسْوَسَتِهِ صَدْرَ"},{"kind":"arabic","text_bw":"AlA_inosaAni","text_ar":"الاـِنْسَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The devil speaks inaudibly in his suggesting vain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable things into the bosom of man"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"hamasa Al$~ayoTaAnu fiY AlS~adori","text_ar":"هَمَسَ الشَّيْطَانُ فِى الصَّدْرِ"},{"kind":"italic_en","text":"The devil suggested vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable things in the bosom;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"wasowasa","text_ar":"وَسْوَسَ"},{"kind":"text","text":". (TA.) See also"},{"kind":"arabic","text_bw":"hamosN","text_ar":"هَمْسٌ"},{"kind":"text","text":"below. ―         -b2-  Also, aor. and inf. n. as above,"},{"kind":"italic_en","text":"He made the faintest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slightest, sound in treading."},{"kind":"text","text":"So in the saying,"},{"kind":"arabic","text_bw":"A_ihomiso waSaho","text_ar":"اـِهْمِسْ وَصَهْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hamosFA waSaho","text_ar":"هَمْسًا وَصَهْ"},{"kind":"italic_en","text":"Make thou the faintest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slightest, sound in treading, and be thou silent:"},{"kind":"text","text":"addressed by a thief to his companion. (TA.) And hence the saying of the Rájiz,"},{"kind":"quote","text":"fahun~a yamo$iyna bihi hamiysaA"},{"kind":"italic_en","text":"And they walk with him making the faintest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slightest, sound in treading."},{"kind":"text","text":"(S.)"},{"kind":"arabic","text_bw":"hamiysN","text_ar":"هَمِيسٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"walking softly; with a soft-sounding tread:"},{"kind":"text","text":"(TA:) [and so"},{"kind":"arabic","text_bw":"hamosN","text_ar":"هَمْسٌ"},{"kind":"text","text":"; as in the saying,]"},{"kind":"arabic","text_bw":"samiEotu hamosa AlA^axofaAfi waAlA^aqodaAmi","text_ar":"سَمِعْتُ هَمْسَ الاَخْفَافِ وَالاَقْدَامِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I heard the soft-sounding treading of the feet of camels and of the feet of men"},{"kind":"text","text":"]. (A.) See also"},{"kind":"arabic","text_bw":"hamosN","text_ar":"هَمْسٌ"},{"kind":"text","text":"below.       -A2-"},{"kind":"arabic","text_bw":"hamasa AlS~awota","text_ar":"هَمَسَ الصَّوْتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hamosN","text_ar":"هَمْسٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made the sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voice to be low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"hamasa AlkalaAma","text_ar":"هَمَسَ الكَلَامَ"},{"kind":"text","text":", [aor. and] inf. n. as above, ["},{"kind":"italic_en","text":"He spoke in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft manner;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"hamasa","text_ar":"هَمَسَ"},{"kind":"text","text":"alone; lit.,]"},{"kind":"italic_en","text":"he made speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the speech to be low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft."},{"kind":"text","text":"(A, TA.)       -A3-"},{"kind":"arabic","text_bw":"hamasa AlT~aEaAma","text_ar":"هَمَسَ الطَّعَامَ"},{"kind":"text","text":", (TK), [aor. and] inf. n. as above, (AZ, K,)"},{"kind":"italic_en","text":"He chewed the food with the mouth closed:"},{"kind":"text","text":"(AZ, K, TA:) or"},{"kind":"italic_en","text":"without opening the mouth."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"huwa yaokulu hamosFA","text_ar":"هُوَ يَْكُلُ هَمْسًا"},{"kind":"italic_en","text":"He eats without opening his mouth."},{"kind":"text","text":"(A.) Hence, a toothless old woman's eating is termed"},{"kind":"arabic","text_bw":"hamosN","text_ar":"هَمْسٌ"},{"kind":"text","text":". (AHeyth.)"},{"kind":"arabic","text_bw":"hamasahu","text_ar":"هَمَسَهُ"},{"kind":"text","text":"also signifies [simply]"},{"kind":"italic_en","text":"He chewed it."},{"kind":"text","text":"(TA.)"},{"kind":"page_break","n":2902}],"source_refs":["A","TA","AHeyth","L","TK","AZ","K"]}]},"classical_definitions":null}