{"lemma":"قَرِبَ","slug":"قَرِبَ","root":"ق.ر.ب","root_slug":"ق-ر-ب","root_link":"/words/roots/ق-ر-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"قَرِبْتَ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"قَرِبْتِ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"قَرِبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"قَرِبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"قَرِبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"قَرِبَ","in_corpus":true,"count":26,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"قَرِبَت","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"قَرِبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"قَرِبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"قَرِبُوا","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"قَرِبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَقْرَب","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَقْرَبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَقْرَبِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَقْرَبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَقْرَبا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَقْرَبُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَقْرَبُوا","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَقْرَبْنَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَقْرَب","in_corpus":true,"count":22,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَقْرَب","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقْرَبانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقْرَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقْرَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقْرَبا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقْرَبُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقْرَبُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقْرَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"قَرِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَرِبْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَقْرَب","in_corpus":true,"count":79,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقْرَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":187,"cross_references":{"qac":{"found":true,"lemma_key":"قَرِبَ","root":"قرب","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","prep","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n35387","n35392","n35393","n35394"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B1%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be near, to come near, to approach"},{"pos":"verb","gloss":"to be related, to be of close relations, to be kindred (especially on the maternal side)"},{"pos":"verb","gloss":"to have relation to something, to be associated"},{"pos":"verb","gloss":"to be engaged with, to be or become involved with"},{"pos":"verb","gloss":"to be near, to come near, to approach","tags":["transitive"],"examples":[{"text":"لَا تَقْرَبِ الْأَسَدَ فَيَأْكُلَكَ.","english":"Do not approach the lion lest he eat you."},{"text":"وَقُلْنَا يَا آدَمُ ٱسْكُنْ أَنْتَ وَزَوْجُكَ الْجَنَّةَ وَكُلَا مِنْهَا رَغَدًا حَيْثُ شِئْتُمَا وَلَا تَقْرَبَا هَٰذِهِ ٱلشَّجَرَةَ فَتَكُونَا مِنَ ٱلظَّالِمِين"}]},{"pos":"verb","gloss":"to copulate with","tags":["euphemistic","transitive"],"examples":[{"text":"وَلَا تَقْرَبُوهُنَّ حَتَّىٰ يَطْهُرْنَ"}]},{"pos":"verb","gloss":"to cause or allow to be near"},{"pos":"verb","gloss":"to make or let approach"},{"pos":"noun","gloss":"verbal noun of قَرُبَ (qaruba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"nearness, presence","examples":[{"text":"عِنْدَمَا كَانَ جَالِسًا بِالْقُرْبِ مِنْ زَوْجَتِهِ... صَرَخَتْ فِي وَجْهِهِ قَائِلَةً: ”اِبْتَعِدْ عَنِّي!“","english":"When he was sitting next to his wife... she yelled into his face, saying: “Go away from me!”"},{"text":"أنا ليه بحب حبك قوي كده ليه\n وأموت في قربك أنا كده ليه","english":"ʾana leih bi-ḥubbi ḥubbak qawī kida leih\n wa-'mūtu fī qorbak ʾana kida leih"}]},{"pos":"prep","gloss":"near, in the vicinity of","examples":[{"text":"قُرْبَ ٱلظُّهْر","english":"towards noon"}]}]},"etymology":{"source":"wiktextract","text":"* From the root ق ر ب (q r b), with the form I being reconstructed securely as Proto-Semitic *ḳarib-, likewise the form II as Proto-Semitic *ḳarrib-.\n* While the Biblical Hebrew קָרַב (qāráḇ, “to approach”) governs prepositions of approach like אֶל (el), לְ (lə), עַל (ʿal), the Arabic قَرُبَ (qaruba) has obtained the opposited preposition مِن (min) by analogy of بَعُدَ (baʕuda, “to be far”); compare the same with دَنَا (danā, “to come near”)."},"ipa":["/qa.ru.ba/","/qa.ri.ba/","/qar.ra.ba/","/qurb/","/qur.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35387","headword_ar":"قَرُبَ","root":"qrb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"(S, Mgh, O, Msb *) and"},{"kind":"arabic","text_bw":"qurobapN","text_ar":"قُرْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qurobaY","text_ar":"قُرْبَى"},{"kind":"text","text":"(Mgh, Msb) and"},{"kind":"arabic","text_bw":"maqorabapN","text_ar":"مَقْرَبَةٌ"},{"kind":"text","text":", (Mgh,) [to which may be added some other syns. mentioned below with"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near;"},{"kind":"text","text":"(S, Mgh, O;) syn."},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":"; (S, O;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":": (Mgh:) or"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"in place,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qurobapN","text_ar":"قُرْبَةٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"in station,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grade,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rank,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qurobaY","text_ar":"قُرْبَى"},{"kind":"text","text":"are"},{"kind":"italic_en","text":"in"},{"kind":"arabic","text_bw":"Alr~aHim","text_ar":"الرَّحِم"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"relationship,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relationship by the female side"},{"kind":"text","text":"]; (Mgh, Msb, TA;) or, accord. to the T,"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":"is in"},{"kind":"arabic","text_bw":"Aln~asab","text_ar":"النَّسَب"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"relationship in a general sense"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"qurobaY","text_ar":"قُرْبَى"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"in"},{"kind":"arabic","text_bw":"Alr~aHim","text_ar":"الرَّحِم"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"relationship by the female side"},{"kind":"text","text":"]: (TA:) You say,"},{"kind":"arabic","text_bw":"qaruba minohu","text_ar":"قَرُبَ مِنْهُ"},{"kind":"text","text":", (A, MA, Msb, K,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"; (A;) and"},{"kind":"arabic","text_bw":"qaribahu","text_ar":"قَرِبَهُ"},{"kind":"text","text":", (S, MA, O, K,) aor."},{"kind":"text","text":"; (S, K;) inf. n. (of the former verb, Msb)"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":", (Msb, K,) or"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qurobapN","text_ar":"قُرْبَةٌ"},{"kind":"text","text":"&c. as above, (Msb,) or"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maqorabapN","text_ar":"مَقْرَبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maqorubapN","text_ar":"مَقْرُبَةٌ"},{"kind":"text","text":"; (MA;) and (of the latter verb, S, MA, O)"},{"kind":"arabic","text_bw":"qirobaAnN","text_ar":"قِرْبَانٌ"},{"kind":"text","text":"(S, MA, O, K) and"},{"kind":"arabic","text_bw":"qurobaAnN","text_ar":"قُرْبَانٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, S, O)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near to it;"},{"kind":"text","text":"(S, A, MA, O, K;) syn."},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":": (S, A, O, K:) or the former verb means thus; but when one says"},{"kind":"arabic","text_bw":"laA taqorabo ka*aA","text_ar":"لَا تَقْرَبْ كَذَا"},{"kind":"text","text":"with fet-h to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", the meaning is,"},{"kind":"italic_en","text":"occupy not thyself with doing such a thing:"},{"kind":"text","text":"(MF, TA, &c.:) or"},{"kind":"arabic","text_bw":"qaribotu AlA^amora","text_ar":"قَرِبْتُ الاَمْرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qarabotuhu","text_ar":"قَرَبْتُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", i. e., like"},{"kind":"arabic","text_bw":"taEiba","text_ar":"تَعِبَ"},{"kind":"text","text":"and like"},{"kind":"arabic","text_bw":"qatala","text_ar":"قَتَلَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qirobaAnN","text_ar":"قِرْبَانٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"I did the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I approached, to it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to doing it"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"to doing something with it"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to it"},{"kind":"text","text":"]: an ex. of the former meaning is the saying [in the Kur xvii. 34],"},{"kind":"arabic","text_bw":"laA taqorabuwA A@lz~inaA","text_ar":"لَا تَقْرَبُوا ا@لزِّنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Commit not ye fornication,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adultery;"},{"kind":"text","text":"or, accord. to some, this is an ex. of the latter meaning]; and hence one says,"},{"kind":"arabic","text_bw":"qaribotu AlmaroA^apa","text_ar":"قَرِبْتُ المَرْاَةَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qirobaAnN","text_ar":"قِرْبَانٌ"},{"kind":"text","text":", a metonymical phrase, meaning"},{"kind":"italic_en","text":"I compressed the woman:"},{"kind":"text","text":"and an ex. of the latter meaning is the saying,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"taqorabuwA AlHimaY","text_ar":"تَقْرَبُوا الحِمَى"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"laA tadonuwA minohu","text_ar":"لَا تَدْنُوا مِنْهُ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Approach not ye to doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to entering upon, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place, that is prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interdicted"},{"kind":"text","text":"]. (Msb.) And the Arabs say, of a man, when a thing has disquieted, or disturbed, and grieved, him,"},{"kind":"arabic","text_bw":"A^axa*ahu maA qaruba wamaA baEuda","text_ar":"اَخَذَهُ مَا قَرُبَ وَمَا بَعُدَ"},{"kind":"text","text":", as though meaning (assumed tropical:)"},{"kind":"italic_en","text":"He became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has become, disquieted by reason of near and remote circumstances of his case:"},{"kind":"text","text":"(O:) or"},{"kind":"italic_en","text":"recent and old griefs took hold upon him."},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"qdm","text_ar":"قدم"},{"kind":"text","text":". [See art."},{"kind":"arabic","text_bw":"bEd","text_ar":"بعد"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"danaA min~iY waqaruba","text_ar":"دَنَا مِنِّى وَقَرُبَ"},{"kind":"text","text":"is expl. by Zj as meaning"},{"kind":"italic_en","text":"He drew near to me and drew nearer."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"dlw","text_ar":"دلو"},{"kind":"text","text":": see 5 in that art.) [And several other verbs belonging to this art. are syn., or nearly so, with"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":"or with"},{"kind":"arabic","text_bw":"qariba","text_ar":"قَرِبَ"},{"kind":"text","text":"in senses expl. above. Thus ↓"},{"kind":"arabic","text_bw":"Aqrb","text_ar":"اقرب","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":"in the first of the senses expl. above, like as"},{"kind":"arabic","text_bw":"A^adonaY","text_ar":"اَدْنَى"},{"kind":"text","text":"is with"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":", for its inf. n.]"},{"kind":"arabic","text_bw":"AlA_iqoraAbu","text_ar":"الاـِقْرَابُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"Ald~ubuw~u","text_ar":"الدُّبُوُّ"},{"kind":"text","text":". (TA.) ↓"},{"kind":"arabic","text_bw":"Aqtrb","text_ar":"اقترب","orth_type":"arrow"},{"kind":"text","text":", also, is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":"in the first of the senses expl. above; (MA;) [i. e.] it is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":": (Msb:) or it is"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tqArb","text_ar":"تقارب","orth_type":"arrow"},{"kind":"text","text":", (S, O, K, TA,) signifying"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, drew near;"},{"kind":"text","text":"(TA;) thus ↓"},{"kind":"arabic","text_bw":"waA@qotaraba","text_ar":"وَا@قْتَرَبَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlwaEodu","text_ar":"الوَعْدُ"},{"kind":"text","text":"[in the Kur xxi. 97] signifies"},{"kind":"arabic","text_bw":"tqArb","text_ar":"تقارب"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"And the fulfilment of the promise shall draw near"},{"kind":"text","text":"]: (S, O, TA:) and you say,"},{"kind":"arabic","text_bw":"Aqtrb min~iY","text_ar":"اقترب مِنِّى"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"He drew near to me"},{"kind":"text","text":"]: (A:) it is also said that is has a more particular signification than"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":"; for it denotes intensiveness in"},{"kind":"arabic","text_bw":"Alqurob","text_ar":"القُرْب"},{"kind":"text","text":"; thus says Ibn-'Arafeh; probably meaning that it denotes labour and difficulty in the accomplishment of the act. (MF, TA.) ↓"},{"kind":"arabic","text_bw":"tqr~b","text_ar":"تقرّب","orth_type":"arrow"},{"kind":"text","text":"[likewise] is"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":", i. e.]"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":", in the phrase"},{"kind":"arabic","text_bw":"tqr~b minohu","text_ar":"تقرّب مِنْهُ"},{"kind":"text","text":": (O: [see"},{"kind":"arabic","text_bw":"qaruba minohu","text_ar":"قَرُبَ مِنْهُ"},{"kind":"text","text":":]) or it signifies"},{"kind":"italic_en","text":"he drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached, by little and little,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tadan~aY","text_ar":"تَدَنَّى"},{"kind":"text","text":",) to a thing. (TA.) And"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qArb","text_ar":"قارب","orth_type":"arrow"},{"kind":"text","text":", (ISd, TA,) or"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":", (Msb,) [like"},{"kind":"arabic","text_bw":"qaribahu","text_ar":"قَرِبَهُ"},{"kind":"text","text":"in many instances,] signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he approached, to the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to doing"},{"kind":"page_break","n":2505},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(ISd, Msb, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"He formed an opinion that was near to certainty."},{"kind":"text","text":"(MF.) ―         -b3-  In the phrase"},{"kind":"arabic","text_bw":"qarabati","text_ar":"قَرَبَتِ"},{"kind":"arabic","text_bw":"Al$~amosu lilomagiybi","text_ar":"الشَّمْسُ لِلْمَغِيبِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"The sun was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near to setting"},{"kind":"text","text":"], like"},{"kind":"arabic","text_bw":"karabat","text_ar":"كَرَبَت"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":"is asserted by Yaakoob to be a substitute for"},{"kind":"arabic","text_bw":"k","text_ar":"ك"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"qaraba","text_ar":"قَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; inf. in."},{"kind":"arabic","text_bw":"qiraAbapN","text_ar":"قِرَابَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"journeyed to water, there being between him and it a night's journey."},{"kind":"text","text":"(S, O.) [See also"},{"kind":"arabic","text_bw":"A^aqoraba Alqawomu","text_ar":"اَقْرَبَ القَوْمُ"},{"kind":"text","text":". Or,] accord. to Lth, you say,"},{"kind":"arabic","text_bw":"qarabuwA","text_ar":"قَرَبُوا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qarabN","text_ar":"قَرَبٌ"},{"kind":"text","text":"[q. v.], meaning"},{"kind":"italic_en","text":"They, after pasturing their camels in the tract between them and the wateringplace, and journeying on during a part of the time until there remained between them and the water a night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evening, hastened in their course."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qaraba AlA_ibil","text_ar":"قَرَبَ الاـِبِل"},{"kind":"text","text":"[in some copies of the K"},{"kind":"arabic","text_bw":"AlA_ibila","text_ar":"الاـِبِلَ"},{"kind":"text","text":"and in others"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":"], aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qiraAbapN","text_ar":"قِرَابَةٌ"},{"kind":"text","text":"; thus in the K; but accord. to Th,"},{"kind":"arabic","text_bw":"qarabati","text_ar":"قَرَبَتِ"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qarabN","text_ar":"قَرَبٌ"},{"kind":"text","text":"; (TA;) i. e."},{"kind":"italic_en","text":"The camels journeyed by night in order to arrive at the water on the morrow:"},{"kind":"text","text":"(K, * TA:) and [a man says, of himself,]"},{"kind":"arabic","text_bw":"qarabotu","text_ar":"قَرَبْتُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qiraAbapN","text_ar":"قِرَابَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"qarabotu AlmaA='a","text_ar":"قَرَبْتُ المَا=ءَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qarabN","text_ar":"قَرَبٌ"},{"kind":"text","text":", so in the Fs [of Th, meaning"},{"kind":"italic_en","text":"I journeyed to the water by night in order to reach it on the following morning"},{"kind":"text","text":"]. (TA.) [Or] you say,"},{"kind":"arabic","text_bw":"qarabuwA AlmaA='a","text_ar":"قَرَبُوا المَا=ءَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"They sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to attain, the water."},{"kind":"text","text":"(A.) ―         -b3-  And [hence] one says,"},{"kind":"arabic","text_bw":"fulaAnN yaqorubu HaAjatuhu","text_ar":"فُلَانٌ يَقْرُبُ حَاجَتُهُ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Such a one seeks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeks to attain, the object of his want;"},{"kind":"text","text":"from the seeking, or seeking to attain, the water: and hence the saying, in a trad.,"},{"kind":"arabic","text_bw":"waA_ino naqorubu bi*`lika A_il~aA A^ano naHomada A@ll~`ha","text_ar":"وَاـِنْ نَقْرُبُ بِذٰلِكَ اـِلَّا اَنْ نَحْمَدَ ا@للّٰهَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"We not seeking thereby"},{"kind":"text","text":"[aught]"},{"kind":"italic_en","text":"save our praising God:"},{"kind":"text","text":"thus expl. by El-Khattábee. (Az, TA.) [Hence, also,] one says"},{"kind":"arabic","text_bw":"qado qaraba A^amorFA laA A^adoriY maA huwa","text_ar":"قَدْ قَرَبَ اَمْرًا لَا اَدْرِى مَا هُوَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He has sought to accomplish an affair, I know not what it is"},{"kind":"text","text":"]: (A, O: *) and"},{"kind":"arabic","text_bw":"fulaAnN yaqorubu A^amorFA laA","text_ar":"فُلَانٌ يَقْرُبُ اَمْرًا لَا"},{"kind":"arabic","text_bw":"yasohulu lahu","text_ar":"يَسْهُلُ لَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one seeks to accomplish an affair that will not be easy to him"},{"kind":"text","text":"]. (A.)"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"yaqorubu A^amorFA","text_ar":"يَقْرُبُ اَمْرًا"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Such a one seeks, desires,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aims at,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the accomplishment of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"an affair,"},{"kind":"text","text":"when he does a deed, or says a saying, with that object. (T, O, TA.)       -A3-"},{"kind":"arabic","text_bw":"qaraba Als~ayofa","text_ar":"قَرَبَ السَّيْفَ"},{"kind":"text","text":", (S, O,) inf. n."},{"kind":"arabic","text_bw":"qarobN","text_ar":"قَرْبٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Aqrbhu","text_ar":"اقربهُ","orth_type":"arrow"},{"kind":"text","text":", (O,) inf. n."},{"kind":"arabic","text_bw":"A_iqoraAbN","text_ar":"اـِقْرَابٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He put the sword into the"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":"[q. v.]: (S, O, K:) or the former, (accord. to the K,) or ↓ the latter, (accord. to the S and TA,)"},{"kind":"italic_en","text":"he made for the sword a"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":": (S, K, TA:) or ↓ the latter has both of these significations: (O:) or the former verb is said of a sword or of a knife in the former sense; and in like manner ↓ the latter verb in the latter sense: or the former phrase signifies"},{"kind":"italic_en","text":"he made for the sword a"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":"; and ↓ the latter phrase,"},{"kind":"italic_en","text":"he put the sword into its"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":": and one says,"},{"kind":"arabic","text_bw":"qiraAbFA","text_ar":"قِرَابًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qr~b","text_ar":"قرّب","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aqrbhu","text_ar":"اقربهُ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he made a"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":". (TA.)       -A4-"},{"kind":"arabic","text_bw":"qarobN","text_ar":"قَرْبٌ"},{"kind":"text","text":"[as an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"qaraba","text_ar":"قَرَبَ"},{"kind":"text","text":"] also signifies The"},{"kind":"italic_en","text":"feeding"},{"kind":"text","text":"a guest"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"A^aqoraAb","text_ar":"اَقْرَاب"},{"kind":"text","text":"(O, K, TA) meaning"},{"kind":"italic_en","text":"flanks"},{"kind":"text","text":"[of an animal or of animals, pl. of"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"qurubN","text_ar":"قُرُبٌ"},{"kind":"text","text":"]. (TA.)       -A5-  And"},{"kind":"arabic","text_bw":"qariba","text_ar":"قَرِبَ"},{"kind":"text","text":", (O, K,) with kesr to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (O,) like"},{"kind":"arabic","text_bw":"fariH","text_ar":"فَرِح"},{"kind":"text","text":", (K,) [aor."},{"kind":"text","text":", inf. n. app."},{"kind":"arabic","text_bw":"qarabN","text_ar":"قَرَبٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"had a complaint"},{"kind":"text","text":"(O, K)"},{"kind":"italic_en","text":"of his"},{"kind":"arabic","text_bw":"qurob","text_ar":"قُرْب"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"qurub","text_ar":"قُرُب"},{"kind":"text","text":", (K,) [i. e.] of his"},{"kind":"italic_en","text":"flank;"},{"kind":"text","text":"(O;) as also ↓"},{"kind":"arabic","text_bw":"qr~b","text_ar":"قرّب","orth_type":"arrow"},{"kind":"text","text":", (O, * K, [in the former this verb is only indicated by the mention of its inf. n.,]) inf. n."},{"kind":"arabic","text_bw":"taqoriybN","text_ar":"تَقْرِيبٌ"},{"kind":"text","text":". (O, K.)"}],"source_refs":["Mgh","Msb","TA","A","MA","K","S","O","ISd"]},{"entry_id":"n35392","headword_ar":"قُرْبٌ","root":"qrb","body":[{"kind":"text","text":"[mentioned in the first sentence of this art. as an inf. n.] is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":": (S, O:) [used as a simple subst., it signifies"},{"kind":"italic_en","text":"Nearness,"},{"kind":"text","text":"and] it is said to be [properly, or primarily,]"},{"kind":"italic_en","text":"in respect of place;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"vicinity;"},{"kind":"text","text":"] as distinguished from"},{"kind":"arabic","text_bw":"qurobapN","text_ar":"قُرْبَةٌ"},{"kind":"text","text":"&c. (Msb, TA.) You say,"},{"kind":"arabic","text_bw":"A_in~a qurobaka","text_ar":"اـِنَّ قُرْبَكَ"},{"kind":"arabic","text_bw":"zayodFA","text_ar":"زَيْدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily Zeyd is in thy vicinity;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"near thee in respect of place"},{"kind":"text","text":"]; but not"},{"kind":"arabic","text_bw":"A_in~a buEodaka zayodFA","text_ar":"اـِنَّ بُعْدَكَ زَيْدًا"},{"kind":"text","text":"; because"},{"kind":"arabic","text_bw":"qurob","text_ar":"قُرْب"},{"kind":"text","text":"is more capable of being used as an adv. n. of place than"},{"kind":"arabic","text_bw":"buEod","text_ar":"بُعْد"},{"kind":"text","text":": in like manner they said also ↓"},{"kind":"arabic","text_bw":"huwa quraAbataka","text_ar":"هُوَ قُرَابَتَكَ","orth_type":"arrow"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"He is in thy vicinity;"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"near thee in respect of place."},{"kind":"text","text":"(Sb, TA. [See also"},{"kind":"arabic","text_bw":"qariybN","text_ar":"قَرِيبٌ"},{"kind":"text","text":".]) [And"},{"kind":"arabic","text_bw":"biAlqurobi minohu","text_ar":"بِالقُرْبِ مِنْهُ"},{"kind":"text","text":"is a phrase of frequent occurrence, meaning"},{"kind":"italic_en","text":"In the vicinity of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near in respect of place to, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"] And one says,"},{"kind":"arabic","text_bw":"tanaAwalahu mino qurobK","text_ar":"تَنَاوَلَهُ مِنْ قُرْبٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mino qariybK","text_ar":"مِنْ قَرِيبٍ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took it with his hand, from a near place"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spot"},{"kind":"text","text":"]. (A, Msb.) And"},{"kind":"arabic","text_bw":"raA^ayotuhu mino qurobK","text_ar":"رَاَيْتُهُ مِنْ قُرْبٍ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"mino qariybK","text_ar":"مِنْ قَرِيبٍ","orth_type":"arrow"},{"kind":"italic_en","text":"I saw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, from a near place"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from within a short distance"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":"; &c.) ―         -b2-  It is also syn. with ↓"},{"kind":"arabic","text_bw":"qaraAbN","text_ar":"قَرَابٌ","orth_type":"arrow"},{"kind":"text","text":"[signifying"},{"kind":"italic_en","text":"Nearness in respect of time"},{"kind":"text","text":"] as used in the saying"},{"kind":"arabic","text_bw":"AifoEalo *`lika biqaraAbK","text_ar":"اِفْعَلْ ذٰلِكَ بِقَرَابٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Do thou that soon;"},{"kind":"text","text":"like as one says,"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qariybK","text_ar":"قَرِيبٍ","orth_type":"arrow"},{"kind":"text","text":"]: (K, TA:) accord. to the K, the word"},{"kind":"arabic","text_bw":"qrAb","text_ar":"قراب"},{"kind":"text","text":"in this case is like"},{"kind":"arabic","text_bw":"saHaAb","text_ar":"سَحَاب"},{"kind":"text","text":": but it is said in a prov.,"},{"kind":"arabic","text_bw":"A^akoyasu","text_ar":"اَكْيَسُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlfiraAru biqiraAbK","text_ar":"الفِرَارُ بِقِرَابٍ","orth_type":"arrow"},{"kind":"text","text":", thus in the S, or, as some relate it, ↓"},{"kind":"arabic","text_bw":"biquraAbK","text_ar":"بِقُرَابٍ","orth_type":"arrow"},{"kind":"text","text":"; and IB says, J has cited this prov. [next] after the"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":"of the sword, but should have said that"},{"kind":"arabic","text_bw":"AlqiraAbu","text_ar":"القِرَابُ"},{"kind":"text","text":"is also syn. with"},{"kind":"arabic","text_bw":"Alqurobu","text_ar":"القُرْبُ"},{"kind":"text","text":", and should then have adduced the prov. as an ex. meaning"},{"kind":"italic_en","text":"The fleeing soon"},{"kind":"text","text":"in eagerness of desire for safety ["},{"kind":"italic_en","text":"is more,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, shrewd"},{"kind":"text","text":"]: (TA:) [this rendering, however, requires consideration; for, accord. to Meyd, who gives only the reading"},{"kind":"arabic","text_bw":"biqiraAbK","text_ar":"بِقِرَابٍ"},{"kind":"text","text":", the meaning of the prov. is, that he who flees with the ↓"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب","orth_type":"arrow"},{"kind":"text","text":"(by which is meant the scabbard) when the sword has passed away from his possession is more shrewd than he who causes, or suffers, the"},{"kind":"arabic","text_bw":"qiraAb","text_ar":"قِرَاب"},{"kind":"text","text":"also to pass away from him: in Freytag's Arab Prov. ii. 210, both of these explanations are given; but"},{"kind":"arabic","text_bw":"qryb","text_ar":"قريب"},{"kind":"text","text":"is there erroneously put for"},{"kind":"arabic","text_bw":"qurob","text_ar":"قُرْب"},{"kind":"text","text":".] ―         -b3-  See also"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":". ―         -b4-  It is also a pl. of"},{"kind":"arabic","text_bw":"qariybN","text_ar":"قَرِيبٌ"},{"kind":"text","text":"[q. v.]. (TA in art."},{"kind":"arabic","text_bw":"zlf","text_ar":"زلف"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":"also, and ↓"},{"kind":"arabic","text_bw":"qurubN","text_ar":"قُرُبٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) the former of which is the original, (TA,) signify The"},{"kind":"arabic","text_bw":"xaASirap","text_ar":"خَاصِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flank"},{"kind":"text","text":"]: (O, K:) or [the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the"},{"kind":"arabic","text_bw":"$aAkilap","text_ar":"شَاكِلَة"},{"kind":"text","text":"[which is syn., or nearly so, with"},{"kind":"arabic","text_bw":"xaASirap","text_ar":"خَاصِرَة"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"to the"},{"kind":"arabic","text_bw":"maraAq~","text_ar":"مَرَاقّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"soft parts"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the belly:"},{"kind":"text","text":"(S, O, K:) and likewise"},{"kind":"italic_en","text":"from the"},{"kind":"arabic","text_bw":"rafog","text_ar":"رَفْغ"},{"kind":"text","text":"[generally meaning"},{"kind":"italic_en","text":"groin"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the armpit, on each side:"},{"kind":"text","text":"(TA:) [properly used in relation to a horse:] sometimes metaphorically used in relation to a she-camel, and to an ass [meaning a wild ass, and also to a man: see 5, last sentence]: (TA:) pl."},{"kind":"arabic","text_bw":"A^aqoraAbN","text_ar":"اَقْرَابٌ"},{"kind":"text","text":"; (T, S, O, K;) which is also used in the place of the dual. (T, TA.)"}],"source_refs":["S","O","K","TA"]},{"entry_id":"n35393","headword_ar":"قَرَبٌ","root":"qrb","body":[{"kind":"text","text":"[mentioned in the latter half of the first paragraph of this art. as an inf. n.] is [said to be] a subst., signifying"},{"kind":"italic_en","text":"A journey to water when it is a night's journey distant:"},{"kind":"text","text":"or, as As said, on the authority of an Arab of the desert, (S, O,)"},{"kind":"italic_en","text":"a journey by night in order to arrive at the water on the morrow;"},{"kind":"text","text":"(S, O, K;) and so ↓"},{"kind":"arabic","text_bw":"qiraAbapN","text_ar":"قِرَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"[which is also mentioned as an inf. n. in the latter half of the first paragraph of this art.]; (K;) a journey by night in order to arrive at the water on the second following day being called"},{"kind":"arabic","text_bw":"TalaqN","text_ar":"طَلَقٌ"},{"kind":"text","text":": (S, O:) and the"},{"kind":"italic_en","text":"seeking water by night:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"when it is not more than a night's journey distant:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"first day in which one journeys to water when it is two days distant;"},{"kind":"text","text":"the second day being called"},{"kind":"arabic","text_bw":"TalaqN","text_ar":"طَلَقٌ"},{"kind":"text","text":": (K: [but the converse seems to be the truth, being asserted by several of the highest authorities, and agreeable with the derivation of each of the two words: see"},{"kind":"arabic","text_bw":"TalaqN","text_ar":"طَلَقٌ"},{"kind":"text","text":":]) or the"},{"kind":"italic_en","text":"night after which, in the morning, one arrives at the water:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"layolapu Alqarabi","text_ar":"لَيْلَةُ القَرَبِ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the night in which people with their camels hasten to the water in a journey such as is termed"},{"kind":"arabic","text_bw":"qarabN baSobaASN","text_ar":"قَرَبٌ بَصْبَاصٌ"},{"kind":"text","text":"; this latter term being applied to signify"},{"kind":"italic_en","text":"a people's letting their camels pasture while they are journeying towards water; and when there remains an evening between them and the water, hastening towards it:"},{"kind":"text","text":"(S, O:) or, as is said on the authority of As,"},{"kind":"arabic","text_bw":"layolapu Alqarabi","text_ar":"لَيْلَةُ القَرَبِ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the second night after the pastor has turned the faces of his camels towards the water, and so left them to pasture;"},{"kind":"text","text":"this second night being the night of hard driving; and the first night being called"},{"kind":"arabic","text_bw":"layolapu AlT~alaqi","text_ar":"لَيْلَةُ الطَّلَقِ"},{"kind":"text","text":": accord. to AA, [the journey called]"},{"kind":"arabic","text_bw":"Alqarabu","text_ar":"القَرَبُ"},{"kind":"text","text":"is ["},{"kind":"italic_en","text":"the journey to water"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"during three days,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more."},{"kind":"text","text":"(TA.) And [hence]"},{"kind":"arabic","text_bw":"Alqaraba","text_ar":"القَرَبَ"},{"kind":"text","text":"is used to signify"},{"kind":"italic_en","text":"What is a night's journey distant."},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"nwb","text_ar":"نوب"},{"kind":"text","text":", in explanation of a verse cited in that art. [Or, accord. to IAar,"},{"kind":"arabic","text_bw":"qarab","text_ar":"قَرَب"},{"kind":"text","text":"there signifies"},{"kind":"italic_en","text":"near,"},{"kind":"text","text":"so as to be visited repeatedly: or, as AA says,"},{"kind":"italic_en","text":"at such a distance as to be visited once in three days."},{"kind":"text","text":"]) [See also a saying mentioned voce"},{"kind":"arabic","text_bw":"HawozN","text_ar":"حَوْزٌ"},{"kind":"text","text":".] ―         -b2-  Also"},{"kind":"italic_en","text":"A well of which the water is near"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the mouth"},{"kind":"text","text":"]. (O, K.)"}],"source_refs":["S","O","TA"]},{"entry_id":"n35394","headword_ar":"قُرُبٌ","root":"qrb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qurobN","text_ar":"قُرْبٌ"},{"kind":"text","text":", last sentence."},{"kind":"page_break","n":2507}],"source_refs":[]}]}}