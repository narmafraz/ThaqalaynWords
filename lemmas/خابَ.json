ces":{"qac":{"found":true,"lemma_key":"خابَ","root":"خيب","pos":"V","occurrence_count":4},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n9822","n9839","n11667","n11795"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fail"},{"pos":"verb","gloss":"to be perforated"},{"pos":"verb","gloss":"to be or become poor"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9822","headword_ar":"خابّ","root":"xb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"muxaAb~N","text_ar":"مُخَابٌّ"},{"kind":"text","text":". [It seems that"},{"kind":"arabic","text_bw":"xAb~hu","text_ar":"خابّهُ"},{"kind":"text","text":", if used, signifies"},{"kind":"italic_en","text":"He acted treacherously towards him, and took him unawares."},{"kind":"text","text":"] ―         -b2-  And [the inf. n.]"},{"kind":"arabic","text_bw":"muxaAb~apN","text_ar":"مُخَابَّةٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"being heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sluggish, and holding back from a thing."},{"kind":"text","text":"(JK.)"}],"source_refs":[]},{"entry_id":"n9839","headword_ar":"خَابٌّ","root":"xb","body":[{"kind":"text","text":", (S, K, TA,) in one copy of the K"},{"kind":"arabic","text_bw":"xaAb~apN","text_ar":"خَابَّةٌ"},{"kind":"text","text":", [as in the CK,] but the former is the more correct, (TA,)"},{"kind":"italic_en","text":"Relationship;"},{"kind":"text","text":"(S, K;) and"},{"kind":"italic_en","text":"affinity,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SihorN","text_ar":"صِهْرٌ"},{"kind":"text","text":": (S:) pl."},{"kind":"arabic","text_bw":"xawaAb~u","text_ar":"خَوَابُّ"},{"kind":"text","text":". (S, K.) You say,"},{"kind":"arabic","text_bw":"liY mino fulaAnK xawaAb~u","text_ar":"لِى مِنْ فُلَانٍ خَوَابُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have ties of relationship,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affinity, to such a one"},{"kind":"text","text":"]. (S.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n11667","headword_ar":"خَابَ","root":"xwb","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxuwbu","text_ar":"يَخُوبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xawobN","text_ar":"خَوْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, poor, needy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indigent."},{"kind":"text","text":"(IAar, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"xaAba","text_ar":"خَابَ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"xyb","text_ar":"خيب"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n11795","headword_ar":"خَابَ","root":"xyb","body":[{"kind":"text","text":", (S, A, Msb, K, &c.,) aor."},{"kind":"arabic","text_bw":"yaxiybu","text_ar":"يَخِيبُ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"yaxuwbu","text_ar":"يَخُوبُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xayobapN","text_ar":"خَيْبَةٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was disappointed of attaining what he desired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought; was balked; was unsuccessful; failed of attaining his desire:"},{"kind":"text","text":"(S, Msb, K:)"},{"kind":"italic_en","text":"he was denied, refused, prohibited from attaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred from, what he desired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought."},{"kind":"text","text":"(A, K.) You say,"},{"kind":"arabic","text_bw":"mano haAba xaAba","text_ar":"مَنْ هَابَ خَابَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who fears will be disappointed"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"xaAba saEoyuhu waA^amaluhu","text_ar":"خَابَ سَعْيُهُ وَاَمَلُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His labour, and his hope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expectation, resulted in disappointment; were disappointed, balked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frustrated;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he attained not what he sought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired."},{"kind":"text","text":"(A, TA.) [See also"},{"kind":"arabic","text_bw":"xayobapN","text_ar":"خَيْبَةٌ"},{"kind":"text","text":", below.] ―         -b2-  Also"},{"kind":"italic_en","text":"He suffered loss."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"kafara","text_ar":"كَفَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He disbelieved;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be came an unbeliever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infidel;"},{"kind":"text","text":"&c.]. (K.)"}],"source_refs":["Msb","K","TA","S"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D8%A8/","headword_ar":"خاب","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61758#8e0378","body_html":"<span class=\"title1\">خاب</span><br><span>الخَيْبَة: فوت الطلب، قال: وَخابَ كُلُّ جَبَّارٍ عَنِيدٍ</span><br><span>[إبراهيم/ 15] ، وَقَدْ خابَ مَنِ افْتَرى [طه/ 61] ، وَقَدْ خابَ مَنْ دَسَّاها [الشمس/ 10] .</span>"},{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=61758#916535","body_html":"خاب<br> خَاب(ي)(n. ac. خَيْبَة [] )<br>a. Was disappointed, frustrated, baffled <br> unsuccessful.<br> <br> خَاَّبَأَخْاَبَa. Disappointed, frustrated, baffled.<br> <br> تَخَاَّبَa. see I <br> خَاْبَةa. Disappointment.<br> <br> خَاِّبa. Disappointed, frustrated, baffled.<br> <br> خَاَّاْبa. Flint that gives no fire."}]}}