{"lemma":"غَيَّرَ","slug":"غَيَّرَ","root":"غ.#.ر","root_slug":"غ-_-ر","root_link":"/words/roots/غ-_-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"غَيَّرْتَ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"غَيَّرْتِ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"غَيَّرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"غَيَّرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"غَيَّرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"غَيَّرَ","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"غَيَّرَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"غَيَّرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"غَيَّرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"غَيَّرُوا","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"غَيَّرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُغَيِّر","in_corpus":true,"count":47,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُغَيِّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُغَيِّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُغَيِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُغَيِّرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُغَيِّرُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُغَيِّرُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُغَيِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُغَيِّر","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُغَيِّر","in_corpus":true,"count":47,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُغَيِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُغَيِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغَيِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَيِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغَيِّرُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغَيِّرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغَيِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُغَيِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغَيِّر","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غَيَّرْنا","in_corpus":true,"count":22,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَيَّرْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":160,"cross_references":{"qac":{"found":true,"lemma_key":"غَيَّرَ","root":"غير","pos":"N","occurrence_count":147},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n32719","n32720"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%8A%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"other than, different from, unlike","examples":[{"text":"غَيْرُهُ","english":"another"},{"text":"هَل عِنْدَكَ أَصْدِقَاءُ غَيْرُ هَٰؤُلَاءِ؟","english":"Do you have any friends other than these?"}]},{"pos":"noun","gloss":"except, save, but","examples":[{"text":"لَا أُرِيدُ غَيْرَ ذٰلِكَ.","english":"I want only this."},{"text":"وَصَلَ الْمُسَافِرُونَ غَيْرَ وَاحِدٍ.","english":"All the travellers arrived but one."}]},{"pos":"noun","gloss":"more than","examples":[{"text":"غَيْرَ مَرَّةٍ","english":"more than once"}]},{"pos":"noun","gloss":"no, not, un-, non-, in-, dis-","examples":[{"text":"غَيْرُ طَيِّبٍ","english":"not good"},{"text":"هَٰذَا غَيْرُ قَانُونِيٍّ","english":"This is illegal"}]},{"pos":"noun","gloss":"someone or something else; someone or something other than; other; others","examples":[{"text":"إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ","english":"Except for those who believe and work good deeds: their reward will not wear off."}]},{"pos":"noun","gloss":"third party"},{"pos":"verb","gloss":"to change, to alter","tags":["transitive"],"examples":[{"text":"إِنَّ اللَّٰهَ لَا يُغَيِّرُ مَا بِقَوْمٍ حَتَّى يُغَيِّرُوا مَا بِأَنْفُسِهِمْ"}]},{"pos":"adj","gloss":"masculine plural of غَيُور (ḡayūr, “zealous, very jealous, very enthusiastic”)","tags":["form-of","masculine","plural"]},{"pos":"noun","gloss":"plural of غَيُور (ḡayūr, “zealot”)","tags":["form-of","plural"]},{"pos":"noun","gloss":"gear","tags":["regional"]}]},"etymology":{"source":"wiktextract","text":"Compare غَارَ (ḡāra, “to be jealous, to display zeal”).\n\nSee the etymology of the corresponding lemma form.\n\nFrom English gear."},"ipa":["/ɣajr/","/ɣaj.ja.ra/","/ɣu.jur/","/ɣeːr/","/ɡeːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32719","headword_ar":"غَيْرٌ","root":"gyr","body":[{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"siwFY","text_ar":"سِوًى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Other"},{"kind":"text","text":"]: and the pl. is"},{"kind":"arabic","text_bw":"A^agoyaArN","text_ar":"اَغْيَارٌ"},{"kind":"text","text":": (S:) [but"},{"kind":"arabic","text_bw":"gayor","text_ar":"غَيْر"},{"kind":"text","text":"itself often has a pl. meaning, as will be seen in what follows:] or [accord. to general usage, as will be seen below,]"},{"kind":"arabic","text_bw":"gayoru","text_ar":"غَيْرُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"siwaY","text_ar":"سِوَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other than; exclusively of;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not,"},{"kind":"text","text":"as used before a substantive or an adjective]. (Msb, K: in the CK [erroneously]"},{"kind":"arabic","text_bw":"siwFY","text_ar":"سِوًى"},{"kind":"text","text":".) It is used to qualify a subst.; [governing (as a prefixed noun) the noun that follows it in the gen. case;] and when so used, it is put in the same case as the noun preceding it. (S.) It qualifies an indeterminate noun: (Mughnee, Msb:) you say"},{"kind":"arabic","text_bw":"jaA='aniY rajulN gayoruka","text_ar":"جَا=ءَنِى رَجُلٌ غَيْرُكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A man, other than,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not, thou, came to me"},{"kind":"text","text":"]: (Msb:) and"},{"kind":"arabic","text_bw":"naEomalo SaAliHFA","text_ar":"نَعْمَلْ صَالِحًا"},{"kind":"arabic","text_bw":"gayora A@l~a*iY kun~aA naEomalu","text_ar":"غَيْرَ ا@لَّذِى كُنَّا نَعْمَلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We will in that case do good, other than,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not, what we used to do:"},{"kind":"text","text":"(Kur xxxv. 34:)]: (Mughnee:) and"},{"kind":"arabic","text_bw":"mino maA='K gayori A=sinK","text_ar":"مِنْ مَا=ءٍ غَيْرِ ا=سِنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Of water other than,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not, altered in taste and colour"},{"kind":"text","text":"]. (Kur xlvii. 16.) It is a noun necessarily prefixed, as to the sense, to a noun which it governs in the gen. case: but sometimes it is without the latter, when the meaning is understood and it is preceded by"},{"kind":"arabic","text_bw":"layosa","text_ar":"لَيْسَ"},{"kind":"text","text":", (Mughnee, K,) or by"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"text","text":": (K:) [in which case it signifies"},{"kind":"italic_en","text":"Any other person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing; any person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing beside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"else:"},{"kind":"text","text":"] you say"},{"kind":"arabic","text_bw":"qabaDotu Ea$arapF layosa gayoruhaA","text_ar":"قَبَضْتُ عَشَرَةً لَيْسَ غَيْرُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I received ten; not other than they"},{"kind":"text","text":"was received by me; i. e.,"},{"kind":"italic_en","text":"not any other thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not anything beside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"else"},{"kind":"text","text":"]; (Mughnee, K;) the enunciative,"},{"kind":"arabic","text_bw":"maqobuwDFA","text_ar":"مَقْبُوضًا"},{"kind":"text","text":", being suppressed: (Mughnee:) and"},{"kind":"arabic","text_bw":"lys","text_ar":"ليس"},{"kind":"arabic","text_bw":"gayorahaA","text_ar":"غَيْرَهَا"},{"kind":"text","text":", (Mughnee, K;) the noun [of"},{"kind":"arabic","text_bw":"lys","text_ar":"ليس"},{"kind":"text","text":"] being understood; i. e.,"},{"kind":"arabic","text_bw":"layosa AlmaqobuwDu gayorahaA","text_ar":"لَيْسَ المَقْبُوضُ غَيْرَهَا"},{"kind":"text","text":": (Mughnee:) and"},{"kind":"arabic","text_bw":"lys gayora","text_ar":"ليس غَيْرَ"},{"kind":"text","text":"; in which the affixed noun [for"},{"kind":"arabic","text_bw":"AlmDAf","text_ar":"المضاف"},{"kind":"text","text":", in the K, I read"},{"kind":"arabic","text_bw":"AlmDAf Alyh","text_ar":"المضاف اليه"},{"kind":"text","text":", as in the Mughnee,] is suppressed, and the noun [of"},{"kind":"arabic","text_bw":"lys","text_ar":"ليس"},{"kind":"text","text":"] is also understood: (Mughnee, K:) and"},{"kind":"arabic","text_bw":"lys gayoru","text_ar":"ليس غَيْرُ"},{"kind":"text","text":"; (Mughnee, K;) in which, accord. to Mbr, and the later authors,"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"is indecl., being likened to"},{"kind":"arabic","text_bw":"qabolu","text_ar":"قَبْلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEodu","text_ar":"بَعْدُ"},{"kind":"text","text":", so that it may be either the noun or the enunciative [of"},{"kind":"arabic","text_bw":"lys","text_ar":"ليس"},{"kind":"text","text":"] or, accord. to Akh, it is decl., because it is not a noun of time like"},{"kind":"arabic","text_bw":"qabolu","text_ar":"قَبْلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEodu","text_ar":"بَعْدُ"},{"kind":"text","text":", nor of place like"},{"kind":"arabic","text_bw":"fawoqu","text_ar":"فَوْقُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taHotu","text_ar":"تَحْتُ"},{"kind":"text","text":", but like"},{"kind":"arabic","text_bw":"kul~N","text_ar":"كُلٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEoDN","text_ar":"بَعْضٌ"},{"kind":"text","text":", so that it is the noun [of"},{"kind":"arabic","text_bw":"lys","text_ar":"ليس"},{"kind":"text","text":"], and the enunciative is suppressed; (Mughnee;) or it may be either indecl. or decl., (Mughnee, K,) accord. to Ibn-Kharoof: (Mughnee:) and"},{"kind":"arabic","text_bw":"lys gayorFA","text_ar":"ليس غَيْرًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lys gayorN","text_ar":"ليس غَيْرٌ"},{"kind":"text","text":"; (Mughnee, K;) in both which cases it is decl., as though the affixed noun were mentioned: (Mughnee:) and"},{"kind":"arabic","text_bw":"laA gayoru","text_ar":"لَا غَيْرُ"},{"kind":"text","text":"; for the saying, [which we find in the Mughnee,] app. taken from a statement of Seer, that this is incorrect, is not good, since it occurs in the following verse, cited by Ibn-Málik;"},{"kind":"quote","text":"jawaAbFA bihi tanojuw A@Eotamido fawarab~inaA\n                      \n                     \n                        laEano EamalK A^asolafota laA gayoru tusoA^alu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Aim thou at"},{"kind":"text","text":"having"},{"kind":"italic_en","text":"an answer by which thou mayest be safe; for, by our Lord, respecting an action which thou shalt have done before, not any other thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not anything beside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"else, thou wilt be asked"},{"kind":"text","text":"]. (K.) ―         -b2-  It does not become determinate by its being prefixed to another noun, because it is very vague: but it is also applied as an epithet to a determinate noun which is near to being indeterminate; as in"},{"kind":"arabic","text_bw":"SiraATa","text_ar":"صِرَاطَ"},{"kind":"arabic","text_bw":"A@l~a*iyna A^anoEamota Ealayohimo gayori A@lomagoDuwbi Ealayohimo","text_ar":"ا@لَّذِينَ اَنْعَمْتَ عَلَيْهِمْ غَيْرِ ا@لْمَغْضُوبِ عَلَيْهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The way of those upon whom Thou hast conferred favour; the other than,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"those who are not, the objects of anger;"},{"kind":"text","text":"(Kur i. 6 and 7;)] because the noun rendered determinate by the art."},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"denoting a genus is near to being indeterminate, and because when"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"occurs between two contraries its vagueness becomes weakened, (Mughnee, K, *) or altogether departs: (K:) or it is here applied as an epithet to a determinate noun because it resembles a determinate noun in its being prefixed to such a noun: (Msb:) Az says that"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"is here in the gen. case because it is an epithet to"},{"kind":"arabic","text_bw":"Al*yn","text_ar":"الذين"},{"kind":"text","text":"; and that it may be an epithet to [what is technically termed in this instance] a determinate noun [as having the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"prefixed to it] because"},{"kind":"arabic","text_bw":"Al*yn","text_ar":"الذين"},{"kind":"text","text":"has not [in itself] a direct meaning ("},{"kind":"arabic","text_bw":"liA^an~a Al~a*iyna","text_ar":"لِاَنَّ الَّذِينَ"},{"kind":"arabic","text_bw":"gayoru maSomuwdK Samoduhu","text_ar":"غَيْرُ مَصْمُودٍ صَمْدُهُ"},{"kind":"text","text":"), [it being merely a conjunct noun, the meaning of which is determined by what follows it,] notwithstanding it has the art."},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"prefixed to it: Abu-l-'Abbás says that Fr holds"},{"kind":"arabic","text_bw":"Al*yn","text_ar":"الذين"},{"kind":"text","text":"to have the office of an indeterminate noun; and"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"to be an epithet of it; not of any other noun; but that"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":", accord. to some, may be an epithet relating to the nouns implied in"},{"kind":"arabic","text_bw":"AnEmt","text_ar":"انعمت"},{"kind":"arabic","text_bw":"Elyhm","text_ar":"عليهم"},{"kind":"text","text":", these not having a direct meaning: Akh says that"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"[with what follows] is a substitute [for"},{"kind":"arabic","text_bw":"Al*yn","text_ar":"الذين"},{"kind":"text","text":"with what follows], as though the meaning were"},{"kind":"arabic","text_bw":"SiraATa gayori AlmagoDuwbi Ealayohimo","text_ar":"صِرَاطَ غَيْرِ المَغْضُوبِ عَلَيْهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the way"},{"kind":"page_break","n":2316},{"kind":"italic_en","text":"of those who are not the objects of anger"},{"kind":"text","text":"]. (TA.) The reading"},{"kind":"arabic","text_bw":"gayora","text_ar":"غَيْرَ"},{"kind":"text","text":"is also related, on the authority of Ibn-Ketheer, in the accus. case, as a denotative of state, [meaning"},{"kind":"italic_en","text":"they being not the objects of anger,"},{"kind":"text","text":"] relating to the pronoun governed in the gen. case by the prep. [in"},{"kind":"arabic","text_bw":"Elyhm","text_ar":"عليهم"},{"kind":"text","text":"]; or by"},{"kind":"arabic","text_bw":"A^aEoniY","text_ar":"اَعْنِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I mean"},{"kind":"text","text":"] understood; or as an exceptive, [accord. to a usage to be explained below,] if the favours be interpreted as conferred in common upon the two classes of persons. (Bd.) ―         -b3-  As it resembles a determinate noun in its being prefixed to a determinate noun, [as"},{"kind":"arabic","text_bw":"AlmgDwb","text_ar":"المغضوب"},{"kind":"text","text":"in the above-cited passage of the Kur,] some have presumed to prefix to it the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":": but against this it may be urged, that its prefixion to a determinate noun is not to render the expression determinate, but for specification; and"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"does not imply specification. (Msb.) ―         -b4-  In the following verse of Hassán,"},{"kind":"quote","text":"A^ataAnaA falamo naEodilo siwaAhu bigayorihi\n                      \n                     \n                        nabiY~N badaA fiY Zulomapi All~ayoli haAdiyaA"},{"kind":"text","text":"the meaning is, ["},{"kind":"italic_en","text":"A prophet came to us, who appeared in the darkness of night, a director in the right way,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and we did not weigh another than him with another than the other,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"with him."},{"kind":"text","text":"(Mughnee.) ―         -b5-  ["},{"kind":"arabic","text_bw":"wagayoru *`lika","text_ar":"وَغَيْرُ ذٰلِكَ"},{"kind":"text","text":"is a phrase of frequent occurrence, meaning"},{"kind":"italic_en","text":"Et cœtera."},{"kind":"text","text":"] ―         -b6-"},{"kind":"arabic","text_bw":"gayoru","text_ar":"غَيْرُ"},{"kind":"text","text":"is also used in the sense of"},{"kind":"arabic","text_bw":"layosa","text_ar":"لَيْسَ"},{"kind":"text","text":"[He, or it,"},{"kind":"italic_en","text":"is not"},{"kind":"text","text":"]; as in the phrase"},{"kind":"arabic","text_bw":"kalaAmu A@ll~`hi gayoru maxoluwqK","text_ar":"كَلَامُ ا@للّٰهِ غَيْرُ مَخْلُوقٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The word of God is not created"},{"kind":"text","text":"], syn."},{"kind":"arabic","text_bw":"layosa bimaxoluwqK","text_ar":"لَيْسَ بِمَخْلُوقٍ"},{"kind":"text","text":". (Az, TA.) ―         -b7-  It is also used in the sense of"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Not,"},{"kind":"text","text":"as used before a participle]; (S, K;) and then it is in the accus. case, as a denotative of state; (S;) as in the phrase"},{"kind":"arabic","text_bw":"famani A@DoTur~a gayora baAgK","text_ar":"فَمَنِ ا@ضْطُرَّ غَيْرَ بَاغٍ"},{"kind":"text","text":", (S, K,) in the Kur [ii. 168, and other places], (S,) i. e.,"},{"kind":"arabic","text_bw":"jaAy^iEFA laA baAgiyFA","text_ar":"جَايِعًا لَا بَاغِيًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"But whosoever is necessitated,"},{"kind":"text","text":"being hungry,"},{"kind":"italic_en","text":"not transgressing the due bounds"},{"kind":"text","text":"]. (S, K.) ―         -b8-  It is also used as an exceptive, (S, Mughnee,) in the sense of"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Except; save;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"but"},{"kind":"text","text":"]; (Msb, K;) and then it is put in the same case in which the word following"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":"would be put in the same phrase, (S, Mughnee, Msb, K,) because it is originally a qualificative, and its use as an exceptive is adventitious: (S:) therefore you say"},{"kind":"arabic","text_bw":"jaA='a Alqawomu gayora zayodK","text_ar":"جَا=ءَ القَوْمُ غَيْرَ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people came, except Zeyd"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"maA jaA='aniY A^aHadN gayora","text_ar":"مَا جَا=ءَنِى اَحَدٌ غَيْرَ"},{"kind":"arabic","text_bw":"zayodK","text_ar":"زَيْدٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gayoru zayodK","text_ar":"غَيْرُ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Not any one came to me, except Zeyd"},{"kind":"text","text":"]: (Msb, K:) or its case depends upon the governing words, so that you say"},{"kind":"arabic","text_bw":"maA qaAma gayoru zayodK","text_ar":"مَا قَامَ غَيْرُ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"No one stood, except Zeyd"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"maA raA^ayotu gayora zayodK","text_ar":"مَا رَاَيْتُ غَيْرَ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw not"},{"kind":"text","text":"any,"},{"kind":"italic_en","text":"except Zeyd"},{"kind":"text","text":"]: (Msb:) but Fr says that some of the Benoo-Asad and Kudá'ah put"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"in the accus. case, when used in the sense of"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":", whether the phrase before it be complete or incomplete; saying"},{"kind":"arabic","text_bw":"maA jaA='aniY gayoraka","text_ar":"مَا جَا=ءَنِى غَيْرَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Not"},{"kind":"text","text":"any one"},{"kind":"italic_en","text":"came to me, except thou"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"mA jA'nY A^aHadN gayoraka","text_ar":"ما جاءنى اَحَدٌ غَيْرَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Not any one came to me, except thou"},{"kind":"text","text":"]: (S, Msb:) and AA says that when"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"has the place of"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":", it is put in the accus. case. (Msb.) In the saying"},{"kind":"arabic","text_bw":"laA A_il`ha gayoru A@ll~`hi","text_ar":"لَا اـِلٰهَ غَيْرُ ا@للّٰهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is no deity other than God"},{"kind":"text","text":"],"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"is in the nom. case because it is the enunciative of"},{"kind":"arabic","text_bw":"lA","text_ar":"لا"},{"kind":"text","text":"; but it may be put in the accus. case, as meaning"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":". (Msb.) When, as an exceptive, it is prefixed to an indecl. word [and not preceded by a prep.], it may be itself indecl., with fet-h for its termination; as in the following verse;"},{"kind":"quote","text":"lamo yamonaEi Al$~uroba minohaA gayora A^ano naTaqato\n                      \n                     \n                        HamaAmapN fiY guSuwnK *aAti A^awoqaAli"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nought prevented the drinking from it, except that a pigeon cooed, upon branches having"},{"kind":"arabic","text_bw":"AwqAl","text_ar":"اوقال"},{"kind":"text","text":", which app. means"},{"kind":"italic_en","text":"stumps of cut shoots"},{"kind":"text","text":"]. (Mughnee, K.) [See also an ex. (of"},{"kind":"arabic","text_bw":"gayora A^an~a","text_ar":"غَيْرَ اَنَّ"},{"kind":"text","text":") in a verse cited voce"},{"kind":"arabic","text_bw":"bayoda","text_ar":"بَيْدَ"},{"kind":"text","text":".] ―         -b9-  [It is often used with a prep.; as in"},{"kind":"arabic","text_bw":"bigayori HisaAbK","text_ar":"بِغَيْرِ حِسَابٍ"},{"kind":"italic_en","text":"Without reckoning;"},{"kind":"text","text":"(Kur ii. 208, &c.;) and"},{"kind":"arabic","text_bw":"mino gayori suwo'K","text_ar":"مِنْ غَيْرِ سُوْءٍ"},{"kind":"italic_en","text":"Without leprosy."},{"kind":"text","text":"(Kur xx. 23, &c.)]       -A2-"},{"kind":"arabic","text_bw":"gayorN","text_ar":"غَيْرٌ"},{"kind":"text","text":"(JK, K) and (JK) ↓"},{"kind":"arabic","text_bw":"giyarN","text_ar":"غِيَرٌ","orth_type":"arrow"},{"kind":"text","text":"(JK, S) signifying The"},{"kind":"italic_en","text":"act of altering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"changing, i. q."},{"kind":"arabic","text_bw":"tagoyiyrN","text_ar":"تَغْيِيرٌ"},{"kind":"text","text":", (JK,) are substs. from"},{"kind":"arabic","text_bw":"gay~arahu","text_ar":"غَيَّرَهُ"},{"kind":"text","text":"; (S with respect to the latter, and K with respect to the former;) not inf. ns., as having no unaugmented verb. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Ald~ahori","text_ar":"الدَّهْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"giyaru","text_ar":"غِيَرُ","orth_type":"arrow"},{"kind":"text","text":", the former of these two words being of the same measure as"},{"kind":"arabic","text_bw":"Einab","text_ar":"عِنَب"},{"kind":"text","text":","},{"kind":"italic_en","text":"The accidents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"casualties, of time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, which alter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"change, things:"},{"kind":"text","text":"(K:) [or"},{"kind":"italic_en","text":"alteration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"change, of time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of fortune;"},{"kind":"text","text":"for] IAmb says, with respect to the saying"},{"kind":"arabic","text_bw":"laA A^araAniY A@ll~`hu bika giyarFA","text_ar":"لَا اَرَانِى ا@للّٰهُ بِكَ غِيَرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God not show me, in thee, alteration of state"},{"kind":"text","text":"], that"},{"kind":"arabic","text_bw":"giyarN","text_ar":"غِيَرٌ"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"tagay~uru AlHaAli","text_ar":"تَغَيُّرُ الحَالِ"},{"kind":"text","text":", a subst. like"},{"kind":"arabic","text_bw":"qiTaEN","text_ar":"قِطَعٌ"},{"kind":"text","text":"[as meaning “ a portion of the night ”]; or that it may be a pl., of which the sing. is ↓"},{"kind":"arabic","text_bw":"giyorapN","text_ar":"غِيْرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"banaAtu gayorK","text_ar":"بَنَاتُ غَيْرٍ"},{"kind":"text","text":"[or ↓"},{"kind":"arabic","text_bw":"giyarK","text_ar":"غِيَرٍ","orth_type":"arrow"},{"kind":"text","text":", as in Freytag's Arab. Prov. i. 309,] (tropical:)"},{"kind":"italic_en","text":"Lying:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a lie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falsehood:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ka*ibN","text_ar":"كَذِبٌ"},{"kind":"text","text":": (TS, K:) or [rather]"},{"kind":"italic_en","text":"lies."},{"kind":"text","text":"(JK, A.) You say"},{"kind":"arabic","text_bw":"jaA='a bibanaAti gayorK","text_ar":"جَا=ءَ بِبَنَاتِ غَيْرٍ"},{"kind":"text","text":"[or ↓"},{"kind":"arabic","text_bw":"giyarK","text_ar":"غِيَرٍ","orth_type":"arrow"},{"kind":"text","text":"] (tropical:)"},{"kind":"italic_en","text":"He uttered lies."},{"kind":"text","text":"(A.)"}],"source_refs":["S","Msb","K","JK","TS"]},{"entry_id":"n32720","headword_ar":"غِيَرٌ","root":"gyr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gayorN","text_ar":"غَيْرٌ"},{"kind":"text","text":", last quarter, in four places: ―         -b2-  and see also"},{"kind":"arabic","text_bw":"giyrapN","text_ar":"غِيرَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}