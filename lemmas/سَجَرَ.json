definition":{"source":"lanes","entries":[{"entry_id":"n18929","headword_ar":"سَجَرٌ","root":"sjr","body":[{"kind":"text","text":"(T, S, M, K, &c.) and ↓"},{"kind":"arabic","text_bw":"sujorapN","text_ar":"سُجْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(T, M, K)"},{"kind":"italic_en","text":"Turbidness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dinginess:"},{"kind":"text","text":"this is the primary signification: and hence, (TA,) (tropical:)"},{"kind":"italic_en","text":"an intermixture of redness in the white of the eye:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"redness in the white of the eye:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"redness inclining to whiteness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"redness inclining to blueness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"redness in the black of the eye:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an intermixture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tinge, of redness in the black of the eye:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a slight redness mixing with the blackness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an inclining of the black to redness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a slight whiteness in the black of the eye:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a dinginess in the interior of the eye, arising from neglecting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaving off, the use of collyrium."},{"kind":"text","text":"(TA.)"}],"source_refs":["T","M","K","TA","S"]}]}}