"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدَلِّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدَلِّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدَلِّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدَلِّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدَلِّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدَلِّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدَلِّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَلِّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدَلِّسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَلِّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدَلِّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"دَلَّسْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَلَّسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُدَلِّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَلِّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n12926","n12927","n12930"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%84%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12926","headword_ar":"دَلَسَ","root":"dls","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dalosN","text_ar":"دَلْسٌ"},{"kind":"text","text":": see the next paragraph, in three places."}],"source_refs":[]},{"entry_id":"n12927","headword_ar":"دلّس","root":"dls","body":[{"kind":"text","text":", (M, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"tadoliysN","text_ar":"تَدْلِيسٌ"},{"kind":"text","text":", (S, M, Mgh, Msb, K,)"},{"kind":"italic_en","text":"He concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid,"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"he did not make"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"known;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tdl~s","text_ar":"تدلّس","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"italic_en","text":"He concealed a fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect, in an article of merchandize, from the purchaser,"},{"kind":"text","text":"(S, Mgh, Msb, K,) in selling; (S, Msb;) as also ↓"},{"kind":"arabic","text_bw":"dalasa","text_ar":"دَلَسَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dalosN","text_ar":"دَلْسٌ"},{"kind":"text","text":"; but the former is the more common: (Msb:) and"},{"kind":"italic_en","text":"he did not show a fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect;"},{"kind":"text","text":"without restriction to a case of selling. (TA.) You say,"},{"kind":"arabic","text_bw":"dal~asa EalaY Alr~ajuli fiY AlbayoEi","text_ar":"دَلَّسَ عَلَى الرَّجُلِ فِى البَيْعِ"},{"kind":"text","text":", (M, A,) and"},{"kind":"arabic","text_bw":"dl~s lahu fiY AlbayoEi","text_ar":"دلّس لَهُ فِى البَيْعِ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He concealed, disguised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloaked, from the man the fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect, of the thing sold;"},{"kind":"text","text":"(A;)"},{"kind":"italic_en","text":"he did not show the fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect, to the man in selling."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"dl~s fiY AlbayoEi wagayorihi","text_ar":"دلّس فِى البَيْعِ وَغَيْرِهِ"},{"kind":"italic_en","text":"He did not show his fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect, in selling, and in other cases."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"dl~s Ealayohi","text_ar":"دلّس عَلَيْهِ"},{"kind":"italic_en","text":"He concealed, disguised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloaked, from him his fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect."},{"kind":"text","text":"(A.) And Az heard an Arab of the desert say,"},{"kind":"arabic","text_bw":"layosa fiY AlA^amori","text_ar":"لَيْسَ فِى الاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"walosN wa laA dalosN","text_ar":"وَلْسٌ وَ لَا دَلْسٌ","orth_type":"arrow"},{"kind":"italic_en","text":"There is not in the affair treachery nor deceit:"},{"kind":"text","text":"(Msb:) or ↓"},{"kind":"arabic","text_bw":"maA liY fiyhi walosN walaA dalosN","text_ar":"مَا لِى فِيهِ وَلْسٌ وَلَا دَلْسٌ","orth_type":"arrow"},{"kind":"italic_en","text":"I have not, with respect to it, treachery nor deceit;"},{"kind":"text","text":"(K,* TA;) referring to a thing, or an affair, in which he was accused, or suspected, of evil. (L, TA.) [In the CK, instead of"},{"kind":"arabic","text_bw":"dalosN","text_ar":"دَلْسٌ"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"dalasN","text_ar":"دَلَسٌ"},{"kind":"text","text":".] ―         -b3-  Hence"},{"kind":"arabic","text_bw":"tadoliysN","text_ar":"تَدْلِيسٌ"},{"kind":"text","text":"in the ascription of a tradition to its relater or relaters; which is, (tropical:)  One's"},{"kind":"italic_en","text":"relating a tradition as from the earliest sheykh when perhaps he has not seen him, but only heard it from one inferior to him, or from one who had heard it from him, and the like;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"when he has seen him, but has heard what he ascribes to him from another, inferior to him;"},{"kind":"text","text":"(Az, TA;) which has been done by several persons in whom confidence is placed: (K:) or one's"},{"kind":"italic_en","text":"not mentioning, in his tradition, him from whom he heard it, but mentioning the highest authority, inducing the opinion that he had heard it from him."},{"kind":"text","text":"(A.)"}],"source_refs":["M","A","Msb","S","Mgh","K"]},{"entry_id":"n12930","headword_ar":"دَلَسٌ","root":"dls","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"dark;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"darkness;"},{"kind":"text","text":"(S, M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"dulosapN","text_ar":"دُلْسَةٌ","orth_type":"arrow"},{"kind":"text","text":": (A, Msb, K:) and the"},{"kind":"italic_en","text":"confusedness of the darkness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the beginning of night;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"AixotilaATu AlZ~alaAmi","text_ar":"اِخْتِلَاطُ الظَّلَامِ"},{"kind":"text","text":". (A, K.) You say,"},{"kind":"arabic","text_bw":"A^ataAnaA","text_ar":"اَتَانَا"},{"kind":"arabic","text_bw":"dalasa AlZ~alaAmi","text_ar":"دَلَسَ الظَّلَامِ"},{"kind":"italic_en","text":"He came to us in the confusedness of the darkness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the beginning of night."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xaraja fiY A@ld~alasi waA@logalasi","text_ar":"خَرَجَ فِى ا@لدَّلَسِ وَا@لْغَلَسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went forth in the confusedness of the darkness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the beginning of night, and in the darkness of the last part of the night"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["A","Msb","K"]}]},"classical_definitions":null}