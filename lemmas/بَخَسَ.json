con.com/?s=%D8%A8%D9%8E%D8%AE%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to belittle, debase"}]},"etymology":null,"ipa":["/bax.xa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1888","headword_ar":"بَخْسٌ","root":"bxs","body":[{"kind":"italic_en","text":"Deficient; defective."},{"kind":"text","text":"(S.) It is said in the Kur [xii. 20],"},{"kind":"arabic","text_bw":"wa$arawohu bivamanK baxosK","text_ar":"وَشَرَوْهُ بِثَمَنٍ بَخْسٍ"},{"kind":"italic_en","text":"And they sold him for a deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective, price:"},{"kind":"text","text":"(S, * Msb, * TA:) or"},{"kind":"italic_en","text":"for a price less than was incumbent:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for an insufficient price:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for an unjust price;"},{"kind":"text","text":"accord. to Zj; because the sale of a man that has been found is unlawful. (TA.)       -A2-"},{"kind":"italic_en","text":"Land that produces herbage without being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"artificially"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"watered:"},{"kind":"text","text":"(JK, S, K:) or"},{"kind":"italic_en","text":"land which is watered by the rain;"},{"kind":"text","text":"because it has deficient watering: (Mgh:) pl."},{"kind":"arabic","text_bw":"buxuwsN","text_ar":"بُخُوسٌ"},{"kind":"text","text":". (JK, TA.) ―         -b2-  Also, (TA, as from Ibn-Málik,) or ↓"},{"kind":"arabic","text_bw":"baxosiY~N","text_ar":"بَخْسِىٌّ","orth_type":"arrow"},{"kind":"text","text":", [which is more probably the correct form,] a rel. n. from"},{"kind":"arabic","text_bw":"baxosN","text_ar":"بَخْسٌ"},{"kind":"text","text":"in the sense immediately preceding, explained in the T as signifying, (Mgh,) Seed-produce"},{"kind":"italic_en","text":"that is not irrigated with water from a spring or well or the like, but only by the rain."},{"kind":"text","text":"(Mgh, and TA from Ibn-Málik.)"}],"source_refs":["JK","S","K","Mgh"]}]},"classical_definitions":null}