:"(K, TA: see"},{"kind":"arabic","text_bw":"duxolapN","text_ar":"دُخْلَةٌ"},{"kind":"text","text":", last sentence, in two places.) [And"},{"kind":"arabic","text_bw":"madoxalu xayorK","text_ar":"مَدْخَلُ خَيْرٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A means of attaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doing, good."},{"kind":"text","text":"] ―         -b3-  [Also"},{"kind":"italic_en","text":"A time of entrance."},{"kind":"text","text":"]"}],"source_refs":["S","Msb"]},{"entry_id":"n12281","headword_ar":"مُدْخَلٌ","root":"dxl","body":[{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"A_idoxaAlN","text_ar":"اـِدْخَالٌ"},{"kind":"text","text":": and is also the pass. part. n. of"},{"kind":"arabic","text_bw":"A^adoxalahu","text_ar":"اَدْخَلَهُ"},{"kind":"text","text":": (S:) [and a n. of place: and of time:] see 4. ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Base, base-born,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble; of suspected origin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adopted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who claims for his father one who is not:"},{"kind":"text","text":"(K, * TA:) because he is introduced among a people [to whom he is not related]. (TA.)"}],"source_refs":["S"]},{"entry_id":"n12282","headword_ar":"مِدْخَلٌ","root":"dxl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"An instrument by means of which one enters:"},{"kind":"text","text":"mentioned by Golius as meaning"},{"kind":"italic_en","text":"a key;"},{"kind":"text","text":"on the authority of Ibn-Seenà (Avicenna).]"}],"source_refs":[]}]},"classical_definitions":null}