gen":"m","num":"p"},{"role":"present_2mp","form":"تُبْطِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُبْطِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُبْطِل","in_corpus":true,"count":25,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُبْطِل","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُبْطِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُبْطِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبْطِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبْطِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبْطِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبْطِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبْطِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُبْطِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبْطِل","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"أَبْطَلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَبْطَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":66,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n2785"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D9%92%D8%B7%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to prove false, to disprove","examples":[{"text":"لِيُحِقَّ الْحَقَّ وَيُبْطِلَ الْبَاطِلَ وَلَوْ كَرِهَ الْمُجْرِمُونَ"}]},{"pos":"verb","gloss":"to nullify, to invalidate, to render ineffective, to rescind, to repeal, to revoke"},{"pos":"verb","gloss":"to defuse, to shut down, to extinguish, to deactivate, to neutralize"},{"pos":"verb","gloss":"to defeat, to render futile, to quash, to foil, to frustrate, to thwart"},{"pos":"verb","gloss":"to assert a falsehood, to be wrong","tags":["intransitive"],"examples":[{"text":"فَإِذَا جَاءَ أَمْرُ اللَّهِ قُضِيَ بِالْحَقِّ وَخَسِرَ هُنَالِكَ الْمُبْطِلُونَ"}]}]},"etymology":{"source":"wiktextract","text":"Compare Ge'ez አብጠለ (ʾäbṭälä) with the same meaning except the modern ones.\n\nSee the etymology of the corresponding lemma form."},"ipa":["/ʔab.tˤa.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2785","headword_ar":"ابطل","root":"bTl","body":[{"kind":"italic_en","text":"He said,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke, what was false,"},{"kind":"page_break","n":219},{"kind":"text","text":"or"},{"kind":"italic_en","text":"untrue;"},{"kind":"text","text":"(Mgh, Msb, K;) ["},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^aHaq~a","text_ar":"اَحَقَّ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"he lied:"},{"kind":"text","text":"(Mgh:)"},{"kind":"italic_en","text":"he made a false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain, claim"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demand; he claimed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, for himself that which was not right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just."},{"kind":"text","text":"(Lth, TA.) ―         -b2-  See also 1.       -A2-"},{"kind":"arabic","text_bw":"AbTlhu","text_ar":"ابطلهُ"},{"kind":"text","text":"[and vulgarly ↓"},{"kind":"arabic","text_bw":"bT~lhu","text_ar":"بطّلهُ","orth_type":"arrow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it,"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"he proved it to be,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"baATil","text_ar":"بَاطِل"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"false, untrue, wrong"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incorrect, fictitious, spurious, unfounded, unsound, vain, unreal, naught, futile, worthless, useless, unprofitable,"},{"kind":"text","text":"(S, * L, K, TA,)"},{"kind":"italic_en","text":"devoid of virtue"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efficacy, ineffectual, null, void, of no force,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no account;"},{"kind":"text","text":"(Msb, TA;)"},{"kind":"italic_en","text":"he nullified it, annulled it, abolished it, cancelled it;"},{"kind":"text","text":"whether it was true or false, right or wrong, authentic or spurious, valid or null; (TA;)"},{"kind":"italic_en","text":"he made it to go for nothing, as a thing of no account,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as a thing that had perished"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become lost."},{"kind":"text","text":"(K.) Hence,"},{"kind":"arabic","text_bw":"AbTl $ahaAdatahu","text_ar":"ابطل شَهَادَتَهُ"},{"kind":"italic_en","text":"He annulled his testimony."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"zwr","text_ar":"زور"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"liyuHiq~a AlHaq~a wa yuyoTila AlbaATila","text_ar":"لِيُحِقَّ الحَقَّ وَ يُيْطِلَ البَاطِلَ"},{"kind":"text","text":", in the Kur [viii. 8, meaning"},{"kind":"italic_en","text":"That He might establish that which is true, and annul that which is false"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Mgh"]}]},"classical_definitions":null}