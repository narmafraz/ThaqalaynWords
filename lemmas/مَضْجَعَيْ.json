ind":"text","text":"so in the saying,"},{"kind":"arabic","text_bw":"huwa Tay~ibu AlmaDaAjiEi","text_ar":"هُوَ طَيِّبُ المَضَاجِعِ"},{"kind":"text","text":"i. e. (assumed tropical:)"},{"kind":"italic_en","text":"He has well-born wives"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"women;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"kariymu AlmafaAri$i","text_ar":"كَرِيمُ المَفَارِشِ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"maDaAjiEu Algayovi","text_ar":"مَضَاجِعُ الغَيْثِ"},{"kind":"text","text":"means (tropical:)"},{"kind":"italic_en","text":"The places of falling of rain."},{"kind":"text","text":"(O, K, TA.) One says,"},{"kind":"arabic","text_bw":"baAtati Alr~iyaADu","text_ar":"بَاتَتِ الرِّيَاضُ"},{"kind":"arabic","text_bw":"maDaAjiEa lilogayovi","text_ar":"مَضَاجِعَ لِلْغَيْثِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The meadows were during the night places of the falling of rain"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["O","K","Msb","TA"]},{"entry_id":"n25575","headword_ar":"مُضْجِعٌ","root":"DjE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"DaAjiEN","text_ar":"ضَاجِعٌ"},{"kind":"text","text":", first sentence."}],"source_refs":[]}]}}