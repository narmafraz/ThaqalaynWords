{"lemma":"مَعْلُومِي","slug":"مَعْلُومِي","root":"ع.ل.م","root_slug":"ع-ل-م","root_link":"/words/roots/ع-ل-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَعْلُوم","root":"علم","pos":"N","occurrence_count":11},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n30376"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B9%D9%92%D9%84%D9%8F%D9%88%D9%85%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"known","examples":[{"text":"الْحَجُّ أَشْهُرٌ مَّعْلُومَاتٌ"}]},{"pos":"adj","gloss":"clear, evident, certain"},{"pos":"adj","gloss":"of course, yes (in answering)"},{"pos":"adj","gloss":"noteworthy, celebrated, distinguished"},{"pos":"adj","gloss":"given (mathematical quantity)"},{"pos":"noun","gloss":"active voice"},{"pos":"noun","gloss":"income, salary, pension"},{"pos":"noun","gloss":"tax"},{"pos":"noun","gloss":"cost, amount"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of عَلِمَ (ʕalima, “to know”), verb form I from the root ع ل م (ʕ l m): literally, “known”. The word is used to describe the active voice because the agent of the verb is mentioned and is therefore known. In the passive, on the other hand, the agent is usually not mentioned and is therefore unknown (مَجْهُول (majhūl))."},"ipa":["/maʕ.luːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30376","headword_ar":"مَعْلُومٌ","root":"Elm","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Known;"},{"kind":"text","text":"&c.]."},{"kind":"arabic","text_bw":"Alwaqotu AlmaEoluwmu","text_ar":"الوَقْتُ المَعْلُومُ"},{"kind":"text","text":"[mentioned in the Kur xv. 38 and xxxviii. 82] means ["},{"kind":"italic_en","text":"The time of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the resurrection."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlA^ay~aAmu","text_ar":"الاَيَّامُ"},{"kind":"arabic","text_bw":"AlmaEoluwmaAtu","text_ar":"المَعْلُومَاتُ"},{"kind":"text","text":"[mentioned in the Kur xxii. 29] means"},{"kind":"page_break","n":2142},{"kind":"text","text":"["},{"kind":"italic_en","text":"The first"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ten days of Dhu-l-Hijjeh,"},{"kind":"text","text":"(S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"the last of which is the day of the sacrifice."},{"kind":"text","text":"(TA.) ―         -b2-  [In grammar, The"},{"kind":"italic_en","text":"active voice."},{"kind":"text","text":"]"}],"source_refs":["S","Mgh","Msb","K"]}]},"classical_definitions":null}