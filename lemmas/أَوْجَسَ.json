count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوجِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوجِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوجَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوجَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوجِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوجِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوجَسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوجَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوجِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُوجَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُوجِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوجِس","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوجَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوجَس","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"أَوْجَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَوْجَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":true,"lemma_key":"أَوْجَسَ","root":"وجس","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n41717","n41723"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%88%D9%92%D8%AC%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to feel, to forebode, to be shrewdly afeared of","examples":[{"text":"وَلَقَدْ جَاءَتْ رُسُلُنَا إِبْرَاهِيمَ بِالْبُشْرَىٰ قَالُوا سَلَامًا قَالَ سَلَامٌ فَمَا لَبِثَ أَن جَاءَ بِعِجْلٍ حَنِيذٍ / فَلَمَّا رَأَىٰ أَيْدِيَهُمْ لَا تَصِلُ إِلَيْهِ نَكِرَهُمْ وَأَوْجَسَ مِنْهُمْ خِيفَةً قَالُوا لَا تَخَفْ إِنَّا أُرْسِلْنَا إِلَىٰ قَوْمِ لُوطٍ.","english":"Pickthall: And Our messengers came unto Abraham with good news. They said: Peace! He answered: Peace! and delayed not to bring a roasted calf. / And when he saw their hands reached not to it, he mistrusted them and conceived a fear of them. They said: Fear not! Lo! we are sent unto the folk of Lot."}]}]},"etymology":null,"ipa":["/ʔaw.d͡ʒa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41717","headword_ar":"اوجس","root":"wjs","body":[{"kind":"italic_en","text":"He conceived"},{"kind":"text","text":"a thing in his mind; syn."},{"kind":"arabic","text_bw":"A^aDomara","text_ar":"اَضْمَرَ"},{"kind":"text","text":". (A.) So in the Kur, [xx. 70,]"},{"kind":"arabic","text_bw":"faA^awojasa fiY nafosihi xiyfapF","text_ar":"فَاَوْجَسَ فِى نَفْسِهِ خِيفَةً"},{"kind":"italic_en","text":"And he conceived in his mind a fear:"},{"kind":"text","text":"(Aboo-Is-hák, S:) and ↓"},{"kind":"arabic","text_bw":"tawaj~asa","text_ar":"تَوَجَّسَ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (S:) or the above words of the Kur. signify"},{"kind":"italic_en","text":"he perceived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"felt, and conceived, in his mind a fear;"},{"kind":"text","text":"(K;) and in like manner in the same book, [xi. 73, and] li. 28: or, as Aboo-Is-hák says, in one place,"},{"kind":"arabic","text_bw":"Awjs","text_ar":"اوجس"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"fear fell into his mind."},{"kind":"text","text":"(TA.) See also 1, and 5."}],"source_refs":["S"]},{"entry_id":"n41723","headword_ar":"اَوْجَسُ","root":"wjs","body":[{"kind":"italic_en","text":"A little"},{"kind":"text","text":"of food, and of beverage. (K.) One says,"},{"kind":"arabic","text_bw":"maA duqotu Einodahu A^awojasu","text_ar":"مَا دُقْتُ عِنْدَهُ اَوْجَسُ"},{"kind":"italic_en","text":"I tasted not, at his abode, any food;"},{"kind":"text","text":"(El-Umawee, S;) and [in like manner] ↓"},{"kind":"arabic","text_bw":"wajosFA","text_ar":"وَجْسًا","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"maAfiY siqaAy^ihi","text_ar":"مَافِى سِقَايِهِ"},{"kind":"arabic","text_bw":"A^awojasu","text_ar":"اَوْجَسُ"},{"kind":"italic_en","text":"There is not in his skin a drop:"},{"kind":"text","text":"thus the phrase is given, without the mention of beverage: or"},{"kind":"italic_en","text":"a drop of water."},{"kind":"text","text":"(TA.) It is said that the word is not used except in negative phrases. (TA.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"AlA^awojasu","text_ar":"الاَوْجَسُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA^awojusu","text_ar":"الاَوْجُسُ"},{"kind":"text","text":"(S, K) the latter on the authority of Yaakoob, (S, TA,) but the former is the more chaste, (TA,)"},{"kind":"italic_en","text":"Time;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ald~ihora","text_ar":"الدِّهْرَ"},{"kind":"text","text":". (S, K.) Hence the saying, (TA,)"},{"kind":"arabic","text_bw":"laAA^afoEaluhu","text_ar":"لَااَفْعَلُهُ"},{"kind":"arabic","text_bw":"sajiysa AlA^awojasi","text_ar":"سَجِيسَ الاَوْجَسِ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"AlA^awojusi","text_ar":"الاَوْجُسِ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"I will not do it ever."},{"kind":"text","text":"(ISk, S, K.) And"},{"kind":"arabic","text_bw":"A^afoEaluhu","text_ar":"اَفْعَلُهُ"},{"kind":"arabic","text_bw":"sajiysa Eujaiyosa AlA^awojasK","text_ar":"سَجِيسَ عُجَِيْسَ الاَوْجَسٍ"},{"kind":"italic_en","text":"I will not do it while time lasts."},{"kind":"text","text":"(El-Fárisee.)"}],"source_refs":["S","K","TA"]}]},"classical_definitions":null}