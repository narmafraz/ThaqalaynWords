{"lemma":"نَدَبَ","slug":"نَدَبَ","root":"ن.د.ب","root_slug":"ن-د-ب","root_link":"/words/roots/ن-د-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"نَدَبْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"نَدَبْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"نَدَبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"نَدَبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"نَدَبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"نَدَبَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"نَدَبَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"نَدَبا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"نَدَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"نَدَبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"نَدَبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَنْدُب","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَنْدُبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَنْدُبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَنْدُبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْدُبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَنْدُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْدُبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْدُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْدُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْدُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْدُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْدُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْدُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْدُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْدُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْدُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْدُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَدَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَدَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْدُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْدُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n39580","n39583","n39584","n39585"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AF%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to incite, to urge","examples":[{"text":"نَدَبُونِي إِلَى مَا فَعَلْتُ","english":"They incited me to what I have done."}]},{"pos":"verb","gloss":"to bewail, wail over, to weep for","examples":[{"text":"نَدَبَتِ ٱلْمَيِّتَ","english":"She wailed for the deceased one."}]},{"pos":"verb","gloss":"to scar, to heal (a wound) by scar formation","examples":[{"text":"نَدِبَ ٱلْجَرْحُ","english":"The wound scarred."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39580","headword_ar":"ندّب","root":"ndb","body":[{"kind":"italic_en","text":"He took, got,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"won, a bet, wager,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake."},{"kind":"text","text":"(L.) ―         -b2-  See 1."}],"source_refs":[]},{"entry_id":"n39583","headword_ar":"نَدْبٌ","root":"ndb","body":[{"kind":"text","text":"A man who is"},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active,"},{"kind":"text","text":"("},{"kind":"italic_en","text":"and quick,"},{"kind":"text","text":"TA,)"},{"kind":"italic_en","text":"in the accomplishment of an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a want;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"minodabaY","text_ar":"مِنْدَبَى","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"minodibaY","text_ar":"مِنْدِبَى","orth_type":"arrow"},{"kind":"text","text":": (TA:) a man"},{"kind":"italic_en","text":"who, when he is sent to accomplish a great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an important, affair, finds it light to him:"},{"kind":"text","text":"(A:)"},{"kind":"italic_en","text":"clever, ingenious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acute in mind; excellent:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"nuduwbN","text_ar":"نُدُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nudabaA'u","text_ar":"نُدَبَاءُ"},{"kind":"text","text":": (K:) the former agreeable with analogy; the latter formed from the imaginary sing."},{"kind":"arabic","text_bw":"nadiybN","text_ar":"نَدِيبٌ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"sumaHaA'u","text_ar":"سُمَحَاءُ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"samoHN","text_ar":"سَمْحٌ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"nadobN","text_ar":"نَدْبٌ"},{"kind":"text","text":", as applied to a horse,"},{"kind":"italic_en","text":"Sharp-spirited;"},{"kind":"text","text":"(Lth, S;) contr. of"},{"kind":"arabic","text_bw":"baliydN","text_ar":"بَلِيدٌ"},{"kind":"text","text":"(Lth)"},{"kind":"italic_en","text":"excellent."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"nadobN","text_ar":"نَدْبٌ"},{"kind":"italic_en","text":"Lightness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"activity."},{"kind":"text","text":"(MF.) ―         -b4-"},{"kind":"arabic","text_bw":"A^araAka nadobFA fiY AlHawaAy^iji","text_ar":"اَرَاكَ نَدْبًا فِى الحَوَايِجِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I see thee to be clever in accomplishing affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wants."},{"kind":"text","text":"(A.)       -A2-  See"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA","A","Lth"]},{"entry_id":"n39584","headword_ar":"نَدَبٌ","root":"ndb","body":[{"kind":"text","text":", (S, K,) and, by poetical licence, ↓"},{"kind":"arabic","text_bw":"nadobN","text_ar":"نَدْبٌ","orth_type":"arrow"},{"kind":"text","text":", (MF,) The"},{"kind":"italic_en","text":"scar,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"scars,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"of a wound,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"not rising above the surrounding skin:"},{"kind":"text","text":"(S:) accord. to the K, pl."},{"kind":"arabic","text_bw":"nadabapN","text_ar":"نَدَبَةٌ"},{"kind":"text","text":"[which is written in several MS. copies of the K"},{"kind":"arabic","text_bw":"nadobapN","text_ar":"نَدْبَةٌ"},{"kind":"text","text":"; and so in the CK; but this, accord. to the TA, is incorrect;] but it is a coll. gen. n., of which the n. un. is"},{"kind":"arabic","text_bw":"nadabapN","text_ar":"نَدَبَةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"$ajarapN","text_ar":"شَجَرَةٌ"},{"kind":"text","text":"is that of"},{"kind":"arabic","text_bw":"$ajarN","text_ar":"شَجَرٌ"},{"kind":"text","text":": (MF:) pl."},{"kind":"arabic","text_bw":"A^anodaAbN","text_ar":"اَنْدَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nuduwbN","text_ar":"نُدُوبٌ"},{"kind":"text","text":": (K:) the former of"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"agreeably with analogy: the latter dev. with respect to analogy; or pl. of"},{"kind":"arabic","text_bw":"nadobN","text_ar":"نَدْبٌ"},{"kind":"text","text":". (MF.) ―         -b2-"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"is also applied, in a trad., to the (tropical:)"},{"kind":"italic_en","text":"Marks"},{"kind":"text","text":"made by Moses' smiting the stone [from which, thereupon, water flowed forth]; these marks being thus likened to the scars of wounds. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"is also employed to signify (tropical:)"},{"kind":"italic_en","text":"Scars"},{"kind":"text","text":"upon men's reputation. A poet says,"},{"kind":"quote","text":"qawomN saA^atoruku fiY A^aEoraADihimo nadabaA"},{"kind":"italic_en","text":"A people upon whose reputation I will leave scars,"},{"kind":"text","text":"the effects of my satires. (TA.)       -A2-"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"direction in which one shoots an arrow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrows:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ri$oqN","text_ar":"رِشْقٌ"},{"kind":"text","text":". (So in the S and the CK and several MS. copies of the K: in other copies,"},{"kind":"arabic","text_bw":"ra$oqN","text_ar":"رَشْقٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"act of shooting an arrow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrows."},{"kind":"text","text":"Both these readings are correct accord. to the TA. See below.)"},{"kind":"arabic","text_bw":"A_irotamaY nadabFA A^awo nadabayoni","text_ar":"اـِرْتَمَى نَدَبًا اَوْ نَدَبَيْنِ"},{"kind":"italic_en","text":"He shot an arrow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrows in one direction"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in two directions:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"wajohFA A^awo wajohayoni","text_ar":"وَجْهًا اَوْ وَجْهَيْنِ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"nadabunaA yawoma ka*aA","text_ar":"نَدَبُنَا يَوْمَ كَذَا"},{"kind":"text","text":"(said by those who are to contend at a shooting-match, TA,)"},{"kind":"italic_en","text":"The day of our commencing shooting shall be such a day."},{"kind":"text","text":"(K.) This confirms the assertion in the TA, that"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"ra$oqN","text_ar":"رَشْقٌ"},{"kind":"text","text":", as well as with"},{"kind":"arabic","text_bw":"ri$oqN","text_ar":"رِشْقٌ"},{"kind":"text","text":". In the Turk. K, in the place of"},{"kind":"arabic","text_bw":"yawoma A@botidaAy^inaA","text_ar":"يَوْمَ ا@بْتِدَايِنَا"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"ywm A@notidaAbinaA","text_ar":"يوم ا@نْتِدَابِنَا"},{"kind":"text","text":"; and Freytag adopts the latter reading; but I find no other authority for it.] ―         -b3-"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"italic_en","text":"A bet, wager, stake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing wagered; what is staked at a shooting match,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a race, and taken by the winner:"},{"kind":"text","text":"(S, * K, * L:) pl."},{"kind":"arabic","text_bw":"A^anodaAbN","text_ar":"اَنْدَابٌ"},{"kind":"text","text":". (Msb.) So in the following phrases. ―         -b4-"},{"kind":"arabic","text_bw":"bayonahumo","text_ar":"بَيْنَهُمْ"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Between them is a bet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wager"},{"kind":"text","text":"]. ―         -b5-"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"arabic","text_bw":"fulaAnN EalaY nadabK","text_ar":"فُلَانٌ عَلَى نَدَبٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one stood to a bet, wager,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake"},{"kind":"text","text":"]. (TA.) ―         -b6-  'Orweh says,"},{"kind":"quote","text":"A^ayaholiku muEotam~N wazayodN walamo A^uqimo\n                      \n                     \n                        EalaY na*abK yawomFA waliY nafosu muxoTiri"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Shall Moatemm and Zeyd perish, and I not stand to a stake, some day, when I have the soul of one who makes his life a stake to his adversary and sallies forth against him?"},{"kind":"text","text":"] These two were his ancestors. (S.) Or, accord. to Az, who reads"},{"kind":"arabic","text_bw":"A^ataholiku","text_ar":"اَتَهْلِكُ"},{"kind":"text","text":", they were two tribes. (TA.)"}],"source_refs":["S","K","MF"]},{"entry_id":"n39585","headword_ar":"نَدِبٌ","root":"ndb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"nadiybN","text_ar":"نَدِيبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}