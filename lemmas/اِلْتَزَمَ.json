":["n43286"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%84%D9%92%D8%AA%D9%8E%D8%B2%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stick to, to keep to, to adhere strictly to; to make oneself responsible for, to take over as a duty specific to oneself; to commit oneself to"},{"pos":"verb","gloss":"to stick to, to keep to, to adhere strictly to; to make oneself responsible for, to take over as a duty specific to oneself; to take over as a monopoly"},{"pos":"verb","gloss":"to stick to, to keep to, to adhere strictly to; to be responsible for, to have the particular duty of, to be bound to"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43286","headword_ar":"اِلْتَزَمَ","root":"lzm","body":[{"kind":"italic_en","text":"He took upon himself"},{"kind":"text","text":"an affair. (KL.) You say,"},{"kind":"arabic","text_bw":"Ailotazamahu","text_ar":"اِلْتَزَمَهُ"},{"kind":"italic_en","text":"He took it upon himself; charged himself with it; obliged himself to do it; became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, answerable for it by an inseparable obligation:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"baA='a","text_ar":"بَا=ءَ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"Ailotazamotu baAlmaAli","text_ar":"اِلْتَزَمْتُ بَالمَالِ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^alozamotu bihi nafosiY","text_ar":"اَلْزَمْتُ بِهِ نَفْسِى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"takaf~alotu","text_ar":"تَكَفَّلْتُ"},{"kind":"page_break","n":3010},{"kind":"arabic","text_bw":"baha","text_ar":"بَهَ"},{"kind":"text","text":", accord. to IAmb, or"},{"kind":"arabic","text_bw":"taHam~alotu bihi","text_ar":"تَحَمَّلْتُ بِهِ"},{"kind":"text","text":", accord. to AZ; (Msb in art."},{"kind":"arabic","text_bw":"kfl","text_ar":"كفل"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"I made myself answerable, responsible"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accountable, by an inseparable obligation, for the property:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"Damina","text_ar":"ضَمِنَ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"Ailotazama","text_ar":"اِلْتَزَمَ"},{"kind":"arabic","text_bw":"AlmaAla","text_ar":"المَالَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlEamala","text_ar":"العَمَلَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He obliged himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took upon himself the obligation, to pay the money &c., and to do the deed."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"Ailotazamahu","text_ar":"اِلْتَزَمَهُ"},{"kind":"italic_en","text":"He kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restricted himself, to it;"},{"kind":"text","text":"i. e. an action, or usage, &c. ―         -b5-  And"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, necessary for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory upon him, to do it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pay it,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"to suffer it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endure it."},{"kind":"text","text":"―         -b6-"},{"kind":"arabic","text_bw":"dalafa liA@lotizaAmiY","text_ar":"دَلَفَ لِا@لْتِزَامِى"},{"kind":"italic_en","text":"He hastened to take me by the hand and embrace me:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"dalafa","text_ar":"دَلَفَ"},{"kind":"text","text":". ―         -b7-"},{"kind":"arabic","text_bw":"AilotizaAmN","text_ar":"اِلْتِزَامٌ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"luzuwmu maA laA yalozamu","text_ar":"لُزُومُ مَا لَا يَلْزَمُ"},{"kind":"text","text":": see below."}],"source_refs":[]}]},"classical_definitions":null}