"arabic","text_bw":"suhuwlapN","text_ar":"سُهُولَةٌ"},{"kind":"text","text":", (S, Msb, K, KL,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, smooth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, plain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth and soft;"},{"kind":"text","text":"(S, Msb, K, KL, TA;) i. e."},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"Hazuna","text_ar":"حَزُنَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hazunato","text_ar":"حَزُنَتْ"},{"kind":"text","text":", (S, * K, * TA,) inf. n."},{"kind":"arabic","text_bw":"HuzuwnapN","text_ar":"حُزُونَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"sahula","text_ar":"سَهُلَ"},{"kind":"text","text":", (MA, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"suhuwlapN","text_ar":"سُهُولَةٌ"},{"kind":"text","text":", (MA, KL,) or"},{"kind":"arabic","text_bw":"sahaAlapN","text_ar":"سَهَالَةٌ"},{"kind":"text","text":", (K,) [but the former is the more common,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy."},{"kind":"text","text":"(MA, Msb, * K, * KL.) ―         -b3-  One says"},{"kind":"arabic","text_bw":"kalaAmN fiyhi suhuwlapN","text_ar":"كَلَامٌ فِيهِ سُهُولَةٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Language,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech, in which is smoothness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easiness"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Msb","K","KL","MA"]},{"entry_id":"n21076","headword_ar":"سَهْلٌ","root":"shl","body":[{"kind":"italic_en","text":"Smooth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, plain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth and soft:"},{"kind":"text","text":"(Msb:) or anything"},{"kind":"italic_en","text":"inclining to smoothness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"softness, plainness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"levelness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smoothness and softness;"},{"kind":"text","text":"(JK, M, K;)"},{"kind":"italic_en","text":"inclining to have little roughness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruggedness and hardness;"},{"kind":"text","text":"(JK, M, TA;) and ↓"},{"kind":"arabic","text_bw":"sahilN","text_ar":"سَهِلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (K.) You say"},{"kind":"arabic","text_bw":"A^aroDN saholapN","text_ar":"اَرْضٌ سَهْلَةٌ"},{"kind":"text","text":", [meaning the same as"},{"kind":"arabic","text_bw":"saholN","text_ar":"سَهْلٌ"},{"kind":"text","text":"used as a subst., expl. in what follows,] (S, Msb,)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HazonapN","text_ar":"حَزْنَةٌ"},{"kind":"text","text":". (TA.) See also 2, last sentence. ―         -b2-  Also"},{"kind":"italic_en","text":"Easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facile;"},{"kind":"text","text":"(MA, Mgh, KL;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"SaEobN","text_ar":"صَعْبٌ"},{"kind":"text","text":". (Mgh.) You say"},{"kind":"arabic","text_bw":"rajulN saholu Alxuluqi","text_ar":"رَجُلٌ سَهْلُ الخُلُقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A man easy of disposition"},{"kind":"text","text":"]: (S, Msb, * TA:) [and]"},{"kind":"arabic","text_bw":"saholu AlmaqaAdapi","text_ar":"سَهْلُ المَقَادَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"easy to be led"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"kalaAmN saholu AlmaA^oxa*i","text_ar":"كَلَامٌ سَهْلُ المَاْخَذِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Language easy in respect of the source of derivation"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"rajulN saholu","text_ar":"رَجُلٌ سَهْلُ"},{"kind":"arabic","text_bw":"Alwajohi","text_ar":"الوَجْهِ"},{"kind":"text","text":", (K, TA,) a phrase mentioned, but not explained, by Lh, (TA,) means"},{"kind":"italic_en","text":"A man having little flesh in the face,"},{"kind":"text","text":"(K, TA,) in the opinion of ISd: and [it is said that]"},{"kind":"arabic","text_bw":"saholu Alxad~ayoni","text_ar":"سَهْلُ الخَدَّيْنِ"},{"kind":"text","text":", in a description of the approved characteristics of the Prophet, means"},{"kind":"italic_en","text":"having expanded cheeks, not elevated in the balls thereof."},{"kind":"text","text":"(TA.)       -A2-  [As a subst.,]"},{"kind":"italic_en","text":"A smooth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, plain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth and soft, tract of land;"},{"kind":"text","text":"[generally meaning"},{"kind":"italic_en","text":"a soft tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plain;"},{"kind":"text","text":"] (IF, S, MA, Mgh, Msb, K, TA;) i. e."},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"jabalN","text_ar":"جَبَلٌ"},{"kind":"text","text":", (S, Msb,) or"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"HazonN","text_ar":"حَزْنٌ"},{"kind":"text","text":": (IF, Mgh, Msb, K, TA:) it is one of the nouns that are used as adv. ns. [of place]: (TA:) [for ex. you say,"},{"kind":"arabic","text_bw":"nazaluwA saholFA","text_ar":"نَزَلُوا سَهْلًا"},{"kind":"text","text":", (a phrase occurring in the TA,) meaning"},{"kind":"italic_en","text":"They alighted and abode in a"},{"kind":"arabic","text_bw":"shl","text_ar":"سهل"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"suhuwlN","text_ar":"سُهُولٌ"},{"kind":"text","text":"(MA, Msb, K) and"},{"kind":"arabic","text_bw":"suhuwlapN","text_ar":"سُهُولَةٌ"},{"kind":"text","text":"[of which latter an ex. occurs in a verse cited voce"},{"kind":"arabic","text_bw":"raA^osN","text_ar":"رَاْسٌ"},{"kind":"text","text":".] (MA.)       -A3-  Also The"},{"kind":"italic_en","text":"crow;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"raven, carrion-crow, rook,"},{"kind":"text","text":"&c.; syn."},{"kind":"arabic","text_bw":"guraAbN","text_ar":"غُرَابٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["Msb","S","K","TA","IF","Mgh","MA"]},{"entry_id":"n21077","headword_ar":"سَهِلٌ","root":"shl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saholN","text_ar":"سَهْلٌ"},{"kind":"text","text":", first sentence. ―         -b2-"},{"kind":"arabic","text_bw":"nahorN sahilN","text_ar":"نَهْرٌ سَهِلٌ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"A^aroDN sahilapN","text_ar":"اَرْضٌ سَهِلَةٌ"},{"kind":"text","text":", (K,) ["},{"kind":"italic_en","text":"A river,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a land,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"abounding with,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"what is termed"},{"kind":"arabic","text_bw":"siholapN","text_ar":"سِهْلَةٌ"},{"kind":"text","text":"[q. v.]. (S, K.)"}],"source_refs":["S","K"]}]}}