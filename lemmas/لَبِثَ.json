"role":"present_2mp","form":"تَلْبَثُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَلْبَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَلْبَث","in_corpus":true,"count":17,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَلْبَث","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَلْبَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَلْبَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَلْبَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَلْبَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَلْبَثُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْبَثُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَلْبَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"لَبِثْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"لَبِثْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَلْبَث","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَلْبَث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":65,"cross_references":{"qac":{"found":true,"lemma_key":"لَبِثَ","root":"لبث","pos":"V","occurrence_count":30},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n37459"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D8%A8%D9%90%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to remain, to stay","examples":[{"text":"وَلَبِثُوا فِي كَهْفِهِمْ ثَلَاثَ مِائَةٍ سِنِينَ وَازْدَادُوا تِسْعًا","english":"They had remained in their cave for three hundred years, adding nine."}]},{"pos":"verb","gloss":"to delay"},{"pos":"verb","gloss":"to tarry"},{"pos":"verb","gloss":"to pause"},{"pos":"verb","gloss":"to hesitate"},{"pos":"noun","gloss":"verbal noun of لَبِثَ (labiṯa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37459","headword_ar":"لَبِثَ","root":"lbv","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"labovN","text_ar":"لَبْثٌ"},{"kind":"text","text":"(which is contr. to analogy, because the inf. n. of an intrans. v. of the measure"},{"kind":"arabic","text_bw":"faEila","text_ar":"فَعِلَ"},{"kind":"text","text":"is, accord. to rule, of the measure"},{"kind":"arabic","text_bw":"faEalN","text_ar":"فَعَلٌ"},{"kind":"text","text":", S,) and"},{"kind":"arabic","text_bw":"labayvN","text_ar":"لَبَيثٌ"},{"kind":"text","text":"(agreeably with analogy, occurring in a verse of Jereer, S,) and"},{"kind":"arabic","text_bw":"labaAvN","text_ar":"لَبَاثٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"lubovN","text_ar":"لُبْثٌ"},{"kind":"text","text":"(which is the first form given by ISd) TA, [and the most common,]) and"},{"kind":"arabic","text_bw":"lubaAvN","text_ar":"لُبَاثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"labaAvapN","text_ar":"لَبَاثَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"labiyvapN","text_ar":"لَبِيثَةٌ"},{"kind":"text","text":", (K,) which are all contr. to analogy, (TA,) and"},{"kind":"arabic","text_bw":"lubovaAnN","text_ar":"لُبْثَانٌ"},{"kind":"text","text":", (ISd,) [this last, which is also contr. to analogy, is said in the TA, to be like"},{"kind":"arabic","text_bw":"sHbAn","text_ar":"سحبان"},{"kind":"text","text":", but this I suppose to be a mistake for"},{"kind":"arabic","text_bw":"suboHaAn","text_ar":"سُبْحَان"},{"kind":"text","text":",] or"},{"kind":"arabic","text_bw":"lubovN","text_ar":"لُبْثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"labaAvN","text_ar":"لَبَاثٌ"},{"kind":"text","text":"are substs., (Msb,)"},{"kind":"italic_en","text":"He tarried; paused; tarried and waited"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expected; was patient, and tarried and waited"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expected:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"he tarried; remained; stayed; stopped; paused;"},{"kind":"text","text":"(ISd, Msb;) as also ↓"},{"kind":"arabic","text_bw":"tlb~v","text_ar":"تلبّث","orth_type":"arrow"},{"kind":"text","text":"; (Msb;)"},{"kind":"arabic","text_bw":"bimakaAnK","text_ar":"بِمَكَانٍ"},{"kind":"italic_en","text":"in a place:"},{"kind":"text","text":"(ISd, Msb:) or ↓"},{"kind":"arabic","text_bw":"tlb~v","text_ar":"تلبّث","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he waited;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tawaq~afa","text_ar":"تَوَقَّفَ"},{"kind":"text","text":"(K) ―         -b2-"},{"kind":"arabic","text_bw":"mAlabiva A^ano faEala ka*aA waka*aA","text_ar":"مالَبِثَ اَنْ فَعَلَ كَذَا وَكَذَا"},{"kind":"italic_en","text":"He delayed not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was not slow, to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in doing, such and such things."},{"kind":"text","text":"(TA, and the other lexicons passim. ―         -b3-"},{"kind":"arabic","text_bw":"Ailobavo Eano fulaAnK","text_ar":"اِلْبَثْ عَنْ فُلَانٍ"},{"kind":"italic_en","text":"Wait for such a one, and leave him, until thy doing so shall manifest the error of his judgement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion."},{"kind":"text","text":"(A.)"}],"source_refs":["S","K","TA","ISd","Msb"]}]}}