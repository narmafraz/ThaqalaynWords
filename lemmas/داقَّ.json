","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n12805"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D9%82%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12805","headword_ar":"دَاقٌّ","root":"dq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daqaqapN","text_ar":"دَقَقَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AF%D8%A7%D9%82/","headword_ar":"دَاقَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=30722#a6903a","body_html":"<span>دَاقَ دَوْقاً ودَواقَةً ودُؤوقاً ودُؤوقَةً، بضمهِما: حَمُقَ، فهو دائِقٌ،</span><br><span>وـ المالُ: هَزُلَ،</span><br><span>وـ الفَصيلُ من اللَّبَنِ عن أُمِّهِ: عَدَلَ عنها حتى سَنِقَ،</span><br><span>وـ الطَّعامَ: ذاقَهُ.</span><br><span>ودِيقَتْ غَنَمُكَ، فهي مَديقَةٌ: أخَذَها الأبَى.</span><br><span>ومَداقُ الحَيَّةِ: مَجالُها.</span><br><span>ومَتاعٌ دائِقٌ تائِقٌ: لا ثَمَنَ لَهُ رُخْصاً وكَساداً.</span><br><span>والدَّوْقَةُ والدَّوْقانِيَّةُ: الفَسادُ، والحُمْقُ.</span><br><span>وأداقوا به: أحاطوا.</span><br><span>وانْداقَ بَطْنُهُ: انْتَفَخَ.</span>"}]}}