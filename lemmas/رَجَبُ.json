{"lemma":"رَجَبُ","slug":"رَجَبُ","root":"ر.ج.ب","root_slug":"ر-ج-ب","root_link":"/words/roots/ر-ج-ب","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["name"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14812","","n14814","n14815","n14816"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AC%D9%8E%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"name","gloss":"Rajab (the seventh month of the Islamic calendar)"}]},"etymology":{"source":"wiktextract","text":"From رَجَب (rajab, “respect”)."},"ipa":["/ra.d͡ʒab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14812","headword_ar":"رَجِبَ","root":"rjb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rajabN","text_ar":"رَجَبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afraid,"},{"kind":"text","text":"(K)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of, him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (TK.) ―         -b2-  And also, (K,) aor. and inf. n. as above; (TA;) and"},{"kind":"arabic","text_bw":"rajaba","text_ar":"رَجَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rajobN","text_ar":"رَجْبٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"He was ashamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bashful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy,"},{"kind":"text","text":"(K,)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with respect to him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (TK.)       -A2-"},{"kind":"arabic","text_bw":"rajibahu","text_ar":"رَجِبَهُ"},{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rajabN","text_ar":"رَجَبٌ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He feared him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"he revered him, venerated him, regarded him with awe,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"honoured him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magnified him;"},{"kind":"text","text":"(S, K;) namely, a man; [and in like manner,"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"rajabN","text_ar":"رَجَبٌ"},{"kind":"text","text":";] as also"},{"kind":"arabic","text_bw":"rajabahu","text_ar":"رَجَبَهُ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"rajobN","text_ar":"رَجْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rujuwbN","text_ar":"رُجُوبٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"rj~bhu","text_ar":"رجّبهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tarojiybN","text_ar":"تَرْجِيبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tarojibapN","text_ar":"تَرْجِبَةٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Arjbhu","text_ar":"ارجبهُ","orth_type":"arrow"},{"kind":"text","text":": (K:) or ↓"},{"kind":"arabic","text_bw":"rj~bhu","text_ar":"رجّبهُ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"tarojiybN","text_ar":"تَرْجِيبٌ"},{"kind":"text","text":", (S,) signifies [simply]"},{"kind":"italic_en","text":"he honoured him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magnified him."},{"kind":"text","text":"(S, * Msb.) You say,"},{"kind":"arabic","text_bw":"daxalotu faraH~aba","text_ar":"دَخَلْتُ فَرَحَّبَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"biY waraj~abaniY","text_ar":"بِى وَرَجَّبَنِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I entered, and he welcomed me with the greeting of"},{"kind":"arabic","text_bw":"maroHabFA","text_ar":"مَرْحَبًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"and treated me with honour"},{"kind":"text","text":"]. (A.) And a poet says,"},{"kind":"quote","text":"A^aHomadu rab~iY faraqFA waA^arojabuho"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"I praise my Lord with fear,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and magnify Him."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"rajaba","text_ar":"رَجَبَ"},{"kind":"text","text":"said of a branch, or twig,"},{"kind":"italic_en","text":"It came forth singly."},{"kind":"text","text":"(K. [Perhaps from"},{"kind":"arabic","text_bw":"rajabN","text_ar":"رَجَبٌ"},{"kind":"text","text":"as the name of a month which is called “ Rejeb the separate. ”])       -A4-"},{"kind":"arabic","text_bw":"rajabahu biqawolK say~iY'K","text_ar":"رَجَبَهُ بِقَوْلٍ سَيِّىءٍ"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"rajamahu","text_ar":"رَجَمَهُ"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"(K,) i. e."},{"kind":"italic_en","text":"He reviled him with a foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil, saying."},{"kind":"text","text":"(Abu-l-'Omeythil, TA.)"}],"source_refs":["K","TA","S","A","Msb"]},{"entry_id":"n14814","headword_ar":"رُجْبٌ","root":"rjb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"part between the rib and the"},{"kind":"arabic","text_bw":"qaS~","text_ar":"قَصّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sternum"},{"kind":"text","text":"]. (K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"A^arojaAbN","text_ar":"اَرْجَابٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14815","headword_ar":"رِجْبٌ","root":"rjb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^arojaAbN","text_ar":"اَرْجَابٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14816","headword_ar":"رَجَبٌ","root":"rjb","body":[{"kind":"italic_en","text":"One of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Arabian"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"months;"},{"kind":"text","text":"(Msb;) [namely,"},{"kind":"italic_en","text":"the seventh thereof;"},{"kind":"text","text":"] so called because of the honour in which it was held in the Time of Ignorance, (S, A, * K, *) inasmuch as war, or fighting, during it was held unlawful: (S:) in a trad., (TA,) it is called"},{"kind":"arabic","text_bw":"rajabu muDara","text_ar":"رَجَبُ مُضَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Rejeb of Mudar"},{"kind":"text","text":"], because Mudar most honoured it: (S, TA:) and it is further distinguished as being between"},{"kind":"arabic","text_bw":"jamaAdaY","text_ar":"جَمَادَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$aEobaAn","text_ar":"شَعْبَان"},{"kind":"text","text":", to show that what is meant by it is not what the [pagan] Arabs called"},{"kind":"arabic","text_bw":"rjb","text_ar":"رجب"},{"kind":"text","text":"according to the computation founded upon postponement; for they used to postpone it from month to month: (TA:) [it is also called"},{"kind":"arabic","text_bw":"rajabN Alfarodu","text_ar":"رَجَبٌ الفَرْدُ"},{"kind":"italic_en","text":"Rejeb the separate;"},{"kind":"text","text":"because it is the only sacred month that is not preceded nor followed by another sacred month; the other sacred months being"},{"kind":"arabic","text_bw":"AlmuHar~amu","text_ar":"المُحَرَّمُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*uw AlqaEodapi","text_ar":"ذُو القَعْدَةِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*uw","text_ar":"ذُو"},{"kind":"arabic","text_bw":"AlHaj~api","text_ar":"الحَجَّةِ"},{"kind":"text","text":":] the pl. is"},{"kind":"arabic","text_bw":"A^irojaAbN","text_ar":"اِرْجَابٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"A^arojibapN","text_ar":"اَرْجِبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^arojubN","text_ar":"اَرْجُبٌ"},{"kind":"text","text":"[all pls. of pauc.] (Msb) and"},{"kind":"arabic","text_bw":"rujuwbN","text_ar":"رُجُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rijaAbN","text_ar":"رِجَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rajabaAtN","text_ar":"رَجَبَاتٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"rajuwbN","text_ar":"رَجُوبٌ"},{"kind":"text","text":"[or rather this last is a quasi-pl. n.] (TA) and [pl. pl.]"},{"kind":"arabic","text_bw":"A^araAjibu","text_ar":"اَرَاجِبُ"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"A^arojubN","text_ar":"اَرْجُبٌ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"A^araAjiybu","text_ar":"اَرَاجِيبُ"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"A^arojaAbN","text_ar":"اَرْجَابٌ"},{"kind":"text","text":"]. (Msb.) The dual,"},{"kind":"arabic","text_bw":"rajabaAni","text_ar":"رَجَبَانِ"},{"kind":"text","text":", (S, Msb,) or"},{"kind":"arabic","text_bw":"Alr~ajabaAni","text_ar":"الرَّجَبَانِ"},{"kind":"text","text":", (A,) ["},{"kind":"italic_en","text":"The two Rejebs"},{"kind":"text","text":"] is applied to ["},{"kind":"italic_en","text":"the two months"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rajabN","text_ar":"رَجَبٌ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"$aEobaAnu","text_ar":"شَعْبَانُ"},{"kind":"text","text":", (S, A, Msb,) by the attribution of predominance to the former. (Msb.)       -A2-  See also"},{"kind":"arabic","text_bw":"A^arojaAbN","text_ar":"اَرْجَابٌ"},{"kind":"text","text":"."}],"source_refs":["S","TA","Msb","K","A"]}]}}