s"},{"role":"present_1mp","form":"نَضْفُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضْفُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n25917","n25918"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D9%81%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25917","headword_ar":"ضَفَا","root":"Dfw","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaDofuw","text_ar":"يَضْفُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"DafowN","text_ar":"ضَفْوٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"Dafuw~N","text_ar":"ضَفُوٌّ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, and a garment, S, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, complete, full, ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without deficiency."},{"kind":"text","text":"(S, Msb, K. *) ―         -b2-  And"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, much in quantity;"},{"kind":"text","text":"(S, K, * TA;) said of property, or property consisting in cattle, (S, TA,) and of hair, and of wool. (TA.) [Hence,] one says,"},{"kind":"arabic","text_bw":"Dafato Ealayohi Aln~iEomapu","text_ar":"ضَفَتْ عَلَيْهِ النِّعْمَةُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"raf~ato","text_ar":"رَفَّتْ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Wealth became abundantly bestowed upon him"},{"kind":"text","text":"]. (M in art."},{"kind":"arabic","text_bw":"rf","text_ar":"رف"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"DafaA AlEayo$u","text_ar":"ضَفَا العَيْشُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Ait~asaEa","text_ar":"اِتَّسَعَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The means of subsistence became ample"},{"kind":"text","text":"]. (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"DafaA AlHawoDu","text_ar":"ضَفَا الحَوْضُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"DafowN","text_ar":"ضَفْوٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"The watering-trough overflowed"},{"kind":"text","text":"(K, * TA)"},{"kind":"italic_en","text":"by reason of its fulness."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"DafiYa","text_ar":"ضَفِىَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"became poor:"},{"kind":"text","text":"mentioned by Az in art."},{"kind":"arabic","text_bw":"Dyq","text_ar":"ضيق"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n25918","headword_ar":"ضَفًا","root":"Dfw","body":[{"kind":"italic_en","text":"A side:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DafawaAhu","text_ar":"ضَفَوَاهُ"},{"kind":"italic_en","text":"his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, two sides."},{"kind":"text","text":"(K.) ["},{"kind":"arabic","text_bw":"Daf~apN","text_ar":"ضَفَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Dif~apN","text_ar":"ضِفَّةٌ"},{"kind":"text","text":", also, have a similar meaning.]"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D9%81%D8%A7/","headword_ar":"ضفا","entries":[{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=2685#86f263","body_html":"<span class=\"title1\">ض ف ا</span><span>: (الضَّفْوُ) السُّبُوغُ. وَقَدْ (ضَفَا) الشَّيْءُ مِنْ بَابِ عَدَا وَسَمَا. وَثَوْبٌ (ضَافٍ) أَيْ سَابِغٌ. </span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=2685#047ee1","body_html":"<span class=\"title1\">[ضفا]</span><span> الضَفْوُ: السُبوغُ. يقال: ضَفا الشئ يضفو. وثوب ضاف، أي سابغٌ. قال بشر : لياليَ لا أطاوع من نَهاني * ويَضْفو تحت كَعْبَيَّ الإزارُ وفلان في ضَفْوَةٍ من عيشه. * وضَفا المال: كثُر. قال الاخطل : إذا الهَدَفُ المِعْزالُ صَوَّبَ رَأْسَهُ * وأعجبه ضفو من الثلة الخطل =</span><span> </span><a></a><a></a><span>ورجل ضافي الرأس، أي كثير شعرَ الرأس.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=2685#f2f791","body_html":"<p>ضفا: ضفا مالُه يَضْفُو ضَفْواً وضُفُوّاً: كثر. وضَفا الشَّعَرُ</p><p>والصُّوفُ يَضْفُو ضَفْواً وضُفُوّاً: كَثُرَ وطالَ. والضَّفْوُ: السَّعة</p><p>والخَيْر؛ قال أَبو ذؤَيب ونسبه الجوهري للأَخطل وغلطه ابن بري في ذلك وقال هو</p><p>لأَبي ذؤَيب:</p><p>إذا الهَدَفُ المِعْزالُ صَوَّبَ رأْسَه،</p><p>وأَعْجَبَه ضَفْوٌ من الثَّلَّةِ الخُطْلِ</p><p>(* قوله «المعزال» هو باللام في الأصل والتهذيب والصحاح، وقال الصاغاني:</p><p>الرواية المعزاب).</p><p>وشَعَرٌ ضافٍ وذَنَبٌ ضافٍ؛ قال الشاعر:</p><p>بضافٍ فُوَيْقَ الأَرضِ ليس بأَعْزَلِ</p><p>(* هذا البيت من معلقة امرئ القيس وصدره:</p><p>ضَليعٍ، إِذا استدبرتَه ، سدّ فرجَه).</p><p>والضَّفْوُ: السُّبُوغُ. ضَفا الشيءُ يَضْفُو. وفَرَسٌ</p><p>ضافي السَّبِيبِ: سابِغُه. وثَوْبٌ ضافٍ أَي سابِغٌ؛ قال بشر:</p><p>لَياليَ لا أُطاوِعُ مَنْ نَهاني،</p><p>ويَضْفُو تحتَ كَعْبَيَّ الإزارُ</p><p>ورجلٌ ضافي الرأْسِ. كثيرُ شَعَرِ الرأْسِ، وفلانٌ ضافي الفَضْلِ على</p><p>المَثَلِ. ودِيمةٌ</p><p>ضافِية وهي تَضْفُو ضَفْواً: تُخْصِبُ منها الأَرضُ. وهو في ضَفْوٍ من</p><p>عَيْشه وضَفْوةٍ من عيشِه أَي سَعةٍ. وضَفا الماءُ يَضْفُو: فاضَ؛ أَنشد</p><p>ابن الأَعرابي:</p><p>وماكِدٍ تَمْأَدُه من بَحْرِه</p><p>يَضْفُو، ويُبْدي تارةً عن قَعْرِه</p><p>تَمْأَدُه أَي تأْخُذُه في ذلك الوقت؛ يقول: يَمْتَلِئُ فتَشْرَبُ</p><p>الإبلِ ماءَه حتى يَظْهَرَ قَعْرُهُ. وضَفا الحَوْضُ يَضْفُو إذا فاضَ من</p><p>امتِلائِه.</p><p>والضَّفا: جانِبُ الشيء، وهما ضَفَواهُ أَي جانِباهُ.</p>"}]}}