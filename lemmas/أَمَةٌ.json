{"lemma": "أَمَةٌ", "slug": "أَمَةٌ", "root": "#.م.#", "root_slug": "_-م-_", "root_link": "/words/roots/_-م-_", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": true, "lemma_key": "أَمَة", "root": "أمو", "pos": "N", "occurrence_count": 2}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 0}, "lanes": {"found": true, "entry_ids": ["n1162", "n1172", "n1173", "n1174", "n1281", "n1288"], "search_url": "https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%8E%D8%A9%D9%8C"}}, "translations": {"en": "to aim at", "fa": "هدف گرفتن", "ur": "نشانہ لینا", "tr": "yönelmek", "id": "menuju", "bn": "লক্ষ্য করা", "es": "dirigirse a", "fr": "se diriger vers", "de": "sich wenden", "ru": "стремиться", "zh": "朝向"}, "definition": null, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n1162", "headword_ar": "اَمَّهُ", "root": "Am", "body": [{"kind": "text", "text": ", (T, S, M, &c.,) aor"}, {"kind": "text", "text": ", (T, M, Msb,) inf. n."}, {"kind": "arabic", "text_bw": "A^am~N", "text_ar": "اَمٌّ"}, {"kind": "text", "text": ", (T, S, M, Msb,)"}, {"kind": "italic_en", "text": "He tended, repaired, betook himself,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "directed his course, to,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "towards, him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it; aimed at, sought, endeavoured after, pursued,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "endeavoured to reach"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "attain"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "obtain, him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it; intended it,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "purposed it;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "qaSadahu", "text_ar": "قَصَدَهُ"}, {"kind": "text", "text": ", (Lth, T, S, M, Mgh, Msb, K,) and"}, {"kind": "arabic", "text_bw": "tawax~aAhu", "text_ar": "تَوَخَّاهُ"}, {"kind": "text", "text": ", (T,) and"}, {"kind": "arabic", "text_bw": "taEam~adahu", "text_ar": "تَعَمَّدَهُ"}, {"kind": "text", "text": ", (Mgh,) and"}, {"kind": "arabic", "text_bw": "tawaj~aha A_ilayohi", "text_ar": "تَوَجَّهَ اـِلَيْهِ"}, {"kind": "text", "text": "; (TA;) as also ↓"}, {"kind": "arabic", "text_bw": "A^am~amahu", "text_ar": "اَمَّمَهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", and ↓"}, {"kind": "arabic", "text_bw": "tA^m~mhu", "text_ar": "تامّمهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (T, S, M, Mgh, Msb, K,) and ↓"}, {"kind": "arabic", "text_bw": "Ay^tm~hu", "text_ar": "ايتمّهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (M, K,) and ↓"}, {"kind": "arabic", "text_bw": "yam~am~hu", "text_ar": "يَمَّمّهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (T, M, K,) and ↓"}, {"kind": "arabic", "text_bw": "tayam~amahu", "text_ar": "تَيَمَّمَهُ", "orth_type": "arrow"}, {"kind": "text", "text": "; (T, M, Mgh, K;) the last two being formed by substitution [of"}, {"kind": "arabic", "text_bw": "Y", "text_ar": "ى"}, {"kind": "text", "text": "for"}, {"kind": "arabic", "text_bw": "A^", "text_ar": "ا"}, {"kind": "text", "text": "]. (M.) Hence,"}, {"kind": "arabic", "text_bw": "yaAAall~`hu A^um~anaA bixayorK", "text_ar": "يَااَللّٰهُ اُمَّنَا بِخَيْرٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "O God, bring us good"}, {"kind": "text", "text": "]. (JK in art."}, {"kind": "arabic", "text_bw": "Alh", "text_ar": "اله"}, {"kind": "text", "text": ", and Bd in iii. 25.) And"}, {"kind": "arabic", "text_bw": "laA^am~a maA huwa", "text_ar": "لَاَمَّ مَا هُوَ"}, {"kind": "text", "text": ", occurring in a trad., meaning"}, {"kind": "italic_en", "text": "He has indeed betaken himself to,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pursued, the right way:"}, {"kind": "text", "text": "or it is used in a pass. sense, as meaning"}, {"kind": "italic_en", "text": "he is in the way which ought to be pursued."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "rasuwla All~`hi", "text_ar": "رَسُولَ اللّٰهِ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "AnoTalaqotu A^ataA^am~amu", "text_ar": "انْطَلَقْتُ اَتَاَمَّمُ", "orth_type": "arrow"}, {"kind": "text", "text": ", in another trad.,"}, {"kind": "italic_en", "text": "I went away, betaking myself to the Apostle of God."}, {"kind": "text", "text": "(TA.) Hence, also,"}, {"kind": "arabic", "text_bw": "AlS~aEiyda lilS~alaAhi", "text_ar": "الصَّعِيدَ لِلصَّلَاهِ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "tayam~ama", "text_ar": "تَيَمَّمَ", "orth_type": "arrow"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He betook himself to dust,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pure dust,"}, {"kind": "text", "text": "to wipe his face and his hands and arms therewith,"}, {"kind": "italic_en", "text": "for prayer"}, {"kind": "text", "text": "]: (T, * M, * Mgh, TA:) as in the Kur iv. 46 and v. 9: (ISk, M, TA:) whence"}, {"kind": "arabic", "text_bw": "Al~at~ayam~umu", "text_ar": "الَّتَّيَمُّمُ"}, {"kind": "text", "text": "as meaning"}, {"kind": "italic_en", "text": "the wiping the face and the hands and arms with dust;"}, {"kind": "text", "text": "(ISk, T, * M, * Mgh, TA;) i. e."}, {"kind": "italic_en", "text": "the performing the act termed"}, {"kind": "arabic", "text_bw": "tawaD~uw^N", "text_ar": "تَوَضُّوٌ"}, {"kind": "italic_en", "text": "with dust:"}, {"kind": "text", "text": "formed by substitution [of"}, {"kind": "arabic", "text_bw": "Y", "text_ar": "ى"}, {"kind": "text", "text": "for"}, {"kind": "arabic", "text_bw": "A=", "text_ar": "ا="}, {"kind": "text", "text": "]: (M, K:) originally"}, {"kind": "arabic", "text_bw": "Alt~aA^am~umu", "text_ar": "التَّاَمُّمُ"}, {"kind": "text", "text": ". (K.) ―         -b2-  See also 8.       -A2-"}, {"kind": "arabic", "text_bw": "A^am~ahu", "text_ar": "اَمَّهُ"}, {"kind": "text", "text": ", (S, M, Mgh, &c.,) aor."}, {"kind": "text", "text": ", (M, Mgh,) inf. n."}, {"kind": "arabic", "text_bw": "A^am~N", "text_ar": "اَمٌّ"}, {"kind": "text", "text": ", (M, Mgh, K,)"}, {"kind": "italic_en", "text": "He broke his head, so as to cleave the skin,"}, {"kind": "text", "text": "(S, Msb,)"}, {"kind": "italic_en", "text": "inflicting a wound such as is termed"}, {"kind": "arabic", "text_bw": "A=m~ap", "text_ar": "ا=مَّة"}, {"kind": "text", "text": "[q. v.]; (S;) [i. e.]"}, {"kind": "italic_en", "text": "he struck,"}, {"kind": "text", "text": "(M, Mgh, K,) or"}, {"kind": "italic_en", "text": "wounded,"}, {"kind": "text", "text": "(M, K,) the"}, {"kind": "arabic", "text_bw": "A^um~", "text_ar": "اُمّ"}, {"kind": "text", "text": "[q. v.]"}, {"kind": "italic_en", "text": "of his head,"}, {"kind": "text", "text": "(M, Mgh, K,) with a staff, or stick. (Mgh.)       -A3-"}, {"kind": "arabic", "text_bw": "A^am~ahumo", "text_ar": "اَمَّهُمْ"}, {"kind": "text", "text": "(S, M, K) and"}, {"kind": "arabic", "text_bw": "A^am~a bihimo", "text_ar": "اَمَّ بِهِمْ"}, {"kind": "text", "text": ", (M, K,) [aor."}, {"kind": "text", "text": ",] inf. n."}, {"kind": "arabic", "text_bw": "A_imaAmapN", "text_ar": "اـِمَامَةٌ"}, {"kind": "text", "text": ", (S, [but in the M and K it seems to be indicated that this is a simple subst.,])"}, {"kind": "italic_en", "text": "He preceded them; went before them; took precedence of them;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "led them, so as to serve as an example,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "object of imitation;"}, {"kind": "text", "text": "syn."}], "source_refs": ["T", "M", "Msb", "S", "Lth", "Mgh", "K", "ISk", "TA"]}, {"entry_id": "n1172", "headword_ar": "اَمَّةٌ", "root": "Am", "body": [{"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "A=m~apN", "text_ar": "ا=مَّةٌ"}, {"kind": "text", "text": "."}], "source_refs": []}, {"entry_id": "n1173", "headword_ar": "اُمَّةٌ", "root": "Am", "body": [{"kind": "italic_en", "text": "A way, course, mode,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "manner, of acting,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "conduct,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like;"}, {"kind": "text", "text": "(AZ, S;) as also ↓"}, {"kind": "arabic", "text_bw": "A_im~apN", "text_ar": "اـِمَّةٌ", "orth_type": "arrow"}, {"kind": "text", "text": ": (AZ, S, K:) Fr assigns this meaning to the latter, and that next following to the former: (T:)"}, {"kind": "italic_en", "text": "a way, course,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rule, of life,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "conduct;"}, {"kind": "text", "text": "(Fr, T, M, K;) as also ↓"}, {"kind": "arabic", "text_bw": "A_im~apN", "text_ar": "اـِمَّةٌ", "orth_type": "arrow"}, {"kind": "text", "text": ". (M, K.) ―         -b2-"}, {"kind": "italic_en", "text": "Religion;"}, {"kind": "text", "text": "as also ↓"}, {"kind": "arabic", "text_bw": "A_im~apN", "text_ar": "اـِمَّةٌ", "orth_type": "arrow"}, {"kind": "text", "text": ": (AZ, S, M, K: [one of the words by which this meaning is expressed in the M and K is"}, {"kind": "arabic", "text_bw": "$iroEap", "text_ar": "شِرْعَة"}, {"kind": "text", "text": "; for which Golius found in the K"}, {"kind": "arabic", "text_bw": "srEp", "text_ar": "سرعة"}, {"kind": "text", "text": ":])"}, {"kind": "italic_en", "text": "one course, which people follow, in religion."}, {"kind": "text", "text": "(T.) You say,"}, {"kind": "arabic", "text_bw": "fulaAnN laA A^um~apa lahu", "text_ar": "فُلَانٌ لَا اُمَّةَ لَهُ"}, {"kind": "italic_en", "text": "Such a one has no religion; no religious persuasion."}, {"kind": "text", "text": "(S.) And a poet says,"}, {"kind": "quote", "text": "wahalo yasotawiY *uw A^um~apK wakafuwru"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "And are one who has religion and one who is an infidel equal?"}, {"kind": "text", "text": "]. (S.) ―         -b3-"}, {"kind": "italic_en", "text": "Obedience"}, {"kind": "text", "text": "[app."}, {"kind": "italic_en", "text": "to God"}, {"kind": "text", "text": "]. (T, M, K.)       -A2-  The"}, {"kind": "italic_en", "text": "people of a"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "particular"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "religion:"}, {"kind": "text", "text": "(Akh, S:)"}, {"kind": "italic_en", "text": "a people to whom an apostle is sent,"}, {"kind": "text", "text": "(M, K,)"}, {"kind": "italic_en", "text": "unbelievers and believers;"}, {"kind": "text", "text": "such being called his"}, {"kind": "arabic", "text_bw": "A^um~ap", "text_ar": "اُمَّة"}, {"kind": "text", "text": ": (M:)"}, {"kind": "italic_en", "text": "any people called after a prophet"}, {"kind": "text", "text": "are said to be his"}, {"kind": "arabic", "text_bw": "A^um~ap", "text_ar": "اُمَّة"}, {"kind": "text", "text": ": (Lth, T:) the"}, {"kind": "italic_en", "text": "followers of the prophet:"}, {"kind": "text", "text": "pl."}, {"kind": "arabic", "text_bw": "A^umamN", "text_ar": "اُمَمٌ"}, {"kind": "text", "text": ". (T, Msb.) It is said in the Kur [ii. 209],"}, {"kind": "arabic", "text_bw": "kaAna Aln~aAsu A^um~apK wAHidapF", "text_ar": "كَانَ النَّاسُ اُمَّةٍ واحِدَةً"}, {"kind": "text", "text": ", meaning"}, {"kind": "italic_en", "text": "Mankind was"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "a people"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "of one religion."}, {"kind": "text", "text": "(Zj, T, TA.) ―         -b2-"}, {"kind": "italic_en", "text": "A nation; a people; a race; a tribe, distinct body,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "family;"}, {"kind": "text", "text": "(Lth, T, M, K;) of mankind; (Lth, T;) or of any living beings; as also ↓"}, {"kind": "arabic", "text_bw": "A^um~N", "text_ar": "اُمٌّ", "orth_type": "arrow"}, {"kind": "text", "text": ": (M, K:)"}, {"kind": "italic_en", "text": "a collective body"}, {"kind": "text", "text": "[of men or other living beings]; (T, S;) a sing. word with a pl. meaning: (Akh, S:)"}, {"kind": "italic_en", "text": "a kind, genus,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "generical class,"}, {"kind": "text", "text": "(T, S, M, K,)"}, {"kind": "italic_en", "text": "by itself,"}, {"kind": "text", "text": "(T,) of any animals, or living beings, (T, S, M, TA,) others than the sons of Adam, (T,) as of dogs, (T, S, M,) and of other beasts, and of birds; (T, M, * TA;) as also ↓"}, {"kind": "arabic", "text_bw": "A^um~N", "text_ar": "اُمٌّ", "orth_type": "arrow"}, {"kind": "text", "text": "; (M, K;) pl. of the former"}, {"kind": "arabic", "text_bw": "A^umamN", "text_ar": "اُمَمٌ"}, {"kind": "text", "text": "; (S, M;) which occurs in a trad. as relating to dogs; (S;) and in the Kur vi. 38, as relating to beasts and birds. (T, M, * TA.) ―         -b3-  A man's"}, {"kind": "italic_en", "text": "people, community, tribe, kinsfolk,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "party;"}, {"kind": "text", "text": "(M, K, TA;) his"}, {"kind": "italic_en", "text": "company."}, {"kind": "text", "text": "(TA.) ―         -b4-"}, {"kind": "italic_en", "text": "A generation of men;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "people of one time:"}, {"kind": "text", "text": "pl."}, {"kind": "arabic", "text_bw": "A^umamN", "text_ar": "اُمَمٌ"}, {"kind": "text", "text": ": as in the saying,"}, {"kind": "arabic", "text_bw": "qado maDato A^umamN", "text_ar": "قَدْ مَضَتْ اُمَمٌ"}, {"kind": "italic_en", "text": "Generations of men have passed away."}, {"kind": "text", "text": "(T.) ―         -b5-  The"}, {"kind": "italic_en", "text": "creatures"}, {"kind": "text", "text": "of God. (M, K.) You say,"}, {"kind": "arabic", "text_bw": "maA raA^ayotu mino A^um~api All~`hi", "text_ar": "مَا رَاَيْتُ مِنْ اُمَّةِ اللّٰهِ"}, {"kind": "arabic", "text_bw": "A^aHosana minohu", "text_ar": "اَحْسَنَ مِنْهُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "I have not seen, of the creatures of God, one more beautiful than he"}, {"kind": "text", "text": "]. (M.)       -A3-"}, {"kind": "italic_en", "text": "I. q."}, {"kind": "arabic", "text_bw": "A_imaAmN", "text_ar": "اـِمَامٌ"}, {"kind": "text", "text": "; (T, M, K;) accord. to A 'Obeyd, applied in this sense to Abraham, in the Kur xvi. 121. (T.) ―         -b2-"}, {"kind": "italic_en", "text": "A righteous man who is an object of imitation."}, {"kind": "text", "text": "(T.) ―         -b3-"}, {"kind": "italic_en", "text": "One who follows the true religion, holding,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "doing, what is different from,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "contrary to, all other religions:"}, {"kind": "text", "text": "(M, K:) [said to be] thus applied to Abraham, ubi suprà. (M.) ―         -b4-"}, {"kind": "italic_en", "text": "One who is known for goodness:"}, {"kind": "text", "text": "(Fr, T:) and so explained by Ibn-Mes'ood as applied to Abraham: (TA:) or, so applied, it has the signification next following: (TA:)"}, {"kind": "italic_en", "text": "a man combining all kinds of good qualities:"}, {"kind": "text", "text": "(T, M, K:) or, as some say,"}, {"kind": "italic_en", "text": "repaired to:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "imitated."}, {"kind": "text", "text": "(Bd:) ―         -b5-"}, {"kind": "italic_en", "text": "A learned man:"}, {"kind": "text", "text": "(T, M, K:)"}, {"kind": "italic_en", "text": "one who has no equal:"}, {"kind": "text", "text": "(T:) the"}, {"kind": "italic_en", "text": "learned man of his age,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "time, who is singular in his learning:"}, {"kind": "text", "text": "(Msb:) and"}, {"kind": "italic_en", "text": "one who is alone in respect of religion."}, {"kind": "text", "text": "(T.)       -A4-  See also"}, {"kind": "arabic", "text_bw": "A_um~N", "text_ar": "اـُمٌّ"}, {"kind": "text", "text": ", first sentence. Hence,"}, {"kind": "arabic", "text_bw": "yaAA^um~ati", "text_ar": "يَااُمَّتِ"}, {"kind": "text", "text": "which see in the same paragraph.       -A5-  The"}, {"kind": "italic_en", "text": "stature of a man; tallness, and beauty of stature;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "justness of stature;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "qaAmapN", "text_ar": "قَامَةٌ"}, {"kind": "text", "text": "; (T, S, M, Msb, K;) and"}, {"kind": "arabic", "text_bw": "$aTaATF", "text_ar": "شَطَاطً"}, {"kind": "text", "text": ": (M, TA: [in the K, the signification of"}, {"kind": "arabic", "text_bw": "na$aATN", "text_ar": "نَشَاطٌ"}, {"kind": "text", "text": "is assigned to it; but this is evidently a mistake for"}, {"kind": "arabic", "text_bw": "$aTaATK", "text_ar": "شَطَاطٍ"}, {"kind": "text", "text": "; for the next three significations before the former of these words in the K are the same as the next three before the latter of them in the M; and the next five after the former word in the K are the same as the next five after the latter in the M, with only this difference, that one of these five is the first of them in the M and the third of them in the K:]) pl."}, {"kind": "arabic", "text_bw": "A^umamN", "text_ar": "اُمَمٌ"}, {"kind": "text", "text": ". (T, S, M. *) You say,"}, {"kind": "arabic", "text_bw": "A_in~ahu", "text_ar": "اـِنَّهُ"}, {"kind": "arabic", "text_bw": "laHasanu AlA^um~api", "text_ar": "لَحَسَنُ الاُمَّةِ"}, {"kind": "text", "text": ", i. e."}, {"kind": "arabic", "text_bw": "Al$~aTaATi", "text_ar": "الشَّطَاطِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Verily he is beautiful in justness of stature"}, {"kind": "text", "text": "]. (M.) And El-Aashà says,"}, {"kind": "quote", "text": "HisaAnu Alwujuwhi TiwaAlu AlA^umamo"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Beautiful in respect of the faces,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "tall in respect of the statures."}, {"kind": "text", "text": "(T, S, M. * [In the last,"}, {"kind": "arabic", "text_bw": "byDu", "text_ar": "بيضُ"}, {"kind": "arabic", "text_bw": "Alwujuwhi", "text_ar": "الوُجُوهِ"}, {"kind": "text", "text": ".]) ―         -b2-  The"}, {"kind": "italic_en", "text": "face."}, {"kind": "text", "text": "(T, M, K.) ―         -b3-"}, {"kind": "arabic", "text_bw": "A^um~apu AlA=wajohi", "text_ar": "اُمَّةُ الا=وَجْهِ"}, {"kind": "italic_en", "text": "The form of the face:"}, {"kind": "text", "text": "(AZ, T:) or"}, {"kind": "italic_en", "text": "the principal part thereof;"}, {"kind": "text", "text": "(M, K;)"}, {"kind": "italic_en", "text": "the part thereof in which beauty is usually known to lie."}, {"kind": "text", "text": "(M) You say,"}, {"kind": "arabic", "text_bw": "A_in~ahu laHasanu A^um~api AlA=wajohi", "text_ar": "اـِنَّهُ لَحَسَنُ اُمَّةِ الا=وَجْهِ"}, {"kind": "italic_en", "text": "Verily he is beautiful in the form of the face:"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "A_in~ahu lA=aqabiyHu A^um~api AlA=wajohi", "text_ar": "اـِنَّهُ لا=َقَبِيحُ اُمَّةِ الا=وَجْهِ"}, {"kind": "italic_en", "text": "verily he is ugly in the form of the face."}, {"kind": "text", "text": "(AZ, T.) ―         -b4-"}, {"kind": "arabic", "text_bw": "A^um~apu AlT~ariyqi", "text_ar": "اُمَّةُ الطَّرِيقِ"}, {"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "A^um~N", "text_ar": "اُمٌّ"}, {"kind": "text", "text": ".       -A6-"}, {"kind": "italic_en", "text": "A time; a period of time; a while."}, {"kind": "text", "text": "(T, S, M, K.) So in the Kur [xii. 45],"}, {"kind": "arabic", "text_bw": "waAd~akara baEoda A^um~apK", "text_ar": "وَادَّكَرَ بَعْدَ اُمَّةٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "And he remembered,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became reminded, after a time"}, {"kind": "text", "text": "]: (S, M:) or,"}, {"kind": "italic_en", "text": "after a long period of time:"}, {"kind": "text", "text": "but some read ↓"}, {"kind": "arabic", "text_bw": "A_im~apK", "text_ar": "اـِمَّةٍ", "orth_type": "arrow"}, {"kind": "text", "text": ", i. e., after"}, {"kind": "italic_en", "text": "favour"}, {"kind": "text", "text": "had been shown him, in his escape: and some read"}, {"kind": "arabic", "text_bw": "A^amapK", "text_ar": "اَمَةٍ"}, {"kind": "text", "text": ", i. e., forgetting. (Bd.) And so in the same [xi. 11],"}, {"kind": "arabic", "text_bw": "walay^ino A^x~aronaA Eanohumu AlEa*aAba", "text_ar": "وَلَيِنْ اخَّرْنَا عَنْهُمُ العَذَابَ"}, {"kind": "arabic", "text_bw": "A_ilA=aY A^um~apK maEoduwdap", "text_ar": "اـِلا=َى اُمَّةٍ مَعْدُودَة"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "And verily, if we kept back from them the punishment"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "until a short period of time."}, {"kind": "text", "text": "(S * Bd.)"}], "source_refs": ["AZ", "S", "K", "T", "Akh", "M", "Lth", "TA", "Fr", "Bd", "Msb"]}, {"entry_id": "n1174", "headword_ar": "اـِمَّةٌ", "root": "Am", "body": [{"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "A^um~apN", "text_ar": "اُمَّةٌ"}, {"kind": "text", "text": ", in three places; first and second sentences. ―         -b2-"}, {"kind": "italic_en", "text": "I. q."}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "A_imaAmapN", "text_ar": "اـِمَامَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(K) [i. e. The"}, {"kind": "italic_en", "text": "office of"}, {"kind": "arabic", "text_bw": "A_imaAm", "text_ar": "اـِمَام"}, {"kind": "text", "text": ", q. v. : or] the"}, {"kind": "italic_en", "text": "acting as,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "performing the office of,"}, {"kind": "arabic", "text_bw": "A_imaAm", "text_ar": "اـِمَام"}, {"kind": "text", "text": ": (T in explanation of"}, {"kind": "arabic", "text_bw": "A_im~apN", "text_ar": "اـِمَّةٌ"}, {"kind": "text", "text": ", and M and Msb in explanation of"}, {"kind": "arabic", "text_bw": "A_imaAmapN", "text_ar": "اـِمَامَةٌ"}, {"kind": "text", "text": ":) and the"}, {"kind": "italic_en", "text": "mode,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "manner, of performing that office."}, {"kind": "text", "text": "(T.) ―         -b3-"}, {"kind": "italic_en", "text": "I. q."}, {"kind": "arabic", "text_bw": "hayoy^apN", "text_ar": "هَيْيَةٌ"}, {"kind": "text", "text": "(Lh, M, K) and"}, {"kind": "arabic", "text_bw": "$aA^onN", "text_ar": "شَاْنٌ"}, {"kind": "text", "text": "(M, K) and"}, {"kind": "arabic", "text_bw": "HaAlN", "text_ar": "حَالٌ"}, {"kind": "text", "text": "(M) and"}, {"kind": "arabic", "text_bw": "HaAlapN", "text_ar": "حَالَةٌ"}, {"kind": "text", "text": "(M, K) [all as meaning"}, {"kind": "italic_en", "text": "State, condition,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "case:"}, {"kind": "text", "text": "or by the first may be here meant"}, {"kind": "italic_en", "text": "external state"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition; form,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "appearance;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "state with respect to apparel and the like"}, {"kind": "text", "text": "]. ―         -b4-"}, {"kind": "italic_en", "text": "An easy and ample state of life;"}, {"kind": "text", "text": "(T;)"}, {"kind": "italic_en", "text": "easiness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pleasantness of life; ampleness of the conveniences of life, or of the means of subsistence; ease and enjoyment; plenty; prosperity; welfare."}, {"kind": "text", "text": "(IAar, M, K. *) You say of an old man when he has strength remaining,"}, {"kind": "arabic", "text_bw": "fulaAnN biA_im~apK", "text_ar": "فُلَانٌ بِاـِمَّةٍ"}, {"kind": "text", "text": ", meaning"}, {"kind": "italic_en", "text": "Such a one is returning to a state of well-being and ease and enjoyment."}, {"kind": "text", "text": "(TA.) ―         -b5-"}, {"kind": "italic_en", "text": "Dominion; mastership; authority."}, {"kind": "text", "text": "(Fr, T, IKtt.) ―         -b6-"}, {"kind": "italic_en", "text": "A blessing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "what God bestows upon one; a benefit, benefaction, favour,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "boon; a cause of happiness;"}, {"kind": "text", "text": "(T, S, M, Msb, K;) as being that which men aim at, pursue, or endeavour to obtain, (T.) See"}, {"kind": "arabic", "text_bw": "A^um~apN", "text_ar": "اُمَّةٌ"}, {"kind": "text", "text": ", last sentence but one.       -A2-  Accord. to IKtt, it signifies also"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "A^amamN", "text_ar": "اَمَمٌ"}, {"kind": "text", "text": "[but in what sense is not said]. (TA.)"}], "source_refs": ["K", "Lh", "M"]}, {"entry_id": "n1281", "headword_ar": "اَمِهَ", "root": "Amh", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^amahN", "text_ar": "اَمَهٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He forgot."}, {"kind": "text", "text": "(S, K.) Hence the reading of I'Ab, [in the Kur xii. 45,]"}, {"kind": "arabic", "text_bw": "waAd~akara baEoda A^amahK", "text_ar": "وَادَّكَرَ بَعْدَ اَمَهٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "And he remembered,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became reminded, after forgetting"}, {"kind": "text", "text": "]. (S.) AHeyth is said to have read"}, {"kind": "arabic", "text_bw": "baEoda A^amohK", "text_ar": "بَعْدَ اَمْهٍ"}, {"kind": "text", "text": "; and accord. to AO,"}, {"kind": "arabic", "text_bw": "A^amohN", "text_ar": "اَمْهٌ"}, {"kind": "text", "text": "signifies"}, {"kind": "arabic", "text_bw": "nisoyaAnN", "text_ar": "نِسْيَانٌ"}, {"kind": "text", "text": "[like"}, {"kind": "arabic", "text_bw": "A^amahN", "text_ar": "اَمَهٌ"}, {"kind": "text", "text": "]; but this is not correct. (Az, TA.) ―         -b2-"}, {"kind": "italic_en", "text": "He confessed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "acknowledged:"}, {"kind": "text", "text": "(S, K:) occurring in this sense in a trad. of Ez-Zuhree; but not well known. (S.) The reading of I'Ab, mentioned above,"}, {"kind": "arabic", "text_bw": "baEoda A^amahK", "text_ar": "بَعْدَ اَمَهٍ"}, {"kind": "text", "text": ", is explained by A'Obeyd as meaning"}, {"kind": "italic_en", "text": "after confessing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "acknowledging."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["S", "K"]}, {"entry_id": "n1288", "headword_ar": "اَمَةٌ", "root": "Amw", "body": [{"kind": "text", "text": ", originally"}, {"kind": "arabic", "text_bw": "Amwp", "text_ar": "اموة"}, {"kind": "text", "text": ", (Msb,) [but whether"}, {"kind": "arabic", "text_bw": "A^amawapN", "text_ar": "اَمَوَةٌ"}, {"kind": "text", "text": "or"}, {"kind": "arabic", "text_bw": "A^amowapN", "text_ar": "اَمْوَةٌ"}, {"kind": "text", "text": "is disputed, as will be seen in what follows,]"}, {"kind": "italic_en", "text": "A female slave;"}, {"kind": "text", "text": "(M, K;)"}, {"kind": "italic_en", "text": "a woman whose condition is that of slavery;"}, {"kind": "text", "text": "(T;)"}, {"kind": "italic_en", "text": "contr. of"}, {"kind": "arabic", "text_bw": "Hur~apN", "text_ar": "حُرَّةٌ"}, {"kind": "text", "text": ": (S:) [in relation to God, best rendered"}, {"kind": "italic_en", "text": "a handmaid:"}, {"kind": "text", "text": "] dual"}, {"kind": "arabic", "text_bw": "A^amataAni", "text_ar": "اَمَتَانِ"}, {"kind": "text", "text": ": (Msb:) pl."}, {"kind": "arabic", "text_bw": "A=mK", "text_ar": "ا=مٍ"}, {"kind": "text", "text": ", (Lth, T, S, M, Msb, K, &c.,) like"}, {"kind": "arabic", "text_bw": "qiADK", "text_ar": "قِاضٍ"}, {"kind": "text", "text": ", (Msb,) a pl. of pauc. [respecting which see what follows after the other pls.], (Lth, T,) and"}, {"kind": "arabic", "text_bw": "A_imaA='N", "text_ar": "اـِمَا=ءٌ"}, {"kind": "text", "text": "[the most common form] (T, S, M, Mgh, Msb, K) and"}, {"kind": "arabic", "text_bw": "A_imowaAnN", "text_ar": "اـِمْوَانٌ"}, {"kind": "text", "text": "(T, S, M, Msb, K) and"}, {"kind": "arabic", "text_bw": "A^umowaAnN", "text_ar": "اُمْوَانٌ"}, {"kind": "text", "text": "(K, and so in some copies of the M) and"}, {"kind": "arabic", "text_bw": "A^amowaAnN", "text_ar": "اَمْوَانٌ"}, {"kind": "text", "text": "(K, and so in some copies of the M) [the last, or last but one, accord. to different copies of the M, on the authority of Lh,] and"}, {"kind": "arabic", "text_bw": "A^amawaAtN", "text_ar": "اَمَوَاتٌ"}, {"kind": "text", "text": ", (M, Msb, K,) for which one may say"}, {"kind": "arabic", "text_bw": "A^amaAtN", "text_ar": "اَمَاتٌ"}, {"kind": "text", "text": ". (Ibn-Keysán, TA.) Accord. to Sb (M) and Mbr (TA) it is originally"}, {"kind": "arabic", "text_bw": "A^amawapN", "text_ar": "اَمَوَةٌ"}, {"kind": "text", "text": ", (S, M, K,) because it has for a pl."}, {"kind": "arabic", "text_bw": "A=mK", "text_ar": "ا=مٍ"}, {"kind": "text", "text": ", (S, M,) which is [originally"}, {"kind": "arabic", "text_bw": "A^aA^omuwN", "text_ar": "اَاْمُوٌ"}, {"kind": "text", "text": ",] of the measure"}, {"kind": "arabic", "text_bw": "A^afoEulN", "text_ar": "اَفْعُلٌ"}, {"kind": "text", "text": ", (Lth, T, S,) like"}, {"kind": "arabic", "text_bw": "A=kumN", "text_ar": "ا=كُمٌ"}, {"kind": "text", "text": ", pl. of"}, {"kind": "arabic", "text_bw": "A^akamapN", "text_ar": "اَكَمَةٌ"}, {"kind": "text", "text": ", (Sb, M,) and like"}, {"kind": "arabic", "text_bw": "A^ayonuqN", "text_ar": "اَيْنُقٌ"}, {"kind": "text", "text": ", [pl. of"}, {"kind": "arabic", "text_bw": "naAqpN", "text_ar": "نَاقةٌ"}, {"kind": "text", "text": ", which is originally"}, {"kind": "arabic", "text_bw": "nawaqpN", "text_ar": "نَوَقةٌ"}, {"kind": "text", "text": ",] for a sing. of the measure"}, {"kind": "arabic", "text_bw": "faEolapN", "text_ar": "فَعْلَةٌ"}, {"kind": "text", "text": "has not a pl. of this form; (S;) and Mbr says that there is no noun of two letters but a letter has been dropped from it, which it indicates by its pl. or dual, or by a verb if it is derived therefrom: (TA:) or it is originally"}, {"kind": "arabic", "text_bw": "faEolapN", "text_ar": "فَعْلَةٌ"}, {"kind": "text", "text": ": (AHeyth, T, K:) AHeyth says that they suppressed its final radical letter, and, forming a pl. from it after the manner of"}, {"kind": "arabic", "text_bw": "naxolapN", "text_ar": "نَخْلَةٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "naxolN", "text_ar": "نَخْلٌ"}, {"kind": "text", "text": ", instead of saying"}, {"kind": "arabic", "text_bw": "A^amN", "text_ar": "اَمٌ"}, {"kind": "text", "text": ", which they disliked as being of only two letters, they transposed the suppressed"}, {"kind": "arabic", "text_bw": "w", "text_ar": "و"}, {"kind": "text", "text": ", changing it into"}, {"kind": "arabic", "text_bw": "A", "text_ar": "ا"}, {"kind": "text", "text": ", and placing it between the"}, {"kind": "arabic", "text_bw": "A", "text_ar": "ا"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "m", "text_ar": "م"}, {"kind": "text", "text": ". (T: [in which this opinion, though it does not account for the termination of the pl."}, {"kind": "arabic", "text_bw": "A=mK", "text_ar": "ا=مٍ"}, {"kind": "text", "text": ", is said to be preferable.]) One says,"}, {"kind": "arabic", "text_bw": "jaA='a toniYF A^amapu All~`hi", "text_ar": "جَا=ءَ تْنِىً اَمَةُ اللّٰهِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The handmaid of God came to me"}, {"kind": "text", "text": "]: and in the dual,"}, {"kind": "arabic", "text_bw": "jaA='a toniY A^mataA All~`hi", "text_ar": "جَا=ءَ تْنِى امَتَا اللّٰهِ"}, {"kind": "text", "text": ": and in the pl.,"}, {"kind": "arabic", "text_bw": "jaA='a niY A_imaA='u All~`hi", "text_ar": "جَا=ءَ نِى اـِمَا=ءُ اللّٰهِ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "A_imowaAnu All~`hi", "text_ar": "اـِمْوَانُ اللّٰهِ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "A^amawaAtu All~`hi", "text_ar": "اَمَوَاتُ اللّٰهِ"}, {"kind": "text", "text": "; and one may also say,"}, {"kind": "arabic", "text_bw": "A^amaAtu All~`h", "text_ar": "اَمَاتُ اللّٰه"}, {"kind": "text", "text": ". (Ibn-Keysán, TA.) [ISd says,]"}, {"kind": "arabic", "text_bw": "wamaAhu All~`hu mino kul~i", "text_ar": "وَمَاهُ اللّٰهُ مِنْ كُلِّ"}, {"kind": "arabic", "text_bw": "A^amapK bHajarK", "text_ar": "اَمَةٍ بحَجَرٍ"}, {"kind": "text", "text": "is mentioned by IAar as said in imprecating evil on a man; but I think it is"}, {"kind": "arabic", "text_bw": "mn kl~", "text_ar": "من كلّ"}, {"kind": "arabic", "text_bw": "A^amoti", "text_ar": "اَمْتِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "May God cast a stone at him from every elevated place,"}, {"kind": "text", "text": "or the like]. (M.)"}], "source_refs": ["Msb", "S", "Lth", "T", "M", "Mgh", "K", "TA", "Sb", "AHeyth"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}