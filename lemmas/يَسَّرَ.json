gen":"m","num":"p"},{"role":"present_2mp","form":"تُيَسِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُيَسِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُيَسِّر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُيَسِّر","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُيَسِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُيَسِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُيَسِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُيَسِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُيَسِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُيَسِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُيَسِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"يَسَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"يَسَّرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُيَسِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُيَسِّر","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":72,"cross_references":{"qac":{"found":true,"lemma_key":"يَسَّرَ","root":"يسر","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n42452","n42458","n42459","n42460","n42461"],"search_url":"https://lanelexicon.com/?s=%D9%8A%D9%8E%D8%B3%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become less complex, effortful, or burdensome; to ease up","tags":["intransitive"]},{"pos":"verb","gloss":"to be able to do or procure easily","tags":["intransitive"]},{"pos":"verb","gloss":"to come or show oneself from the left side","tags":["intransitive"]},{"pos":"verb","gloss":"to be or become simple or easy","tags":["intransitive"]},{"pos":"verb","gloss":"to be or become at financial ease","tags":["intransitive"]},{"pos":"verb","gloss":"to make less complex, effortful, or burdensome; to ease","tags":["intransitive","transitive"],"examples":[{"text":"فَسَنُيَسِّرُهُ لِلْعُسْرَى","english":"We will facilitate for them the Way of Ease."}]},{"pos":"noun","gloss":"verbal noun of يَسُرَ (yasura) (form I)","tags":["form-of","intransitive","noun-from-verb","transitive"],"examples":[{"text":"إِنَّ مَعَ الْعُسْرِ يُسْرًا"}]},{"pos":"noun","gloss":"verbal noun of يَسُرَ (yasura) (form I, uncertain)","tags":["form-of","intransitive","noun-from-verb","transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42452","headword_ar":"يَسَرَ","root":"ysr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yabosiru","text_ar":"يَبْسِرُ"},{"kind":"text","text":", [respecting the form of which see the same verb in a different sense below,] inf. n."},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yasarN","text_ar":"يَسَرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":"below)],"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gentle, and tractable, submissive, manageable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy;"},{"kind":"text","text":"(M, K;) said of a man, and of a horse: (M:) and"},{"kind":"arabic","text_bw":"yusira","text_ar":"يُسِرَ"},{"kind":"text","text":"[app. signifies the same: and] is said of speech, and of a thing or an affair; signifying, [when relating to the former,]"},{"kind":"italic_en","text":"it was gentle,"},{"kind":"text","text":"or [when relating to the latter,]"},{"kind":"italic_en","text":"easy;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"suEida Alr~ajulu","text_ar":"سُعِدَ الرَّجُلُ"},{"kind":"text","text":"[as"},{"kind":"page_break","n":2976},{"kind":"text","text":"syn. with"},{"kind":"arabic","text_bw":"saEida","text_ar":"سَعِدَ"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"nuHisa","text_ar":"نُحِسَ"},{"kind":"text","text":"[as syn. with"},{"kind":"arabic","text_bw":"naHisa","text_ar":"نَحِسَ"},{"kind":"text","text":"]. (Bd, xvii. 30.) See also"},{"kind":"arabic","text_bw":"tys~r","text_ar":"تيسّر"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"yasarato","text_ar":"يَسَرَتْ"},{"kind":"text","text":", said of a woman: see"},{"kind":"arabic","text_bw":"A^ayosarato","text_ar":"اَيْسَرَتْ"},{"kind":"text","text":"-A2-"},{"kind":"arabic","text_bw":"yasura","text_ar":"يَسُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, little in quantity:"},{"kind":"text","text":"(A, Msb:)"},{"kind":"italic_en","text":"contemptible; paltry; of no weight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worth."},{"kind":"text","text":"(A.)       -A3-"},{"kind":"arabic","text_bw":"yasaraniY","text_ar":"يَسَرَنِى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yayosiruniY","text_ar":"يَيْسِرُنِى"},{"kind":"text","text":", (AHn, M, K,) inf. n."},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":", (AHn, M,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, AHn, M)"},{"kind":"italic_en","text":"came on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from the direction of, my left hand."},{"kind":"text","text":"(AHn, M, K.) See also 3.       -A4-"},{"kind":"arabic","text_bw":"yasara","text_ar":"يَسَرَ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yayosiru","text_ar":"يَيْسِرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He divided"},{"kind":"text","text":"anything"},{"kind":"italic_en","text":"into parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portions."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"yasarotu Aln~aAqapa","text_ar":"يَسَرْتُ النَّاقَةَ"},{"kind":"italic_en","text":"I divided the flesh of the she-camel into parts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portions."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"yasaruwA Aljazuwra","text_ar":"يَسَرُوا الجَزُورَ"},{"kind":"italic_en","text":"They slaughtered the she-camel and divided its limbs,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"portions,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"among themselves;"},{"kind":"text","text":"(S, TA;) as also, accord. to Aboo-'Omar ElJarmee, ↓"},{"kind":"arabic","text_bw":"A_it~asaruwhaA","text_ar":"اـِتَّسَرُوهَا","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yat~asiruwnahaA","text_ar":"يَتَّسِرُونَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_it~isaArN","text_ar":"اـِتِّسَارٌ"},{"kind":"text","text":"; and he adds that some people say,"},{"kind":"arabic","text_bw":"yaA^otasiruwnahaA","text_ar":"يَاْتَسِرُونَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A@notisaArN","text_ar":"ا@نْتِسَارٌ"},{"kind":"text","text":", with hemz; and"},{"kind":"arabic","text_bw":"humo muw^otasiruwna","text_ar":"هُمْ مُوْتَسِرُونَ"},{"kind":"text","text":"; like as they say in the case of"},{"kind":"arabic","text_bw":"A_it~aEada","text_ar":"اـِتَّعَدَ"},{"kind":"text","text":". (S.) Soheym Ibn-Wetheel El-Yarboo'ee says,"},{"kind":"quote","text":"A^aquwlu lahumo biAl$~iEobi A_i*o yayosiruwnaniY\n                      \n                     \n                        A^alamo tayoy^asuwA A^an~iY A@bonu faArisi zahodami"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I say to them, in the ravine, when they divide me among themselves,"},{"kind":"text","text":"deciding what shares they shall severally have in me,"},{"kind":"italic_en","text":"Know ye not that I am the son of the rider of Zahdam,"},{"kind":"text","text":"and that ye may obtain a great ransom for me?] for capture had befallen him, and they played with [gaming-] arrows for him. (S, TA. [but in the latter, instead of"},{"kind":"arabic","text_bw":"tayoy^asuwA","text_ar":"تَيْيَسُوا"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"taEolamuwA","text_ar":"تَعْلَمُوا"},{"kind":"text","text":", which signifies the same.]) You say also, ↓"},{"kind":"arabic","text_bw":"A_it~asaruwA","text_ar":"اـِتَّسَرُوا","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yat~asiruwna","text_ar":"يَتَّسِرُونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaA^otasiruwna","text_ar":"يَاْتَسِرُونَ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"tayAasaruwA","text_ar":"تَياَسَرُوا","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"They divided among themselves the slaughtered camel."},{"kind":"text","text":"(M, K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"yasara","text_ar":"يَسَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yayosiru","text_ar":"يَيْسِرُ"},{"kind":"text","text":", (S, M, A, Msb, K,) in the [second]"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is not suppressed as it is in"},{"kind":"arabic","text_bw":"yaEidu","text_ar":"يَعِدُ"},{"kind":"text","text":"and its cöordinates [having"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"for the first radical], (S,) and"},{"kind":"arabic","text_bw":"yiysaru","text_ar":"يِيسَرُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"yiyjalu","text_ar":"يِيجَلُ"},{"kind":"text","text":", in the dial. of the Benoo-Asad, (TA,) inf. n."},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":", (M, TA,) or"},{"kind":"arabic","text_bw":"mayosirN","text_ar":"مَيْسِرٌ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He played at the game called"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"text","text":"; (M, Msb, K;)"},{"kind":"italic_en","text":"he played with gamingarrows."},{"kind":"text","text":"(S, A, Msb.)"}],"source_refs":["M","A","Msb","AHn","K","S","TA"]},{"entry_id":"n42458","headword_ar":"يَسْرٌ","root":"ysr","body":[{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"yasarN","text_ar":"يَسَرٌ","orth_type":"arrow"},{"kind":"text","text":", (M, A, K, TA,) [each an inf. n. (see 1) used as an epithet,] and"},{"kind":"arabic","text_bw":"yaAsirN","text_ar":"يَاسِرٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"Easy and gentle in tractableness, submissiveness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manageableness;"},{"kind":"text","text":"applied to a man and to a horse: (TA:) or [simply]"},{"kind":"italic_en","text":"easy; facile;"},{"kind":"text","text":"(M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"yasiyrN","text_ar":"يَسِيرٌ"},{"kind":"text","text":", (Msb), this last being syn. with"},{"kind":"arabic","text_bw":"hay~inN","text_ar":"هَيِّنٌ"},{"kind":"text","text":", (S, K,) and signifying"},{"kind":"italic_en","text":"not difficult,"},{"kind":"arabic","text_bw":"gayoru EasiyrK","text_ar":"غَيْرُ عَسِيرٍ"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ","orth_type":"arrow"},{"kind":"text","text":"[respecting which see also"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":", pl."},{"kind":"arabic","text_bw":"mayaAsiyru","text_ar":"مَيَاسِيرُ"},{"kind":"text","text":"]. (A.) Hence, ↓"},{"kind":"arabic","text_bw":"yasaraAtN","text_ar":"يَسَرَاتٌ","orth_type":"arrow"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"yasorapN","text_ar":"يَسْرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yasarapN","text_ar":"يَسَرَةٌ"},{"kind":"text","text":", applied to the legs of a beast, signifies"},{"kind":"italic_en","text":"Easy:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active,"},{"kind":"text","text":"legs of a beast: (S, TA:) or"},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active, and obedient,"},{"kind":"text","text":"legs of a beast of carriage: (A:) or the"},{"kind":"italic_en","text":"legs"},{"kind":"text","text":"of a she-camel: and you say also,"},{"kind":"arabic","text_bw":"A_in~a qawaAy^ima h`*aA Alfarasi yasaraAtN xifaAfN","text_ar":"اـِنَّ قَوَايِمَ هٰذَا الفَرَسِ يَسَرَاتٌ خِفَافٌ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"verily the legs of this horse are obedient"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active."},{"kind":"text","text":"(TA.) [Hence also,]"},{"kind":"arabic","text_bw":"wilaAdapN yasorN","text_ar":"وِلَادَةٌ يَسْرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An easy birth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bringing forth"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"waladato waladahaA","text_ar":"وَلَدَتْ وَلَدَهَا"},{"kind":"arabic","text_bw":"yasorFA","text_ar":"يَسْرًا"},{"kind":"italic_en","text":"She brought forth her child easily:"},{"kind":"text","text":"(M, K *:) said of a woman: (M:) or ↓"},{"kind":"arabic","text_bw":"yasarFA","text_ar":"يَسَرًا","orth_type":"arrow"},{"kind":"text","text":". (CK.) And it is said in a trad., ↓"},{"kind":"arabic","text_bw":"A_in~a h`*aA Ald~iyna yusorN","text_ar":"اـِنَّ هٰذَا الدِّينَ يُسْرٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Verily this religion is easy; liberal; one having little straitness."},{"kind":"text","text":"(TA.) You say also, ↓"},{"kind":"arabic","text_bw":"xu*o mayosuwrahu","text_ar":"خُذْ مَيْسُورَهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"wadaEo maEosuwrahu","text_ar":"وَدَعْ مَعْسُورَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Take thou what is easy thereof, and leave thou what is difficult"},{"kind":"text","text":"]. (A.) And ↓"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ","orth_type":"arrow"},{"kind":"text","text":"is applied to a saying, or speech: (A:) so in the Kur. xvii. 30; meaning,"},{"kind":"italic_en","text":"gentle;"},{"kind":"text","text":"(Bd, Jel;)"},{"kind":"italic_en","text":"easy:"},{"kind":"text","text":"(Jel:) or ↓"},{"kind":"arabic","text_bw":"quwolN mayosuwrN","text_ar":"قُوْلٌ مَيْسُورٌ","orth_type":"arrow"},{"kind":"text","text":"means prayer for"},{"kind":"arabic","text_bw":"mayosuwr","text_ar":"مَيْسُور"},{"kind":"text","text":", i. e., for"},{"kind":"arabic","text_bw":"yusor","text_ar":"يُسْر"},{"kind":"text","text":"[q. v.]. (Bd.) ―         -b2-"},{"kind":"arabic","text_bw":"fatolN yasorN","text_ar":"فَتْلٌ يَسْرٌ"},{"kind":"text","text":"[The"},{"kind":"italic_en","text":"twisting"},{"kind":"text","text":"a rope or cord"},{"kind":"italic_en","text":"towards the left, by rolling it against the body from right to left;"},{"kind":"text","text":"or] the"},{"kind":"italic_en","text":"twisting downwards, by extending the right hand towards the body"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and so rolling the rope or cord downwards against the body or thigh,"},{"kind":"text","text":"which is the usual way of twisting]; (S, A *, K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"$azorN","text_ar":"شَزْرٌ"},{"kind":"text","text":". (M, A, TA) ―         -b3-"},{"kind":"arabic","text_bw":"TaEonN yasorN","text_ar":"طَعْنٌ يَسْرٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"thrusting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piercing,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"straight forward;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"opposite the face:"},{"kind":"text","text":"(S, M, K:) opposed to"},{"kind":"arabic","text_bw":"$azorN","text_ar":"شَزْرٌ"},{"kind":"text","text":", which is from one's right and one's left. (TA.) See an ex. voce"},{"kind":"arabic","text_bw":"$azarahu","text_ar":"شَزَرَهُ"},{"kind":"text","text":"."}],"source_refs":["TA","M","A","K","Msb","S","Jel"]},{"entry_id":"n42459","headword_ar":"يُسْرٌ","root":"ysr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Easiness; facility;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"; (S, M, Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"yusurN","text_ar":"يُسُرٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, TA;) [and ↓"},{"kind":"arabic","text_bw":"yusoraY","text_ar":"يُسْرَى","orth_type":"arrow"},{"kind":"text","text":"; (see 3, where it is variously explained;)] and ↓"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ","orth_type":"arrow"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":", [and therefore signifies as above; or"},{"kind":"italic_en","text":"easy; facile;"},{"kind":"text","text":"] (S;) or this last signifies, (accord. to the lexicologists, M,) what is"},{"kind":"italic_en","text":"made easy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facilitated;"},{"kind":"text","text":"or (accord. to Sb, M, [but see"},{"kind":"arabic","text_bw":"maEaquwlN","text_ar":"مَعَقُولٌ"},{"kind":"text","text":",]) it is an inf. n. of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":", (M, K,) [used in the sense of"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":"as explained above,] of the same kind as [its contr.]"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":"; and Abu-l-Hasan says, that this is the truth; for it has no unaugmented verb, and inf. ns. of this measure are not of verbs which are in use, but only of imaginary unaugmented triliteral-radical verbs, as in the case of"},{"kind":"arabic","text_bw":"majoluwdN","text_ar":"مَجْلُودٌ"},{"kind":"text","text":", which is [really] from"},{"kind":"arabic","text_bw":"tajal~ada","text_ar":"تَجَلَّدَ"},{"kind":"text","text":". (M.) For examples of"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":". ―         -b2-  Also, (accord. to the M; but in the K, or; and in both of these lexicons the signification here following is placed first;) and in like manner, ↓"},{"kind":"arabic","text_bw":"yusurN","text_ar":"يُسُرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"yasaArN","text_ar":"يَسَارٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Mgh, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"yasaArapN","text_ar":"يَسَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"mayosarapN","text_ar":"مَيْسَرَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mayosurapN","text_ar":"مَيْسُرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) of which last Sb says that it is like"},{"kind":"arabic","text_bw":"masorubapN","text_ar":"مَسْرُبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ma$orubapN","text_ar":"مَشْرُبَةٌ"},{"kind":"text","text":"in not being after the manner of the verb, [but after that of the simple substantive,] (M,) and ↓"},{"kind":"arabic","text_bw":"mayosirapN","text_ar":"مَيْسِرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K.)"},{"kind":"italic_en","text":"Easiness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of circumstances"},{"kind":"text","text":"]; (M, K;)"},{"kind":"italic_en","text":"competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"richness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opulence;"},{"kind":"text","text":"(S, M, Mgh, Msb, K;)"},{"kind":"italic_en","text":"abundance;"},{"kind":"text","text":"(Msb;) [in these senses, also,"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":";] and ↓"},{"kind":"arabic","text_bw":"yusoraY","text_ar":"يُسْرَى","orth_type":"arrow"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"the same;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"easy things"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances; contr. of"},{"kind":"arabic","text_bw":"EusoraY","text_ar":"عُسْرَى"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"mayosarapN","text_ar":"مَيْسَرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA, art."},{"kind":"arabic","text_bw":"Esr","text_ar":"عسر"},{"kind":"text","text":".) You say also, ↓"},{"kind":"arabic","text_bw":"A^anoZironiY Hat~aY yasaAri","text_ar":"اَنْظِرْنِى حَتَّى يَسَارِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Grant thou me a delay until"},{"kind":"text","text":"I shall be in a state of"},{"kind":"italic_en","text":"easiness of circumstances,"},{"kind":"text","text":"&c.]; in which the last word is indecl., with kesr for its termination, because it is altered from the inf. n., which is"},{"kind":"arabic","text_bw":"Almayosarapu","text_ar":"المَيْسَرَةُ"},{"kind":"text","text":". (S.) In the Kur. [ii. 280,] some read, ↓"},{"kind":"arabic","text_bw":"fanaZirapN A_ilaY mayosurihi","text_ar":"فَنَظِرَةٌ اـِلَى مَيْسُرِهِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Then"},{"kind":"text","text":"let there be"},{"kind":"italic_en","text":"a postponement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delay, until his"},{"kind":"text","text":"being in a state of"},{"kind":"italic_en","text":"easiness of circumstances"},{"kind":"text","text":"]: but Akh says, that this is not allowable; for there is no noun of the measure"},{"kind":"arabic","text_bw":"mafoEulN","text_ar":"مَفْعُلٌ"},{"kind":"text","text":"[of this kind]: as to"},{"kind":"arabic","text_bw":"makorumN","text_ar":"مَكْرُمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEuwnN","text_ar":"مَعُونٌ"},{"kind":"text","text":", [it is said that] they are pls. [virtually though not in the language of the grammarians] of"},{"kind":"arabic","text_bw":"makorumapN","text_ar":"مَكْرُمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEuwnapN","text_ar":"مَعُونَةٌ"},{"kind":"text","text":". (S.) [On this point, see"},{"kind":"arabic","text_bw":"maA^olukN","text_ar":"مَاْلُكٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A^aluwkN","text_ar":"اَلُوكٌ"},{"kind":"text","text":".]       -A2-  See also"},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":", in two places.       -A3-"},{"kind":"arabic","text_bw":"Euwdu yusorK","text_ar":"عُودُ يُسْرٍ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Euwdu A^usorK","text_ar":"عُودُ اُسْرٍ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"A^sr","text_ar":"اسر"},{"kind":"text","text":"."}],"source_refs":["M","K","S","Mgh","Msb"]},{"entry_id":"n42460","headword_ar":"يَسَرٌ","root":"ysr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"yasorN","text_ar":"يَسْرٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"Made easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facilitated; i. q."},{"kind":"arabic","text_bw":"muyas~arN","text_ar":"مُيَسَّرٌ"},{"kind":"text","text":": (assumed tropical:)"},{"kind":"italic_en","text":"prepared:"},{"kind":"text","text":"(K:) or [the"},{"kind":"italic_en","text":"game called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"italic_en","text":"prepared:"},{"kind":"text","text":"or, as some say, (assumed tropical:)"},{"kind":"italic_en","text":"anything prepared."},{"kind":"text","text":"(M.)       -A2-"},{"kind":"arabic","text_bw":"A^aEosaru yasarN","text_ar":"اَعْسَرُ يَسَرٌ"},{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who works, or does anything, with both his hands"},{"kind":"text","text":"["},{"kind":"italic_en","text":"alike"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"ambidextrous; ambidexter:"},{"kind":"text","text":"(S, M, Msb:) and ↓"},{"kind":"arabic","text_bw":"A^aEosaru A^ayosaru","text_ar":"اَعْسَرُ اَيْسَرُ","orth_type":"arrow"},{"kind":"text","text":"occurs in a trad., accord. to one relation; but the former is the correct expression: (A'Obeyd:) and the fem. is"},{"kind":"arabic","text_bw":"EasoraA='u yasarapN","text_ar":"عَسْرَا=ءُ يَسَرَةٌ"},{"kind":"text","text":": (M:) explained before, in art."},{"kind":"arabic","text_bw":"Esr","text_ar":"عسر"},{"kind":"text","text":". (K.)       -A3-  See also"},{"kind":"arabic","text_bw":"yaAsirN","text_ar":"يَاسِرٌ"},{"kind":"text","text":", in six places."}],"source_refs":["K","S","M","Msb"]},{"entry_id":"n42461","headword_ar":"يُسُرٌ","root":"ysr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}