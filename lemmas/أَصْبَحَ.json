2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُصْبِحُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُصْبِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُصْبِح","in_corpus":true,"count":31,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُصْبِح","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُصْبِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُصْبِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُصْبِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُصْبِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُصْبِحُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُصْبِحُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصْبِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُصْبِح","in_corpus":true,"count":64,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصْبِح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَصْبَحْنا","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَصْبَحْتُ","in_corpus":true,"count":15,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":296,"cross_references":{"qac":{"found":true,"lemma_key":"أَصْبَحَ","root":"صبح","pos":"V","occurrence_count":28},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n23630","n23650"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B5%D9%92%D8%A8%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23630","headword_ar":"اصبح","root":"SbH","body":[{"kind":"italic_en","text":"He entered upon the time of morning termed"},{"kind":"arabic","text_bw":"SabaAH","text_ar":"صَبَاح"},{"kind":"text","text":"[which means both"},{"kind":"italic_en","text":"dawn"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"forenoon"},{"kind":"text","text":"]: (S, * Msb: [in the former this meaning is indicated, but not expressed:]) or"},{"kind":"italic_en","text":"he entered upon the time of daybreak,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dawn, the time termed"},{"kind":"arabic","text_bw":"SuboH","text_ar":"صُبْح"},{"kind":"text","text":". (L, K.) By the following words of EshShemmákh,"},{"kind":"quote","text":"waqiylu AlmunaAdiY A^aSobaHa Alqawomu A^adolijiY"},{"kind":"text","text":"is meant, ["},{"kind":"italic_en","text":"And the saying of the crier is,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, have nearly entered upon the time of dawn: prosecute the night-journey:"},{"kind":"text","text":"for the Arabs, when they have nearly arrived at a place which they desire to reach, say,"},{"kind":"arabic","text_bw":"qado balagonaAhu","text_ar":"قَدْ بَلَغْنَاهُ"},{"kind":"text","text":"; and when travellers are near the time of daybreak, they say,"},{"kind":"arabic","text_bw":"A^aSobaHonaA","text_ar":"اَصْبَحْنَا"},{"kind":"text","text":". (T, L.) ―         -b2-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"He awoke from sleep in the"},{"kind":"arabic","text_bw":"jawof","text_ar":"جَوْف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"last third,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"last sixth,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the night."},{"kind":"text","text":"(A, TA.) [And simply (tropical:)"},{"kind":"italic_en","text":"He awoke:"},{"kind":"text","text":"for] one says to the sleeper,"},{"kind":"arabic","text_bw":"A^aSobiHo","text_ar":"اَصْبِحْ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Awake thou from sleep."},{"kind":"text","text":"(A, TA.) And one says also,"},{"kind":"arabic","text_bw":"A^aSobiHo yaA rajulu","text_ar":"اَصْبِحْ يَا رَجُلُ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Become roused, O man,"},{"kind":"text","text":"(A, K, * TA,)"},{"kind":"italic_en","text":"from thy heedlessness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inadvertence,"},{"kind":"text","text":"(A, TA,)"},{"kind":"italic_en","text":"and see thy right course,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"what will rectify thy state."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^aSobiHo layolu","text_ar":"اَصْبِحْ لَيْلُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Become morning, O night"},{"kind":"text","text":"] a prov.: (Meyd, A, TA:) said in a distressing night, that is long by reason of evil. (Meyd. [See Freytag's Arab. Prov., i. 727.]) ―         -b3-  [Also"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became in the morning"},{"kind":"text","text":"in any particular state or condition: in this sense, and in that next following, an incomplete, i. e. a non-attributive, verb.] ―         -b4-  And [hence, simply,]"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":". (S, K.) One says,"},{"kind":"arabic","text_bw":"ASbH EaAlimFA","text_ar":"اصبح عَالِمًا"},{"kind":"italic_en","text":"He became knowing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"learned."},{"kind":"text","text":"(S, TA.) Thus,"},{"kind":"arabic","text_bw":"faA^aSobaHuwA ZaAhiriyna","text_ar":"فَاَصْبَحُوا ظَاهِرِينَ"},{"kind":"text","text":", in the Kur lxi. last verse, means"},{"kind":"italic_en","text":"And they became victorious."},{"kind":"text","text":"(Bd.) And"},{"kind":"arabic","text_bw":"faA^aSobaHa yuqal~ibu kaf~ayohi","text_ar":"فَاَصْبَحَ يُقَلِّبُ كَفَّيْهِ"},{"kind":"text","text":", in the Kur xviii. 40, ["},{"kind":"italic_en","text":"And he became in a state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, in which he turned over his hands;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"and he became repentant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grieved for what he had done."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"qlb","text_ar":"قلب"},{"kind":"text","text":", and Bd.) And"},{"kind":"arabic","text_bw":"faA^aSobaHuwA laA taraY A_il~aA masaAkinahumo","text_ar":"فَاَصْبَحُوا لَا تَرَى اـِلَّا مَسَاكِنَهُمْ"},{"kind":"text","text":", in the Kur xlvi. 24, i. e. ["},{"kind":"italic_en","text":"And they became"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in a condition such that,"},{"kind":"text","text":"if thou wert present in their country,"},{"kind":"italic_en","text":"thou wouldst not see aught save their dwellingplaces;"},{"kind":"text","text":"or, as Hamzeh and Ks read,"},{"kind":"arabic","text_bw":"laA yuraY A_il~aA","text_ar":"لَا يُرَى اـِلَّا"},{"kind":"arabic","text_bw":"masaAkinuhumo","text_ar":"مَسَاكِنُهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"there was not to be seen aught save their dwelling-places"},{"kind":"text","text":"]. (Bd.) ["},{"kind":"arabic","text_bw":"A^aSobaHa yafoEalu ka*aA","text_ar":"اَصْبَحَ يَفْعَلُ كَذَا"},{"kind":"text","text":"is of frequent occurrence, meaning"},{"kind":"italic_en","text":"He became occupied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"engaged, in doing such a thing; he betook, set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"applied, himself to doing such a thing; set about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, doing such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"began to do such a thing."},{"kind":"text","text":"] ―         -b5-  [Also"},{"kind":"italic_en","text":"He performed the prayer of daybreak."},{"kind":"text","text":"] It is said in a trad.,"},{"kind":"arabic","text_bw":"A^aSobiHuwA biAlS~uboHi","text_ar":"اَصْبِحُوا بِالصُّبْحِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Perform ye the prayer of daybreak in the time of daybreak."},{"kind":"text","text":"(L.) ―         -b6-  See also 8. ―         -b7-  Also"},{"kind":"italic_en","text":"He acted gently."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Ar$","text_ar":"ارش"},{"kind":"text","text":": see an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"maA^orwu$N","text_ar":"مَاْروُشٌ"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"A_iSobaAHN","text_ar":"اـِصْبَاحٌ"},{"kind":"italic_en","text":"He trimmed a lamp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wick;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared it properly for use."},{"kind":"text","text":"(TA.) ―         -b2-  See, again, 8.       -A3-  as a subst., see"},{"kind":"arabic","text_bw":"SuboHN","text_ar":"صُبْحٌ"},{"kind":"text","text":", in two places."}],"source_refs":["A","TA","K","Meyd"]},{"entry_id":"n23650","headword_ar":"اَصْبَحُ","root":"SbH","body":[{"kind":"italic_en","text":"Of a black colour inclining to redness:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"having redness intermixed in his black hair:"},{"kind":"text","text":"(Sh, TA:) or"},{"kind":"italic_en","text":"whose hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beard, has a red hue overspreading it:"},{"kind":"text","text":"(Aboo-Nasr, Sh, TA:) or"},{"kind":"italic_en","text":"having hair intensely red:"},{"kind":"text","text":"(TA:) it is"},{"kind":"italic_en","text":"nearly the same as"},{"kind":"arabic","text_bw":"A^aSohabu","text_ar":"اَصْهَبُ"},{"kind":"text","text":": (Lth, S:) and is an epithet applied to a man and to a lion: (S:) and to hair as meaning"},{"kind":"italic_en","text":"having whiteness naturally intermixed in it with redness;"},{"kind":"text","text":"(K, TA;) of whatever kind it be: (TA:) fem."},{"kind":"arabic","text_bw":"SaboHaA='u","text_ar":"صَبْحَا=ءُ"},{"kind":"text","text":": (K:) and pl."},{"kind":"arabic","text_bw":"SuboHN","text_ar":"صُبْحٌ"},{"kind":"text","text":": (TA:) and hence [accord. to some] ↓"},{"kind":"arabic","text_bw":"AlS~uboHu","text_ar":"الصُّبْحُ","orth_type":"arrow"},{"kind":"text","text":"meaning “ the dawn; ” for, as Az says, the colour of the true dawn inclines a little to redness. (TA.) [Hence, because of his colour,]"},{"kind":"arabic","text_bw":"AlA^aSobaHu","text_ar":"الاَصْبَحُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The lion."},{"kind":"text","text":"(K.) In the phrase"},{"kind":"arabic","text_bw":"A^usuwdN SuboHN","text_ar":"اُسُودٌ صُبْحٌ"},{"kind":"text","text":", the epithet is added as a corroborative. (Z, TA.) ―         -b2-  And the fem.,"},{"kind":"arabic","text_bw":"SaboHaA='u","text_ar":"صَبْحَا=ءُ"},{"kind":"text","text":"signifies A female"},{"kind":"italic_en","text":"conspicuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, in the"},{"kind":"arabic","text_bw":"jabiyn","text_ar":"جَبِين"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"side of the forehead"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K","Sh","TA","Lth","S"]}]},"classical_definitions":null}