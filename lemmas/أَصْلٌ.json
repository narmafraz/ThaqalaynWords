g in the M, I find"}, {"kind": "arabic", "text_bw": "EaAqib", "text_ar": "عَاقِب"}, {"kind": "text", "text": ".]) ―         -b3-  Also, (S, * K,) inf. n. as above, (S, TA,)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(judgment, or opinion,)"}, {"kind": "italic_en", "text": "was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, firm,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sound,"}, {"kind": "text", "text": "(S, * TA,) or"}, {"kind": "italic_en", "text": "good."}, {"kind": "text", "text": "(K.) ―         -b4-  And, inf. n. as above,"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a thing)"}, {"kind": "italic_en", "text": "was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, eminent, noble,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "honourable."}, {"kind": "text", "text": "(Msb.)       -A2-"}, {"kind": "arabic", "text_bw": "A^aSalahu", "text_ar": "اَصَلَهُ"}, {"kind": "text", "text": ", [aor. and inf. n. as in what follows next after this sentence,]"}, {"kind": "italic_en", "text": "He hit,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "struck, its root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foundation; that by being which it was what it was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in being which it consisted;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "its ultimate constituent."}, {"kind": "text", "text": "(A, TA.) ―         -b2-  And hence, (A, TA,)"}, {"kind": "arabic", "text_bw": "A^aSalahu EilomFA", "text_ar": "اَصَلَهُ عِلْمًا"}, {"kind": "text", "text": ", (A, K, TA,) aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^aSolN", "text_ar": "اَصْلٌ"}, {"kind": "text", "text": ": (TA;) or ↓"}, {"kind": "arabic", "text_bw": "A=Salahu", "text_ar": "ا=صَلَهُ", "orth_type": "arrow"}, {"kind": "text", "text": "[with medd, (which I think to be a mistake, unless this be a dial. var.,) and without"}, {"kind": "arabic", "text_bw": "ElmA", "text_ar": "علما"}, {"kind": "text", "text": "]; (so in a copy of the M;) (assumed tropical:)"}, {"kind": "italic_en", "text": "He knew it completely,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "thoroughly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "superlatively well,"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "qatalahu", "text_ar": "قَتَلَهُ"}, {"kind": "text", "text": ", (K,) [i. e.]"}, {"kind": "arabic", "text_bw": "qatalahu EilomFA", "text_ar": "قَتَلَهُ عِلْمًا"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "so that he was acquainted with its"}, {"kind": "arabic", "text_bw": "A^aSol", "text_ar": "اَصْل"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foundation,"}, {"kind": "text", "text": "or its"}, {"kind": "italic_en", "text": "ultimate constituent,"}, {"kind": "text", "text": "as is indicated in the A and TA]: (M:) or this is from"}, {"kind": "arabic", "text_bw": "A^aSalapN", "text_ar": "اَصَلَةٌ"}, {"kind": "text", "text": ", as meaning “a certain very deadly serpent;” (A, TA;) [whence the phrase,] ―         -b3-"}, {"kind": "arabic", "text_bw": "A^aSalatohu AlA^aSalapu", "text_ar": "اَصَلَتْهُ الاَصَلَةُ"}, {"kind": "text", "text": ", (K,) inf. n."}, {"kind": "arabic", "text_bw": "A^aSolN", "text_ar": "اَصْلٌ"}, {"kind": "text", "text": ", (TA,)"}, {"kind": "italic_en", "text": "The"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "serpent called"}, {"kind": "text", "text": "]"}, {"kind": "arabic", "text_bw": "ASlp", "text_ar": "اصلة"}, {"kind": "italic_en", "text": "sprang upon him"}, {"kind": "text", "text": "(K, TA)"}, {"kind": "italic_en", "text": "and slew him."}, {"kind": "text", "text": "(TA.)       -A3-"}, {"kind": "arabic", "text_bw": "A^aSila", "text_ar": "اَصِلَ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", (M, K,) inf. n."}, {"kind": "arabic", "text_bw": "A^aSalN", "text_ar": "اَصَلٌ"}, {"kind": "text", "text": ", (M,) said of water,"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "A^asina", "text_ar": "اَسِنَ"}, {"kind": "text", "text": "; (M, K;) i. e."}, {"kind": "italic_en", "text": "It became altered for the worse"}, {"kind": "text", "text": "(M, TA)"}, {"kind": "italic_en", "text": "in its taste and odour,"}, {"kind": "text", "text": "(TA,)"}, {"kind": "italic_en", "text": "from fetid black mud"}, {"kind": "text", "text": "(K, TA)"}, {"kind": "italic_en", "text": "therein:"}, {"kind": "text", "text": "so says Ibn-'Abbád: (TA:) and said of flesh-meat,"}, {"kind": "italic_en", "text": "it became altered"}, {"kind": "text", "text": "(K, TA)"}, {"kind": "italic_en", "text": "in like manner."}, {"kind": "text", "text": "(TA.)       -A4-"}, {"kind": "arabic", "text_bw": "A^aSila fulaAnN yafoEalu ka*aA wa ka*aA", "text_ar": "اَصِلَ فُلَانٌ يَفْعَلُ كَذَا وَ كَذَا"}, {"kind": "italic_en", "text": "Such a one set about,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "commenced, doing thus and thus,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "such and such things."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["K", "M", "S", "TA", "A"]}, {"entry_id": "n879", "headword_ar": "اَصْلٌ", "root": "ASl", "body": [{"kind": "text", "text": "The"}, {"kind": "italic_en", "text": "lower,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lowest, part"}, {"kind": "text", "text": "of a thing; [i. e. its"}, {"kind": "italic_en", "text": "root, bottom,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foot;"}, {"kind": "text", "text": "] (M, Msb, K;) as also ↓"}, {"kind": "arabic", "text_bw": "yaA^oSuwlN", "text_ar": "يَاْصُولٌ", "orth_type": "arrow"}, {"kind": "text", "text": ": (M, K:) so of a mountain: and of a wall; (TA;) i. e. its"}, {"kind": "italic_en", "text": "foundation,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "base:"}, {"kind": "text", "text": "(Msb:) and of a tree [or plant]; (TA;) i. e. [its"}, {"kind": "italic_en", "text": "stem,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "trunk,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock,"}, {"kind": "text", "text": "or] the"}, {"kind": "italic_en", "text": "part from which the branches are broken off:"}, {"kind": "text", "text": "(TA in art."}, {"kind": "arabic", "text_bw": "ksr", "text_ar": "كسر"}, {"kind": "text", "text": ":) [and also its"}, {"kind": "italic_en", "text": "root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foot;"}, {"kind": "text", "text": "for] the"}, {"kind": "arabic", "text_bw": "saAq", "text_ar": "سَاق"}, {"kind": "text", "text": "of a tree is said to be the part between its"}, {"kind": "arabic", "text_bw": "A^aSol", "text_ar": "اَصْل"}, {"kind": "text", "text": "and the place where its branches shoot out: (TA in art."}, {"kind": "arabic", "text_bw": "swq", "text_ar": "سوق"}, {"kind": "text", "text": ":) [and"}, {"kind": "italic_en", "text": "a stump"}, {"kind": "text", "text": "of a tree: and hence,"}, {"kind": "italic_en", "text": "a block"}, {"kind": "text", "text": "of wood: (see exs. voce"}, {"kind": "arabic", "text_bw": "naqiyrN", "text_ar": "نَقِيرٌ"}, {"kind": "text", "text": ":)] pl."}, {"kind": "arabic", "text_bw": "A^uSuwlN", "text_ar": "اُصُولٌ"}, {"kind": "text", "text": "(S, M, Msb, K) and [pl. of pauc.]"}, {"kind": "arabic", "text_bw": "A=SulN", "text_ar": "ا=صُلٌ"}, {"kind": "text", "text": ": (AHn, K:) [ISd says that] the former is its only pl.: (M:) [but] the latter pl. occurs in a verse of Lebeed, (which see below,) as cited by AHn. (TA.) You say,"}, {"kind": "arabic", "text_bw": "qaEada fiY A^aSoli jabali", "text_ar": "قَعَدَ فِى اَصْلِ جَبَلِ"}, {"kind": "italic_en", "text": "He sat upon,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "at, the lowest part"}, {"kind": "text", "text": "[&c.]"}, {"kind": "italic_en", "text": "of the mountain;"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "fiY A^aSoli AlHaAy^iTi", "text_ar": "فِى اَصْلِ الحَايِطِ"}, {"kind": "italic_en", "text": "at the lowest part"}, {"kind": "text", "text": "[&c.]"}, {"kind": "italic_en", "text": "of the wall."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "qalaEahu mino A^aSolihi", "text_ar": "قَلَعَهُ مِنْ اَصْلِهِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He pulled it up,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "out,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "off, from its root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foundation,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lowest part"}, {"kind": "text", "text": "]; and"}, {"kind": "arabic", "text_bw": "bA^uSuwlihi", "text_ar": "باُصُولِهِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "with its roots,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foundations,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lowest parts;"}, {"kind": "text", "text": "both meaning,"}, {"kind": "italic_en", "text": "utterly, entirely,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "altogether"}, {"kind": "text", "text": "]. (TA in explanation of"}, {"kind": "arabic", "text_bw": "AstA^Slhu", "text_ar": "استاصلهُ"}, {"kind": "text", "text": ", q. v.) And"}, {"kind": "arabic", "text_bw": "qalaEa A^aSola Al$~ajarapi", "text_ar": "قَلَعَ اَصْلَ الشَّجَرَةِ"}, {"kind": "italic_en", "text": "He pulled up,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "out, the lowest part,"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "stem"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "root"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "foot"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stump,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "of the tree."}, {"kind": "text", "text": "(TA.) Lebeed says, [of a wild cow,]"}, {"kind": "quote", "text": "tajotaAfu A=Sula qaAliSK mutanab~i*K\n                      \n                     \n                        biEujuwbi A^anoqaA='K yamiylu hayaAmuhaA"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "She enters into the midst of the stems of trees with high branches, apart from others,"}, {"kind": "text", "text": "i. e. from other trees,"}, {"kind": "italic_en", "text": "in the hinder parts of sand-hills, the fine loose sand thereof inclining"}, {"kind": "text", "text": "upon her]: (AHn, TA:) but as some relate it,"}, {"kind": "arabic", "text_bw": "A^aSolFA qaAliSFA", "text_ar": "اَصْلًا قَالِصًا"}, {"kind": "text", "text": ". (TA. [See EM, p. 161.]) ―         -b2-"}, {"kind": "italic_en", "text": "A thing upon which another thing is built"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "founded"}, {"kind": "text", "text": "[either properly or tropically]: (KT, Kull p. 50, TA:) the"}, {"kind": "italic_en", "text": "foundation,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "basis,"}, {"kind": "text", "text": "of a thing, [either properly or tropically,]"}, {"kind": "italic_en", "text": "which being imagined to be taken away,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "abstracted, by its being taken away,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "abstracted, the rest thereof becomes also taken away,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "abstracted:"}, {"kind": "text", "text": "(Er-Rághib, TA:)"}, {"kind": "italic_en", "text": "that upon which the existence"}, {"kind": "text", "text": "of anything"}, {"kind": "italic_en", "text": "rests"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "depends"}, {"kind": "text", "text": "]; so the father is"}, {"kind": "arabic", "text_bw": "ASl", "text_ar": "اصل"}, {"kind": "text", "text": "to the offspring, and the river is"}, {"kind": "arabic", "text_bw": "ASl", "text_ar": "اصل"}, {"kind": "text", "text": "to the streamlet that branches off from it: (Msb:) or"}, {"kind": "italic_en", "text": "a thing upon which another thing depends as a branch;"}, {"kind": "text", "text": "as the father in relation to the son: (Kull:) [i. e. the"}, {"kind": "italic_en", "text": "origin, source, beginning,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "commencement,"}, {"kind": "text", "text": "of a thing: the"}, {"kind": "italic_en", "text": "origin, original, root, race,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock,"}, {"kind": "text", "text": "from which a man springs. Hence"}, {"kind": "arabic", "text_bw": "$aYo'N", "text_ar": "شَىْءٌ"}, {"kind": "arabic", "text_bw": "lahu A^aSolN", "text_ar": "لَهُ اَصْلٌ"}, {"kind": "italic_en", "text": "A thing having root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a foundation;"}, {"kind": "text", "text": "and consequently,"}, {"kind": "italic_en", "text": "having rootedness, fixedness, im-"}, {"kind": "italic_en", "text": "mobility, stability,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "permanence; rooted, fixed, immoveable, stable,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "permanent."}, {"kind": "text", "text": "Whence,]"}, {"kind": "arabic", "text_bw": "maAlN", "text_ar": "مَالٌ"}, {"kind": "arabic", "text_bw": "lahu A^aSolN", "text_ar": "لَهُ اَصْلٌ"}, {"kind": "text", "text": ", (Mgh voce"}, {"kind": "arabic", "text_bw": "EaqaArN", "text_ar": "عَقَارٌ"}, {"kind": "text", "text": ",) and"}, {"kind": "arabic", "text_bw": "milokN vaAbitN lahu A^aSolN", "text_ar": "مِلْكٌ ثَابِتٌ لَهُ اَصْلٌ"}, {"kind": "text", "text": ", (Msb in explanation of that word,) and"}, {"kind": "arabic", "text_bw": "maA lahu A^aSolN", "text_ar": "مَا لَهُ اَصْلٌ"}, {"kind": "text", "text": ", (KT in explanation of the same,) ["}, {"kind": "italic_en", "text": "Real,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "immoveable, property;] property such as consists in a house or land yielding a revenue;"}, {"kind": "text", "text": "(Mgh;) or"}, {"kind": "italic_en", "text": "such as a house and palm-trees;"}, {"kind": "text", "text": "(Msb;) or"}, {"kind": "italic_en", "text": "such as land and a house."}, {"kind": "text", "text": "(KT.) [Hence, also,"}, {"kind": "arabic", "text_bw": "A^aSolN maAlK", "text_ar": "اَصْلٌ مَالٍ"}, {"kind": "text", "text": "signifying"}, {"kind": "italic_en", "text": "A source of wealth"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "profit; a stock, fund, capital,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "principal."}, {"kind": "text", "text": "You say,]"}, {"kind": "arabic", "text_bw": "Ait~axa*otuhu linafosiY A^aSola maAlKliln~asoli laA lilit~ijaArapi", "text_ar": "اِتَّخَذْتُهُ لِنَفْسِى اَصْلَ مَالٍلِلنَّسْلِ لَا لِلِتِّجَارَةِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "I took it for myself as a source of wealth"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "profit, for breeding, not for traffic"}, {"kind": "text", "text": "]. (Mgh in art."}, {"kind": "arabic", "text_bw": "qnw", "text_ar": "قنو"}, {"kind": "text", "text": ".) You say also,"}, {"kind": "arabic", "text_bw": "baAEa A^aSola A^aroDihi", "text_ar": "بَاعَ اَصْلَ اَرْضِهِ"}, {"kind": "text", "text": "[meaning"}, {"kind": "italic_en", "text": "He sold the fundamental property, i. e. the property itself, of his land"}, {"kind": "text", "text": "]. (S voce"}, {"kind": "arabic", "text_bw": "EikorN", "text_ar": "عِكْرٌ"}, {"kind": "text", "text": ".) [See also an ex. in conjugation 4 in art."}, {"kind": "arabic", "text_bw": "bqaY", "text_ar": "بقَى"}, {"kind": "text", "text": ": and another in the first paragraph of art."}, {"kind": "arabic", "text_bw": "Hbs", "text_ar": "حبس"}, {"kind": "text", "text": ".] And"}, {"kind": "arabic", "text_bw": "A^axa*ahu biA^aSolihi", "text_ar": "اَخَذَهُ بِاَصْلِهِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He took it as it were with its root,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like;"}, {"kind": "text", "text": "meaning,"}, {"kind": "italic_en", "text": "entirely"}, {"kind": "text", "text": "]. (K. [See"}, {"kind": "arabic", "text_bw": "A^aSiylapN", "text_ar": "اَصِيلَةٌ"}, {"kind": "text", "text": ".]) And"}, {"kind": "arabic", "text_bw": "qaTaEa A^aSolahumo", "text_ar": "قَطَعَ اَصْلَهُمْ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He cut off their root, race,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock; i. e. he extirpated them"}, {"kind": "text", "text": "]. (M.) And"}, {"kind": "arabic", "text_bw": "fulaAnN fiY A^aSoli Sidoqi", "text_ar": "فُلَانٌ فِى اَصْلِ صِدْقِ"}, {"kind": "text", "text": ", (S and L in art."}, {"kind": "arabic", "text_bw": "DnA^", "text_ar": "ضنا"}, {"kind": "text", "text": ",) and"}, {"kind": "page_break", "n": 65}, {"kind": "arabic", "text_bw": "fiY A^aSoli suwo'K", "text_ar": "فِى اَصْلِ سُوْءٍ"}, {"kind": "text", "text": ", (L ibid.,)"}, {"kind": "italic_en", "text": "Such a one is of an excel-lent origin,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "race,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock,"}, {"kind": "text", "text": "(S, L,) and"}, {"kind": "italic_en", "text": "of a bad origin,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "race,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stock;"}, {"kind": "text", "text": "(L;)"}, {"kind": "arabic", "text_bw": "ASl", "text_ar": "اصل"}, {"kind": "text", "text": "being here syn. with"}, {"kind": "arabic", "text_bw": "Dino'", "text_ar": "ضِنْء"}, {"kind": "text", "text": "(S, L) and"}, {"kind": "arabic", "text_bw": "maEodin", "text_ar": "مَعْدِن"}, {"kind": "text", "text": ". (S.) And"}, {"kind": "arabic", "text_bw": "fulaAnN fiY A^aSoli Alkarami", "text_ar": "فُلَانٌ فِى اَصْلِ الكَرَمِ"}, {"kind": "italic_en", "text": "Such a one is of"}, {"kind": "text", "text": "[a race]"}, {"kind": "italic_en", "text": "the source of generosity,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "nobleness;"}, {"kind": "arabic", "text_bw": "ASl", "text_ar": "اصل"}, {"kind": "text", "text": "being here syn. with"}, {"kind": "arabic", "text_bw": "buw^obuw^", "text_ar": "بُوْبُو"}, {"kind": "text", "text": ". (S in art."}, {"kind": "arabic", "text_bw": "bA^", "text_ar": "با"}, {"kind": "text", "text": ".) And"}, {"kind": "arabic", "text_bw": "laA A^aSola", "text_ar": "لَا اَصْلَ"}, {"kind": "arabic", "text_bw": "lahu wa laA faSola", "text_ar": "لَهُ وَ لَا فَصْلَ"}, {"kind": "italic_en", "text": "He has no"}, {"kind": "arabic", "text_bw": "Hasab", "text_ar": "حَسَب"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "grounds of pretension to respect"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "honour;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rank,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "nobility,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like]; nor tongue [i. e. eloquence]:"}, {"kind": "text", "text": "(Ks, S, O, Msb:) or"}, {"kind": "italic_en", "text": "he has no intellect,"}, {"kind": "text", "text": "(IAar, Msb, El-Munáwee,)"}, {"kind": "italic_en", "text": "nor eloquence:"}, {"kind": "text", "text": "(El-Munáwee, TA:) or"}, {"kind": "italic_en", "text": "he has no lineage, nor tongue:"}, {"kind": "text", "text": "(L:) or"}, {"kind": "italic_en", "text": "he has no father, nor child:"}, {"kind": "text", "text": "(Kull p. 53:) [or"}, {"kind": "italic_en", "text": "he has no"}, {"kind": "text", "text": "known"}, {"kind": "italic_en", "text": "stock nor branch;"}, {"kind": "text", "text": "for]"}, {"kind": "arabic", "text_bw": "faSolN", "text_ar": "فَصْلٌ"}, {"kind": "text", "text": "is the contr. of"}, {"kind": "arabic", "text_bw": "A^aSolN", "text_ar": "اَصْلٌ"}, {"kind": "text", "text": ", and in relationship signifies"}, {"kind": "italic_en", "text": "a branch."}, {"kind": "text", "text": "(Msb in art."}, {"kind": "arabic", "text_bw": "fSl", "text_ar": "فصل"}, {"kind": "text", "text": ".) You say also,"}, {"kind": "arabic", "text_bw": "maA faEalotuhu A^aSolFA", "text_ar": "مَا فَعَلْتُهُ اَصْلًا"}, {"kind": "text", "text": ", meaning"}, {"kind": "italic_en", "text": "I have not done it ever;"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "I will not do it ever;"}, {"kind": "text", "text": "the last word being in the accus. case as an adverbial noun; i. e."}, {"kind": "italic_en", "text": "I have not done it at any time;"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "I will not do it at any time."}, {"kind": "text", "text": "(Msb, El-Munáwee, TA.) ―         -b3-  [It also signifies The"}, {"kind": "italic_en", "text": "original,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "elemental, matter, material, substance,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "part,"}, {"kind": "text", "text": "of a thing; syn. with"}, {"kind": "arabic", "text_bw": "EunoSurN", "text_ar": "عُنْصُرٌ"}, {"kind": "text", "text": ";]"}, {"kind": "italic_en", "text": "that from which a thing is taken"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "made"}, {"kind": "text", "text": "]. (KT voce"}, {"kind": "arabic", "text_bw": "daAxilN", "text_ar": "دَاخِلٌ"}, {"kind": "text", "text": ".) ―         -b4-  [The"}, {"kind": "italic_en", "text": "fundamental,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "essential, part"}, {"kind": "text", "text": "of a thing. Hence, sing. of"}, {"kind": "arabic", "text_bw": "A^uSuwlN", "text_ar": "اُصُولٌ"}, {"kind": "text", "text": "as signifying The"}, {"kind": "italic_en", "text": "fundamentals, fundamental articles"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "dogmas, principles, elements,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rudiments,"}, {"kind": "text", "text": "of a science &c. Whence,]"}, {"kind": "arabic", "text_bw": "Eilomu AlA^uSuwli", "text_ar": "عِلْمُ الاُصُولِ"}, {"kind": "text", "text": ", (TA,) [meaning]"}, {"kind": "arabic", "text_bw": "Eilomu", "text_ar": "عِلْمُ"}, {"kind": "arabic", "text_bw": "A^uSuwli Ald~iyni", "text_ar": "اُصُولِ الدِّينِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The science of the fundamentals, fundamental articles"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "dogmas,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "principles, of religion; the science of theology,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "divinity; according to the system of the Muslims, as distinguished from that of the philosophers;"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "the science of the articles,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "tenets, of belief;"}, {"kind": "text", "text": "also called"}, {"kind": "arabic", "text_bw": "Alfiqohu AlA^akobaru", "text_ar": "الفِقْهُ الاَكْبَرُ"}, {"kind": "text", "text": "; (Kull. voce"}, {"kind": "arabic", "text_bw": "fiqoh", "text_ar": "فِقْه"}, {"kind": "text", "text": ";) and [more commonly]"}, {"kind": "arabic", "text_bw": "Eilomu AlkalaAmi", "text_ar": "عِلْمُ الكَلَامِ"}, {"kind": "text", "text": ". (Hájjee Khaleefeh.) [See also 2.] ―         -b5-"}, {"kind": "italic_en", "text": "A radical"}, {"kind": "text", "text": "(as opposed to an augmentative)"}, {"kind": "italic_en", "text": "letter;"}, {"kind": "text", "text": "as being an essential element of a word. (The Lexicons passim.) ―         -b6-  The"}, {"kind": "italic_en", "text": "original form"}, {"kind": "text", "text": "of a word. (The same passim.) ―         -b7-  The"}, {"kind": "italic_en", "text": "original,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "primary, signification"}, {"kind": "text", "text": "of a word. (The same passim.) ―         -b8-"}, {"kind": "italic_en", "text": "An original copy"}, {"kind": "text", "text": "of a book: and"}, {"kind": "italic_en", "text": "a copy"}, {"kind": "text", "text": "of a book"}, {"kind": "italic_en", "text": "from which one quotes, or transcribes, any portion."}, {"kind": "text", "text": "(TA, &c., passim.) ―         -b9-  [The"}, {"kind": "italic_en", "text": "original,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "primary, state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition:"}, {"kind": "text", "text": "or] the"}, {"kind": "italic_en", "text": "old state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition."}, {"kind": "text", "text": "(Kull p. 50.) You say,"}, {"kind": "arabic", "text_bw": "AlA^aSolu fiY AlA^a$oyaA='i AlA_ibaAHapu wa AlT~ahaArapu", "text_ar": "الاَصْلُ فِى الاَشْيَا=ءِ الاـِبَاحَةُ وَ الطَّهَارَةُ"}, {"kind": "italic_en", "text": "The old state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition, of things is that of being allowable,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lawful, and that of being pure,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "clean."}, {"kind": "text", "text": "(Kull ubi suprà.) And"}, {"kind": "arabic", "text_bw": "rajaEato A_ilaY A^aSolihaA", "text_ar": "رَجَعَتْ اـِلَى اَصْلِهَا"}, {"kind": "italic_en", "text": "She returned,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "reverted,"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "to her original,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "old, state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "to her natural disposition;"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "to a natural disposition which she had relinquished."}, {"kind": "text", "text": "(S voce"}, {"kind": "arabic", "text_bw": "EitorN", "text_ar": "عِتْرٌ"}, {"kind": "text", "text": ".) ―         -b10-  [The"}, {"kind": "italic_en", "text": "utmost point,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "degree, to which a person,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "thing, can go,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "be brought"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "reduced:"}, {"kind": "text", "text": "and, app., the"}, {"kind": "italic_en", "text": "utmost that one can do."}, {"kind": "text", "text": "Hence the saying,]"}, {"kind": "arabic", "text_bw": "laA^aDoTar~an~aka A_ilaY A^aSolika", "text_ar": "لَاَضْطَرَّنَّكَ اـِلَى اَصْلِكَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "I will assuredly impel thee,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "drive thee, against thy will, to the utmost point to which thou canst go,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "be brought"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "reduced:"}, {"kind": "text", "text": "or,"}, {"kind": "italic_en", "text": "constrain thee to do thine utmost"}, {"kind": "text", "text": "]. (IAar in L, art."}, {"kind": "arabic", "text_bw": "qH", "text_ar": "قح"}, {"kind": "text", "text": "[where it is given in explanation of the phrases"}, {"kind": "arabic", "text_bw": "laA^aDoTar~an~aka", "text_ar": "لَاَضْطَرَّنَّكَ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "quHaAHika", "text_ar": "قُحَاحِكَ"}, {"kind": "text", "text": "; and so in the T in art."}, {"kind": "arabic", "text_bw": "tr", "text_ar": "تر"}, {"kind": "text", "text": "in explanation of the former of these two phrases; which is said in the M, in art."}, {"kind": "arabic", "text_bw": "tr", "text_ar": "تر"}, {"kind": "text", "text": ", to mean"}, {"kind": "italic_en", "text": "I will assuredly make thee to have recourse to thine utmost effort,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "endeavour;"}, {"kind": "text", "text": "and in the L in art."}, {"kind": "arabic", "text_bw": "qH", "text_ar": "قح"}, {"kind": "text", "text": "this is given as another explanation of the latter of the same two phrases. See also the saying,"}, {"kind": "arabic", "text_bw": "laA^ulojiy^an~aka A_ilaY qur~i qaraArika", "text_ar": "لَاُلْجِيَنَّكَ اـِلَى قُرِّ قَرَارِكَ"}, {"kind": "text", "text": ", explained voce"}, {"kind": "arabic", "text_bw": "qaraArN", "text_ar": "قَرَارٌ"}, {"kind": "text", "text": ".]) ―         -b11-  ["}, {"kind": "italic_en", "text": "That by being which a thing is what it is,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in being which it consists;"}, {"kind": "text", "text": "or its"}, {"kind": "italic_en", "text": "ultimate constituent;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "HaqiyqapN", "text_ar": "حَقِيقَةٌ"}, {"kind": "text", "text": "; a meaning well known; and indicated, in the A and TA, by the coupling of"}, {"kind": "arabic", "text_bw": "Haqiyqap", "text_ar": "حَقِيقَة"}, {"kind": "text", "text": "with"}, {"kind": "arabic", "text_bw": "A^aSol", "text_ar": "اَصْل"}, {"kind": "text", "text": ", evidently as an explicative adjunct.] ―         -b12-  [The"}, {"kind": "italic_en", "text": "prime"}, {"kind": "text", "text": "of a thing; the"}, {"kind": "italic_en", "text": "principal, purest, best,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "choicest, part thereof; what is,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "constitutes, the most essential part"}, {"kind": "text", "text": "thereof; its"}, {"kind": "italic_en", "text": "very essence."}, {"kind": "text", "text": "Hence,]"}, {"kind": "arabic", "text_bw": "A^aSolu daArK", "text_ar": "اَصْلُ دَارٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The principal part of a country"}, {"kind": "text", "text": "]; (As, S, Msb, K, voce"}, {"kind": "arabic", "text_bw": "EaqorN", "text_ar": "عَقْرٌ"}, {"kind": "text", "text": ";) [which is]"}, {"kind": "italic_en", "text": "the place where the people dwell,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "abide."}, {"kind": "text", "text": "(As and S ibid. [See"}, {"kind": "arabic", "text_bw": "EaqorN", "text_ar": "عَقْرٌ"}, {"kind": "text", "text": ".]) And"}, {"kind": "arabic", "text_bw": "A^aSolN", "text_ar": "اَصْلٌ"}, {"kind": "arabic", "text_bw": "qawomK", "text_ar": "قَوْمٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The principal place of abode of a people"}, {"kind": "text", "text": "]. (S and K voce"}, {"kind": "arabic", "text_bw": "bayoDapN", "text_ar": "بَيْضَةٌ"}, {"kind": "text", "text": ". [See this word.]) And"}, {"kind": "arabic", "text_bw": "huwa fiY A^aSoli qawomihi", "text_ar": "هُوَ فِى اَصْلِ قَوْمِهِ"}, {"kind": "italic_en", "text": "He is of the prime,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "of the purest in race, the best,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the choicest, of his people;"}, {"kind": "text", "text": "i. q."}, {"kind": "arabic", "text_bw": "Suy~aAbatihimo", "text_ar": "صُيَّابَتِهِمْ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "Suy~aAbihimo", "text_ar": "صُيَّابِهِمْ"}, {"kind": "text", "text": ". (TA in art."}, {"kind": "arabic", "text_bw": "Syb", "text_ar": "صيب"}, {"kind": "text", "text": ".) ―         -b13-"}, {"kind": "italic_en", "text": "What is most fit,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "proper:"}, {"kind": "text", "text": "as when one says,"}, {"kind": "arabic", "text_bw": "AlA^aSolu fiY AlA_inosaAni AlEilomu", "text_ar": "الاَصْلُ فِى الاـِنْسَانِ العِلْمُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "What is most fit,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "proper, in man, is knowledge"}, {"kind": "text", "text": "]; i. e., knowledge is more fit, or proper, than ignorance: and"}, {"kind": "arabic", "text_bw": "AlA^aSolu fiY AlmubotadaA_i Alt~aqodiymu", "text_ar": "الاَصْلُ فِى المُبْتَدَاـِ التَّقْدِيمُ"}, {"kind": "italic_en", "text": "What is"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "most"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "fit,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "proper, in the case of the inchoative, is the putting"}, {"kind": "text", "text": "[it]"}, {"kind": "italic_en", "text": "before"}, {"kind": "text", "text": "[the enunciative], whenever there is no obstacle. (Kull p.50.) ―         -b14-"}, {"kind": "italic_en", "text": "What is preponderant in relation to what is preponderated:"}, {"kind": "text", "text": "as, in language, the word used in its proper sense [in relation to that used in a tropical sense]. (Kull ibid.) ―         -b15-"}, {"kind": "italic_en", "text": "What is"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "essential,"}, {"kind": "text", "text": "or]"}, {"kind": "italic_en", "text": "requisite,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "needful:"}, {"kind": "text", "text": "as when one says"}, {"kind": "arabic", "text_bw": "AlA^aSolu fiY AlHayawaAni Algi*aA='u", "text_ar": "الاَصْلُ فِى الحَيَوَانِ