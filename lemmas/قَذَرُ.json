{"lemma":"قَذَرُ","slug":"قَذَرُ","root":"ق.ذ.ر","root_slug":"ق-ذ-ر","root_link":"/words/roots/ق-ذ-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n35327","","n35329","n35330","n35331","n35332"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B0%D9%8E%D8%B1%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be dirty, unclean"},{"pos":"verb","gloss":"to be dirty, unclean (of clothes, etc.)"},{"pos":"verb","gloss":"to dirty, to soil, to make dirty"},{"pos":"verb","gloss":"to find (something) dirty"},{"pos":"verb","gloss":"to hate (a place) due to its filthiness"},{"pos":"verb","gloss":"to make dirty, unclean"},{"pos":"verb","gloss":"to make dirty, to foul"},{"pos":"verb","gloss":"to accuse of impurity"},{"pos":"noun","gloss":"dirtiness, uncleanliness"},{"pos":"noun","gloss":"feces, stool, excrement"},{"pos":"adj","gloss":"dirty, unclean"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35327","headword_ar":"قَذِرَ","root":"q*r","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (Lth, Mgh, Msb, K;) and"},{"kind":"arabic","text_bw":"qa*ura","text_ar":"قَذُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Lth, Mgh, K;) and"},{"kind":"arabic","text_bw":"qa*ara","text_ar":"قَذَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n."},{"kind":"arabic","text_bw":"qa*arN","text_ar":"قَذَرٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,) of"},{"kind":"arabic","text_bw":"qa*ira","text_ar":"قَذِرَ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"qa*aArapN","text_ar":"قَذَارَةٌ"},{"kind":"text","text":", (S, Mgh, K,) of"},{"kind":"arabic","text_bw":"qa*ura","text_ar":"قَذُرَ"},{"kind":"text","text":"; (Lth;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Mgh, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unclean, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"(S, Mgh, Msb.)       -A2-"},{"kind":"arabic","text_bw":"qa*irahu","text_ar":"قَذِرَهُ"},{"kind":"text","text":". (S, Mgh, Msb, K,) aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"qa*arahu","text_ar":"قَذَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n. [of the former]"},{"kind":"arabic","text_bw":"qa*arN","text_ar":"قَذَرٌ"},{"kind":"text","text":", and [of the latter]"},{"kind":"arabic","text_bw":"qa*orN","text_ar":"قَذْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"tq*~rhu","text_ar":"تقذّرهُ","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Astq*rhu","text_ar":"استقذرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, Msb, K;) [and ↓"},{"kind":"arabic","text_bw":"q*~rhu","text_ar":"قذّرهُ","orth_type":"arrow"},{"kind":"text","text":"; (see"},{"kind":"arabic","text_bw":"qaA*uwrapN","text_ar":"قَاذُورَةٌ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"He held it to be unclean, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he disliked it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated it, for its uncleanness, dirtiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthiness:"},{"kind":"text","text":"(Msb:) or (assumed tropical:)"},{"kind":"italic_en","text":"he disliked it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated it:"},{"kind":"text","text":"(S.) or (assumed tropical:)"},{"kind":"italic_en","text":"he shunned it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided it, through dislike,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred:"},{"kind":"text","text":"(Mgh:)"},{"kind":"arabic","text_bw":"qa*irahu","text_ar":"قَذِرَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Astq*rhu","text_ar":"استقذرهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tqd~r","text_ar":"تقدّر","orth_type":"arrow"},{"kind":"text","text":"are syn. [in this last, or a similar, sense]: (Lth:) and"},{"kind":"arabic","text_bw":"qa*arahu","text_ar":"قَذَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", signifies (tropical:)"},{"kind":"italic_en","text":"he disliked it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated it,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"shunned it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided it:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"taqa*~arato","text_ar":"تَقَذَّرَتْ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"shunned, avoided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed herself far from, unclean things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul actions; preserved herself therefrom."},{"kind":"text","text":"(S.) It is said in a trad.,"},{"kind":"arabic","text_bw":"qa*irotu lakumo","text_ar":"قَذِرْتُ لَكُمْ"},{"kind":"arabic","text_bw":"jaw~aAla AlquraY","text_ar":"جَوَّالَ القُرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I dislike, for you, what goes round about the towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages"},{"kind":"text","text":"], meaning, I dislike, for you, oxen and cows that eat filth; therefore do not ye eat them. (Mgh.) And El-'Ajjáj says"},{"kind":"quote","text":"waqa*ariY maA layosa bimaqo*uwri"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"And my disliking what was not disliked"},{"kind":"text","text":"], meaning, that he had come to dislike ("},{"kind":"arabic","text_bw":"yaqo*aru","text_ar":"يَقْذَرُ"},{"kind":"text","text":") the food which he did not dislike in his youth. (TA.)"}],"source_refs":["S","Mgh","Msb","K","Lth","TA"]},{"entry_id":"n35329","headword_ar":"قَذْرٌ","root":"q*r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qa*irN","text_ar":"قَذِرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35330","headword_ar":"قَذَرٌ","root":"q*r","body":[{"kind":"text","text":": see 1. ―         -b2-  [As a simple subst.,"},{"kind":"italic_en","text":"Uncleanness, dirt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"an unclean, a dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a filthy, thing:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aqo*aArN","text_ar":"اَقْذَارٌ"},{"kind":"text","text":":] also,"},{"kind":"italic_en","text":"dirt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth, which renders one legally impure:"},{"kind":"text","text":"(Az, Msb:) ↓"},{"kind":"arabic","text_bw":"qaA*uwrapN","text_ar":"قَاذُورَةٌ","orth_type":"arrow"},{"kind":"text","text":"is likewise used in the sense of"},{"kind":"arabic","text_bw":"qa*arN","text_ar":"قَذَرٌ"},{"kind":"text","text":": (Msb:) and [hence] both these words also signify (tropical:)"},{"kind":"italic_en","text":"a foul action:"},{"kind":"text","text":"(TA, for this meaning of"},{"kind":"arabic","text_bw":"qa*arN","text_ar":"قَذَرٌ"},{"kind":"text","text":", accord. to an explanation of its pl."},{"kind":"arabic","text_bw":"A^aqo*aArN","text_ar":"اَقْذَارٌ"},{"kind":"text","text":"; and L, Msb, for the same meaning of"},{"kind":"arabic","text_bw":"qaA*uwrapN","text_ar":"قَاذُورَةٌ"},{"kind":"text","text":":)"},{"kind":"arabic","text_bw":"qaA*uwrapN","text_ar":"قَاذُورَةٌ"},{"kind":"text","text":"is also explained as signifying"},{"kind":"italic_en","text":"adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication,"},{"kind":"text","text":"(Msb, K,) and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(Msb:) or this latter word signifies"},{"kind":"italic_en","text":"anything that is deemed foul"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yusotafoHa$u","text_ar":"يُسْتَفْحَشُ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and that ought to be shunned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided:"},{"kind":"text","text":"(Mgh:)"},{"kind":"italic_en","text":"an offence for which a punishment such as is termed"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"italic_en","text":"is inflicted; such as adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"drinking"},{"kind":"text","text":"["},{"kind":"italic_en","text":"wine"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]: (IAth:) or"},{"kind":"italic_en","text":"foul action,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"evil speech."},{"kind":"text","text":"(Khálid Ibn-Jembeh.) You say"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"yatanaz~ahu Eani Alqa*ari","text_ar":"يَتَنَزَّهُ عَنِ القَذَرِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlqaA*uwraAti","text_ar":"القَاذُورَاتِ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"AlA^aqo*aAri","text_ar":"الاَقْذَارِ"},{"kind":"text","text":", (S,) ["},{"kind":"italic_en","text":"He shuns, avoids,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removes himself far from, that which is unclean,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unclean things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul conduct,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"foul actions; preserves himself therefrom."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"A@l~atiY nahaY","text_ar":"ا@لَّتِى نَهَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_ijotanibuwA AlqaA*uwwaraAti","text_ar":"اـِجْتَنِبُوا القَاذُووَرَاتِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"A@ll~`hu EanohaA","text_ar":"ا@للّٰهُ عَنْهَا"},{"kind":"italic_en","text":"Shun ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoid ye, the foul actions, such as adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication, and the like, which God hath forbidden."},{"kind":"text","text":"(Msb.)       -A2-  See also"},{"kind":"arabic","text_bw":"qa*irN","text_ar":"قَذِرٌ"},{"kind":"text","text":"."}],"source_refs":["Az","Msb","K","Mgh","IAth","S"]},{"entry_id":"n35331","headword_ar":"قَذُرٌ","root":"q*r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qa*irN","text_ar":"قَذِرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35332","headword_ar":"قَذِرٌ","root":"q*r","body":[{"kind":"text","text":", (Lth, S, Mgh, Msb, K,) from"},{"kind":"arabic","text_bw":"qa*ira","text_ar":"قَذِرَ"},{"kind":"text","text":", (Lth.) and ↓"},{"kind":"arabic","text_bw":"qa*orN","text_ar":"قَذْرٌ","orth_type":"arrow"},{"kind":"text","text":", (Lth, K,) from"},{"kind":"arabic","text_bw":"qa*ura","text_ar":"قَذُرَ"},{"kind":"text","text":", (Lth,) and ↓"},{"kind":"arabic","text_bw":"qa*urN","text_ar":"قَذُرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qa*arN","text_ar":"قَذَرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [but the last has an intensive signification, as though meaning “ dirt, ” or “ filth, ” itself, (see"},{"kind":"arabic","text_bw":"Eur~apN","text_ar":"عُرَّةٌ"},{"kind":"text","text":",)] A thing"},{"kind":"italic_en","text":"unclean, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"(S, Mgh, Msb.)"}],"source_refs":["Lth","S","Mgh","Msb","K"]}]}}