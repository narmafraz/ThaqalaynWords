,"gen":"m","num":"p"},{"role":"present_2mp","form":"تُمَرِّضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُمَرِّضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُمَرِّض","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُمَرِّض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُمَرِّضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُمَرِّضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُمَرِّضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمَرِّضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُمَرِّضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمَرِّضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُمَرِّضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُمَرِّض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمَرِّض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"مَرَّضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مَرَّضْتُ","in_corpus":true,"count":17,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":139,"cross_references":{"qac":{"found":true,"lemma_key":"مَرَّضَ","root":"مرض","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n38477","n38483","n38484","n38485"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B1%D9%8E%D9%91%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become sick","examples":[{"text":"وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِ","english":"and when I get sick it is He who cures me"}]},{"pos":"verb","gloss":"to nurse the sick","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of مَرِضَ (mariḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"disease, sickness, illness"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *maraṣ̂- (“to be ill”). Compare Biblical Hebrew נִמְרַץ (nimraṣ, “to be sore”) and Ugaritic 𐎎𐎗𐎕 (mrṣ)."},"ipa":["/ma.ri.dˤa/","/mar.ra.dˤa/","/ma.radˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38477","headword_ar":"مَرِضَ","root":"mrD","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ"},{"kind":"text","text":", (Msb, K,) which latter is a dial. form rarely used, (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, or an animal [of any kind], Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"diseased, disordered, distempered, sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ill;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"in the state termed"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"(S, Msb, K) denoting that change of the constitution or temperament which is described in the explanation of this term below; (K;) as also ↓"},{"kind":"arabic","text_bw":"AmrD","text_ar":"امرض","orth_type":"arrow"},{"kind":"text","text":", expl. by"},{"kind":"arabic","text_bw":"SaAra *aA","text_ar":"صَارَ ذَا"},{"kind":"arabic","text_bw":"maraDK","text_ar":"مَرَضٍ"},{"kind":"text","text":". (K, TA; but not in the CK.) ―         -b2-  [Hence,"},{"kind":"arabic","text_bw":"mariDati AlEayonu","text_ar":"مَرِضَتِ العَيْنُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The eye became languid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languishing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weak:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":":) or, as Golius says, on the authority of Ibn-Maaroof,"},{"kind":"italic_en","text":"was weak from much,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"too much, looking."},{"kind":"text","text":"] ―         -b3-  And"},{"kind":"arabic","text_bw":"mariDati All~ayolapu","text_ar":"مَرِضَتِ اللَّيْلَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The night became dark."},{"kind":"text","text":"(Th, O.) ―         -b4-  [The verb probably has several other tropical significations agreeable with explanations of"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":"which will be found below.]"}],"source_refs":["S","Msb","K"]},{"entry_id":"n38483","headword_ar":"مَرْضٌ","root":"mrD","body":[{"kind":"text","text":": see 1: and see what here next follows, in six places."}],"source_refs":[]},{"entry_id":"n38484","headword_ar":"مَرَضٌ","root":"mrD","body":[{"kind":"text","text":"(IDrd, S, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb, K:) see 1:"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"suqomN","text_ar":"سُقْمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Disease, disorder, distemper, sickness, illness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"malady"},{"kind":"text","text":"]; (IDrd, S;) which is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"SiH~apN","text_ar":"صِحَّةٌ"},{"kind":"text","text":"; and affects man and the camel [&c.]: (IDrd:) or"},{"kind":"italic_en","text":"a certain state foreign to the constitution"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"temperament, injurious to the intellect;"},{"kind":"text","text":"whence it is known that pains and tumours are accidents arising therefrom: or, as IF says,"},{"kind":"italic_en","text":"that whereby a man passes beyond the limit of health"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rectitude, whether it be disease"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eil~ap","text_ar":"عِلَّة"},{"kind":"text","text":"),"},{"kind":"page_break","n":2709},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"hypocrisy,"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"a falling short of doing what he ought to do in an affair:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a dark and disordered state of the constitution"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"temperament, after a clear and right state thereof:"},{"kind":"text","text":"(O, K:) or ↓"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ","orth_type":"arrow"},{"kind":"text","text":"is (assumed tropical:)  ["},{"kind":"italic_en","text":"a disease"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the heart:"},{"kind":"text","text":"(K:) Aboo-Is-hák says,"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suqomN","text_ar":"سُقْمٌ"},{"kind":"text","text":"are said to be in the body and (assumed tropical:)  in religion, like as"},{"kind":"arabic","text_bw":"SiH~apN","text_ar":"صِحَّةٌ"},{"kind":"text","text":"is said to be in the body and in religion; and ↓"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ","orth_type":"arrow"},{"kind":"text","text":"is in the heart, applying to (assumed tropical:)"},{"kind":"italic_en","text":"everything whereby a man quits a state of soundness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rectitude in religion:"},{"kind":"text","text":"(TA:) and As says, I recited to Aboo-'Amr Ibn-El-'Alà [the words of the Kur, ii. 9, &c.,]"},{"kind":"arabic","text_bw":"fiY quluwbihimo maraDN","text_ar":"فِى قُلُوبِهِمْ مَرَضٌ"},{"kind":"text","text":"and he said to me ↓ “"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ"},{"kind":"text","text":", O boy ”: (AHát, IDrd, Msb:) and"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":", or this and ↓"},{"kind":"arabic","text_bw":"maroDN","text_ar":"مَرْضٌ","orth_type":"arrow"},{"kind":"text","text":"also, signifies (assumed tropical:)"},{"kind":"italic_en","text":"doubt:"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"hypocrisy:"},{"kind":"text","text":"(K:) and (assumed tropical:)"},{"kind":"italic_en","text":"weakness of belief:"},{"kind":"text","text":"(TA:) and the former, (TA,) or ↓ both, (K,) (assumed tropical:)"},{"kind":"italic_en","text":"languor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languidness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weakness:"},{"kind":"text","text":"(K:) and (assumed tropical:)"},{"kind":"italic_en","text":"darkness"},{"kind":"text","text":"(IAar, K) in the heart: (IAar:) and (assumed tropical:)"},{"kind":"italic_en","text":"defectiveness; deficiency;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection;"},{"kind":"text","text":"(IAar, K;) which last is said by IAar to be the primary signification: (TA:) or"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"in the body is"},{"kind":"italic_en","text":"a languor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languidness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weakness, of the limbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members:"},{"kind":"text","text":"and in the eye, (assumed tropical:)"},{"kind":"italic_en","text":"weakness of sight:"},{"kind":"text","text":"and in the heart, (assumed tropical:)"},{"kind":"italic_en","text":"a flagging,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remissness, in respect of the truth:"},{"kind":"text","text":"(Ibn-'Arafeh:) or it properly signifies"},{"kind":"italic_en","text":"an accidental affection of the body, which puts it out of the right state proper to it, and necessarily occasions interruption,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infirmity, in its actions:"},{"kind":"text","text":"and tropically, (tropical:)"},{"kind":"italic_en","text":"affections of the mind, which interrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mar, its integrity;"},{"kind":"text","text":"such as (tropical:)"},{"kind":"italic_en","text":"ignorance;"},{"kind":"text","text":"and (tropical:)"},{"kind":"italic_en","text":"evil belief;"},{"kind":"text","text":"and (tropical:)"},{"kind":"italic_en","text":"envy;"},{"kind":"text","text":"and (tropical:)"},{"kind":"italic_en","text":"malevolence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"malice;"},{"kind":"text","text":"and (tropical:)"},{"kind":"italic_en","text":"love of acts of disobedience;"},{"kind":"text","text":"for these prevent from the attaining of excellences, or lead to the cessation of true eternal life: (Bd, ii. 9:) it is a gen. n.: (IDrd:) and the n. un. is ↓"},{"kind":"arabic","text_bw":"maroDapN","text_ar":"مَرْضَةٌ","orth_type":"arrow"},{"kind":"text","text":": (A, TA:) it is one of the inf. ns. which have pls., like"},{"kind":"arabic","text_bw":"$ugolN","text_ar":"شُغْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaqolN","text_ar":"عَقْلٌ"},{"kind":"text","text":"; the pls. of these three being"},{"kind":"arabic","text_bw":"A^amoraADN","text_ar":"اَمْرَاضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^a$ogaAlN","text_ar":"اَشْغَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuquwlN","text_ar":"عُقُولٌ"},{"kind":"text","text":". (Sb.)"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"arabic","text_bw":"qulowbihimo maraDN","text_ar":"قُلْوبِهِمْ مَرَضٌ"},{"kind":"text","text":", in the Kur, [ii. 9, &c.,] means (assumed tropical:)"},{"kind":"italic_en","text":"In their hearts is doubt:"},{"kind":"text","text":"(AO:) or (assumed tropical:)"},{"kind":"italic_en","text":"doubt and hypocrisy."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Al~a*iY fiY qalobihi maraDN","text_ar":"الَّذِى فِى قَلْبِهِ مَرَضٌ"},{"kind":"text","text":", in the same, [xxxiii. 32,] (assumed tropical:)"},{"kind":"italic_en","text":"In whose heart is darkness:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"flagging,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remissness, in respect of what is commanded and what is forbidden:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"love of adultery"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"hypocrisy."},{"kind":"text","text":"(A.)"}],"source_refs":["IDrd","S","O","Msb","K","TA","IAar","A","AO"]},{"entry_id":"n38485","headword_ar":"مَرِضٌ","root":"mrD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}