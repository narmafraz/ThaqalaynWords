{"lemma":"مَطْلَبٌ","slug":"مَطْلَبٌ","root":"ط.ل.ب","root_slug":"ط-ل-ب","root_link":"/words/roots/ط-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n26907"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B7%D9%92%D9%84%D9%8E%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of طَلَبَ (ṭalaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"something sought"}]},"etymology":null,"ipa":["/matˤ.lab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26907","headword_ar":"مَطْلَبٌ","root":"Tlb","body":[{"kind":"italic_en","text":"A place,"},{"kind":"text","text":"(Msb, KL,) or"},{"kind":"italic_en","text":"time,"},{"kind":"text","text":"(KL,)"},{"kind":"italic_en","text":"of seeking:"},{"kind":"text","text":"(Msb, KL:) [and so ↓"},{"kind":"arabic","text_bw":"muT~alabN","text_ar":"مُطَّلَبٌ","orth_type":"arrow"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"maTaAlibu","text_ar":"مَطَالِبُ"},{"kind":"text","text":". (KL.) [And particularly applied to"},{"kind":"italic_en","text":"A place in which treasure is buried and sought."},{"kind":"text","text":"And"},{"kind":"italic_en","text":"A place where anything remarkable is to be sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looked for, in a book."},{"kind":"text","text":"] ―         -b2-  [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"A person from whom one seeks a thing."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"layosa liY maTolabN siwaAka","text_ar":"لَيْسَ لِى مَطْلَبٌ سِوَاكَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I have none from whom to seek the accomplishment of my desires but Thee"},{"kind":"text","text":"] occurs in a trad. respecting prayer. (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"maToluwbN","text_ar":"مَطْلُوبٌ"},{"kind":"text","text":". ―         -b4-  It is also an inf. n. of 1 [q. v.]. (A, MA, Msb.)"}],"source_refs":["Msb","KL"]}]},"classical_definitions":null}