{"lemma":"مارِدٌ","slug":"مارِدٌ","root":"م.ر.د","root_slug":"م-ر-د","root_link":"/words/roots/م-ر-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مارِد","root":"مرد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n38453"],"search_url":"https://lanelexicon.com/?s=%D9%85%D8%A7%D8%B1%D9%90%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"recalcitrant, defiant, rebellious, lawless, mutinous, insubordinate, insurrectionary, contumacious"},{"pos":"adj","gloss":"gigantic, giant, giantlike, titanic"},{"pos":"noun","gloss":"rebel, insurgent, mutineer"},{"pos":"noun","gloss":"demon, devil, fiend, evil spirit"},{"pos":"noun","gloss":"bashi-bazouk (irregular Turkish soldier)"},{"pos":"noun","gloss":"giant"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb مَرَدَ (marada, “to be rebellious”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38453","headword_ar":"مَارِدٌ","root":"mrd","body":[{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"marada","text_ar":"مَرَدَ"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"mariydN","text_ar":"مَرِيدٌ","orth_type":"arrow"},{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"maruda","text_ar":"مَرُدَ"},{"kind":"text","text":"] (S, M, A, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"mutamar~idN","text_ar":"مُتَمَرِّدٌ","orth_type":"arrow"},{"kind":"text","text":"(A, K) [One"},{"kind":"italic_en","text":"who exalts himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is insolent and audacious, in pride and in acts of rebellion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedience; an insolent and audacious rebel"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unbeliever;"},{"kind":"text","text":"see 1;]"},{"kind":"italic_en","text":"bold"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"audacious;"},{"kind":"text","text":"(M, L, K;)"},{"kind":"italic_en","text":"and immoderate, inordinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitant;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, immoderately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inordinately, proud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unbelieving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedient"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellious; &c.;"},{"kind":"text","text":"see 1; (S, M, A, L, Msb, K;)"},{"kind":"italic_en","text":"and strong:"},{"kind":"text","text":"(L:) these epithets are applied to evil beings of mankind and of the jinn, (L,) and to any animal: (M, L:) the first is said to be applied to an evil jinnee of the most powerful class: (Mir-át ez-Zemán, &c.) pl. (of the first, M, L,)"},{"kind":"arabic","text_bw":"maradapN","text_ar":"مَرَدَةٌ"},{"kind":"text","text":"(M, L, K) and"},{"kind":"arabic","text_bw":"mur~aAdN","text_ar":"مُرَّادٌ"},{"kind":"text","text":"; (A;) and (of the second, M, L)"},{"kind":"arabic","text_bw":"muradaA='u","text_ar":"مُرَدَا=ءُ"},{"kind":"text","text":". (M, L, K.) ↓"},{"kind":"arabic","text_bw":"mir~iydN","text_ar":"مِرِّيدٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same in an intensive degree. (S, L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"maAridN","text_ar":"مَارِدٌ"},{"kind":"italic_en","text":"Lofty, high:"},{"kind":"text","text":"(L, K:) applied to a building. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maAridN","text_ar":"مَارِدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maruwdN","text_ar":"مَرُودٌ","orth_type":"arrow"},{"kind":"text","text":"One"},{"kind":"italic_en","text":"who often goes and comes, by reason of his briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness."},{"kind":"text","text":"(L.)"}],"source_refs":["S","M","A","L","Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%A7%D8%B1%D8%AF/","headword_ar":"ماردينيّ","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=99844#673d66","body_html":"ماردينيّ<br>نسبة إلى ماردين: بلدة بتركيا."}]}}