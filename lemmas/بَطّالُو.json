{"lemma":"بَطّالُو","slug":"بَطّالُو","root":"ب.ط.ل","root_slug":"ب-ط-ل","root_link":"/words/roots/ب-ط-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n2792"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B7%D9%91%D8%A7%D9%84%D9%8F%D9%88"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2792","headword_ar":"بَطَّالٌ","root":"bTl","body":[{"kind":"text","text":", applied to a man, signifies"},{"kind":"arabic","text_bw":"bay~inN","text_ar":"بَيِّنٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*uw baATilK","text_ar":"ذُو بَاطِلٍ","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlbuTuwli","text_ar":"البُطُولِ","orth_type":"arrow"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"Having a vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false, object"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursuit; manifesting the having such an object"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursuit:"},{"kind":"text","text":"or, accord. to an explanation of"},{"kind":"arabic","text_bw":"*w bATl","text_ar":"ذو باطل"},{"kind":"text","text":"by Bd in xxxviii. 26,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"muboTilN","text_ar":"مُبْطِلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAbivN","text_ar":"عَابِثٌ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"jesting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joking;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"baTala fiY","text_ar":"بَطَلَ فِى"},{"kind":"arabic","text_bw":"Hadiyvihi","text_ar":"حَدِيثِهِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"baTila","text_ar":"بَطِلَ"},{"kind":"text","text":";) or"},{"kind":"italic_en","text":"saying what is untrue:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"playing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sporting,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"doing that in which is no profit;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"baATilN","text_ar":"بَاطِلٌ","orth_type":"arrow"},{"kind":"text","text":", q. v.]: (K:) one"},{"kind":"italic_en","text":"who jests,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jokes, in his discourse:"},{"kind":"text","text":"one"},{"kind":"italic_en","text":"who is diverted from that which would bring profit in the present life or in that which is to come:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"idle; unoccupied:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"exceedingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extremely, idle:"},{"kind":"text","text":"(KL:) or"},{"kind":"italic_en","text":"unoccupied and lazy;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mutabaT~ilN","text_ar":"مُتَبَطِّلٌ","orth_type":"arrow"},{"kind":"text","text":". (Mgh.) [In the present day it is commonly used as signifying"},{"kind":"italic_en","text":"Bad, worthless,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"useless;"},{"kind":"text","text":"applied to a man and to anything.]       -A2-  See also"},{"kind":"arabic","text_bw":"baTalN","text_ar":"بَطَلٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA","S","Msb","KL"]}]},"classical_definitions":null}