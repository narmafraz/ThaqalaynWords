on them;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"came upon them from every quarter,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"abundantly and suddenly."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"Anfjr biA@lokarami","text_ar":"انفجر بِا@لْكَرَمِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tfj~r","text_ar":"تفجّر","orth_type":"arrow"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He was profuse of generosity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liberality"},{"kind":"text","text":"]: (K:) and"},{"kind":"arabic","text_bw":"fiY Alxayori","text_ar":"فِى الخَيْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tfj~r","text_ar":"تفجّر","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"he was profuse in bounty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beneficence"},{"kind":"text","text":"]. (S, O, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Anfjr","text_ar":"انفجر"},{"kind":"arabic","text_bw":"AlS~uboHu","text_ar":"الصُّبْحُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tfj~r","text_ar":"تفجّر","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The dawn broke forth"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Anfjr Eanohu All~ayolu","text_ar":"انفجر عَنْهُ اللَّيْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The night departed from before it;"},{"kind":"text","text":"namely, the rising dawn]. (K.)"}],"source_refs":["S","O","Msb","K"]}]},"classical_definitions":null}