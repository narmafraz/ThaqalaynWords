"arabic","text_bw":"daniYo'N","text_ar":"دَنِىْءٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n13221","headword_ar":"دانى","root":"dnw","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mudaAnaApN","text_ar":"مُدَانَاةٌ"},{"kind":"text","text":": see 1, in two places. You say also,"},{"kind":"arabic","text_bw":"daAnayotu AlA^amora","text_ar":"دَانَيْتُ الاَمْرَ"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experiencing,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(M.) ―         -b2-"},{"kind":"arabic","text_bw":"daAnayotu Alqayoda lilobaEiyri","text_ar":"دَانَيْتُ القَيْدَ لِلْبَعِيرِ"},{"kind":"italic_en","text":"I made the shackles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hobbles, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted, to the camel."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"daAnaY Alqayodu qayonaYi AlbaEiyri","text_ar":"دَانَى القَيْدُ قَيْنَىِ البَعِيرِ"},{"kind":"text","text":"(M, TA)"},{"kind":"italic_en","text":"The shackles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hobbles, straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the two parts of the camel that were the places thereof."},{"kind":"text","text":"] (TA.) Dhu-r-Rummeh says,"},{"kind":"quote","text":"daAnaY lahu Alqayodu fiY dayomuwmapK qa*afK\n                      \n                     \n                        qayonayohi waA@noHasarato Eanohu AlA^anaAEiymu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The shackles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hobbles, straitened to him, in a far-extending, wide desert, the two parts of him that were the places thereof, and enjoyments became removed from him"},{"kind":"text","text":"]. (M.) And you say also,"},{"kind":"arabic","text_bw":"daAnayotu bayona AlA^amorayoni","text_ar":"دَانَيْتُ بَيْنَ الاَمْرَيْنِ"},{"kind":"italic_en","text":"I made the two affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"events, to be nearly uninterrupted;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaArabotu","text_ar":"قَارَبْتُ"},{"kind":"text","text":": (T, S, Msb:) or"},{"kind":"italic_en","text":"I made the two affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"events, to be connected;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jamaEotu","text_ar":"جَمَعْتُ"},{"kind":"text","text":". (M.)"}],"source_refs":["M","TA","T","S","Msb"]}]},"classical_definitions":null}