","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْتَجِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْتَجِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْتَجِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْتَجِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْتَجِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْتَجِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْتَجِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْتَجِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْتَجِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْتَجِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْتَجِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"اِرْتَجَلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِرْتَجَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَرْتَجِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْتَجِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n14924"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B1%D9%92%D8%AA%D9%8E%D8%AC%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14924","headword_ar":"ارتجل","root":"rjl","body":[{"kind":"text","text":": see 1, first sentence. ―         -b2-  Said of a horse, (in his running, TA,)"},{"kind":"italic_en","text":"He mixed the pace termed"},{"kind":"arabic","text_bw":"AlEanaq","text_ar":"العَنَق"},{"kind":"italic_en","text":"with that termed"},{"kind":"arabic","text_bw":"Alhamolajap","text_ar":"الهَمْلَجَة"},{"kind":"text","text":", (T, TA,) or"},{"kind":"italic_en","text":"the former pace with somewhat of the latter, and thus,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"he went those two paces alternately,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"somewhat of the former and somewhat of the latter."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"italic_en","text":"He took"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"by his"},{"kind":"arabic","text_bw":"rijol","text_ar":"رِجْل"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot"},{"kind":"text","text":"]. (S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Artjl Al$~aApa","text_ar":"ارتجل الشَّاةَ"},{"kind":"text","text":": see 1, in the middle of the paragraph. ―         -b3-"},{"kind":"arabic","text_bw":"Artjl","text_ar":"ارتجل"},{"kind":"arabic","text_bw":"Alr~anoda","text_ar":"الرَّنْدَ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"Alz~anodapa","text_ar":"الزَّنْدَةَ"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Artjl","text_ar":"ارتجل"},{"kind":"text","text":"alone in a similar sense: see 5, in two places.       -A3-  ["},{"kind":"italic_en","text":"He extemporized"},{"kind":"text","text":"a speech or verses;"},{"kind":"italic_en","text":"spoke"},{"kind":"text","text":"it or them"},{"kind":"italic_en","text":"extemporaneously, impromptu,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without premeditation;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he began"},{"kind":"text","text":"an oration (a"},{"kind":"arabic","text_bw":"xuTobap","text_ar":"خُطْبَة"},{"kind":"text","text":"), and poetry,"},{"kind":"italic_en","text":"without his having prepared it beforehand;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"he spoke"},{"kind":"text","text":"a speech (Msb, K)"},{"kind":"italic_en","text":"without consideration or thought,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"without his having prepared it;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"he recited"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"related"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"standing, without forecast, consideration, thought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meditation;"},{"kind":"text","text":"so accord. to Er-Rághib [who seems to have held this to be the primary signification of the verb when relating to a speech or the like]; or"},{"kind":"italic_en","text":"without reiteration, and without pausing, halting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hesitating."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Artjl Al$~aYo'a","text_ar":"ارتجل الشَّىْءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He did, performed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produced, the thing without premeditation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"previous preparation"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"xrE","text_ar":"خرع"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"Artjl","text_ar":"ارتجل"},{"kind":"arabic","text_bw":"A@somFA","text_ar":"ا@سْمًا"},{"kind":"italic_en","text":"He coined a name."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"Artjl biraA^oyihi","text_ar":"ارتجل بِرَاْيِهِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"independent of others, with none to take part"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"share"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate with him, in his opinion,"},{"kind":"text","text":"(Msb, K, TA,)"},{"kind":"italic_en","text":"without consulting any one respecting it,"},{"kind":"text","text":"(Msb, TA,)"},{"kind":"italic_en","text":"and kept constantly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perseveringly, to it."},{"kind":"text","text":"(Msb.) [Hence,]"},{"kind":"arabic","text_bw":"A^amoruka maA A@rotajalota","text_ar":"اَمْرُكَ مَا ا@رْتَجَلْتَ"},{"kind":"italic_en","text":"Thine affair"},{"kind":"text","text":"[to which thou shouldst keep]"},{"kind":"italic_en","text":"is that respecting which thou art alone"},{"kind":"text","text":"[&c.]"},{"kind":"italic_en","text":"in thine opinion."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Airotajilo maA A@rotajalota mina AlA^amori","text_ar":"اِرْتَجِلْ مَا ا@رْتَجَلْتَ مِنَ الاَمْرِ"},{"kind":"text","text":"is explained in the T as meaning"},{"kind":"arabic","text_bw":"Airokabo maA rakibota minohu","text_ar":"اِرْكَبْ مَا رَكِبْتَ مِنْهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Undertake thou what thou hast undertaken of the affair:"},{"kind":"text","text":"but it may rather signify"},{"kind":"italic_en","text":"keep thou to what thou hast undertaken of the affair;"},{"kind":"text","text":"agreeably with what here follows]. (TA.) One says also, ↓"},{"kind":"arabic","text_bw":"Airotajilo rajolaka","text_ar":"اِرْتَجِلْ رَجْلَكَ","orth_type":"arrow"},{"kind":"italic_en","text":"Keep thou to thine affair:"},{"kind":"text","text":"(IAar, M, K, TA:) in [some of] the copies of the K, erroneously,"},{"kind":"arabic","text_bw":"rajalaka","text_ar":"رَجَلَكَ"},{"kind":"text","text":". (TA.)       -A4-"},{"kind":"italic_en","text":"He collected a detached number"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qiToEap","text_ar":"قِطْعَة"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"rijol","text_ar":"رِجْل"},{"kind":"text","text":"])"},{"kind":"italic_en","text":"of locusts, to roast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fry, them."},{"kind":"text","text":"(S.)       -A5-"},{"kind":"italic_en","text":"He set up a"},{"kind":"arabic","text_bw":"mirojal","text_ar":"مِرْجَل"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"to cook food in it:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"he cooked food in a"},{"kind":"arabic","text_bw":"mirojal","text_ar":"مِرْجَل"},{"kind":"text","text":". (K.)       -A6-"},{"kind":"arabic","text_bw":"Artjl Aln~ahaAru","text_ar":"ارتجل النَّهَارُ"},{"kind":"text","text":": see 5."}],"source_refs":["T","TA","S","K","Msb","IAar","M"]}]},"classical_definitions":null}