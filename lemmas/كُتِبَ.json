asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْتُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُكْتَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكْتُب","in_corpus":true,"count":41,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكْتُب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كُتِبْتُ","in_corpus":true,"count":160,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"كُتِبْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَتَبْتُ","in_corpus":true,"count":146,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"كَتَبْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُكْتَب","in_corpus":true,"count":41,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُكْتَب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1675,"cross_references":{"qac":{"found":true,"lemma_key":"كُتِبَ","root":"كتب","pos":"V","occurrence_count":49},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":13},"lanes":{"found":true,"entry_ids":[""]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to mark (symbols, shapes, graphs, glyphs, letters, and the like) on a surface, to write, to inscribe; to draw (figures)","tags":["transitive"]},{"pos":"verb","gloss":"to mark (symbols, shapes, graphs, glyphs, letters, and the like) on a surface, to write, to inscribe; to cut (figures)","tags":["transitive"]},{"pos":"verb","gloss":"to produce or generate by writing; to write up, to compose, to draw up, to draft","tags":["transitive"]},{"pos":"verb","gloss":"to produce or generate by writing; to set down figures with a typewriter or a keyboard, to typewrite or keyboard, to type","tags":["transitive"]},{"pos":"verb","gloss":"to put down in writing, to write down; to record; to register; to track","tags":["transitive"],"examples":[{"text":"وَٱللَّهُ يَكْتُبُ مَا يُبَيِّتُونَ فَأَعْرِضْ عَنْهُمْ وَتَوَكَّلْ عَلَى ٱللَّهِ","english":"But God records what they scheme by night; so turn away from them and rely upon Allah."}]},{"pos":"verb","gloss":"to put down in writing, to write down; to record; to register; to track; to write down (an event, such as a destiny or a fatality); to destine or predestine; to foreordain","tags":["transitive"],"examples":[{"text":"قُل لَنْ يُصِيبَنَا إِلَّا مَا كَتَبَ اللَّهُ لَنَا","english":"Say \"Never will we be struck except by what Allah has decreed for us...\""}]},{"pos":"verb","gloss":"to put down in writing, to write down; to record; to register; to track; to write down (an ordinance, a law, a commandment, or the like); to prescribe","tags":["transitive"],"examples":[{"text":"مِنْ أَجْلِ ذٰلِكَ كَتَبْنَا عَلَىٰ بَنِي إِسْرَائِيلَ أَنَّهُ مَن قَتَلَ نَفْسًا بِغَيْرِ نَفْسٍ أَوْ فَسَادٍ فِي الْأَرْضِ فَكَأَنَّمَا قَتَلَ النَّاسَ جَمِيعًا وَمَنْ أَحْيَاهَا فَكَأَنَّمَا أَحْيَا النَّاسَ جَمِيعًا","english":"Because of that, We decreed upon the Children of Israel that whoever kills a soul unless for a soul or for corruption in the land; it is as if he had slain mankind entirely. And whoever saves one: it is as if he had saved mankind entirely."}]},{"pos":"verb","gloss":"to put down in writing, to write down; to record; to register; to track; to bequeath","tags":["transitive"],"examples":[{"text":"يَا قَوْمِ ٱدْخُلُوا ٱلْأَرْضَ ٱلْمُقَدَّسَةَ ٱلَّتِي كَتَبَ ٱللَّهُ لَكُمْ وَلَا تَرْتَدُّوا عَلَى أَدْبَارِكُمْ فَتَنْقَلِبُوا خَاسِرِينَ","english":"O my people, enter the Holy Land that Allah has assigned to you and do not turn back and become losers."}]},{"pos":"noun","gloss":"verbal noun of كَتَبَ (kataba)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"verb","gloss":"to cause to write, to make someone write","tags":["causative","transitive"]},{"pos":"verb","gloss":"to deploy in squadrons","tags":["transitive"]},{"pos":"noun","gloss":"plural of كِتَاب (kitāb)","tags":["form-of","plural","transitive"]},{"pos":"noun","gloss":"Classical Arabic spelling of كِتَاب (kitāb)","tags":["Arabic","Classical","alt-of","transitive"]}]},"etymology":{"source":"wiktextract","text":"From Proto-West Semitic *katab-, but the sense \"to write\" has long been considered a borrowing from another Central Semitic language, perhaps denominally from كِتَاب (kitāb).\n\nForm-II causative of كَتَبَ (kataba, “to write”)."},"ipa":["/ka.ta.ba/","/kat.ta.ba/","/ku.tub/","/ki.taːb/"]}