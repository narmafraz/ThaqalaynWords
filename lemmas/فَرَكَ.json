,"gen":"m","num":"p"},{"role":"present_2mp","form":"تَفْرُكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْرُكْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْرُك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْرُك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْرُكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْرُكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْرُكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْرُكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْرُكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْرُكُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْرُكْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَفْرُك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْرُك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"فَرَكْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرَكْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n33696","n33703","n33704"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D9%83%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to chafe, to scrub, to rub"}]},"etymology":null,"ipa":["/fa.ra.ka/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33696","headword_ar":"فَرْكٌ","root":"frk","body":[{"kind":"text","text":", as expl. by Lth, signifies (O, TA) primarily (TA) One's"},{"kind":"italic_en","text":"rubbing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rubbing and pressing,"},{"kind":"text","text":"a thing [with the hand]"},{"kind":"italic_en","text":"so that its integument becomes stripped off"},{"kind":"text","text":"(O, TA)"},{"kind":"italic_en","text":"from its kernel;"},{"kind":"text","text":"as, for instance, a [shelled] walnut. (TA.) One says,"},{"kind":"arabic","text_bw":"faraka Als~unobula","text_ar":"فَرَكَ السُّنْبُلَ"},{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"farokN","text_ar":"فَرْكٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He rubbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rubbed and pressed, the ears of corn"},{"kind":"text","text":"(K, TA) with his hand ["},{"kind":"italic_en","text":"so that the kernels became divested of their husks"},{"kind":"text","text":"]. (S, O, Msb, TA.) And"},{"kind":"arabic","text_bw":"faraka Alv~awoba","text_ar":"فَرَكَ الثَّوْبَ"},{"kind":"text","text":"(S, O, Msb, K)"},{"kind":"italic_en","text":"He rubbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rubbed and pressed, the garment"},{"kind":"text","text":"(K, TA) with his hand ["},{"kind":"italic_en","text":"to remove a soil"},{"kind":"text","text":"]. (S, O, Msb, TA.) And"},{"kind":"arabic","text_bw":"faraka AlmaniY~a mina Alv~awobi","text_ar":"فَرَكَ المَنِىَّ مِنَ الثَّوْبِ"},{"kind":"text","text":"(Mgh, O, Msb,) aor. and inf. n. as above, (Mgh,)"},{"kind":"italic_en","text":"He rubbed,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"rubbed and pressed,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"with his hand, the"},{"kind":"text","text":"[dry soil of]"},{"kind":"italic_en","text":"sperma, so that it crumbled, and came off from the garment;"},{"kind":"text","text":"(Mgh, Msb;) like"},{"kind":"arabic","text_bw":"Hat~ahu","text_ar":"حَتَّهُ"},{"kind":"text","text":": and in like manner"},{"kind":"arabic","text_bw":"AlT~iyna","text_ar":"الطِّينَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the"},{"kind":"text","text":"dry"},{"kind":"italic_en","text":"mud"},{"kind":"text","text":"]. (Msb.) [And"},{"kind":"arabic","text_bw":"faraka Alqamolapa","text_ar":"فَرَكَ القَمْلَةَ"},{"kind":"italic_en","text":"He rubbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rubbed and pressed, the louse, between his finger and thumb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise,"},{"kind":"text","text":"to kill it. (See the pass. part. n., below.)]       -A2-"},{"kind":"arabic","text_bw":"farikato zawojahaA","text_ar":"فَرِكَتْ زَوْجَهَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"farikahaA zawojuhaA","text_ar":"فَرِكَهَا زَوْجُهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, O, K;) and"},{"kind":"arabic","text_bw":"farakatohu","text_ar":"فَرَكَتْهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"farakahaA","text_ar":"فَرَكَهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", but this form of the verb is extr.; (K;) inf. n."},{"kind":"arabic","text_bw":"firokN","text_ar":"فِرْكٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"farokN","text_ar":"فَرْكٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"furuwkN","text_ar":"فُرُوكٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"She hated her husband,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"her husband hated her;"},{"kind":"text","text":"(S, O;) or"},{"kind":"italic_en","text":"she hated her husband vehemently,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"her husband hated her vehemently:"},{"kind":"text","text":"(K:) the verb has not been heard otherwise than as relating to the husband and wife: (S, O:) Lh has mentioned"},{"kind":"arabic","text_bw":"farakatohu","text_ar":"فَرَكَتْهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taforukuhu","text_ar":"تَفْرُكُهُ"},{"kind":"text","text":"; but it is not well known: (TA:) all of the nouns mentioned above as inf. ns. signify [hatred, or] vehement hatred, in a general sense, as also ↓"},{"kind":"arabic","text_bw":"furuk~aAnN","text_ar":"فُرُكَّانٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) which is [app. a simple subst.] mentioned on the authority of Seer, and also mentioned as with two kesrehs and the teshdeed [i. e. ↓"},{"kind":"arabic","text_bw":"firik~aAnN","text_ar":"فِرِكَّانٌ","orth_type":"arrow"},{"kind":"text","text":"]: (TA:) or all relate peculiarly to the hatred of the husband and wife; (K, TA;) i. e., to the man's hating his wife; or to her hating him, which is the better known: it is said in a trad. of Ibn-Mes'ood,"},{"kind":"arabic","text_bw":"A_in~a AlHub~a mina A@ll~`hi waAlfiroka mina Al$~ayoTaAni","text_ar":"اـِنَّ الحُبَّ مِنَ ا@للّٰهِ وَالفِرْكَ مِنَ الشَّيْطَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily love"},{"kind":"text","text":"of the husband"},{"kind":"italic_en","text":"is from God, and hatred"},{"kind":"text","text":"of the husband"},{"kind":"italic_en","text":"is from the Devil"},{"kind":"text","text":"]: A'Obeyd says that"},{"kind":"arabic","text_bw":"Alfiroku","text_ar":"الفِرْكُ"},{"kind":"text","text":"signifies the woman's hating"},{"kind":"italic_en","text":"her husband;"},{"kind":"text","text":"that it relates peculiarly to the wife and the husband, and that it had not been heard by him as used in relation to any but them two: and IAar says that the sons of a man by a wife who hates him, which sons are termed"},{"kind":"arabic","text_bw":"A^awolaAdu Alfiroki","text_ar":"اَوْلَادُ الفِرْكِ"},{"kind":"text","text":", possess generosity, because the sons thus called are most like to their fathers, and do not resemble her: and when the husband hates the wife, one says"},{"kind":"arabic","text_bw":"SlfhA","text_ar":"صلفها"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"SalafahaA","text_ar":"صَلَفَهَا"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"SalifahaA","text_ar":"صَلِفَهَا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Slft Endh","text_ar":"صلفت عنده"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"Salifato Einodahu","text_ar":"صَلِفَتْ عِنْدَهُ"},{"kind":"text","text":"]. (TA.)       -A3-"},{"kind":"arabic","text_bw":"farikati","text_ar":"فَرِكَتِ"},{"kind":"arabic","text_bw":"AlA^u*uni","text_ar":"الاُذُنِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"farakN","text_ar":"فَرَكٌ"},{"kind":"text","text":", (S, O, K,)"},{"kind":"italic_en","text":"The ear had a flaccidity in its"},{"kind":"arabic","text_bw":"A^aSol","text_ar":"اَصْل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"base,"},{"kind":"text","text":"meaning the"},{"kind":"italic_en","text":"part surrounding the entrance of the meatus auditorius"},{"kind":"text","text":"]. (S, * O, * K.)"}],"source_refs":["O","TA","S","Msb","K","Mgh"]},{"entry_id":"n33703","headword_ar":"فَرْكٌ","root":"frk","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n33704","headword_ar":"فَرِكٌ","root":"frk","body":[{"kind":"text","text":", (O, K,) like"},{"kind":"arabic","text_bw":"katifN","text_ar":"كَتِفٌ"},{"kind":"text","text":", (K,) or correctly, as written in the L and A. ↓"},{"kind":"arabic","text_bw":"farokN","text_ar":"فَرْكٌ","orth_type":"arrow"},{"kind":"text","text":", (TA, [but this I think doubtful,]) [A fruit or the like]"},{"kind":"italic_en","text":"of which the integument becomes rubbed off"},{"kind":"text","text":"[with the hand]: (O, K: [I read"},{"kind":"arabic","text_bw":"Almunofariku qi$oruhu","text_ar":"المُنْفَرِكُ قِشْرُهُ"},{"kind":"text","text":", as in the CK, for"},{"kind":"arabic","text_bw":"Almutafar~iku qi$oruhu","text_ar":"المُتَفَرِّكُ قِشْرُهُ"},{"kind":"text","text":"in other copies of the K and in the O:]) thus applied to an almond, and likewise to a peach. (TA.) ―         -b2-  See also what next follows."}],"source_refs":["O","K"]}]},"classical_definitions":null}