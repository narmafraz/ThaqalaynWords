{"lemma":"تَخَلِّي","slug":"تَخَلِّي","root":"خ.ل.#","root_slug":"خ-ل-_","root_link":"/words/roots/خ-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11421"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AE%D9%8E%D9%84%D9%90%D9%91%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to relinquish or surrender"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11421","headword_ar":"تخلّى","root":"xlw","body":[{"kind":"italic_en","text":"He went forth into the field,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open country, to satisfy a want of nature."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"txl~Y fiY AlxalaA='i","text_ar":"تخلّى فِى الخَلَا=ءِ"},{"kind":"italic_en","text":"He went forth into the vacant tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into the privy, to satisfy a want of nature:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he satisfied a want of nature therein."},{"kind":"text","text":"(TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, vacant from occupation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"business;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"unoccupied; unemployed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure;"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"tafar~aga","text_ar":"تَفَرَّغَ"},{"kind":"text","text":": (S:) or so"},{"kind":"arabic","text_bw":"txl~Y mina Al$~ugoli","text_ar":"تخلّى مِنَ الشُّغْلِ"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"frg","text_ar":"فرغ"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"txl~Y liloEibaAdapi","text_ar":"تخلّى لِلْعِبَادَةِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, vacant for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he confined himself exclusively to, the service of God."},{"kind":"text","text":"(TA.) [See also 1, in the latter part of the paragraph. In like manner, one says also,"},{"kind":"arabic","text_bw":"liloA^amori","text_ar":"لِلْاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا","orth_type":"arrow"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, vacant for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he confined himself exclusively to, the affair."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"taxal~awoA bixaliy~apK","text_ar":"تَخَلَّوْا بِخَلِيَّةٍ"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"They confined themselves exclusively to a she-camel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to she-camels, such as they termed"},{"kind":"arabic","text_bw":"xlyp","text_ar":"خلية"},{"kind":"text","text":", (K, TA,)"},{"kind":"arabic","text_bw":"yaHolubuwnahaA","text_ar":"يَحْلُبُونَهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"milking"},{"kind":"text","text":"only"},{"kind":"italic_en","text":"her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"them"},{"kind":"text","text":"]. (S, TA.) And"},{"kind":"arabic","text_bw":"txl~Y xaliy~apF","text_ar":"تخلّى خَلِيَّةً"},{"kind":"italic_en","text":"He took for himself a"},{"kind":"arabic","text_bw":"xly~p","text_ar":"خليّة"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"txl~Y mina AlA^amori","text_ar":"تخلّى مِنَ الاَمْرِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":": see 2. ―         -b4-  And"},{"kind":"arabic","text_bw":"taxal~ati AlA_ibilu bilaA raAEK","text_ar":"تَخَلَّتِ الاـِبِلُ بِلَا رَاعٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The camels were left to themselves without a pastor"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"swE","text_ar":"سوع"},{"kind":"text","text":".)"}],"source_refs":["S","K","TA"]}]},"classical_definitions":null}