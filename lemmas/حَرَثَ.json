unt":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْرُثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْرُثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْرِثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْرِثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْرُثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْرُثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْرِثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْرِثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْرُثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَحْرِثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَرَثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَرَثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْرُث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْرُث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْرِث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْرِث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"حَرَثَ","root":"حرث","pos":"N","occurrence_count":13},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n7552"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D9%8E%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to plow, to till, to cultivate","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of حَرَثَ (ḥaraṯa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plowing, tilling, cultivation, plantation, culture"},{"pos":"noun","gloss":"arable land, tilth","examples":[{"text":"نِسَاؤُكُمْ حَرْثٌ لَكُمْ فَأْتُوا حَرْثَكُمْ أَنَّى شِئْتُمْ وَقَدِّمُوا لِأَنْفُسِكُمْ وَاتَّقُوا اللَّهَ وَاعْلَمُوا أَنَّكُمْ مُلَاقُوهُ وَبَشِّرِ الْمُؤْمِنِينَ","english":"Your wives are a place of sowing of seed for you, so come to your place of cultivation however you wish and put forth [righteousness] for yourselves. And fear Allah and know that you will meet Him. And give good tidings to the believers."}]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ḥaraṯ-.\nCognate with Hebrew חרש (ħaráš)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7552","headword_ar":"حَرَثَ","root":"Hrv","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HarovN","text_ar":"حَرْثٌ"},{"kind":"text","text":", (S, A, Msb, K,)"},{"kind":"italic_en","text":"He gained, acquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"(S, A, K,) wealth; (S;) as also ↓"},{"kind":"arabic","text_bw":"AHtrv","text_ar":"احترث","orth_type":"arrow"},{"kind":"text","text":": (Az, TA:)"},{"kind":"italic_en","text":"he collected"},{"kind":"text","text":"wealth. (S, A, Msb, K.) ―         -b2-"},{"kind":"italic_en","text":"He sought, sought after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to gain, sustenance;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"laboured diligently;"},{"kind":"arabic","text_bw":"liEiyaAlihi","text_ar":"لِعِيَالِهِ"},{"kind":"italic_en","text":"for his family;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHtrv","text_ar":"احترث","orth_type":"arrow"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"he worked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laboured,"},{"kind":"text","text":"for the goods of the present world, (Az, TA,) and (tropical:)  for those of the world to come. (Az, A, TA.) You say,"},{"kind":"arabic","text_bw":"AuHoruvo liA=xiratika","text_ar":"اُحْرُثْ لِا=خِرَتِكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Labour for thy good in the world to come."},{"kind":"text","text":"(A, TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"AuHoruvo lidunoyaAka kaA^an~aka","text_ar":"اُحْرُثْ لِدُنْيَاكَ كَاَنَّكَ"},{"kind":"arabic","text_bw":"taEiy$u A^abadFA","text_ar":"تَعِيشُ اَبَدًا"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"Labour for thy good in the present world as though thou wert to live for ever:"},{"kind":"text","text":"and, in continuation,"},{"kind":"arabic","text_bw":"waA@Eomalo liA=xiratika kaA^an~aka tamuwtu","text_ar":"وَا@عْمَلْ لِا=خِرَتِكَ كَاَنَّكَ تَمُوتُ"},{"kind":"arabic","text_bw":"gadFA","text_ar":"غَدًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"and work for thy good in the world to come as though thou wert to die to-morrow."},{"kind":"text","text":"(TA.) ―         -b3-  Also"},{"kind":"arabic","text_bw":"Harava","text_ar":"حَرَثَ"},{"kind":"text","text":", (T, S, Mgh, Msb, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HarovN","text_ar":"حَرْثٌ"},{"kind":"text","text":"(T, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"HiraAvapN","text_ar":"حِرَاثَةٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AHtrv","text_ar":"احترث","orth_type":"arrow"},{"kind":"text","text":"; (T, S;)"},{"kind":"italic_en","text":"He sowed;"},{"kind":"text","text":"(T, S, K;)"},{"kind":"italic_en","text":"he cast seed upon the ground:"},{"kind":"text","text":"(T, TA:) [accord. to Bd (xlii. 19), this is the primary signification: see"},{"kind":"arabic","text_bw":"HarovN","text_ar":"حَرْثٌ"},{"kind":"text","text":", below:] and the former verb,"},{"kind":"italic_en","text":"he tilled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cultivated,"},{"kind":"text","text":"land, either"},{"kind":"italic_en","text":"by sowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by planting:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he ploughed up"},{"kind":"text","text":"land"},{"kind":"italic_en","text":"for sowing:"},{"kind":"text","text":"(Mgh, Msb:) or"},{"kind":"italic_en","text":"he ploughed"},{"kind":"text","text":"land; because the doing so is a means of gain. (Ham p. 70.) And the former verb,"},{"kind":"italic_en","text":"He ploughed up"},{"kind":"text","text":"the ground"},{"kind":"italic_en","text":"by much walking upon it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHrv","text_ar":"احرث","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b4-  Also, the former verb, (L, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HarovN","text_ar":"حَرْثٌ"},{"kind":"text","text":", (A, L, K,)"},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had, four wives together."},{"kind":"text","text":"(A, L, K.) ―         -b5-"},{"kind":"italic_en","text":"Immoderatè inivit:"},{"kind":"text","text":"(A, K:)"},{"kind":"italic_en","text":"multùm inivit."},{"kind":"text","text":"(IAar, L.) And"},{"kind":"arabic","text_bw":"Harava A@moraA^atahu","text_ar":"حَرَثَ ا@مْرَاَتَهُ"},{"kind":"italic_en","text":"Multùm inivit mulierem suam."},{"kind":"text","text":"(IAar, L.) ―         -b6-  (tropical:)"},{"kind":"italic_en","text":"He emaciated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered lean,"},{"kind":"text","text":"(IAar, S, A, K,) a beast, (K,) or a camel, (IAar, TA,) or a she-camel, (IAar, S, A,) and a horse, (IAar, TA,)"},{"kind":"italic_en","text":"by journeying"},{"kind":"text","text":"(IAar, S, A, K)"},{"kind":"italic_en","text":"thereon;"},{"kind":"text","text":"(IAar, S, K;) as also ↓"},{"kind":"arabic","text_bw":"AHrv","text_ar":"احرث","orth_type":"arrow"},{"kind":"text","text":", (so in the"},{"kind":"page_break","n":542},{"kind":"text","text":"A and L and TA, and in some copies of the S, in this art., and so in the S and L and K in art."},{"kind":"arabic","text_bw":"lhd","text_ar":"لهد"},{"kind":"text","text":",) or ↓"},{"kind":"arabic","text_bw":"AHtrv","text_ar":"احترث","orth_type":"arrow"},{"kind":"text","text":". (So in some copies of the S in the present art.) ―         -b7-  (tropical:)"},{"kind":"italic_en","text":"He stirred"},{"kind":"text","text":"a fire, (S, A, K,)"},{"kind":"italic_en","text":"and made"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"to burn up,"},{"kind":"text","text":"(TA,) with the"},{"kind":"arabic","text_bw":"miHoraAv","text_ar":"مِحْرَاث"},{"kind":"text","text":". (A, TA.) ―         -b8-  (tropical:)"},{"kind":"italic_en","text":"He examined, looked into, scrutinized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"investigated:"},{"kind":"text","text":"(K, TA:) app. in an absolute sense: but accord. to some of the leading lexicologists,"},{"kind":"italic_en","text":"he examined, looked into, scrutinized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"investigated,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"studied,"},{"kind":"text","text":"the book, or the Kur-án: (TA:)"},{"kind":"italic_en","text":"he studied"},{"kind":"text","text":"the Kur-án: (S:) or"},{"kind":"italic_en","text":"he studied"},{"kind":"text","text":"the Kur-án"},{"kind":"italic_en","text":"long, and meditated upon"},{"kind":"text","text":"it. (A, TA.) ―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"He called to mind"},{"kind":"text","text":"a thing, or an affair,"},{"kind":"italic_en","text":"and became excited thereby:"},{"kind":"text","text":"[for ex.,] Ru-beh says,"},{"kind":"quote","text":"waAlqawolu manosiY~N A_i*aA lamo yuHoravi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the saying is forgotten if it be not called to mind so as to produce excitement"},{"kind":"text","text":"]. (TA.) ―         -b10-  (assumed tropical:)"},{"kind":"italic_en","text":"He applied himself to the study of"},{"kind":"arabic","text_bw":"Alfiqoh","text_ar":"الفِقْه"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the law"},{"kind":"text","text":"]; or"},{"kind":"italic_en","text":"he learned the science so called."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","K","A","Az","TA","T","Mgh","L","IAar"]}]}}