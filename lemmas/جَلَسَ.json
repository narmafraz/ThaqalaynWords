"role":"present_2mp","form":"تَجْلِسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْلِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْلِس","in_corpus":true,"count":38,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْلِس","in_corpus":true,"count":24,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْلِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْلِسا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْلِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْلِسُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْلِسْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَلَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَلَسْتُ","in_corpus":true,"count":15,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْلِس","in_corpus":true,"count":15,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْلِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":247,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n6125"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sit"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew גלש (galáš, “surf”)."},"ipa":["/d͡ʒa.la.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6125","headword_ar":"جَلَسَ","root":"jls","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"juluwsN","text_ar":"جُلُوسٌ"},{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"majolasN","text_ar":"مَجْلَسٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,)"},{"kind":"italic_en","text":"He placed his seat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"posteriors, upon rugged"},{"kind":"text","text":"[or rather"},{"kind":"italic_en","text":"elevated"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ground, such as is termed"},{"kind":"arabic","text_bw":"jalosN","text_ar":"جَلْسٌ"},{"kind":"text","text":": this is the primary signification: (TA:) [and hence,]"},{"kind":"italic_en","text":"He sat; i. q."},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"[when the latter is used in its largest sense]: (Msb, and so S and L and A and K in art."},{"kind":"arabic","text_bw":"qEd","text_ar":"قعد"},{"kind":"text","text":":) you say,"},{"kind":"arabic","text_bw":"jalasa mutarab~iEFA","text_ar":"جَلَسَ مُتَرَبِّعًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaEada mutarab~iEFA","text_ar":"قَعَدَ مُتَرَبِّعًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sat cross-legged"},{"kind":"text","text":"]: (Msb:) accord. to El-Fárábee and others,"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":"; and thus it has a more common application than"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"[when the latter is used in its most proper and restricted sense]: (Msb:) but"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"also signifies the contr. of"},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":": ('Orweh Ibn-Zubeyr, L in art."},{"kind":"arabic","text_bw":"qEd","text_ar":"قعد"},{"kind":"text","text":":) properly speaking,"},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":"differs from"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"; the former signifying"},{"kind":"italic_en","text":"he sat up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sat after sleeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prostration,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"after lying on his side;"},{"kind":"text","text":"(B, TA;) and the latter, he sat down; or sat after standing: (Msb, B, TA: and see other authorities to the same effect in art."},{"kind":"arabic","text_bw":"qEd","text_ar":"قعد"},{"kind":"text","text":":) for"},{"kind":"arabic","text_bw":"juluwsN","text_ar":"جُلُوسٌ"},{"kind":"text","text":"is a change of place from low to high, and"},{"kind":"arabic","text_bw":"quEuwdN","text_ar":"قُعُودٌ"},{"kind":"text","text":"is a change of place from high to low: and one says,"},{"kind":"arabic","text_bw":"jalasa mut~akiy^FA","text_ar":"جَلَسَ مُتَّكِيًا"},{"kind":"text","text":", but not"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"arabic","text_bw":"mut~akiy^FA","text_ar":"مُتَّكِيًا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"He sat"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"leaning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reclining, upon one side:"},{"kind":"text","text":"(Msb:) but both these verbs sometimes signify"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became:"},{"kind":"text","text":"and thus, [it is said,]"},{"kind":"arabic","text_bw":"jalasa mutarab~iEFA","text_ar":"جَلَسَ مُتَرَبِّعًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faEada mutarab~iEFA","text_ar":"فَعَدَ مُتَرَبِّعًا"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cross-legged:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jalasa bayona","text_ar":"جَلَسَ بَيْنَ"},{"kind":"arabic","text_bw":"$uEabihaA AlA^arobaEi","text_ar":"شُعَبِهَا الاَرْبَعِ"},{"kind":"text","text":"in like manner signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"between her four limbs,"},{"kind":"text","text":"] (El-Fárábee, Msb,) because the man, in this case, is resting upon his own four limbs. (Msb.) ["},{"kind":"arabic","text_bw":"jalasa maEahu","text_ar":"جَلَسَ مَعَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jalasa A_ilayohi","text_ar":"جَلَسَ اـِلَيْهِ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"xalaA mEh","text_ar":"خَلَا معه"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xlA Alyh","text_ar":"خلا اليه"},{"kind":"text","text":", signify the same; i. e."},{"kind":"italic_en","text":"He sat with him:"},{"kind":"text","text":"or the latter,"},{"kind":"italic_en","text":"he sat by him;"},{"kind":"text","text":"like “ assedit ei. ”] An instance of the inf. n."},{"kind":"arabic","text_bw":"majolasN","text_ar":"مَجْلَسٌ"},{"kind":"text","text":"is found in a trad., in which it is said,"},{"kind":"arabic","text_bw":"faA_i*aA A^atayotumo A_ilaY Almajolisi faA^aEoTuwA AlT~ariyqa Haq~ahu","text_ar":"فَاـِذَا اَتَيْتُمْ اـِلَى المَجْلِسِ فَاَعْطُوا الطَّرِيقَ حَقَّهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"But when ye come to sitting, perform ye the duties relating to the road"},{"kind":"text","text":"]. (TA.) [The trad. commences thus:"},{"kind":"arabic","text_bw":"A_iy~aAkumo waAljuluwsa EalaY AlT~uruqaAti","text_ar":"اـِيَّاكُمْ وَالجُلُوسَ عَلَى الطُّرُقَاتِ"},{"kind":"italic_en","text":"Beware ye of sitting on the roads:"},{"kind":"text","text":"and then, after the words before cited, (in which, however, in my copy of the Jámi' es-Sagheer, instead of"},{"kind":"arabic","text_bw":"Almjls","text_ar":"المجلس"},{"kind":"text","text":", I find"},{"kind":"arabic","text_bw":"AlmajaAlisi","text_ar":"المَجَالِسِ"},{"kind":"text","text":", which is pl. of"},{"kind":"arabic","text_bw":"Almajolisu","text_ar":"المَجْلِسُ"},{"kind":"text","text":",) it is added that the duties thus alluded to are the lowering of the eyes, the putting away or aside what is hurtful or annoying, the returning of salutations, the enjoining of that which is good, and the forbidding of that which is evil.] ―         -b2-"},{"kind":"arabic","text_bw":"jalasati Alr~axamapu","text_ar":"جَلَسَتِ الرَّخَمَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The aquiline vulture lay upon its breast on the ground;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"javamat","text_ar":"جَثَمَت"},{"kind":"text","text":": a saying applied to him who is of the seceders. (A, TA.) [See also"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, as, for instance, a plant,)"},{"kind":"italic_en","text":"remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued."},{"kind":"text","text":"(AHn, TA.) ―         -b4-  Also, (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalosN","text_ar":"جَلْسٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He came to"},{"kind":"arabic","text_bw":"Aljalos","text_ar":"الجَلْس"},{"kind":"text","text":", (TA,) or ["},{"kind":"italic_en","text":"the high country called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Nejd:"},{"kind":"text","text":"(T, S, A, TA:) and in like manner said of a cloud;"},{"kind":"italic_en","text":"it came to Nejd."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","A","Msb","K","TA","T"]}]}}