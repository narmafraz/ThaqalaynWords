{"lemma":"أَشْكَلَ","slug":"أَشْكَلَ","root":"ش.ك.ل","root_slug":"ش-ك-ل","root_link":"/words/roots/ش-ك-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَشْكَلْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَشْكَلْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَشْكَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَشْكَلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَشْكَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَشْكَلَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَشْكَلَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَشْكَلا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَشْكَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَشْكَلُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَشْكَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُشْكِل","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُشْكِلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُشْكِلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُشْكِلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشْكِلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُشْكِلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشْكِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشْكِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشْكِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشْكِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشْكِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشْكِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشْكِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْكِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشْكِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْكِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشْكِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُشْكِل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْكِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَشْكَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَشْكَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n22845","n22861"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D9%83%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22845","headword_ar":"اشكل","root":"$kl","body":[{"kind":"text","text":"[primarily] signifies"},{"kind":"arabic","text_bw":"SaAra *aA $akolK","text_ar":"صَارَ ذَا شَكْلٍ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as had a likeness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resemblance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"match,"},{"kind":"text","text":"&c.]. (TA.) ―         -b2-  [And hence, app.,] said of a thing, or case, or an affair; (S, Mgh, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"$akala","text_ar":"شَكَلَ","orth_type":"arrow"},{"kind":"text","text":", (O, K, TA, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"$akila","text_ar":"شَكِلَ"},{"kind":"text","text":", evidently not meant by the author of the K, as it is his rule, after mentioning a verb of this form, to add"},{"kind":"arabic","text_bw":"kafariHa","text_ar":"كَفَرِحَ"},{"kind":"text","text":"or the like,]) inf. n."},{"kind":"arabic","text_bw":"$akolN","text_ar":"شَكْلٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"$k~l","text_ar":"شكّل","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"ta$okiylN","text_ar":"تَشْكِيلٌ"},{"kind":"text","text":"; (TA;) (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dubious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ailotabasa","text_ar":"اِلْتَبَسَ"},{"kind":"text","text":", (S, O, Msb, K,) and"},{"kind":"arabic","text_bw":"AixotalaTa","text_ar":"اِخْتَلَطَ"},{"kind":"text","text":", (O, TA,) or"},{"kind":"arabic","text_bw":"Ai$otabaha","text_ar":"اِشْتَبَهَ"},{"kind":"text","text":": (Mgh:) [and ↓"},{"kind":"arabic","text_bw":"A$tkl","text_ar":"اشتكل","orth_type":"arrow"},{"kind":"text","text":"is mentioned in this sense by Golius as on the authority of J (whom I do not find to have mentioned it either in this art. or elsewhere), and by Freytag as on the authority of Abu-l-'Alà: accord. to Sh,"},{"kind":"arabic","text_bw":"A$kl","text_ar":"اشكل"},{"kind":"text","text":"in this sense is from"},{"kind":"arabic","text_bw":"$ukolapN","text_ar":"شُكْلَةٌ"},{"kind":"text","text":"signifying “ redness mixed with whiteness: ” (see"},{"kind":"arabic","text_bw":"mu$okilN","text_ar":"مُشْكِلٌ"},{"kind":"text","text":":) but] accord. to Er-Rághib,"},{"kind":"arabic","text_bw":"A_i$okaAlN","text_ar":"اـِشْكَالٌ"},{"kind":"text","text":"in a thing, or case, or an affair, is metaphorical, [and] like"},{"kind":"arabic","text_bw":"Ai$otibaAhN","text_ar":"اِشْتِبَاهٌ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Al$ibohu","text_ar":"الشِبْهُ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"A$kl AlA^amoru EalaY Alr~ajuli","text_ar":"اشكل الاَمْرُ عَلَى الرَّجُلِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dubious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused, to the man"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"$akala","text_ar":"شَكَلَ","orth_type":"arrow"},{"kind":"text","text":"means the same. (Zj, O.) And"},{"kind":"arabic","text_bw":"A^a$okalato EalaY~a AlA^axobaAru","text_ar":"اَشْكَلَتْ عَلَىَّ الاَخْبَارُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The tidings were dubious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused, to me"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"A^aHokalato","text_ar":"اَحْكَلَتْ"},{"kind":"text","text":"; both meaning the same. (TA.) And one says also,"},{"kind":"arabic","text_bw":"Ealayohi A_i$okaAlN","text_ar":"عَلَيْهِ اـِشْكَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Elyh A_i$okaAlaAtN","text_ar":"عليه اـِشْكَالَاتٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"There is doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncertainty,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"there are doubts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncertainties, respecting it:"},{"kind":"text","text":"thus using the inf. n. as a simple subst., and therefore pluralizing it]. (Mz, 3rd"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":"; &c.) ―         -b3-  It is also said of a disease; [app. as meaning (assumed tropical:)"},{"kind":"italic_en","text":"It became nearly cured;"},{"kind":"text","text":"because still in a somewhat doubtful state;] like as you say"},{"kind":"arabic","text_bw":"tamaAvala","text_ar":"تَمَاثَلَ"},{"kind":"text","text":"; and so ↓"},{"kind":"arabic","text_bw":"$akala","text_ar":"شَكَلَ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"A$kl Aln~axolu","text_ar":"اشكل النَّخْلُ"},{"kind":"italic_en","text":"The palm-trees became in that state in which their dates were sweet"},{"kind":"text","text":"(Ks, S, A, O, K)"},{"kind":"italic_en","text":"and ripe,"},{"kind":"text","text":"(Ks, S, O, Msb,) or"},{"kind":"italic_en","text":"nearly ripe;"},{"kind":"text","text":"(A, TA;) and ↓"},{"kind":"arabic","text_bw":"t$k~l","text_ar":"تشكّل","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (O.) ―         -b5-  And"},{"kind":"arabic","text_bw":"A$klt AlEayonu","text_ar":"اشكلت العَيْنُ"},{"kind":"italic_en","text":"The eye had in it what is termed"},{"kind":"arabic","text_bw":"$ukolapN","text_ar":"شُكْلَةٌ"},{"kind":"text","text":"[q. v.: see also"},{"kind":"arabic","text_bw":"$akalN","text_ar":"شَكَلٌ"},{"kind":"text","text":"]. (K.)       -A2-"},{"kind":"arabic","text_bw":"A$kl AlkitaAba","text_ar":"اشكل الكِتَابَ"},{"kind":"text","text":": see 1."}],"source_refs":["K","S","O","Msb","TA","Mgh","Ks","A"]},{"entry_id":"n22861","headword_ar":"اَشْكَلُ","root":"$kl","body":[{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^a$obapu","text_ar":"اَشْبَةُ"},{"kind":"text","text":": so in the saying,"},{"kind":"arabic","text_bw":"h`*aA A^a$okalu bika*aA","text_ar":"هٰذَا اَشْكَلُ بِكَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is more,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, like to such a thing"},{"kind":"text","text":"]. (S, K. *) ―         -b2-  Also"},{"kind":"italic_en","text":"Of a colour in which whiteness and redness are intermixed;"},{"kind":"text","text":"(S, Msb, K;) applied to blood; and, accord. to IDrd, a name for"},{"kind":"italic_en","text":"blood,"},{"kind":"text","text":"because of the redness and whiteness intermixed therein; (S;) [and] applied to a man; (Msb;) or to anything: (TA:) or"},{"kind":"italic_en","text":"in which is whiteness inclining to redness and duskiness:"},{"kind":"text","text":"(K:) or it signifies, with the Arabs, ["},{"kind":"italic_en","text":"of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"two colours intermixed."},{"kind":"text","text":"(TA.) [Hence,] it is applied to water, (K, TA,) as meaning (tropical:)"},{"kind":"italic_en","text":"Mixed with blood:"},{"kind":"text","text":"(TA: [see an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"Hat~aY","text_ar":"حَتَّى"},{"kind":"text","text":":]) pl."},{"kind":"arabic","text_bw":"$ukolN","text_ar":"شُكْلٌ"},{"kind":"text","text":". (K.) And the fem.,"},{"kind":"arabic","text_bw":"$akolaA='u","text_ar":"شَكْلَا=ءُ"},{"kind":"text","text":", is applied as an epithet to an eye, (S, K,) meaning"},{"kind":"italic_en","text":"Having in it what is termed"},{"kind":"arabic","text_bw":"$ukolapN","text_ar":"شُكْلَةٌ"},{"kind":"text","text":", which is"},{"kind":"italic_en","text":"the like of a redness in the white thereof;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"$uholapN","text_ar":"شُهْلَةٌ"},{"kind":"text","text":"in the black: (S:) pl. as above. (K.) A man is said to be"},{"kind":"arabic","text_bw":"A^a$okalu AlEayoni","text_ar":"اَشْكَلُ العَيْنِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Having a redness,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"the like of a redness,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"in the white of the eye:"},{"kind":"text","text":"(Mgh, O:) the Prophet is said to have been"},{"kind":"arabic","text_bw":"A^a$okalu AlEayoni","text_ar":"اَشْكَلُ العَيْنِ"},{"kind":"text","text":": and it has been expl. as meaning"},{"kind":"italic_en","text":"long in the slit of the eye:"},{"kind":"text","text":"(K:) but ISd says that this is extraordinary; and MF, that the leading authorities on the trads. consentaneously assert it to be a pure mistake, and inapplicable to the Prophet, even if lexicologically correct. (TA.) ―         -b3-  Applied to a camel, (K, TA,) and to a sheep or goat, (TA,)"},{"kind":"italic_en","text":"of which the blackness is mixed with redness,"},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"with dust-colour;"},{"kind":"text","text":"as though its colour were dubious to thee: (TA:) pl. as above, applied to rams &c., (K, TA,) in this sense. (TA.) ―         -b4-  Applied to a sheep or goat,"},{"kind":"italic_en","text":"White in the"},{"kind":"arabic","text_bw":"$aAkilap","text_ar":"شَاكِلَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flank"},{"kind":"text","text":"]: (S, O:) fem."},{"kind":"arabic","text_bw":"$akolaA='u","text_ar":"شَكْلَا=ءُ"},{"kind":"text","text":"; (S;) applied to a ewe, as meaning"},{"kind":"italic_en","text":"white in the"},{"kind":"arabic","text_bw":"$aAkilap","text_ar":"شَاكِلَة"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"the rest of her being black."},{"kind":"text","text":"(TA.)       -A2-  Also The"},{"kind":"italic_en","text":"mountain-species of"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lote-tree"},{"kind":"text","text":"]; (S, O, K;) described to AHn, by some one or more of the Arabs of the desert, as"},{"kind":"italic_en","text":"a sort of trees like the"},{"kind":"arabic","text_bw":"Eun~aAb","text_ar":"عُنَّاب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"jujube"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in its thorns and the crookedness of its branches, but smaller in leaf, and having more branches; very hard, and having a small drupe,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"nubayoqap","text_ar":"نُبَيْقَة"},{"kind":"text","text":", [dim. of"},{"kind":"arabic","text_bw":"nabiqapN","text_ar":"نَبِقَةٌ"},{"kind":"text","text":", n. un. of"},{"kind":"arabic","text_bw":"nabiqN","text_ar":"نَبِقٌ"},{"kind":"text","text":", which means the “ drupes of the"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"text","text":", ”])"},{"kind":"italic_en","text":"which is very acid: the places of its growth are lofty mountains; and bows are made of it"},{"kind":"text","text":"[as is shown by an ex. in the S and O]: (TA:) [app. with tenween, having a] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, K:) AHn says that"},{"kind":"italic_en","text":"the growth of the"},{"kind":"arabic","text_bw":"A$kl","text_ar":"اشكل"},{"kind":"italic_en","text":"is like"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the trees called"},{"kind":"arabic","text_bw":"$iroyaAn","text_ar":"شِرْيَان"},{"kind":"text","text":"[of which likewise bows are made]. (TA.)"}],"source_refs":["TA","K","S","Mgh","O"]}]},"classical_definitions":null}