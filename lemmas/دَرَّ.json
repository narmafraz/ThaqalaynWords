رِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَدْرُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدِرّا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدُرّا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدُرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدِرُّونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدِرُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدُرُّونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدُرُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَدْرُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَدِرّ","in_corpus":true,"count":16,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدِرّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدُرّ","in_corpus":true,"count":16,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدُرّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"دَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":361,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n12319"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stream, to flow, to well","tags":["intransitive"]},{"pos":"verb","gloss":"to accrue","tags":["intransitive"]},{"pos":"verb","gloss":"to be abundant, to be plentiful","tags":["intransitive"]},{"pos":"noun","gloss":"verbal noun of دَرَّ (darra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"copious flow of milk"},{"pos":"noun","gloss":"milk, lactation"},{"pos":"noun","gloss":"achievement, accomplishment"},{"pos":"noun","gloss":"nature, natural disposition"},{"pos":"noun","gloss":"soul, mind, intellect"},{"pos":"noun","gloss":"pearls","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Afroasiatic *dâr- (“to increase”). Cognate with Old South Arabian 𐩵𐩧𐩧 (drr, “abundance, harvest”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12319","headword_ar":"دَرَّ","root":"dr","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", [the latter anomalous,] inf. n."},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":"(Msb, K, TA) and"},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(milk)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant,"},{"kind":"text","text":"(Msb, K, TA,)"},{"kind":"italic_en","text":"and flowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamed; it flowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamed, copiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundantly;"},{"kind":"text","text":"and so (assumed tropical:)  the water of the eye, or tears, and the like, (TA,) &c.; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"Astdr~","text_ar":"استدرّ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) and, said of milk,"},{"kind":"italic_en","text":"it ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it collected"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"became excerned"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the udder from the ducts and other parts of the body."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,] said of sweat, (assumed tropical:)"},{"kind":"italic_en","text":"It flowed"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"like as milk flows."},{"kind":"text","text":"(TA.) ―         -b3-  And of the tax called"},{"kind":"arabic","text_bw":"xaraAj","text_ar":"خَرَاج"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"Its produce became abundant."},{"kind":"text","text":"(K.) ―         -b4-  And [in like manner] one says,"},{"kind":"arabic","text_bw":"laAadar~a dar~uhu","text_ar":"لَاَدَرَّ دَرُّهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":", below. ―         -b5-  And [hence,]"},{"kind":"arabic","text_bw":"dar~a","text_ar":"دَرَّ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, consecutive."},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"dhdr","text_ar":"دهدر"},{"kind":"text","text":".) And (assumed tropical:)"},{"kind":"italic_en","text":"It continued;"},{"kind":"text","text":"as in the phrase,"},{"kind":"arabic","text_bw":"dar~a lahu Al$~aYo'N","text_ar":"دَرَّ لَهُ الشَّىْءٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The thing continued to him"},{"kind":"text","text":"]. (Sh, TA in art."},{"kind":"arabic","text_bw":"jrY","text_ar":"جرى"},{"kind":"text","text":".) ―         -b6-  And, said of a horse, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dariyrN","text_ar":"دَرِيرٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"dar~apN","text_ar":"دَرَّةٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He ran vehemently:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ran easily"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"and without interruption."},{"kind":"text","text":"(TA.) ―         -b7-  And of herbage, (K,) inf. n."},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"It became tangled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"luxuriant,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"by reason of its abundance."},{"kind":"text","text":"(TA.) ―         -b8-  One says also, of a she-camel,"},{"kind":"arabic","text_bw":"dar~ato","text_ar":"دَرَّتْ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"dar~ato bilabanihaA","text_ar":"دَرَّتْ بِلَبَنِهَا"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", [the former anomalous,] inf. n."},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Adr~t","text_ar":"ادرّت","orth_type":"arrow"},{"kind":"text","text":", alone, (S, K,) and ↓"},{"kind":"arabic","text_bw":"Adr~t","text_ar":"ادرّت","orth_type":"arrow"},{"kind":"arabic","text_bw":"bilabanihaA","text_ar":"بِلَبَنِهَا"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"She yielded her milk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it to flow, copiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundantly."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"dar~aAlD~aroEu biAll~abani","text_ar":"دَرَّالضَّرْعُ بِاللَّبَنِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S,) or"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"The udder abounded with milk:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"yielded milk copiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundantly:"},{"kind":"page_break","n":863},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"All~abana","text_ar":"اللَّبَنَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Adr~","text_ar":"ادرّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; or"},{"kind":"italic_en","text":"it yielded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emitted, the milk."},{"kind":"text","text":"] ―         -b9-  And [hence,]"},{"kind":"arabic","text_bw":"dar~ato Haluwbapu","text_ar":"دَرَّتْ حَلُوبَةُ"},{"kind":"arabic","text_bw":"Almusolimiyna","text_ar":"المُسْلِمِينَ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"liqoHatuhumo","text_ar":"لِقْحَتُهُمْ"},{"kind":"text","text":", (TA,) [lit."},{"kind":"italic_en","text":"The milch-camel of the Muslims yielded milk copiously,"},{"kind":"text","text":"] meaning (tropical:)"},{"kind":"italic_en","text":"the tribute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"taxes, pertaining to the Muslims poured in abundantly."},{"kind":"text","text":"(S, * A, TA.) ―         -b10-  And"},{"kind":"arabic","text_bw":"dar~ati Als~amaA='u biAlmaTari","text_ar":"دَرَّتِ السَّمَا=ءُ بِالمَطَرِ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"dar~N","text_ar":"دَرٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":", (K,) (assumed tropical:)"},{"kind":"italic_en","text":"The sky poured down rain"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"abundantly."},{"kind":"text","text":"(TA.) ―         -b11-  And"},{"kind":"arabic","text_bw":"dar~abimaA Einodahu","text_ar":"دَرَّبِمَا عِنْدَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He produced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave forth, what he had."},{"kind":"text","text":"(A.) ―         -b12-  And"},{"kind":"arabic","text_bw":"dar~ati Ald~unoyaA EalaY A^aholihaA","text_ar":"دَرَّتِ الدُّنْيَا عَلَى اَهْلِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The world was bountiful to its inhabitants."},{"kind":"text","text":"(A.) ―         -b13-  And"},{"kind":"arabic","text_bw":"dar~ati Als~uwqu","text_ar":"دَرَّتِ السُّوقُ"},{"kind":"text","text":", (S in art."},{"kind":"arabic","text_bw":"gr","text_ar":"غر"},{"kind":"text","text":", and K,) inf. n."},{"kind":"arabic","text_bw":"dir~apN","text_ar":"دِرَّةٌ"},{"kind":"text","text":", (S ubi suprà,) (tropical:)"},{"kind":"italic_en","text":"The market became brisk, its goods selling much;"},{"kind":"text","text":"(S ubi suprà, K, TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"gaAr~at","text_ar":"غَارَّت"},{"kind":"text","text":". (S ubi suprà.) ―         -b14-  And"},{"kind":"arabic","text_bw":"dar~ati AlEuruwqu","text_ar":"دَرَّتِ العُرُوقُ"},{"kind":"italic_en","text":"The ducts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veins, became filled with milk,"},{"kind":"text","text":"(TA,) or (tropical:)"},{"kind":"italic_en","text":"with blood."},{"kind":"text","text":"(A, TA.) ―         -b15-  And"},{"kind":"arabic","text_bw":"dar~a AlEiroqu","text_ar":"دَرَّ العِرْقُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The vein pulsated uninterruptedly."},{"kind":"text","text":"(TA.) ―         -b16-  And"},{"kind":"arabic","text_bw":"dar~F Als~ahomu","text_ar":"دَرًّ السَّهْمُ"},{"kind":"text","text":", (AHn, K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"duruwrN","text_ar":"دُرُورٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The arrow turned round well upon the nail"},{"kind":"text","text":"(AHn, K *)"},{"kind":"italic_en","text":"of the left thumb,"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"so as to produce a sound,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"Han~aAnN","text_ar":"حَنَّانٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"being turned with the thumb and fore finger of the right hand"},{"kind":"text","text":"[for the purpose of testing its sonorific quality]: the arrow does not thus turn, nor does it produce the kind of sound termed"},{"kind":"arabic","text_bw":"Haniyn","text_ar":"حَنِين"},{"kind":"text","text":", unless in consequence of the hardness of its wood, and its goodly straightness, and its compact make. (AHn.)       -A2-"},{"kind":"arabic","text_bw":"dar~a","text_ar":"دَرَّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft, tender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supple."},{"kind":"text","text":"(IAar, K.)       -A3-  And"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a lamp)"},{"kind":"italic_en","text":"gave light, shone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly."},{"kind":"text","text":"(K.) ―         -b2-  And, aor."},{"kind":"arabic","text_bw":"yadar~u","text_ar":"يَدَرُّ"},{"kind":"text","text":". which is extr., (K,) or, as some say, the pret. is originally"},{"kind":"arabic","text_bw":"darira","text_ar":"دَرِرَ"},{"kind":"text","text":", [the sec. pers. being"},{"kind":"arabic","text_bw":"darirota","text_ar":"دَرِرْتَ"},{"kind":"text","text":",] and, if so, the aor. is not extr., (MF,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a man's face)"},{"kind":"italic_en","text":"became goodly after disease."},{"kind":"text","text":"(K.)"}],"source_refs":["Msb","K","TA","S","A","AHn","MF"]}]}}