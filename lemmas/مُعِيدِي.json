{"lemma":"مُعِيدِي","slug":"مُعِيدِي","root":"ع.#.د","root_slug":"ع-_-د","root_link":"/words/roots/ع-_-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n30955"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%90%D9%8A%D8%AF%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"active participle of عَيَّدَ (ʕayyada, “to hold a feast, to celebrate”)","tags":["active","form-ii","form-of","participle"]},{"pos":"verb","gloss":"passive participle of عَيَّدَ (ʕayyada)","tags":["form-ii","form-of","participle","passive"]},{"pos":"verb","gloss":"active participle of أَعَادَ (ʔaʕāda, “to repeat, bring back, restore”)","tags":["active","form-iv","form-of","participle"]}]},"etymology":{"source":"wiktextract","text":"From the root ع و د (ʕ w d)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30955","headword_ar":"مُعِيدٌ","root":"Ewd","body":[{"kind":"text","text":"A stallion-camel"},{"kind":"italic_en","text":"that has covered repeatedly;"},{"kind":"text","text":"(S, M, O, K;) and"},{"kind":"italic_en","text":"that does not require assistance in his doing so."},{"kind":"text","text":"(Sh, O.) ―         -b2-  And hence, (Sh, O,) applied to a man"},{"kind":"italic_en","text":"Acquainted with affairs,"},{"kind":"text","text":"(Sh, O, K,)"},{"kind":"italic_en","text":"not inexperienced therein,"},{"kind":"text","text":"(Sh, O,)"},{"kind":"italic_en","text":"possessing skill and ability to do a thing."},{"kind":"text","text":"(O, K. *) One says,"},{"kind":"arabic","text_bw":"fulaAnN muEiydN lih`*aA AlA^amori","text_ar":"فُلَانٌ مُعِيدٌ لِهٰذَا الاَمْرِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Such a one is able to do this thing:"},{"kind":"text","text":"(S, O, Msb, K: *) because accustomed, or habituated, to it. (Msb.) ―         -b3-  And hence, (O,) or because he returns to his prey time after time, (TA,) The"},{"kind":"italic_en","text":"lion,"},{"kind":"text","text":"(O, K, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Almubodiy^u AlmuEiydu","text_ar":"المُبْدِيُ المُعِيدُ"},{"kind":"text","text":"applied to God: ―         -b5-  and"},{"kind":"arabic","text_bw":"mubodiy^N muEiydN","text_ar":"مُبْدِيٌ مُعِيدٌ"},{"kind":"text","text":"applied to a man, and to a horse: see art."},{"kind":"arabic","text_bw":"bdA^","text_ar":"بدا"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"muEiydN","text_ar":"مُعِيدٌ"},{"kind":"text","text":"also signifies A road"},{"kind":"italic_en","text":"travelled and trodden time after time."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"EawodN","text_ar":"عَوْدٌ"},{"kind":"text","text":".]"}],"source_refs":["Sh","O","K","TA"]}]},"classical_definitions":null}