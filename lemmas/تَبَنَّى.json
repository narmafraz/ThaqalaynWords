assical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%AA%D8%A8%D9%86%D9%89/", "headword_ar": "تُبنى", "entries": [{"lexicon_id": "dictionary_52", "lexicon_en": "Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)", "lexicon_ar": "معجم البلدان لياقوت الحموي", "permalink": "https://arabiclexicon.hawramani.com/?p=138579#abe274", "body_html": "تُبنى:<br>بالضم ثم السكون، وفتح النون، والقصر: بلدة بحوران من أعمال دمشق قال النابغة:<br>فلا زال قبر بين تبنى وجاسم ... عليه، من الوسميّ، جود ووابل<br>فينبت حوذانا وعوفا منوّرا، ... سأهدي له من خير ما قال قائل<br>قصد الشعراء بالاستسقاء للقبور، وإن كان الميت لا ينتفع بذلك، أن ينزله الناس فيمروا على ذلك القبر فيرحّموا من فيه وقال ابن حبيب: تبنى قرية من أرض البثنية لغسان قال ذلك في تفسير قول كثيّر:<br>أكاريس حلّت منهم مرج راهط، ... فأكناف تبنى مرجها فتلالها<br>كأنّ القيان الغرّ، وسط بيوتهم، ... نعاج بجوّ من رماح حلالها"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}