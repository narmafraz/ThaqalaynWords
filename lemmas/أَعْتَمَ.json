"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["","n30448"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%AA%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to darken, to black out, to become dim","tags":["intransitive"]},{"pos":"verb","gloss":"to darken, to cloud, to dim","tags":["transitive"]},{"pos":"adj","gloss":"elative degree of مُعْتِم (muʕtim, “dark, cloudy”)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30448","headword_ar":"اعتمّ","root":"Em","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tEm~m","text_ar":"تعمّم","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstEm~","text_ar":"استعمّ","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"AEtm~","text_ar":"اعتمّ"},{"kind":"arabic","text_bw":"biAlEimaAmapi","text_ar":"بِالعِمَامَةِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tEm~m","text_ar":"تعمّم","orth_type":"arrow"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He attired himself with the turban:"},{"kind":"text","text":"(S, K:) and ↓"},{"kind":"arabic","text_bw":"tEm~m","text_ar":"تعمّم","orth_type":"arrow"},{"kind":"text","text":"is also expl. as meaning"},{"kind":"italic_en","text":"he attired himself with the helmet:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"with the garments of war."},{"kind":"text","text":"(TA.) ―         -b2-  And [hence] one says,"},{"kind":"arabic","text_bw":"AiEotam~ati AlA=kaAmu biAln~abaAti","text_ar":"اِعْتَمَّتِ الا=كَامُ بِالنَّبَاتِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taEam~amat","text_ar":"تَعَمَّمَت","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The hills became crowned with plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"bihaA ruw^uwsu AljibaAli","text_ar":"بِهَا رُوُوسُ الجِبَالِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taEam~amato","text_ar":"تَعَمَّمَتْ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The heads of the mountains became crowned with its light"},{"kind":"text","text":"]: referring to the sun, when its light has fallen upon the heads of the mountains and become to them like the turban. (Mgh.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AEtm~ All~abanu","text_ar":"اعتمّ اللَّبَنُ"},{"kind":"text","text":": see 2, last sentence. ―         -b4-  And"},{"kind":"arabic","text_bw":"AEtm~ Aln~abtu","text_ar":"اعتمّ النَّبتُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, became of its full height, and blossomed,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Aikotahala","text_ar":"اِكْتَهَلَ"},{"kind":"text","text":", (S, K, TA,) and"},{"kind":"arabic","text_bw":"TaAla","text_ar":"طَالَ"},{"kind":"text","text":"; and"},{"kind":"italic_en","text":"became luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant and dense:"},{"kind":"text","text":"(TA:) like"},{"kind":"arabic","text_bw":"Agtm~","text_ar":"اغتمّ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"gm","text_ar":"غم"},{"kind":"text","text":".) ―         -b5-  And"},{"kind":"arabic","text_bw":"AEtm~ Al$~aAb~u","text_ar":"اعتمّ الشَّابُّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man, became tall."},{"kind":"text","text":"(S.) ―         -b6-  And"},{"kind":"arabic","text_bw":"AEtm~","text_ar":"اعتمّ"},{"kind":"text","text":"is said of a beast of the bovine kind as meaning (assumed tropical:)"},{"kind":"italic_en","text":"He had all his teeth grown."},{"kind":"text","text":"(As, TA. [See"},{"kind":"arabic","text_bw":"EamamN","text_ar":"عَمَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaDobN","text_ar":"عَضْبٌ"},{"kind":"text","text":".])"}],"source_refs":["K","S","TA"]}]},"classical_definitions":null}