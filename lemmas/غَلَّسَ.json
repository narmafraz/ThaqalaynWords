n.com/?s=%D8%BA%D9%8E%D9%84%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"the timespan between daybreak and sunrise; the morning twilight, the morning half-light; dawn"},{"pos":"verb","gloss":"to journey in the darkness of the last part of the night","tags":["intransitive"]},{"pos":"verb","gloss":"to perform in the darkness of the last part of the night","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Compare Tigre ቀለስ (ḳäläs, “today's morning, this morning”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32229","headword_ar":"غلّس","root":"gls","body":[{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tagoliysN","text_ar":"تَغْلِيسٌ"},{"kind":"text","text":", (S, Mgh, Msb,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a company of men, Msb, K,)"},{"kind":"italic_en","text":"journeyed in the"},{"kind":"arabic","text_bw":"galas","text_ar":"غَلَس"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"darkness of the last part of the night:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"went forth in the"},{"kind":"arabic","text_bw":"galas","text_ar":"غَلَس"},{"kind":"text","text":". (Mgh, Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"gl~swA","text_ar":"غلّسوا"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"gl~swA","text_ar":"غلّسوا"},{"kind":"arabic","text_bw":"AlmaA='a","text_ar":"المَا=ءَ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"They came to the water in the"},{"kind":"arabic","text_bw":"galas","text_ar":"غَلَس"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"darkness of the last part of the night,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"beginning of daybreak:"},{"kind":"text","text":"and in like manner you say of birds of the kind called"},{"kind":"arabic","text_bw":"qaTFA","text_ar":"قَطًا"},{"kind":"text","text":", and of [wild] asses. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"gl~s biAlS~alaApi","text_ar":"غلّس بِالصَّلَاةِ"},{"kind":"italic_en","text":"He performed the prayer"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of daybreak"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"galas","text_ar":"غَلَس"},{"kind":"text","text":". (S, * Mgh, Msb.)"}],"source_refs":["Msb","K","S","Mgh"]},{"entry_id":"n32231","headword_ar":"غَلَسٌ","root":"gls","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"darkness of the last part of the night,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"when it becomes mixed with the light of the dawn:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"beginning of the dawn, until it spreads in the tracts of the horizon:"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"gabasN","text_ar":"غَبَسٌ"},{"kind":"text","text":": both signify"},{"kind":"italic_en","text":"blackness mixed with whiteness and redness;"},{"kind":"text","text":"like the dawn. (Az, TA.)"},{"kind":"arabic","text_bw":"bigalasK","text_ar":"بِغَلَسٍ"},{"kind":"italic_en","text":"In a period of the darkness so called."},{"kind":"text","text":"(S, Msb, K.) [See also"},{"kind":"arabic","text_bw":"gaba$N","text_ar":"غَبَشٌ"},{"kind":"text","text":".]"}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_definitions":null}