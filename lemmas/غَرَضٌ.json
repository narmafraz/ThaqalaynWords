", "text": "intends,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "purposes, to attain:"}, {"kind": "text", "text": "(B:)"}, {"kind": "italic_en", "text": "an object of want,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "of desire:"}, {"kind": "text", "text": "(TA:) the"}, {"kind": "italic_en", "text": "advantage,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "good, which one seeks,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "endeavours,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "purposes, to attain,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "obtain, from a thing:"}, {"kind": "text", "text": "so much used in this tropical sense as to be, in this sense, conventionally regarded as proper. (MF.) You say,"}, {"kind": "arabic", "text_bw": "garaDuhu ka*aA", "text_ar": "غَرَضُهُ كَذَا"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "His object of aim"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "endeavour"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pursuit,"}, {"kind": "text", "text": "&c.,"}, {"kind": "italic_en", "text": "is such a thing:"}, {"kind": "text", "text": "(Msb:) or"}, {"kind": "italic_en", "text": "his object of want,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "of desire, is such a thing"}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "faEala", "text_ar": "فَعَلَ"}, {"kind": "arabic", "text_bw": "ligaraDK SaHiyHK", "text_ar": "لِغَرَضٍ صَحِيحٍ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "He did,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "acted, for a just,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "right, object of aim"}, {"kind": "text", "text": "&c. (Msb.) And"}, {"kind": "arabic", "text_bw": "fahimotu", "text_ar": "فَهِمْتُ"}, {"kind": "arabic