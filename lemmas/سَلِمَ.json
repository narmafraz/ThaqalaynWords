{"lemma":"سَلِمَ","slug":"سَلِمَ","root":"س.ل.م","root_slug":"س-ل-م","root_link":"/words/roots/س-ل-م","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَلِمْتَ","in_corpus":true,"count":31,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَلِمْتِ","in_corpus":true,"count":31,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَلِمْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَلِمْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَلِمْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَلِمَ","in_corpus":true,"count":16,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَلِمَت","in_corpus":true,"count":31,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَلِما","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَلِمَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَلِمُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَلِمْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْلَم","in_corpus":true,"count":21,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْلَمِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْلَمِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْلَما","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْلَمانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْلَمُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْلَمُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْلَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْلَم","in_corpus":true,"count":69,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْلَم","in_corpus":true,"count":21,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْلَما","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْلَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْلَما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْلَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْلَمُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْلَمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْلَمْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْلَم","in_corpus":true,"count":66,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْلَم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَلِمْنا","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَلِمْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":314,"cross_references":{"qac":{"found":true,"lemma_key":"سَلِمَ","root":"سلم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":11,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":17},"lanes":{"found":true,"entry_ids":["n20529"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%90%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"peace","tags":["uncountable"],"examples":[{"text":"إِنْ أَرَدْتَ السِّلْمَ فَتَأَهَّبْ لِلْحَرْبِ.","english":"If you want peace, then prepare for war."},{"text":"وَإِن جَنَحُوا لِلسَّلْمِ فَٱجْنَحْ لَهَا","english":"And if they incline to peace, incline to it too."}]},{"pos":"adj","gloss":"peaceful","examples":[{"text":"أَنَا سِلْمٌ لِمَنْ سَالَمَنِي.","english":"I am peaceful to him who keeps peace to me."}]},{"pos":"noun","gloss":"submission, surrender","examples":[{"text":"وَأَلْقَوْا إِلَى ٱللَّٰهِ يَوْمَئِذٍ ٱلسَّلَمَ ۖ وَضَلَّ عَنْهُم مَّا كَانُوا يَفْتَرُونَ","english":"And they proffer unto God on that day submission, and the idols they fell for failed them."}]},{"pos":"adj","gloss":"in peace","examples":[{"text":"ضَرَبَ ٱللّٰهُ مَثَلًا رَّجُلًا فِيهِ شُرَكَاءُ مُتَشَاكِسُونَ وَرَجُلًا سَلَمًا لِّرَجُلٍ هَلْ يَسْتَوِيَانِ مَثَلًا ۚ ٱلْحَمْدُ لِلَّٰهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","english":"God coined a simile: A man with various partners disputing and a man in peace. Are the two equal in the simile? Praise be to God! But most of them know not."}]},{"pos":"noun","gloss":"ladder, stairs","examples":[{"text":"وَإِن كَانَ كَبُرَ عَلَيْكَ إِعْرَاضُهُمْ فَإِنِ ٱسْتَطَعْتَ أَن تَبْتَغِيَ نَفَقًا فِي ٱلْأَرْضِ أَوْ سُلَّمًا فِي ٱلسَّمَاءِ فَتَأْتِيَهُم بِآيَةٍ","english":"And if their aversion is grievous unto thee, then, if thou canst, seek a way down into the earth or a ladder unto the sky that thou mayst bring unto them a portent (to convince them all)!"}]},{"pos":"verb","gloss":"to be safe, to be well"},{"pos":"verb","gloss":"to be free (from); to become free (from), to escape (from)","examples":[{"text":"High honor is not spared from harm until blood has been shed at its sides."}]},{"pos":"verb","gloss":"to surrender","tags":["transitive"]},{"pos":"verb","gloss":"to submit to, to be submissive to; to succumb, to yield or to surrender to","examples":[{"text":"فَلَا وَرَبِّكَ لَا يُؤْمِنُونَ حَتَّى يُحَكِّمُوكَ فِيمَا شَجَرَ بَيْنَهُمْ ثُمَّ لَا يَجِدُوا فِي أَنْفُسِهِمْ حَرَجًا مِمَّا قَضَيْتَ وَيُسَلِّمُوا تَسْلِيمًا","english":"But nay, by thy Lord, they will not believe until they make thee judge about the dispute arising between them and find between themselves no trammel from what thou rulest and submit with whole submission."}]},{"pos":"verb","gloss":"to greet (with عَلَى (ʕalā))"},{"pos":"verb","gloss":"to make safe, to keep safe, to protect","examples":[{"text":"اللّٰهُ يُسَلِّمُكَ","english":"you're welcome; may God protect you; get well soon; goodbye (as an answer)"},{"text":"إِذْ يُرِيكَهُمُ ٱللَّٰهُ فِي مَنَامِكَ قَلِيلًا ۖ وَلَوْ أَرَاكَهُمْ كَثِيرًا لَّفَشِلْتُمْ وَلَتَنَازَعْتُمْ فِي ٱلْأَمْرِ وَلَٰكِنَّ ٱللَّٰهَ سَلَّمَ ۗ إِنَّهُ عَلِيمٌ بِذَاتِ ٱلصُّدُورِ","english":"When God showed them unto thee in thy dream as few, and if he had shown them to thee as many, ye would have dithered and would have made a fuss of the matter, but God kept you safe of it, for he knows how the breasts of the people go."}]},{"pos":"verb","gloss":"to hand over, to deliver","examples":[{"text":"فقالَ لِأتباعِهِ أكثَرَ مِن مَرَّةٍ إنَّهُ سيُسَلَّمُ.","english":"He told his followers more than once that he would be handed over."}]},{"pos":"verb","gloss":"to admit, to concede, to grant"},{"pos":"noun","gloss":"stones","tags":["collective"],"examples":[{"text":"١ عَفَتِ الدِّيارُ مَحَلُّهَا فَمُقَامُهَا * بمنًى تأبَّدَ غَوْلُها فَرِجَامُهَا\n٢ فمَدافعُ الرَّيَّانِ عُرِّيَ رَسْمُهَا * خَلَقًا كما ضَمِنَ الوُحِيَّ سِلاَمُها\n٣ دِمَنٌ تَجَرَّمَ بَعدَ عَهْدِ أنِيسِهَا * حِجَجٌ خَلَوْنَ حَلالُهَا وحَرَامُهَا\n٤ رُزِقَتْ مَرابيعَ النُّجُومِ وَصَابَهَا * وَدْقُ الرَّوَاعِدِ جَوْدُهَا فَرِهَامُها\n٥ مِنْ كلِّ سَارِيَةٍ وغادٍ مُدْجِنٍ * وَعَشِيَّةٍ مُتجاوبٍ إرْزَامُهَا\n٦ فَعَلا فُرُوعُ الأيْهُقَانِ وَأطْفَلَتْ * بالجَلهَتين ظِبَاؤهَا ونَعَامُهَا","english":"Effaced are her resting-places where she stayed and settled in Mina: deserted are her camps in Ḡawl and ar-Rijām\nand the torrents of ar-Rayyān: the traces thereof are laid bare and are torn, as inscribed rocks.\nCampsites have already passed after their period of use; years of war and peace overcome.\nCast off there fell upon them the rains of spring signs, and there swept sated thunder clouds and drizzling rains\nfrom every cloud of night, every full one of morn, and those of eve, answering like a hoting squawk,\nand there sprung shoots of arugula, and in the brinks of a valley the goats and antelopes have youngs."}]},{"pos":"noun","gloss":"Vachellia flava syn. Acacia ehrenbergiana (species of drought-resistant trees in the genus Vachellia)","tags":["collective"]},{"pos":"noun","gloss":"captives","tags":["collective"]},{"pos":"noun","gloss":"futures contract, time bargain, forward transaction"}]},"etymology":{"source":"wiktextract","text":"From Aramaic סוּלַם (sulam), with influence from Hebrew סֻלָּם (sullām) – compare against Classical Syriac ܣܒܠܬܐ (sebbelṯā) and Classical Mandaic ࡎࡅࡌࡁࡉࡋࡕࡀ (sumbiltā) – from Akkadian 𒄑𒄿𒇻 (simmiltum, “stair; stairs; ladder”).\n\nCognates include Hebrew שלם and Aramaic שלם."},"ipa":["/silm/","/sul.lam/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20529","headword_ar":"سَلِمَ","root":"slm","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"salaAmapN","text_ar":"سَلَامَةٌ"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":", (Bd in xxxix. 30,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he escaped;"},{"kind":"text","text":"(M, TA;) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free;"},{"kind":"text","text":"(TA;)"},{"kind":"arabic","text_bw":"mina AlA=faAti","text_ar":"مِنَ الا=فَاتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from evils of any kind"},{"kind":"text","text":"], (S, Mgh,) or"},{"kind":"arabic","text_bw":"mina AlA=fapi","text_ar":"مِنَ الا=فَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from evil of any kind"},{"kind":"text","text":"], (K,) or"},{"kind":"arabic","text_bw":"mina AlbalaA='i","text_ar":"مِنَ البَلَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction"},{"kind":"text","text":"], (A, TA,) or"},{"kind":"arabic","text_bw":"mina AlA^amori","text_ar":"مِنَ الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the affair"},{"kind":"text","text":"]: (M:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a traveller)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, safe, secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, from evils of any kind:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"salima mina AlEayobi","text_ar":"سَلِمَ مِنَ العَيْبِ"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from fault, defect, imperfection, blemish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vice;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"bariy^a","text_ar":"بَرِيَ"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"brA^","text_ar":"برا"},{"kind":"text","text":".) [Hence,] one says,"},{"kind":"arabic","text_bw":"laA bi*iY tasolamu maA kaAna","text_ar":"لَا بِذِى تَسْلَمُ مَا كَانَ"},{"kind":"arabic","text_bw":"Ga*aA waka*aA","text_ar":"گَذَا وَكَذَا"},{"kind":"text","text":", (ISk, S, K, *) meaning"},{"kind":"italic_en","text":"No, by God"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who maketh thee to be in safety,"},{"kind":"text","text":"(ISk, S, K,) ["},{"kind":"italic_en","text":"such and such things were not;"},{"kind":"text","text":"] and to two persons"},{"kind":"arabic","text_bw":"lA b*Y tasolamaAni","text_ar":"لا بذى تَسْلَمَانِ"},{"kind":"text","text":", and to a pl. number"},{"kind":"arabic","text_bw":"lA b*Y tasolamuwna","text_ar":"لا بذى تَسْلَمُونَ"},{"kind":"text","text":", and to a female"},{"kind":"arabic","text_bw":"lA b*Y tasolamiyna","text_ar":"لا بذى تَسْلَمِينَ"},{"kind":"text","text":", and to a pl. number [of females]"},{"kind":"arabic","text_bw":"lA b*Y tasolamona","text_ar":"لا بذى تَسْلَمْنَ"},{"kind":"text","text":". (ISk, S, K. *) And"},{"kind":"arabic","text_bw":"laA A^afoEalu *`lika bi*iY tasolamu","text_ar":"لَا اَفْعَلُ ذٰلِكَ بِذِى تَسْلَمُ"},{"kind":"text","text":", meaning,"},{"kind":"arabic","text_bw":"bi*iY salaAmatiki","text_ar":"بِذِى سَلَامَتِكِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I will not do that, by the Author"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"Lord"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Master"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of thy safety"},{"kind":"text","text":"]; and in like manner,"},{"kind":"arabic","text_bw":"b*Y tasolamaAni","text_ar":"بذى تَسْلَمَانِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"b*Y tasolamuwna","text_ar":"بذى تَسْلَمُونَ"},{"kind":"text","text":". (Sb, M. [See also"},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Ai*ohabo bi*iY tasolamu","text_ar":"اِذْهَبْ بِذِى تَسْلَمُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"Ai*ohabo bisalaAmatika","text_ar":"اِذْهَبْ بِسَلَامَتِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Go thou with thy safety;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"with the Author of thy safety"},{"kind":"text","text":"to protect thee; meaning"},{"kind":"italic_en","text":"go thou in safety"},{"kind":"text","text":"]; and [to two persons]"},{"kind":"arabic","text_bw":"Ai*ohabaA bi*iY tasolamaAni","text_ar":"اِذْهَبَا بِذِى تَسْلَمَانِ"},{"kind":"text","text":". (S, K.)"},{"kind":"arabic","text_bw":"*Y","text_ar":"ذى"},{"kind":"text","text":"is thus prefixed to a verb [as virtually governing it in the gen. case] like as"},{"kind":"arabic","text_bw":"A=yap","text_ar":"ا=يَة"},{"kind":"text","text":"is in an instance mentioned under this latter word; but these are two extr. instances; for only a noun significant of time is [regularly] prefixed to a verb, as in the phrase"},{"kind":"arabic","text_bw":"h`*aA yawomu yufoEalu","text_ar":"هٰذَا يَوْمُ يُفْعَلُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"yufoEalu fiyhi","text_ar":"يُفْعَلُ فِيهِ"},{"kind":"text","text":": (Akh, S:) it is not prefixed to any but this verb"},{"kind":"arabic","text_bw":"tasolamu","text_ar":"تَسْلَمُ"},{"kind":"text","text":"[and its variations as above mentioned]. (Sb, M, K.) ―         -b2-  And hence, (Mgh,) one says also,"},{"kind":"arabic","text_bw":"salimato lahu AlD~ayoEapu","text_ar":"سَلِمَتْ لَهُ الضَّيْعَةُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"The landed estate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from participation to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xalaSat","text_ar":"خَلَصَت"},{"kind":"text","text":". (Mgh, TA.)       -A2-"},{"kind":"arabic","text_bw":"slmhu","text_ar":"سلمهُ"},{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"salamahu","text_ar":"سَلَمَهُ"},{"kind":"text","text":", or perhaps"},{"kind":"arabic","text_bw":"salimahu","text_ar":"سَلِمَهُ"},{"kind":"text","text":", for some verbs of this measure are trans., as"},{"kind":"arabic","text_bw":"Hasiba","text_ar":"حَسِبَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wariva","text_ar":"وَرِثَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"slm","text_ar":"سلم"},{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":", q. v. infrà,]"},{"kind":"italic_en","text":"He made him a captive."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"salamatohu AlHay~apu","text_ar":"سَلَمَتْهُ الحَيَّةُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (M, K, TA,)"},{"kind":"italic_en","text":"The serpent bit him:"},{"kind":"text","text":"(M, * K, * TA:) mentioned by Az, but he adds that no one but Lth has said this. (TA.)       -A4-"},{"kind":"arabic","text_bw":"salama Aljiloda","text_ar":"سَلَمَ الجِلْدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He tanned the skin with"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"leaves of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mimosa flava"},{"kind":"text","text":"]. (S, K, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"salama","text_ar":"سَلَمَ"},{"kind":"arabic","text_bw":"Ald~alowa","text_ar":"الدَّلْوَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He finished making the leathern bucket;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"made it firm, strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it firmly, strongly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundly."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","M","A","Mgh","Msb","K","TA","ISk","Akh"]}]}}