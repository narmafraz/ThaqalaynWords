{"lemma":"تَيْسِ","slug":"تَيْسِ","root":"ت.#.س","root_slug":"ت-_-س","root_link":"/words/roots/ت-_-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n4243","n4244"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%8A%D9%92%D8%B3%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a male goat; billy goat, he-goat"}]},"etymology":{"source":"wiktextract","text":"Compare Aramaic תֵּישָׁא / תַּיְשָׁא (tēšā / tayšā, “goat”) and Hebrew תַּיִשׁ (táyish, “billy goat”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4243","headword_ar":"تَيْسٌ","root":"tys","body":[{"kind":"italic_en","text":"A he-goat;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"male of the"},{"kind":"arabic","text_bw":"maEoz","text_ar":"مَعْز"},{"kind":"text","text":": (S,* M, A, K:) and the"},{"kind":"italic_en","text":"male of the mountain-goat:"},{"kind":"text","text":"(A, K) and"},{"kind":"italic_en","text":"of the gazelle:"},{"kind":"text","text":"(S, M, A, K:) the female of the last [as well as of the first and second] is called"},{"kind":"arabic","text_bw":"EanozN","text_ar":"عَنْزٌ"},{"kind":"text","text":": (S, M:) or"},{"kind":"italic_en","text":"that has completed a year:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"a yearling he-goat:"},{"kind":"text","text":"before the year it is called"},{"kind":"arabic","text_bw":"jadoYN","text_ar":"جَدْىٌ"},{"kind":"text","text":": (AZ, * Msb, TA:) pl. (of pauc.,"},{"kind":"page_break","n":325},{"kind":"text","text":"M)"},{"kind":"arabic","text_bw":"A^atoyaAsN","text_ar":"اَتْيَاسٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"A^atoyusN","text_ar":"اَتْيُسٌ"},{"kind":"text","text":", (M, TA,) and (of mult., M)"},{"kind":"arabic","text_bw":"tuyuwsN","text_ar":"تُيُوسٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"tiyasapN","text_ar":"تِيَسَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"matoyuwsaA='u","text_ar":"مَتْيُوسَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"ma$oyuwxaA='u","text_ar":"مَشْيُوخَا=ءُ"},{"kind":"text","text":", q. v.]: (K:) the last [which is properly a quasi-pl. n.] signifies the same as"},{"kind":"arabic","text_bw":"tuyuwsN","text_ar":"تُيُوسٌ"},{"kind":"text","text":", (S,) or"},{"kind":"italic_en","text":"a herd of"},{"kind":"arabic","text_bw":"tuyuws","text_ar":"تُيُوس"},{"kind":"text","text":". (M.) You say of the"},{"kind":"arabic","text_bw":"nak~aAH","text_ar":"نَكَّاح"},{"kind":"text","text":", [i. e. of him who marries often, or the like,]"},{"kind":"arabic","text_bw":"baniY fulaAnK","text_ar":"بَنِى فُلَانٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa mino mutoyuwsaA='i","text_ar":"هُوَ مِنْ مُتْيُوسَا=ءِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"He is of the he-goats of the sons of such a one"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["A","K","S","M","TA","Msb"]},{"entry_id":"n4244","headword_ar":"تَيَسٌ","root":"tys","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"in a she-goat,"},{"kind":"italic_en","text":"of having horns like those of the mountain-goat,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"in length."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":null}