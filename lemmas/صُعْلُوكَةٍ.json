{"lemma":"صُعْلُوكَةٍ","slug":"صُعْلُوكَةٍ","root":"ص.ع.ل.ك","root_slug":"ص-ع-ل-ك","root_link":"/words/roots/ص-ع-ل-ك","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n24369"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8F%D8%B9%D9%92%D9%84%D9%8F%D9%88%D9%83%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"poor, beggar, robber"}]},"etymology":null,"ipa":["/sˤuʕ.luːk/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24369","headword_ar":"صُعْلُوكٌ","root":"SElk","body":[{"kind":"italic_en","text":"Poor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needy;"},{"kind":"text","text":"(S, O, K, TA;) ["},{"kind":"italic_en","text":"a poor man;"},{"kind":"text","text":"] and ISd adds,"},{"kind":"italic_en","text":"having no property;"},{"kind":"text","text":"and Az adds,"},{"kind":"italic_en","text":"and having no reliance"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon any person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing"},{"kind":"text","text":"]: (TA:) and"},{"kind":"italic_en","text":"a thief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"robber:"},{"kind":"text","text":"(KL:) pl."},{"kind":"arabic","text_bw":"SaEaAliyku","text_ar":"صَعَالِيكُ"},{"kind":"text","text":". (S, O.)"},{"kind":"arabic","text_bw":"SaEaAliyku AlEarabi","text_ar":"صَعَالِيكُ العَرَبِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"*uw^obaAnuhaA","text_ar":"ذُوْبَانُهَا"},{"kind":"text","text":"[i. e., as expl. voce"},{"kind":"arabic","text_bw":"*iy^obN","text_ar":"ذِيْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The thieves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpers, and paupers, of the Arabs;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the paupers of the Arabs who practise thieving:"},{"kind":"text","text":"because they act like wolves]. (S, O.) 'Orweh Ibn-El-Ward was called"},{"kind":"arabic","text_bw":"Eurowapu AlS~aEaAliyki","text_ar":"عُرْوَةُ الصَّعَالِيكِ"},{"kind":"text","text":"because he used to collect the poor in a"},{"kind":"arabic","text_bw":"HaZiyrap","text_ar":"حَظِيرَة"},{"kind":"text","text":"[i. e. an enclosure for cattle] and sustain them by means of the plunder that he took. (S, O, K.)"}],"source_refs":["TA","KL"]}]},"classical_definitions":null}