سُوقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسُوقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسُق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسُوق","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسُق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسُوق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسُوقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسُوقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسُوقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسُوقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسُوقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسُوقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سُقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سُقْتُ","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسُوق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسُوق","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":63,"cross_references":{"qac":{"found":true,"lemma_key":"ساق","root":"سوق","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":20},"lanes":{"found":true,"entry_ids":["n20149","n21288"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to drive"},{"pos":"verb","gloss":"to conscript"},{"pos":"verb","gloss":"to pilot"},{"pos":"verb","gloss":"to transport"},{"pos":"verb","gloss":"to send"},{"pos":"verb","gloss":"to utter"},{"pos":"verb","gloss":"to cite, to quote"},{"pos":"noun","gloss":"leg"},{"pos":"noun","gloss":"shank"},{"pos":"noun","gloss":"side of an angle"},{"pos":"noun","gloss":"perpendicular"},{"pos":"noun","gloss":"trunk, stalk","examples":[{"text":"وَمَثَلُهُمْ فِي الْإِنجِيلِ كَزَرْعٍ أَخْرَجَ شَطْأَهُ فَآزَرَهُ فَاسْتَغْلَظَ فَاسْتَوَىٰ عَلَىٰ سُوقِهِ"}]},{"pos":"noun","gloss":"column, pillar"},{"pos":"noun","gloss":"scale (balance)"},{"pos":"noun","gloss":"genus, gender, kind"},{"pos":"noun","gloss":"pain, torment"},{"pos":"noun","gloss":"cupbearer"},{"pos":"noun","gloss":"water carrier"},{"pos":"noun","gloss":"barkeeper"},{"pos":"noun","gloss":"waiter"}]},"etymology":{"source":"wiktextract","text":"From Aramaic שָׁקָא (šāqā, “shin”), ultimately from Akkadian 𒆸 (sâqu, “to be narrow, skinny, or constricted”), cognate to native Arabic ضَيِّق (ḍayyiq, “narrow, pressed”); compare Classical Syriac ܫܩܐ (šāqā, “shin”), Hebrew שׁוֹק (shok, “shin”). Connected back to the root س و ق (s w q) by the urging on of animals with one's legs when riding or by driving them forward by tapping at their legs.\n\nDerived from the active participle of سَقَى (saqā, “to water”)."},"ipa":["/saː.qa/","/saːq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20149","headword_ar":"سَاقٍ","root":"sqY","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saq~aA='N","text_ar":"سَقَّا=ءٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Giving to drink;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one who gives to drink:"},{"kind":"text","text":"(K, TA:) the former signifies [generally as above, or"},{"kind":"italic_en","text":"a cup-bearer:"},{"kind":"text","text":"and also]"},{"kind":"italic_en","text":"watering"},{"kind":"text","text":"seed-produce; or"},{"kind":"italic_en","text":"a waterer"},{"kind":"text","text":"of seedproduce: (Msb:) [and ↓ the latter generally signifies"},{"kind":"italic_en","text":"a water-carrier:"},{"kind":"text","text":"] the pl. of the former is"},{"kind":"arabic","text_bw":"suq~FY","text_ar":"سُقًّى"},{"kind":"text","text":", (K, TA,) with damm and then teshdeed, (TA,) [accord. to the CK"},{"kind":"arabic","text_bw":"suqiY~N","text_ar":"سُقِىٌّ"},{"kind":"text","text":", which is app. a mistranscription,] and"},{"kind":"arabic","text_bw":"suq~aA='N","text_ar":"سُقَّا=ءٌ"},{"kind":"text","text":", (K, TA,) like"},{"kind":"arabic","text_bw":"rum~aAnN","text_ar":"رُمَّانٌ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"suqaApN","text_ar":"سُقَاةٌ"},{"kind":"text","text":": (CK: [this last is a well-known pl. of"},{"kind":"arabic","text_bw":"saAqK","text_ar":"سَاقٍ"},{"kind":"text","text":", and as such has occurred above, voce"},{"kind":"arabic","text_bw":"siqaAyapN","text_ar":"سِقَايَةٌ"},{"kind":"text","text":":]) the pl. of ↓"},{"kind":"arabic","text_bw":"saq~aA='N","text_ar":"سَقَّا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"saq~aAw^uwna","text_ar":"سَقَّاوُونَ"},{"kind":"text","text":": (K:) and a woman is termed ↓"},{"kind":"arabic","text_bw":"saq~aA='apN","text_ar":"سَقَّا=ءَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saq~aAyapN","text_ar":"سَقَّايَةٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) It is said in a prov.,"},{"kind":"quote","text":"↓ \n      Aisoqi raqaA$i A_in~ahaA saq~aAyapN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Give thou to drink to Rakáshi: verily she is one who gives to drink:"},{"kind":"arabic","text_bw":"raqaA$i","text_ar":"رَقَاشِ"},{"kind":"text","text":"being a woman's name]: it is applied to him who does good: meaning do thou good to him, because of his doing good. (A'Obeyd, S.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"saAqiY","text_ar":"سَاقِى"},{"kind":"arabic","text_bw":"AlEayoni","text_ar":"العَيْنِ"},{"kind":"italic_en","text":"A certain vein"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"the central artery of the retina"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which passes from the interior of the head to the eye, and the severing of which occasions the loss of the sight."},{"kind":"text","text":"(JK.) [See also the next paragraph.]"}],"source_refs":["K","TA","Msb"]},{"entry_id":"n21288","headword_ar":"سَاقٌ","root":"swq","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"shank;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"part between the knee and the foot"},{"kind":"text","text":"of a human being; (Msb;) or the"},{"kind":"italic_en","text":"part between the ankle and the knee"},{"kind":"text","text":"(K, TA) of a human being; (TA;) the"},{"kind":"arabic","text_bw":"sAq","text_ar":"ساق"},{"kind":"text","text":"of the human foot: (S, TA:) and [the"},{"kind":"italic_en","text":"part properly corresponding thereto,"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"thigh commonly so called,"},{"kind":"text","text":"and also the"},{"kind":"italic_en","text":"arm,"},{"kind":"text","text":"of a beast;] the"},{"kind":"italic_en","text":"part above the"},{"kind":"arabic","text_bw":"waZiyf","text_ar":"وَظِيف"},{"kind":"text","text":"of the horse and mule and ass and camel, and the"},{"kind":"italic_en","text":"part above the"},{"kind":"arabic","text_bw":"kuraAE","text_ar":"كُرَاع"},{"kind":"text","text":"of the ox-kind and sheep or goat and antelope: (TA:) [it is also sometimes applied to the"},{"kind":"italic_en","text":"shank commonly so called, of the hind leg,"},{"kind":"text","text":"and, less properly,"},{"kind":"italic_en","text":"of the fore leg,"},{"kind":"text","text":"of a beast: and to the"},{"kind":"italic_en","text":"bone of any of the parts above mentioned:"},{"kind":"text","text":"and sometimes, by synecdoche, to the"},{"kind":"italic_en","text":"hind leg,"},{"kind":"text","text":"and, less properly, to the"},{"kind":"italic_en","text":"fore leg"},{"kind":"text","text":"also, of a beast: it generally corresponds to"},{"kind":"arabic","text_bw":"*iraAEN","text_ar":"ذِرَاعٌ"},{"kind":"text","text":": of a bird, it is the"},{"kind":"italic_en","text":"thigh commonly so called:"},{"kind":"text","text":"and sometimes the"},{"kind":"italic_en","text":"shank commonly so called:"},{"kind":"text","text":"and, by synecdoche, the"},{"kind":"italic_en","text":"leg:"},{"kind":"text","text":"] it is of the fem. gender: (Msb, TA:) and for this reason, (TA,) the dim. is ↓"},{"kind":"arabic","text_bw":"suwayoqapN","text_ar":"سُوَيْقَةٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb, TA:) the pl. [of mult.] is"},{"kind":"arabic","text_bw":"suwqN","text_ar":"سُوقٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and"},{"kind":"arabic","text_bw":"siyqaAnN","text_ar":"سِيقَانٌ"},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^asow^uqN","text_ar":"اَسْوُقٌ"},{"kind":"text","text":", (S, O, K,) the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"in this last being with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"in order that it may bear the dammeh. (O, K.) A poet says,"},{"kind":"quote","text":"lilofataY EaqolN yaEiy$u bihi\n                      \n                     \n                        Hayovu tahodiY saAqahu qadamuho"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"The young man has intelligence whereby he lives when his foot directs aright his shank."},{"kind":"text","text":"(IAar, TA.) And one says of a man when difficulty, or calamity, befalls him,"},{"kind":"arabic","text_bw":"ka$afa Eano saAqihi","text_ar":"كَشَفَ عَنْ سَاقِهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He uncovered his shank;"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"he prepared himself for difficulty"},{"kind":"text","text":"]: so says IAmb: and hence, he says, (TA, [in which a similar explanation is cited from ISd also,]) they mention the"},{"kind":"arabic","text_bw":"sAq","text_ar":"ساق"},{"kind":"text","text":"when they mean to express the difficulty of a case or an event, and to tell of the terror occasioned thereby. (K, TA.) Thus, the saying"},{"kind":"arabic","text_bw":"yawoma yuko$afu Eano saAqK","text_ar":"يَوْمَ يُكْشَفُ عَنْ سَاقٍ"},{"kind":"text","text":", (S, K, TA,) in the Kur [lxviii. 42], (S, TA,) [lit."},{"kind":"italic_en","text":"On a day when a shank shall be uncovered,"},{"kind":"text","text":"] means (assumed tropical:)"},{"kind":"italic_en","text":"on a day when difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calamity, shall be disclosed."},{"kind":"text","text":"(I'Ab, Mujáhid, S, K, TA.) It is like the saying,"},{"kind":"arabic","text_bw":"qaAmati AlHarobu EalaY saAqK","text_ar":"قَامَتِ الحَرْبُ عَلَى سَاقٍ"},{"kind":"text","text":", (S, TA,) which means (assumed tropical:)"},{"kind":"italic_en","text":"The war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battle, became vehement,"},{"kind":"text","text":"(Msb in this art. and in art."},{"kind":"arabic","text_bw":"Hrb","text_ar":"حرب"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"so that safety from destruction was difficult of attainment:"},{"kind":"text","text":"(Id. in art."},{"kind":"arabic","text_bw":"Hrb","text_ar":"حرب"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"ka$afati AlHarobu Eano saAqK","text_ar":"كَشَفَتِ الحَرْبُ عَنْ سَاقٍ"},{"kind":"text","text":", [as also"},{"kind":"arabic","text_bw":"$am~arato Eano saAqihaA","text_ar":"شَمَّرَتْ عَنْ سَاقِهَا"},{"kind":"text","text":",] i. e. (assumed tropical:)"},{"kind":"italic_en","text":"The war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battle, became vehement."},{"kind":"text","text":"(Jel in lxviii. 42.) And in like manner,"},{"kind":"arabic","text_bw":"waA@lotaf~ati A@ls~aAqu biAls~aAqi","text_ar":"وَا@لْتَفَّتِ ا@لسَّاقُ بِالسَّاقِ"},{"kind":"text","text":", (K, TA,) in the Kur [lxxv. 29], (TA,) means (assumed tropical:)"},{"kind":"italic_en","text":"And the affliction of the present state of existence shall be combined with that of the final state:"},{"kind":"text","text":"(K, TA:) or it means"},{"kind":"italic_en","text":"when the"},{"kind":"text","text":"[one]"},{"kind":"italic_en","text":"leg shall be inwrapped with the"},{"kind":"text","text":"other"},{"kind":"italic_en","text":"leg by means of the grave-clothes."},{"kind":"text","text":"(TA.) One says also,"},{"kind":"arabic","text_bw":"qaAma Alqawomu EalaY saAqK","text_ar":"قَامَ القَوْمُ عَلَى سَاقٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The people"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, became in a state of toil, and trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qaraEa liloA^amori saAqahu","text_ar":"قَرَعَ لِلْاَمْرِ سَاقَهُ"},{"kind":"text","text":", [originating from one's striking the shin of his camel in order to make him lie down to be mounted; lit."},{"kind":"italic_en","text":"He struck his shank for the affair;"},{"kind":"text","text":"] meaning (assumed tropical:)"},{"kind":"italic_en","text":"he prepared himself for the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ta$am~ara","text_ar":"تَشَمَّرَ"},{"kind":"text","text":": (JK:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active, and he rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastened, to do the thing;"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"he applied himself vigorously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diligently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with energy, to the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair; i. q."},{"kind":"arabic","text_bw":"$am~ara lahu","text_ar":"شَمَّرَ لَهُ"},{"kind":"text","text":"[q. v.]; (TA;) or"},{"kind":"arabic","text_bw":"tajar~ada lahu","text_ar":"تَجَرَّدَ لَهُ"},{"kind":"text","text":". (A and TA in art."},{"kind":"arabic","text_bw":"qrE","text_ar":"قرع"},{"kind":"text","text":"[q. v.: see also"},{"kind":"arabic","text_bw":"ZunobuwbN","text_ar":"ظُنْبُوبٌ"},{"kind":"text","text":", in several places].) [It is also said that]"},{"kind":"arabic","text_bw":"A^awohato bisaAqK","text_ar":"اَوْهَتْ بِسَاقٍ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"kidotu","text_ar":"كِدْتُ"},{"kind":"arabic","text_bw":"A^afoEalu","text_ar":"اَفْعَلُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I nearly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"almost, did"},{"kind":"text","text":"what I purposed: but this explanation seems to have been derived only from what here, as in the TA, immediately follows]: Kurt says, describing the wolf,"},{"kind":"quote","text":"wal`kin~iY ramayotuka mino baEiydK\n                      \n                     \n                        falamo A^afoEalo waqado A^awohato bisaAqi"},{"kind":"text","text":"[i. e., app.,"},{"kind":"italic_en","text":"But I shot at thee from afar, and I did not"},{"kind":"text","text":"what I purposed,"},{"kind":"italic_en","text":"though it"},{"kind":"text","text":"(the shot,"},{"kind":"arabic","text_bw":"Alr~amoyapu","text_ar":"الرَّمْيَةُ"},{"kind":"text","text":", I suppose, being meant to be understood,)"},{"kind":"italic_en","text":"maimed a shank:"},{"kind":"text","text":"which virtually means,"},{"kind":"italic_en","text":"though I nearly did what I purposed:"},{"kind":"text","text":"the poet, I assume, says"},{"kind":"arabic","text_bw":"Awht bsAq","text_ar":"اوهت بساق"},{"kind":"text","text":"for the sake of the measure and rhyme, for"},{"kind":"arabic","text_bw":"A^awohato saAqFA","text_ar":"اَوْهَتْ سَاقًا"},{"kind":"text","text":": see what is said, in the explanations of the preposition"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":", respecting the phrase"},{"kind":"arabic","text_bw":"waA@mosaHuwA biruw^u=sikumo","text_ar":"وَا@مْسَحُوا بِرُوُ=سِكُمْ"},{"kind":"text","text":"]. (TA.) ―         -b2-  By a secondary application,"},{"kind":"arabic","text_bw":"saAqN","text_ar":"سَاقٌ"},{"kind":"text","text":"signifies (assumed tropical:)  ["},{"kind":"italic_en","text":"A greave;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"a thing that is worn on the"},{"kind":"arabic","text_bw":"sAq","text_ar":"ساق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shank"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the leg, made of iron"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other material."},{"kind":"text","text":"(Mgh.) ―         -b3-  Also (tropical:)  [The"},{"kind":"italic_en","text":"stem, stock,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trunk,"},{"kind":"text","text":"i. e.] the"},{"kind":"italic_en","text":"part between the"},{"kind":"arabic","text_bw":"A^aSol","text_ar":"اَصْل"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot,"},{"kind":"text","text":"(though it is also syn. with"},{"kind":"arabic","text_bw":"sAq","text_ar":"ساق"},{"kind":"text","text":"in the sense in which the latter is here explained,)]"},{"kind":"italic_en","text":"and the place where the branches shoot out;"},{"kind":"text","text":"(TA;) or the"},{"kind":"italic_en","text":"support;"},{"kind":"text","text":"(Msb;) or the"},{"kind":"arabic","text_bw":"ji*oE","text_ar":"جِذْع"},{"kind":"text","text":"; (S, K;) of a tree, or shrub: (S, Msb, K, TA:) pl. [of mult.]"},{"kind":"arabic","text_bw":"suwqN","text_ar":"سُوقٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"suwqN","text_ar":"سُوقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suwuwqN","text_ar":"سُوُوقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suw^uwqN","text_ar":"سُوُوقٌ"},{"kind":"page_break","n":1472},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^asowuqN","text_ar":"اَسْوُقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^asow^uqN","text_ar":"اَسْوُقٌ"},{"kind":"text","text":". (TA.) It is related in a trad. of Mo'áwiyeh, that a man said, I applied to him to decide in a litigation with the son of my brother, and began to overcome him therein; whereupon he said, Thou art like as Aboo-Duwád says,"},{"kind":"quote","text":"A^an~aY A^utiyHa lahu HirobaA='u tanoDubapK\n                      \n                     \n                        laA yurosilu Als~aAqa A_il~aA mumosikFA saAqaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whencesoever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"however, a preparation is made for him,"},{"kind":"text","text":"to catch him, he is like"},{"kind":"italic_en","text":"a chameleon of a tree of the kind called"},{"kind":"arabic","text_bw":"tanoDub","text_ar":"تَنْضُب"},{"kind":"text","text":","},{"kind":"italic_en","text":"he will not loose the stem"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"unless grasping a stem"},{"kind":"text","text":"]: he meant that no plea of his came to nought but he clung to another; likening him to the chameleon, which places itself facing the sun, and ascends half-way up the tree, or shrub, then climbs to the branches when the sun becomes hot, then climbs to a higher branch, and will not loose the former until it grasps the other. (O, TA. *) ―         -b4-  [Hence, perhaps, as it seems to be indicated in the O,] one says,"},{"kind":"arabic","text_bw":"waladato fulaAnapu valaAvapa baniyna EalaY saAqK","text_ar":"وَلَدَتْ فُلَانَةُ ثَلَاثَةَ بَنِينَ عَلَى سَاقٍ"},{"kind":"text","text":", (K, [in the copies of which, however, I find"},{"kind":"arabic","text_bw":"valaAva","text_ar":"ثَلَاثَ"},{"kind":"text","text":"put for"},{"kind":"arabic","text_bw":"valaAvapa","text_ar":"ثَلَاثَةَ"},{"kind":"text","text":",]) or"},{"kind":"arabic","text_bw":"EalaY saAqK waAHidK","text_ar":"عَلَى سَاقٍ وَاحِدٍ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"waAHidapK","text_ar":"وَاحِدَةٍ"},{"kind":"text","text":", (O,) i. e. (tropical:)"},{"kind":"italic_en","text":"Such a woman brought forth three sons, one after another, without any girl between them:"},{"kind":"text","text":"(S, O, K, TA:) so says ISk: and"},{"kind":"arabic","text_bw":"wulida lifulaAnK valaAvapu","text_ar":"وُلِدَ لِفُلَانٍ ثَلَاثَةُ"},{"kind":"arabic","text_bw":"A^awolaAdK saAqFA EalaY saAqK","text_ar":"اَوْلَادٍ سَاقًا عَلَى سَاقٍ"},{"kind":"text","text":", i. e. (tropical:)"},{"kind":"italic_en","text":"Three children were born to such a one, one after another."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"banaY Alqawomu buyuwtahumo EalaY saAqK waAHidK","text_ar":"بَنَى القَوْمُ بُيُوتَهُمْ عَلَى سَاقٍ وَاحِدٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, built their houses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constructed their tents, in one row"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"series"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"saAqN","text_ar":"سَاقٌ"},{"kind":"text","text":"also signifies (assumed tropical:)  The"},{"kind":"italic_en","text":"soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":": hence the saying of 'Alee (in the war of the [schismatics called]"},{"kind":"arabic","text_bw":"$uraAp","text_ar":"شُرَاة"},{"kind":"text","text":"),"},{"kind":"arabic","text_bw":"laAbud~a liY mino qitaAlihimo walawo talifato saAqiY","text_ar":"لَابُدَّ لِى مِنْ قِتَالِهِمْ وَلَوْ تَلِفَتْ سَاقِى"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"There is not for me any way of avoiding combating them, though my soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self, should perish"},{"kind":"text","text":"by my doing so]. (Abu-l-' Abbás, O, TA.) So too in the saying,"},{"kind":"arabic","text_bw":"qadaHa fiY saAqihi","text_ar":"قَدَحَ فِى سَاقِهِ"},{"kind":"text","text":"[as though meaning (tropical:)"},{"kind":"italic_en","text":"He cankered his very soul"},{"kind":"text","text":"]: (IAar, TA in art."},{"kind":"arabic","text_bw":"qdH","text_ar":"قدح"},{"kind":"text","text":":) [or]"},{"kind":"italic_en","text":"he deceived him, and did that which was displeasing to him:"},{"kind":"text","text":"(L in that art.:) or (tropical:)"},{"kind":"italic_en","text":"he impugned his honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reputation;"},{"kind":"text","text":"from the action of canker-worms ("},{"kind":"arabic","text_bw":"qawaAdiH","text_ar":"قَوَادِح"},{"kind":"text","text":") cankering the stem, or trunk, of a shrub, or tree. (A in that art.)       -A2-"},{"kind":"arabic","text_bw":"saAqu Hur~K","text_ar":"سَاقُ حُرٍّ"},{"kind":"text","text":"[is said to signify] The"},{"kind":"italic_en","text":"male of the"},{"kind":"arabic","text_bw":"qamaAriY~","text_ar":"قَمَارِىّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"species of collared turtle-doves of which the female is called"},{"kind":"arabic","text_bw":"qumoriy~apN","text_ar":"قُمْرِيَّةٌ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"qumoriY~N","text_ar":"قُمْرِىٌّ"},{"kind":"text","text":")]; (S, Msb, K;) i. e. the"},{"kind":"arabic","text_bw":"wara$aAn","text_ar":"وَرَشَان"},{"kind":"text","text":": (S, Msb:) the former appellation being given to it as imitative of its cry: (As, K:) it has neither fem. nor pl.: (AHát, TA:) or"},{"kind":"arabic","text_bw":"Als~aAqu","text_ar":"السَّاقُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the pigeon;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlHur~u","text_ar":"الحُرُّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"its young one:"},{"kind":"text","text":"(Sh, K:) the poet Ibn-Harmeh uses the phrase"},{"kind":"arabic","text_bw":"kasaAqi A@boni Hur~K","text_ar":"كَسَاقِ ا@بْنِ حُرٍّ"},{"kind":"text","text":". (O, TA.) [See more in art."},{"kind":"arabic","text_bw":"Hr","text_ar":"حر"},{"kind":"text","text":".]"}],"source_refs":["K","TA","S","Msb","Mgh","O","JK","As","Sh"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D9%82/","headword_ar":"ساق","entries":[{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=61777#60518e","body_html":"<span class=\"title1\">س وق [ساق]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: يَوْمَ يُكْشَفُ عَنْ ساقٍ .</span><br><span>قال: عن شدة الآخرة.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت الشاعر وهو يقول:</span><br><span>أسلم عصام أنّه شر باق </span><span class=\"red\">...</span><span> قبلك سر الناس ضرب الأعناق </span><br><span>قد قامت الحرب بنا على ساق </span>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61777#c0b1f6","body_html":"<span class=\"title1\">ساق</span><br><span>سَوْقُ الإبل: جلبها وطردها، يقال: سُقْتُهُ فَانْسَاقَ، والسَّيِّقَةُ: ما يُسَاقُ من الدّوابّ. وسُقْتُ المهر إلى المرأة، وذلك أنّ مهورهم كانت الإبل، وقوله: إِلى رَبِّكَ يَوْمَئِذٍ الْمَساقُ</span><br><span>[القيامة/ 30] ، نحو قوله: وَأَنَّ إِلى رَبِّكَ الْمُنْتَهى [النجم/ 42] ، وقوله: سائِقٌ وَشَهِيدٌ</span><br><span>[ق/ 21] ، أي: ملك يَسُوقُهُ، وآخر يشهد عليه وله، وقيل: هو كقوله: كَأَنَّما يُساقُونَ إِلَى الْمَوْتِ</span><br><span>[الأنفال/ 6] ، وقوله: وَالْتَفَّتِ السَّاقُ بِالسَّاقِ</span><br><span>[القيامة/ 29] ، قيل:</span><br><span>عني التفاف الساقين عند خروج الروح. وقيل:</span><br><span>التفافهما عند ما يلفّان في الكفن، وقيل: هو أن يموت فلا تحملانه بعد أن كانتا تقلّانه، وقيل:</span><br><span>أراد التفاف البليّة بالبليّة نحو قوله تعالى: يَوْمَ يُكْشَفُ عَنْ ساقٍ [القلم/ 42] ، من قولهم:</span><br><span>كشفت الحرب عن ساقها، وقال بعضهم في قوله: يَوْمَ يُكْشَفُ عَنْ ساقٍ [القلم/ 42] :</span><br><span>إنه إشارة إلى شدّة ، وهو أن يموت الولد في بطن الناقة فيدخل المذمّر يده في رحمها فيأخذ بساقه فيخرجه ميّتا، قال: فهذا هو الكشف عن الساق، فجعل لكلّ أمر فظيع. وقوله:</span><br><span>فَاسْتَوى عَلى سُوقِهِ</span><br><span>[الفتح/ 29] ، قيل:</span><br><span>هو جمع ساق نحو: لابة ولوب، وقارة وقور، وعلى هذا: فَطَفِقَ مَسْحاً بِالسُّوقِ وَالْأَعْناقِ</span><br><span><div>[ص/ 33] ، ورجل أَسْوَقُ، وامرأة سَوْقَاءُ بيّنة السّوق، أي: عظيمة السّاق، والسُّوقُ: الموضع الذي يجلب إليه المتاع للبيع، قال: وَقالُوا مالِ هذَا الرَّسُولِ يَأْكُلُ الطَّعامَ وَيَمْشِي فِي الْأَسْواقِ</div>[الفرقان/ 7] ، والسَّوِيقُ سمّي لِانْسِوَاقِهِ في الحلق من غير مضغ. </span>"},{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=61777#d53edc","body_html":"ساق<br>عن العبرية بمعنى كيس. يستخدم للذكور."}]}}