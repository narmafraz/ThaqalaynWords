t_1ms","form":"أَغْتَمّ","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n31438","n32348"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%BA%D9%92%D8%AA%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be affect with grief, to make sad"},{"pos":"verb","gloss":"to be full of clouds"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31438","headword_ar":"اَغْتَمُ","root":"gtm","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"gutomiY~N","text_ar":"غُتْمِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (S, * K, * TA,) [and ↓"},{"kind":"arabic","text_bw":"A^agotamiY~N","text_ar":"اَغْتَمِىٌّ","orth_type":"arrow"},{"kind":"text","text":", occurring in the"},{"kind":"arabic","text_bw":"fAkhp AlxlfA='","text_ar":"فاكهة الخلفا=ء"},{"kind":"text","text":", p. 151, 1. 18, as mentioned by Freytag, who explains it as meaning “ barbarus, ”] One"},{"kind":"italic_en","text":"who does not utter anything with clearness, perspicuousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinctness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with chasteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correctness;"},{"kind":"text","text":"(S, Mgh, Msb, K, TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aEojamu","text_ar":"اَعْجَمُ"},{"kind":"text","text":": (TA:) fem. of the first,"},{"kind":"arabic","text_bw":"gatomaA='u","text_ar":"غَتْمَا=ءُ"},{"kind":"text","text":", applied to a woman: (Msb, TA:) pl. of the first"},{"kind":"arabic","text_bw":"gutomN","text_ar":"غُتْمٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"A^agotaAmN","text_ar":"اَغْتَامٌ"},{"kind":"text","text":", (Mgh,) or this latter is pl. of the second. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"gutomiY~N","text_ar":"غُتْمِىٌّ"},{"kind":"text","text":"."}],"source_refs":["S","Mgh","Msb","K","TA"]},{"entry_id":"n32348","headword_ar":"اغتمّ","root":"gm","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused to mourn"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lament,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to be sorrowful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unhappy;"},{"kind":"text","text":"(S, * K;) as also ↓"},{"kind":"arabic","text_bw":"Angm~","text_ar":"انغمّ","orth_type":"arrow"},{"kind":"text","text":": (K:) both mentioned by Sb. (TA.) ―         -b2-  And, said of a plant, or herbage,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tall,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and tangled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"luxuriant,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and abundant:"},{"kind":"text","text":"(K, TA:) as also"},{"kind":"arabic","text_bw":"AEtm~","text_ar":"اعتمّ"},{"kind":"text","text":". (TA.) [And in like manner ↓"},{"kind":"arabic","text_bw":"gam~a","text_ar":"غَمَّ","orth_type":"arrow"},{"kind":"text","text":"is expl. by Freytag as occurring in the Deewán of the Hudhalees, said of a plant, meaning"},{"kind":"italic_en","text":"It was tall and luxuriant."},{"kind":"text","text":"] ―         -b3-  And, said of a man,"},{"kind":"italic_en","text":"He withheld himself from going out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":null}