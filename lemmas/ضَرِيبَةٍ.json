{"lemma":"ضَرِيبَةٍ","slug":"ضَرِيبَةٍ","root":"ض.ر.ب","root_slug":"ض-ر-ب","root_link":"/words/roots/ض-ر-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n25704"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%B1%D9%90%D9%8A%D8%A8%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"tribute, tax, public levy"}]},"etymology":null,"ipa":["/dˤa.riː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25704","headword_ar":"ضَرِيبَةٌ","root":"Drb","body":[{"kind":"italic_en","text":"A man,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"anything,"},{"kind":"text","text":"(T, S, * TA,)"},{"kind":"italic_en","text":"living"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dead,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smitten, with the sword:"},{"kind":"text","text":"(T, S, K, TA:) the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is affixed, though the word has the meaning of a pass. part. n., because it becomes numbered with substs., like"},{"kind":"arabic","text_bw":"naTiyHapN","text_ar":"نَطِيحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^akiylapN","text_ar":"اَكِيلَةٌ"},{"kind":"text","text":". (S.) ―         -b2-  [And also] The"},{"kind":"italic_en","text":"place"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon which the blow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stroke, falls, of the body that is beaten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"struck."},{"kind":"text","text":"(Ham p. 129.) ―         -b3-  And"},{"kind":"italic_en","text":"Wool,"},{"kind":"text","text":"or ["},{"kind":"italic_en","text":"goats'"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hair, separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked asunder, with the fingers, and then folded together, and bound with a thread, and spun:"},{"kind":"text","text":"(S: [more fully expl. voce"},{"kind":"arabic","text_bw":"saliylapN","text_ar":"سَلِيلَةٌ"},{"kind":"text","text":":]) and"},{"kind":"italic_en","text":"wool that is beaten with a mallet:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a portion of wool:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a portion of cotton,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of wool:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"DaraAy^ibu","text_ar":"ضَرَايِبُ"},{"kind":"text","text":". (S.) ―         -b4-  Also (tropical:)"},{"kind":"italic_en","text":"An impost that is levied, of the poll-tax"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land-tax"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(S, A, Mgh, O, Msb, K, TA,) and"},{"kind":"italic_en","text":"of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the tolls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar exactions, termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^aroSaAd","text_ar":"اَرْصَاد"},{"kind":"text","text":": (S, O, TA:) pl. as above. (S, A, Mgh, &c.) And (hence, TA) (tropical:)  The"},{"kind":"arabic","text_bw":"gal~ap","text_ar":"غَلَّة"},{"kind":"text","text":"[as meaning the"},{"kind":"italic_en","text":"income,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revenue, arising from the service"},{"kind":"text","text":"] of a slave; (S, K, TA;) i. e."},{"kind":"arabic","text_bw":"Dariybapu AlEabodi","text_ar":"ضَرِيبَةُ العَبْدِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"what the slave pays to his master, of the impost that is laid upon him:"},{"kind":"arabic","text_bw":"DariybapN","text_ar":"ضَرِيبَةٌ"},{"kind":"text","text":"being of the measure"},{"kind":"arabic","text_bw":"faEiylapN","text_ar":"فَعِيلَةٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlapN","text_ar":"مَفْعُولَةٌ"},{"kind":"text","text":". (TA.) ―         -b5-  And (tropical:)"},{"kind":"italic_en","text":"A nature;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a natural, a native,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an innate, disposition"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"temper"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"[as though signifying"},{"kind":"italic_en","text":"a particular cast of constitution, moulded by the Creator:"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"TabiyEapN","text_ar":"طَبِيعَةٌ"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"sajiy~apN","text_ar":"سَجِيَّةٌ"},{"kind":"text","text":": (S:) pl. as above. (A, TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN kariymu AlD~ariybapi","text_ar":"فُلَانٌ كَرِيمُ الضَّرِيبَةِ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"Such a one is generous in respect of nature"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"lay^iymu AlD~ariybapi","text_ar":"لَيِيمُ الضَّرِيبَةِ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"mean"},{"kind":"text","text":"&c.]; (S;) and"},{"kind":"arabic","text_bw":"A_in~ahu lakariymu AlD~araAy^ibi","text_ar":"اـِنَّهُ لَكَرِيمُ الضَّرَايِبِ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"Verily he is generous in respect of natural dispositions"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"xuliqa Aln~aAsu EalaY DaraAy^iba $at~aY","text_ar":"خُلِقَ النَّاسُ عَلَى ضَرَايِبَ شَتَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Men are created of diverse natures"},{"kind":"text","text":"&c.]. (TA.) ―         -b6-  See also"},{"kind":"arabic","text_bw":"maDoribN","text_ar":"مَضْرِبٌ"},{"kind":"text","text":"."}],"source_refs":["K","T","TA","S","A","Mgh","O","Msb"]}]},"classical_definitions":null}