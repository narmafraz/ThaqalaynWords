"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n1175"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1175","headword_ar":"اَمَمٌ","root":"Am","body":[{"kind":"italic_en","text":"Nearness."},{"kind":"text","text":"(S, M, K.) ―         -b2-  ["},{"kind":"italic_en","text":"Near; nigh."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"A^axa*otu *lika mino A^amamK","text_ar":"اَخَذْتُ ذلِكَ مِنْ اَمَمٍ"},{"kind":"italic_en","text":"I took that from near; from nigh."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"daArukumo A^amamN","text_ar":"دَارُكُمْ اَمَمٌ"},{"kind":"italic_en","text":"Your house is near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nigh."},{"kind":"text","text":"(M, TA.) And"},{"kind":"arabic","text_bw":"huwa A^amamN minoka","text_ar":"هُوَ اَمَمٌ مِنْكَ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is near to thee:"},{"kind":"text","text":"and in like manner you say of two: (M, TA:) and of"},{"kind":"page_break","n":91},{"kind":"text","text":"a pl. number. (S, M, TA.) And"},{"kind":"arabic","text_bw":"daAriY A^amama daArihi","text_ar":"دَارِى اَمَمَ دَارِهِ"},{"kind":"italic_en","text":"My house is opposite to, facing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in front of, his house."},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"italic_en","text":"Easy:"},{"kind":"text","text":"(S, M, K:)"},{"kind":"italic_en","text":"near at hand; near to be reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laid hold of."},{"kind":"text","text":"(T, TA.) ―         -b4-"},{"kind":"italic_en","text":"Between near and distant."},{"kind":"text","text":"(ISk, T, S.) ―         -b5-"},{"kind":"italic_en","text":"Conforming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conformable, to the just mean:"},{"kind":"text","text":"(M, K: *) and ↓"},{"kind":"arabic","text_bw":"muw^aAm~N","text_ar":"مُوَامٌّ","orth_type":"arrow"},{"kind":"text","text":", (AA, T, S, M, K,) [in form] like"},{"kind":"arabic","text_bw":"muDaAr~N","text_ar":"مُضَارٌّ"},{"kind":"text","text":", (S,) originally"},{"kind":"arabic","text_bw":"muw^aAmimN","text_ar":"مُوَامِمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"the same;"},{"kind":"text","text":"(T;)"},{"kind":"italic_en","text":"of a middle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"middling, kind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sort; neither exceeding, nor falling short of, what is right;"},{"kind":"text","text":"(AA, T, S, M;) applied to an affair, or a case, (T, S,) and a thing [of any kind]; (S;) as also ↓"},{"kind":"arabic","text_bw":"muw^am~N","text_ar":"مُوَمٌّ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and"},{"kind":"italic_en","text":"convenient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suitable:"},{"kind":"text","text":"(M, K:) and"},{"kind":"arabic","text_bw":"A^amamN","text_ar":"اَمَمٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muw^aAm~N","text_ar":"مُوَامٌّ","orth_type":"arrow"},{"kind":"text","text":"both signify an affair, or a case, that is"},{"kind":"italic_en","text":"manifest, clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"not exceeding the due bounds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limits."},{"kind":"text","text":"(M.)"}],"source_refs":["M","TA","S","K","AA","T"]}]},"classical_definitions":null}