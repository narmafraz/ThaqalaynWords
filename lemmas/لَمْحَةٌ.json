{"lemma":"لَمْحَةٌ","slug":"لَمْحَةٌ","root":"ل.م.ح","root_slug":"ل-م-ح","root_link":"/words/roots/ل-م-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n37979"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D9%85%D9%92%D8%AD%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37979","headword_ar":"لَمْحَةٌ","root":"lmH","body":[{"kind":"text","text":", subst. from"},{"kind":"arabic","text_bw":"lamaHa","text_ar":"لَمَحَ"},{"kind":"text","text":", (S, L,)"},{"kind":"italic_en","text":"A glance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slight look."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"lamoHapN","text_ar":"لَمْحَةٌ"},{"kind":"italic_en","text":"A shining, gleaming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistening,"},{"kind":"text","text":"of lightning. (S.) ―         -b3-"},{"kind":"arabic","text_bw":"fiY fulaAnK lamoHapN mino A^abiyhi","text_ar":"فِى فُلَانٍ لَمْحَةٌ مِنْ اَبِيهِ"},{"kind":"italic_en","text":"In such a one is a likeness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point of resemblance, to his father:"},{"kind":"text","text":"then they said"},{"kind":"arabic","text_bw":"mino Abyh","text_ar":"مِنْ ابيه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"malAmiHu","text_ar":"مَلامِحُ","orth_type":"arrow"},{"kind":"text","text":", (S,) signifying"},{"kind":"italic_en","text":"likenessess,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"points of resemblance;"},{"kind":"text","text":"forming an extr. pl., (S, K,) as though from another word than"},{"kind":"arabic","text_bw":"lamoHapN","text_ar":"لَمْحَةٌ"},{"kind":"text","text":": (S:) they did not say"},{"kind":"arabic","text_bw":"malomaHapN","text_ar":"مَلْمَحَةٌ"},{"kind":"text","text":". (TA.) ―         -b4-  ↓"},{"kind":"arabic","text_bw":"malaAmiHu","text_ar":"مَلَامِحُ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"What appear of the beauties and defects of the face"},{"kind":"text","text":"(K) of a human being: or the"},{"kind":"italic_en","text":"parts thereof that are glanced at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"viewed lightly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quickly."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","L","K"]}]},"classical_definitions":null}