"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n39381"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%92%D8%AC%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to help, aid, assist, support"},{"pos":"verb","gloss":"to travel in the highland of Arabia (i.e. the Nejd)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39381","headword_ar":"انجد","root":"njd","body":[{"kind":"text","text":", (S, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_inojaAdN","text_ar":"اـِنْجَادٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"najada","text_ar":"نَجَدَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"nAjd","text_ar":"ناجد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"munaAjadapN","text_ar":"مُنَاجَدَةٌ"},{"kind":"text","text":"; (S, L;)"},{"kind":"italic_en","text":"He aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assisted,"},{"kind":"text","text":"another: (S, L, Msb, K;)"},{"kind":"italic_en","text":"he succoured"},{"kind":"text","text":"him. (L.) ―         -b2-"},{"kind":"arabic","text_bw":"Anjdhu Ealayohi","text_ar":"انجدهُ عَلَيْهِ"},{"kind":"italic_en","text":"He aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assisted, him against him."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"Anjd Ald~aEowapa","text_ar":"انجد الدَّعْوَةَ"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"He answered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complied with, the call, prayer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"invitation."},{"kind":"text","text":"(L, K.) And"},{"kind":"arabic","text_bw":"Anjdhu Ald~aEowapa","text_ar":"انجدهُ الدَّعْوَةَ"},{"kind":"italic_en","text":"He answered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complied with, his call, prayer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"invitation."},{"kind":"text","text":"(M, L.) ―         -b4-"},{"kind":"arabic","text_bw":"Anjd","text_ar":"انجد"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near to his family,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wife;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"qaruba mino A^aholihi","text_ar":"قَرُبَ مِنْ اَهْلِهِ"},{"kind":"text","text":". (Lh, ISd, K.)       -A2-"},{"kind":"arabic","text_bw":"Anjdt Als~amaA='u","text_ar":"انجدت السَّمَا=ءُ"},{"kind":"italic_en","text":"The sky became clear."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"Anjd","text_ar":"انجد"},{"kind":"text","text":"(L, K) and ↓"},{"kind":"arabic","text_bw":"tnj~d","text_ar":"تنجّد","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a person, or thing, L, both said of such a thing as a mountain, TA,)"},{"kind":"italic_en","text":"became high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lofty."},{"kind":"text","text":"(L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"gaAra waA^anojada","text_ar":"غَارَ وَاَنْجَدَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He became famous in the low countries and in the high."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"Anjd","text_ar":"انجد"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"A_inojaAdN","text_ar":"اـِنْجَادٌ"},{"kind":"text","text":", L,)"},{"kind":"italic_en","text":"He entered upon the country of Nejd:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"he came to Nejd,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to high land"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country:"},{"kind":"text","text":"(L, K:) or"},{"kind":"italic_en","text":"he went thither:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he went forth to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, it."},{"kind":"text","text":"(Lh, ISd, L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"A^anojada","text_ar":"اَنْجَدَ"},{"kind":"arabic","text_bw":"mano raA^aY HaDanaA","text_ar":"مَنْ رَاَى حَضَنَا"},{"kind":"text","text":", a proverb,"},{"kind":"italic_en","text":"He enters Nejd who sees Hadan,"},{"kind":"text","text":"which is the name of a mountain; i. e., in going up from El-Ghowr, or El-Ghór. (S, L.)"}],"source_refs":["S","L","Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%86%D8%AC%D8%AF/","headword_ar":"أَنْجُد","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=131078#96883f","body_html":"أَنْجُد<br>من (ن ج د) جمع نجد: ما ارتفع من الأرض وصلب والطريق في الجبل."}]}}