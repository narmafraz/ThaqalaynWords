{"lemma":"تِيهَيْ","slug":"تِيهَيْ","root":"ت.#.ه","root_slug":"ت-_-ه","root_link":"/words/roots/ت-_-ه","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n4269","n4270"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%90%D9%8A%D9%87%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"desert, wasteland"},{"pos":"noun","gloss":"haughtiness, pride"},{"pos":"noun","gloss":"maze, labyrinth"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4269","headword_ar":"تَيْهٌ","root":"tyn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"tiyhN","text_ar":"تِيهٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n4270","headword_ar":"تِيهٌ","root":"tyn","body":[{"kind":"text","text":"[originally an inf. n.: see 1, throughout:]"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"mafaAzap","text_ar":"مَفَازَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"desert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waterless desert,"},{"kind":"text","text":"&c.,] (S, Msb, K)"},{"kind":"italic_en","text":"in which one loses his way,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"wherein is no sign,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mark, whereby one may be guided therein;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tayohaA='u","text_ar":"تَيْهَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"A^atoyaAhN","text_ar":"اَتْيَاهٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ataAwiyhN","text_ar":"اَتَاوِيهٌ"},{"kind":"text","text":", (S, K,) the latter of which is a pl. of the former pl., (TA,) and"},{"kind":"arabic","text_bw":"A^ataAwihapN","text_ar":"اَتَاوِهَةٌ"},{"kind":"text","text":". (Meyd, in Freytag's Lex.) [Hence,]"},{"kind":"arabic","text_bw":"Alt~iyhu","text_ar":"التِّيهُ"},{"kind":"text","text":", [also called"},{"kind":"arabic","text_bw":"tiyhu baniY","text_ar":"تِيهُ بَنِى"},{"kind":"arabic","text_bw":"A_isoraAy^iyla","text_ar":"اـِسْرَايِيلَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"The place"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desert"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in which the Children of Israel lost their way, between Egypt and the 'Akabeh"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at the head of the eastern gulf of the Red Sea"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"unable to find the way of egress from it."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^aroDN tiyhN","text_ar":"اَرْضٌ تِيهٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tayohN","text_ar":"تَيْهٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tayohaA='u","text_ar":"تَيْهَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"matiyhapN","text_ar":"مَتِيهَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) originally ["},{"kind":"arabic","text_bw":"matoyihapN","text_ar":"مَتْيِهَةٌ"},{"kind":"text","text":",] of the measure"},{"kind":"arabic","text_bw":"mafoEilapN","text_ar":"مَفْعِلَةٌ"},{"kind":"text","text":", (S,) and ↓"},{"kind":"arabic","text_bw":"mutiyhapN","text_ar":"مُتِيهَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"matoyahapN","text_ar":"مَتْيَهَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"matoyapN","text_ar":"مَتْيَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"mutoyihapN","text_ar":"مُتْيِهَةٌ","orth_type":"arrow"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"A land wherein one loses his way,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"wide, and having in it no signs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks, of the way, nor mountains nor hills."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"baladN A^atoyahu","text_ar":"بَلَدٌ اَتْيَهُ","orth_type":"arrow"},{"kind":"italic_en","text":"A country to which,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in which, one cannot find his way."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA"]}]}}