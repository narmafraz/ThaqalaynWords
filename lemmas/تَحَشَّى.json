_bw":"Aln~aAHiyapu","text_ar":"النَّاحِيَةُ"},{"kind":"text","text":". (Har p. 194.) ―         -b2-  And"},{"kind":"arabic","text_bw":"tH$~Y minohu","text_ar":"تحشّى مِنْهُ"},{"kind":"text","text":"; (IAar, K;) and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"HA$Y","text_ar":"حاشى","orth_type":"arrow"},{"kind":"text","text":", (Har p. 294,) inf. n."},{"kind":"arabic","text_bw":"muHaA$aApN","text_ar":"مُحَاشَاةٌ"},{"kind":"text","text":"; (KL;)"},{"kind":"italic_en","text":"He abstained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrained,"},{"kind":"text","text":"(IAar, K, KL, Har,)"},{"kind":"italic_en","text":"from him,"},{"kind":"text","text":"(IAar, K, Har,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(IAar, KL,)"},{"kind":"italic_en","text":"through disdain and pride;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he disdained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scorned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was ashamed of, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(IAar, K, Har.) ―         -b3-  And"},{"kind":"arabic","text_bw":"laA yataHa$~aY","text_ar":"لَا يَتَحَشَّى"},{"kind":"text","text":", (El-Báhilee, TA,) and"},{"kind":"arabic","text_bw":"lA","text_ar":"لا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yuHaA$iY","text_ar":"يُحَاشِى","orth_type":"arrow"},{"kind":"text","text":", (Har p. 294,)"},{"kind":"italic_en","text":"He will not care, mind, heed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard."},{"kind":"text","text":"(El-Báhilee, Har, TA.)       -A2-  See also 3, in two places, first and second sentences."}],"source_refs":["TA","IAar","K","KL","Har"]}]},"classical_definitions":null}