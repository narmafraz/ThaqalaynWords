{"lemma":"لُدِّ","slug":"لُدِّ","root":"#.ل.د","root_slug":"_-ل-د","root_link":"/words/roots/_-ل-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"لُدِّ","root":"لدد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n37664","n37670"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8F%D8%AF%D9%90%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37664","headword_ar":"لَدّ","root":"ld","body":[{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"ladida","text_ar":"لَدِدَ"},{"kind":"text","text":", (second pers."},{"kind":"arabic","text_bw":"ladidota","text_ar":"لَدِدْتَ"},{"kind":"text","text":", L,) aor."},{"kind":"text","text":", (L, Msb,) inf. n."},{"kind":"arabic","text_bw":"ladadN","text_ar":"لَدَدٌ"},{"kind":"text","text":"(S, A, L, Msb,)"},{"kind":"italic_en","text":"He was violent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, in contention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altercation; in dispute; in litigation."},{"kind":"text","text":"(S, A, L, Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"lad~ahu","text_ar":"لَدَّهُ"},{"kind":"text","text":", (S, L, Msb, K,) aor."},{"kind":"text","text":", (S, L, Msb,) inf. n."},{"kind":"arabic","text_bw":"lad~N","text_ar":"لَدٌّ"},{"kind":"text","text":", (L, Msb,)"},{"kind":"italic_en","text":"He overcame him in contention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altercation; in dispute; in litigation:"},{"kind":"text","text":"(S, * L, K: *) or"},{"kind":"italic_en","text":"he opposed him violently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently, in contention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altercation; in dispute; in litigation."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"ladidota","text_ar":"لَدِدْتَ"},{"kind":"text","text":", (in some copies of the K,"},{"kind":"arabic","text_bw":"ladadota","text_ar":"لَدَدْتَ"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"laddN","text_ar":"لَددٌ"},{"kind":"text","text":", (IKtt, L: in the K,"},{"kind":"arabic","text_bw":"lad~N","text_ar":"لَدٌّ"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"Thou becamest such as is called"},{"kind":"arabic","text_bw":"A^alad~","text_ar":"اَلَدّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"violent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, in contention, &c."},{"kind":"text","text":"]. (IKtt, L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"lad~ahu Eani AlA^amori","text_ar":"لَدَّهُ عَنِ الاَمْرِ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"lad~N","text_ar":"لَدٌّ"},{"kind":"text","text":", L,)"},{"kind":"italic_en","text":"He restrained, withheld, debarred, hindered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prevented, him from doing the thing:"},{"kind":"text","text":"(L, K: *)"},{"kind":"italic_en","text":"he made him to return"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned him back"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, with gentleness, from the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"rad~ahu","text_ar":"رَدَّهُ"},{"kind":"text","text":": (T and L, art."},{"kind":"arabic","text_bw":"rd","text_ar":"رد"},{"kind":"text","text":":) of the dial. of Hudheyl. (L.)       -A2-"},{"kind":"arabic","text_bw":"lad~ahu","text_ar":"لَدَّهُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"lad~ahu biAll~aduwdi","text_ar":"لَدَّهُ بِاللَّدُودِ"},{"kind":"text","text":", (M,) aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"lad~N","text_ar":"لَدٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"luduwdN","text_ar":"لُدُودٌ"},{"kind":"text","text":"; (M, K;) and ↓"},{"kind":"arabic","text_bw":"Ald~hu","text_ar":"الدّهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, L, K;) and"},{"kind":"arabic","text_bw":"lad~ahu All~aduwda","text_ar":"لَدَّهُ اللَّدُودَ"},{"kind":"text","text":"; (M, L, K;)"},{"kind":"italic_en","text":"He administered to him the medicine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"draught, termed"},{"kind":"arabic","text_bw":"laduwd","text_ar":"لَدُود"},{"kind":"text","text":". (S, * M, L, K. *) The action termed"},{"kind":"arabic","text_bw":"All~ad~u","text_ar":"اللَّدُّ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the taking a child's tongue, and drawing it to one side, and pouring medicine in the other side, between the tongue and the side of the mouth."},{"kind":"text","text":"(Fr, L.) ―         -b2-"},{"kind":"arabic","text_bw":"lud~a","text_ar":"لُدَّ"},{"kind":"italic_en","text":"He had a medicine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"draught, of the kind termed"},{"kind":"arabic","text_bw":"laduwd","text_ar":"لَدُود"},{"kind":"italic_en","text":"administered to him."},{"kind":"text","text":"(S, L, K.) See also 8. ―         -b3-"},{"kind":"arabic","text_bw":"ladadotuhumu Aln~aSiyHapa","text_ar":"لَدَدْتُهُمُ النَّصِيحَةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I administered to them sincere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faithful, advice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsel, like as one administers the medicine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"draught, termed"},{"kind":"arabic","text_bw":"laduwd","text_ar":"لَدُود"},{"kind":"text","text":". (L.)"}],"source_refs":["L","Msb","S","A","K","M"]},{"entry_id":"n37670","headword_ar":"لَدٌّ","root":"ld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"laAd~N","text_ar":"لَادٌّ"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sack of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"juwaAliq","text_ar":"جُوَالِق"},{"kind":"text","text":": (S, L, K:) like"},{"kind":"arabic","text_bw":"labiydN","text_ar":"لَبِيدٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","L","K"]}]},"classical_definitions":null}