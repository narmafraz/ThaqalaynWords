ype":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"thing for which the live coals are prepared:"},{"kind":"text","text":"(S:) [and"},{"kind":"arabic","text_bw":"mijomarapN","text_ar":"مِجْمَرَةٌ"},{"kind":"text","text":"also signifies a blacksmith's"},{"kind":"italic_en","text":"fire-place:"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"kwr","text_ar":"كور"},{"kind":"text","text":":)] pl."},{"kind":"arabic","text_bw":"majaAmiru","text_ar":"مَجَامِرُ"},{"kind":"text","text":". (S.)"}],"source_refs":["S","Mgh","Msb","K","TA"]}]}}