":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدَبَّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَبَّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَبِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَبِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدَبَّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَبَّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَبِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَبِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدَبَّرْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُدَبِّرْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"دَبَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَبَّرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُدَبَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَبَّر","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُدَبِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَبِّر","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":68,"cross_references":{"qac":{"found":true,"lemma_key":"دَبَّرَ","root":"دبر","pos":"N","occurrence_count":18},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":22},"lanes":{"found":true,"entry_ids":["n11995","n11996","n11997","n11998","n11999","n12000"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%A8%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be hindmost, to come behind, to follow"},{"pos":"verb","gloss":"to turn the back"},{"pos":"verb","gloss":"to elapse, to pass (of time)"},{"pos":"verb","gloss":"to grow old, to age"},{"pos":"verb","gloss":"to veer to the west"},{"pos":"verb","gloss":"to be turned backwards"},{"pos":"verb","gloss":"to fall behind the aim"},{"pos":"verb","gloss":"to take away"},{"pos":"verb","gloss":"to have galls in the back, to have sores in the back"},{"pos":"verb","gloss":"to arrange, to dispose, to plan, to prepare, to organize, to hatch, to contrive, to devise, to forecast","examples":[{"text":"يُدَبِّرُ الْأَمْرَ مِنَ السَّمَاءِ إِلَى الْأَرْضِ ثُمَّ يَعْرُجُ إِلَيْهِ فِي يَوْمٍ كَانَ مِقْدَارُهُ أَلْفَ سَنَةٍ مِّمَّا تَعُدُّونَ","english":"He arranges [each] matter from the heaven to the earth; then it will ascend to Him in a Day, the extent of which is a thousand years of those which you count."}]},{"pos":"verb","gloss":"to set free"},{"pos":"verb","gloss":"to direct, to manage, to regulate"},{"pos":"noun","gloss":"verbal noun of دَبَرَ (dabara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of دَبِرَ (dabira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"back, back side, reverse"},{"pos":"noun","gloss":"buttocks"},{"pos":"noun","gloss":"anus"},{"pos":"noun","gloss":"rear part"},{"pos":"noun","gloss":"end, tail"},{"pos":"noun","gloss":"swarm, flock, drove"},{"pos":"noun","gloss":"great wealth, much property"},{"pos":"adj","gloss":"having galls in the back"}]},"etymology":{"source":"wiktextract","text":"From Proto-Afroasiatic *dâb-. Compare دُبْر (dubr, “back”), perhaps cognate with Hebrew דִּבֵּר (“to speak”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11995","headword_ar":"دَبْرٌ","root":"dbx","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"location,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter, that is behind"},{"kind":"text","text":"a thing. (K. [In the CK, for"},{"kind":"arabic","text_bw":"xalof","text_ar":"خَلْف"},{"kind":"text","text":"is put"},{"kind":"arabic","text_bw":"xalaf","text_ar":"خَلَف"},{"kind":"text","text":".]) Hence the saying, (TA,)"},{"kind":"arabic","text_bw":"jaEalotu kalaAmahu dabora A^u*uniY","text_ar":"جَعَلْتُ كَلَامَهُ دَبْرَ اُذُنِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I turned away from his speech, and feigned myself deaf to it:"},{"kind":"text","text":"(T, S:)"},{"kind":"italic_en","text":"I did not listen to his speech, nor care for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard it."},{"kind":"text","text":"(M, K, * TA.) You say also,"},{"kind":"arabic","text_bw":"A^u*unihi","text_ar":"اُذُنِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jaEalahu daAbira","text_ar":"جَعَلَهُ دَابِرَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He turned away from him, avoided him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shunned him."},{"kind":"text","text":"(T, * A.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"dabariY~N","text_ar":"دَبَرِىٌّ"},{"kind":"text","text":". ―         -b3-  Also, [like"},{"kind":"arabic","text_bw":"A_idobaArN","text_ar":"اـِدْبَارٌ"},{"kind":"text","text":", inf. n. of 4,] (assumed tropical:)"},{"kind":"italic_en","text":"Death."},{"kind":"text","text":"(K.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"Constant sleep:"},{"kind":"text","text":"(M, K:) it is like"},{"kind":"arabic","text_bw":"tasobiyxN","text_ar":"تَسْبِيخٌ"},{"kind":"text","text":". (M.)       -A2-"},{"kind":"italic_en","text":"I. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ","orth_type":"arrow"},{"kind":"text","text":"; these two words being pls. [or rather coll. gen. ns.] whereof the sings. [or ns. un.] are ↓"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"dibaArapN","text_ar":"دِبَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"; which signify"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"ma$aArap","text_ar":"مَشَارَة"},{"kind":"text","text":"[explained in the TA as meaning a"},{"kind":"italic_en","text":"channel of water;"},{"kind":"text","text":"but it seems to be here used as meaning"},{"kind":"italic_en","text":"a portion of ground separated from the adjacent parts, for sowing or planting, being surrounded by dams, or by ridges of earth, which retain the water for irrigation,"},{"kind":"text","text":"as explained in art."},{"kind":"arabic","text_bw":"$wr","text_ar":"شور"},{"kind":"text","text":", and as is indicated by its Persian equivalent here following,]"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"land that is sown or for sowing;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"called in Persian"},{"kind":"arabic","text_bw":"kurod","text_ar":"كُرْد"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"small channels for irrigation between tracts of seedproduce;"},{"kind":"text","text":"(K;) and its sing. is"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":": (TA:) [Mtr says,]"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"ma$aArapN","text_ar":"مَشَارَةٌ"},{"kind":"text","text":"; in Persian"},{"kind":"arabic","text_bw":"karodah","text_ar":"كَرْدَه"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"kurod","text_ar":"كُرْد"},{"kind":"text","text":"as above]; and the pl. is"},{"kind":"arabic","text_bw":"daborN","text_ar":"دَبْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":": (Mgh:) [ISd says,]"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a small channel for irrigation between tracts of land sown or for sowing:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"ma$aArapN","text_ar":"مَشَارَةٌ"},{"kind":"text","text":": and the pl. is"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":": it is also said that"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"kurodapN","text_ar":"كُرْدَةٌ"},{"kind":"text","text":"; and its n. un. is"},{"kind":"arabic","text_bw":"dibaArapN","text_ar":"دِبَارَةٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"dibaAraAtN","text_ar":"دِبَارَاتٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"rivulets that flow through land of seed-produce;"},{"kind":"text","text":"and its sing. is"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":": but I know not how this is, unless"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":"have"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":"for its pl., and this have"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"added to it, as in"},{"kind":"arabic","text_bw":"fiHaAlapN","text_ar":"فِحَالَةٌ"},{"kind":"text","text":", and so"},{"kind":"arabic","text_bw":"dbArAt","text_ar":"دبارات"},{"kind":"text","text":"be a pl. pl., i. e. perfect pl. of"},{"kind":"arabic","text_bw":"dibaArapN","text_ar":"دِبَارَةٌ"},{"kind":"text","text":": AHn says that"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a patch of ground that is sown;"},{"kind":"text","text":"[as is also said in the K;] and the pl. is"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":". (M.) ―         -b2-  Also"},{"kind":"italic_en","text":"A piece of rugged ground in a"},{"kind":"arabic","text_bw":"baHorN","text_ar":"بَحْرٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"sea"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large river"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"like an island, which the water overflows"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at times"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and from which"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at times"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it recedes."},{"kind":"text","text":"(M, K.) ―         -b3-  And"},{"kind":"italic_en","text":"A mountain;"},{"kind":"text","text":"(T, K;) in the Abyssinian language: (TA: [Az says, “I know not whether it be Arabic or not:”]) whence the saying of the King of Abyssinia, (T, * K, * TA,)"},{"kind":"arabic","text_bw":"maA A^uHib~u A^an~a liY daborFA *ahabFA waA^an~iYA=*ayotu rajulFA","text_ar":"مَا اُحِبُّ اَنَّ لِى دَبْرًا ذَهَبًا وَاَنِّىا=ذَيْتُ رَجُلًا"},{"kind":"arabic","text_bw":"mina Almusolimiyna","text_ar":"مِنَ المُسْلِمِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I would not that I had a mountain of gold and that I had harmed a man of the Muslims"},{"kind":"text","text":"]: (T, K:) but [SM says that] this is a confounding of two readings; which are,"},{"kind":"arabic","text_bw":"daborFA mino *ahabK","text_ar":"دَبْرًا مِنْ ذَهَبٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ano yakuwna daborN liY *ahabFA","text_ar":"اَنْ يَكُونَ دَبْرٌ لِى ذَهَبًا"},{"kind":"text","text":": (TA:) another reading is"},{"kind":"arabic","text_bw":"*aborFA mino *ahabK","text_ar":"ذَبْرًا مِنْ ذَهَبٍ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"*br","text_ar":"ذبر"},{"kind":"text","text":".) ―         -b4-  See also"},{"kind":"arabic","text_bw":"diborN","text_ar":"دِبْرٌ"},{"kind":"text","text":". ―         -b5-  Also, (S, M, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"diborN","text_ar":"دِبْرٌ","orth_type":"arrow"},{"kind":"text","text":", (AHn, M, K,)"},{"kind":"italic_en","text":"A swarm of bees:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"hornets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large wasps;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zanaAbiyru","text_ar":"زَنَابِيرُ"},{"kind":"text","text":": (S, M, K:) and the"},{"kind":"italic_en","text":"like thereof, having stings in their hinder parts:"},{"kind":"text","text":"(B:) it has no sing., or n. un.: (As, M:) or the n. un. is ↓"},{"kind":"arabic","text_bw":"daborapN","text_ar":"دَبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"diborapN","text_ar":"دِبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"; of which the dim. ↓"},{"kind":"arabic","text_bw":"dubayorapN","text_ar":"دُبَيْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"occurs in a trad.: (TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^adoburN","text_ar":"اَدْبُرٌ"},{"kind":"text","text":"(K) and [of mult.]"},{"kind":"arabic","text_bw":"dubuwrN","text_ar":"دُبُورٌ"},{"kind":"text","text":": (As, S, K:) and ↓"},{"kind":"arabic","text_bw":"dabuwrN","text_ar":"دَبُورٌ","orth_type":"arrow"},{"kind":"text","text":", with fet-h to the first letter, signifies"},{"kind":"italic_en","text":"bees;"},{"kind":"text","text":"and has no proper sing. (M.) 'Ásim Ibn-Thábit El-Ansáree was called"},{"kind":"arabic","text_bw":"HamiY~u Ald~abori","text_ar":"حَمِىُّ الدَّبْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The protected of hornets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bees"},{"kind":"text","text":"], because his corpse was protected from his enemies by large hornets, (S,) or by a swarm of bees. (M, Mgh * in art."},{"kind":"arabic","text_bw":"HmY","text_ar":"حمى"},{"kind":"text","text":".) ―         -b6-"},{"kind":"arabic","text_bw":"daborN","text_ar":"دَبْرٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"young ones of locusts;"},{"kind":"text","text":"(AHn, K;) and so ↓"},{"kind":"arabic","text_bw":"diborN","text_ar":"دِبْرٌ","orth_type":"arrow"},{"kind":"text","text":". (AHn, M, K.)"}],"source_refs":["TA","T","S","M","K","Mgh","AHn","B","As"]},{"entry_id":"n11996","headword_ar":"دُبْرٌ","root":"dbx","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"duburN","text_ar":"دُبُرٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"dabariY~N","text_ar":"دَبَرِىٌّ"},{"kind":"text","text":"; the latter in two places.       -A2-  See also 4, first sentence."}],"source_refs":[]},{"entry_id":"n11997","headword_ar":"دِبْرٌ","root":"dbx","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daborN","text_ar":"دَبْرٌ"},{"kind":"text","text":", last sentence but two, and last sentence. ―         -b2-  Also, (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"daborN","text_ar":"دَبْرٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"Much property"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(S, M, K;)"},{"kind":"italic_en","text":"such as cannot be computed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calculated:"},{"kind":"text","text":"(M:) the sing. [and dual] and pl. are alike: you say [using it as an epithet]"},{"kind":"arabic","text_bw":"maAlN diborN","text_ar":"مَالٌ دِبْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maAlaAni diborN","text_ar":"مَالَانِ دِبْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amowaAlN diborN","text_ar":"اَمْوَالٌ دِبْرٌ"},{"kind":"text","text":": (S, M:) this mode of usage is best known; but sometimes"},{"kind":"arabic","text_bw":"dubuwrN","text_ar":"دُبُورٌ"},{"kind":"text","text":"is used as its pl.: (M:) in like manner you say"},{"kind":"arabic","text_bw":"maAlN davorN","text_ar":"مَالٌ دَثْرٌ"},{"kind":"text","text":": and you say also"},{"kind":"arabic","text_bw":"rajulN *uw","text_ar":"رَجُلٌ ذُو"},{"kind":"arabic","text_bw":"diborK","text_ar":"دِبْرٍ"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"rjl dbr","text_ar":"رجل دبر"},{"kind":"text","text":", [unless this be a mistake for the phrase immediately preceding,] (Fr, TA,) meaning"},{"kind":"italic_en","text":"a man having large possessions in land"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"houses"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other property."},{"kind":"text","text":"(Fr, S, TA.)"}],"source_refs":["S","M","K","TA","Fr"]},{"entry_id":"n11998","headword_ar":"دَبَرٌ","root":"dbx","body":[{"kind":"text","text":"[app. signifies"},{"kind":"italic_en","text":"A tract of the western sky at sunset:"},{"kind":"text","text":"for] the Arabs said,"},{"kind":"arabic","text_bw":"A_i*aA raA^ayota Alv~uray~aA","text_ar":"اـِذَا رَاَيْتَ الثُّرَيَّا"},{"kind":"arabic","text_bw":"bidabaro fa$ahorN nitaAjo wa$ahorN maTaro waA_i*aA raA^ayota Al$~iEoraY biqabalo","text_ar":"بِدَبَرْ فَشَهْرٌ نِتَاجْ وَشَهْرٌ مَطَرْ وَاـِذَا رَاَيْتَ الشِّعْرَى بِقَبَلْ"},{"kind":"arabic","text_bw":"famajodu fatFY waHimolu jamalo","text_ar":"فَمَجْدُ فَتًى وَحِمْلُ جَمَلْ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"When thou seest the Pleiades near to setting with sunset, then"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is a month which"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is a time of breeding"},{"kind":"text","text":"of camels,"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a month which is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a time of rain: and when thou seest Sirius"},{"kind":"text","text":"["},{"kind":"italic_en","text":"near to rising"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with sunset,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"then is the glory of the generous man, and"},{"kind":"text","text":"the time for"},{"kind":"italic_en","text":"the burden of the full-grown hecamel;"},{"kind":"text","text":"for] then is the most intense degree of cold, when none but the generous and noble and"},{"kind":"page_break","n":846},{"kind":"text","text":"ingenuous man will patiently persevere in the exercise of hospitality and beneficence, and when the heavy burden is not laid save upon the strong full-grown he-camel, because then the camels become lean and the pasturage is scanty. (M.)       -A2-  Also, and so is"},{"kind":"arabic","text_bw":"A^adobaArN","text_ar":"اَدْبَارٌ"},{"kind":"text","text":", a pl. [or rather the former is a coll. gen. n.] of ↓"},{"kind":"arabic","text_bw":"dabarapN","text_ar":"دَبَرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) which signifies"},{"kind":"italic_en","text":"A gall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sore, on the back"},{"kind":"text","text":"(M, * Mgh, K, * TA) of a horse or the like (M, K, TA) and of a camel, (M, Mgh,)"},{"kind":"italic_en","text":"produced by the saddle and the like;"},{"kind":"text","text":"(Mgh;) and also"},{"kind":"italic_en","text":"on the"},{"kind":"arabic","text_bw":"kirokirap","text_ar":"كِرْكِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"callous projection on the breast"},{"kind":"text","text":"] of a camel. (S and K in art."},{"kind":"arabic","text_bw":"sr","text_ar":"سر"},{"kind":"text","text":".) They used to say, in the Time of Ignorance,"},{"kind":"arabic","text_bw":"A_i*aA baraA^a Ald~abaru waEafaA AlA^avaru","text_ar":"اـِذَا بَرَاَ الدَّبَرُ وَعَفَا الاَثَرُ"},{"kind":"text","text":", explained as meaning ["},{"kind":"italic_en","text":"When"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the galls on the back"},{"kind":"text","text":"of the beast or"},{"kind":"italic_en","text":"upon the foot"},{"kind":"text","text":"of the camel ["},{"kind":"italic_en","text":"shall heal, and the footstep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mark, become obliterated"},{"kind":"text","text":"]. (TA from a trad.)       -A3-  Also inf. n. of"},{"kind":"arabic","text_bw":"dabira","text_ar":"دَبِرَ"},{"kind":"text","text":". (M, Mgh.)"}],"source_refs":["S","M","K","TA","Mgh"]},{"entry_id":"n11999","headword_ar":"دَبِرٌ","root":"dbx","body":[{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"A^adobaru","text_ar":"اَدْبَرُ","orth_type":"arrow"},{"kind":"text","text":"(M) A horse or the like, (M, K,) and a camel, (M,)"},{"kind":"italic_en","text":"having galls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sores,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"on his back"},{"kind":"text","text":"(TA) ["},{"kind":"italic_en","text":"produced by the saddle and the like; having his back galled:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"dabarN","text_ar":"دَبَرٌ"},{"kind":"text","text":"]: fem. [of the former]"},{"kind":"arabic","text_bw":"dabirapN","text_ar":"دَبِرَةٌ"},{"kind":"text","text":"and [of the latter] ↓"},{"kind":"arabic","text_bw":"daboraA='u","text_ar":"دَبْرَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": and pl. [of either]"},{"kind":"arabic","text_bw":"daboraY","text_ar":"دَبْرَى"},{"kind":"text","text":". (M, TA.) [Hence the prov.,]"},{"kind":"arabic","text_bw":"haAna EalaY AlA^amolasi maA laAqaY Ald~abiru","text_ar":"هَانَ عَلَى الاَمْلَسِ مَا لَاقَى الدَّبِرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What he that had galls on his back experienced was a light matter to him that had a sound back"},{"kind":"text","text":"]: applied to one who has an ill concern for his companion. (K.) ―         -b2-  In the phrase"},{"kind":"arabic","text_bw":"rajulN","text_ar":"رَجُلٌ"},{"kind":"arabic","text_bw":"xasirN wadabirN","text_ar":"خَسِرٌ وَدَبِرٌ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"A man erring and perishing"},{"kind":"text","text":"], Lh says that"},{"kind":"arabic","text_bw":"dabirN","text_ar":"دَبِرٌ"},{"kind":"text","text":"is an imitative sequent to"},{"kind":"arabic","text_bw":"xasirN","text_ar":"خَسِرٌ"},{"kind":"text","text":": but [ISd says,] I think that"},{"kind":"arabic","text_bw":"xasirN","text_ar":"خَسِرٌ"},{"kind":"text","text":"is a verbal epithet, and that"},{"kind":"arabic","text_bw":"dabirN","text_ar":"دَبِرٌ"},{"kind":"text","text":"is a possessive epithet. (M in art."},{"kind":"arabic","text_bw":"dmr","text_ar":"دمر"},{"kind":"text","text":".) You say also"},{"kind":"arabic","text_bw":"A^aHomaqN","text_ar":"اَحْمَقٌ"},{"kind":"arabic","text_bw":"daAmirN","text_ar":"دَامِرٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAsirN daAbirN","text_ar":"خَاسِرٌ دَابِرٌ","orth_type":"arrow"},{"kind":"text","text":": (T in art."},{"kind":"arabic","text_bw":"bt","text_ar":"بت"},{"kind":"text","text":": [see art."},{"kind":"arabic","text_bw":"xsr","text_ar":"خسر"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"daAbirN","text_ar":"دَابِرٌ"},{"kind":"text","text":"is said to be an imitative sequent to"},{"kind":"arabic","text_bw":"xaAsirN","text_ar":"خَاسِرٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["M","K","TA"]},{"entry_id":"n12000","headword_ar":"دُبُرٌ","root":"dbx","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"duborN","text_ar":"دُبْرٌ","orth_type":"arrow"},{"kind":"text","text":", (the latter a contraction of the former, Msb, [and not so commonly used, like as"},{"kind":"arabic","text_bw":"A_ibolN","text_ar":"اـِبْلٌ"},{"kind":"text","text":"is not so commonly used as"},{"kind":"arabic","text_bw":"A_ibilN","text_ar":"اـِبِلٌ"},{"kind":"text","text":",]) The"},{"kind":"italic_en","text":"back;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":": (S, A, B, K;) the first signification given in the [S and] A and B: pl."},{"kind":"arabic","text_bw":"A^adobaArN","text_ar":"اَدْبَارٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"wal~aY duburahu","text_ar":"وَلَّى دُبُرَهُ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"He turned his back;"},{"kind":"text","text":"and tropically,] (tropical:)"},{"kind":"italic_en","text":"he was put to flight."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"wal~aAhu duburahu","text_ar":"وَلَّاهُ دُبُرَهُ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"He turned his back to him;"},{"kind":"text","text":"and tropically,] the same as the phrase immediately preceding. (Mgh, Msb.) It is said in the Kur [liv. 45],"},{"kind":"arabic","text_bw":"wayuwal~uwna Ald~ubura","text_ar":"وَيُوَلُّونَ الدُّبُرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And they shall turn the back,"},{"kind":"text","text":"in flight]: where"},{"kind":"arabic","text_bw":"Aldbr","text_ar":"الدبر"},{"kind":"text","text":"is used in a collective sense, agreeably with another passage in the Kur [xiv. 44],"},{"kind":"arabic","text_bw":"laA yarotad~u A_ilayohimo Tarofuhumo","text_ar":"لَا يَرْتَدُّ اـِلَيْهِمْ طَرْفُهُمْ"},{"kind":"text","text":". (S, B.) You also say, ↓"},{"kind":"arabic","text_bw":"wal~awoA daborapF","text_ar":"وَلَّوْا دَبْرَةً","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They turned back in flight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"being routed."},{"kind":"text","text":"(A, TA.) ―         -b2-  The"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hinder part, contr. of"},{"kind":"arabic","text_bw":"qubulN","text_ar":"قُبُلٌ"},{"kind":"text","text":", (S, A, Msb, K,) of anything: (Msb:) as, for instance, of a shirt. (Kur xii. 25, 27, and 28.) You say,"},{"kind":"arabic","text_bw":"waqaEa Als~ahomu","text_ar":"وَقَعَ السَّهْمُ"},{"kind":"arabic","text_bw":"bidubori Alhadafi","text_ar":"بِدُبْرِ الهَدَفِ"},{"kind":"italic_en","text":"The arrow fell behind the butt."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"qbl","text_ar":"قبل"},{"kind":"text","text":".) ―         -b3-  The"},{"kind":"italic_en","text":"backside; posteriors; buttocks; rump;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"podex:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"anus:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AisotN","text_ar":"اِسْتٌ"},{"kind":"text","text":". (K.) [It has the former of these two significations in many instances; and the latter of them in many other instances: in the S and K in art."},{"kind":"arabic","text_bw":"jEr","text_ar":"جعر"},{"kind":"text","text":", it is given as a syn. of"},{"kind":"arabic","text_bw":"majoEarN","text_ar":"مَجْعَرٌ"},{"kind":"text","text":", which has the latter signification in the present day. This latter signification may also be intended in the S, M, A, Msb, and K, by the explanation “"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"qubulN","text_ar":"قُبُلٌ"},{"kind":"text","text":", ” as well as the “ back, or hinder part, ” of anything: for"},{"kind":"arabic","text_bw":"qubulN","text_ar":"قُبُلٌ"},{"kind":"text","text":"very often signifies the “ anterior pudendum ” of a man or woman, and is so explained. The anus is also called"},{"kind":"arabic","text_bw":"Haloqapu Ald~uburi","text_ar":"حَلْقَةُ الدُّبُرِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HitaAru Ald~uburi","text_ar":"حِتَارُ الدُّبُرِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$araju Ald~uburi","text_ar":"شَرَجُ الدُّبُرِ"},{"kind":"text","text":".] Its pl."},{"kind":"arabic","text_bw":"A^adobaArN","text_ar":"اَدْبَارٌ"},{"kind":"text","text":"is also applied to the"},{"kind":"italic_en","text":"part which comprises the"},{"kind":"arabic","text_bw":"Aisot","text_ar":"اِسْت"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"anus"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vulva,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"external portion of the female organs of generation,"},{"kind":"text","text":"] of a solid-hoofed animal, and of a cloven-hoofed animal, and of that which has claws, or talons: or, as some say, of a camel, or an animal having feet like those of the camel: and the sing., to the"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vulva"},{"kind":"text","text":"] alone, of any such animal. (M, TT.) ―         -b4-  (assumed tropical:)  The"},{"kind":"italic_en","text":"latter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"last, part,"},{"kind":"text","text":"(T, S, M, Msb, K,) of a thing, an affair, or an event, (T, S, Msb,) or of anything: (M, K:) pl."},{"kind":"arabic","text_bw":"A^adobaArN","text_ar":"اَدْبَارٌ"},{"kind":"text","text":"(M) [and"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dabariY~N","text_ar":"دَبَرِىٌّ"},{"kind":"text","text":"]. [See also"},{"kind":"arabic","text_bw":"daAbirN","text_ar":"دَابِرٌ"},{"kind":"text","text":".] One says,"},{"kind":"arabic","text_bw":"jiy^otuka duburi Al$~ahori","text_ar":"جِيْتُكَ دُبُرِ الشَّهْرِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY duburihi","text_ar":"فِى دُبُرِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"arabic","text_bw":"duburihi","text_ar":"دُبُرِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^adobaAra Al$~ahori","text_ar":"اَدْبَارَ الشَّهْرِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY A^adobaArihi","text_ar":"فِى اَدْبَارِهِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"I came to thee in the latter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"last, part"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, of the month."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"A^adoEuw laka fiY A^adobaAri AlS~alawaAti","text_ar":"اَدْعُو لَكَ فِى اَدْبَارِ الصَّلَوَاتِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I will petition for thee in the latter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"last, parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the conclusions, of the prayers"},{"kind":"text","text":"]. (A.) See also"},{"kind":"arabic","text_bw":"dabariY~N","text_ar":"دَبَرِىٌّ"},{"kind":"text","text":". In the Kur [I. xxxix.],"},{"kind":"arabic","text_bw":"waA^adobaAra","text_ar":"وَاَدْبَارَ"},{"kind":"arabic","text_bw":"Als~ujuwdi","text_ar":"السُّجُودِ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"And in the latter parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the ends, of the prayers:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Als~ujuwdi","text_ar":"السُّجُودِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waA_idobaAra","text_ar":"وَاـِدْبَارَ","orth_type":"arrow"},{"kind":"text","text":"[virtually] signifies the same [i. e."},{"kind":"italic_en","text":"and in the ending of prostration"},{"kind":"text","text":"], and is another reading of the text: Ks and Th adopt the former reading, because every single prostration has its latter part: or, accord. to the T, the meaning is,"},{"kind":"italic_en","text":"and in the two rek'ahs"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alr~akoEataAni","text_ar":"الرَّكْعَتَانِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"after sunset;"},{"kind":"text","text":"as is related on the authority of 'Alee the son of Aboo-Tálib. (TA.) The similar expression in the Kur [lii. last verse]"},{"kind":"arabic","text_bw":"waA^adobaAra Aln~ujuwmi","text_ar":"وَاَدْبَارَ النُّجُومِ"},{"kind":"text","text":"is explained by the lexicologists as signifying (assumed tropical:)"},{"kind":"italic_en","text":"And during the consecution of the stars,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"their taking towards the west, to set:"},{"kind":"text","text":"but [ISd says,] I know not how this is, since"},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":", by which they explain it, is an inf. n., and"},{"kind":"arabic","text_bw":"A^adobaAr","text_ar":"اَدْبَار"},{"kind":"text","text":"is a pl. of a subst.:"},{"kind":"arabic","text_bw":"Aln~ujuwmi","text_ar":"النُّجُومِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waA_idobaAra","text_ar":"وَاـِدْبَارَ","orth_type":"arrow"},{"kind":"text","text":", which is another reading of the text, signifies"},{"kind":"italic_en","text":"and during the setting of the stars:"},{"kind":"text","text":"and Ks and Th adopt this latter reading: (M:) or, accord. to the T, both mean"},{"kind":"italic_en","text":"and in the two rek'ahs before daybreak."},{"kind":"text","text":"(TA.) ―         -b5-  Also The"},{"kind":"italic_en","text":"hinder part,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"and angle,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"zaAwiyap","text_ar":"زَاوِيَة"},{"kind":"text","text":",) of a house or chamber or tent. (M, K.) ―         -b6-"},{"kind":"arabic","text_bw":"Eitoqa AlEabodi Eano","text_ar":"عِتْقَ العَبْدِ عَنْ"},{"kind":"arabic","text_bw":"duburK","text_ar":"دُبُرٍ"},{"kind":"text","text":"(S, K) means"},{"kind":"italic_en","text":"The emancipation of the slave after the death of his owner."},{"kind":"text","text":"(S, Mgh, * Msb. * [See 2.]) ―         -b7-  [See also"},{"kind":"arabic","text_bw":"dabiyrN","text_ar":"دَبِيرٌ"},{"kind":"text","text":", of which, and of"},{"kind":"arabic","text_bw":"dibaArN","text_ar":"دِبَارٌ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"duburN","text_ar":"دُبُرٌ"},{"kind":"text","text":"is said in the TA in art."},{"kind":"arabic","text_bw":"qbl","text_ar":"قبل"},{"kind":"text","text":"to be a pl.]."}],"source_refs":["S","A","Msb","K","T","M"]}]}}