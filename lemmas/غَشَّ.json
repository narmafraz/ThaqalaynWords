_in_corpus":18,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["","n31882","n31883"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to act dishonestly toward someone"},{"pos":"verb","gloss":"to cheat, to cheat someone","examples":[{"text":"الطُّلَّابُ يَغُشُّونَ فِي الاِمْتِحَانِ.","english":"The students cheat during the exam."}]},{"pos":"verb","gloss":"to adulterate, to dash","examples":[{"text":"الكشوث\nقال س: ويسمّى عندنا طنية تأويله قرّوعة،\n أقول: ولم يكن في الأمّ التي قرأنا فيها،\nقال ع: الكشوث هو صنف من أصناف الأفيثمون أو الأفيثمون صنف من أصناف الكشوث، فأمّا الفرق بينهما فهو أنّ الكشوث أكبر بزرا حتّى إنّه يغشّ به بزر البنج وهو أعظم نباتا وأغلظ ساقا وإنّما يتعلّق بالكتّان، والقيثنون أيضا دقيق النبات دقيق البزر جدّا والطيّب منه المتعلّق بالصعتر، ,وقد أوقع بعضهم الكشوث على الأفسنتين.","english":"Dodder\nS says: It is called amongst us tiña, explained as scabies.\nI say it is not in the original text we have read.\nʕ says: Dodder is a kind of epithyme, or epithyme is a kind of dodder. The difference between both is that dodder has larger seeds, to the point that henbane seed is dashed thereby, and it is taller and thicker in the stem, and it but betwines flax. Epithyme, moreover, grows short and has sore minute seeds, and the good one hangs with thyme. And some have called absynthe dodder."}]},{"pos":"noun","gloss":"verbal noun of غَشَّ (ḡašša) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"adulteration, corruption, debasement"},{"pos":"noun","gloss":"fraud, deceit"},{"pos":"noun","gloss":"verbal noun of غَشَّ (ḡašša) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"disloyalty, perfidy"},{"pos":"noun","gloss":"deceit, fraud, imposture"},{"pos":"noun","gloss":"cheating, academic dishonesty"}]},"etymology":null,"ipa":null}