lic_en","text":"a certain"},{"kind":"text","text":"["},{"kind":"italic_en","text":"celebrated"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"well in Mekkeh,"},{"kind":"text","text":"(so in another copy of the S,) [i. e.]"},{"kind":"italic_en","text":"a certain well adjacent to the Kaabeh;"},{"kind":"text","text":"(K;) so called [because its water is somewhat brackish, or] because of the copiousness of its water; (JM;) as also ↓"},{"kind":"arabic","text_bw":"zumazim","text_ar":"زُمَزِم","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"zumazimN","text_ar":"زُمَزِمٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"zumazimu","text_ar":"زُمَزِمُ"},{"kind":"text","text":"], (IAar, TA,) and ↓"},{"kind":"arabic","text_bw":"zumaAzimN","text_ar":"زُمَازِمٌ","orth_type":"arrow"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"zumaAzimu","text_ar":"زُمَازِمُ"},{"kind":"text","text":"], and ↓"},{"kind":"arabic","text_bw":"zam~amN","text_ar":"زَمَّمٌ","orth_type":"arrow"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"zam~amu","text_ar":"زَمَّمُ"},{"kind":"text","text":", (accord. to different copies of the K,) the last ("},{"kind":"arabic","text_bw":"zam~am","text_ar":"زَمَّم"},{"kind":"text","text":") on the authority of IAar. (TA.) The names of this well, collected from trads. and lexicons, have been found to amount to more than sixty. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"zamozam","text_ar":"زَمْزَم"},{"kind":"text","text":"[with or without tenween] is also the name of"},{"kind":"italic_en","text":"A celebrated well at El-Medeeneh, which is regarded as a means of obtaining a blessing, and the water of which is drunk and transported"},{"kind":"text","text":"[like that of the more celebrated well of the same name at Mekkeh]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"zamozamN","text_ar":"زَمْزَمٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"zamozamu","text_ar":"زَمْزَمُ"},{"kind":"text","text":"(accord. to different copies of the S, [used by a poet with tenween, but probably by poetic license, for it is app. a fem. proper name, and therefore imperfectly decl.,]) is also"},{"kind":"italic_en","text":"A name of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, a she-camel,"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EayoTal","text_ar":"عَيْطَل"},{"kind":"text","text":". (S.)"}],"source_refs":["K","Kz","TA","IKh","Msb","IAar"]},{"entry_id":"n18070","headword_ar":"زِمْزِمٌ","root":"zm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zimozimapN","text_ar":"زِمْزِمَةٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n18071","headword_ar":"زُمَزِمٌ","root":"zm","body":[{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"zumazimu","text_ar":"زُمَزِمُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zamozamN","text_ar":"زَمْزَمٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}