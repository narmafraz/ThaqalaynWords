ole":"present_2mp","form":"تَحْضُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْضُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْضُر","in_corpus":true,"count":21,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْضُر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْضُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْضُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْضُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْضُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْضُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْضُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْضُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْضُر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْضُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَضَرْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَضَرْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":214,"cross_references":{"qac":{"found":true,"lemma_key":"حَضَرَ","root":"حضر","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n8303"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B6%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be present, to attend"},{"pos":"verb","gloss":"to be settled, to be sedentary"},{"pos":"verb","gloss":"to prepare, to make ready","examples":[{"text":"الأُمُّ تُحَضِّرُ وَجْبَةً لِأُسْرَتِهَا.","english":"The mother prepares a meal for her family."}]},{"pos":"noun","gloss":"plural of حَاضِر (ḥāḍir)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of حَاضِر (ḥāḍir)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8303","headword_ar":"حَضَرَ","root":"HDr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, A, Msb, K, &c.;) and"},{"kind":"arabic","text_bw":"HaDira","text_ar":"حَضِرَ"},{"kind":"text","text":", (AA, Kh, Lth, Fr, S, Msb, K, &c.,) aor. as above, (Kh, Lth, Fr, Az, S, Msb, &c.,) not"},{"kind":"text","text":", as is implied in the K; but the latter form of the pret. is disallowed by some; (MF;) and, with its aor., is an instance of the intermixture of dialects; (Msb;) and is like"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"naEima","text_ar":"نَعِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; which are said by IKoot to be the only instances of the kind; (MF;) inf. n."},{"kind":"arabic","text_bw":"HuDuwrN","text_ar":"حُضُورٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"HaDaAra","text_ar":"حَضَارَ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AHtDr","text_ar":"احتضر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tHD~r","text_ar":"تحضّر","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present; contr. of"},{"kind":"arabic","text_bw":"gaAba","text_ar":"غَابَ"},{"kind":"text","text":": (S, K:)"},{"kind":"italic_en","text":"he came after having been absent."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"HaDarati AlS~alaApu","text_ar":"حَضَرَتِ الصَّلَاةُ"},{"kind":"text","text":", (Lth, A, L, Msb,) and, as the people of El-Medeeneh say,"},{"kind":"arabic","text_bw":"HaDirat","text_ar":"حَضِرَت"},{"kind":"text","text":", but all say"},{"kind":"arabic","text_bw":"taHoDuru","text_ar":"تَحْضُرُ"},{"kind":"text","text":", (Lth, L,) originally"},{"kind":"arabic","text_bw":"HaDara waqotu AlS~alaApi","text_ar":"حَضَرَ وَقْتُ الصَّلَاةِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The time of prayer came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrived."},{"kind":"text","text":"(Msb.) ―         -b3-  ["},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, ready,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared."},{"kind":"text","text":"See 4; and see also"},{"kind":"arabic","text_bw":"HADirN","text_ar":"حاضِرٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"HaDarahu","text_ar":"حَضَرَهُ"},{"kind":"text","text":", (AA, Fr, A, Mgh, K, &c.,) and"},{"kind":"arabic","text_bw":"HaDirahu","text_ar":"حَضِرَهُ"},{"kind":"text","text":", (AA, Fr, &c.,) aor. and inf. ns. as above; (TA;) and ↓"},{"kind":"arabic","text_bw":"AHtDrhu","text_ar":"احتضرهُ","orth_type":"arrow"},{"kind":"text","text":", (Mgh, TA,) and ↓"},{"kind":"arabic","text_bw":"tHD~rh","text_ar":"تحضّره","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present with him; attended him; came into his presence; came to him:"},{"kind":"text","text":"(K, &c.:) and"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in it;"},{"kind":"text","text":"namely, a place. (Mgh.) One says,"},{"kind":"arabic","text_bw":"HaDarati AlqaADiYa A@moraA^apN","text_ar":"حَضَرَتِ القَاضِىَ ا@مْرَاَةٌ"},{"kind":"text","text":", (Az,) and"},{"kind":"arabic","text_bw":"HaDirat","text_ar":"حَضِرَت"},{"kind":"text","text":", (Fr, S,) and"},{"kind":"arabic","text_bw":"HaDira","text_ar":"حَضِرَ"},{"kind":"text","text":", in which the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"is elided because"},{"kind":"arabic","text_bw":"AlqADY","text_ar":"القاضى"},{"kind":"text","text":"intervenes between the verb and"},{"kind":"arabic","text_bw":"AmrA^p","text_ar":"امراة"},{"kind":"text","text":", (Sh,) but the first is the most approved, (Az,) ["},{"kind":"italic_en","text":"A woman came into the presence of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"presented herself before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to, the judge."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"HaDarotu majolisa AlqaADiY","text_ar":"حَضَرْتُ مَجْلِسَ القَاضِى"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HuDuwrN","text_ar":"حُضُورٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I was present at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attended, the court of the judge."},{"kind":"text","text":"(Msb.) [And"},{"kind":"arabic","text_bw":"HaDara darosFA","text_ar":"حَضَرَ دَرْسًا"},{"kind":"italic_en","text":"He attended a lecture."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"HaDaruwA AlmiyaAha","text_ar":"حَضَرُوا المِيَاهَ"},{"kind":"italic_en","text":"They stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, by the waters."},{"kind":"text","text":"(S. [See"},{"kind":"arabic","text_bw":"HaADirN","text_ar":"حَاضِرٌ"},{"kind":"text","text":".]) ―         -b2-"},{"kind":"arabic","text_bw":"A^aEuw*u bika rab~i","text_ar":"اَعُوذُ بِكَ رَبِّ"},{"kind":"arabic","text_bw":"A^ano yaHoDuruwni","text_ar":"اَنْ يَحْضُرُونِ"},{"kind":"text","text":"[in the Kur xxiii. 100] means ["},{"kind":"italic_en","text":"I seek thy protection, O my Lord,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from their"},{"kind":"text","text":"(the devils')"},{"kind":"italic_en","text":"bringing evil upon me:"},{"kind":"text","text":"(S:) or ["},{"kind":"italic_en","text":"from their being present with me:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"hovering around me."},{"kind":"text","text":"(Ksh, Bd.) ―         -b3-"},{"kind":"arabic","text_bw":"Aljin~u taHoDuru All~abana","text_ar":"الجِنُّ تَحْضُرُ اللَّبَنَ"},{"kind":"text","text":", (S, K,) or ↓"},{"kind":"arabic","text_bw":"taHotaDiruhu","text_ar":"تَحْتَضِرُهُ","orth_type":"arrow"},{"kind":"text","text":", (T, TA,) (assumed tropical:)  ["},{"kind":"italic_en","text":"The jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii, come to, and taint, the milk."},{"kind":"text","text":"] ―         -b4-"},{"kind":"arabic","text_bw":"HuDira","text_ar":"حُضِرَ"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"AuHotuDira","text_ar":"اُحْتُضِرَ","orth_type":"arrow"},{"kind":"text","text":", (A, Mgh, K,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HaDarahu Almawotu","text_ar":"حَضَرَهُ المَوْتُ"},{"kind":"text","text":", (A, K,) i. e. (tropical:)  ["},{"kind":"italic_en","text":"He was visited by the angel of death;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he became at the point of death; in the agony of death;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Almawotu","text_ar":"المَوْتُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AiHotaDarahu","text_ar":"اِحْتَضَرَهُ","orth_type":"arrow"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"he was visited by death,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by the angels of death;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(Mgh:) or ↓"},{"kind":"arabic","text_bw":"AuHotuDira","text_ar":"اُحْتُضِرَ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he died a youth."},{"kind":"text","text":"(S and TA voce"},{"kind":"arabic","text_bw":"A^ajozara","text_ar":"اَجْزَرَ"},{"kind":"text","text":", q. v.) ―         -b5-"},{"kind":"arabic","text_bw":"HaDaronaA Eano maA='i ka*aA","text_ar":"حَضَرْنَا عَنْ مَا=ءِ كَذَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We removed from such a water."},{"kind":"text","text":"(K, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"HaDarotu AlA^amora","text_ar":"حَضَرْتُ الاَمْرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I was present at the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(A.) ―         -b7-"},{"kind":"arabic","text_bw":"HaDarotu AlA^amora bixayorK","text_ar":"حَضَرْتُ الاَمْرَ بِخَيْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I formed a right opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judgment, respecting the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(A.) ―         -b8-"},{"kind":"arabic","text_bw":"HaDarahu Alham~u","text_ar":"حَضَرَهُ الهَمُّ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AHtDrhu","text_ar":"احتضرهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tHD~rhu","text_ar":"تحضّرهُ","orth_type":"arrow"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"Anxiety befell him."},{"kind":"text","text":"] (S, A.) ―         -b9-"},{"kind":"arabic","text_bw":"HaDaraniY ka*aA","text_ar":"حَضَرَنِى كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a thing occurred to my mind."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"quwluwA maA yaHoDurukumo","text_ar":"قُولُوا مَا يَحْضُرُكُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Say ye what is in your minds;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"what is ready with you."},{"kind":"text","text":"(TA from a trad.)       -A3-"},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":","},{"kind":"page_break","n":589},{"kind":"text","text":"(Msb,) inf. n."},{"kind":"arabic","text_bw":"HiDaArapN","text_ar":"حِضَارَةٌ"},{"kind":"text","text":", (AZ, S, K,) or"},{"kind":"arabic","text_bw":"HaDaArapN","text_ar":"حَضَارَةٌ"},{"kind":"text","text":", (As, S, A,) or both, (Msb,) [see"},{"kind":"arabic","text_bw":"badaA","text_ar":"بَدَا"},{"kind":"text","text":", the contr. of"},{"kind":"arabic","text_bw":"HaDara","text_ar":"حَضَرَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"bdw","text_ar":"بدو"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He resided, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in a region, district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract, of cities, towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages, and of cultivated land;"},{"kind":"text","text":"(S, Msb, K;) [as also ↓"},{"kind":"arabic","text_bw":"tHD~r","text_ar":"تحضّر","orth_type":"arrow"},{"kind":"text","text":": or this latter signifies"},{"kind":"italic_en","text":"he became an inhabitant of such a region, district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract:"},{"kind":"text","text":"] you say ↓"},{"kind":"arabic","text_bw":"badawiY~N yataHaD~aru","text_ar":"بَدَوِىٌّ يَتَحَضَّرُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"an inhabitant of the desert who becomes an inhabitant of a region, district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract, of cities"},{"kind":"text","text":"&c.]; and [contr.]"},{"kind":"arabic","text_bw":"HaDariY~N yatabad~aY","text_ar":"حَضَرِىٌّ يَتَبَدَّى"},{"kind":"text","text":". (A.) [See also 8.]"}],"source_refs":["S","Msb","K","Lth","A","L","Mgh","TA","Az","Fr","Sh","T","AZ","As"]}]}}