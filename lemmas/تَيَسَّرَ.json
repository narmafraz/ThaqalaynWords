,"verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n42456"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%8A%D9%8E%D8%B3%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to get easier"},{"pos":"noun","gloss":"verbal noun of تَيَسَّرَ (tayassara) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42456","headword_ar":"تيسّر","root":"ysr","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, M, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, facilitated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy;"},{"kind":"text","text":"(M, A, Msb, K, TA;)"},{"kind":"italic_en","text":"contr. of difficult, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Astysr","text_ar":"استيسر","orth_type":"arrow"},{"kind":"text","text":". (M, A, Msb, K.) You say,"},{"kind":"arabic","text_bw":"A^axa*onaA maA tayas~ara","text_ar":"اَخَذْنَا مَا تَيَسَّرَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"maA A@sotayosara","text_ar":"مَا ا@سْتَيْسَرَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"We took what was easy"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of obtainment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of attainment"},{"kind":"text","text":"]. (TA.) And it is said in a trad., respecting the eleemosinary tax called"},{"kind":"arabic","text_bw":"wayajoEalu mEahaA $aAtayoni A_ini, zakaAp","text_ar":"وَيَجْعَلُ معَهَا شَاتَيْنِ اـِنِ, زَكَاة"},{"kind":"arabic","text_bw":"lahu A^awo Ei$ariyna dirohamFA","text_ar":"لَهُ اَوْ عِشَرِينَ دِرْهَمًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A@sotayosarataA","text_ar":"ا@سْتَيْسَرَتَا","orth_type":"arrow"},{"kind":"italic_en","text":"And he shall put with it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"them, two sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, if they be easy to him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to give"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"or twenty dirhems."},{"kind":"text","text":"(TA.) And in the Kur, [ii. 192,]"},{"kind":"arabic","text_bw":"mina AlhadoYi","text_ar":"مِنَ الهَدْىِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"famaA A@sotayosara","text_ar":"فَمَا ا@سْتَيْسَرَ","orth_type":"arrow"},{"kind":"italic_en","text":"What is easy"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to give"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"of camels and kine and sheep or goats:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"either a camel or a cow or a sheep or goat."},{"kind":"text","text":"(M, TA.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"tys~r lahu","text_ar":"تيسّر لَهُ"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Astysr","text_ar":"استيسر","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, or an affair, K)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prepared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made ready for him:"},{"kind":"text","text":"(S, K, TA:) [and"},{"kind":"italic_en","text":"he prepared himself for it."},{"kind":"text","text":"] It is said in a trad.,"},{"kind":"arabic","text_bw":"qado tayas~araA liloqitaAli","text_ar":"قَدْ تَيَسَّرَا لِلْقِتَالِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They had both prepared themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made themselves ready, for fight."},{"kind":"text","text":"(TA, from a trad.) ―         -b3-"},{"kind":"arabic","text_bw":"tayas~arati AlbilaAdu","text_ar":"تَيَسَّرَتِ البِلَادُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The countries became abundant in herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the goods, conveniences,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comforts, of life."},{"kind":"text","text":"(TA, from a trad.)"}],"source_refs":["S","TA","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D9%8A%D8%B3%D8%B1/","headword_ar":"تيسر الوصول، إلى جامع الأصول","entries":[{"lexicon_id":"dictionary_50","lexicon_en":"Kâtip Çelebi / Ḥājī Khalīfa, Kashf al-Ẓunūn ʿan Asāmī al-Kutub wa-l-Funūn (d. 1657)","lexicon_ar":"كشف الظنون عن أسامي الكتب والفنون لحاجي خليفة","permalink":"https://arabiclexicon.hawramani.com/?p=135474#38df05","body_html":"تيسر الوصول، إلى جامع الأصول<br>يأتي: في الجيم."}]}}