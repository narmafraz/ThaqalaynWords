m":"p"},{"role":"present_2mp","form":"تُفَرِّغُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفَرِّغْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفَرِّغ","in_corpus":true,"count":46,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفَرِّغ","in_corpus":true,"count":21,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفَرِّغانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفَرِّغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفَرِّغانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفَرِّغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفَرِّغُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفَرِّغُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفَرِّغْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفَرِّغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفَرِّغ","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَرَّغْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرَّغْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":329,"cross_references":{"qac":{"found":true,"lemma_key":"فَرَّغَ","root":"فرغ","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n33635","n33640","n33641","n33642","n33643"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D9%91%D8%BA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be empty, to be vacant","tags":["intransitive"]},{"pos":"verb","gloss":"to be exhausted, to wind up","tags":["intransitive"]},{"pos":"verb","gloss":"to empty, to void","tags":["transitive"]},{"pos":"adj","gloss":"empty, vacant"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ف ر غ (f r ḡ)."},"ipa":["/fa.ra.ɣa/","/far.ra.ɣa/","/fa.riɣ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33635","headword_ar":"فَرَغَ","root":"frg","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":"; and app."},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", as below; inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":"; or, accord. to some, the latter is a simple subst., but it is more commonly used than the former;] said of a thing,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty, vacant, void, devoid, destitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":". (Msb.) [You say,"},{"kind":"arabic","text_bw":"faraga mino ka*aA","text_ar":"فَرَغَ مِنْ كَذَا"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty, vacant, void, devoid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destitute, of such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied thereby."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"faraga laka","text_ar":"فَرَغَ لَكَ"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vacant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied, for thee;"},{"kind":"text","text":"as though it were a place, or a vessel: and hence,"},{"kind":"italic_en","text":"the thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, exclusively for thee"},{"kind":"text","text":"]. (TA voce"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":".) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"faraga","text_ar":"فَرَغَ"},{"kind":"text","text":"(O, * K, * TA) said of a man, (TA,) [and app."},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":"also, as below,] inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He died;"},{"kind":"text","text":"(O, K, TA;) because his body became devoid of his soul, or spirit. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faraga mina Al$~ugoli","text_ar":"فَرَغَ مِنَ الشُّغْلِ"},{"kind":"text","text":", (S, O, Msb, K, *) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"(S, O, Msb, K) and [more commonly]"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":", (S, O, K,) or the latter is a simple subst.; (Msb;) and"},{"kind":"arabic","text_bw":"farag","text_ar":"فَرَغ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (O, K,) mentioned by Yoo; (O;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (O, Msb, K,) of the dial. of Temeem; (Msb;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", a compound of two dial. vars.; (O, Msb;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vacant from, devoid of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from, business, occupation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employment; unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure."},{"kind":"text","text":"(K, * TA.) [See also 5.] ―         -b4-  [And hence,"},{"kind":"arabic","text_bw":"faraga mina","text_ar":"فَرَغَ مِنَ"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"italic_en","text":"He ceased from, ended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"finished, the affair."},{"kind":"text","text":"] ―         -b5-  And"},{"kind":"arabic","text_bw":"faraga lahu","text_ar":"فَرَغَ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (O, Msb, K, TA,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", (O, * Msb, K, * TA,) aor."},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"and [more commonly]"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, his object,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the object to which he directed himself;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSada","text_ar":"قَصَدَ"},{"kind":"text","text":": (O, Msb, K, TA:) [or"},{"kind":"italic_en","text":"he made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, his exclusive object;"},{"kind":"text","text":"agreeably with an explanation of the phrase here following]: whence, in the Kur [lv. 31],"},{"kind":"arabic","text_bw":"lakumo sanaforugu","text_ar":"لَكُمْ سَنَفْرُغُ"},{"kind":"italic_en","text":"We will make you our object;"},{"kind":"text","text":"expl. by IAar as meaning"},{"kind":"arabic","text_bw":"sanaEomidu","text_ar":"سَنَعْمِدُ"},{"kind":"text","text":"[which is syn. with"},{"kind":"arabic","text_bw":"sanaqoSidu","text_ar":"سَنَقْصِدُ"},{"kind":"text","text":"]; (TA;) and some read"},{"kind":"arabic","text_bw":"sanaforagu","text_ar":"سَنَفْرَغُ"},{"kind":"text","text":"; (O, TA;) and some,"},{"kind":"arabic","text_bw":"saniforagu","text_ar":"سَنِفْرَغُ"},{"kind":"text","text":"; (O;) and some,"},{"kind":"arabic","text_bw":"saniforigu","text_ar":"سَنِفْرِغُ"},{"kind":"text","text":", asserting that Temeem say"},{"kind":"arabic","text_bw":"niEolimu","text_ar":"نِعْلِمُ"},{"kind":"text","text":"; (O, TA;) and some,"},{"kind":"arabic","text_bw":"sanaforagu A_ilayokumo","text_ar":"سَنَفْرَغُ اـِلَيْكُمْ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"sanaqoSidu","text_ar":"سَنَقْصِدُ"},{"kind":"arabic","text_bw":"A_ilayokumo","text_ar":"اـِلَيْكُمْ"},{"kind":"text","text":"; or"},{"kind":"arabic","text_bw":"sanaforugu lakumo","text_ar":"سَنَفْرُغُ لَكُمْ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"We will apply ourself exclusively"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sanatajar~adu","text_ar":"سَنَتَجَرَّدُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to"},{"kind":"text","text":"the reckoning with, and the requiting of,"},{"kind":"italic_en","text":"you;"},{"kind":"text","text":"and it is said to be a threat; (Bd;) a metaphorical phrase, from a man's saying to him whom he threatens,"},{"kind":"arabic","text_bw":"saA^aforugu","text_ar":"سَاَفْرُغُ"},{"kind":"arabic","text_bw":"laka","text_ar":"لَكَ"},{"kind":"text","text":", (Ksh, Bd,) meaning"},{"kind":"italic_en","text":"I will apply myself exclusively to"},{"kind":"text","text":"the making an assault upon"},{"kind":"italic_en","text":"thee:"},{"kind":"text","text":"(Ksh:) one says [also] in threatening,"},{"kind":"arabic","text_bw":"laA^aforugan~a laka","text_ar":"لَاَفْرُغَنَّ لَكَ"},{"kind":"text","text":"[meaning in like manner"},{"kind":"italic_en","text":"I will assuredly apply myself"},{"kind":"text","text":"&c.]. (TA.) [See, again, 5.] ―         -b6-"},{"kind":"arabic","text_bw":"fariga AlmaA='u","text_ar":"فَرِغَ المَا=ءُ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"The water poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(S, O, K.)       -A2-"},{"kind":"arabic","text_bw":"faruga","text_ar":"فَرُغَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"faraAgapN","text_ar":"فَرَاغَةٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"was easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, and quick, in pace, and wide in step."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"farugati","text_ar":"فَرُغَتِ"},{"kind":"arabic","text_bw":"AlD~arobapu","text_ar":"الضَّرْبَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"wound made by a"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"stroke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blow, was wide;"},{"kind":"text","text":"(O, K, TA;) likened to the"},{"kind":"arabic","text_bw":"farog","text_ar":"فَرْغ"},{"kind":"text","text":"of the leathern bucket. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faraAgapN","text_ar":"فَرَاغَةٌ"},{"kind":"text","text":"(as an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"faruga","text_ar":"فَرُغَ"},{"kind":"text","text":", TK) signifies The"},{"kind":"italic_en","text":"being impatient, and disquieted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitated."},{"kind":"text","text":"(O, K.)       -A3-"},{"kind":"arabic","text_bw":"faraga","text_ar":"فَرَغَ"},{"kind":"text","text":"as trans.: see 4."}],"source_refs":["TA","S","O","Msb","K","Ksh","Bd"]},{"entry_id":"n33640","headword_ar":"فَرْغٌ","root":"frg","body":[{"kind":"italic_en","text":"Width, breadth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ampleness."},{"kind":"text","text":"(S, O, TA.) ―         -b2-  And The"},{"kind":"italic_en","text":"place whence the water pours forth, between the cross-pieces of wood"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlEaraAqiY","text_ar":"العَرَاقِى"},{"kind":"text","text":"), of the leathern-bucket; (S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"firaAgN","text_ar":"فِرَاغٌ","orth_type":"arrow"},{"kind":"text","text":": (K: [expl. in the O as signifying the"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of the leathern bucket"},{"kind":"italic_en","text":"from which the water pours forth:"},{"kind":"text","text":"]) pl. of the former"},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"mafaArigu","text_ar":"مَفَارِغُ"},{"kind":"text","text":", [which is anomalous, like"},{"kind":"arabic","text_bw":"ma$aAbihu","text_ar":"مَشَابِهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maHaAsinu","text_ar":"مَحَاسِنُ"},{"kind":"text","text":"&c.,] (A, TA,) or this is pl. of ↓"},{"kind":"arabic","text_bw":"maforagN","text_ar":"مَفْرَغٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-  Hence"},{"kind":"arabic","text_bw":"AlfarogaAni","text_ar":"الفَرْغَانِ"},{"kind":"text","text":", (S, O,)"},{"kind":"arabic","text_bw":"farogu Ald~alowi Almuqad~amu","text_ar":"فَرْغُ الدَّلْوِ المُقَدَّمُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"farogu Ald~alowi","text_ar":"فَرْغُ الدَّلْوِ"},{"kind":"arabic","text_bw":"Almuw^ax~aru","text_ar":"المُوَخَّرُ"},{"kind":"text","text":", (S, O, K,) or"},{"kind":"arabic","text_bw":"Alfarogu AlA^aw~alu","text_ar":"الفَرْغُ الاَوَّلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alfarogu Alv~aAniY","text_ar":"الفَرْغُ الثَّانِى"},{"kind":"text","text":", (Kzw,)"},{"kind":"italic_en","text":"Two of the Mansions of the Moon,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"the Twenty-sixth Mansion"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the Twentyseventh; four stars, wide apart, forming the corners of a square,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"four-sided figure;"},{"kind":"text","text":"(Kzw;)"},{"kind":"italic_en","text":"each consisting of two stars,"},{"kind":"text","text":"(S, O, K, and Kzw,)"},{"kind":"italic_en","text":"of two bright stars,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"the apparent distance between each two stars being the measure of five cubits,"},{"kind":"text","text":"(S, O, L,) or"},{"kind":"italic_en","text":"the measure of a spear;"},{"kind":"text","text":"(K;) [see"},{"kind":"arabic","text_bw":"*iraAEN","text_ar":"ذِرَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rumoHN","text_ar":"رُمْحٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"the former pair consists of the stars a and"},{"kind":"text","text":"b"},{"kind":"italic_en","text":"of Pegasus;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the latter, of"},{"kind":"text","text":"g"},{"kind":"italic_en","text":"in Pegasus together with the bright star in the head of Andromeda;"},{"kind":"text","text":"as is shown by what here follows:] the Arabs name"},{"kind":"arabic","text_bw":"Ald~alowu","text_ar":"الدَّلْوُ"},{"kind":"text","text":"the four bright stars in Pegasus which form a square, or four-sided figure; i. e., that at the extremity of the neck, which is called"},{"kind":"arabic","text_bw":"matonu Alfarasi","text_ar":"مَتْنُ الفَرَسِ"},{"kind":"text","text":", and that which is called"},{"kind":"arabic","text_bw":"manokibu Alfarasi","text_ar":"مَنْكِبُ الفَرَسِ"},{"kind":"text","text":", and that which is called"},{"kind":"arabic","text_bw":"janaAHu Alfarasi","text_ar":"جَنَاحُ الفَرَسِ"},{"kind":"text","text":", and the star that belongs to both Pegasus and Andromeda: (Kzw, descr. of Pegasus:) [these two pairs of stars are what are commonly known as the"},{"kind":"arabic","text_bw":"farogaAni","text_ar":"فَرْغَانِ"},{"kind":"text","text":"; and are plainly indicated by the periods assigned to the auroral settings thereof: but the periods assigned to their auroral risings would lead us to apply the appel-lation of the"},{"kind":"arabic","text_bw":"frgAn","text_ar":"فرغان"},{"kind":"text","text":"to some other stars, not easily determinable, in Aquarius: see"},{"kind":"arabic","text_bw":"nawo'N","text_ar":"نَوْءٌ"},{"kind":"text","text":": and see also"},{"kind":"arabic","text_bw":"manaAzilu Alqamari","text_ar":"مَنَازِلُ القَمَرِ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"nzl","text_ar":"نزل"},{"kind":"text","text":".] The pl."},{"kind":"arabic","text_bw":"Alfuruwgu","text_ar":"الفُرُوغُ"},{"kind":"text","text":"is said to be applied to"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"farogaAni","text_ar":"فَرْغَانِ"},{"kind":"italic_en","text":"with the stars around them:"},{"kind":"text","text":"(O, TA:) and (accord. to El-Jumahee, O, TA)"},{"kind":"arabic","text_bw":"Alfuruwgu","text_ar":"الفُرُوغُ"},{"kind":"text","text":"[in the CK erroneously written"},{"kind":"arabic","text_bw":"Alfaruwgu","text_ar":"الفَرُوغُ"},{"kind":"text","text":"] signifies ["},{"kind":"italic_en","text":"The constellation called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AljawozaA='u","text_ar":"الجَوْزَا=ءُ"},{"kind":"text","text":". (O, K, TA. [But see"},{"kind":"arabic","text_bw":"furuwEu AljawozaA='i","text_ar":"فُرُوعُ الجَوْزَا=ءِ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"frE","text_ar":"فرع"},{"kind":"text","text":".]) ―         -b4-"},{"kind":"arabic","text_bw":"farogN","text_ar":"فَرْغٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A vessel in which is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the exuded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expressed, juice termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"dibos","text_ar":"دِبْس"},{"kind":"text","text":", (O, K,) and"},{"kind":"arabic","text_bw":"Saqor","text_ar":"صَقْر"},{"kind":"text","text":". (O.) ―         -b5-  Also"},{"kind":"italic_en","text":"Land affected with drought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"barrenness."},{"kind":"text","text":"(IB, TA.) ―         -b6-  See also the next paragraph."}],"source_refs":["TA","A","S","O","K","Kzw","L"]},{"entry_id":"n33641","headword_ar":"فِرْغٌ","root":"frg","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faArigN","text_ar":"فَارِغٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"*ahaba damuhu firogFA","text_ar":"ذَهَبَ دَمُهُ فِرْغًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"farogFA","text_ar":"فَرْغًا","orth_type":"arrow"},{"kind":"text","text":"mean"},{"kind":"italic_en","text":"His blood went for nothing, as a thing of no account, unretaliated, and uncompensated by a mulct,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"and retaliation for it was not sought:"},{"kind":"text","text":"(S, O:) and in like manner one says,"},{"kind":"arabic","text_bw":"*ahabato dimaAw^uhumo firgFA","text_ar":"ذَهَبَتْ دِمَاوُهُمْ فِرغًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Their bloods went for nothing,"},{"kind":"text","text":"&c.]. (Z, TA.) Hence, in the Kur xxviii. 9, accord. to one reading,"},{"kind":"arabic","text_bw":"waA^aSobaHa fuw^aAdu A^um~i muwsaY firogFA","text_ar":"وَاَصْبَحَ فُوَادُ اُمِّ مُوسَى فِرْغًا"},{"kind":"text","text":"(Ksh and Bd) i. e."},{"kind":"italic_en","text":"And the heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, of the mother of Moses became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it were"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing that was lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that had gone away."},{"kind":"text","text":"(Ksh. [See"},{"kind":"arabic","text_bw":"faArigN","text_ar":"فَارِغٌ"},{"kind":"text","text":".])"}],"source_refs":["S","O","K"]},{"entry_id":"n33642","headword_ar":"فَرِغٌ","root":"frg","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faArigN","text_ar":"فَارِغٌ"},{"kind":"text","text":", first quarter."}],"source_refs":[]},{"entry_id":"n33643","headword_ar":"فُرُغٌ","root":"frg","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"mufar~agN","text_ar":"مُفَرَّغٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Made empty, vacant, void,"},{"kind":"text","text":"&c.]: (O, TA:) so in the phrase"},{"kind":"arabic","text_bw":"A_inaA='N furugN","text_ar":"اـِنَا=ءٌ فُرُغٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An emptied vessel"},{"kind":"text","text":"]: (TA:) and so in the saying [in the Kur xxviii. 9], accord. to the reading of Kh,"},{"kind":"arabic","text_bw":"waA^aSobaHa","text_ar":"وَاَصْبَحَ"},{"kind":"arabic","text_bw":"fuw^aAdu A^um~i muwsaY furugFA","text_ar":"فُوَادُ اُمِّ مُوسَى فُرُغًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the heart of the mother of Moses became rendered void"},{"kind":"text","text":"of patience, or of anxiety, &c.: see"},{"kind":"arabic","text_bw":"faArigN","text_ar":"فَارِغٌ"},{"kind":"text","text":"]. (O, TA.) ―         -b2-  Applied to a bow, as also ↓"},{"kind":"arabic","text_bw":"firaAgN","text_ar":"فِرَاغٌ","orth_type":"arrow"},{"kind":"text","text":", it means"},{"kind":"italic_en","text":"Without a string:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"without an arrow."},{"kind":"text","text":"(TA.)"}],"source_refs":["O","TA"]}]}}