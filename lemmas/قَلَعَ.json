تُقْلِعُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jaA*K","text_ar":"جَاذٍ"},{"kind":"text","text":", art."},{"kind":"arabic","text_bw":"j*w","text_ar":"جذو"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}