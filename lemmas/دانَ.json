{"lemma":"دانَ","slug":"دانَ","root":"د.#.ن","root_slug":"د-_-ن","root_link":"/words/roots/د-_-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"دِنْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"دِنْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"دِنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"دِنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"دِنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"دانَ","in_corpus":true,"count":20,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"دانَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"دانا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"دانَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"دانُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"دِنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَدِن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَدِين","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَدِينِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَدِينِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَدِينا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَدِينانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَدِينُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَدِينُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدِنْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَدِين","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَدِين","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدِينا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدِينانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدِينا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدِينانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدِينُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدِينُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدِنْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"دِنْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دِنّا","in_corpus":true,"count":27,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَدِين","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدِين","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":88,"cross_references":{"qac":{"found":true,"lemma_key":"دان","root":"دنو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n13236","n13496","n13578"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to owe (money)"},{"pos":"verb","gloss":"to borrow"},{"pos":"verb","gloss":"to lend"},{"pos":"verb","gloss":"to compel"},{"pos":"verb","gloss":"to render contemptible"},{"pos":"verb","gloss":"to submit, to yield, to obey"},{"pos":"verb","gloss":"to judge","examples":[{"text":"أَإِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَإِنَّا لَمَدِينُونَ","english":"...after we die and become dust and bone, [that] we shall be brought for judgement?”’"}]},{"pos":"verb","gloss":"to hold religion.","tags":["intransitive"]},{"pos":"verb","gloss":"to be or become low, base, vile, despised, inferior, weak, of low quality"}]},"etymology":{"source":"wiktextract","text":"From the root د ي ن (d y n). Compare Hebrew דן.\n\nFrom the root د و ن (d w n)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13236","headword_ar":"دَانٍ","root":"dnw","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, near; drawing near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approaching:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"near;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"daniY~N","text_ar":"دَنِىٌّ"},{"kind":"text","text":":] act. part. n. of"},{"kind":"arabic","text_bw":"danaA minohu","text_ar":"دَنَا مِنْهُ"},{"kind":"text","text":". (Msb.)"}],"source_refs":[]},{"entry_id":"n13496","headword_ar":"دَانَ","root":"dwn","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaduwnu","text_ar":"يَدُونُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dawonN","text_ar":"دَوْنٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"A^udiyna","text_ar":"اُدِينَ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) with damm, (K,) inf. n."},{"kind":"arabic","text_bw":"A_idaAnapN","text_ar":"اـِدَانَةٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"duwnN","text_ar":"دُونٌ"},{"kind":"text","text":"; (S, K;) [i. e.]"},{"kind":"italic_en","text":"low, base, vile,"},{"kind":"text","text":"&c.: or"},{"kind":"italic_en","text":"weak:"},{"kind":"text","text":"(K:) mentioned by Er-Rághib on the authority of IKt: (TA:) so say some: but accord. to others,"},{"kind":"arabic","text_bw":"duwnN","text_ar":"دُونٌ"},{"kind":"text","text":"has no verb. (S, TA.)"},{"kind":"arabic","text_bw":"lamo yaduno","text_ar":"لَمْ يَدُنْ"},{"kind":"text","text":", (as in my copies of the S,) or"},{"kind":"arabic","text_bw":"lm yudano","text_ar":"لم يُدَنْ"},{"kind":"text","text":", (as in the TA,) at the end of a verse of 'Adee, as some relate it, [perhaps the only authority for these two verbs,] is accord. to others"},{"kind":"arabic","text_bw":"lm ydan~o","text_ar":"لم يدَنّْ"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"dan~aY","text_ar":"دَنَّى"},{"kind":"text","text":"meaning “ he, or it, was, or became, weak. ” (S, K.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n13578","headword_ar":"دَانَ","root":"dyn","body":[{"kind":"text","text":", (IAar, S, K, TA,) aor."},{"kind":"arabic","text_bw":"yadiynu","text_ar":"يَدِينُ"},{"kind":"text","text":", (IAar, M, K, TA,) [inf. n."},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":", (which see below,) in this and most of the other senses, or the inf. n. is"},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":"is a simple subst.,]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, obedient; he obeyed:"},{"kind":"text","text":"(IAar, S, M, K, TA:) this is the primary signification: or, as some say, the primary signification is the following; namely,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, abased and submissive:"},{"kind":"text","text":"(IAar, * K, * TA:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, abased and enslaved and obedient."},{"kind":"text","text":"(S.) You say,"},{"kind":"arabic","text_bw":"daAna lahu","text_ar":"دَانَ لَهُ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"dinotu lahu","text_ar":"دِنْتُ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, obedient to him"},{"kind":"text","text":"[&c.], or"},{"kind":"italic_en","text":"obeyed him"},{"kind":"text","text":"[&c.]. (S, M, TA.) And"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"arabic","text_bw":"A^adiynuhu","text_ar":"اَدِينُهُ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"I served him, did service for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ministered to him, and acted well to him."},{"kind":"text","text":"(M, K.) ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"He became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a servant of God,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a Muslim."},{"kind":"text","text":"(TK.) You say,"},{"kind":"arabic","text_bw":"daAna biA@loA_isolaAmi","text_ar":"دَانَ بِا@لْاـِسْلَامِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":", with kesr, [and"},{"kind":"arabic","text_bw":"diyaAnapN","text_ar":"دِيَانَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, a servant of God by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"following the religion of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"El-Islám;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he followed El-Islám as his religion;"},{"kind":"text","text":"] and so ↓"},{"kind":"arabic","text_bw":"tdy~n","text_ar":"تديّن","orth_type":"arrow"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"daAna bika*A","text_ar":"دَانَ بِكَذا"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"dinotu bihi","text_ar":"دِنْتُ بِهِ"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"diyaAnapN","text_ar":"دِيَانَةٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tdy~n","text_ar":"تديّن","orth_type":"arrow"},{"kind":"text","text":", [and"},{"kind":"arabic","text_bw":"tdy~ntu bh","text_ar":"تديّنتُ به"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I, followed such a thing as his,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"my, religion;"},{"kind":"text","text":"] (S, TA;) from"},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":"as signifying “ obedience. ” (S.) And"},{"kind":"arabic","text_bw":"dAn bidiynihimo","text_ar":"دان بِدِينِهِمْ"},{"kind":"italic_en","text":"He followed them in their religion; agreed with them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was of one mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion with them, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting, their religion; took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adopted, their religion as his."},{"kind":"text","text":"(TA.) And the trad. of 'Alee,"},{"kind":"arabic","text_bw":"maHab~apu AlEulamaA='u diynN yudaAnu","text_ar":"مَحَبَّةُ العُلَمَا=ءُ دِينٌ يُدَانُ"},{"kind":"arabic","text_bw":"A@ll~`hu bihi","text_ar":"ا@للّٰهُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The love of the learned is"},{"kind":"text","text":"a kind of"},{"kind":"italic_en","text":"religion with which God is served"},{"kind":"text","text":"]. (TA.) In the phrase"},{"kind":"arabic","text_bw":"wa laA yadiynuwna diyna AlHaq~i","text_ar":"وَ لَا يَدِينُونَ دِينَ الحَقِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nor follow the religion of the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the true religion"},{"kind":"text","text":"], in the Kur ix. 29, El-Islám is meant. (Jel.)       -A2-  Also"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disobedient; he disobeyed:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, mighty, potent, powerful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, in rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state; noble, honourable, glorious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illustrious."},{"kind":"text","text":"(IAar, T, K.) Thus it bears significations contr. to those mentioned in the first part of this paragraph. (MF.)       -A3-  Also, (S, M, Msb, K,) first pers."},{"kind":"arabic","text_bw":"dinotu","text_ar":"دِنْتُ"},{"kind":"text","text":", (T, M8gh,) aor. as above, (T, S, Msb,) inf. n."},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":", (S, Msb,) from"},{"kind":"arabic","text_bw":"AlmudaAyanapu","text_ar":"المُدَايَنَةُ"},{"kind":"text","text":", (Msb, [see 3,])"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^axa*a Ald~ayona","text_ar":"اَخَذَ الدَّيْنَ"},{"kind":"text","text":", (IKt, M, Msb, K,) or [rather]"},{"kind":"arabic","text_bw":"A^axa*a dayonFA","text_ar":"اَخَذَ دَيْنًا"},{"kind":"text","text":", (T,) ["},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received, a loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like; he borrowed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bought, upon credit;"},{"kind":"text","text":"which is the meaning generally obtaining: and ↓"},{"kind":"arabic","text_bw":"Aid~aAna","text_ar":"اِدَّانَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstdAn","text_ar":"استدان","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tdy~n","text_ar":"تديّن","orth_type":"arrow"},{"kind":"text","text":"signify [in like manner]"},{"kind":"arabic","text_bw":"A^axa*a dayonFA","text_ar":"اَخَذَ دَيْنًا"},{"kind":"text","text":": (K:) or the first, i. e."},{"kind":"arabic","text_bw":"dAn","text_ar":"دان"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, a loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(ISk, S, Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"Ad~An","text_ar":"ادّان","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstdAn","text_ar":"استدان","orth_type":"arrow"},{"kind":"text","text":": (S, Mgh:) and"},{"kind":"italic_en","text":"he became indebted, in debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"under the obligation of a debt:"},{"kind":"text","text":"(S:) and ↓"},{"kind":"arabic","text_bw":"Ad~An","text_ar":"ادّان","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstdAn","text_ar":"استدان","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"arabic","text_bw":"A^axa*a bidayonK","text_ar":"اَخَذَ بِدَيْنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received, by incurring a debt;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bought, upon credit;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"A^axa*a dayonFA","text_ar":"اَخَذَ دَيْنًا"},{"kind":"text","text":"]; (M;) or the first and last of these three signify"},{"kind":"arabic","text_bw":"A^axa*a Ald~ayona","text_ar":"اَخَذَ الدَّيْنَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AiqotaraDa","text_ar":"اِقْتَرَضَ"},{"kind":"text","text":"[which means the same]: but ↓"},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted, what is termed"},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"a loan,"},{"kind":"text","text":"or"},{"kind":"page_break","n":943},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sold, a thing upon credit"},{"kind":"text","text":"]: (TA:) accord. to Esh-Sheybánee, this last verb signifies"},{"kind":"italic_en","text":"he became entitled to a debt from others"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"from another"},{"kind":"text","text":"]: Lth says that it ("},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ"},{"kind":"text","text":") signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"musotadiynN","text_ar":"مُسْتَدِينٌ"},{"kind":"text","text":"; [i. e. it is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"AstdAn","text_ar":"استدان"},{"kind":"text","text":", as it is said to be in the M and K;] but [Az says,] this, which has been mentioned on the authority of some one or more by Sh, is in my opinion a mistake;"},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he sold upon credit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became entitled to a debt from others"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"from another"},{"kind":"text","text":"]; (T, TA;) or"},{"kind":"italic_en","text":"he sold to persons upon a limited credit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for payment at an appointed period, so that he became entitled to a debt from them:"},{"kind":"text","text":"(S:) and accord. to Sh, ↓"},{"kind":"arabic","text_bw":"Ad~An","text_ar":"ادّان","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he became much in debt."},{"kind":"text","text":"(T, TA.) El-Ahmar cites the following verse of El-'Ojeyr Es-Saloolee:"},{"kind":"quote","text":"nadiynu wayaqoDiY A@ll~`hu Ean~aA waqado naraY\n                      \n                     \n                        maSaAriEa qawomN laA yadiynuwna Duy~aEi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We incur debt, and God pays for us; and sometimes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, we see the places of overthrow of a people, who incur not debt, in a state of perdition"},{"kind":"text","text":"]: in the S [and the T]"},{"kind":"arabic","text_bw":"Duy~aEaA","text_ar":"ضُيَّعَا"},{"kind":"text","text":"; but correctly as above; for the whole of the"},{"kind":"arabic","text_bw":"qaSiydap","text_ar":"قَصِيدَة"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"maxofuwDap","text_ar":"مَخْفُوضَة"},{"kind":"text","text":". (IB, TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"muEoriDFA","text_ar":"مُعْرِضًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aid~aAna","text_ar":"اِدَّانَ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) or, as some relate it,"},{"kind":"arabic","text_bw":"daAna","text_ar":"دَانَ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He bought upon credit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"borrowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded a loan, of whomsoever he could, addressing himself to such as came in his way:"},{"kind":"text","text":"(S, TA:) or both mean"},{"kind":"italic_en","text":"he bought upon credit avoiding payment:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he contracted a debt with every one who presented himself to him:"},{"kind":"text","text":"(K, TA: [see also other explanations voce"},{"kind":"arabic","text_bw":"muEoriDN","text_ar":"مُعْرِضٌ"},{"kind":"text","text":":]) ↓"},{"kind":"arabic","text_bw":"Ad~An","text_ar":"ادّان","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he bought upon credit:"},{"kind":"text","text":"(K:) or [thus and also]"},{"kind":"italic_en","text":"the contr.,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he sold upon credit."},{"kind":"text","text":"(T, K.) ―         -b2-  It is also trans.; and so is ↓"},{"kind":"arabic","text_bw":"A^adaAna","text_ar":"اَدَانَ","orth_type":"arrow"},{"kind":"text","text":". (Msb.) You say,"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", (M, Mgh, K, [in the CK"},{"kind":"arabic","text_bw":"diynapN","text_ar":"دِينَةٌ"},{"kind":"text","text":"is here put for"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":",]) inf. n."},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"A^adanotuhu","text_ar":"اَدَنْتُهُ","orth_type":"arrow"},{"kind":"text","text":"(M, Mgh, K,) inf. n."},{"kind":"arabic","text_bw":"A_idaAnapN","text_ar":"اـِدَانَةٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"I gave him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted him, to a certain period, what is termed"},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"the loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like; I lent to him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I gave him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted him, credit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sold to him, upon credit"},{"kind":"text","text":"]: (M, K, TA:)"},{"kind":"italic_en","text":"so that he owed a debt:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aqoraDotuhu","text_ar":"اَقْرَضْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I gave him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"granted him, a loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]; (M, * Mgh, K;) as also ↓"},{"kind":"arabic","text_bw":"day~anotuhu","text_ar":"دَيَّنْتُهُ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) or"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":"has this last meaning: (A 'Obeyd, S, M:) and ↓"},{"kind":"arabic","text_bw":"A^adanotuhu","text_ar":"اَدَنْتُهُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, of him a loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AisotaqoraDotu minohu","text_ar":"اِسْتَقْرَضْتُ مِنْهُ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"Aisotadanotuhu","text_ar":"اِسْتَدَنْتُهُ","orth_type":"arrow"},{"kind":"text","text":": (M:) or"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":"has each of the last two meanings: (A 'Obeyd, T, Msb:) and signifies also"},{"kind":"italic_en","text":"I received from him a loan,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(K.) And one says, ↓"},{"kind":"arabic","text_bw":"A^adin~iY","text_ar":"اَدِنِّى","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ea$arapa daraAhima","text_ar":"عَشَرَةَ دَرَاهِمَ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"Lend thou to me ten dirhems."},{"kind":"text","text":"(S, TA.)       -A4-"},{"kind":"arabic","text_bw":"dAnhu","text_ar":"دانهُ"},{"kind":"text","text":", (S,) first pers."},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":", (M, K,) or the latter is the inf. n. and the former is a simple subst., (M,) also signifies"},{"kind":"italic_en","text":"He repaid, requited, compensated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompensed, him,"},{"kind":"text","text":"(S, M, Msb, K,)"},{"kind":"arabic","text_bw":"bifiEolihi","text_ar":"بِفِعْلِهِ"},{"kind":"italic_en","text":"for his deed:"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"dAynhu","text_ar":"داينهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mudaAyanapN","text_ar":"مُدَايَنَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"diyaAnN","text_ar":"دِيَانٌ"},{"kind":"text","text":". (M.) And"},{"kind":"arabic","text_bw":"din~aAhumo","text_ar":"دِنَّاهُمْ"},{"kind":"italic_en","text":"We did to them like as they did to us."},{"kind":"text","text":"(Ham p. 10.) One says,"},{"kind":"arabic","text_bw":"kamaA tadiynu tudaAnu","text_ar":"كَمَا تَدِينُ تُدَانُ"},{"kind":"text","text":", (T, S, M,) a prov., (M,) meaning"},{"kind":"italic_en","text":"Like as thou repayest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requitest,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"thou shalt be repaid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requited,"},{"kind":"text","text":"&c.; (S, M;) i. e."},{"kind":"italic_en","text":"according to thy deed thou shalt be repaid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requited,"},{"kind":"text","text":"&c.: (S:) or, as some say,"},{"kind":"italic_en","text":"like as thou doest, it shall be done to thee:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"like as thou doest thou shalt be given,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"repaid,"},{"kind":"text","text":"&c. (T.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"Aall~`hum~a dinohumo kamaA","text_ar":"اَللّٰهُمَّ دِنْهُمْ كَمَا"},{"kind":"arabic","text_bw":"yadiynuwnanaA","text_ar":"يَدِينُونَنَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"O God, repay them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requite them,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the like of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that which they do to us."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Aall~`hu layadiynu mina Aljam~~aA='i liloqaronaA='i","text_ar":"اَللّٰهُ لَيَدِينُ مِنَ الجَمَّّا=ءِ لِلْقَرْنَا=ءِ"},{"kind":"text","text":", a trad. of Selmán, means"},{"kind":"italic_en","text":"God will assuredly retaliate"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for her that is hornless upon her that is horned"},{"kind":"text","text":"]. (TA.) ―         -b3-  And one says,"},{"kind":"arabic","text_bw":"mano daAna nafosahu","text_ar":"مَنْ دَانَ نَفْسَهُ"},{"kind":"arabic","text_bw":"rabiHa","text_ar":"رَبِحَ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He who reckons with himself"},{"kind":"text","text":"["},{"kind":"italic_en","text":"gains"},{"kind":"text","text":"] (Ham p. 10. [Or the verb may here have the meaning next following.])       -A5-  Also,"},{"kind":"arabic","text_bw":"dAnhu","text_ar":"دانهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He abased him,"},{"kind":"text","text":"(T, S, K,) and"},{"kind":"italic_en","text":"enslaved him."},{"kind":"text","text":"(T, S.) Hence, (T,) it is said in a trad.,"},{"kind":"arabic","text_bw":"Alkay~isu mano daAna","text_ar":"الكَيِّسُ مَنْ دَانَ"},{"kind":"arabic","text_bw":"nafosahu waEamila limaA baEoda Almawoti","text_ar":"نَفْسَهُ وَعَمِلَ لِمَا بَعْدَ المَوْتِ"},{"kind":"text","text":", (S, T,) i. e. ["},{"kind":"italic_en","text":"The intelligent is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he who abases, and enslaves, himself"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and works for that which shall be after death"},{"kind":"text","text":"]: or, as some say,"},{"kind":"italic_en","text":"who reckons with himself:"},{"kind":"text","text":"(T:) or, accord. to some,"},{"kind":"italic_en","text":"who overcomes himself."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"dAnhu","text_ar":"دانهُ"},{"kind":"text","text":", (K,) first pers."},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", (T,) signifies"},{"kind":"italic_en","text":"He made him to do that which he disliked."},{"kind":"text","text":"(AZ, T, K.) And"},{"kind":"arabic","text_bw":"diyna","text_ar":"دِينَ"},{"kind":"italic_en","text":"He was made to do that which he disliked."},{"kind":"text","text":"(T.) ―         -b2-  And"},{"kind":"arabic","text_bw":"dinotuhu","text_ar":"دِنْتُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I ruled, governed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"managed, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(M, TA.) And"},{"kind":"italic_en","text":"I possessed it; owned it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had, authority over it."},{"kind":"text","text":"(Sh, S, K, TA.)       -A6-"},{"kind":"arabic","text_bw":"dAn","text_ar":"دان"},{"kind":"text","text":", (IAar, T, K,) aor."},{"kind":"arabic","text_bw":"yadiynN","text_ar":"يَدِينٌ"},{"kind":"text","text":", (K,) [inf. n., app.,"},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":", which see below,] signifies also"},{"kind":"italic_en","text":"He became accustomed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he accustomed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated himself, to good"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to evil:"},{"kind":"text","text":"(IAar, T, K:) and, accord. to Lth, (T,)"},{"kind":"arabic","text_bw":"diyna","text_ar":"دِينَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he was accustomed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated:"},{"kind":"text","text":"(T, M:) or, as some say,"},{"kind":"arabic","text_bw":"diynN","text_ar":"دِينٌ"},{"kind":"text","text":"signifying “ custom, ” or “ habit, ” has no verb. (M.)       -A7-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, IAar, T)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, smitten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected, by a disease."},{"kind":"text","text":"(IAar, T, K.)"}],"source_refs":["IAar","S","K","TA","M","Msb","T","IKt","Mgh"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AF%D8%A7%D9%86/","headword_ar":"دان","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=51044#31d90b","body_html":"دان<br>عن الفارسية بمعنى عارف وعالم وخبير. يستخدم للذكور.<br>دان<br>عن العبرية بمعنى القاضي. يستخدم للذكور."},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=51044#27842d","body_html":"دان: عامية أذن، ودانين: أذنين، ودانين الجدي أي آذان الجدي وهو بطونيكا وبطونيقا وقسطون، باطونيقي (بوشر)."}]}}