:0},"lanes":{"found":true,"entry_ids":["n3950"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AA%D9%92%D8%B9%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3950","headword_ar":"اتعب","root":"tEb","body":[{"kind":"italic_en","text":"He fatigued, tired, wearied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded,"},{"kind":"text","text":"another; (S, Msb, K;) and himself, in a work that he imposed upon himself, or in which he laboured; and his travelling-camels, by urging them quickly, or by hard journeying. (TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He broke"},{"kind":"text","text":"a bone"},{"kind":"italic_en","text":"again after it had been set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consolidated:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he caused"},{"kind":"text","text":"a bone"},{"kind":"italic_en","text":"to have a defect in it, after it had been set, so that there remained in it a constant swelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resulted a lameness:"},{"kind":"arabic","text_bw":"AtEb AlEaZoma","text_ar":"اتعب العَظْمَ"},{"kind":"text","text":"signifying"},{"kind":"arabic","text_bw":"A^aEonatahu baEoda Aljabori","text_ar":"اَعْنَتَهُ بَعْدَ الجَبْرِ"},{"kind":"text","text":": (so in the CK:) or"},{"kind":"arabic","text_bw":"A^aEotabahu bEd Aljbr","text_ar":"اَعْتَبَهُ بعد الجبر"},{"kind":"text","text":". (So in MS. copies of the K and in the TA. [In the latter, in art."},{"kind":"arabic","text_bw":"Etb","text_ar":"عتب"},{"kind":"text","text":", this reading is confirmed; but a remark below, voce"},{"kind":"arabic","text_bw":"mutoEabN","text_ar":"مُتْعَبٌ"},{"kind":"text","text":", rather favours the former reading, that of the CK.]) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"He filled"},{"kind":"text","text":"a vessel; (A, K;) as, for instance, a drinking-cup, or bowl. (A.)       -A2-"},{"kind":"arabic","text_bw":"AtEb Alqawomu","text_ar":"اتعب القَوْمُ"},{"kind":"italic_en","text":"The people's cattle became fatigued, tired, wearied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded."},{"kind":"text","text":"(K.)"}],"source_refs":[]}]},"classical_definitions":null}