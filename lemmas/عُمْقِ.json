{"lemma":"عُمْقِ","slug":"عُمْقِ","root":"ع.م.ق","root_slug":"ع-م-ق","root_link":"/words/roots/ع-م-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n30549","","n30552","n30553","n30554","n30555","n30556"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D9%85%D9%92%D9%82%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become deep"},{"pos":"verb","gloss":"to deepen"},{"pos":"noun","gloss":"depth"},{"pos":"noun","gloss":"bottom"},{"pos":"noun","gloss":"verbal noun of عَمُقَ (ʕamuqa, “to be or become deep”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"depth"},{"pos":"noun","gloss":"bottom"},{"pos":"adj","gloss":"masculine plural of عَمِيق (ʕamīq)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30549","headword_ar":"عَمُقَ","root":"Emq","body":[{"kind":"text","text":", (S, O, K,) or"},{"kind":"arabic","text_bw":"Eamuqato","text_ar":"عَمُقَتْ"},{"kind":"text","text":", (Msb,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"EamaAqapN","text_ar":"عَمَاقَةٌ"},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ"},{"kind":"text","text":", (Msb,) said of a well ("},{"kind":"arabic","text_bw":"rakiY~N","text_ar":"رَكِىٌّ"},{"kind":"text","text":", S, O, or"},{"kind":"arabic","text_bw":"biy^orN","text_ar":"بِيْرٌ"},{"kind":"text","text":"Msb),"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, deep:"},{"kind":"text","text":"(S, * O, * Msb, K, * TA:) and so"},{"kind":"arabic","text_bw":"maEuqa","text_ar":"مَعُقَ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"maA A^aboEada EamaAqapa h`*ihi Alr~akiy~api","text_ar":"مَا اَبْعَدَ عَمَاقَةَ هٰذِهِ الرَّكِيَّةِ"},{"kind":"text","text":"(O, K *) and ↓"},{"kind":"arabic","text_bw":"maA A^aEomaqahaA","text_ar":"مَا اَعْمَقَهَا","orth_type":"arrow"},{"kind":"text","text":"(K) ["},{"kind":"italic_en","text":"How great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far-extending, is the depth of this well !"},{"kind":"text","text":"]: and so"},{"kind":"arabic","text_bw":"maA A^amoEaqahaA","text_ar":"مَا اَمْعَقَهَا"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Eamuqa","text_ar":"عَمُقَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eamiqa","text_ar":"عَمِقَ"},{"kind":"text","text":", inf. n. (of the former, TA)"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ"},{"kind":"text","text":"and (of the latter, TA)"},{"kind":"arabic","text_bw":"EamaAqapN","text_ar":"عَمَاقَةٌ"},{"kind":"text","text":", said of a [road such as is termed]"},{"kind":"arabic","text_bw":"faj~","text_ar":"فَجّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, far-extending:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long:"},{"kind":"text","text":"(K:) but accord. to a saying of IAar, app. not used in the latter sense when said of a road. (TA.) And"},{"kind":"arabic","text_bw":"Eamuqa","text_ar":"عَمُقَ"},{"kind":"text","text":"said of a place,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distant, remote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","O","K","Msb"]},{"entry_id":"n30552","headword_ar":"عَمْقٌ","root":"Emq","body":[{"kind":"text","text":"(S, O, Msb, K, TA) and ↓"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K, TA,) or the latter is an inf. n., (Msb,) and ↓"},{"kind":"arabic","text_bw":"EumuqN","text_ar":"عُمُقٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) The"},{"kind":"italic_en","text":"bottom"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qaEor","text_ar":"قَعْر"},{"kind":"text","text":") of a well (S, O, K, TA) and the like, (K, TA,) and of a [road such as is termed]"},{"kind":"arabic","text_bw":"faj~","text_ar":"فَجّ"},{"kind":"text","text":", and of a valley: (S, O, TA:) or the"},{"kind":"italic_en","text":"depth"},{"kind":"text","text":"of a well (Msb, TA) and the like; [i. e.] the"},{"kind":"italic_en","text":"distance to the bottom:"},{"kind":"text","text":"(TA:) [and"},{"kind":"arabic","text_bw":"EumuwqN","text_ar":"عُمُوقٌ"},{"kind":"text","text":", which may be a pl. of the first or second, and perhaps of the third, signifies"},{"kind":"italic_en","text":"deep places"},{"kind":"text","text":"of the ground: (see"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":":) and ↓"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ","orth_type":"arrow"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"depth"},{"kind":"text","text":"of anything; or"},{"kind":"italic_en","text":"distance between the two opposite surfaces"},{"kind":"text","text":"thereof:] but accord. to IAar, ↓"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ","orth_type":"arrow"},{"kind":"text","text":"as an attribute of a road signifies"},{"kind":"italic_en","text":"distance:"},{"kind":"text","text":"and as an attribute of a well it is the"},{"kind":"italic_en","text":"length of"},{"kind":"text","text":"its"},{"kind":"italic_en","text":"cavity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interior, from top to bottom."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EamoqN","text_ar":"عَمْقٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EumoqN","text_ar":"عُمْقٌ","orth_type":"arrow"},{"kind":"text","text":"signify also The"},{"kind":"italic_en","text":"distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, extremity"},{"kind":"text","text":"of a desert, or waterless desert: pl."},{"kind":"arabic","text_bw":"A^aEomaAqN","text_ar":"اَعْمَاقٌ"},{"kind":"text","text":": (S, O, K, TA:) which is also expl. as signifying"},{"kind":"italic_en","text":"sides, regions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tracts;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"extremities;"},{"kind":"text","text":"without restriction: and"},{"kind":"italic_en","text":"sides, regions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tracts,"},{"kind":"text","text":"of the earth, or of a land. (TA.) Ru-beh says,"},{"kind":"quote","text":"fiY sabosabK munojaridi AlA^aEolaAqi\n                      \n                     \n                        AlA^aEomaAqi ↓ \n      gayori AlfijaAji Eamiqi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In a desert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waterless desert, bared of the beaten tracks, except the far-extending (?) remote in respect of the extremities"},{"kind":"text","text":"]. (O.)       -A2-  And"},{"kind":"arabic","text_bw":"EamoqN","text_ar":"عَمْقٌ"},{"kind":"italic_en","text":"Full-grown unripe dates put in the sun to dry"},{"kind":"text","text":"(AHn, K, TA)"},{"kind":"italic_en","text":"and to ripen."},{"kind":"text","text":"(AHn, TA.) ―         -b2-  [And accord. to Forskål, (Flora Aeg. Arab. p. cxii.,) The"},{"kind":"italic_en","text":"Euphorbia officin. arborea;"},{"kind":"text","text":"mentioned by him as found at a place in Tihámeh, which suggests that its name may perhaps be correctly"},{"kind":"arabic","text_bw":"EimoqaY","text_ar":"عِمْقَى"},{"kind":"text","text":", q. v.]"}],"source_refs":["S","O","Msb","K","TA","AHn"]},{"entry_id":"n30553","headword_ar":"عُمْقٌ","root":"Emq","body":[{"kind":"text","text":": see the next preceding paragraph, in four places."}],"source_refs":[]},{"entry_id":"n30554","headword_ar":"عَمَقٌ","root":"Emq","body":[{"kind":"italic_en","text":"A right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due."},{"kind":"text","text":"(ISh, O, K.) So in the saying,"},{"kind":"arabic","text_bw":"fiY h`*ihi Ald~aAri EamaqN","text_ar":"فِى هٰذِهِ الدَّارِ عَمَقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In this house is a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due,"},{"kind":"text","text":"pertaining to some one]: (ISh, O:) and"},{"kind":"arabic","text_bw":"lahu fiyhi EamaqN","text_ar":"لَهُ فِيهِ عَمَقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There pertains to him, in it, a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due"},{"kind":"text","text":"]. (K.)"}],"source_refs":["ISh","O"]},{"entry_id":"n30555","headword_ar":"عَمِقٌ","root":"Emq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamiyqN","text_ar":"عَمِيقٌ"},{"kind":"text","text":", and the verse cited above."}],"source_refs":[]},{"entry_id":"n30556","headword_ar":"عُمُقٌ","root":"Emq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamoqN","text_ar":"عَمْقٌ"},{"kind":"text","text":", first sentence. ―         -b2-  [And see"},{"kind":"arabic","text_bw":"EamiyqN","text_ar":"عَمِيقٌ"},{"kind":"text","text":".]"}],"source_refs":[]}]},"classical_definitions":null}