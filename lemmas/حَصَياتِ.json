{"lemma":"حَصَياتِ","slug":"حَصَياتِ","root":"ح.ص.#","root_slug":"ح-ص-_","root_link":"/words/roots/ح-ص-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n8285"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B5%D9%8E%D9%8A%D8%A7%D8%AA%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"pebble, shingle"},{"pos":"noun","gloss":"calculus (in the body)"}]},"etymology":{"source":"wiktextract","text":"Singulative noun composed of حَصًى (ḥaṣan, “gravel, pebbles”) + ـَة (-a)."},"ipa":["/ħa.sˤaːh/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8285","headword_ar":"حَصَاةٌ","root":"HSw and HSY","body":[{"kind":"text","text":"n. un. of"},{"kind":"arabic","text_bw":"HaSFY","text_ar":"حَصًى"},{"kind":"text","text":"[q. v.]. (S, Msb, K.) ―         -b2-  Also ["},{"kind":"italic_en","text":"A stone in the bladder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kidneys:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a hardening of the urine in the bladder so that it becomes like a pebble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small stone."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"HaSaApu misokK","text_ar":"حَصَاةُ مِسْكٍ"},{"kind":"italic_en","text":"A hard piece that is found in the vesicle of musk:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"any piece of musk."},{"kind":"text","text":"(Lth, TA.)       -A2-"},{"kind":"italic_en","text":"Intelligence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding,"},{"kind":"text","text":"(S, K,) and"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mental perception;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"A^aSaApN","text_ar":"اَصَاةٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN *uw","text_ar":"فُلَانٌ ذُو"},{"kind":"arabic","text_bw":"HaSaAhK","text_ar":"حَصَاهٍ"},{"kind":"italic_en","text":"Such a one possesses intelligence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding,"},{"kind":"text","text":"(S, TA,) and"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mental perception:"},{"kind":"text","text":"(TA:) [or]"},{"kind":"italic_en","text":"is prudent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discreet,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wont to conceal his secret."},{"kind":"text","text":"(As, TA.) Or"},{"kind":"arabic","text_bw":"HaSaApN","text_ar":"حَصَاةٌ"},{"kind":"text","text":"was used by the Arabs not as meaning intelligence, or understanding; but as meaning"},{"kind":"italic_en","text":"Gravity, staidness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency."},{"kind":"text","text":"(Har p. 537.) And"},{"kind":"arabic","text_bw":"HaSaApu All~isaAni","text_ar":"حَصَاةُ اللِّسَانِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Gravity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"staidness, in respect of the tongue."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"page_break","n":588},{"kind":"text","text":"The"},{"kind":"italic_en","text":"act of numbering, counting, calculating, reckoning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"computing:"},{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"AlA_iHoSaA='u","text_ar":"الاـِحْصَا=ءُ"},{"kind":"text","text":". (Az, IB, TA.)"}],"source_refs":["S","TA","K"]}]},"classical_definitions":null}