كُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَشْكُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَشْكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْكُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْك","in_corpus":true,"count":48,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَشْكُو","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُشْكَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْك","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَشْكُو","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُشْكَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْكُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْكُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْكُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْكُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْكُوْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَشْك","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْك","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشْكُو","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْكُو","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شَكَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَكَوْتُ","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْكَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْكَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":164,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n22873"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%83%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to complain"}]},"etymology":null,"ipa":["/ʃa.kaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22873","headword_ar":"شَكَا","root":"$kw and $kY","body":[{"kind":"text","text":", (K,) first pers."},{"kind":"arabic","text_bw":"$akawotu","text_ar":"شَكَوْتُ"},{"kind":"text","text":", (S, Msb,) of which"},{"kind":"arabic","text_bw":"$akayotu","text_ar":"شَكَيْتُ"},{"kind":"text","text":"is a dial. var., (K in art."},{"kind":"arabic","text_bw":"$kY","text_ar":"شكى"},{"kind":"text","text":",) aor."},{"kind":"text","text":", (S, Msb,) [and of the latter"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"$akowN","text_ar":"شَكْوٌ"},{"kind":"text","text":", (S, Msb,) or"},{"kind":"arabic","text_bw":"$akowaY","text_ar":"شَكْوَى"},{"kind":"text","text":", (K,) or this is a simple subst., (S, Msb,) also pronounced"},{"kind":"arabic","text_bw":"$akowFY","text_ar":"شَكْوًى"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"$ikaAyapN","text_ar":"شِكَايَةٌ"},{"kind":"text","text":", (S, K,) with kesr, (K,) in which the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is [said to be] substituted for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"because most inf. ns. of the measure"},{"kind":"arabic","text_bw":"fiEaAlapN","text_ar":"فِعَالَةٌ"},{"kind":"text","text":"of verbs ending with an infirm radical letter are of verbs of which that letter is"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", (TA,) or this also is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"$akaApN","text_ar":"شَكَاةٌ"},{"kind":"text","text":", (S, K,) or this too is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"$akaAwapN","text_ar":"شَكَاوَةٌ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"$akiy~apN","text_ar":"شَكِيَّةٌ"},{"kind":"text","text":", (S, K,) is a trans. verb; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"t$k~Y","text_ar":"تشكّى","orth_type":"arrow"},{"kind":"text","text":": (K:) one says,"},{"kind":"arabic","text_bw":"$akaA A^amorahu A_ilaY A@ll~`hi","text_ar":"شَكَا اَمْرَهُ اـِلَى ا@للّٰهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"A$tkY A^amorahu","text_ar":"اشتكى اَمْرَهُ"},{"kind":"text","text":"], and ↓"},{"kind":"arabic","text_bw":"t$k~Y","text_ar":"تشكّى","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"t$k~Y A^amorahu","text_ar":"تشكّى اَمْرَهُ"},{"kind":"text","text":"], (K, TA,) meaning ["},{"kind":"italic_en","text":"He complained of his case to God;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he told to God the weakness of his condition:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"$akawotu fulaAnFA","text_ar":"شَكَوْتُ فُلَانًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ai$otakayotuhu","text_ar":"اِشْتَكَيْتُهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I complained to such a one of his conduct to me"},{"kind":"text","text":"]; (S;) [or]"},{"kind":"arabic","text_bw":"$akaA fulaAnFA","text_ar":"شَكَا فُلَانًا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he told such a one of his evil conduct to him:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"$akaA fulaAnFA","text_ar":"شَكَا فُلَانًا"},{"kind":"arabic","text_bw":"A_ilaY fulaAnK","text_ar":"اـِلَى فُلَانٍ"},{"kind":"italic_en","text":"He complained of such a one to such a one:"},{"kind":"text","text":"(MA:) [and"},{"kind":"arabic","text_bw":"$akawotu A_ilayohi ka*aA","text_ar":"شَكَوْتُ اـِلَيْهِ كَذَا"},{"kind":"italic_en","text":"I complained to him of such a thing:"},{"kind":"text","text":"] see 4: and [in like manner]"},{"kind":"arabic","text_bw":"A_ilayohi ka*aA","text_ar":"اـِلَيْهِ كَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى","orth_type":"arrow"},{"kind":"italic_en","text":"He complained to him of such a thing:"},{"kind":"text","text":"(MA:) and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ai$otakayotu","text_ar":"اِشْتَكَيْتُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I complained of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"$akawotuhu","text_ar":"شَكَوْتُهُ"},{"kind":"text","text":"]: (Msb:) Er-Rághib says,"},{"kind":"arabic","text_bw":"Al$ikaAyapu","text_ar":"الشِكَايَةُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"The showing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revealing, of grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow;"},{"kind":"text","text":"whence the saying in the Kur [xii. 86],"},{"kind":"arabic","text_bw":"A_in~amaA A^a$okuw bav~iY waHuzoniY A_ilaY A@ll~`hi","text_ar":"اـِنَّمَا اَشْكُو بَثِّى وَحُزْنِى اـِلَى ا@للّٰهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I only show my grief and my lamentation to God"},{"kind":"text","text":"]; and in the same [lviii. 1],"},{"kind":"arabic","text_bw":"A_ilaY A@ll~`hi","text_ar":"اـِلَى ا@للّٰهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wata$otakiY","text_ar":"وَتَشْتَكِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And showeth her grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow, to God"},{"kind":"text","text":"]; the primary signification of"},{"kind":"arabic","text_bw":"Al$~akowu","text_ar":"الشَّكْوُ"},{"kind":"text","text":"being"},{"kind":"italic_en","text":"the opening of the small skin for water or milk called"},{"kind":"arabic","text_bw":"$akowap","text_ar":"شَكْوَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"and showing what is in it;"},{"kind":"text","text":"so that it is as though originally metaphorical [though what is termed"},{"kind":"arabic","text_bw":"HaqiyqapN Eurofiy~apN","text_ar":"حَقِيقَةٌ عُرْفِيَّةٌ"},{"kind":"text","text":"(expl. in art."},{"kind":"arabic","text_bw":"Hq","text_ar":"حق"},{"kind":"text","text":")]; like the phrases"},{"kind":"arabic","text_bw":"bavavotu lahu maA fiY wiEaAy^iY","text_ar":"بَثَثْتُ لَهُ مَا فِى وِعَايِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafaDotu lahu maA fiY jiraAbiY","text_ar":"نَفَضْتُ لَهُ مَا فِى جِرَابِى"},{"kind":"text","text":", meaning “ I showed him what was in my heart. ” (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"$akaA","text_ar":"شَكَا"},{"kind":"text","text":"is also said of a camel as meaning"},{"kind":"italic_en","text":"He stretched out his neck, and made much moaning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prolonged utterance of a complaining voice, being fatigued by journeying."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$akaAhu","text_ar":"شَكَاهُ"},{"kind":"text","text":", (MA, K, TA,) inf. n."},{"kind":"arabic","text_bw":"$akowN","text_ar":"شَكْوٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$akaApN","text_ar":"شَكَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$akowaY","text_ar":"شَكْوَى"},{"kind":"text","text":", (MA, TA,) is said in relation to a disease, or sickness; (MA, K, TA;) meaning"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a diseased, or sick, person)"},{"kind":"italic_en","text":"complained of it,"},{"kind":"text","text":"namely, his disease, or sickness; (MA; [accord. to the TK, followed in this case, as in many others, by Freytag, it means"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(i. e. disease, or sickness,)"},{"kind":"italic_en","text":"afflicted him;"},{"kind":"text","text":"which I think to be indubitably a mistake;]) and ↓"},{"kind":"arabic","text_bw":"t$k~Y","text_ar":"تشكّى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى","orth_type":"arrow"},{"kind":"text","text":"signify the same [as"},{"kind":"arabic","text_bw":"$akaA maraDahu","text_ar":"شَكَا مَرَضَهُ"},{"kind":"italic_en","text":"he complained of his disease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sickness"},{"kind":"text","text":"]: (TA:) [or] these two verbs ("},{"kind":"arabic","text_bw":"t$k~Y","text_ar":"تشكّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى"},{"kind":"text","text":") signify [or signify also]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, diseased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sick."},{"kind":"text","text":"(TA in additions at the end of this art.) One says also, ↓"},{"kind":"arabic","text_bw":"A$tkY","text_ar":"اشتكى","orth_type":"arrow"},{"kind":"arabic","text_bw":"EuDowFA mino A^aEoDaAy^ihi","text_ar":"عُضْوًا مِنْ اَعْضَايِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"t$k~Y","text_ar":"تشكّى","orth_type":"arrow"},{"kind":"text","text":", both meaning the same [i. e., originally,"},{"kind":"italic_en","text":"He complained of"},{"kind":"text","text":"a pain, or disease, in"},{"kind":"italic_en","text":"some one of his members;"},{"kind":"text","text":"but generally meaning"},{"kind":"italic_en","text":"he had a complaint of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disease in, some one of his members;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$akaA EuDowFA","text_ar":"شَكَا عُضْوًا"},{"kind":"text","text":"not unfrequently occurs used in the same sense]: (S:) [thus one often says of a brute; for ex.,] As says, in explaining"},{"kind":"arabic","text_bw":"AlqulaAbu","text_ar":"القُلَابُ"},{"kind":"text","text":"as meaning “ a certain disease that attacks the camel, ”"},{"kind":"arabic","text_bw":"minohu qalobahu","text_ar":"مِنْهُ قَلْبَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ya$otakiY","text_ar":"يَشْتَكِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he has a pain in consequence thereof in his heart;"},{"kind":"text","text":"in which"},{"kind":"arabic","text_bw":"qalobahu","text_ar":"قَلْبَهُ"},{"kind":"text","text":", though determinate, may be considered as an explicative, like"},{"kind":"arabic","text_bw":"baTonahu","text_ar":"بَطْنَهُ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"A^alima baTonahu","text_ar":"اَلِمَ بَطْنَهُ"},{"kind":"text","text":", q. v.]. (S in art."},{"kind":"arabic","text_bw":"qlb","text_ar":"قلب"},{"kind":"text","text":".) ―         -b4-  One says also,"},{"kind":"arabic","text_bw":"huwa yu$okaY bika*aA","text_ar":"هُوَ يُشْكَى بِكَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He is accused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspected, of such a thing;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"yut~ahamu bihi","text_ar":"يُتَّهَمُ بِهِ"},{"kind":"text","text":": (K: [there mentioned as though it were from"},{"kind":"arabic","text_bw":"A^u$okiYa","text_ar":"اُشْكِىَ"},{"kind":"text","text":", and held to be so by the author of the TK; but it is from"},{"kind":"arabic","text_bw":"$ukiYa","text_ar":"شُكِىَ"},{"kind":"text","text":"; as though meaning"},{"kind":"italic_en","text":"he is complained of by reason of such a thing:"},{"kind":"text","text":"]) mentioned by Yaakoob, in the “ Alfádh. ” (TA.)       -A2-"},{"kind":"arabic","text_bw":"$kY fulaAnN","text_ar":"شكى فُلَانٌ"},{"kind":"text","text":"[thus in my original, app."},{"kind":"arabic","text_bw":"$akaA","text_ar":"شَكَا"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"$akaY","text_ar":"شَكَى"},{"kind":"text","text":",] is mentioned by Az as meaning"},{"kind":"italic_en","text":"The nails of such a one became split in several,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, places."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","S","Msb","TA","MA"]}]}}