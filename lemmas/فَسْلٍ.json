xt_ar":"فُسْلٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"fusalA='u","text_ar":"فُسَلا=ءُ"},{"kind":"text","text":", (S, M, O, K,) which last is anomalous, as though they imagined it to have as its sing."},{"kind":"arabic","text_bw":"fasiylN","text_ar":"فَسِيلٌ"},{"kind":"text","text":". (M.) ―         -b2-  Also, the former, Anything"},{"kind":"italic_en","text":"bad, corrupt, vile, base, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproved."},{"kind":"text","text":"(TA.) [The pl.]"},{"kind":"arabic","text_bw":"fusuwlN","text_ar":"فُسُولٌ"},{"kind":"text","text":", applied to dirhems, or pieces of money, means"},{"kind":"italic_en","text":"Bad;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as are termed"},{"kind":"arabic","text_bw":"zuyuwf","text_ar":"زُيُوف"},{"kind":"text","text":". (TA.)       -A2-  And"},{"kind":"arabic","text_bw":"fasolN","text_ar":"فَسْلٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"Cuttings from grape-vines, for planting."},{"kind":"text","text":"(AHn, M, K. *)"}],"source_refs":["S","M","O","Msb","K","TA","Kr"]},{"entry_id":"n33884","headword_ar":"فِسْلٌ","root":"fsl","body":[{"kind":"italic_en","text":"Foolish, stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound in intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding."},{"kind":"text","text":"(AA, O, K.)"}],"source_refs":[]}]},"classical_definitions":null}