_in_corpus":30,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":22},"lanes":{"found":true,"entry_ids":["n7924"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B3%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to freeze","tags":["transitive"]},{"pos":"verb","gloss":"to annihilate","tags":["obsolete"]},{"pos":"verb","gloss":"to curry (to use a currycomb on a horse)"},{"pos":"noun","gloss":"verbal noun of حَسَّ (ḥassa, “to freeze, curry a horse”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"freezing"},{"pos":"noun","gloss":"currying of a horse"},{"pos":"verb","gloss":"to be moved with compassion"},{"pos":"verb","gloss":"to be moved with compassion"},{"pos":"verb","gloss":"to feel"},{"pos":"verb","gloss":"to have sensation, perceive by the senses"},{"pos":"verb","gloss":"to listen"},{"pos":"verb","gloss":"to notice, know, understand"},{"pos":"verb","gloss":"to know for certain"},{"pos":"verb","gloss":"to awaken (intransitive, modern)"},{"pos":"noun","gloss":"verbal noun of حَسَّ (ḥassa, “to feel, be moved with compassion”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"feeling"},{"pos":"noun","gloss":"being moved with compassion"},{"pos":"noun","gloss":"perception, sensation"},{"pos":"noun","gloss":"instinct"},{"pos":"noun","gloss":"compassion"},{"pos":"noun","gloss":"low sound"},{"pos":"noun","gloss":"voice"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew חָשׁ (ḥaš)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7924","headword_ar":"حِسٌّ","root":"Hs","body":[{"kind":"text","text":"[accord. to some, a subst. from 1, q. v., in several senses explained above; but accord. to others, an inf. n. As a simple subst., it is often used as syn. with"},{"kind":"arabic","text_bw":"HaAs~apN","text_ar":"حَاسَّةٌ"},{"kind":"text","text":"in the first of the senses assigned to the latter below; i. e.,"},{"kind":"italic_en","text":"A sense; a faculty of sense;"},{"kind":"text","text":"as, for instance, in the K in art."},{"kind":"arabic","text_bw":"smE","text_ar":"سمع"},{"kind":"text","text":". ―         -b2-  Hence"},{"kind":"arabic","text_bw":"AlHis~u Almu$otaraku","text_ar":"الحِسُّ المُشْتَرَكُ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"$rk","text_ar":"شرك"},{"kind":"text","text":"].       -A2-"},{"kind":"italic_en","text":"A sound:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, sound;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HasiysN","text_ar":"حَسِيسٌ","orth_type":"arrow"},{"kind":"text","text":": (S, Mgh, Msb, TA:) [in the present day it often signifies the"},{"kind":"italic_en","text":"voice"},{"kind":"text","text":"of a man or woman; and particularly"},{"kind":"italic_en","text":"when soft:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a plaintive voice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, in singing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weeping,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"such as that of a lute;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ran~ahN","text_ar":"رَنَّهٌ"},{"kind":"text","text":": (TA:) or ↓"},{"kind":"arabic","text_bw":"HasiysN","text_ar":"حَسِيسٌ","orth_type":"arrow"},{"kind":"text","text":", [or both,] the"},{"kind":"italic_en","text":"sound by which a thing is perceived:"},{"kind":"text","text":"(Bd in xxi. 102:) and the former,"},{"kind":"italic_en","text":"motion:"},{"kind":"text","text":"(K:) and the"},{"kind":"italic_en","text":"passing"},{"kind":"text","text":"of anything"},{"kind":"italic_en","text":"near by one, so that he hears it without seeing it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HasiysN","text_ar":"حَسِيسٌ","orth_type":"arrow"},{"kind":"text","text":". (K TA.) It is said in the Kur [xxi. 102], ↓"},{"kind":"arabic","text_bw":"laA yasomaEuwna HasiysahaA","text_ar":"لَا يَسْمَعُونَ حَسِيسَهَا","orth_type":"arrow"},{"kind":"italic_en","text":"They shall not hear its low sound:"},{"kind":"text","text":"(S:) [meaning, that of hellfire:] or"},{"kind":"italic_en","text":"the sound by which it shall be perceived:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"the motion of its flaming."},{"kind":"text","text":"(TA.) And in a trad.,"},{"kind":"arabic","text_bw":"fasamiEa His~a Hay~apK","text_ar":"فَسَمِعَ حِسَّ حَيَّةٍ"},{"kind":"italic_en","text":"And he heard the motion,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the sound of the passing along, of a serpent."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"maA samiEa lahu His~FA walaA","text_ar":"مَا سَمِعَ لَهُ حِسًّا وَلَا"},{"kind":"arabic","text_bw":"jirosFA","text_ar":"جِرْسًا"},{"kind":"italic_en","text":"He heard not any motion, nor any sound, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.) It may refer to a man and to other things; as, for instance, wind. (TA.)       -A3-"},{"kind":"italic_en","text":"A pain which attacks a woman after childbirth,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"in the womb:"},{"kind":"text","text":"(A:) or the"},{"kind":"italic_en","text":"pain of childbirth, when the latter is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"first"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"felt:"},{"kind":"text","text":"but the former meaning is confirmed by a trad. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"H$s~u AlHum~aY","text_ar":"حشسُّ الحُمَّى"},{"kind":"italic_en","text":"The commencement of fever, when the latter is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"first"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"felt;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"HisaAsuhaA","text_ar":"حِسَاسُهَا","orth_type":"arrow"},{"kind":"text","text":": (Lh, TA:) or"},{"kind":"arabic","text_bw":"His~N","text_ar":"حِسٌّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a touch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slight affection,"},{"kind":"text","text":"of fever,"},{"kind":"italic_en","text":"at its very commencement."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"italic_en","text":"Cold that nips, shrinks, shrivels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blasts,"},{"kind":"text","text":"(lit.,"},{"kind":"italic_en","text":"burns,"},{"kind":"arabic","text_bw":"yuHorqu","text_ar":"يُحْرقُ"},{"kind":"text","text":", for which, in the TA, is substituted"},{"kind":"arabic","text_bw":"yaqoTaEu","text_ar":"يَقْطَعُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"the herbage."},{"kind":"text","text":"(S, K.) [See also"},{"kind":"arabic","text_bw":"HaAs~apN","text_ar":"حَاسَّةٌ"},{"kind":"text","text":".]"}],"source_refs":["K","S","Mgh","Msb","TA","Bd","A","Lh"]}]}}