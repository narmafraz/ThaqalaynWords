nslations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"tombstone"},{"pos":"noun","gloss":"grave","examples":[{"text":"أُطْلُبُوا ٱلْعِلْمَ مِنَ ٱلْمَهْدِ إلَى ٱللَّحْدِ","english":"Seek ye knowledge from the cradle onto the grave."}]}]},"etymology":null,"ipa":["/laħd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37614","headword_ar":"لَحَدَ","root":"lHd","body":[{"kind":"text","text":"(A) and ↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":"(L, K) (tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(as an arrow, A)"},{"kind":"italic_en","text":"declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviated, from the right course:"},{"kind":"text","text":"(A, L, K:) and also"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined:"},{"kind":"text","text":"you say"},{"kind":"arabic","text_bw":"laHada A_ilayohi","text_ar":"لَحَدَ اـِلَيْهِ"},{"kind":"text","text":", (A, L, K,) aor."},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":"(A;) and ↓"},{"kind":"arabic","text_bw":"AltHd","text_ar":"التحد","orth_type":"arrow"},{"kind":"text","text":"; (S, L, K;)"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(A, L, K.) Some read, [in the Kur xvi. 105,]"},{"kind":"arabic","text_bw":"lisaAnu A@l~a*iY","text_ar":"لِسَانُ ا@لَّذِى"},{"kind":"arabic","text_bw":"yaloHaduwna A_ilayohi","text_ar":"يَلْحَدُونَ اـِلَيْهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The tongue of him unto whom they incline"},{"kind":"text","text":"]. (S.) ―         -b2-"},{"kind":"arabic","text_bw":"fiY Ald~iyni","text_ar":"فِى الدِّينِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":"; (S, A, L, Msb;) and"},{"kind":"arabic","text_bw":"laHada fiyhi","text_ar":"لَحَدَ فِيهِ"},{"kind":"text","text":", (S, L, Msb,) aor."},{"kind":"text","text":"; (L;) (tropical:)"},{"kind":"italic_en","text":"He deviated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swerved, from the right way, with respect to religion:"},{"kind":"text","text":"(S, A, L:)"},{"kind":"italic_en","text":"he impugned religion."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"fiY AlHarami","text_ar":"فِى الحَرَمِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsook, the right course, with respect to that which he was commanded to do, in the sacred Temple"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"territory of Mekkeh;"},{"kind":"text","text":"(L, K;)"},{"kind":"italic_en","text":"and inclined to do wrong, wrongfully, unjustly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"injuriously:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he did wrong, wrongfully, unjustly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"injuriously, therein;"},{"kind":"text","text":"(S, L, K;)"},{"kind":"italic_en","text":"and so opposed others:"},{"kind":"text","text":"(Fr, L:) or"},{"kind":"italic_en","text":"he associated others with God, therein;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"A^a$oraka biAll~`hi","text_ar":"اَشْرَكَ بِاللّٰهِ"},{"kind":"text","text":": so in the K and Basáïr; in the latter as on the authority of Zj: or"},{"kind":"italic_en","text":"he doubted respecting God, therein:"},{"kind":"text","text":"so in the L and other lexicons, as on the authority of Zj: (TA:) or"},{"kind":"italic_en","text":"he hoarded up corn in expectation of its becoming dear, therein;"},{"kind":"text","text":"(L, K;) a meaning taken from a trad of 'Omar; (L;) but this is merely a kind of wrong-doing: (TA:) or"},{"kind":"italic_en","text":"he desecrated it, and violated its sanctity."},{"kind":"text","text":"(Msb.) The origin of the phrase is in the text of the Kur [xx. 26,]"},{"kind":"arabic","text_bw":"wamano yurido fiyhi","text_ar":"وَمَنْ يُرِدْ فِيهِ"},{"kind":"arabic","text_bw":"biA_iloHaAdK biZulomK","text_ar":"بِاـِلْحَادٍ بِظُلْمٍ"},{"kind":"text","text":", i.e."},{"kind":"arabic","text_bw":"A_iloHaAdFA biZulomK","text_ar":"اـِلْحَادًا بِظُلْمٍ"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"being redundant. (S, L.)       -A2-"},{"kind":"arabic","text_bw":"laHada Alqabora","text_ar":"لَحَدَ القَبْرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"laHodN","text_ar":"لَحْدٌ"},{"kind":"text","text":"; L,) and ↓"},{"kind":"arabic","text_bw":"AlHdhu","text_ar":"الحدهُ","orth_type":"arrow"},{"kind":"text","text":"; (A, L, K;) and"},{"kind":"arabic","text_bw":"laHada","text_ar":"لَحَدَ"},{"kind":"arabic","text_bw":"lahu laHodFA","text_ar":"لَهُ لَحْدًا"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"He made a"},{"kind":"arabic","text_bw":"laHod","text_ar":"لَحْد"},{"kind":"italic_en","text":"to the grave."},{"kind":"text","text":"(S, A, L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"laHada A@lomay~ita","text_ar":"لَحَدَ ا@لْمَيِّتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"laHodN","text_ar":"لَحْدٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AlHdhu","text_ar":"الحدهُ","orth_type":"arrow"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"laHada lahu","text_ar":"لَحَدَ لَهُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He made a"},{"kind":"arabic","text_bw":"laHod","text_ar":"لَحْد"},{"kind":"italic_en","text":"for the corpse:"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"AlHdhu","text_ar":"الحدهُ","orth_type":"arrow"},{"kind":"text","text":"has this signification; (L;) and in like manner,"},{"kind":"arabic","text_bw":"laHada lah laHodFA","text_ar":"لَحَدَ لَه لَحْدًا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlHd","text_ar":"الحد","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he dug a"},{"kind":"arabic","text_bw":"laHod","text_ar":"لَحْد"},{"kind":"italic_en","text":"for him:"},{"kind":"text","text":"(A, Mgh, Msb:) and"},{"kind":"arabic","text_bw":"laHadahu","text_ar":"لَحَدَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he buried him;"},{"kind":"text","text":"(L, K;) or"},{"kind":"italic_en","text":"put him into a"},{"kind":"arabic","text_bw":"lHd","text_ar":"لحد"},{"kind":"text","text":"; and so ↓"},{"kind":"arabic","text_bw":"AlHdhu","text_ar":"الحدهُ","orth_type":"arrow"},{"kind":"text","text":". (Mgh, Msb.)"}],"source_refs":["A","L","K","S","Msb","Fr","TA","Mgh"]}]}}