n":"f","num":"s"},{"role":"present_3fs","form":"تَشْجِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَشْجُج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشُجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشُجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشِجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشِجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشُجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشُجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشِجّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشِجّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشُجُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشُجُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِجُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِجُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْجِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَشْجُجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَشُجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشُجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شَجَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَجَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n21792"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"grieving, lamenting, mourning, sad, unhappy"},{"pos":"verb","gloss":"to break up, to cleave"},{"pos":"verb","gloss":"to dilute with water","tags":["obsolete"],"examples":[{"text":"وَمَهًا يَرِفُّ كَأَنَّهُ إِذْ ذُقْتَهُ … عَانِيَّةٌ شُجَّتْ بِمَاءِ يَرَاعِ","english":"An essence, which when tried, tastes like wine of ʿānah diluted with sump water"},{"text":"القبج بالفارسية هو الحجل عنه ومن كتاب أهرن وفي اللغة: القبج ذكر الحجل، قال الصنوبري\nيٰأخِي قُمْ فَقَدْ شَجَجْنا لَكَ الرَّاحَ … فَخُذْها مَشْجُوجَةً أيّ شَجّ\nقَطَعَ المَاءُ جِسْمَها قِطَعًا لَمْ … تَغْذِ أَمْثالَها مَناقِيرُ قَبْج","english":"Al-qabj is Persian for partridge ibidem [in ar-Rāzī’s Ḥāwī]. From ʾAhrun’s book and the lexicographers: It is the male partridge. Aṣ-Ṣanawbarīy said:\n O brother, get up! We have mixed wine for you.\n Take it in a mixed state in whichever fashion!\n The water has stripped down its substance into bits,\n of size smaller than partridge beaks eat."}]}]},"etymology":null,"ipa":["/ʃa.d͡ʒin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21792","headword_ar":"شَجٍ","root":"$jw","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Grieving, mourning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lamenting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrowing, sad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unhappy;"},{"kind":"text","text":"applied to a man; (S, Msb;) and"},{"kind":"arabic","text_bw":"$ajiyapN","text_ar":"شَجِيَةٌ"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"faEilapN","text_ar":"فَعِلَةٌ"},{"kind":"text","text":", applied to a woman: one says,"},{"kind":"arabic","text_bw":"wayolN lil$~ajiY mina","text_ar":"وَيْلٌ لِلشَّجِى مِنَ"},{"kind":"arabic","text_bw":"AlxaliY~i","text_ar":"الخَلِىِّ"},{"kind":"text","text":"[mentioned and expl. voce"},{"kind":"arabic","text_bw":"xaAlK","text_ar":"خَالٍ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"xlw","text_ar":"خلو"},{"kind":"text","text":", where each of these epithets is written with teshdeed to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; and likewise in another saying there mentioned]: (S:) or, in this saying, (TA,) it signifies"},{"kind":"italic_en","text":"occupied"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by anxiety"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief"},{"kind":"text","text":"]; (K, TA; [in the CK,"},{"kind":"arabic","text_bw":"Al$~ajA","text_ar":"الشَّجا"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":";]) and"},{"kind":"arabic","text_bw":"xaliY~","text_ar":"خَلِىّ"},{"kind":"text","text":"means “ free [therefrom]: ” so says AZ: and in this instance"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":"may mean"},{"kind":"italic_en","text":"occupied by a bone choking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructing, his throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by anxiety, and not having found a way of escape therefrom;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by his opponent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversary, whom he has been unable to withstand:"},{"kind":"text","text":"(TA:) and sometimes one says ↓"},{"kind":"arabic","text_bw":"$ajiY~N","text_ar":"شَجِىٌّ","orth_type":"arrow"},{"kind":"text","text":", like as one says"},{"kind":"arabic","text_bw":"HazinN","text_ar":"حَزِنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaziynN","text_ar":"حَزِينٌ"},{"kind":"text","text":"; though this is rare; (Msb;) it is mentioned in the 'Eyn; but"},{"kind":"arabic","text_bw":"$ajK","text_ar":"شَجٍ"},{"kind":"text","text":"is more known; and is said by Az to be the chaste form: (TA:) Mbr says, the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"AlxlY","text_ar":"الخلى"},{"kind":"text","text":"is with teshdeed, and the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":"is without teshdeed, (S,) and sometimes this"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is with teshdeed in poetry; (S, K;) but if you make it to be from"},{"kind":"arabic","text_bw":"$ajaAhu","text_ar":"شَجَاهُ"},{"kind":"text","text":", it is ↓"},{"kind":"arabic","text_bw":"$ajiY~N","text_ar":"شَجِىٌّ","orth_type":"arrow"},{"kind":"text","text":"only, syn. with"},{"kind":"arabic","text_bw":"ma$ojuw~N","text_ar":"مَشْجُوٌّ"},{"kind":"text","text":". [i. e."},{"kind":"italic_en","text":"grieved,"},{"kind":"text","text":"&c.]; (S;) and so it is said to be by Az and Z: and Az adds, the second way of accounting for it is, that they often lengthen"},{"kind":"arabic","text_bw":"faEilN","text_ar":"فَعِلٌ"},{"kind":"text","text":"with a"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", saying,"},{"kind":"arabic","text_bw":"fulaAnN qaminN","text_ar":"فُلَانٌ قَمِنٌ"},{"kind":"arabic","text_bw":"lika*aA","text_ar":"لِكَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qamiynN","text_ar":"قَمِينٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"samijN","text_ar":"سَمِجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samiyjN","text_ar":"سَمِيجٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"karK","text_ar":"كَرٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kariY~N","text_ar":"كَرِىٌّ"},{"kind":"text","text":": and the third way is, that they assimilated one word in measure to another, as in"},{"kind":"arabic","text_bw":"AlgadaAyaA","text_ar":"الغَدَايَا"},{"kind":"arabic","text_bw":"waAlEa$aAyaA","text_ar":"وَالعَشَايَا"},{"kind":"text","text":", the [proper] pl. of"},{"kind":"arabic","text_bw":"gadaApN","text_ar":"غَدَاةٌ"},{"kind":"text","text":"being only"},{"kind":"arabic","text_bw":"gadawaAtN","text_ar":"غَدَوَاتٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B4%D8%AC/","headword_ar":"شج","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=75167#f03e65","body_html":"<h3>شج</h3><span class=\"sense\">1</span> شَجَّهُ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ and شَجِّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) the former <abbr title=\"regular\">reg.</abbr>, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) [the latter <abbr title=\"irregular\">irreg.</abbr>,] <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> شَجٌّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) He broke it, [so as to cleave its skin or its flesh,] namely, another's head: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or he clave his skin of the face or of the head; or he clave its skin, i. e. the skin of the face or of the head: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) originally he struck it, namely, the head, so as to wound it and cleave it [in the skin or flesh thereof]; and then used in relation to other members: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or شَجَّهُ فِى رَأْسِهِ and فِى وَجْهِهِ [he wounded him so as to cleave the skin or the flesh in his head and in his face]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <abbr title=\"according\">Accord.</abbr> to some, [<abbr title=\"contrary\">contr.</abbr> to the authority of the <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,] it is from شَجَّتِ السَّفِينَةُ البّحْرَ [<abbr title=\"explained\">expl.</abbr> below]. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b2:</span> [Hence,] it is said in a <abbr title=\"proverb, مَثَلٌ\">prov.</abbr>, فُلَانٌ يَشُجُّ بِيَدٍ وَيَأْسُو بِأُخْرَى [Such a one breaks a head with one hand and cures with another]; meaning (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) such a one corrupts, or mars, one time, and rectifies, or repairs, another time. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) and زَيْدٌ يَشُجُّ مَرَّةً وَيَأْسُو مَرَّةً (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Zeyd does, or says, wrong one time, and right one time. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> And شَجَّتِ السَّفِينَةُ البَحْرَ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The ship clave the sea: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) and [in like manner] شَجَّ البَحْرَ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) he clave the sea; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) said of a swimmer. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And شَجَّ المَفَازَةَ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He traversed the desert. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) And شَجَّ الأَرْضَ بِرَاحِلَتِهِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He traversed the land, with his camel that he rode, at a vehement rate. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b4:</span> And شَجَّ الشَّرَابَ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) or شَجَّ الخَمْرَ بِالمَآء, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ and شَجِّ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> شَجٌّ, [as above,] (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He mixed the beverage, or the wine, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) with water. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) Hence, فَكَانَ يَشُِجُّ عَلَىَّ مِسْكًا, occurring in a <abbr title=\"tradition (hadith), حَدِيْثٌ\">trad.</abbr>, means (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) And it was as though it mixed with her odour of musk the breath of wind that reached my organ of smell. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 2 تَشْجِيجٌ [The breaking of another's head much, so as to cleave the skin or the flesh: or the breaking of heads so as to cleave the skin or the flesh. <span class=\"sub-sense\">b2:</span> And hence, perhaps,] (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The acting with penetrative energy, vigour, or effectiveness; <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr> تَصْمِيمٌ. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 3 بَيْنَهُمْ شِجَاجٌ (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and ↓ تَشَاجٌّ (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) Between them is a mutual breaking of heads. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>. [In the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr>, شَجَاجٌ is erroneously put for شِجَاجٌ.]) 6 تَشَاْجَّ see what next precedes.<br><br>شَجَّةٌ A single act of breaking of one's head [so as to cleave its skin or its flesh]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> and A wound by which the head is broken (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, * <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>) so as to cleave its skin or its flesh: (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>:) and [such] a wound in the face: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, * <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> شِجَاجٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>) and شَجَّاتٌ. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) What are termed شِجَاج are of ten different kinds, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>,) distinguished by the following epithets: [1]<br><br>حَارِصَةٌ, which peels off the [external] skin, but does not bring blood: [2] دَامِيَةٌ, which brings blood: [3] بَاضِعَةٌ, [which cleaves the flesh slightly, and brings blood, but does not make it to flow: (but in art. دمغ, <abbr title=\"under the heading\">voce</abbr> دَامِغَةٌ, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>, what are here mentioned as the second and third are transposed:) 4, مُتَلَاحِمَةٌ,] which cleaves the flesh much: [5]<br><br>سِمْحَاقٌ, which leaves between it and the bone only a thin skin: these are five شجاج for which there is no retaliation nor any determinate mulct, but respecting which a judge must give his sentence: [6] مُوضِحَةٌ, which reaches to the bone, and for which the mulct is five camels: [7] هَاشِمَةٌ, which breaks the bone, and for which the mulct is ten camels: [8] مُنَقِّلَةٌ, from which bone is removed, from one place to another, and for which the mulct is fifteen camels: [9] مَأْمُومَةٌ, also called آمَّةٌ, which leaves between it and the brain only a thin skin, and for which the mulct is one third of the whole price of blood: [10] دَامِغَةٌ, which reaches the brain, and for which the mulct is also one third of the whole price of blood. (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.) The شَجَّة of 'Abd-El-Hameed, [who was the goodliest man of his age,] the son of 'Abd-Allah the son of 'Omar the son of El-Khattáb, was the subject of a <abbr title=\"proverb, مَثَلٌ\">prov.</abbr> on account of its beauty [and is said to have increased his goodliness]. (<abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr>.) شَجَجٌ The mark, or scar, of a wound by which the forehead has been broken. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) شَجَجَى The عَقْعَق [or magpie]; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>; omitted in the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr>;) [and] so ↓ شَجَوْجًى. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in art. شجو.) شَجِيجٌ and ↓ مَشْجُوجٌ A head broken [so that its skin or its flesh is cloven]: or a man having his head [so] broken: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> [of the former]<br><br>شَجَّى: you say قَوْمٌ شَجَّى. (<abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> Each is also applied as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> to a wooden peg or stake [as meaning (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Having its head broken, or mangled, by blows]: and so is ↓ مُشَجَّجٌ, but in an intensive sense. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.) <span class=\"sub-sense\">b3:</span> And both the first and ↓ last signify (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) A wooden peg or stake; (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) each as an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> in which the quality of a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr> predominates: because its head is separated, or uncompacted, in its component parts [or fibres by its being battered]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) One says, مَا بِالدَّارِ شَجِيجٌ and ↓ مُشَجَّجٌ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) There is not in the house [even] a wooden peg or stake. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) شَجَوْجًى: see شَجَجَى.<br><br>سَابِحٌ شَجَّاجٌ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) A swimmer that cleaves the water vehemently. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) أَشَجُّ A man having a mark, or scar, of a wound by which his forehead has been broken. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) مُشَجَّجٌ: see شَجِيجٌ, in three places.<br><br>مَشْجُوجٌ: see شَجِيجٌ."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=75167#7f19ef","body_html":"شج<br>الشَّجّ: كَسْرُ الرَّأْس. وبَيْنَهم شِجَاجٌ. ويُقال: شَجَّه يَشُجُّه ويَشِجُّه. والشَّجَجُ: أثَرُ شَجَّةٍ في الجَبِين، والنَّعْتُ أشَجُّ. وشَجَجْتُ المَفَازَةَ: قَطَعْتها، والشَّرَابَ بالمِزَاج. والشَّجِيْجُ: المَشْجُوْجُ. وفي المَثَل قَوْلُهم: \" يَشُجُّ مَرَّةً ويَأْسُو أُخْرى \". ويُسَمّى الوتِدُ: شَجِيْجاً. وشَجَّجَ الانسانُ: أي صَمَّمَ تَشْجِيْجاً."}]}}