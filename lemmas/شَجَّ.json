p":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِجّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شَجَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَجَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n21792"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"grieving, lamenting, mourning, sad, unhappy"},{"pos":"verb","gloss":"to break up, to cleave"},{"pos":"verb","gloss":"to dilute with water","tags":["obsolete"],"examples":[{"text":"وَمَهًا يَرِفُّ كَأَنَّهُ إِذْ ذُقْتَهُ … عَانِيَّةٌ شُجَّتْ بِمَاءِ يَرَاعِ","english":"An essence, which when tried, tastes like wine of ʿānah diluted with sump water"},{"text":"القبج بالفارسية هو الحجل عنه ومن كتاب أهرن وفي اللغة: القبج ذكر الحجل، قال الصنوبري\nيٰأخِي قُمْ فَقَدْ شَجَجْنا لَكَ الرَّاحَ … فَخُذْها مَشْجُوجَةً أيّ شَجّ\nقَطَعَ المَاءُ جِسْمَها قِطَعًا لَمْ … تَغْذِ أَمْثالَها مَناقِيرُ قَبْج","english":"Al-qabj is Persian for partridge ibidem [in ar-Rāzī’s Ḥāwī]. From ʾAhrun’s book and the lexicographers: It is the male partridge. Aṣ-Ṣanawbarīy said:\n O brother, get up! We have mixed wine for you.\n Take it in a mixed state in whichever fashion!\n The water has stripped down its substance into bits,\n of size smaller than partridge beaks eat."}]}]},"etymology":null,"ipa":["/ʃa.d͡ʒin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21792","headword_ar":"شَجٍ","root":"$jw","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Grieving, mourning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lamenting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrowing, sad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unhappy;"},{"kind":"text","text":"applied to a man; (S, Msb;) and"},{"kind":"arabic","text_bw":"$ajiyapN","text_ar":"شَجِيَةٌ"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"faEilapN","text_ar":"فَعِلَةٌ"},{"kind":"text","text":", applied to a woman: one says,"},{"kind":"arabic","text_bw":"wayolN lil$~ajiY mina","text_ar":"وَيْلٌ لِلشَّجِى مِنَ"},{"kind":"arabic","text_bw":"AlxaliY~i","text_ar":"الخَلِىِّ"},{"kind":"text","text":"[mentioned and expl. voce"},{"kind":"arabic","text_bw":"xaAlK","text_ar":"خَالٍ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"xlw","text_ar":"خلو"},{"kind":"text","text":", where each of these epithets is written with teshdeed to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; and likewise in another saying there mentioned]: (S:) or, in this saying, (TA,) it signifies"},{"kind":"italic_en","text":"occupied"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by anxiety"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief"},{"kind":"text","text":"]; (K, TA; [in the CK,"},{"kind":"arabic","text_bw":"Al$~ajA","text_ar":"الشَّجا"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":";]) and"},{"kind":"arabic","text_bw":"xaliY~","text_ar":"خَلِىّ"},{"kind":"text","text":"means “ free [therefrom]: ” so says AZ: and in this instance"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":"may mean"},{"kind":"italic_en","text":"occupied by a bone choking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructing, his throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by anxiety, and not having found a way of escape therefrom;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by his opponent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversary, whom he has been unable to withstand:"},{"kind":"text","text":"(TA:) and sometimes one says ↓"},{"kind":"arabic","text_bw":"$ajiY~N","text_ar":"شَجِىٌّ","orth_type":"arrow"},{"kind":"text","text":", like as one says"},{"kind":"arabic","text_bw":"HazinN","text_ar":"حَزِنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaziynN","text_ar":"حَزِينٌ"},{"kind":"text","text":"; though this is rare; (Msb;) it is mentioned in the 'Eyn; but"},{"kind":"arabic","text_bw":"$ajK","text_ar":"شَجٍ"},{"kind":"text","text":"is more known; and is said by Az to be the chaste form: (TA:) Mbr says, the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"AlxlY","text_ar":"الخلى"},{"kind":"text","text":"is with teshdeed, and the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"Al$~ajiY","text_ar":"الشَّجِى"},{"kind":"text","text":"is without teshdeed, (S,) and sometimes this"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is with teshdeed in poetry; (S, K;) but if you make it to be from"},{"kind":"arabic","text_bw":"$ajaAhu","text_ar":"شَجَاهُ"},{"kind":"text","text":", it is ↓"},{"kind":"arabic","text_bw":"$ajiY~N","text_ar":"شَجِىٌّ","orth_type":"arrow"},{"kind":"text","text":"only, syn. with"},{"kind":"arabic","text_bw":"ma$ojuw~N","text_ar":"مَشْجُوٌّ"},{"kind":"text","text":". [i. e."},{"kind":"italic_en","text":"grieved,"},{"kind":"text","text":"&c.]; (S;) and so it is said to be by Az and Z: and Az adds, the second way of accounting for it is, that they often lengthen"},{"kind":"arabic","text_bw":"faEilN","text_ar":"فَعِلٌ"},{"kind":"text","text":"with a"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", saying,"},{"kind":"arabic","text_bw":"fulaAnN qaminN","text_ar":"فُلَانٌ قَمِنٌ"},{"kind":"arabic","text_bw":"lika*aA","text_ar":"لِكَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qamiynN","text_ar":"قَمِينٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"samijN","text_ar":"سَمِجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samiyjN","text_ar":"سَمِيجٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"karK","text_ar":"كَرٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kariY~N","text_ar":"كَرِىٌّ"},{"kind":"text","text":": and the third way is, that they assimilated one word in measure to another, as in"},{"kind":"arabic","text_bw":"AlgadaAyaA","text_ar":"الغَدَايَا"},{"kind":"arabic","text_bw":"waAlEa$aAyaA","text_ar":"وَالعَشَايَا"},{"kind":"text","text":", the [proper] pl. of"},{"kind":"arabic","text_bw":"gadaApN","text_ar":"غَدَاةٌ"},{"kind":"text","text":"being only"},{"kind":"arabic","text_bw":"gadawaAtN","text_ar":"غَدَوَاتٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","TA"]}]}}