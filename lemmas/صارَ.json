hich are also sometimes applied to"},{"kind":"italic_en","text":"a column"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"SawaArK","text_ar":"صَوَارٍ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","M","K","TA"]},{"entry_id":"n25173","headword_ar":"صَارٌ","root":"Swr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Say~irN","text_ar":"صَيِّرٌ"},{"kind":"text","text":", below, in two places."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B5%D8%A7%D8%B1/","headword_ar":"صارا","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=107253#c9af91","body_html":"صارا<br>عن العبرية إحدى صيغ الاسم سارا بمعنى أميرة وملكة."}]}}