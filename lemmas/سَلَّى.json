","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسَلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسَلَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُسَلِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُسَلّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُسَلِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَلِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسَلَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَلَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"سَلَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَلَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":44,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n20580","n20589","","n20587"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"placenta"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew שִׁלְיָה."},"ipa":["/sa.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20580","headword_ar":"سُلَّى","root":"slw","body":[{"kind":"text","text":", [said to be] like"},{"kind":"arabic","text_bw":"rub~aY","text_ar":"رُبَّى"},{"kind":"text","text":", [but it may be"},{"kind":"arabic","text_bw":"sul~FY","text_ar":"سُلًّى"},{"kind":"text","text":", as there is no apparent cause for its being imperfectly decl.,]"},{"kind":"italic_en","text":"A quality that renders forgetful of the objects of love"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that renders content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy, without them."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"slY","text_ar":"سلى"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n20589","headword_ar":"سُلَّى","root":"slY","body":[{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"sul~FY","text_ar":"سُلًّى"},{"kind":"text","text":",] mentioned in this art. in the TA: see art."},{"kind":"arabic","text_bw":"slw","text_ar":"سلو"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n20587","headword_ar":"سَلًى","root":"slY","body":[{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"salFA","text_ar":"سَلًا"},{"kind":"text","text":"[thus differently written, the former the more correct, unless the word be derived from"},{"kind":"arabic","text_bw":"Als~alowapu","text_ar":"السَّلْوَةُ"},{"kind":"text","text":", as it is said to be in the Ham p. 656, but this is improbable,] The"},{"kind":"italic_en","text":"secundine;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"skin,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"membrane,"},{"kind":"text","text":"] (M, K,) or"},{"kind":"italic_en","text":"thin skin,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"in which is the fœtus,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the womb,"},{"kind":"text","text":"] (S, M, Msb, K,) of human beings, and of horses and camels, (M,) or of human beings and of cattle, (K,) or [peculiarly] of cattle, (T, S,) that of human beings being termed"},{"kind":"arabic","text_bw":"ma$iymapN","text_ar":"مَشِيمَةٌ"},{"kind":"text","text":": (TA:) it is pulled off from the face of the young camel at the time of the birth, or else it kills it, like as it does when it becomes disrupted in the belly: when it comes forth, the she-camel is safe, and so is the young one; but if it becomes disrupted in the belly, she perishes, and so does the young one: (S:) pl."},{"kind":"arabic","text_bw":"A^asolaA='N","text_ar":"اَسْلَا=ءٌ"},{"kind":"text","text":". (M, Msb, K.) [Hence,] one says,"},{"kind":"arabic","text_bw":"AinoqaTaEa","text_ar":"اِنْقَطَعَ"},{"kind":"arabic","text_bw":"Als~alaY fiY AlbaToni","text_ar":"السَّلَى فِى البَطْنِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The secundine became disrupted in the belly"},{"kind":"text","text":"]; (S, Meyd, K;) i. e. artifice departed [or came to an end]; (S;) a prov. applied in the case of an affair's becoming beyond one's power of accomplishment, and coming to an end; (Meyd;) like the saying,"},{"kind":"arabic","text_bw":"balaga Als~ik~iynu AlEaZoma","text_ar":"بَلَغَ السِّكِّينُ العَظْمَ"},{"kind":"text","text":"[The knife reached to the bone]. (S, K.) And"},{"kind":"arabic","text_bw":"huwa A=kilu AlA^asolaA='i","text_ar":"هُوَ ا=كِلُ الاَسْلَا=ءِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He is the eater of secundines"},{"kind":"text","text":"]; meaning he is low, base, vile, or sordid. (TA.) And"},{"kind":"arabic","text_bw":"waqaEa Alqawomu fiY salaY jamalK","text_ar":"وَقَعَ القَوْمُ فِى سَلَى جَمَلٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, fell into"},{"kind":"text","text":"the like of"},{"kind":"italic_en","text":"the secundine of a hecamel"},{"kind":"text","text":"]; meaning they fell into a difficult affair or case; (S, K *) or they fell into an unparalleled evil; (Meyd;) for the he-camel has no"},{"kind":"arabic","text_bw":"slY","text_ar":"سلى"},{"kind":"text","text":". (S, Meyd.)"}],"source_refs":["M","K","S","Msb","T","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D9%84%D9%89/","headword_ar":"سلى","entries":[{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=22308#d6fd87","body_html":"<span>(سلى) : أَسْلَى القَوْمُ: إذا أَمْنُوا السَّبُعَ.</span>"},{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=22308#456700","body_html":"<span>(سلى) : اسْتَلَت النَّاقَةُ: إذا طَرَحَتْ سَلاها.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=22308#88e788","body_html":"<h3>سل</h3>ى<span class=\"sense\">1</span> سَلِيَتٌ, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـَ (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> سَلًى, said of a ewe, or she-goat, [and of a she-camel,] Her secundine (سَلَاهَا) became disrupted [in her belly]. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">A2:</span> سَلَاهَا, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> سَلْىٌ; (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>;) or ↓ سلّاها, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَسْلِيَةٌ; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) He pulled out or off, or removed from its place, her secundine (سَلَاهَا), namely, a ewe's, or she-goat's, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or a she-camel's. (So in one of my copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) And سَلَيْتُ النَّاقَةَ I drew [forth] the she-camel's secundine (سَلَاهَا) after the bringing forth without letting it fall (بَعْدَ الرَّحَمِ or الرَّحْمِ). (<abbr title=\"El-Lihyanee (Abu al-Ḥasan al-Liḥyānī)\">Lh</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) <span class=\"sub-sense\">A3:</span> سَلَيْتُهُ a <abbr title=\"dialect, لُغَةٌ\">dial.</abbr> var. of سَلَوْتُهُ, mentioned by Esh-Shereeshee. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See 1 in art. سلو, first sentence.<span class=\"sense\">2</span> سَلَّىَ see the preceding paragraph.<span class=\"sense\">8</span> اِسْتَلَتْ She (a camel, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, [or a ewe or goat,]) cast forth her secundine (سَلَاهَا). (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> She (a ewe, or goat,) became fat. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> in art. سلو, and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in the present art.) <span class=\"sub-sense\">A2:</span> استلت سمنًا [i. e. سَمْنًا] She collected سمن [or clarified butter]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>. [See also 8 in art. سلأ.]) سَلًى or سَلًا [thus differently written, the former the more correct, unless the word be derived from السَّلْوَةُ, as it is said to be in the <abbr title=\"Sharḥ Dīwān al-Ḥamāsah by al-Tabrīzī\">Ham</abbr> p. 656, but this is improbable,] The secundine; i. e. the skin, [or membrane,] (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or thin skin, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) in which is the fœtus, or young, [in the womb,] (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) of human beings, and of horses and camels, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>,) or of human beings and of cattle, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or [peculiarly] of cattle, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) that of human beings being termed مَشِيمَةٌ: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) it is pulled off from the face of the young camel at the time of the birth, or else it kills it, like as it does when it becomes disrupted in the belly: when it comes forth, the she-camel is safe, and so is the young one; but if it becomes disrupted in the belly, she perishes, and so does the young one: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> أَسْلَآءٌ. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) [Hence,] one says, اِنْقَطَعَ السَّلَى فِى البَطْنِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [The secundine became disrupted in the belly]; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) i. e. artifice departed [or came to an end]; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>;) a <abbr title=\"proverb, مَثَلٌ\">prov.</abbr> applied in the case of an affair's becoming beyond one's power of accomplishment, and coming to an end; (<abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>;) like the saying, بَلَغَ السِّكِّينُ العَظْمَ [The knife reached to the bone]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) and هُوَ آكِلُ الأَسْلَآءِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [He is the eater of secundines]; meaning he is low, base, vile, or sordid. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And وَقَعَ القَوْمُ فِى سَلَى جَمَلٍ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [The people, or party, fell into the like of the secundine of a hecamel]; meaning they fell into a difficult affair or case; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> *) or they fell into an unparalleled evil; (<abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>;) for the he-camel has no سلى. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>.) سَلْيَآءُ A ewe, or she-goat, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and a she-camel, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) whose secundine (سَلَاهَا) has become disrupted [in her belly]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> And A ewe, or she-goat, [or she-camel,] whose secundine (سَلَاهَا) has been pulled out or off, or removed from its place. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) سُلَّى, [or سُلًّى,] mentioned in this art. in the <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>: see art. سلو."}]}}