{"lemma":"سَلَّى","slug":"سَلَّى","root":"س.ل.#","root_slug":"س-ل-_","root_link":"/words/roots/س-ل-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَلَّيْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَلَّيْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَلَّيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَلَّيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَلَّيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَلَّى","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَلَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَلَّيا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَلَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَلَّوْا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَلَّيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُسَلّ","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُسَلِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُسَلَّى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُسَلِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُسَلِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُسَلَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m",