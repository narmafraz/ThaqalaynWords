{"lemma": "سَوادٌ", "slug": "سَوادٌ", "root": "س.#.د", "root_slug": "س-_-د", "root_link": "/words/roots/س-_-د", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["name", "noun"], "has_etymology": false, "sense_count": 6}, "lanes": {"found": true, "entry_ids": ["n21179", "n21180"], "search_url": "https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%88%D8%A7%D8%AF%D9%8C"}}, "translations": {"en": "blackness", "fa": "سیاهی", "ur": "سیاہی", "tr": "siyahlık", "id": "kehitaman", "bn": "কালো", "es": "negror", "fr": "noirceur", "de": "Schwarz", "ru": "чернота", "zh": "黑色"}, "definition": {"source": "wiktextract", "senses": [{"pos": "noun", "gloss": "blackness, black", "tags": ["uncountable"]}, {"pos": "noun", "gloss": "an indistinct or unrecognizable figure; a shape; a silhouette; the shadow of a thing or an animal", "tags": ["countable", "uncountable"], "examples": [{"text": "رَأَيْتُ سَوَادًا مِنْ بَعِيدٍ", "english": "I saw a shape in the distance."}]}, {"pos": "noun", "gloss": "multitude (of people)", "tags": ["uncountable"], "examples": [{"text": "سَوَادُ النَّاس", "english": "the majority of people"}]}, {"pos": "noun", "gloss": "the body of a human or an animal", "tags": ["countable", "rare"]}, {"pos": "noun", "gloss": "the backwoods; the countryside", "tags": ["uncountable"]}, {"pos": "name", "gloss": "Sawad, a fertile region in southern Iraq", "tags": ["archaic", "historical"]}]}, "etymology": null, "ipa": ["/sa.waːd/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n21179", "headword_ar": "سَوَادٌ", "root": "swd", "body": [{"kind": "italic_en", "text": "Blackness; contr. of"}, {"kind": "arabic", "text_bw": "bayaADN", "text_ar": "بَيَاضٌ"}, {"kind": "text", "text": "; (M, Mgh;)"}, {"kind": "italic_en", "text": "a certain colour,"}, {"kind": "text", "text": "(S, Msb,)"}, {"kind": "italic_en", "text": "well known."}, {"kind": "text", "text": "(Msb.) One says,"}, {"kind": "arabic", "text_bw": "laqiyahu fiY sawaAdi All~ayoli", "text_ar": "لَقِيَهُ فِى سَوَادِ اللَّيْلِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He met him in the blackness of night"}, {"kind": "text", "text": "]. (TA.) And"}, {"kind": "arabic", "text_bw": "Al$~aApu tamo$iY fiY", "text_ar": "الشَّاةُ تَمْشِى فِى"}, {"kind": "arabic", "text_bw": "sawaAdK wataA^okulu fiY sawaAdK watanoZuru fiY sawaAdK", "text_ar": "سَوَادٍ وَتَاْكُلُ فِى سَوَادٍ وَتَنْظُرُ فِى سَوَادٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The sheep,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "goat, walks in blackness, and eats in blackness, and looks in blackness"}, {"kind": "text", "text": "]; meaning the blackness of its legs and of its mouth and of what is around its eyes. (Mgh, * Msb.) And"}, {"kind": "arabic", "text_bw": "A_i*aA kavura", "text_ar": "اـِذَا كَثُرَ"}, {"kind": "arabic", "text_bw": "AlbayaADu qal~a Als~awaAdu", "text_ar": "البَيَاضُ قَلَّ السَّوَادُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "When whiteness becomes much, blackness becomes little"}, {"kind": "text", "text": "]; by whiteness meaning"}, {"kind": "italic_en", "text": "milk;"}, {"kind": "text", "text": "and by blackness,"}, {"kind": "italic_en", "text": "dates."}, {"kind": "text", "text": "(TA.) ―         -b2-"}, {"kind": "italic_en", "text": "Black clothing."}, {"kind": "text", "text": "(Mgh in art."}, {"kind": "arabic", "text_bw": "byD", "text_ar": "بيض"}, {"kind": "text", "text": ". [See its contr."}, {"kind": "arabic", "text_bw": "bayaADN", "text_ar": "بَيَاضٌ"}, {"kind": "text", "text": ".]) ―         -b3-  [Hence,]"}, {"kind": "arabic", "text_bw": "sawaAdu Alqalobi", "text_ar": "سَوَادُ القَلْبِ"}, {"kind": "text", "text": "(S, M, A, K) and ↓"}, {"kind": "arabic", "text_bw": "sawaAdatuhu", "text_ar": "سَوَادَتُهُ", "orth_type": "arrow"}, {"kind": "text", "text": "(M) and ↓"}, {"kind": "arabic", "text_bw": "A^asowaduhu", "text_ar": "اَسْوَدُهُ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "sawodaAw^uhu", "text_ar": "سَوْدَاوُهُ", "orth_type": "arrow"}, {"kind": "text", "text": "(S, M, K) and ↓"}, {"kind": "arabic", "text_bw": "suwayodaAw^uhu", "text_ar": "سُوَيْدَاوُهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S, M, A, K,) the last a dim., (TA,)"}, {"kind": "italic_en", "text": "The heart's core; the black,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "inner, part of the heart:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a black thing in the heart:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the black clot of blood that is within the heart"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "resembling a piece of liver"}, {"kind": "text", "text": "(Zj in his “ Khalk el-Insán ”)]: or"}, {"kind": "italic_en", "text": "the heart's blood: i. q."}, {"kind": "arabic", "text_bw": "Hab~atuhu", "text_ar": "حَبَّتُهُ"}, {"kind": "text", "text": ": (S, M, K, TA:) or, as some say,"}, {"kind": "arabic", "text_bw": "damuhu", "text_ar": "دَمُهُ"}, {"kind": "text", "text": ". (M, TA.) One says,"}, {"kind": "arabic", "text_bw": "AijoEalohumo fiY sawaAdi qalobika", "text_ar": "اِجْعَلْهُمْ فِى سَوَادِ قَلْبِكَ"}, {"kind": "text", "text": "(A, TA) and ↓"}, {"kind": "arabic", "text_bw": "suwayodaAy^ihi", "text_ar": "سُوَيْدَايِهِ", "orth_type": "arrow"}, {"kind": "text", "text": "(A) (tropical:)  ["}, {"kind": "italic_en", "text": "Place them in the inmost part of thy heart;"}, {"kind": "text", "text": "i. e."}, {"kind": "italic_en", "text": "give them the best,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "most intimate, place in thy affections"}, {"kind": "text", "text": "]. (A, TA.) ―         -b4-"}, {"kind": "arabic", "text_bw": "sawaAdu AlbaToni", "text_ar": "سَوَادُ البَطْنِ"}, {"kind": "text", "text": "signifies"}, {"kind": "italic_en", "text": "The liver."}, {"kind": "text", "text": "(L, TA.) ―         -b5-"}, {"kind": "arabic", "text_bw": "sawAdN", "text_ar": "سَوادٌ"}, {"kind": "text", "text": "is also"}, {"kind": "italic_en", "text": "syn. with"}, {"kind": "arabic", "text_bw": "$axoSN", "text_ar": "شَخْصٌ"}, {"kind": "text", "text": "(tropical:)  [as meaning"}, {"kind": "italic_en", "text": "A person;"}, {"kind": "text", "text": "and also, in a more general sense,"}, {"kind": "italic_en", "text": "a bodily,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "corporeal, form"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "figure"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "substance"}, {"kind": "text", "text": "]; (A'Obeyd, S, M, A, Msb, K;) of a man, and of other things; (Msb;) expressly said by A'Obeyd to be of any article of household goods or utensils and furniture and the like, and of other things: (M:) because appearing black when seen from a distance: (TA:) pl."}, {"kind": "arabic", "text_bw": "A^asowidapN", "text_ar": "اَسْوِدَةٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "A^asaAwidu", "text_ar": "اَسَاوِدُ"}, {"kind": "text", "text": ", (S, M, A,) the latter a pl. pl. (S, M.) El-Asshà says,"}, {"kind": "quote", "text": "tanaAhayotumu Ean~aA waqado kaAna fiykumu\n                      \n                     \n                        A^asaAwidu SaroEaY lamo yuwas~ado qatiyluhaA"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Ye refrained from"}, {"kind": "text", "text": "retaliating upon"}, {"kind": "italic_en", "text": "us when there were among you prostrate persons the slain whereof had not been pillowed"}, {"kind": "text", "text": "in graves]: by the"}, {"kind": "arabic", "text_bw": "AsAwd", "text_ar": "اساود"}, {"kind": "text", "text": "meaning the"}, {"kind": "arabic", "text_bw": "$uxuwS", "text_ar": "شُخُوص"}, {"kind": "text", "text": "of the slain. (S.) And it is said in a trad.,"}, {"kind": "arabic", "text_bw": "A_i*aA raA^aY A^aHadukumo sawaAdFA", "text_ar": "اـِذَا رَاَى اَحَدُكُمْ سَوَادًا"}, {"kind": "arabic", "text_bw": "bilayolK falaA yakuno A^ajobana Als~awaAdayoni faA_in~ahu yaxaAfuka kamaA", "text_ar": "بِلَيْلٍ فَلَا يَكُنْ اَجْبَنَ السَّوَادَيْنِ فَاـِنَّهُ يَخَافُكَ كَمَا"}, {"kind": "arabic", "text_bw": "taxaAfuhu", "text_ar": "تَخَافُهُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "When any one of you sees a bodily form,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a person, by night, let him not be the more cowardly of the two bodily forms,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "persons; for he feareth thee, like as thou fearest him"}, {"kind": "text", "text": "]:"}, {"kind": "arabic", "text_bw": "swAdA", "text_ar": "سوادا"}, {"kind": "text", "text": "here meaning"}, {"kind": "arabic", "text_bw": "$axoSFA", "text_ar": "شَخْصًا"}, {"kind": "text", "text": ". (L.) The saying"}, {"kind": "arabic", "text_bw": "laA yuzaAyilu sawaAdiY bayaADaka", "text_ar": "لَا يُزَايِلُ سَوَادِى بَيَاضَكَ"}, {"kind": "text", "text": "is expl. by As as meaning"}, {"kind": "arabic", "text_bw": "laA yuzAyilu $axoSiY $axoSaka", "text_ar": "لَا يُزايِلُ شَخْصِى شَخْصَكَ"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "My person will not separate itself from thy person"}, {"kind": "text", "text": "]:"}, {"kind": "arabic", "text_bw": "sawaAdN", "text_ar": "سَوَادٌ"}, {"kind": "text", "text": ", with the Arabs, meaning"}, {"kind": "arabic", "text_bw": "$axoSN", "text_ar": "شَخْصٌ"}, {"kind": "text", "text": ", and in like manner"}, {"kind": "arabic", "text_bw": "bayaADN", "text_ar": "بَيَاضٌ"}, {"kind": "text", "text": ". (IAar, L.) [Hence, app.,]"}, {"kind": "arabic", "text_bw": "qaAla liYa Al$~ar~u A^aqimo", "text_ar": "قَالَ لِىَ الشَّرُّ اَقِمْ"}, {"kind": "arabic", "text_bw": "sawaAdaka", "text_ar": "سَوَادَكَ"}, {"kind": "text", "text": "[as though lit. signifying"}, {"kind": "italic_en", "text": "Evil said to me, Erect thy person"}, {"kind": "text", "text": "]; meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "be thou patient:"}, {"kind": "text", "text": "a prov. (TA.) ―         -b6-  As its pl."}, {"kind": "arabic", "text_bw": "A^asaAwidu", "text_ar": "اَسَاوِدُ"}, {"kind": "text", "text": "means the"}, {"kind": "arabic", "text_bw": "$uxuwS", "text_ar": "شُخُوص"}, {"kind": "text", "text": "of the vessels of a house, [accord. to the statement of A'Obeyd cited above,] such as the"}, {"kind": "arabic", "text_bw": "miToharap", "text_ar": "مِطْهَرَة"}, {"kind": "text", "text": "and the"}, {"kind": "arabic", "text_bw": "A_ij~aAnap", "text_ar": "اـِجَّانَة"}, {"kind": "text", "text": "and the"}, {"kind": "arabic", "text_bw": "jafonap", "text_ar": "جَفْنَة"}, {"kind": "text", "text": ", these being called"}, {"kind": "arabic", "text_bw": "A^asaAwidu Ald~aAri", "text_ar": "اَسَاوِدُ الدَّارِ"}, {"kind": "text", "text": ", it is also used as meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "Household goods"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "utensils"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "furniture"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "the like,"}, {"kind": "text", "text": "absolutely. (Har p. 495.) [And in like manner] the sing. is also used as meaning (assumed tropical:)  The"}, {"kind": "italic_en", "text": "travelling-apparatus and baggage and train"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "vaqal", "text_ar": "ثَقَل"}, {"kind": "text", "text": ") of a commander: (S:) and (assumed tropical:)  the"}, {"kind": "italic_en", "text": "tents and apparatus and beasts and other things, collectively,"}, {"kind": "text", "text": "of an army. (TA.) ―         -b7-  Also, the sing., (assumed tropical:)"}, {"kind": "italic_en", "text": "Property,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "cattle, &c.;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "maAlN", "text_ar": "مَالٌ"}, {"kind": "text", "text": ": (Aboo-Málik, TA:) or"}, {"kind": "italic_en", "text": "much thereof;"}, {"kind": "text", "text": "(A'Obeyd, S, K;) as in the saying"}, {"kind": "arabic", "text_bw": "lifulaAnK sawaAdN", "text_ar": "لِفُلَانٍ سَوَادٌ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "To such a one belongs much property,"}, {"kind": "text", "text": "&c.]. (A'Obeyd, S.) ―         -b8-  Also (tropical:)"}, {"kind": "italic_en", "text": "A collection, company,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "collective body,"}, {"kind": "text", "text": "of men; (M, A, L;) as in the saying"}, {"kind": "arabic", "text_bw": "kav~arotu sawaAda Alqawomi bisawaAdiY", "text_ar": "كَثَّرْتُ سَوَادَ القَوْمِ بِسَوَادِى"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "I increased the number of the collective body of the people,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "party, by my person"}, {"kind": "text", "text": "]: (A, TA:) and ↓"}, {"kind": "arabic", "text_bw": "A^FsowadaAtN", "text_ar": "اًسْوَدَاتٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "A^asaAwidu", "text_ar": "اَسَاوِدُ"}, {"kind": "text", "text": "are used in the same sense; (M;) or [rather] as pls. of this meaning: (L, TA:) or all these as meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "sundry, distinct"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "separate, sorts"}, {"kind": "text", "text": "of men, or people: (M:) [but]"}, {"kind": "arabic", "text_bw": "sawaAdu Almusolimiyna", "text_ar": "سَوَادُ المُسْلِمِينَ"}, {"kind": "text", "text": "means (assumed tropical:)"}, {"kind": "italic_en", "text": "the collective body of the Muslims:"}, {"kind": "text", "text": "(Mgh, Msb:) and so"}, {"kind": "arabic", "text_bw": "Als~awaAdu", "text_ar": "السَّوَادُ"}, {"kind": "arabic", "text_bw": "AlA^aEoZamu", "text_ar": "الاَعْظَمُ"}, {"kind": "text", "text": ", a tropical phrase [in which"}, {"kind": "arabic", "text_bw": "mina Almusolimiyna", "text_ar": "مِنَ المُسْلِمِينَ"}, {"kind": "text", "text": "is understood]: (A:) or this means (tropical:)"}, {"kind": "italic_en", "text": "the great number of the Muslims agreed in obedience to the Imám."}, {"kind": "text", "text": "(TA.) (assumed tropical:)  The"}, {"kind": "italic_en", "text": "commonalty,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "generality,"}, {"kind": "text", "text": "of men of people: (S, K:) (assumed tropical:)  the"}, {"kind": "italic_en", "text": "bulk,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "main part,"}, {"kind": "text", "text": "of a people: (M, TA:) or (assumed tropical:)  the"}, {"kind": "italic_en", "text": "greater number."}, {"kind": "text", "text": "(Msb.) And (assumed tropical:)"}, {"kind": "italic_en", "text": "A great number"}, {"kind": "text", "text": "(S, Msb, K) of any kind. (S.) ―         -b9-  (assumed tropical:)"}, {"kind": "italic_en", "text": "A collection of palmtrees and of trees in general;"}, {"kind": "text", "text": "on account of their greenness and blackness, because greenness nearly resembles blackness. (M, L.) ―         -b10-  And (tropical:)  The"}, {"kind": "italic_en", "text": "rural district"}, {"kind": "text", "text": "of any province; i. e. the"}, {"kind": "italic_en", "text": "district around the towns"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages,"}, {"kind": "text", "text": "and the"}, {"kind": "arabic", "text_bw": "rasaAtiyq", "text_ar": "رَسَاتِيق"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "districts of sown fields with towns"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages"}, {"kind": "text", "text": "], of any province: (M, TA:) or the"}, {"kind": "italic_en", "text": "environs, consisting of towns,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages, and of cultivated land,"}, {"kind": "text", "text": "(A, TA,) [but more properly applied to the latter than to the former,] of a city, (A,) or"}, {"kind": "italic_en", "text": "of the chief city"}, {"kind": "text", "text": "of a province: (TA:) or the"}, {"kind": "italic_en", "text": "towns,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages,"}, {"kind": "text", "text": "[but properly"}, {"kind": "italic_en", "text": "with the cultivated lands pertaining to them,"}, {"kind": "text", "text": "] of a province of city: (K:) thus [particularly] of El-Koofeh and El-Basrah: (S, O:) hence, (A,)"}, {"kind": "arabic", "text_bw": "sawaAdu AlEiraAqi", "text_ar": "سَوَادُ العِرَاقِ"}, {"kind": "text", "text": ", (A, Mgh, O, Msb,) or [simply]"}, {"kind": "arabic", "text_bw": "Als~awaAdu", "text_ar": "السَّوَادُ"}, {"kind": "text", "text": ", (K,)"}, {"kind": "italic_en", "text": "the district of towns"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages, and cultivated lands, of El- 'Irák;"}, {"kind": "text", "text": "(O, K; *) or"}, {"kind": "italic_en", "text": "the district between ElBasrah and El-Koofeh, with the towns,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "villages, around them;"}, {"kind": "text", "text": "(A;) or"}, {"kind": "italic_en", "text": "extending in length from Hadeethet El-Mowsil to 'Abbádán, and in breadth from El-'Odheyb to Holwán;"}, {"kind": "text", "text": "(Mgh;) so called because of the"}, {"kind": "arabic", "text_bw": "xuDorap", "text_ar": "خُضْرَة"}, {"kind": "text", "text": "[which means both greenness and a colour approaching to blackness] of its trees and its seed-produce; (Mgh, Msb;) for that which is"}, {"kind": "arabic", "text_bw": "A^axoDar", "text_ar": "اَخْضَر"}, {"kind": "text", "text": "the Arabs term"}, {"kind": "arabic", "text_bw": "A^asowad", "t