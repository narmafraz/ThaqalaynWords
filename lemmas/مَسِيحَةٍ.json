{"lemma":"مَسِيحَةٍ","slug":"مَسِيحَةٍ","root":"م.س.ح","root_slug":"م-س-ح","root_link":"/words/roots/م-س-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَسِيح","root":"مسح","pos":"N","occurrence_count":11},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n38566"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B3%D9%90%D9%8A%D8%AD%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"anointed"},{"pos":"noun","gloss":"messiah, Messiah","examples":[{"text":"الْمَسِيح","english":"the Messiah, Christ"}]}]},"etymology":{"source":"wiktextract","text":"Related to مَسَحَ (masaḥa, “to anoint”). Cognate to Aramaic ܡܫܺܝܚܳܐ (m'šīḥāʿ) and Hebrew מָשִׁיחַ (mashíakh), whence the Ancient Greek borrowing Μεσσίας (Messías) and the Greek calque Χριστός (Christós), thus the English terms \"Messiah\" and \"Christ\"."},"ipa":["/ma.siːħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38566","headword_ar":"مَسِيحَةٌ","root":"msH","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"*uw^aAbapN","text_ar":"ذُوَابَةٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"a portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lock, of hair hanging down loosely from the middle of the head to the back;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the hair of the fore part of the head; the hair over the forehead;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"part whence that hair grows;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plait of hair hanging down; &c."},{"kind":"text","text":"]: (S, L, K:) or"},{"kind":"italic_en","text":"hair that is left without its being dressed with oil"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anything else:"},{"kind":"text","text":"or that"},{"kind":"italic_en","text":"part of a man's head that is between the ear and the eyebrow, rising to the part below that where the sutures of the scull unite:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that part of the side of the hair upon which a man puts his hand, next to his ear:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the hair of each side of the head:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"masaAy^iHu","text_ar":"مَسَايِحُ"},{"kind":"text","text":": or"},{"kind":"arabic","text_bw":"msAy^H","text_ar":"مسايح"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"place which a man wipes with his hand:"},{"kind":"text","text":"or, accord. to As, the"},{"kind":"italic_en","text":"hair:"},{"kind":"text","text":"or, accord. to Sh, the"},{"kind":"italic_en","text":"hair which one wipes with his hand, upon his cheek and his head."},{"kind":"text","text":"(L.) ―         -b2-  See"},{"kind":"arabic","text_bw":"masiyHN","text_ar":"مَسِيحٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"masiyHapN","text_ar":"مَسِيحَةٌ"},{"kind":"italic_en","text":"A bow:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"an excellent bow:"},{"kind":"text","text":"(L.) pl."},{"kind":"arabic","text_bw":"masaAy^Hu","text_ar":"مَسَايحُ"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","L","K"]}]},"classical_definitions":null}