is in bad condition."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"rajulN","text_ar":"رَجُلٌ"},{"kind":"arabic","text_bw":"rav~u Alhayoy^api","text_ar":"رَثُّ الهَيْيَةِ"},{"kind":"italic_en","text":"A man whose garb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparel, is old, and worn out;"},{"kind":"text","text":"(T, S, * M;)"},{"kind":"italic_en","text":"threadbare, shabby,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean."},{"kind":"text","text":"(M.) This last phrase is [also] tropical [as meaning (tropical:)"},{"kind":"italic_en","text":"A man whose aspect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, is weak,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"vile, mean, paltry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"despicable:"},{"kind":"text","text":"see 1, last sentence but two]. (A.) And one says also"},{"kind":"arabic","text_bw":"rajulN rav~N","text_ar":"رَجُلٌ رَثٌّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A man old, and worn out;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weak,"},{"kind":"text","text":"&c.]. (T.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"kalaAmN rav~N","text_ar":"كَلَامٌ رَثٌّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Meagre, unsubstantial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flimsy, speech"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language."},{"kind":"text","text":"(A.) ―         -b3-  See also what next follows."}],"source_refs":["M","A","K","T","Mgh","S","Msb"]}]},"classical_definitions":null}