"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n20283"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%92%D8%B3%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20283","headword_ar":"انسلّ","root":"sl","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became pulled out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drawn forth, gently;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"it became drawn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulled out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, as a sword from its scabbard,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a hair from dough."},{"kind":"text","text":"(Mgh.) You say,"},{"kind":"arabic","text_bw":"Ansl~","text_ar":"انسلّ"},{"kind":"arabic","text_bw":"Als~ayofu mina Algamodi","text_ar":"السَّيْفُ مِنَ الغَمْدِ"},{"kind":"italic_en","text":"The sword"},{"kind":"text","text":"["},{"kind":"italic_en","text":"became drawn from the scabbard:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"slipped out from the scabbard."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Ansl~ qiyaAduAlfarasi mino yadihi","text_ar":"انسلّ قِيَادُالفَرَسِ مِنْ يَدِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The leading-rope of the horse slipped out"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"came forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from his hand"},{"kind":"text","text":"]. (Mgh.) ―         -b2-  And [hence], as also ↓"},{"kind":"arabic","text_bw":"tsl~l","text_ar":"تسلّل","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,)"},{"kind":"italic_en","text":"He slipped away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stole away;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"went away covertly, secretly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestinely:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he went forth,"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"bayonihimo","text_ar":"بَيْنِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from among them"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"Ainosalalotu","text_ar":"اِنْسَلَلْتُ"},{"kind":"arabic","text_bw":"mino bayoni yadayohi","text_ar":"مِنْ بَيْنِ يَدَيْهِ"},{"kind":"italic_en","text":"I went away,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"went forth, deliberately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leisurely,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"by degrees, from before him."},{"kind":"text","text":"(TA.) Sb says that"},{"kind":"arabic","text_bw":"Ainosalalotu","text_ar":"اِنْسَلَلْتُ"},{"kind":"text","text":"[used in this or a similar sense] is not a quasi-pass. verb; but is only like [a verb of the measure]"},{"kind":"arabic","text_bw":"faEalotu","text_ar":"فَعَلْتُ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"Aifotaqara","text_ar":"اِفْتَقَرَ"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"DaEufa","text_ar":"ضَعُفَ"},{"kind":"text","text":". (M.) It is said in a prov.,"},{"kind":"arabic","text_bw":"ramatoniY bidaAy^ihaAwaA@nosal~ato","text_ar":"رَمَتْنِى بِدَايِهَاوَا@نْسَلَّتْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She reproached me with her own fault, and slipped away"},{"kind":"text","text":"]: (S, Meyd, TA:) [originally] said by one of the fellow-wives of Ruhm, daughter of El-Khazraj, wife of Saad Ibn-Zeyd-Menáh, on Ruhm's reproaching her with a fault that was in herself. (Meyd, TA. [See also Freytag's Arab. Prov. cap. x. no. 2; and another prov. there referred to in cap. ii. no. 78.]) And one says also,"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Astl~","text_ar":"استلّ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He went away with such a thing covertly, secretly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestinely."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","K","Meyd","TA"]}]}}