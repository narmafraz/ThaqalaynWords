{"lemma":"حَبا","slug":"حَبا","root":"ح.ب.#","root_slug":"ح-ب-_","root_link":"/words/roots/ح-ب-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَبَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَبَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَبَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَبَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَبَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَبا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَبَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَبَوا","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَبَوْا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَبَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْب","in_corpus":true,"count":31,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَحْبَى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَحْبُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْبَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْبَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْبُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْبُونَ","in_corpus":true,"count":13,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْبَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَحْبُوْنَ","in_corpus":true,"count":13,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْب","in_corpus":true,"count":87,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْبَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْبُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْب","in_corpus":true,"count":31,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْبَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْبُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْبَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْبَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْبُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْبَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْبَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْبُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْبُونَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْبَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَحْبُوْنَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْب","in_corpus":true,"count":349,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْب","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْبَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْبَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْبُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْبُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَبَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَبَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":546,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n7006","n7010"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%A8%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to crawl, to creep"},{"pos":"verb","gloss":"to present, give, award"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7006","headword_ar":"حَبَا","root":"Hbw","body":[{"kind":"text","text":", (Msb, K,) [aor."},{"kind":"arabic","text_bw":"yaHobuw","text_ar":"يَحْبُو"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"Hubuw~N","text_ar":"حُبُوٌّ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, Msb, TA),"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near."},{"kind":"text","text":"(Msb, K.) And hence, (TA,)"},{"kind":"arabic","text_bw":"Habawotu liloxamosiyna","text_ar":"حَبَوْتُ لِلْخَمْسِينَ"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near to fifty"},{"kind":"text","text":"[years]; (S, ISd, TA;) [as also"},{"kind":"arabic","text_bw":"Hbwt Alxamosiyna","text_ar":"حبوت الخَمْسِينَ"},{"kind":"text","text":"; for] IAar says that"},{"kind":"arabic","text_bw":"HabaAhaA","text_ar":"حَبَاهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HabaA lahaA","text_ar":"حَبَا لَهَا"},{"kind":"text","text":"both have this signification. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Habati AlA^aDolaAEu A_ilaY AlS~ulobi","text_ar":"حَبَتِ الاَضْلَاعُ اـِلَى الصُّلْبِ"},{"kind":"italic_en","text":"The ribs joined to the backbone;"},{"kind":"text","text":"(K;) and in like manner, with the same meaning, one says of the entrails: and"},{"kind":"italic_en","text":"the ribs were near to the backbone."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Habati Al$~araAsiyfu","text_ar":"حَبَتِ الشَّرَاسِيفُ"},{"kind":"text","text":", (K,) inf. n. as above, (TA,) i. e. ["},{"kind":"italic_en","text":"The extremities of the ribs, projecting over the belly,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"were long, so that they were near one another."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"HabaA Almasiylu","text_ar":"حَبَا المَسِيلُ"},{"kind":"italic_en","text":"The water-course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel of a torrent, became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"contracted,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"so that one part thereof was near to another."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"HabaA","text_ar":"حَبَا"},{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaHobuw","text_ar":"يَحْبُو"},{"kind":"text","text":", (Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"HabowN","text_ar":"حَبْوٌ"},{"kind":"text","text":", said of a child, (S, Mgh, Msb, K,) before he stands; (Lth, TA;) as also"},{"kind":"arabic","text_bw":"HabaY","text_ar":"حَبَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHobiY","text_ar":"يَحْبِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaboYN","text_ar":"حَبْىٌ"},{"kind":"text","text":", which, however, is rare; (Msb;)"},{"kind":"italic_en","text":"He crept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawled,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"dragged himself along,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon his posteriors;"},{"kind":"text","text":"(Mgh;) or so"},{"kind":"arabic","text_bw":"HbA EalaY A@sotihi","text_ar":"حبا عَلَى ا@سْتِهِ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"he went along upon his posteriors, protruding his chest:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"went along on four"},{"kind":"text","text":"[or, as we say,"},{"kind":"italic_en","text":"on all fours"},{"kind":"text","text":"]: in this last sense it is used by the lawyers. (Mgh.) And, said of a man,"},{"kind":"italic_en","text":"He went along upon his hands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arms, and his belly:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"upon his hands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arms, and his knees:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon his posteriors:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon his elbows and knees:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"he crept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawled:"},{"kind":"text","text":"for] you say,"},{"kind":"arabic","text_bw":"maA jaA='a A_il~aA HabowFA","text_ar":"مَا جَا=ءَ اـِلَّا حَبْوًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He came not save creeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawling:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maAnajaAfulaAnN A_il~aA HabowFA","text_ar":"مَانَجَافُلَانٌ اـِلَّا حَبْوًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one escaped not save creeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawling"},{"kind":"text","text":"]. (TA.) Also, said of a camel having his fore shank bound up to his arm,"},{"kind":"italic_en","text":"He crept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawled, along:"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he dragged himself along on the ground:"},{"kind":"text","text":"] and, said of a camel,"},{"kind":"italic_en","text":"he lay down, and crept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawled,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"dragged himself along,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by reason of fatigue:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"being constrained to ascend a difficult tract of sand, he protruded his chest, and then crept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crawled."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,] said of an arrow,"},{"kind":"italic_en","text":"It glided along the ground, and then hit the butt:"},{"kind":"text","text":"(S:) or so"},{"kind":"arabic","text_bw":"HbA A_ilaY AlgaraDi","text_ar":"حبا اـِلَى الغَرَضِ"},{"kind":"text","text":". (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"HbA AlmaAlu","text_ar":"حبا المَالُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HabowN","text_ar":"حَبْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The cattle clave to the ground, motionless, by reason of emaciation."},{"kind":"text","text":"(K.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Habati Als~afiynapu","text_ar":"حَبَتِ السَّفِينَةُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HabowN","text_ar":"حَبْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The ship ran."},{"kind":"text","text":"(K.)       -A3-"},{"kind":"arabic","text_bw":"HabaA lahu","text_ar":"حَبَا لَهُ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"presented itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its breadth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"width,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its side, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AiEotaraDa","text_ar":"اِعْتَرَضَ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":"; (Mgh;) as do, for instance, waves to a ship; (TA;) and as clouds, like a mountain, before they cover the sky. (S.) And"},{"kind":"arabic","text_bw":"HbA Alr~amolu","text_ar":"حبا الرَّمْلُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHobuw","text_ar":"يَحْبُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HabowN","text_ar":"حَبْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The sands rose up, extending sideways"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muEotariDFA","text_ar":"مُعْتَرِضًا"},{"kind":"text","text":"): (TA:) or"},{"kind":"italic_en","text":"extended widely."},{"kind":"text","text":"(IAar, TA.)       -A4-"},{"kind":"arabic","text_bw":"HabaAhu","text_ar":"حَبَاهُ"},{"kind":"text","text":", (S, Msb, K,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"HabowN","text_ar":"حَبْوٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"HabowapN","text_ar":"حَبْوَةٌ"},{"kind":"text","text":", (S, TA,) or this is a simple subst, (K,) and the inf. n. is"},{"kind":"arabic","text_bw":"HibaA='N","text_ar":"حِبَا=ءٌ"},{"kind":"text","text":", (Msb,) or this last also is a simple subst., (S, * K,)"},{"kind":"italic_en","text":"He gave him"},{"kind":"text","text":"(S, Msb, K) a thing (Msb)"},{"kind":"italic_en","text":"without any compensation"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"and without"},{"kind":"text","text":"["},{"kind":"italic_en","text":"receiving"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"any favour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a general sense."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"HibaA='N","text_ar":"حِبَا=ءٌ"},{"kind":"text","text":"below.]) You say,"},{"kind":"arabic","text_bw":"HabaAhu ka*aA","text_ar":"حَبَاهُ كَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God, or a man,)"},{"kind":"italic_en","text":"gave him such a thing without"},{"kind":"text","text":"["},{"kind":"italic_en","text":"receiving"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"any favour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit, and without requital."},{"kind":"text","text":"(Ham pp. 327 and 654.) ―         -b2-  And also, (K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"HibaA='N","text_ar":"حِبَا=ءٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He denied him, refused him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused to give him;"},{"kind":"text","text":"(K, TA;) on the authority of IAar only. (TA.) Thus the verb bears two contr. significations. (K.) ―         -b3-"},{"kind":"arabic","text_bw":"HbA maA Hawolahu","text_ar":"حبا مَا حَوْلَهُ"},{"kind":"italic_en","text":"He defended, protected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarded, what was around him;"},{"kind":"text","text":"(As, S, K;) as also ↓"},{"kind":"arabic","text_bw":"Hb~Ahu","text_ar":"حبّاهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHobiyapN","text_ar":"تَحْبِيَةٌ"},{"kind":"text","text":". (S, K.) J cites as an ex. of the former verb, from a poem of Ibn-Ahmar, the phrase"},{"kind":"arabic","text_bw":"lamo yaHobuhaA faHolN","text_ar":"لَمْ يَحْبُهَا فَحْلٌ"},{"kind":"text","text":"[as though meaning"},{"kind":"italic_en","text":"A stallion did not defend them"},{"kind":"text","text":"]; referring to she-camels: but accord. to AHn, it means"},{"kind":"italic_en","text":"did not regard them;"},{"kind":"text","text":"being occupied with himself. (TA.) ―         -b4-  You say also,"},{"kind":"arabic","text_bw":"fulaAnN yaHobuw qaSaAhumo","text_ar":"فُلَانٌ يَحْبُو قَصَاهُمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaHuwTu qaSaAhumo","text_ar":"يَحُوطُ قَصَاهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one fights in their defence;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defends them in a distant quarter:"},{"kind":"text","text":"but generally meant ironically: see 1 in art."},{"kind":"arabic","text_bw":"HwT","text_ar":"حوط"},{"kind":"text","text":"]: both signify the same. (Abu-l-'Abbás, TA.)"}],"source_refs":["Msb","K","TA","S","Mgh"]},{"entry_id":"n7010","headword_ar":"حَبًا","root":"Hbw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HabiY~N","text_ar":"حَبِىٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]}}