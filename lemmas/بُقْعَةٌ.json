{"lemma":"بُقْعَةٌ","slug":"بُقْعَةٌ","root":"ب.ق.ع","root_slug":"ب-ق-ع","root_link":"/words/roots/ب-ق-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بُقْعَة","root":"بقع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3009"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D9%82%D9%92%D8%B9%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"spot, stain, smudge"},{"pos":"noun","gloss":"patch, area, place, region"}]},"etymology":null,"ipa":["/buq.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3009","headword_ar":"بُقْعَةٌ","root":"bqE","body":[{"kind":"text","text":"(S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"baqoEapN","text_ar":"بَقْعَةٌ","orth_type":"arrow"},{"kind":"text","text":", (AZ, Msb, K,) but the former is the more common, (Msb,) and more chaste, (TA,)"},{"kind":"italic_en","text":"A piece, part, portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plot,"},{"kind":"text","text":"(Mgh, Msb, K,) of land, or ground, (S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"differing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in any manner,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in colour,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"in appearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"external state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"from that which adjoins it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is next to it:"},{"kind":"text","text":"(Mgh, K:) this is the primary signification: (Mgh:) ["},{"kind":"italic_en","text":"a patch of ground:"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"biqaAEN","text_ar":"بِقَاعٌ"},{"kind":"text","text":", (S, K,) or this is pl. of"},{"kind":"arabic","text_bw":"baqoEapN","text_ar":"بَقْعَةٌ"},{"kind":"text","text":", (Msb, TA,) and the pl. of"},{"kind":"arabic","text_bw":"buqoEapN","text_ar":"بُقْعَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"buqaEN","text_ar":"بُقَعٌ"},{"kind":"text","text":". (Mgh, Msb, TA.) You say"},{"kind":"arabic","text_bw":"A^aroDN fiyhaA buqaEN mina AljaraAdi","text_ar":"اَرْضٌ فِيهَا بُقَعٌ مِنَ الجَرَادِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Land in which are bare places occasioned by the locusts"},{"kind":"text","text":"]. (Lh, K.) And"},{"kind":"arabic","text_bw":"fiY AlA^aroDi mino nabotK","text_ar":"فِى الاَرْضِ مِنْ نَبْتٍ"},{"kind":"italic_en","text":"In the land are small portions of herbage."},{"kind":"text","text":"(AHn.) And"},{"kind":"arabic","text_bw":"buqoEapN mino kalaA^","text_ar":"بُقْعَةٌ مِنْ كَلَا"},{"kind":"italic_en","text":"A patch of herbage."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"bqTF","text_ar":"بقطً"},{"kind":"text","text":".) ―         -b2-  [The former also signifies"},{"kind":"italic_en","text":"A spot;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small portion of any surface, distinct from what surrounds it."},{"kind":"text","text":"] And the pl."},{"kind":"arabic","text_bw":"buqaEN","text_ar":"بُقَعٌ"},{"kind":"italic_en","text":"Places"},{"kind":"text","text":"in a garment, or piece of cloth, which has been dyed,"},{"kind":"italic_en","text":"remaining undyed."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"buqaEu AlmaA='i","text_ar":"بُقَعُ المَا=ءِ"},{"kind":"italic_en","text":"Places"},{"kind":"text","text":"in a garment, or piece of cloth, which has been washed,"},{"kind":"italic_en","text":"in which the water remains, undried."},{"kind":"text","text":"(Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"huwa Hasanu AlbuqoEapi Einoda AlA^amiyri","text_ar":"هُوَ حَسَنُ البُقْعَةِ عِنْدَ الاَمِيرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He has a good station with the prince,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commander."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"julobapN","text_ar":"جُلْبَةٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","Msb","K","AZ","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D9%82%D8%B9%D8%A9/","headword_ar":"بقعة الصديان","entries":[{"lexicon_id":"dictionary_50","lexicon_en":"Kâtip Çelebi / Ḥājī Khalīfa, Kashf al-Ẓunūn ʿan Asāmī al-Kutub wa-l-Funūn (d. 1657)","lexicon_ar":"كشف الظنون عن أسامي الكتب والفنون لحاجي خليفة","permalink":"https://arabiclexicon.hawramani.com/?p=133656#974067","body_html":"بقعة الصديان<br>للإمام، رضي الدين: حسن بن محمد بن حسن بن حيدر الهندي، الصنعاني.<br>المتوفى: سنة خمس وستمائة."}]}}