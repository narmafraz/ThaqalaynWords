ext","text":"or"},{"kind":"italic_en","text":"noises."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n23856","headword_ar":"صَخَبٌ","root":"Sxb","body":[{"kind":"text","text":"inf. n. of 1: (Msb, TA:) [used as a simple subst., its pl. is"},{"kind":"arabic","text_bw":"A^aSoxaAbN","text_ar":"اَصْخَابٌ"},{"kind":"text","text":":] one says,"},{"kind":"arabic","text_bw":"samiEotu","text_ar":"سَمِعْتُ"},{"kind":"arabic","text_bw":"A^aSoxaAba AlT~ayori","text_ar":"اَصْخَابَ الطَّيْرِ"},{"kind":"italic_en","text":"I heard the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"confused"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"cries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voices, of the birds."},{"kind":"text","text":"(Msb. [See also 8.])"}],"source_refs":["Msb","TA"]},{"entry_id":"n23857","headword_ar":"صَخِبٌ","root":"Sxb","body":[{"kind":"text","text":"(A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"Sax~aAbN","text_ar":"صَخَّابٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"SaxobaAnu","text_ar":"صَخْبَانُ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"SaxuwbN","text_ar":"صَخُوبٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"SaAxibN","text_ar":"صَاخِبٌ","orth_type":"arrow"},{"kind":"text","text":"(A, Msb) are epithets from"},{"kind":"arabic","text_bw":"Saxiba","text_ar":"صَخِبَ"},{"kind":"text","text":"; (S, A, Msb, K;) all except the last signifying One"},{"kind":"italic_en","text":"who clamours,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raises confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises, vehemently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much;"},{"kind":"text","text":"(TA;) [the last having a similar, but not intensive, signification, i. e."},{"kind":"italic_en","text":"clamouring,"},{"kind":"text","text":"&c.:] and the first, though masc., is applied by the poet Usámeh ElHudhalee to a female singer considered as a person ("},{"kind":"arabic","text_bw":"$axoS","text_ar":"شَخْص"},{"kind":"text","text":"[and meaning in this instance"},{"kind":"italic_en","text":"loud of voice"},{"kind":"text","text":"]); for an epithet of the measure"},{"kind":"arabic","text_bw":"faEilN","text_ar":"فَعِلٌ"},{"kind":"text","text":"applied to a woman ("},{"kind":"arabic","text_bw":"AimoraA^apN","text_ar":"اِمْرَاَةٌ"},{"kind":"text","text":") is not known in the language: (L, TA:) the [proper] fem. epithet is"},{"kind":"arabic","text_bw":"SaxibapN","text_ar":"صَخِبَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Sax~aAbapN","text_ar":"صَخَّابَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"SaxobaY","text_ar":"صَخْبَى","orth_type":"arrow"},{"kind":"text","text":"(Msb) and ↓"},{"kind":"arabic","text_bw":"SaxuwbN","text_ar":"صَخُوبٌ","orth_type":"arrow"},{"kind":"text","text":"(K, TA, in the CK [erroneously]"},{"kind":"arabic","text_bw":"SaxuwbapN","text_ar":"صَخُوبَةٌ"},{"kind":"text","text":") and ↓"},{"kind":"arabic","text_bw":"Suxub~apN","text_ar":"صُخُبَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) the pl. of"},{"kind":"arabic","text_bw":"SaxobaAnu","text_ar":"صَخْبَانُ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"SuxobaAnN","text_ar":"صُخْبَانٌ","orth_type":"arrow"},{"kind":"text","text":"; (Kr, K;) [and the pl. of"},{"kind":"arabic","text_bw":"SaxuwbN","text_ar":"صَخُوبٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"SuxubN","text_ar":"صُخُبٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"SuburN","text_ar":"صُبُرٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"SabuwrN","text_ar":"صَبُورٌ"},{"kind":"text","text":":] the hypocrites are described in a trad. as"},{"kind":"arabic","text_bw":"SuxubN biAln~ahaAri xu$ubN biAll~ayoli","text_ar":"صُخُبٌ بِالنَّهَارِ خُشُبٌ بِاللَّيْلِ"},{"kind":"text","text":"[expl. voce"},{"kind":"arabic","text_bw":"xa$abN","text_ar":"خَشَبٌ"},{"kind":"text","text":"], meaning"},{"kind":"italic_en","text":"clamorous and contentious."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HimaArN Saxibu Al$~awaAribi","text_ar":"حِمَارٌ صَخِبُ الشَّوَارِبِ"},{"kind":"italic_en","text":"An ass that makes his braying to reciprocate"},{"kind":"text","text":"["},{"kind":"italic_en","text":"loudly"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the ducts of his throat;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"that brays vehemently."},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"$rb","text_ar":"شرب"},{"kind":"text","text":", q. v.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EuwdN Saxibu AlA^awotaAri","text_ar":"عُودٌ صَخِبُ الاَوْتَارِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"A lute of which the chords send forth loud sounds"},{"kind":"text","text":"]. (A, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"maA='N","text_ar":"مَا=ءٌ"},{"kind":"arabic","text_bw":"Saxibu AlA=*iY~i","text_ar":"صَخِبُ الا=ذِىِّ"},{"kind":"text","text":"(S, A, * K) and"},{"kind":"arabic","text_bw":"AlA=*iY~i","text_ar":"الا=ذِىِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muSoTaxibu","text_ar":"مُصْطَخِبُ","orth_type":"arrow"},{"kind":"text","text":"(K) (tropical:)"},{"kind":"italic_en","text":"Water of which the waves send forth a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"loud"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound,"},{"kind":"text","text":"(S, TA,) or"},{"kind":"italic_en","text":"are agitated,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"dash together."},{"kind":"text","text":"(TA.) See also what next follows."}],"source_refs":["A","Msb","K","S","L","TA"]}]},"classical_definitions":null}