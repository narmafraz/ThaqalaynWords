{"lemma":"حَشَمُ","slug":"حَشَمُ","root":"ح.ش.م","root_slug":"ح-ش-م","root_link":"/words/roots/ح-ش-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n8120","","n8122","n8123"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B4%D9%8E%D9%85%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tell unpleasant things"},{"pos":"verb","gloss":"to make angry, to irritate"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8120","headword_ar":"حَشِمَ","root":"H$m","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, angry;"},{"kind":"text","text":"(Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AHt$m","text_ar":"احتشم","orth_type":"arrow"},{"kind":"text","text":": (Msb:) or the latter signifies"},{"kind":"italic_en","text":"he became angered."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded and stupified by shame;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ashamed and confounded"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupified, and remained speechless and motionless."},{"kind":"text","text":"(Msb.) See also 8.       -A2-"},{"kind":"arabic","text_bw":"Ha$amahu","text_ar":"حَشَمَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ha$omN","text_ar":"حَشْمٌ"},{"kind":"text","text":"; (Msb;) or"},{"kind":"arabic","text_bw":"Ha$imahu","text_ar":"حَشِمَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He angered him;"},{"kind":"text","text":"(Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AH$mhu","text_ar":"احشمهُ","orth_type":"arrow"},{"kind":"text","text":", (IAar, S, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"H$~mhu","text_ar":"حشّمهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) And, accord. to AZ (S) and El-Fárábee, (Msb,)"},{"kind":"arabic","text_bw":"Ha$amahu","text_ar":"حَشَمَهُ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He annoyed him,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"and said to him what he disliked,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and angered him;"},{"kind":"text","text":"(S, Msb;) namely, a man sitting with him. (S, Msb, K.) An Arab of chaste speech is related to have said,"},{"kind":"arabic","text_bw":"baniY fulaAnK","text_ar":"بَنِى فُلَانٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*`lika mim~aA yuHo$imu","text_ar":"ذٰلِكَ مِمَّا يُحْشِمُ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"That is of the things that anger the sons of such a one."},{"kind":"text","text":"(S.) ―         -b2-  Accord. to IAar, (S,)"},{"kind":"arabic","text_bw":"Ha$amahu","text_ar":"حَشَمَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He caused him to become confounded and stupified by shame;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to become ashamed and confounded"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupified, and to remain speechless and motionless;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"AH$mhu","text_ar":"احشمهُ","orth_type":"arrow"},{"kind":"text","text":": (S, Msb, K:) and both signify"},{"kind":"italic_en","text":"it caused him to be affected with shame, shyness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bashfulness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to shrink;"},{"kind":"text","text":"as in the saying, to one shrinking from food,"},{"kind":"arabic","text_bw":"maA Al~a*iY Ha$amaka","text_ar":"مَا الَّذِى حَشَمَكَ"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"A^aHo$amaka","text_ar":"اَحْشَمَكَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"What caused thee to be affected with shame,"},{"kind":"text","text":"&c.? (TA.)       -A3-"},{"kind":"arabic","text_bw":"Ha$ama","text_ar":"حَشَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He became fat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a good condition of body, after leanness."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Ha$amati Ald~aAb~apu fiY A^aw~ali Alr~abiyEi","text_ar":"حَشَمَتِ الدَّابَّةُ فِى اَوَّلِ الرَّبِيعِ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ha$omN","text_ar":"حَشْمٌ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"The beast obtained somewhat of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"herbage called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"text","text":","},{"kind":"italic_en","text":"in the beginning thereof, and became fat, and in good condition, and large in the belly,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and goodly:"},{"kind":"text","text":"(TA:) or, as En-Nadr says,"},{"kind":"arabic","text_bw":"Ha$amati Ald~awaAb~u","text_ar":"حَشَمَتِ الدَّوَابُّ"},{"kind":"italic_en","text":"the beasts became in good condition."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"maA Ha$ama mino TaEaAminaA","text_ar":"مَا حَشَمَ مِنْ طَعَامِنَا"},{"kind":"italic_en","text":"He ate not of our food"},{"kind":"text","text":"(K, TA) aught. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maA Ha$ama AlS~ayoda","text_ar":"مَا حَشَمَ الصَّيْدَ"},{"kind":"italic_en","text":"He hit not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"found not, the game,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"object of the chase."},{"kind":"text","text":"(K.)       -A4-"},{"kind":"arabic","text_bw":"Ha$ama","text_ar":"حَشَمَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ha$omN","text_ar":"حَشْمٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fatigued, tired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wearied."},{"kind":"text","text":"(K, TA.) The Arabs say,"},{"kind":"arabic","text_bw":"AlHusuwmu yuwrivu AlHu$uwma","text_ar":"الحُسُومُ يُورِثُ الحُشُومَ"},{"kind":"italic_en","text":"Labour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toil, occasions fatigue."},{"kind":"text","text":"(Yoo, TA.)"}],"source_refs":["Msb","K","IAar","S","TA","TK"]},{"entry_id":"n8122","headword_ar":"حَشَمٌ","root":"H$m","body":[{"kind":"text","text":"A man's"},{"kind":"italic_en","text":"special dependents, consisting of his family and slaves"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"others"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"his neighbours, who are angry on his account"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"when an event befalls him;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Hu$omapN","text_ar":"حُشْمَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (Yoo, TA;) in the K, erroneously,"},{"kind":"arabic","text_bw":"Ha$amapN","text_ar":"حَشَمَةٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":"; (K;) which IAar thinks to be pl. of"},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":"used in a sing. sense; (TA;) [for] this word is applied to"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of such persons"},{"kind":"text","text":"] as well as to a pl. number: (K:) you say,"},{"kind":"arabic","text_bw":"h`*aA AlgulaAmu","text_ar":"هٰذَا الغُلَامُ"},{"kind":"arabic","text_bw":"Ha$amN liY","text_ar":"حَشَمٌ لِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This young man,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slave, is a dependent of mine"},{"kind":"text","text":"]: (IAar, TA:) or"},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":"signifies, (ISk, Mgh, Msb,) or signifies also, (K,) a man's"},{"kind":"italic_en","text":"relations and household;"},{"kind":"text","text":"(ISk, Mgh, Msb, K;) or his"},{"kind":"italic_en","text":"servants;"},{"kind":"text","text":"(S, Msb;) and"},{"kind":"italic_en","text":"those who are angry on his account"},{"kind":"text","text":"(ISk, S, Mgh, Msb)"},{"kind":"italic_en","text":"when an event befalls him;"},{"kind":"text","text":"(Mgh, Msb;) for which reason they are thus called: (S:) or a man's"},{"kind":"italic_en","text":"followers;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"those on whose account he should be angry:"},{"kind":"text","text":"(Ham p. 614:) or the"},{"kind":"arabic","text_bw":"Ha$am","text_ar":"حَشَم"},{"kind":"text","text":"of a man are"},{"kind":"italic_en","text":"those who are angry on his account;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"those on whose account he is angry:"},{"kind":"text","text":"(Har p. 164:) accord. to ISk, (Msb,) it is a word having a pl. signification, and having no proper sing.: (Mgh, Msb:) but some say that it has for its pl."},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":": (Mgh:) and accord. to the K, ↓"},{"kind":"arabic","text_bw":"Hu$amaA='u","text_ar":"حُشَمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Ha$omaA'","text_ar":"حَشْمَاء"},{"kind":"text","text":"] signifies"},{"kind":"italic_en","text":"neighbours"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"guests;"},{"kind":"text","text":"as though it were pl. of"},{"kind":"arabic","text_bw":"Ha$iymN","text_ar":"حَشِيمٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"kuramaA='u","text_ar":"كُرَمَا=ءُ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"kariymN","text_ar":"كَرِيمٌ"},{"kind":"text","text":": but [perhaps this should be"},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":"; for] we find in the M,"},{"kind":"arabic","text_bw":"h`w^ulaA='i A^aHo$aAmiY","text_ar":"هٰوُلَا=ءِ اَحْشَامِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"These are my neighbours,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"my guests:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"Hu$umN","text_ar":"حُشُمٌ","orth_type":"arrow"},{"kind":"text","text":", with two dammehs, signifies"},{"kind":"italic_en","text":"slaves;"},{"kind":"text","text":"(IAar, TA;) or, as some say,"},{"kind":"italic_en","text":"followers, whether slaves or free persons."},{"kind":"text","text":"(TA.)       -A2-  Also"},{"kind":"italic_en","text":"An object of desire"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quest;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TalabapN","text_ar":"طَلَبَةٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Talabap","text_ar":"طَلَبَة"},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"huwa Ha$amuhu","text_ar":"هُوَ حَشَمُهُ"},{"kind":"italic_en","text":"It is his object of desire"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quest."},{"kind":"text","text":"(TK.)"}],"source_refs":["K","TA","IAar","ISk","Mgh","Msb","S"]},{"entry_id":"n8123","headword_ar":"حُشُمٌ","root":"H$m","body":[{"kind":"text","text":"Persons"},{"kind":"italic_en","text":"having,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possessing,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"*awuw","text_ar":"ذَوُو"},{"kind":"text","text":", as in the explanation of IAar, for which"},{"kind":"arabic","text_bw":"*uw","text_ar":"ذُو"},{"kind":"text","text":"is erroneously substituted in the copies of the K, TA,)"},{"kind":"italic_en","text":"consummate shame, shyness, bashfulness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pudency."},{"kind":"text","text":"(IAar, K, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}