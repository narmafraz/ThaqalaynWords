{"lemma":"حَجا","slug":"حَجا","root":"ح.ج.#","root_slug":"ح-ج-_","root_link":"/words/roots/ح-ج-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَجَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَجَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَجَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَجَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَجَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَجا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَجَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَجَوا","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَجَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَجَوْا","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَجَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْج","in_corpus":true,"count":13,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَحْجَى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَحْجُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْجِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْجِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْجَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْجَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْجُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْجُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْجُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْجُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْجَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَحْجُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْج","in_corpus":true,"count":76,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْجَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْجُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْج","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْجَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْجُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْجَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْجَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْجُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْجُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْجَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْجُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْجُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْجَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَحْجُوْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْج","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْج","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْجَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْجَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَجَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَجَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْجُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْجُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":154,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n7248","n7252","n7254"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AC%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7248","headword_ar":"حَجَا","root":"Hjw","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"arabic","text_bw":"yaHojuw","text_ar":"يَحْجُو"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"HajowN","text_ar":"حَجْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He thought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opined:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"he thought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opined,"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"and, doing so, claimed"},{"kind":"text","text":"it ("},{"kind":"arabic","text_bw":"Aid~aEaAhu","text_ar":"اِدَّعَاهُ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"not being certain of it:"},{"kind":"text","text":"(K:) [or"},{"kind":"italic_en","text":"he thought it and asserted"},{"kind":"text","text":"it; as appears from a verse here following, cited in the TA as an ex. of the meaning explained as above in the K:] and"},{"kind":"arabic","text_bw":"biZan~ihi","text_ar":"بِظَنِّهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى"},{"kind":"text","text":"alone,"},{"kind":"italic_en","text":"he thought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opined,"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"not being certain of it."},{"kind":"text","text":"(T, TA.) You say,"},{"kind":"arabic","text_bw":"A^anaA A^aHojuw bihi xayorFA","text_ar":"اَنَا اَحْجُو بِهِ خَيْرًا"},{"kind":"italic_en","text":"I think,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opine, that there is good in him."},{"kind":"text","text":"(S, TA.) And Aboo-Shembel says, respecting Aboo-'Amr Esh-Sheybánee,"},{"kind":"quote","text":"qado kunotu A^aHojuw A^abaA EamorKwA^axaAviqapK\n                      \n                     \n                        Hat~aY A^alam~ato binaA yawomFA mulim~aAtu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I used to think and assert Aboo-'Amr to be a trustworthy person, until, one day, misfortunes befell us"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"HajaA Alqawoma ka*aA waka*aA","text_ar":"حَجَا القَوْمَ كَذَا وَكَذَا"},{"kind":"text","text":"(S, K *)"},{"kind":"italic_en","text":"He repaid, requited, compensated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompensed, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, such and such things,"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"jazaAhumo","text_ar":"جَزَاهُمْ"},{"kind":"text","text":"; [so in my copies of the S, and in the K; but Freytag gives, as the reading found by him in the S,"},{"kind":"arabic","text_bw":"HzAhm","text_ar":"حزاهم"},{"kind":"text","text":", as though meaning"},{"kind":"italic_en","text":"he computed them by conjecture to be such and such in number;"},{"kind":"text","text":"which is agreeable with what follows;] and"},{"kind":"italic_en","text":"he thought them to be so."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"italic_en","text":"He directed himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aim, to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards,"},{"kind":"text","text":"him, or it: (Az, TA:) and ↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"italic_en","text":"he directed himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aim, to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, the thing."},{"kind":"text","text":"(S, TA.)       -A3-  Also, (K,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"He kept"},{"kind":"text","text":"a secret: (K:) or"},{"kind":"italic_en","text":"he concealed"},{"kind":"text","text":"it: (AZ, TA:) [and ↓"},{"kind":"arabic","text_bw":"HaAjiY","text_ar":"حَاجِى","orth_type":"arrow"},{"kind":"text","text":"has a similar meaning; for] you say,"},{"kind":"arabic","text_bw":"laAmuHaAjaApa EinodiY","text_ar":"لَامُحَاجَاةَ عِنْدِى"},{"kind":"arabic","text_bw":"fiY ka*aA","text_ar":"فِى كَذَا"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"There is no concealment with me in respect of such a thing;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"lA mukaAfaA^apa","text_ar":"لا مُكَافَاَةَ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"laA yaHojuw A_ibilahu","text_ar":"لَا يَحْجُو اـِبِلَهُ"},{"kind":"text","text":", said of a pastor,"},{"kind":"italic_en","text":"He does not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will not, keep and tend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasture and defend, his camels."},{"kind":"text","text":"(TA.) One says also of a pastor whose sheep or goats [and camels] are lost by him, and become dispersed,"},{"kind":"arabic","text_bw":"maA yaHojuw ganamahu walaA A_ibilahu","text_ar":"مَا يَحْجُو غَنَمَهُ وَلَا اـِبِلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He does not keep his sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, nor his camels, from being lost and becoming dispersed"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"siq~A='N laA yaHojuw AlmaA='a","text_ar":"سِقّا=ءٌ لَا يَحْجُو المَا=ءَ"},{"kind":"italic_en","text":"A skin that will not hold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retain, water."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"maAHajawotu minohu","text_ar":"مَاحَجَوْتُ مِنْهُ"},{"kind":"arabic","text_bw":"$ayoy^FA","text_ar":"شَيْيًا"},{"kind":"italic_en","text":"I did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retain in my memory, of it, aught;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"mA hajawotu","text_ar":"ما هَجَوْتُ"},{"kind":"text","text":". (Ks, TA.)       -A4-  Also, (K,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld."},{"kind":"text","text":"(K, TA.) [See"},{"kind":"arabic","text_bw":"HijFA","text_ar":"حِجًا"},{"kind":"text","text":".]       -A5-"},{"kind":"arabic","text_bw":"HaAjayotuhu","text_ar":"حَاجَيْتُهُ"},{"kind":"arabic","text_bw":"faHajawotuhu","text_ar":"فَحَجَوْتُهُ"},{"kind":"text","text":": see 3.       -A6-"},{"kind":"arabic","text_bw":"HajaA biAlomakaAni","text_ar":"حَجَا بِالْمَكَانِ"},{"kind":"text","text":", (S, K,) inf. n. as above, (K,)"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"and became fixed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therein"},{"kind":"text","text":"]; (TA;) as also"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"HajaA","text_ar":"حَجَا"},{"kind":"text","text":", (IAar, K,) inf. n. as above, (IAar,)"},{"kind":"italic_en","text":"He stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused."},{"kind":"text","text":"(IAar, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"HajaA bihi","text_ar":"حَجَا بِهِ"},{"kind":"text","text":", [inf. n. as above, (see Ham p. 523,)]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tenacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious, of it,"},{"kind":"text","text":"namely, a thing; (S, K;) as also"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"HajiY bihi","text_ar":"حَجِى بِهِ"},{"kind":"text","text":", (Fr, S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajFY","text_ar":"حَجًى"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"HajFA","text_ar":"حَجًا"},{"kind":"text","text":"], (TK,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became attached to it, and clave to it;"},{"kind":"text","text":"(Fr, S, K;) as also"},{"kind":"arabic","text_bw":"Hajiy^a bh","text_ar":"حَجِيَ به"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":"; (Fr, S;) and"},{"kind":"arabic","text_bw":"tHj~A^bh","text_ar":"تحجّابه"},{"kind":"text","text":". (Fr, TA.) ↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He kept to the"},{"kind":"arabic","text_bw":"HajaA","text_ar":"حَجَا"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"place of bending"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turning of a valley."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"bih`*aA AlmakaAni","text_ar":"بِهٰذَا المَكَانِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taHaj~ayotu","text_ar":"تَحَجَّيْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I preceded you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outwent you, to this place, and clave to it before you."},{"kind":"text","text":"(S, TA.) And [hence,]"},{"kind":"arabic","text_bw":"bihimo","text_ar":"بِهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHj~Y","text_ar":"تحجّى","orth_type":"arrow"},{"kind":"text","text":"is said to mean (assumed tropical:)"},{"kind":"italic_en","text":"He was first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foremost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quick, to blame them."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"HajiYa","text_ar":"حَجِىَ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", (TA,) is also [said to be]"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"EadaA","text_ar":"عَدَا"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He ran;"},{"kind":"text","text":"(TK;) thus bearing two contr. significations: (K:) but this requires consideration. (TA.) ―         -b4-  [Golius, as on the authority of the KL, assigns to it also the meaning “ Hilaris et lubens fuit: ” but in this sense it is said in the KL to be with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"for its last radical letter: see art."},{"kind":"arabic","text_bw":"HjA^","text_ar":"حجا"},{"kind":"text","text":".]"}],"source_refs":["S","K","TA","Az","AZ","IAar","Fr","TK"]},{"entry_id":"n7252","headword_ar":"حَجًا","root":"Hjw","body":[{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"HajFY","text_ar":"حَجًى"},{"kind":"italic_en","text":"A side, region, quarter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract"},{"kind":"text","text":": (S, Msb, K, TA:) and"},{"kind":"italic_en","text":"an extremity"},{"kind":"text","text":": (TA:) pl."},{"kind":"arabic","text_bw":"A^aHajaA='N","text_ar":"اَحَجَا=ءٌ"},{"kind":"text","text":". (S, Msb.) ―         -b2-"},{"kind":"italic_en","text":"A refuge; a place to which one has recourse for refuge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protection;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"maHojFY","text_ar":"مَحْجًى","orth_type":"arrow"},{"kind":"text","text":"(Lh, TA) and"},{"kind":"arabic","text_bw":"maHojaA^N","text_ar":"مَحْجَاٌ"},{"kind":"text","text":". (Lh, K in art."},{"kind":"arabic","text_bw":"HjA^","text_ar":"حجا"},{"kind":"text","text":".) ―         -b3-"},{"kind":"italic_en","text":"Elevated ground."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"italic_en","text":"A place of bending"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turning"},{"kind":"text","text":"of a valley. (TA.) ―         -b5-"},{"kind":"italic_en","text":"Anything by which one is veiled, concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected;"},{"kind":"text","text":"(Mgh, Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"HijFA","text_ar":"حِجًا","orth_type":"arrow"},{"kind":"text","text":". (Mgh, TA.) [Hence applied to"},{"kind":"italic_en","text":"A parapet"},{"kind":"text","text":"on the top of a house; as is indicated in the Mgh and TA.]       -A2-"},{"kind":"italic_en","text":"Bubbles upon water, arising from the drops of rain"},{"kind":"text","text":": pl. [or rather coll. gen. n.] of ↓"},{"kind":"arabic","text_bw":"HajaApN","text_ar":"حَجَاةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, K: [in the CK, erroneously,"},{"kind":"arabic","text_bw":"HijAp","text_ar":"حِجاة"},{"kind":"text","text":":]) the latter word, which is like"},{"kind":"arabic","text_bw":"HaSaApN","text_ar":"حَصَاةٌ"},{"kind":"text","text":", is explained by Az as signifying"},{"kind":"italic_en","text":"a bubble that rises upon water, like a flask;"},{"kind":"text","text":"and as having for its pl."},{"kind":"arabic","text_bw":"HajawaAtN","text_ar":"حَجَوَاتٌ"},{"kind":"text","text":": and the same word ("},{"kind":"arabic","text_bw":"HjAp","text_ar":"حجاة"},{"kind":"text","text":") signifies also"},{"kind":"italic_en","text":"a pool of water,"},{"kind":"text","text":"itself,"},{"kind":"italic_en","text":"such as is left by a torrent."},{"kind":"text","text":"(TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"HajiY~N","text_ar":"حَجِىٌّ"},{"kind":"text","text":".       -A4-"},{"kind":"arabic","text_bw":"HajaA","text_ar":"حَجَا"},{"kind":"text","text":"is also used, by poetic license, for"},{"kind":"arabic","text_bw":"HajaAj","text_ar":"حَجَاج"},{"kind":"text","text":", q. v. (TA in art."},{"kind":"arabic","text_bw":"Hj","text_ar":"حج"},{"kind":"text","text":".)"}],"source_refs":["S","Msb","K","TA","Lh"]},{"entry_id":"n7254","headword_ar":"حِجًا","root":"Hjw","body":[{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"HijFY","text_ar":"حِجًى"},{"kind":"italic_en","text":"Intelligence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"sagacity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill and knowledge"},{"kind":"text","text":": (K:) [said to be] from"},{"kind":"arabic","text_bw":"HajaA","text_ar":"حَجَا"},{"kind":"text","text":"meaning “ he, or it, prevented, or withheld; ” because it prevents, or withholds, a man from doing that which is bad, or corrupt. (TA.)       -A2-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"miqodaArN","text_ar":"مِقْدَارٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Quantity, measure,"},{"kind":"text","text":"&c.]: pl."},{"kind":"arabic","text_bw":"A^aHojaA='N","text_ar":"اَحْجَا=ءٌ"},{"kind":"text","text":". (K.)       -A3-  See also"},{"kind":"arabic","text_bw":"HajFA","text_ar":"حَجًا"},{"kind":"text","text":".       -A4-  [Also said by Golius, as on the authority of J, to signify “ an enigma, ” as though syn. with"},{"kind":"arabic","text_bw":"A^uHojiy~apN","text_ar":"اُحْجِيَّةٌ"},{"kind":"text","text":"; but I have not found it in this sense in any copy of the S, nor in any other lexicon.]"}],"source_refs":["K"]}]}}