unt":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطَّرِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطَّرِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطَّرِد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطَّرِد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطَّرِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطَّرِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطَّرِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطَّرِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطَّرِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطَّرِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطَّرِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَطَّرِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطَّرِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِطَّرَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِطَّرَدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n26551"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B7%D9%8E%D9%91%D8%B1%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26551","headword_ar":"اِطَّرَدَ","root":"Trd","body":[{"kind":"text","text":", as trans.: see 1, first sentence.       -A2-  As quasi-pass.: see 1, second sentence. ―         -b2-"},{"kind":"arabic","text_bw":"AiT~arada","text_ar":"اِطَّرَدَ"},{"kind":"arabic","text_bw":"AlmaA='u","text_ar":"المَا=ءُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The water flowed in a regular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a continuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an uninterrupted, course, one portion following another:"},{"kind":"text","text":"(A, * L, Msb:) and"},{"kind":"arabic","text_bw":"AT~rdt","text_ar":"اطّردت"},{"kind":"arabic","text_bw":"AlA^anohaAru","text_ar":"الاَنْهَارُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The rivers so flowed:"},{"kind":"text","text":"(Msb:) or [simply]"},{"kind":"italic_en","text":"the rivers ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"AiDoTarada Alxayolu","text_ar":"اِضْطَرَدَ الخَيْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The horses ran, following one another:"},{"kind":"text","text":"occurring in a trad.: the verb is originally"},{"kind":"arabic","text_bw":"AiTotarada","text_ar":"اِطْتَرَدَ"},{"kind":"text","text":"; the augmentative"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":", and then the radical"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":": (L:) and for"},{"kind":"arabic","text_bw":"AiDoTiraAdN","text_ar":"اِضْطِرَادٌ"},{"kind":"text","text":", some say"},{"kind":"arabic","text_bw":"AiloTiraAdN","text_ar":"اِلْطِرَادٌ"},{"kind":"text","text":", changing the"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"[as in"},{"kind":"arabic","text_bw":"AiloTajaEa","text_ar":"اِلْطَجَعَ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AiDoTajaEa","text_ar":"اِضْطَجَعَ"},{"kind":"text","text":"]. (Az, TA in art."},{"kind":"arabic","text_bw":"DjE","text_ar":"ضجع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"AT~rdwA A_ilaY Almasiyri","text_ar":"اطّردوا اـِلَى المَسِيرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They followed one another to go on a journey."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"AT~rd Al$~aYo'u","text_ar":"اطّرد الشَّىْءُ"},{"kind":"text","text":", (S, A, L,) or"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":", (Msb, K,) (tropical:)"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the affair, followed a regular and con. tinuous course, one part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stage, following another"},{"kind":"page_break","n":1839},{"kind":"italic_en","text":"uninterruptedly:"},{"kind":"text","text":"(S, A, L, Msb, K:) and"},{"kind":"arabic","text_bw":"AT~rd","text_ar":"اطّرد"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"the affair followed a right, a direct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an even, course."},{"kind":"text","text":"(S, L, K.) And"},{"kind":"arabic","text_bw":"AT~rd AlkalaAmu","text_ar":"اطّرد الكَلَامُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The language,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech, was consecutive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninterrupted, in its parts."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"AT~rdt qiraA='atuhu","text_ar":"اطّردت قِرَا=ءَتُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His recitation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reading, continued uninterruptedly:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"yawomN Tar~aAdN","text_ar":"يَوْمٌ طَرَّادٌ"},{"kind":"text","text":"meaning “ a long day. ” (Mgh.) And"},{"kind":"arabic","text_bw":"AT~rd AlHad~u","text_ar":"اطّرد الحَدُّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The definition was of uniform, undeviating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"general, application; it uniformly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commonly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly, applied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"all the things to which it related followed one uniform,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"undeviating, way, like the course of rivers."},{"kind":"text","text":"(Msb. [And in like manner one says of a rule.])"},{"kind":"arabic","text_bw":"AT~rd","text_ar":"اطّرد"},{"kind":"text","text":"said of a word, form or measure, construction, or government, means (tropical:)"},{"kind":"italic_en","text":"It was agreeable with the common,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, course of speech in respect of analogy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rule; it was agreeable with common,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, analogy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rule:"},{"kind":"text","text":"and, said of the same, or of a rule,"},{"kind":"italic_en","text":"it was agreeable with the common,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, course of speech in respect of usage; it was agreeable with common,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, usage; it commonly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly, obtained:"},{"kind":"text","text":"[the verb is used absolutely to express each of these two meanings; the context in general showing clearly which meaning is intended:] the former meaning is also expressed by the phrase"},{"kind":"arabic","text_bw":"AT~rd fiY AlqiyaAsi","text_ar":"اطّرد فِى القِيَاسِ"},{"kind":"text","text":"; and the latter, by the phrase"},{"kind":"arabic","text_bw":"AT~rd fiY AlAisotiEomaAli","text_ar":"اطّرد فِى الاِسْتِعْمَالِ"},{"kind":"text","text":". (Mz, 12th"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":". [See also the contr."},{"kind":"arabic","text_bw":"$a*~a","text_ar":"شَذَّ"},{"kind":"text","text":": and see"},{"kind":"arabic","text_bw":"muT~aridN","text_ar":"مُطَّرِدٌ"},{"kind":"text","text":", below.])"}],"source_refs":["Msb","L","S","A","K"]}]},"classical_definitions":null}