{"lemma":"رُبِّ","slug":"رُبِّ","root":"ر.ب.ب","root_slug":"ر-ب-ب","root_link":"/words/roots/ر-ب-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رُبِّ","root":"ربو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["adj","adv","noun","verb"],"has_etymology":true,"sense_count":19},"lanes":{"found":true,"entry_ids":["n14365","n14366","n14367","n14368","n14369","n14370"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D8%A8%D9%90%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be master, to be lord"},{"pos":"verb","gloss":"to have possession, to gather, to control"},{"pos":"verb","gloss":"to have authority over, to govern"},{"pos":"verb","gloss":"to impact, to comprise, to contain"},{"pos":"verb","gloss":"to collect, to congregate"},{"pos":"verb","gloss":"to grow, to increase, to become greater"},{"pos":"verb","gloss":"to bring up, to raise (a child)"},{"pos":"noun","gloss":"master, lord, king, sovereign, potentate","examples":[{"text":"رَبُّ الدَّار","english":"master of the house"},{"text":"رَبُّ الْعَائِلَة","english":"paterfamilias"}]},{"pos":"noun","gloss":"Lord, an epithet of God","examples":[{"text":"اَللهُ رَبُّ الْعَالَمِين","english":"God is Lord of the Worlds"},{"text":"الرَّبّ","english":"the LORD"}]},{"pos":"noun","gloss":"god, deity","examples":[{"text":"يَا صَاحِبَيِ السِّجْنِ أَأَرْبَابٌ مُّتَفَرِّقُونَ خَيْرٌ أَمِ اللّٰهُ الْوَاحِدُ الْقَهَّارُ","english":"[Joseph said:] \"O my two companions of the prison! Are many different deities better than God the One [Who is the Source of all things], the Overpowering?\""}]},{"pos":"noun","gloss":"leader, chief, head","examples":[{"text":"رَبُّ بَحْرِيّ","english":"seaman (naval rank)"}]},{"pos":"noun","gloss":"owner, proprietor"},{"pos":"noun","gloss":"one possessed of, one endowed with"},{"pos":"noun","gloss":"having to do with"},{"pos":"noun","gloss":"verbal noun of رَبَّ (rabba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thickened fruit juice, thickened juice"},{"pos":"noun","gloss":"mash, pulp"},{"pos":"adj","gloss":"many","examples":[{"text":"رُبَّ رَجُلٍ","english":"many a man"},{"text":"رُبَّ مَرَّةٍ","english":"many a time"}]},{"pos":"adv","gloss":"likely, perhaps, mayhap, potentially"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *rabb-."},"ipa":["/rab.ba/","/rabb/","/rubb/","/rub.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14365","headword_ar":"رَبْ","root":"rb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raA^aba","text_ar":"رَاَبَ"},{"kind":"text","text":", of which it is an imperative."}],"source_refs":[]},{"entry_id":"n14366","headword_ar":"رُبَ","root":"rb","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raba","text_ar":"رَبَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubu","text_ar":"رُبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubo","text_ar":"رُبْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabo","text_ar":"رَبْ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"rubamaA","text_ar":"رُبَمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabamaA","text_ar":"رَبَمَا"},{"kind":"text","text":"&c.: see"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14367","headword_ar":"رَبٌ","root":"rb","body":[{"kind":"text","text":": see the next paragraph, last sentence but one."}],"source_refs":[]},{"entry_id":"n14368","headword_ar":"رَبٌّ","root":"rb","body":[{"kind":"italic_en","text":"A lord, a possessor, an owner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a proprietor,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maAlikN","text_ar":"مَالِكٌ"},{"kind":"text","text":", (T, IAmb, S, M, A, Msb, K,) of a thing, (T,) of anything, (S, M, A, K,) or of an irrational thing; (Msb;)"},{"kind":"italic_en","text":"a person who has a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just title"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claim, to the possession"},{"kind":"text","text":"of anything; or its"},{"kind":"arabic","text_bw":"SaAHib","text_ar":"صَاحِب"},{"kind":"text","text":"[which is syn. with"},{"kind":"arabic","text_bw":"maAlik","text_ar":"مَالِك"},{"kind":"text","text":"]; (M, A, K;)"},{"kind":"arabic","text_bw":"rab~N","text_ar":"رَبٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maAlikN","text_ar":"مَالِكٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SaAHibN","text_ar":"صَاحِبٌ"},{"kind":"text","text":"all signifying in Pers."},{"kind":"arabic","text_bw":"xudaAwanod","text_ar":"خُدَاوَنْد"},{"kind":"text","text":": (KL:) and"},{"kind":"italic_en","text":"a lord, master,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief;"},{"kind":"text","text":"(Msb, TA;) or"},{"kind":"italic_en","text":"a lord, master,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, to whom obedience is paid:"},{"kind":"text","text":"(IAmb, TA:) and"},{"kind":"italic_en","text":"a lord, ruler, governor, regulator,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposer;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"an orderer, a rectifier,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reformer:"},{"kind":"text","text":"(IAmb, TA:)"},{"kind":"italic_en","text":"a rearer, fosterer, bringer-up, feeder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nourisher:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a completer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an accomplisher:"},{"kind":"text","text":"(TA:) it is an epithet, like"},{"kind":"arabic","text_bw":"nam~N","text_ar":"نَمٌّ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"nam~a","text_ar":"نَمَّ"},{"kind":"text","text":": or an inf. n. used as an intensive epithet; like"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":"; (Ksh and Bd * in i. l;) originally signifying the “ bringing (a thing) to a state of completion by degrees;” (Bd, ibid.;) then used in the sense of"},{"kind":"arabic","text_bw":"maAlikN","text_ar":"مَالِكٌ"},{"kind":"text","text":": (Ksh and Bd ibid.:) the pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A^arobaAbN","text_ar":"اَرْبَابٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"rubuwbN","text_ar":"رُبُوبٌ"},{"kind":"text","text":", (M, K,) and accord. to Sh,"},{"kind":"arabic","text_bw":"ribaAbN","text_ar":"رِبَابٌ"},{"kind":"text","text":"also, (TA,) signifying"},{"kind":"arabic","text_bw":"A^aSoHaAbN","text_ar":"اَصْحَابٌ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"rabuwbN","text_ar":"رَبُوبٌ","orth_type":"arrow"},{"kind":"text","text":"is app. a quasi-pl. n.: (M:) the fem. is ↓"},{"kind":"arabic","text_bw":"rab~apN","text_ar":"رَبَّةٌ","orth_type":"arrow"},{"kind":"text","text":"; of which the pl. is"},{"kind":"arabic","text_bw":"rab~aAtN","text_ar":"رَبَّاتٌ"},{"kind":"text","text":". (T.) Whoever possesses a thing is its"},{"kind":"arabic","text_bw":"rab~","text_ar":"رَبّ"},{"kind":"text","text":": you say,"},{"kind":"arabic","text_bw":"huwa rab~u Ald~aAb~api","text_ar":"هُوَ رَبُّ الدَّابَّةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is the possessor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"owner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"master, of the beast"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Ald~aAri","text_ar":"الدَّارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the house"},{"kind":"text","text":"], (T,) and"},{"kind":"arabic","text_bw":"AlmaAli","text_ar":"المَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cattle"},{"kind":"text","text":"]; (Msb;) and"},{"kind":"arabic","text_bw":"Albayoti","text_ar":"البَيْتِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"hiYa rab~apu","text_ar":"هِىَ رَبَّةُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She is the owner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mistress, of the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent"},{"kind":"text","text":"]. (T.) With the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", it is [properly] applied only to"},{"kind":"italic_en","text":"God:"},{"kind":"text","text":"(T, S, M, A, Msb, K:) He is"},{"kind":"arabic","text_bw":"rab~u AlA^arobaAbi","text_ar":"رَبُّ الاَرْبَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The Lord of lords"},{"kind":"text","text":"]. (T. [Thus the pl. with the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"is applied to created beings.]) To any other being it is not [properly] applied but as a prefixed noun governing another noun as its complement in the gen. case [or in a similar manner]. (S.) The pagan Arabs, however, sometimes applied it to A"},{"kind":"italic_en","text":"king,"},{"kind":"text","text":"(S,) or to a"},{"kind":"italic_en","text":"lord"},{"kind":"text","text":"as meaning a"},{"kind":"italic_en","text":"master"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief:"},{"kind":"text","text":"(Msb:) El- Hárith says, (S, Msb,) i. e. Ibn-Hillizeh, (S,)"},{"kind":"quote","text":"wahuwa Alr~ab~u waAl$~ahiydu EalaY yuwo\n                      \n                     \n                        mi AlHiyaArayoni waAlbalaA='u balaA='u"},{"kind":"text","text":"(S, Msb,) i. e."},{"kind":"italic_en","text":"And he"},{"kind":"text","text":"(meaning El-Mundhir Ibn-Má-es-Semà, or, as some say, 'Amr Ibn-Hind,)"},{"kind":"italic_en","text":"was the king"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lord"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and witness of"},{"kind":"text","text":"our fighting on"},{"kind":"italic_en","text":"the day of El-Hiyárán"},{"kind":"text","text":"(the name of a place),"},{"kind":"italic_en","text":"and the trial was a"},{"kind":"text","text":"hard"},{"kind":"italic_en","text":"trial."},{"kind":"text","text":"(EM, p. 285: [in which"},{"kind":"arabic","text_bw":"AlHayaArayoni","text_ar":"الحَيَارَيْنِ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"AlHiyaArayoni","text_ar":"الحِيَارَيْنِ"},{"kind":"text","text":".]) Some forbid that a man should be called the"},{"kind":"arabic","text_bw":"rab~","text_ar":"رَبّ"},{"kind":"text","text":"of his slave: (Msb:) it is said in a trad. that the slave shall not say to his master,"},{"kind":"arabic","text_bw":"rab~Y","text_ar":"رَبّى"},{"kind":"text","text":", because it is like attributing a partner to God: (TA:) but"},{"kind":"arabic","text_bw":"rab~","text_ar":"رَبّ"},{"kind":"text","text":"is sometimes used in the sense of"},{"kind":"italic_en","text":"lord"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"master"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief"},{"kind":"text","text":"prefixed to a noun signifying a rational being governed by it in the gen. case: thus in the saying of the Prophet,"},{"kind":"arabic","text_bw":"Hat~aY talida AlA^amapu rab~ahaA","text_ar":"حَتَّى تَلِدَ الاَمَةُ رَبَّهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"So that the female slave shall bring forth"},{"kind":"text","text":"him who will become"},{"kind":"italic_en","text":"her master"},{"kind":"text","text":"], or ↓"},{"kind":"arabic","text_bw":"rab~atahaA","text_ar":"رَبَّتَهَا","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"her mistress"},{"kind":"text","text":"], accord. to different transmitters; (Msb;) relating to the signs of the hour of resurrection: i. e., the female slave shall bring forth to her master a child that shall be as a master [or mistress] to her because like his [or her] father in rank: meaning that captives and concubines shall be numerous. (TA.) As to the phrase in the Kur [xii. 42],"},{"kind":"arabic","text_bw":"Au*okuroniY Einoda rab~ika","text_ar":"اُذْكُرْنِى عِنْدَ رَبِّكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Mention thou me in the presence of thy lord"},{"kind":"text","text":"], Joseph thus addressed his fellow-prisoner agreeably with the acceptation in which he [the latter] understood the words. (TA.) A similar instance also occurs in the same chapter, in the verse immediately preceding. (Msb.) In another verse, [23 of the same ch.,]"},{"kind":"arabic","text_bw":"A_in~ahu rab~iY","text_ar":"اـِنَّهُ رَبِّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily he is my lord"},{"kind":"text","text":"] may refer to Joseph's master or to God. (M, TA.) The words of the Kur [lxxxix. 28 and 29],"},{"kind":"arabic","text_bw":"AirojiEiY A_ilaY rab~iki raADiyapF","text_ar":"اِرْجِعِى اـِلَى رَبِّكِ رَاضِيَةً"},{"kind":"arabic","text_bw":"maroDiy~apF faA@doxuliY fiY EabodYi","text_ar":"مَرْضِيَّةً فَا@دْخُلِى فِى عَبْدىِ"},{"kind":"text","text":", as some read, [instead of"},{"kind":"arabic","text_bw":"EibaAdiY","text_ar":"عِبَادِى"},{"kind":"text","text":",] may mean"},{"kind":"italic_en","text":"Return to thine owner,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"approving, approved,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and enter into my servant."},{"kind":"text","text":"(M, TA.) ―         -b2-  Without the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", as some say, (L, TA,) it is sometimes written and pronounced ↓"},{"kind":"arabic","text_bw":"rabN","text_ar":"رَبٌ","orth_type":"arrow"},{"kind":"text","text":", without teshdeed; (L, K;) as in the following verse, cited by El-Mufaddal,"},{"kind":"quote","text":"waqado Ealima AlA^aqowaAmu A^ano layosa fawoqahu\n                      \n                     \n                        rabN gayoru mano yaEoTiY AlHuZuwZa wayarozuqu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the peoples have known that there is not above him a lord beside Him who gives the portions"},{"kind":"text","text":"of mankind and of others"},{"kind":"italic_en","text":"and grants the means of subsistence"},{"kind":"text","text":"]. (L.) And Ahmad Ibn-Yahyà [i. e. Th] mentions the phrase"},{"kind":"arabic","text_bw":"laA warabiyka laA","text_ar":"لَا وَرَبِيكَ لَا"},{"kind":"arabic","text_bw":"A^afoEalu","text_ar":"اَفْعَلُ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"laA warab~ika","text_ar":"لَا وَرَبِّكَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"No, by thy Lord, I will not do"},{"kind":"text","text":"such a thing]; the [latter]"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"because of the reduplication. (M, K: * in the CK"},{"kind":"arabic","text_bw":"raboyika","text_ar":"رَبْيِكَ"},{"kind":"text","text":".)"}],"source_refs":["T","IAmb","S","M","A","Msb","K","KL","TA","L"]},{"entry_id":"n14369","headword_ar":"رُبَّ","root":"rb","body":[{"kind":"text","text":"is a word of which there are seventy dial. vars., all mentioned by Zekereeyà El-Ansáree in his great Expos. of the “ Munferijeh, ” but only eighteen of which are mentioned in the K, including some that are formed with the affix"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":", some with the affix"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":", and some with both these affixes together; as follows: (TA:)"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"(T, S, M, Msb, Mughnee, K, &c.) and"},{"kind":"arabic","text_bw":"rab~a","text_ar":"رَبَّ"},{"kind":"text","text":"(T, M, Mughnee, K) and"},{"kind":"arabic","text_bw":"rub~u","text_ar":"رُبُّ"},{"kind":"text","text":", (Mughnee,) and ↓"},{"kind":"arabic","text_bw":"ruba","text_ar":"رُبَ","orth_type":"arrow"},{"kind":"text","text":"(T, S, M, Mughnee, K) and"},{"kind":"arabic","text_bw":"raba","text_ar":"رَبَ"},{"kind":"text","text":"(T, M, Mughnee, K) and"},{"kind":"arabic","text_bw":"rubu","text_ar":"رُبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubo","text_ar":"رُبْ"},{"kind":"text","text":"(Mughnee, K) and"},{"kind":"arabic","text_bw":"rabo","text_ar":"رَبْ"},{"kind":"text","text":"; (Mughnee;) and ↓"},{"kind":"arabic","text_bw":"rub~ata","text_ar":"رُبَّتَ","orth_type":"arrow"},{"kind":"text","text":"(T, S, M, Msb, Mughnee, K) and"},{"kind":"arabic","text_bw":"rab~ata","text_ar":"رَبَّتَ"},{"kind":"text","text":"(M, Mughnee, K) and"},{"kind":"arabic","text_bw":"rub~uta","text_ar":"رُبُّتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~atu","text_ar":"رُبَّتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~atu","text_ar":"رَبَّتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~utu","text_ar":"رُبُّتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~ati","text_ar":"رُبَّتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~ati","text_ar":"رَبَّتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~uti","text_ar":"رُبُّتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~ut","text_ar":"رَبُّت"},{"kind":"text","text":"(TA)"},{"kind":"page_break","n":1004},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~ato","text_ar":"رُبَّتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~ato","text_ar":"رَبَّتْ"},{"kind":"text","text":"(Mughnee) and"},{"kind":"arabic","text_bw":"rub~uto","text_ar":"رُبُّتْ"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"rubata","text_ar":"رُبَتَ","orth_type":"arrow"},{"kind":"text","text":"(T, Mughnee, K) and"},{"kind":"arabic","text_bw":"rabata","text_ar":"رَبَتَ"},{"kind":"text","text":"(Mughnee, K) and"},{"kind":"arabic","text_bw":"rubuta","text_ar":"رُبُتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubota","text_ar":"رُبْتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabota","text_ar":"رَبْتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubatu","text_ar":"رُبَتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabatu","text_ar":"رَبَتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubutu","text_ar":"رُبُتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubotu","text_ar":"رُبْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabotu","text_ar":"رَبْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubati","text_ar":"رُبَتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabati","text_ar":"رَبَتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubuti","text_ar":"رُبُتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabuti","text_ar":"رَبُتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruboti","text_ar":"رُبْتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raboti","text_ar":"رَبْتِ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"rubato","text_ar":"رُبَتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabato","text_ar":"رَبَتْ"},{"kind":"text","text":"(Mughnee) and"},{"kind":"arabic","text_bw":"rubuto","text_ar":"رُبُتْ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"rub~amaA","text_ar":"رُبَّمَا"},{"kind":"text","text":"(T, S, M, K) and"},{"kind":"arabic","text_bw":"rab~amaA","text_ar":"رَبَّمَا"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"rub~umaA","text_ar":"رُبُّمَا"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"rubamaA","text_ar":"رُبَمَا","orth_type":"arrow"},{"kind":"text","text":"(T, K) and"},{"kind":"arabic","text_bw":"rabamaA","text_ar":"رَبَمَا"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"rubumaA","text_ar":"رُبُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubomaA","text_ar":"رُبْمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabomaA","text_ar":"رَبْمَا"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"rub~atamaA","text_ar":"رُبَّتَمَا","orth_type":"arrow"},{"kind":"text","text":"(T, S, M, K) and"},{"kind":"arabic","text_bw":"rab~atamaA","text_ar":"رَبَّتَمَا"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"rub~utamaA","text_ar":"رُبُّتَمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~atumaA","text_ar":"رُبَّتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~atumaA","text_ar":"رَبَّتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~utumaA","text_ar":"رُبُّتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~atomaA","text_ar":"رُبَّتْمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rab~atomaA","text_ar":"رَبَّتْمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~utomaA","text_ar":"رُبُّتْمَا"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"rubatamaA","text_ar":"رُبَتَمَا","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabatamaA","text_ar":"رَبَتَمَا"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"rubutamaA","text_ar":"رُبُتَمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubotamaA","text_ar":"رُبْتَمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabotamaA","text_ar":"رَبْتَمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubatumaA","text_ar":"رُبَتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabatumaA","text_ar":"رَبَتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubutumaA","text_ar":"رُبُتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubotumaA","text_ar":"رُبْتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabotumaA","text_ar":"رَبْتُمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubatomaA","text_ar":"رُبَتْمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabatomaA","text_ar":"رَبَتْمَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubutomaA","text_ar":"رُبُتْمَا"},{"kind":"text","text":": (TA:) [of all these, the most common are"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~amaA","text_ar":"رُبَّمَا"},{"kind":"text","text":": and] ↓"},{"kind":"arabic","text_bw":"rub~ata","text_ar":"رُبَّتَ","orth_type":"arrow"},{"kind":"text","text":"is the most common of the forms that have the affix"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":": (Mughnee and K on the letter"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":":) and the forms with teshdeed are more common than the [corresponding] forms without teshdeed. (M.) It is a word, (M,) or particle, (T, S, Mughnee, K,) governing the gen. case: (S, M, Mughnee, K:) or a noun, (K, TA,) [i. e. an indecl. noun,] in the opinion of the Koofees and some others; but this opinion is rejected by Ibn-Málik in the Tesheel and its Expos., and by AHei, and by IHsh in the Mughnee. (TA.) Accord. to some, (K, TA,) it is used to denote a small number, (T, M, Msb, K, TA,) always, (TA,) or mostly: (Msb, TA:) [thus it may be rendered"},{"kind":"italic_en","text":"Few"},{"kind":"text","text":"if we render the noun following it as a pl.; and"},{"kind":"italic_en","text":"scarce any"},{"kind":"text","text":"if we render the noun following as a sing. or a pl.:] it is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"kamo","text_ar":"كَمْ"},{"kind":"text","text":"when this latter is not used interrogatively: (T:) [and with"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"affixed, restricting it from government, it may be rendered"},{"kind":"italic_en","text":"Few times,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seldom:"},{"kind":"text","text":"] or it is used to denote a large number; (K, TA;) i. e. always: so says IDrst: (TA:) [thus used, but such is not always the case, it may be rendered"},{"kind":"italic_en","text":"Many,"},{"kind":"text","text":"whether we render the noun following it as a sing. or as a pl.: and with"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"affixed,"},{"kind":"italic_en","text":"Many times, many a time, oftentimes, ofttimes, often,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frequently:"},{"kind":"text","text":"] or it is used to denote a small and a large number; (Mughnee, K;) often the latter, and seldom the former: (Mughnee:) or it is used in a case of boasting, or glorying, (K, TA,) exclusively of other cases, (TA,) to denote a large number: (K, TA:) or it does not denote by itself either a small number or a large number; but one or the other of these meanings is inferred from the context: (K:) [but sometimes neither of these meanings can be clearly inferred from the context: in these cases, it may be rendered"},{"kind":"italic_en","text":"Some:"},{"kind":"text","text":"and with"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"affixed,"},{"kind":"italic_en","text":"Sometimes:"},{"kind":"text","text":"] accord. to Er-Radee, its primary meaning is to denote a small number, but it has been so much used to denote a large number as to be in this latter sense as though it were proper, and in the former sense as though it were tropical, requiring context [to explain it]. (Marginal note in my copy of the Mughnee.) [Without the affix"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":",] it governs an indeterminate noun (T, * S, Msb, Mughnee, K) only, (T, S, K,) and a pronoun. (S, M, Mughnee.) You say,"},{"kind":"arabic","text_bw":"rub~a yawomK bak~arotu fiyhi","text_ar":"رُبَّ يَوْمٍ بَكَّرْتُ فِيهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, days have I gone forth early therein"},{"kind":"text","text":"]: (T:) and"},{"kind":"arabic","text_bw":"rub~a rajulK qaAy^imN","text_ar":"رُبَّ رَجُلٍ قَايِمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, men are standing"},{"kind":"text","text":"]: (M:) and"},{"kind":"arabic","text_bw":"rub~a rajulK qaAma","text_ar":"رُبَّ رَجُلٍ قَامَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, men stood"},{"kind":"text","text":"]: (Msb:) and in like manner,"},{"kind":"arabic","text_bw":"rajulK","text_ar":"رَجُلٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rub~ata","text_ar":"رُبَّتَ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) for the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"in this case is not a denotative of the fem. gender. (Msb.) The pronoun affixed to it is of the third pers., (S, M,) and is [generally] sing. and masc., (S, Mughnee,) though it may be followed by a fem. and by a dual and by a pl.: (S:) notwithstanding its being determinate in the utmost degree, its use in this manner is allowable because it resembles an indeterminate noun in its being used without the previous mention of the noun to which it relates; and hence it requires a noun to explain it: (IJ, M:) it annuls the government of"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"; (TA;) and the indeterminate noun that follows it is put in the accus. case as a specificative: (S, Mughnee:) thus you say,"},{"kind":"arabic","text_bw":"rub~ahu rajulFA qado Darabotu","text_ar":"رُبَّهُ رَجُلًا قَدْ ضَرَبْتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, men I have beaten"},{"kind":"text","text":"]: (S, M: *) but accord. to the Koofees, you say"},{"kind":"arabic","text_bw":"rub~ahu rajulFA","text_ar":"رُبَّهُ رَجُلًا"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"rub~ahaA A@moraA^apF","text_ar":"رُبَّهَا ا@مْرَاَةً"},{"kind":"text","text":", (M,) and"},{"kind":"arabic","text_bw":"rub~ahumaA rajulayon$","text_ar":"رُبَّهُمَا رَجُلَيْنش"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rub~ahumo rijaAlFA","text_ar":"رُبَّهُمْ رِجَالًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rub~ahun~a nisaA='F","text_ar":"رُبَّهُنَّ نِسَا=ءً"},{"kind":"text","text":": he who puts the pronoun in the sing. [in all cases] holds it to be allusive to something unknown; and he who does not put it in the sing. [when it is not followed by a sing. noun] holds it to be used in reply to a question, as though it were said to a man, “ Hast thou not any young women? ” and he answered,"},{"kind":"arabic","text_bw":"rub~ahun~a jawaArK qado malakotu","text_ar":"رُبَّهُنَّ جَوَارٍ قَدْ مَلَكْتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, young women have I possessed"},{"kind":"text","text":"]: Ibn-Es-Sarráj says that the grammarians are as though they were of one consent in holding"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"to be a replicative [app. meaning in a case of this kind, with an affixed pronoun]: (S:) [but it is not always a replicative in a case of this kind; though perhaps it was originally:] AHeyth cites as an ex."},{"kind":"quote","text":"warub~ahu EaTibFA A^anoqa*otu mi AlEaTabi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And many a perishing"},{"kind":"text","text":"man"},{"kind":"italic_en","text":"have I saved from perdition"},{"kind":"text","text":"]. (TA. [But the reading commonly found in grammars is"},{"kind":"arabic","text_bw":"mino EaTabiho","text_ar":"مِنْ عَطَبِهْ"},{"kind":"italic_en","text":"from his state of perdition."},{"kind":"text","text":"]) The following is an ex. of the use of"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"to denote a small number, [or rather to denote singleness,]"},{"kind":"quote","text":"A^alaA rub~a mawoluwdK walayosa lahu A^abN\n                      \n                     \n                        wa*iY waladK lamo yalodihi A^abawaAni"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Now surely scarce an instance is there of anyone born not having a father, and of anyone having offspring whom two parents have not procreated"},{"kind":"text","text":"]; meaning [our Lord] Jesus and Adam: (Mughnee: [but I have substituted"},{"kind":"arabic","text_bw":"yalodihi","text_ar":"يَلْدِهِ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"yalodahu","text_ar":"يَلْدَهُ"},{"kind":"text","text":", the reading in my copy of that work:"},{"kind":"arabic","text_bw":"lamo yalodihi","text_ar":"لَمْ يَلْدِهِ"},{"kind":"text","text":"is for"},{"kind":"arabic","text_bw":"lamo yalidohu","text_ar":"لَمْ يَلِدْهُ"},{"kind":"text","text":", for the sake of the metre; like as"},{"kind":"arabic","text_bw":"limo A^ajodi","text_ar":"لِمْ اَجْدِ"},{"kind":"text","text":"is for"},{"kind":"arabic","text_bw":"lamo A^ajido","text_ar":"لَمْ اَجِدْ"},{"kind":"text","text":":]) and among the many exs. of its use to denote a large number, is the saying, in a trad.,"},{"kind":"arabic","text_bw":"yaA rub~a kAasiyapK fiY Ald~unoyaA EaAriyapN yawoma Alqiy`mapi","text_ar":"يَا رُبَّ كاَسِيَةٍ فِى الدُّنْيَا عَارِيَةٌ يَوْمَ القِيٰمَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O, many a female having clothing in the present state of existence"},{"kind":"text","text":"will be"},{"kind":"italic_en","text":"naked on the day of resurrection!"},{"kind":"text","text":"]; and the saying of an Arab of the desert, after the ending of Ramadán,"},{"kind":"arabic","text_bw":"yaA rub~a SaAy^imihi lano","text_ar":"يَا رُبَّ صَايِمِهِ لَنْ"},{"kind":"arabic","text_bw":"yaESuwmahu wayaA rub~a qaAy^imihi lano yaquwmahu","text_ar":"يَعصُومَهُ وَيَا رُبَّ قَايِمِهِ لَنْ يَقُومَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O, many a keeper of its fast shall not keep its fast"},{"kind":"text","text":"again!"},{"kind":"italic_en","text":"and O, many a passer of its nights in prayer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"per-"},{"kind":"italic_en","text":"former of its"},{"kind":"arabic","text_bw":"taraAwiyH","text_ar":"تَرَاوِيح"},{"kind":"text","text":","},{"kind":"italic_en","text":"shall not pass its nights in prayer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perform its"},{"kind":"arabic","text_bw":"trAwyH","text_ar":"تراويح"},{"kind":"text","text":", again!]. (Mughnee.) [But in this last ex., and in others, it relates to few in comparison with others, though many abstractedly.] ―         -b2-"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"is affixed to"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"&c. in order that a verb may follow it; (S, Mughnee;) and the verb that follows it is generally a preterite, (T, Mughnee,) as to the letter and the meaning: (Mughnee:) you say,"},{"kind":"arabic","text_bw":"rub~amaA jaA='aniY fulaAnN","text_ar":"رُبَّمَا جَا=ءَنِى فُلَانٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Seldom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, such a one came to me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has come to me"},{"kind":"text","text":"]: (T:) sometimes the verb is a future; (T, Mughnee;) but only when it expresses an event of which one is certain: (T:) so in the saying in the Kur [xv. 2],"},{"kind":"arabic","text_bw":"rub~amaA yawad~u A@l~a*yna kafaruwA lawo kaAnuwA","text_ar":"رُبَّمَا يَوَدُّ ا@لَّذينَ كَفَرُوا لَوْ كَانُوا"},{"kind":"arabic","text_bw":"musolimiyna","text_ar":"مُسْلِمِينَ"},{"kind":"text","text":", (T, S, M, Mughnee), meaning"},{"kind":"italic_en","text":"Often"},{"kind":"text","text":"["},{"kind":"italic_en","text":"will those who have disbelieved wish that they had been Muslims"},{"kind":"text","text":"]; (Mughnee, Jel;) or"},{"kind":"italic_en","text":"seldom,"},{"kind":"text","text":"(Zj, T, M, Jel,) because terrors will bereave them of their reason so that they will but seldom recover reason to wish this; (Jel;) for God's threat is true, as though it had come to pass, and therefore the verb here is equivalent to a preterite [which is often used in the Kur and elsewhere in this manner]. (T.)"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"is also sometimes affixed when a noun follows, (T, Mughnee,) or a nominal proposition, and generally restricts"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"&c. from governing: thus, Aboo-Duwád says,"},{"kind":"quote","text":"rub~amaA AljaAmilu Almuw^ab~alu fiyhimo\n                      \n                     \n                        waEanaA jiyju bayonahun~a AlmihaAru"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Sometimes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, the numerous herd of camels is among them, and"},{"kind":"text","text":"there are"},{"kind":"italic_en","text":"swift horses, among which are the colts"},{"kind":"text","text":"]: another says, making"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":"affixed, to govern,"},{"kind":"quote","text":"rub~amaA DarobapK bisayofK SaqiylK\n                      \n                     \n                        qayoni buSoraY waTaEonapK najolaA='a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Many a stroke with a polished sword of the forging of Busrà,"},{"kind":"text","text":"(the Bozrah of the Bible, a city famous for its sword-blades,)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"many a"},{"kind":"italic_en","text":"wide spear-wound;"},{"kind":"text","text":"or, perhaps,"},{"kind":"italic_en","text":"few strokes"},{"kind":"text","text":"&c.]: (Mughnee: [but I have substituted"},{"kind":"arabic","text_bw":"qayoni","text_ar":"قَيْنِ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"bayona","text_ar":"بَيْنَ"},{"kind":"text","text":", which is the reading in my copy of the Mughnee, an evident mistranscription:]) and another, cited by IAar, says,"},{"kind":"quote","text":"gaArapK ↓ \n      maAwiY~a yaA rub~atamaA\n                      \n                     \n                        $aEowaA='a kaA@ll~a*oEapi biA@lomiysami"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Máweeyeh,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maAwiY~a","text_ar":"مَاوِىَّ"},{"kind":"text","text":"being an apocopated proper name of a woman, originally"},{"kind":"arabic","text_bw":"maAwiy~apu","text_ar":"مَاوِيَّةُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"O, many a raid spreading widely and dispersedly, like the burn with the branding-iron"},{"kind":"text","text":"]. (T. [In the TT, as from the T, I find, here,"},{"kind":"arabic","text_bw":"balo","text_ar":"بَلْ"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"yA","text_ar":"يا"},{"kind":"text","text":", which I find in a copy of the T, and which is the reading commonly known.])"}],"source_refs":["TA","T","S","M","K","Msb","IJ","Zj","Jel"]},{"entry_id":"n14370","headword_ar":"رُبٌّ","root":"rb","body":[{"kind":"italic_en","text":"Rob,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inspissated juice,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dibos","text_ar":"دِبْس"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of any fruit;"},{"kind":"text","text":"i. e., (M, TA,) the"},{"kind":"italic_en","text":"first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear, juice of the thick residuum of any fruit after it has been pressed"},{"kind":"text","text":"(M, K, TA)"},{"kind":"italic_en","text":"and cooked:"},{"kind":"text","text":"(M, TA:)"},{"kind":"italic_en","text":"thick"},{"kind":"arabic","text_bw":"TilaA='","text_ar":"طِلَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"expressed juice;"},{"kind":"text","text":"such as the"},{"kind":"italic_en","text":"inspissated juice of dates,"},{"kind":"text","text":"with which a skin for clarified butter is seasoned; see 1, in the latter half of the paragraph]: (S:) or"},{"kind":"italic_en","text":"what flows from fresh ripe"},{"kind":"page_break","n":1005},{"kind":"italic_en","text":"dates, like honey, when it has been cooked"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and so rendered thick"},{"kind":"text","text":"]; before which it is called"},{"kind":"arabic","text_bw":"SaqorN","text_ar":"صَقْرٌ"},{"kind":"text","text":": (Msb in the present art. and in art."},{"kind":"arabic","text_bw":"Sqr","text_ar":"صقر"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"what is prepared by coction from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of, dates:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"expressed juice of grapes,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of apples, &c., cooked and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thickened:"},{"kind":"text","text":"(KL:) and"},{"kind":"italic_en","text":"dregs,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"black dregs,"},{"kind":"text","text":"(IDrd, M,) of clarified butter, (IDrd, M, K,) and of olive-oil: (IDrd, M:) pl."},{"kind":"arabic","text_bw":"rubuwbN","text_ar":"رُبُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ribaAbN","text_ar":"رِبَابٌ"},{"kind":"text","text":"(S) [and pl. pl. (i. e. pl. of"},{"kind":"arabic","text_bw":"rubuwbN","text_ar":"رُبُوبٌ"},{"kind":"text","text":")"},{"kind":"arabic","text_bw":"rubuwbaAtN","text_ar":"رُبُوبَاتٌ"},{"kind":"text","text":", which means"},{"kind":"italic_en","text":"sorts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species, of"},{"kind":"arabic","text_bw":"rub~","text_ar":"رُبّ"},{"kind":"text","text":"]       -A2-  See also"},{"kind":"arabic","text_bw":"rub~aY","text_ar":"رُبَّى"},{"kind":"text","text":"."}],"source_refs":["M","TA","K","S","KL","IDrd"]}]},"classical_definitions":null}