ntry_ids":["n9164"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AD%D9%8E%D9%85%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take up (a burden)"},{"pos":"verb","gloss":"to tolerate, bear, support, suffer"},{"pos":"verb","gloss":"to make debts"},{"pos":"verb","gloss":"to break up a camp and depart"},{"pos":"noun","gloss":"verbal noun of تَحَمَّلَ (taḥammala) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"forbearance, endurance, stamina"}]},"etymology":{"source":"wiktextract","text":"Compare حَمَلَ (ḥamala, “to carry”).\n\nVerbal noun of تَحَمَّلَ (taḥammala)."},"ipa":["/ta.ħam.ma.la/","/ta.ħam.mul/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9164","headword_ar":"تحمّل","root":"Hml","body":[{"kind":"italic_en","text":"He took upon himself the bearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carrying, of loads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burdens:"},{"kind":"text","text":"this is the primary signification. (Har p. 48.) ―         -b2-  [Hence, (assumed tropical:)"},{"kind":"italic_en","text":"He burdened himself with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, chargeable with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took upon himself, the burden of,"},{"kind":"text","text":"a sin, or crime, or the like; as also ↓"},{"kind":"arabic","text_bw":"AHtml","text_ar":"احتمل","orth_type":"arrow"},{"kind":"text","text":":] you say"},{"kind":"arabic","text_bw":"AHtml A_ivomFA","text_ar":"احتمل اـِثْمًا"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"tHml~hu","text_ar":"تحملّهُ"},{"kind":"text","text":". (Jel in iv. 112 and xxxiii. 58.) And"},{"kind":"arabic","text_bw":"tHm~l guromFA","text_ar":"تحمّل غُرْمًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imposed, upon himself a debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine."},{"kind":"text","text":"(MA.) ―         -b3-  [And hence, likewise, several other significations:] see 2, in two places: ―         -b4-  and 8: ―         -b5-  and 1, in six places. ―         -b6-  Also He"},{"kind":"italic_en","text":"bound the load,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burden,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the loads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burdens, on the saddle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saddles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the beast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beasts;"},{"kind":"text","text":"] (Har p. 48;) and ↓"},{"kind":"arabic","text_bw":"AHtyl","text_ar":"احتيل","orth_type":"arrow"},{"kind":"text","text":"signifies [the same, or]"},{"kind":"italic_en","text":"he put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"placed, the load,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burden,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the loads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burdens,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"on the saddle,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"saddles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the beast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beasts."},{"kind":"text","text":"] (Har p. 556.) ―         -b7-  [And hence,]"},{"kind":"arabic","text_bw":"tHm~lwA","text_ar":"تحمّلوا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHtmlwA","text_ar":"احتملوا","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They went away, departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed."},{"kind":"text","text":"(S, TA.)"}],"source_refs":[]}]},"classical_definitions":null}