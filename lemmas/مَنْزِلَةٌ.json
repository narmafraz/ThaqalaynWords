{"lemma":"مَنْزِلَةٌ","slug":"مَنْزِلَةٌ","root":"ن.ز.ل","root_slug":"ن-ز-ل","root_link":"/words/roots/ن-ز-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n43933"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%86%D9%92%D8%B2%D9%90%D9%84%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"position, status, rank","examples":[{"text":"هُوَ بِمَنْزِلَةِ أَبِيهِ.","english":"He is treated as his father."},{"text":"رَفِيعُ ٱلْمَنَازِلِ","english":"of high rank"}]},{"pos":"noun","gloss":"house, dwelling, residence"}]},"etymology":null,"ipa":["/man.zi.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43933","headword_ar":"مَنْزِلَةٌ","root":"nzl","body":[{"kind":"italic_en","text":"A space which one traverses in journeying."},{"kind":"text","text":"(TA, art."},{"kind":"arabic","text_bw":"syr","text_ar":"سير"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"manozilapN","text_ar":"مَنْزِلَةٌ"},{"kind":"text","text":", used unrestrictedly,"},{"kind":"italic_en","text":"Station, standing, footing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grade; honourable station"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rank; a place of preferment."},{"kind":"text","text":"―         -b3-"},{"kind":"italic_en","text":"A predicament in which one stands."},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"kalimapN bimanozilapi","text_ar":"كَلِمَةٌ بِمَنْزِلَةِ"},{"kind":"arabic","text_bw":"kalimapK A^uxoraY","text_ar":"كَلِمَةٍ اُخْرَى"},{"kind":"italic_en","text":"A word equivalent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar, to another word."},{"kind":"text","text":"―         -b5-  [You say]"},{"kind":"arabic","te