"},{"role":"present_3fd","form":"تَدْهَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدْهَمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْهَمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْهَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"دَهَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَهَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَهِمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَهِمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَدْهَم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدْهَم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n13288","n13289"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%87%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to assail, to hit, to come suddenly over","tags":["transitive"]},{"pos":"verb","gloss":"to surprise, to ambush","tags":["transitive"]},{"pos":"verb","gloss":"to raid, to enter suddenly","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of دَهَمَ (dahama) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"noun","gloss":"verbal noun of دَهِمَ (dahima) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"verb","gloss":"to turn black or dark","tags":["transitive"]},{"pos":"verb","gloss":"to darken, to denigrate","tags":["transitive"]},{"pos":"adj","gloss":"common plural of أَدْهَم (ʔadham, “black, deep-black”)","tags":["common","form-of","plural","transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13288","headword_ar":"دَهْمٌ","root":"dhm","body":[{"kind":"italic_en","text":"A malicious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grievous, act, by which one takes others unawares,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by surprise."},{"kind":"text","text":"(TA from a trad.)       -A2-  Also, (S, TA,) or ↓"},{"kind":"arabic","text_bw":"duhomN","text_ar":"دُهْمٌ","orth_type":"arrow"},{"kind":"text","text":", (JK, and so in one place in the TA,)"},{"kind":"italic_en","text":"A numerous company:"},{"kind":"text","text":"(Lth, JK, TA:) or"},{"kind":"italic_en","text":"a multitude:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"duhuwmN","text_ar":"دُهُومٌ"},{"kind":"text","text":". (S.) A rájiz says,"},{"kind":"quote","text":"jiy^onaA bidahomK yadohamu\n                      \n                     \n                        majorK kaA^an~a fawoqahu Aln~ujuwmaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We came with a numerous company that would overwhelm the other numerous companies; a great army, as though the stars were above it"},{"kind":"text","text":"]. (S, TA.) [See also"},{"kind":"arabic","text_bw":"dahomaA='u","text_ar":"دَهْمَا=ءُ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A^adohamu","text_ar":"اَدْهَمُ"},{"kind":"text","text":".] And one says,"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maAA^adoraY A^aY~u Ald~uhomi","text_ar":"مَااَدْرَى اَىُّ الدُّهْمِ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A@ll~`hi huwa","text_ar":"ا@للّٰهِ هُوَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aY~u duhomi","text_ar":"اَىُّ دُهْمِ","orth_type":"arrow"},{"kind":"text","text":", (JK, K, TA,) or"},{"kind":"arabic","text_bw":"AY~ Ald~ahomi hw","text_ar":"اىّ الدَّهْمِ هو"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AY~ dahomi All~`h hw","text_ar":"اىّ دَهْمِ اللّٰه هو"},{"kind":"text","text":", (so in the CK and in my MS. copy of the K,) i. e."},{"kind":"italic_en","text":"I know not what one of the creation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of mankind, he is, and what one of the creatures of God he is."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":["S","TA","Lth","JK","K"]},{"entry_id":"n13289","headword_ar":"دُهْمٌ","root":"dhm","body":[{"kind":"text","text":": see the next preceding paragraph, in three places. ―         -b2-  Also pl. of"},{"kind":"arabic","text_bw":"A^adohamu","text_ar":"اَدْهَمُ"},{"kind":"text","text":"[q. v.]. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}