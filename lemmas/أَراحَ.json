le":"present_3md","form":"يُراحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُراحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرِيحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرِيحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُراحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُراحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرِيحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرِيحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُراحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُراحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرِيحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرِيحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُرِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُراح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُراح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرِيح","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَرَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَرَحْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n16979"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to let (someone) rest"},{"pos":"verb","gloss":"to free (someone مِن (min) from)"},{"pos":"verb","gloss":"to release (someone مِن (min) from)"},{"pos":"verb","gloss":"to gladden (someone بِ (bi) with)"},{"pos":"verb","gloss":"to soothe"},{"pos":"verb","gloss":"to disburden"}]},"etymology":{"source":"wiktextract","text":"Compare رَاحَة (rāḥa, “rest, comfort”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16979","headword_ar":"اراح","root":"rwH","body":[{"kind":"italic_en","text":"He breathed:"},{"kind":"text","text":"(S, A, K:) said of a man, (A,) and of a horse. (S.) ―         -b2-  ["},{"kind":"italic_en","text":"It emitted an odour:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, Msb)"},{"kind":"italic_en","text":"stank;"},{"kind":"text","text":"(S, Msb, K;) as also"},{"kind":"arabic","text_bw":"A^arowaHa","text_ar":"اَرْوَحَ"},{"kind":"text","text":": (Msb, TA:) the former said of flesh-meat, (S, K,) and of water; (K;) and so the latter: (TA:) or the latter,"},{"kind":"italic_en","text":"it became altered"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the worse"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in odour;"},{"kind":"text","text":"(Lh, S, M, A, Msb;) said of flesh-meat, (Lh, M, A, * Msb,) and of water, (Lh, S, M, A, Msb,) &c.; (S;) and so the former, said of water: (L, TA:) ISd makes a distinction between"},{"kind":"arabic","text_bw":"ArwH","text_ar":"اروح"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"trw~H","text_ar":"تروّح","orth_type":"arrow"},{"kind":"text","text":"[q. v., as does also J,] said of water. (Msb, TA.) ―         -b3-  Also, (inf. n."},{"kind":"arabic","text_bw":"A_iraAHapN","text_ar":"اـِرَاحَةٌ"},{"kind":"text","text":", L,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, and a beast, Lh)"},{"kind":"italic_en","text":"revived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his spirit returned to him, after fatigue;"},{"kind":"text","text":"(Lh, S, K;) like ↓"},{"kind":"arabic","text_bw":"AstrAH","text_ar":"استراح","orth_type":"arrow"},{"kind":"text","text":", q. v.: (TA:) and"},{"kind":"italic_en","text":"he had rest."},{"kind":"text","text":"(K.) ―         -b4-  And [hence], (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iraAHapN","text_ar":"اـِرَاحَةٌ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"A_irowaAHN","text_ar":"اـِرْوَاحٌ"},{"kind":"text","text":", (Msb,) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"died;"},{"kind":"text","text":"(S, Msb, K;) as though he found rest: and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"died,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"A^araAHa faA^araAHa","text_ar":"اَرَاحَ فَاَرَاحَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He rested,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"had rest, and so rested"},{"kind":"text","text":"others], meaning (assumed tropical:)"},{"kind":"italic_en","text":"he died, and so people became at rest from him."},{"kind":"text","text":"(A.) ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"A^araHonaA biAlS~alaApi","text_ar":"اَرَحْنَا بِالصَّلَاةِ"},{"kind":"italic_en","text":"We performed the act of prayer:"},{"kind":"text","text":"because its performance is [a cause of] rest to the soul; the waiting for the time thereof being troublesome. (Msb.) ―         -b6-"},{"kind":"arabic","text_bw":"A^araAHato","text_ar":"اَرَاحَتْ"},{"kind":"text","text":"said of camels &c. [as though meaning"},{"kind":"italic_en","text":"They returned in the evening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afternoon, to rest"},{"kind":"text","text":"]: see 1, in the latter half of the paragraph. ―         -b7-"},{"kind":"arabic","text_bw":"ArAH","text_ar":"اراح"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iraAHapN","text_ar":"اـِرَاحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_iraAHN","text_ar":"اـِرَاحٌ"},{"kind":"text","text":", said of a man,"},{"kind":"italic_en","text":"His camels,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"cattle, returned to him in the evening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afternoon, from pasture."},{"kind":"text","text":"(L.) ―         -b8-  And"},{"kind":"arabic","text_bw":"ArAH","text_ar":"اراح"},{"kind":"text","text":", [app. for"},{"kind":"arabic","text_bw":"ArAH baEiyrahu","text_ar":"اراح بَعِيرَهُ"},{"kind":"text","text":",] like wise said of a man,"},{"kind":"italic_en","text":"He alighted from his camel to rest him and to alleviate him."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"A^araAHuwA","text_ar":"اَرَاحُوا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^arowaHuwA","text_ar":"اَرْوَحُوا"},{"kind":"text","text":": see 1, in the last quarter of the paragraph.       -A2-"},{"kind":"arabic","text_bw":"A^araAHahu","text_ar":"اَرَاحَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^arowaHahu","text_ar":"اَرْوَحَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ArAH Alr~iyHa","text_ar":"اراح الرِّيحَ"},{"kind":"text","text":", &c.: see 1, in the last quarter of the paragraph, in twelve places. ―         -b2-"},{"kind":"arabic","text_bw":"ArAHhu","text_ar":"اراحهُ"},{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iraAHapN","text_ar":"اـِرَاحَةٌ"},{"kind":"text","text":", (Msb, TA,) and ↓"},{"kind":"arabic","text_bw":"raAHapN","text_ar":"رَاحَةٌ","orth_type":"arrow"},{"kind":"text","text":"is a subst. used as an inf. n., [i. e. a quasi-inf. n.,] like"},{"kind":"arabic","text_bw":"TaAEapN","text_ar":"طَاعَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaArapN","text_ar":"عَارَةٌ"},{"kind":"text","text":"used as inf. ns. of"},{"kind":"arabic","text_bw":"A^aTaAEahu","text_ar":"اَطَاعَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aEaArahu","text_ar":"اَعَارَهُ"},{"kind":"text","text":", (TA,) said of God, (S, K,) or of a man, (A, Msb,)"},{"kind":"italic_en","text":"He rested him, made him to be at rest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at ease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave him rest;"},{"kind":"text","text":"(S, * A, * Msb;) namely, a hired man, (Msb,) or any man; as also"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rw~H","text_ar":"روّح","orth_type":"arrow"},{"kind":"text","text":": (TA:) and the former,"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"caused him to enter into a state of rest,"},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"of mercy."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"binaA","text_ar":"بِنَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raw~iHuwA","text_ar":"رَوِّحُوا","orth_type":"arrow"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"lv","text_ar":"لث"},{"kind":"text","text":")"},{"kind":"italic_en","text":"Give ye us rest."},{"kind":"text","text":"(TK in that art.) And"},{"kind":"arabic","text_bw":"ArAH baEiyrahu","text_ar":"اراح بَعِيرَهُ"},{"kind":"italic_en","text":"He revived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recovered, his camel."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"ArAH Aln~aAsa biAlS~alaApi","text_ar":"اراح النَّاسَ بِالصَّلَاةِ"},{"kind":"italic_en","text":"He chanted the call to prayer, and so made the people to ease their hearts by performing the act of prayer."},{"kind":"text","text":"(L.) ―         -b4-  And"},{"kind":"arabic","text_bw":"ArAH","text_ar":"اراح"},{"kind":"text","text":", (S, M, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iraAHapN","text_ar":"اـِرَاحَةٌ"},{"kind":"text","text":"; (M, Mgh;) accord. to one dial.,"},{"kind":"arabic","text_bw":"haraAHa","text_ar":"هَرَاحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yuhariyHu","text_ar":"يُهَرِيحُ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"rw~H","text_ar":"روّح","orth_type":"arrow"},{"kind":"text","text":", (S, * A, TA,) inf. n."},{"kind":"arabic","text_bw":"tarowiyHN","text_ar":"تَرْوِيحٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the pastor, Msb)"},{"kind":"italic_en","text":"drove back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought back,"},{"kind":"text","text":"(S, M, Msb, K,) camels, (S, M, A, Mgh, Msb, K,) and sheep or goats, (M, A, * Mgh,) and cows or bulls, (A, * Mgh,)"},{"kind":"italic_en","text":"in the evening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afternoon,"},{"kind":"text","text":"(M, Msb,)"},{"kind":"italic_en","text":"after the declining of the sun from the meridian,"},{"kind":"text","text":"(S,) ["},{"kind":"italic_en","text":"from their place of pasture,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to their nightly resting-place,"},{"kind":"text","text":"(S, M, K,) or"},{"kind":"arabic","text_bw":"A_ilaY A^aholihaA","text_ar":"اـِلَى اَهْلِهَا"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"EalaY A^aholihaA","text_ar":"عَلَى اَهْلِهَا"},{"kind":"text","text":"(for you say"},{"kind":"arabic","text_bw":"raAHato EalaY A^aholihaA","text_ar":"رَاحَتْ عَلَى اَهْلِهَا"},{"kind":"text","text":") i. e."},{"kind":"italic_en","text":"to their owners"},{"kind":"text","text":"]. (Msb.) ―         -b5-  [Hence,]"},{"kind":"arabic","text_bw":"ArAH Ealayohi Haq~ahu","text_ar":"اراح عَلَيْهِ حَقَّهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He restored to him his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due;"},{"kind":"text","text":"(S, K;) as also"},{"kind":"arabic","text_bw":"A^arowaHa","text_ar":"اَرْوَحَ"},{"kind":"text","text":". (K.) And the saying, in a trad., of Umm-Zara,"},{"kind":"arabic","text_bw":"ArAH","text_ar":"اراح"},{"kind":"arabic","text_bw":"EalaY~a naEamFA variy~FA","text_ar":"عَلَىَّ نَعَمًا ثَرِيًّا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He gave me much cattle:"},{"kind":"text","text":"because she was [as though she were] a"},{"kind":"arabic","text_bw":"muraAH","text_ar":"مُرَاح"},{"kind":"text","text":"for his bounty. (L.)"}],"source_refs":["S","A","K","Msb","TA","Lh","M","L","God","Mgh"]}]},"classical_definitions":null}