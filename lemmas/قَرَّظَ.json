,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُقَرِّظُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُقَرِّظْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُقَرِّظ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُقَرِّظ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُقَرِّظانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُقَرِّظا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُقَرِّظانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُقَرِّظا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُقَرِّظُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُقَرِّظُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُقَرِّظْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُقَرِّظ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُقَرِّظ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَرَّظْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"قَرَّظْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n35539"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"Acacia spp. or Vachellia spp., especially Vachellia nilotica and Acacia etbaica syn. Vachellia etbaica, and especially its leaves or pods","tags":["collective"]},{"pos":"verb","gloss":"to tan or dye with قَرَظ (qaraẓ)"},{"pos":"verb","gloss":"to pluck the leaves or pods قَرَظ (qaraẓ)"},{"pos":"verb","gloss":"to praise, to eulogize, to commend a living person"},{"pos":"noun","gloss":"verbal noun of قَرَظَ (qaraẓa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-West Semitic, cognate to Aramaic קרטא / ܩܷܪܱܛܳܐ (qerraṭṭā, “acacia; carob”), and Ancient Greek κεράτιον (kerátion, “carob tree”), matched to the Semitic. This tree is important for tanning and dying, hence the meaning of “to eulogize”.\nAccording to Löw the Syriac word is from Arabic and the Arabic from Greek, but a borrowing of ظ (ẓ) is hard (save from South Semitic). and the Greek gives regularly already existing قِيرَاط (qīrāṭ).\nDictionnaire du faisceau dialectal arabe andalou considers a borrowing from Egyptian ꜣqrw (“a tree the fruits of which are used officinally”) with an added second element, compare نَبَق (nabaq) where the same seems to have happened."},"ipa":["/qa.raðˤ/"]}