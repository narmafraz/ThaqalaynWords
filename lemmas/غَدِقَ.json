en":"m","num":"p"},{"role":"present_2mp","form":"تَغْدَقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَغْدَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَغْدَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَغْدَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَغْدَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَغْدَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَغْدَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَغْدَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَغْدَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَغْدَقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَغْدَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"غَدِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَدِقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَغْدَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغْدَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"غَدِقَ","root":"غدق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n31523","n31524"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%AF%D9%90%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to abound with water, to be copious"},{"pos":"adj","gloss":"plentiful, bountiful"},{"pos":"noun","gloss":"a rain or spring that is abundant albeit gentle"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31523","headword_ar":"غَدَقٌ","root":"gdq","body":[{"kind":"text","text":"[an inf. n.: and used in the sense of the part. n. ↓"},{"kind":"arabic","text_bw":"gadiqN","text_ar":"غَدِقٌ","orth_type":"arrow"},{"kind":"text","text":", meaning]"},{"kind":"italic_en","text":"Abundant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copious;"},{"kind":"text","text":"applied to water; (S, O, Msb, K, TA;) not restricted to rain; (TA;) as also ↓"},{"kind":"arabic","text_bw":"mugodiqN","text_ar":"مُغْدِقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mugodawodiqN","text_ar":"مُغْدَوْدِقٌ","orth_type":"arrow"},{"kind":"text","text":", both applied to rain, and the latter [or both] applied to water [in general]; and ↓"},{"kind":"arabic","text_bw":"gayodaAqN","text_ar":"غَيْدَاقٌ","orth_type":"arrow"},{"kind":"text","text":"likewise, applied to water, and, as AA"},{"kind":"page_break","n":2234},{"kind":"text","text":"says, to rain: or"},{"kind":"arabic","text_bw":"gadaqN","text_ar":"غَدَقٌ"},{"kind":"text","text":"is applied to rain as meaning"},{"kind":"italic_en","text":"abundant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copious,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to be"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"general in its extent."},{"kind":"text","text":"(TA.) It is said in the Kur [lxxii. 16],"},{"kind":"arabic","text_bw":"lawi A@sotaqaAmuwA EalaY A@lT~ariyqapi laA^asoqayonaAhumo maA='F","text_ar":"لَوِ ا@سْتَقَامُوا عَلَى ا@لطَّرِيقَةِ لَاَسْقَيْنَاهُمْ مَا=ءً"},{"kind":"arabic","text_bw":"gadaqFA","text_ar":"غَدَقًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If they should go on undeviatingly in the way"},{"kind":"text","text":"which they are pursuing,"},{"kind":"italic_en","text":"we would water then with abundant water"},{"kind":"text","text":"]; (O, TA;) to try them thereby; the"},{"kind":"arabic","text_bw":"Tryqp","text_ar":"طريقة"},{"kind":"text","text":"here being that of infidelity; so says Th, and in like manner Fr; but others say that it is that of the right direction: (TA:) 'Ásim Ibn-Abi-n-Najood read ↓"},{"kind":"arabic","text_bw":"gadiqFA","text_ar":"غَدِقًا","orth_type":"arrow"},{"kind":"text","text":". (O, TA.) In the saying, in a trad.,"},{"kind":"arabic","text_bw":"Aall~`hum~a A@soqinaA gadaqFA","text_ar":"اَللّٰهُمَّ ا@سْقِنَا غَدَقًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mugodiqFA","text_ar":"مُغْدِقًا","orth_type":"arrow"},{"kind":"text","text":", the last word is used as a corroborative [the meaning being"},{"kind":"italic_en","text":"O God, water us very abundantly"},{"kind":"text","text":"]. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"gayodaAqN","text_ar":"غَيْدَاقٌ"},{"kind":"text","text":"."}],"source_refs":["TA"]},{"entry_id":"n31524","headword_ar":"غَدِقٌ","root":"gdq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gadaqN","text_ar":"غَدَقٌ"},{"kind":"text","text":", in two places. You say also"},{"kind":"arabic","text_bw":"EayonN gadiqapN","text_ar":"عَيْنٌ غَدِقَةٌ"},{"kind":"italic_en","text":"A spring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"source abounding with water."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^aroDN gadiqapN","text_ar":"اَرْضٌ غَدِقَةٌ"},{"kind":"italic_en","text":"Land that is moist and irrigated in the utmost degree; abounding with water."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eu$obN gadiqN","text_ar":"عُشْبٌ غَدِقٌ"},{"kind":"italic_en","text":"Herbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, plentifully irrigated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flourishing and fresh, juicy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moist."},{"kind":"text","text":"(En-Nadr, AHn, TA.)"}],"source_refs":[]}]}}