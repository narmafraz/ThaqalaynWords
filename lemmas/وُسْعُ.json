مَجْلِسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tawaAs~aEuwA","text_ar":"تَوَاسَّعُوا","orth_type":"arrow"},{"kind":"italic_en","text":"They made room, or ample space,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one for another,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the sitting-place."},{"kind":"text","text":"(S, art."},{"kind":"arabic","text_bw":"fsH","text_ar":"فسح"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"was~aEa Ealayohi","text_ar":"وَسَّعَ عَلَيْهِ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"was~aEa Ealayohi rizoqahu","text_ar":"وَسَّعَ عَلَيْهِ رِزْقَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"amplified, enlarged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made ample"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plentiful, his means of subsistence; contr. of"},{"kind":"arabic","text_bw":"Day~aqa","text_ar":"ضَيَّقَ"},{"kind":"text","text":". ―         -b5-  See 1, and 4."}],"source_refs":["God"]}]}}