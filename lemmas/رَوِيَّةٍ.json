{"lemma":"رَوِيَّةٍ","slug":"رَوِيَّةٍ","root":"ر.#.#","root_slug":"ر-_-_","root_link":"/words/roots/ر-_-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14339","n14346","n17174"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%88%D9%90%D9%8A%D9%8E%D9%91%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"deliberation, advice"}]},"etymology":null,"ipa":["/ra.wij.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14339","headword_ar":"رُوْيَةٌ","root":"rA^Y","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"raA^aY","text_ar":"رَاَى"},{"kind":"text","text":"[q. v.] : (T, S, M, Msb, K:) [and also a subst.: used a as subst.,) it means The"},{"kind":"italic_en","text":"sight"},{"kind":"text","text":"of the eye; as also ↓"},{"kind":"arabic","text_bw":"raA^oYN","text_ar":"رَاْىٌ","orth_type":"arrow"},{"kind":"text","text":": [and accord. to the M and K, it is with the mind also; like"},{"kind":"arabic","text_bw":"raA^oYN","text_ar":"رَاْىٌ"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"ruwFY","text_ar":"رُوًى"},{"kind":"text","text":". (Msb.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"riy^oYN","text_ar":"رِيْىٌ"},{"kind":"text","text":"―         -b3-  [Also The"},{"kind":"italic_en","text":"phasis"},{"kind":"text","text":"of the moon.]"}],"source_refs":["T","S","M","Msb","K"]},{"entry_id":"n14346","headword_ar":"رُوَيَّةٌ","root":"rA^Y","body":[{"kind":"text","text":"dim. of"},{"kind":"arabic","text_bw":"riy^apN","text_ar":"رِيَةٌ"},{"kind":"text","text":", q. v.; also prounced"},{"kind":"arabic","text_bw":"ruway~apN","text_ar":"رُوَيَّةٌ"},{"kind":"text","text":". (T.)"}],"source_refs":[]},{"entry_id":"n17174","headword_ar":"رَوِيَّةٌ","root":"rwY","body":[{"kind":"italic_en","text":"A want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing wanted:"},{"kind":"text","text":"(A 'Obeyd, T, S:) so in the saying,"},{"kind":"arabic","text_bw":"lanaA Einoda fulaAnK rawiy~apN","text_ar":"لَنَا عِنْدَ فُلَانٍ رَوِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We have a want to be supplied to us on the part of such a one;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"we want a thing of such a one"},{"kind":"text","text":"]: (A 'Obeyd, T:) and"},{"kind":"arabic","text_bw":"lanaA qibalaka rawiy~apN","text_ar":"لَنَا قِبَلَكَ رَوِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We have a want to be supplied to us on thy part; we want a thing of thee"},{"kind":"text","text":"]. (S.) ―         -b2-  And The"},{"kind":"italic_en","text":"remainder of a debt"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(S.)       -A2-  Also, (S,) or"},{"kind":"arabic","text_bw":"rawiy~apN","text_ar":"رَوِيَّةٌ"},{"kind":"arabic","text_bw":"fiY A^amorK","text_ar":"فِى اَمْرٍ"},{"kind":"text","text":", (M, K, *) thus usually pronounced without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (S,) [originally"},{"kind":"arabic","text_bw":"rawiyoy^apN","text_ar":"رَوِيْيَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"Inspection, examination, consideration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thought, of an affair;"},{"kind":"text","text":"(S, M, K;)"},{"kind":"italic_en","text":"without haste:"},{"kind":"text","text":"(M:) pl."},{"kind":"arabic","text_bw":"rawaAyaA","text_ar":"رَوَايَا"},{"kind":"text","text":". (JM, TA.) You say,"},{"kind":"arabic","text_bw":"maDaY EalaY wajohihi bigayori rawiy~apK","text_ar":"مَضَى عَلَى وَجْهِهِ بِغَيْرِ رَوِيَّةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went at random, heedlessly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a headlong manner, without consideration"},{"kind":"text","text":"]. (A in art."},{"kind":"arabic","text_bw":"rkb","text_ar":"ركب"},{"kind":"text","text":".) See"},{"kind":"arabic","text_bw":"raAwiyapN","text_ar":"رَاوِيَةٌ"},{"kind":"text","text":", near the end. [See also"},{"kind":"arabic","text_bw":"rawiyoy^apN","text_ar":"رَوِيْيَةٌ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"rwA^","text_ar":"روا"},{"kind":"text","text":".)"}],"source_refs":["S","M"]}]},"classical_definitions":null}