{"lemma":"رَبَّى","slug":"رَبَّى","root":"ر.ب.ب","root_slug":"ر-ب-ب","root_link":"/words/roots/ر-ب-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"رَبَّيْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"رَبَّيْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"رَبَّيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"رَبَّيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"رَبَّيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"رَبَّى","in_corpus":true,"count":178,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"رَبَّت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"رَبَّيا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"رَبَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"رَبَّوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"رَبَّيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُرَبّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُرَبَّى","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُرَبِّي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُرَبِّي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُرَبِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُرَبَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُرَبَّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُرَبِّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُرَبِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُرَبُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَبُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَبَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُرَبِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَبّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُرَبَّى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُرَبِّي","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَبّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُرَبَّى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُرَبِّي","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَبَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَبَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَبِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَبِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَبَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَبَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَبِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَبِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَبُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَبُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَبَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُرَبِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُرَبّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَبَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَبَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُرَبَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَبَّى","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرَبِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَبِّي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":196,"cross_references":{"qac":{"found":true,"lemma_key":"رَبَّى","root":"ربب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14387","n14388","n14389","n14390"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%A8%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"many a man","examples":[{"text":"وَكَأَيِّنْ مِنْ نَبِيٍّ قَاتَلَ مَعَهُ رِبِّيُّونَ كَثِيرٌ","english":"And how many a prophet and with him fought many many a man."}]}]},"etymology":{"source":"wiktextract","text":"From the absolute state plural of Classical Syriac ܪܒܘܬܐ (rebbūṯā, “myriad”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14387","headword_ar":"رُبَّى","root":"rb","body":[{"kind":"text","text":", applied to a ewe or she-goat ("},{"kind":"arabic","text_bw":"$aApN","text_ar":"شَاةٌ"},{"kind":"text","text":"), (S, M, &c.,)"},{"kind":"italic_en","text":"That has brought forth:"},{"kind":"text","text":"(M, Msb, K:) and so"},{"kind":"italic_en","text":"if her young one has died:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"that has recently brought forth:"},{"kind":"text","text":"(Lh, S, M, Mgh, Msb, K:) or"},{"kind":"italic_en","text":"that has brought forth twenty days before:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"that has brought forth two months before:"},{"kind":"text","text":"(El-Umawee, S, M:) or"},{"kind":"italic_en","text":"that is followed,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"accompanied,"},{"kind":"text","text":"(As, Mgh,)"},{"kind":"italic_en","text":"by her young one:"},{"kind":"text","text":"(As, M, Mgh:) or"},{"kind":"italic_en","text":"that is confined in the tent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"house, for the sake of her milk:"},{"kind":"text","text":"(Msb: [see also"},{"kind":"arabic","text_bw":"rabiybapN","text_ar":"رَبِيبَةٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"rabiybN","text_ar":"رَبِيبٌ"},{"kind":"text","text":":]) accord. to AZ, (S, Msb,) it is applied to a she-goat, (S, M, Msb,) and"},{"kind":"arabic","text_bw":"raguwvN","text_ar":"رَغُوثٌ"},{"kind":"text","text":"is applied to a ewe: (M:) accord. to others, the former is applied to a she-goat and a ewe, and sometimes to a she-camel: (S, Msb:) the pl. is ↓"},{"kind":"arabic","text_bw":"rubaAbN","text_ar":"رُبَابٌ","orth_type":"arrow"},{"kind":"text","text":", (As, T, S, M, Mgh, Msb, K,) which is extr. [in form]: (M, K:) Lh mentions the phrase"},{"kind":"arabic","text_bw":"ganamN rubaAbN","text_ar":"غَنَمٌ رُبَابٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"ribaAbN","text_ar":"رِبَابٌ"},{"kind":"text","text":", which, he says, is rare. (M.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"rub~aAnN","text_ar":"رُبَّانٌ"},{"kind":"text","text":", in two places.       -A2-"},{"kind":"italic_en","text":"A benefit, favour, boon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good."},{"kind":"text","text":"(AA, T, K.) [See an ex. in the first paragraph of art."},{"kind":"arabic","text_bw":"j$A^","text_ar":"جشا"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"A want;"},{"kind":"text","text":"(AA, T, K;) as in the saying,"},{"kind":"arabic","text_bw":"liY Einoda fulaAnK rub~aY","text_ar":"لِى عِنْدَ فُلَانٍ رُبَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have a want for such a one to supply,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplish"},{"kind":"text","text":"]. (AA, T.)       -A3-  A child's"},{"kind":"italic_en","text":"nurse;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAyapN","text_ar":"دَايَةٌ"},{"kind":"text","text":". (AA, T. In one copy of the T"},{"kind":"arabic","text_bw":"bAbh","text_ar":"بابه"},{"kind":"text","text":"; and in the TA"},{"kind":"arabic","text_bw":"rAyp","text_ar":"راية"},{"kind":"text","text":". [Perhaps the right reading is"},{"kind":"arabic","text_bw":"raAb~apN","text_ar":"رَابَّةٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"a foster-mother."},{"kind":"text","text":"])       -A4-"},{"kind":"italic_en","text":"A firm knot:"},{"kind":"text","text":"(AA, T, K:) [and so, app., ↓"},{"kind":"arabic","text_bw":"rub~aAnN","text_ar":"رُبَّانٌ","orth_type":"arrow"},{"kind":"text","text":", if correctly written thus, in the instance here following.] You say,"},{"kind":"arabic","text_bw":"A_ino kunota","text_ar":"اـِنْ كُنْتَ"},{"kind":"arabic","text_bw":"A_izorika","text_ar":"اـِزْرِكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"biY ta$hd~u Zahoraka faA^aroxi birub~aAni","text_ar":"بِى تَشهدُّ ظَهْرَكَ فَاَرْخِ بِرُبَّانِ","orth_type":"arrow"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"birub~aA","text_ar":"بِرُبَّا"},{"kind":"arabic","text_bw":"A_izorika","text_ar":"اـِزْرِكَ"},{"kind":"text","text":"(so in the TT, as from the M, [as though for"},{"kind":"arabic","text_bw":"birub~aY","text_ar":"بِرُبَّى"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"minE rub~aY A_izorika","text_ar":"مِنع رُبَّى اـِزْرِكَ"},{"kind":"text","text":", (T, TA,) a prov., meaning (assumed tropical:)"},{"kind":"italic_en","text":"If thou place thy reliance upon me,"},{"kind":"text","text":"then let me weary myself, and"},{"kind":"italic_en","text":"enjoy thou relaxation and rest:"},{"kind":"text","text":"(T, TA:) here"},{"kind":"arabic","text_bw":"rub~aY","text_ar":"رُبَّى"},{"kind":"text","text":"[properly] signifies"},{"kind":"italic_en","text":"a firm knot."},{"kind":"text","text":"(T.) [See also a similar prov. in Freytag's Arab. Prov. i. 24.])       -A5-  Also a name of"},{"kind":"italic_en","text":"Jumádà-l-Oolà"},{"kind":"text","text":"[the fifth month of the Arabian calendar]; and so ↓"},{"kind":"arabic","text_bw":"rub~N","text_ar":"رُبٌّ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) and likewise, (K,) or accord. to Kr, (M,) a name of"},{"kind":"italic_en","text":"Jumádà-l-Ákhireh"},{"kind":"text","text":"[the sixth month]; and so ↓"},{"kind":"arabic","text_bw":"rub~apu","text_ar":"رُبَّةُ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) and this last likewise, (K, there expressly said to be with damm,) or ↓"},{"kind":"arabic","text_bw":"rab~apu","text_ar":"رَبَّةُ","orth_type":"arrow"},{"kind":"text","text":", (so accord. to the M as transcribed in the TT,) a name of"},{"kind":"italic_en","text":"Dhu-l-Kaadeh"},{"kind":"text","text":"[the eleventh month]: (M, K:) thus these months were called in the Time of Ignorance. (M. [See also"},{"kind":"arabic","text_bw":"$ahorN","text_ar":"شَهْرٌ"},{"kind":"text","text":": and see"},{"kind":"arabic","text_bw":"run~aY","text_ar":"رُنَّى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Alr~un~aY","text_ar":"الرُّنَّى"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"rn","text_ar":"رن"},{"kind":"text","text":".])"}],"source_refs":["M","Msb","K","Lh","S","Mgh","As","T","AA","TA"]},{"entry_id":"n14388","headword_ar":"رَبِّىٌّ","root":"rb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rab~aAniY~N","text_ar":"رَبَّانِىٌّ"},{"kind":"text","text":". ―         -b2-  And for its pl.,"},{"kind":"arabic","text_bw":"rab~iy~uwna","text_ar":"رَبِّيُّونَ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"rib~iY~N","text_ar":"رِبِّىٌّ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n14389","headword_ar":"رُبِّىٌّ","root":"rb","body":[{"kind":"text","text":"rel. n. of"},{"kind":"arabic","text_bw":"rub~apN","text_ar":"رُبَّةٌ"},{"kind":"text","text":", q. v. (Sb, S, M.) ―         -b2-  See also its pl.,"},{"kind":"arabic","text_bw":"rub~iy~uwna","text_ar":"رُبِّيُّونَ"},{"kind":"text","text":", in the next paragraph, in two places."}],"source_refs":[]},{"entry_id":"n14390","headword_ar":"رِبِّىٌّ","root":"rb","body":[{"kind":"text","text":"sing. of"},{"kind":"arabic","text_bw":"rib~iy~uwna","text_ar":"رِبِّيُّونَ"},{"kind":"text","text":"(T, S, K,) which signifies"},{"kind":"italic_en","text":"Thousands"},{"kind":"text","text":"(Fr, Th, T, S, K) of men: (S, K:) accord. to Akh, it is from"},{"kind":"arabic","text_bw":"Alr~ab~u","text_ar":"الرَّبُّ"},{"kind":"text","text":"; and if so, it is ↓"},{"kind":"arabic","text_bw":"rab~iy~uwna","text_ar":"رَبِّيُّونَ","orth_type":"arrow"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":": but accord. to Fr, it is from"},{"kind":"arabic","text_bw":"rib~apN","text_ar":"رِبَّةٌ"},{"kind":"text","text":", meaning “ a company: ” (Th, T:) Zj says that it is"},{"kind":"arabic","text_bw":"rib~iy~uwna","text_ar":"رِبِّيُّونَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rub~iy~uwna","text_ar":"رُبِّيُّونَ","orth_type":"arrow"},{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"and also with damm to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", and signifies"},{"kind":"italic_en","text":"a numerous company:"},{"kind":"text","text":"he adds that"},{"kind":"arabic","text_bw":"rib~apN","text_ar":"رِبَّةٌ"},{"kind":"text","text":"is said by some to signify “ ten thousand; ” and that"},{"kind":"arabic","text_bw":"rb~yuwn","text_ar":"ربّيُون"},{"kind":"text","text":"is said to signify"},{"kind":"italic_en","text":"learned, pious, patient men;"},{"kind":"text","text":"and that each of these sayings is good: accord. to Aboo-Tálib, it signifies"},{"kind":"italic_en","text":"numerous companies:"},{"kind":"text","text":"(T:) [in the Kur iii. 140,] El-Hasan read ↓"},{"kind":"arabic","text_bw":"rub~iy~uwna","text_ar":"رُبِّيُّونَ","orth_type":"arrow"},{"kind":"text","text":"; and Ibn-' Abbas, ↓"},{"kind":"arabic","text_bw":"rab~iy~uwna","text_ar":"رَبِّيُّونَ","orth_type":"arrow"},{"kind":"text","text":"; the former with damm, and the latter with fet-h, to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":". (L, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"rab~aAniY~N","text_ar":"رَبَّانِىٌّ"},{"kind":"text","text":"."}],"source_refs":["T","S","K","Fr","Th"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%A8%D9%89/","headword_ar":"ربى","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=22302#4b9fa2","body_html":"<h3>رب</h3>ى<span class=\"sense\">1</span> رَبَيْتُ, in the copies of the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, in art. ربو, is a mistake for رَبِيتُ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in that art., <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>) لَا وَرَبِيكَ for لَا وَرَبِّكَ [as though رَبٍ were a <abbr title=\"dialect, لُغَةٌ\">dial.</abbr> var. of رَبٌّ]: see رَبٌّ (last sentence), in art. رب.<br><br>رِبَيَانِ a dual of رِبًا, mentioned in art. ربو.<br><br>رُبْيَةٌ A species. of the [small animals called]<br><br>حَشَرَات [<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>]: (<abbr title=\"Abū Ḥatim al-Sijistāniī\">AHát</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> and <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> * in art. ربو:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> رُبًى: (<abbr title=\"Abū Ḥatim al-Sijistāniī\">AHát</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) <abbr title=\"according\">accord.</abbr> to <abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, the rat, or mouse: <abbr title=\"plural, جَمْعٌ\">pl.</abbr> as above: (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) [or] a certain small beast, or reptile, between the rat, or mouse, and [what is called] أُمُّ حُبَيْنٍ [<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>]. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) and The cat. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> in art. ربو.) <span class=\"sub-sense\">A2:</span> See also رِبًا (last sentence), in art. ربو.<br><br>رُبَيَّةٌ: see رِبًا (last sentence), in art. ربو.<br><br>رُبِّيَّةٌ: see رِبًا (last sentence), in art. ربو.<br><br>أُرْبِيَّةٌ: see art. ربو.<br><br>إِرْبِيَانٌ A species of fish, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> and <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> in art. ربو, and <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr> in the present art.,) white, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) resembling worms, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) found at El-Basrah. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b2:</span> <abbr title=\"according\">Accord.</abbr> to <abbr title=\"Abū Bakr ibn al-Ṣayrafī\">Seer</abbr>, A certain plant. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.)"},{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=22302#27a00d","body_html":"<span>(ربى) : الإِربِيان: بَقْلَةٌ من ذُكورِ البَقْل، قال صالِحٌ: مع السَّعْدان نَبْتَ الإِربيانِ.</span>"},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=22302#ee22e2","body_html":"<div>ربى: رَبَّيْتُه وتَرَبَّيْتُه، وهو تَرْبِيَتي. ورَبِيْتُ بكُوْرَةِ كذا: إذا نَشَأْتَ بها.</div><div>وفلانٌ مُرْبٍ لفُلانٍ على سَوَايَةٍ: أي مُضْمِرٌ له ذاكَ. وهو الإِرْبَاءُ.</div><div>والرُّبْيَةُ من الحَشَرَاتِ: بَيْنَ الفَأْرِ وأُمِّ حُبَيْنٍ، والجَمِيْعُ الرُّبى.</div><div>والإِرْبِيَانُ: سَمَكَةٌ حَمْرَاءُ نَحْوُ الإِصْبَعِ المَعْقُوْفَةِ.</div><div>ورَبَّيْتُ عن فلانٍ: أي نَفَّسْت من خُنَاقِه.</div><div>ورَابَيْتُه مُرَابَاةً: أي صادَيْتُه ودارَيْته.</div><div>وفي صُلْحِ نَجْرَانَ: \" لَيْسَ عليهم رُبْيَةٌ ولا دَمٌ \"، وهي من الرِّبَا، وأصْلُه رُبْوَةٌ، ويُرْوى: رِبْيَةٌ.</div>"}]}}