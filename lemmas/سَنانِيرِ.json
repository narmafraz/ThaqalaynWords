{"lemma":"سَنانِيرِ","slug":"سَنانِيرِ","root":"س.ن.ر","root_slug":"س-ن-ر","root_link":"/words/roots/س-ن-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n20951","n20952"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%86%D8%A7%D9%86%D9%90%D9%8A%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"cat"}]},"etymology":{"source":"wiktextract","text":"Borrowed from Aramaic שׁוּנָּרָא / ܫܘܢܪܐ (šunnāra), ܣܢܘܪܐ (sannūrā), from Akkadian 𒊓𒀀 (šurānum), whence also Hebrew שֻׁנָּר (šunnār), ultimately non-Semitic."},"ipa":["/sin.nawr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20951","headword_ar":"سَنَوَّرٌ","root":"snr","body":[{"kind":"italic_en","text":"A coat made of thongs,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"worn in war,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"like a coat of mail:"},{"kind":"text","text":"(S, K:) [and]"},{"kind":"italic_en","text":"any weapon of iron:"},{"kind":"text","text":"(A:) and"},{"kind":"italic_en","text":"weapons,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arms, collectively:"},{"kind":"text","text":"(M, K:) or, accord. to some,"},{"kind":"italic_en","text":"coats of mail:"},{"kind":"text","text":"(M:) so As means in explaining"},{"kind":"arabic","text_bw":"Als~anaw~aru","text_ar":"السَّنَوَّرُ"},{"kind":"text","text":"as signifying"},{"kind":"italic_en","text":"what consists of rings:"},{"kind":"text","text":"(TA:) or, as some say,"},{"kind":"italic_en","text":"a coat of mail:"},{"kind":"text","text":"(Ham p. 352:) or"},{"kind":"italic_en","text":"all iron."},{"kind":"text","text":"(AO.)"}],"source_refs":["S","M","K","A","TA"]},{"entry_id":"n20952","headword_ar":"سِنَّوْرٌ","root":"snr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"cat;"},{"kind":"text","text":"of the masc. gender; syn."},{"kind":"arabic","text_bw":"hir~N","text_ar":"هِرٌّ"},{"kind":"text","text":"; (M, A, Msb;) as also ↓"},{"kind":"arabic","text_bw":"sun~aArN","text_ar":"سُنَّارٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"sunaArN","text_ar":"سُنَارٌ","orth_type":"arrow"},{"kind":"text","text":": (as in a copy of the M:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"sanaAniyru","text_ar":"سَنَانِيرُ"},{"kind":"text","text":": (S, Msb, K:) but"},{"kind":"arabic","text_bw":"sn~wr","text_ar":"سنّور"},{"kind":"text","text":"is rare in the language of the Arabs:"},{"kind":"arabic","text_bw":"hir~N","text_ar":"هِرٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DayowanN","text_ar":"ضَيْوَنٌ"},{"kind":"text","text":"are more common. (IAmb, Msb.) And"},{"kind":"arabic","text_bw":"Aibonu Als~in~awori","text_ar":"اِبْنُ السِّنَّوْرِ"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"dariS","text_ar":"دَرِص"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"daroS","text_ar":"دَرْص"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"kitten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (T in art."},{"kind":"arabic","text_bw":"bny","text_ar":"بني"},{"kind":"text","text":".) ―         -b2-"},{"kind":"italic_en","text":"A lord, master,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief;"},{"kind":"text","text":"(M, K;) in some copies of the K,"},{"kind":"arabic","text_bw":"siyd","text_ar":"سِيد"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"say~id","text_ar":"سَيِّد"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"a chief of a tribe:"},{"kind":"text","text":"(Sgh:) pl. as above. (Sgh, K.) ―         -b3-"},{"kind":"italic_en","text":"A vertebra"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"of the upper part"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"of the neck"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"of a camel:"},{"kind":"text","text":"(M, TA:) pl. as above. (TA.) ―         -b4-  The"},{"kind":"italic_en","text":"root of the tail:"},{"kind":"text","text":"(Er-Riyáshee, K:) pl. as above. (K.)"}],"source_refs":["K","Msb","S","Sgh","M","TA"]}]},"classical_definitions":null}