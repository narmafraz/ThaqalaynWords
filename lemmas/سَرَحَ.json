"role":"present_2mp","form":"تَسْرَحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْرَح","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْرَح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْرَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْرَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَرَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَرَحْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْرَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْرَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":21,"cross_references":{"qac":{"found":true,"lemma_key":"سَرَحَ","root":"سرح","pos":"V","occurrence_count":3},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["","n19511","n19512"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%B1%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19511","headword_ar":"سَرْحٌ","root":"srH","body":[{"kind":"italic_en","text":"Cattle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels &c., pasturing,"},{"kind":"text","text":"(S, A, Mgh, Msb, K,) or"},{"kind":"italic_en","text":"pasturing where they please, by themselves:"},{"kind":"text","text":"(S, A, K:) or only"},{"kind":"italic_en","text":"such as are sent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"driven, forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to pasture"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the morning, and brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"driven, back in the evening to their nightly resting-place:"},{"kind":"text","text":"(L:) an inf. n. used as a subst. (Mgh, Msb.) A'Obeyd says that"},{"kind":"arabic","text_bw":"saroHN","text_ar":"سَرْحٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saAriHN","text_ar":"سَارِحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saAriHapN","text_ar":"سَارِحَةٌ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"Cattle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels &c.:"},{"kind":"text","text":"and Khálid Ibn-Jembeh says that ↓"},{"kind":"arabic","text_bw":"saAriHapN","text_ar":"سَارِحَةٌ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"camels"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a single beast;"},{"kind":"text","text":"as well as"},{"kind":"italic_en","text":"a collection"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of beasts"},{"kind":"text","text":"]. (TA.)       -A2-  Also"},{"kind":"italic_en","text":"A certain kind of trees, of great size,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"and tall,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"not depastured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seldom eaten by the camels &c., but used for their shade: they grow in Nejd, in plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, and in rugged ground, but not in sand nor upon a mountain; and have a yellow fruit:"},{"kind":"text","text":"(TA:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": and it is said to be the"},{"kind":"italic_en","text":"same as the"},{"kind":"arabic","text_bw":"A='","text_ar":"ا=ء"},{"kind":"text","text":": (S:) but this is a mistake; the fact being that"},{"kind":"italic_en","text":"it bears a kind of berry termed"},{"kind":"arabic","text_bw":"A='","text_ar":"ا=ء"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"resembling the olive:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"any trees without thorns:"},{"kind":"text","text":"(K:) n. un. in this sense with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (Fr, Ham p. 603, TA:) or"},{"kind":"italic_en","text":"any tall trees:"},{"kind":"text","text":"(K:) or ["},{"kind":"italic_en","text":"trees"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the kind called"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":","},{"kind":"italic_en","text":"great, with spreading branches, beneath which men alight in the"},{"kind":"arabic","text_bw":"Sayof","text_ar":"صَيْف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"summer"},{"kind":"text","text":"]: (Ham ubi suprà:) accord. to AHn, the"},{"kind":"arabic","text_bw":"saroHap","text_ar":"سَرْحَة"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a great tree with spreading branches, beneath which people often alight, widely extending; men alight beneath it in the"},{"kind":"arabic","text_bw":"Sayof","text_ar":"صَيْف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"summer"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and pitch tents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"build houses, beneath it; and its shade is good:"},{"kind":"text","text":"accord. to information given to Az by an Arab of the desert not known by him to have uttered a lie,"},{"kind":"italic_en","text":"it has a dusty colour, is not so tall as the"},{"kind":"arabic","text_bw":"A^avol","text_ar":"اَثْل"},{"kind":"text","text":"[a species of tamarisk],"},{"kind":"italic_en","text":"has small leaves, and lank branches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"twigs, and always grows slanting, its inclination among all the trees being towards the south"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alyamiyn","text_ar":"اليَمِين"},{"kind":"text","text":"): Lth says that the"},{"kind":"arabic","text_bw":"saroH","text_ar":"سَرْح"},{"kind":"text","text":"are"},{"kind":"italic_en","text":"a kind of trees that have a fruit, and they are the"},{"kind":"arabic","text_bw":"A^alaA='","text_ar":"اَلَا=ء"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlAlA='","text_ar":"الالا=ء"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"AlA='","text_ar":"الا=ء"},{"kind":"text","text":", i. e. the"},{"kind":"arabic","text_bw":"A='","text_ar":"ا=ء"},{"kind":"text","text":",]); but Az says that this is a mistake: Lth cites the saying of' Antarah,"},{"kind":"quote","text":"baTalN kaA^an~a viyaAbahu fiY saroHapK\n                      \n                     \n                        tuHo*aY niEaAlu Als~iboti layosa bitawo'ami"},{"kind":"text","text":"(L,) i. e. He is"},{"kind":"italic_en","text":"a man of valour,"},{"kind":"text","text":"tall of stature,"},{"kind":"italic_en","text":"as though his clothes were upon a"},{"kind":"text","text":"great tree such as is called"},{"kind":"arabic","text_bw":"srHp","text_ar":"سرحة"},{"kind":"text","text":";"},{"kind":"italic_en","text":"sandals of"},{"kind":"arabic","text_bw":"sbt","text_ar":"سبت"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"are cut and made"},{"kind":"text","text":"for him, such as are worn by the kings; and"},{"kind":"italic_en","text":"he is not a twin;"},{"kind":"text","text":"so that he has been well suckled: (EM p. 245:) thus he describes this person as tall of stature, showing that the"},{"kind":"arabic","text_bw":"srHp","text_ar":"سرحة"},{"kind":"text","text":"is a large tree: but the"},{"kind":"arabic","text_bw":"AlA='","text_ar":"الا=ء"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"A='","text_ar":"ا=ء"},{"kind":"text","text":"] has no trunk nor tallness: IAar says that the"},{"kind":"arabic","text_bw":"saroH","text_ar":"سَرْح"},{"kind":"text","text":"are"},{"kind":"arabic","text_bw":"*akowaAn","text_ar":"ذَكْوَان"},{"kind":"italic_en","text":"that have become large;"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"*kwAn","text_ar":"ذكوان"},{"kind":"text","text":"are certain trees having beautiful [shoots such as are termed]"},{"kind":"arabic","text_bw":"EasaAliyj","text_ar":"عَسَالِيج"},{"kind":"text","text":": the pl. is"},{"kind":"arabic","text_bw":"siraAHN","text_ar":"سِرَاحٌ"},{"kind":"text","text":". (L.) ―         -b2-  The n. un.,"},{"kind":"arabic","text_bw":"saroHapN","text_ar":"سَرْحَةٌ"},{"kind":"text","text":", is applied to signify (tropical:)  A man's"},{"kind":"italic_en","text":"wife,"},{"kind":"text","text":"(S, A,) by a metonymy. (S.) The Arabs are said by Az to term a woman, or wife, a"},{"kind":"arabic","text_bw":"saroHp","text_ar":"سَرْحة"},{"kind":"text","text":"growing over water, because in this case it is in the most beautiful condition. (TA.) ―         -b3-  [Accord. to Forskål, (Flora Aegypt. Arab. pp. cvi. and 68,) the name of"},{"kind":"arabic","text_bw":"srH","text_ar":"سرح"},{"kind":"text","text":"is applied to a plant of the class pentandria, which he terms"},{"kind":"italic_en","text":"Cadaba farinosa,"},{"kind":"text","text":"(described by him in p. 68,) growing in the lower region of the mountains of Wádee-Surdud, in Tihámeh.]       -A3-  Also The"},{"kind":"italic_en","text":"exterior court"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"yard of a house,"},{"kind":"text","text":"(K,) or, as in the L,"},{"kind":"italic_en","text":"of a gate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"door."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","A","Mgh","Msb","K","L","TA"]},{"entry_id":"n19512","headword_ar":"سُرُحٌ","root":"srH","body":[{"kind":"italic_en","text":"Easy;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"sariyHN","text_ar":"سَرِيحٌ","orth_type":"arrow"},{"kind":"text","text":". (L.) You say,"},{"kind":"arabic","text_bw":"waladatohu suruHFA","text_ar":"وَلَدَتْهُ سُرُحًا"},{"kind":"italic_en","text":"She brought him forth with ease."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"taxoruju suruHFA","text_ar":"تَخْرُجُ سُرُحًا"},{"kind":"italic_en","text":"It passes forth easily and quickly:"},{"kind":"text","text":"occurring in a trad., describing a draught of water that satisfies thirst ("},{"kind":"arabic","text_bw":"$urobapu maA='K","text_ar":"شُرْبَةُ مَا=ءٍ"},{"kind":"text","text":"). (TA.) And"},{"kind":"arabic","text_bw":"naAqapN suruHN","text_ar":"نَاقَةٌ سُرُحٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"munosariHapN","text_ar":"مُنْسَرِحَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, she-camel;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"saruwHN","text_ar":"سَرُوحٌ","orth_type":"arrow"},{"kind":"text","text":": (L:) or"},{"kind":"italic_en","text":"a she-camel quick and easy in pace."},{"kind":"text","text":"(A, MA, and Har p. 481.) And"},{"kind":"arabic","text_bw":"farasN suruHN","text_ar":"فَرَسٌ سُرُحٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"munosariHN","text_ar":"مُنْسَرِحٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"siroyaAHN","text_ar":"سِرْيَاحٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"xayolN suruHN","text_ar":"خَيْلٌ سُرُحٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"A horse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"horses, quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift."},{"kind":"text","text":"(S, K.) [See also"},{"kind":"arabic","text_bw":"saraAHi","text_ar":"سَرَاحِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"sar~aAHN","text_ar":"سَرَّاحٌ"},{"kind":"text","text":".] And"},{"kind":"arabic","text_bw":"milaATN suruHu Aljanobi","text_ar":"مِلَاطٌ سُرُحُ الجَنْبِ"},{"kind":"italic_en","text":"A shoulderblade,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"an upper arm-bone,"},{"kind":"text","text":"of a camel, (ISh, T, TA,)"},{"kind":"italic_en","text":"quick to go and come"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"move forwards and backwards"},{"kind":"text","text":"]. (As, S, TA.) And"},{"kind":"arabic","text_bw":"mi$oyapN suruHN","text_ar":"مِشْيَةٌ سُرُحٌ"},{"kind":"italic_en","text":"An easy gait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner of going;"},{"kind":"text","text":"(S, K;) like"},{"kind":"arabic","text_bw":"sujuHN","text_ar":"سُجُحٌ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"EaTaA='N suruHN","text_ar":"عَطَا=ءٌ سُرُحٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A gift promptly given, without deferring:"},{"kind":"text","text":"(K:) or (tropical:)"},{"kind":"italic_en","text":"a gift that is easy and quick;"},{"kind":"text","text":"a metaphorical phrase from"},{"kind":"arabic","text_bw":"naAqapN suruHN","text_ar":"نَاقَةٌ سُرُحٌ"},{"kind":"text","text":"expl. above. (Har p. 481.)       -A2-  [See also"},{"kind":"arabic","text_bw":"sariyHapN","text_ar":"سَرِيحَةٌ"},{"kind":"text","text":", of which, in two senses, it is a pl.]"}],"source_refs":["L","K","TA","S","ISh","T"]}]}}