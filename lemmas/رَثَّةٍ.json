or spread as furniture, and of a rope: (M:) [i. e. it means"},{"kind":"italic_en","text":"any such thing that is old, and worn out,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bad:"},{"kind":"text","text":"] see also"},{"kind":"arabic","text_bw":"rav~N","text_ar":"رَثٌّ"},{"kind":"text","text":". ―         -b2-  Hence, (T, A, Mgh,)"},{"kind":"arabic","text_bw":"riv~apN","text_ar":"رِثَّةٌ"},{"kind":"text","text":"signifies (tropical:)  The"},{"kind":"italic_en","text":"weak"},{"kind":"text","text":"of mankind; (T, S, M, A, Mgh, K;) [the"},{"kind":"italic_en","text":"old, and worn-out,"},{"kind":"text","text":"thereof;] and the"},{"kind":"italic_en","text":"refuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"basest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meanest sort,"},{"kind":"text","text":"thereof: (S, M:) as being likened to the chattels, or articles of furniture, thus termed. (A, Mgh.) ―         -b3-  Also (assumed tropical:)"},{"kind":"italic_en","text":"A foolish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupid, woman; one who is unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient, in intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding."},{"kind":"text","text":"(S, K.)"}],"source_refs":["T","S","M","Mgh","K","A"]}]},"classical_definitions":null}