{"lemma":"أَتْقَيَيْنِ","slug":"أَتْقَيَيْنِ","root":"ت.ق.#","root_slug":"ت-ق-_","root_link":"/words/roots/ت-ق-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَتْقَى","root":"وقي","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n44703"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AA%D9%92%D9%82%D9%8E%D9%8A%D9%8E%D9%8A%D9%92%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"more righteous, more God-fearing, more pious","examples":[{"text":"إِنَّ أَكْرَمَكُمْ عِنْدَ ٱللّٰهِ أَتْقَاكُمْ"}]}]},"etymology":{"source":"wiktextract","text":"Elative of تَقِيّ (taqiyy, “God-fearing, pious”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44703","headword_ar":"اِتَّقى","root":"wqY","body":[{"kind":"italic_en","text":"He preserved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarded, himself exceedingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinarily:"},{"kind":"text","text":"(Ksh, Bd in ii. 1:)"},{"kind":"italic_en","text":"he put a thing between him and another to preserve him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guard him."},{"kind":"text","text":"(Ham, p. 359.) ―         -b2-  In the conventional language of the law,"},{"kind":"italic_en","text":"He preserved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarded, himself exceedingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinarily,"},{"kind":"text","text":"(Ksh, Bd, ubi supra,)"},{"kind":"italic_en","text":"from sin, of commission"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of omission,"},{"kind":"text","text":"(Ksh,) [or]"},{"kind":"italic_en","text":"from what would harm him in the world to come."},{"kind":"text","text":"(Bd, who describes three degrees.) It may often be rendered"},{"kind":"italic_en","text":"He was pious;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"careful of his religious duties."},{"kind":"text","text":"―         -b3-"},{"kind":"arabic","text_bw":"Ait~aqaY Ealayohimo waHa*ira","text_ar":"اِتَّقَى عَلَيْهِمْ وَحَذِرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He guarded himself against them in an extraordinary degree, and was cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wary"},{"kind":"text","text":"]. (JK, TA, in art."},{"kind":"arabic","text_bw":"x$Y","text_ar":"خشى"},{"kind":"text","text":".) See 1. ―         -b4-"},{"kind":"arabic","text_bw":"yatoqiY","text_ar":"يَتْقِى"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"yat~aqiY","text_ar":"يَتَّقِى"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"tqY","text_ar":"تقى"},{"kind":"text","text":": and see a verse of Khufáf Ibn-Nudbeh, (quoted in the S, in art."},{"kind":"arabic","text_bw":"wqY","text_ar":"وقى"},{"kind":"text","text":",) cited voce"},{"kind":"arabic","text_bw":"A^avorN","text_ar":"اَثْرٌ"},{"kind":"text","text":". ―         -b5-"},{"kind":"arabic","text_bw":"yat~aqo","text_ar":"يَتَّقْ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"yat~aqi","text_ar":"يَتَّقِ"},{"kind":"text","text":": see a verse cited voce"},{"kind":"arabic","text_bw":"mutaA^aw~ibN","text_ar":"مُتَاَوِّبٌ"},{"kind":"text","text":"."}],"source_refs":["Ksh"]}]},"classical_definitions":null}