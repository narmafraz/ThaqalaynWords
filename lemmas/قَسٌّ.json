text","text":"pl. of"},{"kind":"arabic","text_bw":"A^atuwnN","text_ar":"اَتُونٌ"},{"kind":"text","text":", (Fr,) [Syr."},{"kind":"text","text":"165"},{"kind":"text","text":", a"},{"kind":"text","text":"consenuit, (Golius,)] The"},{"kind":"italic_en","text":"head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, of the Christians, in knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"one of the heads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chiefs, of the Christians,"},{"kind":"text","text":"(S, M,)"},{"kind":"italic_en","text":"in religion and knowledge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science:"},{"kind":"text","text":"(S:) or the"},{"kind":"italic_en","text":"learned man of the Christians:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"an intelligent, an ingenious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a clever, and a learned, man:"},{"kind":"text","text":"(M:) [in the present day applied to"},{"kind":"italic_en","text":"a Christian presbyter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"priest:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"jaAvaliyqN","text_ar":"جَاثَلِيقٌ"},{"kind":"text","text":":] pl. (of the first, Msb)"},{"kind":"arabic","text_bw":"qusuwsN","text_ar":"قُسُوسٌ"},{"kind":"text","text":", (Msb, K,) and (of the second, M, Msb)"},{"kind":"arabic","text_bw":"qis~iysuwna","text_ar":"قِسِّيسُونَ"},{"kind":"text","text":"(Fr, M, Msb, K) and"},{"kind":"arabic","text_bw":"qasaAqisapN","text_ar":"قَسَاقِسَةٌ"},{"kind":"text","text":", (Fr, and so in some copies of the K,) contr. to rule, (TA,) or"},{"kind":"arabic","text_bw":"qasaAwisapN","text_ar":"قَسَاوِسَةٌ"},{"kind":"text","text":", (M, Sgh, and so in some copies of the K,) contr. to rule, (M,) one of the seens [in the original form, which is"},{"kind":"arabic","text_bw":"qasaAsisapN","text_ar":"قَسَاسِسَةٌ"},{"kind":"text","text":",] being changed into wáw. (CK [but in the copies of the K which have"},{"kind":"arabic","text_bw":"qasaAqisapN","text_ar":"قَسَاقِسَةٌ"},{"kind":"text","text":", we find added “ and the seens being many, ” meaning, in the original form"},{"kind":"arabic","text_bw":"qasaAsisapN","text_ar":"قَسَاسِسَةٌ"},{"kind":"text","text":", or in"},{"kind":"arabic","text_bw":"qis~iysN","text_ar":"قِسِّيسٌ"},{"kind":"text","text":", “ they change one of them into wáw. ”])       -A2-"},{"kind":"arabic","text_bw":"qas~N","text_ar":"قَسٌّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Hoar-frost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rime."},{"kind":"text","text":"(A, K.) See"},{"kind":"arabic","text_bw":"qas~iY~N","text_ar":"قَسِّىٌّ"},{"kind":"text","text":"."}],"source_refs":["S","M","A","Msb","K","Fr","Golius","TA"]}]},"classical_definitions":null}