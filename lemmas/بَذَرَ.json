ind":"text","text":"(T, MF) and"},{"kind":"arabic","text_bw":"tabo*irapN","text_ar":"تَبْذِرَةٌ"},{"kind":"text","text":": (T:) this is the primary signification. (MF.) ―         -b2-  Also, (M,) inf. n. as above, (M, K,)"},{"kind":"italic_en","text":"He sowed"},{"kind":"text","text":"land; (M, L, K;) and so ↓"},{"kind":"arabic","text_bw":"b*~r","text_ar":"بذّر","orth_type":"arrow"},{"kind":"text","text":", (M, L,) inf. n."},{"kind":"arabic","text_bw":"tabo*iyrN","text_ar":"تَبْذِيرٌ"},{"kind":"text","text":". (L, K.) ―         -b3-  Also, (M,) inf. n. as above, (M, K,)"},{"kind":"italic_en","text":"He scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"(M, K,) a thing; (M;) and so ↓"},{"kind":"arabic","text_bw":"b*~r","text_ar":"بذّر","orth_type":"arrow"},{"kind":"text","text":", [or rather"},{"kind":"italic_en","text":"he scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, much,"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"tabo*iyrN","text_ar":"تَبْذِيرٌ"},{"kind":"text","text":". (K.) ―         -b4-"},{"kind":"arabic","text_bw":"ba*ara A@ll~`hu","text_ar":"بَذَرَ ا@للّٰهُ"},{"kind":"arabic","text_bw":"Alxaloqi","text_ar":"الخَلْقِ"},{"kind":"text","text":", (M, A,) inf. n. as above, (M,)"},{"kind":"italic_en","text":"God scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, mankind"},{"kind":"text","text":"(M, A) in the earth. (A.) ―         -b5-"},{"kind":"arabic","text_bw":"ba*ara AlkalaAma","text_ar":"بَذَرَ الكَلَامَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He disseminated, scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diffused, talk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech,"},{"kind":"text","text":"(Msb, TA,)"},{"kind":"arabic","text_bw":"bayona Aln~aAsi","text_ar":"بَيْنَ النَّاسِ"},{"kind":"italic_en","text":"among the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mankind,"},{"kind":"text","text":"like as seed is scattered: (TA:) and ↓"},{"kind":"arabic","text_bw":"b*~rhu","text_ar":"بذّرهُ","orth_type":"arrow"},{"kind":"italic_en","text":"he did so much."},{"kind":"text","text":"(Msb.) ―         -b6-"},{"kind":"arabic","text_bw":"ba*arati AlA^aroDu","text_ar":"بَذَرَتِ الاَرْضُ"},{"kind":"text","text":", (M, A,) aor. as above, (M,) and so the inf. n., (M, K,) (tropical:)"},{"kind":"italic_en","text":"The land put forth its plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage,"},{"kind":"text","text":"(As, M, A, K,)"},{"kind":"italic_en","text":"in a scattered state:"},{"kind":"text","text":"(As, M, A:) or"},{"kind":"italic_en","text":"put forth its"},{"kind":"arabic","text_bw":"ba*or","text_ar":"بَذْر"},{"kind":"text","text":". (M.)       -A2-"},{"kind":"arabic","text_bw":"ba*ura","text_ar":"بَذُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ba*aArapN","text_ar":"بَذَارَةٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He divulged what was secret; he revealed what he had heard."},{"kind":"text","text":"(T, L.)       -A3-"},{"kind":"arabic","text_bw":"ba*ira","text_ar":"بَذِرَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"ba*arN","text_ar":"بَذَرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He talked much; was loquacious."},{"kind":"text","text":"(M.)"}],"source_refs":["T","S","A","Msb","K","MF","M","L","TA","As"]}]}}