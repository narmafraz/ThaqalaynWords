{"lemma":"أَحالَ","slug":"أَحالَ","root":"ح.#.ل","root_slug":"ح-_-ل","root_link":"/words/roots/ح-_-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَحَلْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَحَلْتِ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَحَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَحَلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَحَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَحالَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَحالَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَحالا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَحالَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَحالُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَحَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُحِل","in_corpus":true,"count":77,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُحَل","in_corpus":true,"count":77,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُحال","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُحِيل","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُحالِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُحالِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُحِيلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُحِيلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُحالانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُحالا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُحِيلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُحِيلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُحالُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحالُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحِيلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحِيلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُحَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحِل","in_corpus":true,"count":145,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُحال","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُحِيل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحِل","in_corpus":true,"count":77,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُحال","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُحِيل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحالانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحالا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحِيلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحِيلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحالانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحالا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحِيلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحِيلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحالُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحالُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحِيلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحِيلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُحَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَحَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَحَلْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُحال","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحال","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحِيل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحِيل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":395,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["verb"],"has_etymology":true,"sense_count":17},"lanes":{"found":true,"entry_ids":["n9575"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AD%D8%A7%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to change, to transform","tags":["transitive"]},{"pos":"verb","gloss":"to translate, to convert","tags":["transitive"]},{"pos":"verb","gloss":"to transfer","tags":["transitive"]},{"pos":"verb","gloss":"to send","tags":["transitive"]},{"pos":"verb","gloss":"to assign","tags":["transitive"]},{"pos":"verb","gloss":"to forward, to pass on","tags":["transitive"]},{"pos":"verb","gloss":"to refer","tags":["transitive"]},{"pos":"verb","gloss":"to change","tags":["intransitive"]},{"pos":"verb","gloss":"to sit firmly","tags":["intransitive"]},{"pos":"verb","gloss":"to appear, to come on (of the night)","tags":["intransitive"]},{"pos":"verb","gloss":"to be or become a year old","tags":["intransitive"]},{"pos":"verb","gloss":"to remain (somewhere) for a year","tags":["intransitive"]},{"pos":"verb","gloss":"to not become pregnant during a given year (of a female camel, or sometimes a woman)","tags":["intransitive"]},{"pos":"verb","gloss":"to not bear fruit during a given year (of a palm tree)","tags":["intransitive"]},{"pos":"verb","gloss":"to assault [with عَلَى (ʕalā) ‘someone’] (with a whip, spear, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to fatten [with بِ (bi) ‘someone’] (of bread, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to utter untruth or absurdities","tags":["intransitive"]}]},"etymology":{"source":"wiktextract","text":"Denominative from حَوْل (ḥawl, “year”), originally a \"turning\"."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9575","headword_ar":"احال","root":"Hwl","body":[{"kind":"text","text":", as an intrans. v.: see 1, in eighteen places. ―         -b2-"},{"kind":"arabic","text_bw":"tajan~aba rawoDapF waA^aHaAla yaEoduw","text_ar":"تَجَنَّبَ رَوْضَةً وَاَحَالَ يَعْدُو"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He withdrew from a meadow, and set to running,"},{"kind":"text","text":"] is a prov., meaning he forsook abundance of herbage, or of the goods and conveniences and comforts of life, and preferred to it straitness, or difficulty. (S.) ―         -b3-"},{"kind":"arabic","text_bw":"AHAl Ealayohi biAls~awoTi","text_ar":"احال عَلَيْهِ بِالسَّوْطِ"},{"kind":"italic_en","text":"He set upon him with the whip,"},{"kind":"text","text":"(S, MA, K,)"},{"kind":"arabic","text_bw":"yaDoribuhu","text_ar":"يَضْرِبُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"striking him"},{"kind":"text","text":"]: (S:) or"},{"kind":"italic_en","text":"he desired to strike him with the whip:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he struck him with the whip:"},{"kind":"text","text":"(MA:) and"},{"kind":"arabic","text_bw":"A^aHalotuhu","text_ar":"اَحَلْتُهُ"},{"kind":"arabic","text_bw":"biAls~awoTi","text_ar":"بِالسَّوْطِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biAlr~umoHi","text_ar":"بِالرُّمْحِ"},{"kind":"text","text":", [if"},{"kind":"arabic","text_bw":"AHlth","text_ar":"احلته"},{"kind":"text","text":"be not a mistranscription for"},{"kind":"arabic","text_bw":"A^aHalotu Ealayohi","text_ar":"اَحَلْتُ عَلَيْهِ"},{"kind":"text","text":", in the MS. from which I take this, as it may be inferred to be from what here precedes and follows,]"},{"kind":"italic_en","text":"I aimed at him with the whip,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"with the spear, and set upon him with it:"},{"kind":"text","text":"whence the saying, of him who has struck one at the point of death, and killed him,"},{"kind":"arabic","text_bw":"yuHiylu Almawota EalaY AlD~arobi","text_ar":"يُحِيلُ المَوْتَ عَلَى الضَّرْبِ"},{"kind":"text","text":", i. e. (assumed tropical:)"},{"kind":"italic_en","text":"He makes death"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as it were"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to hang upon, and cleave to, striking;"},{"kind":"text","text":"like as the spear is made to cleave to the"},{"kind":"arabic","text_bw":"muHaAl","text_ar":"مُحَال"},{"kind":"arabic","text_bw":"Ealayoh","text_ar":"عَلَيْه"},{"kind":"text","text":", who is the person thrust, or pierced. (Msb.) El-Farezdak says, (S, TA,) addressing Hubeyreh Ibn-Damdam, (TA,)"},{"kind":"quote","text":"wakunota ka*iy^obi Als~awo'i lam~aA raA^aY damFA\n                      \n                     \n                        biSaAHibihi yawomFA A^aHaAla EalaY Ald~ami"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"And thou mast like the wicked wolf: when he saw blood upon his companion, one day,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he set upon the blood."},{"kind":"text","text":"(S, TA.) ―         -b4-  [Hence, perhaps,]"},{"kind":"arabic","text_bw":"HAl Ealayohi","text_ar":"حال عَلَيْهِ"},{"kind":"italic_en","text":"He reckoned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"esteemed him, weak."},{"kind":"text","text":"(K.) ―         -b5-"},{"kind":"arabic","text_bw":"AHAl All~ayoli","text_ar":"احال اللَّيْلِ"},{"kind":"italic_en","text":"Night poured upon the earth;"},{"kind":"text","text":"(K;) and"},{"kind":"italic_en","text":"came on."},{"kind":"text","text":"(TA.) [See also 1, last sentence but one.] ―         -b6-"},{"kind":"arabic","text_bw":"AHAl bifulaAnK Alxubozu","text_ar":"احال بِفُلَانٍ الخُبْزُ"},{"kind":"italic_en","text":"The bread fattened such a one;"},{"kind":"text","text":"and in like manner one says of anything by which one becomes fat. (AA, TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"AHAl","text_ar":"احال"},{"kind":"italic_en","text":"He did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"said, what was"},{"kind":"arabic","text_bw":"muHaAl","text_ar":"مُحَال"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"absurd, inconsistent, self-contradictory, unreal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impossible"},{"kind":"text","text":"]. (S, Sgh, K. *) ―         -b8-  And"},{"kind":"italic_en","text":"His camels did not conceive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become pregnant,"},{"kind":"text","text":"(AA, S, K,)"},{"kind":"italic_en","text":"during a year,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two years,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"some years,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"having been covered."},{"kind":"text","text":"(S.)       -A2-  As a trans. v.: see 2, in three places. ―         -b2-"},{"kind":"arabic","text_bw":"AHAl Algariyma","text_ar":"احال الغَرِيمَ"},{"kind":"italic_en","text":"He referred the creditor, from himself,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the payment of what was due to him,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to another."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"A^aHalotuhu bidayonihi","text_ar":"اَحَلْتُهُ بِدَيْنِهِ"},{"kind":"italic_en","text":"I transferred his debt"},{"kind":"text","text":"[i. e. the debt due to him from me]"},{"kind":"italic_en","text":"by making another person than myself responsible for it."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^aHalotu zayodFA bimaA kaAna lahu EalaY~a EalaY rajulK","text_ar":"اَحَلْتُ زَيْدًا بِمَا كَانَ لَهُ عَلَىَّ عَلَى رَجُلٍ"},{"kind":"italic_en","text":"I referred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned over, Zeyd, for the payment of what was due to him from me, to a certain man, transferring the responsibility for the debt to the latter:"},{"kind":"text","text":"in which case, I am termed ↓"},{"kind":"arabic","text_bw":"muHiylN","text_ar":"مُحِيلٌ","orth_type":"arrow"},{"kind":"text","text":"; and Zeyd is termed ↓"},{"kind":"arabic","text_bw":"muHaAlN","text_ar":"مُحَالٌ","orth_type":"arrow"},{"kind":"text","text":"; and the other man,"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muHaAlN","text_ar":"مُحَالٌ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muHotaAlN","text_ar":"مُحْتَالٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"HawiylN","text_ar":"حَوِيلٌ","orth_type":"arrow"},{"kind":"text","text":"; and the property,"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muHaAlN","text_ar":"مُحَالٌ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) and ↓"},{"kind":"arabic","text_bw":"Hay~ilN","text_ar":"حَيِّلٌ","orth_type":"arrow"},{"kind":"text","text":", [originally"},{"kind":"arabic","text_bw":"HawiylN","text_ar":"حَوِيلٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"HayowilN","text_ar":"حَيْوِلٌ"},{"kind":"text","text":",] also, is applied to him to whom the reference is made; and to him who accepts the reference; both together being termed"},{"kind":"arabic","text_bw":"Hay~ilaAni","text_ar":"حَيِّلَانِ"},{"kind":"text","text":". (Aboo-Sa'eed, TA.) And you say,"},{"kind":"arabic","text_bw":"AHAl","text_ar":"احال"},{"kind":"arabic","text_bw":"Ealayohi bidayonihi","text_ar":"عَلَيْهِ بِدَيْنِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He referred"},{"kind":"text","text":"a person"},{"kind":"italic_en","text":"to him for the payment of his debt"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"AHAl","text_ar":"احال"},{"kind":"text","text":"[alone]"},{"kind":"italic_en","text":"He transferred the debt for which he was responsible to the responsibility of another."},{"kind":"text","text":"(Har p. 59.) And"},{"kind":"arabic","text_bw":"A^aHalotu AlA^amora EalaY zayodK","text_ar":"اَحَلْتُ الاَمْرَ عَلَى زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I turned over the affair to Zeyd;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I made the performance of the affair to be required restrictively of Zeyd."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"AHAl Ealayohi AlmaA='a","text_ar":"احال عَلَيْهِ المَا=ءَ"},{"kind":"italic_en","text":"He poured out the water upon it:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"AHAl AlmaA='a mina Ald~alowi","text_ar":"احال المَا=ءَ مِنَ الدَّلْوِ"},{"kind":"italic_en","text":"he poured forth the water from the bucket, and turned over the latter."},{"kind":"text","text":"(S.) ―         -b4-"},{"kind":"arabic","text_bw":"AHAl A@ll~`hu Ealayohi","text_ar":"احال ا@للّٰهُ عَلَيْهِ"},{"kind":"arabic","text_bw":"AlHawola","text_ar":"الحَوْلَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God made the year to pass over him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]: (Lh, TA:) or"},{"kind":"arabic","text_bw":"AHAl All~`h AlHawola","text_ar":"احال اللّٰه الحَوْلَ"},{"kind":"italic_en","text":"God made the year complete."},{"kind":"text","text":"(K, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"AHAl Alr~ajulu A_ibilahu","text_ar":"احال الرَّجُلُ اـِبِلَهُ"},{"kind":"arabic","text_bw":"AlEaAma","text_ar":"العَامَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The man made his she-camels to pass the year without becoming pregnant;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the stallion did not cover the man's she-camels during the year."},{"kind":"text","text":"(Lh, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"A^aHowala Eayonahu","text_ar":"اَحْوَلَ عَيْنَهُ"},{"kind":"text","text":", (Ks, Lh, S,) or"},{"kind":"arabic","text_bw":"A^aHaAlahaA","text_ar":"اَحَالَهَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Hw~lhA","text_ar":"حوّلها","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He made his eye to be"},{"kind":"arabic","text_bw":"HawolaA='a","text_ar":"حَوْلَا=ءَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"squinting,"},{"kind":"text","text":"&c.]. (Ks, Lh, S, K.) [See 1, last sentence.] ―         -b7-"},{"kind":"arabic","text_bw":"AHAl kalaAmahu","text_ar":"احال كَلَامَهُ"},{"kind":"italic_en","text":"He made his speech"},{"kind":"arabic","text_bw":"muHaAl","text_ar":"مُحَال"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"absurd, inconsistent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self-contradictory"},{"kind":"text","text":"]. (S. [See also 2.])       -A3-"},{"kind":"arabic","text_bw":"maA A^aHowala","text_ar":"مَا اَحْوَلَ"},{"kind":"arabic","text_bw":"Hiylaka","text_ar":"حِيلَكَ"},{"kind":"italic_en","text":"How fluctuating,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"shifting,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"varying, are thy evasions, wiles, artifices,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"artful contrivances"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"devices!"},{"kind":"text","text":"(Har p. 309.) ―         -b2-  And"},{"kind":"arabic","text_bw":"maA A^aHowalahu","text_ar":"مَا اَحْوَلَهُ"},{"kind":"italic_en","text":"How surpassing is he in the practice of evasions, shifts, wiles, artifices,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"artful contrivances"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"devices;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in turning over,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revolving, thoughts, ideas, schemes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contrivances, in his mind, so as to find a way of attaining his object!"},{"kind":"text","text":"(Fr, S, K;) as also"},{"kind":"arabic","text_bw":"mA A^aHoyalahu","text_ar":"ما اَحْيَلَهُ"},{"kind":"text","text":". (Fr, S in art."},{"kind":"arabic","text_bw":"Hyl","text_ar":"حيل"},{"kind":"text","text":", and K.)"}],"source_refs":["S","MA","K","TA","AA","Mgh","Lh","Ks"]}]},"classical_definitions":null}