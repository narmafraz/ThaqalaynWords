nt":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَبَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَبِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَبِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَبُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَبُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَبَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعَبِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُعَبّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَبَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَبَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُعَبَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَبَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَبِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَبِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n27761","n27919"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%A8%D9%8E%D9%91%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27761","headword_ar":"عُبَّى","root":"Eb","body":[{"kind":"text","text":"A woman"},{"kind":"italic_en","text":"of whom a child scarcely ever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"never, dies."},{"kind":"text","text":"(Kr, K.)"}],"source_refs":[]},{"entry_id":"n27919","headword_ar":"عَبِىٌّ","root":"EbY","body":[{"kind":"text","text":"One's"},{"kind":"italic_en","text":"share"},{"kind":"text","text":"of the"},{"kind":"arabic","text_bw":"jazuwr","text_ar":"جَزُور"},{"kind":"text","text":"[or slaughtered camel for portions of which the players at the game called"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"text","text":"contend]. (K, TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D8%A8%D9%89/","headword_ar":"عبى","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=11118#d5eb4b","body_html":"عبى: عبى ومشتقاتها: انظرها في مادة عبأ."},{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=11118#7537be","body_html":"<span>(عبى) : هذا عَبُّيكَ من هذه الجَزُورِ، أَي نَصِيبُك وخُذْ عَبِيَّكَ من هذا الحيِّ، أي قِطْعَةَ منهُم، إذا صَنَع طَعاماً ليُعِينُوك.</span><br><span>(والتَّعابِي: أن يَمِيلَ رَجُلٌ مع قَوْم، والآخَرُ مع قوم آخَرين، وذلك إذا صَنَعُوا طَعاماً، فخَبَزَ أَحدُ الفَريقين لهذا، والآخرُ لآخر.</span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=11118#9be756","body_html":"<span class=\"title1\">[عبى]</span><span> العَباءَةُ والعَبايَةُ: ضربٌ من الأكسية، والجمع العَباءُ والعَباءَات. وقال يونس: عَبَّيْتُ الجيش تَعْبِيَةً وتَعْبِئَةً وتَعْبِيئاً، إذا هيّأته في مواضعه. وقال أبو زيد: عبأته بالهمز.</span><span> </span><a></a><a></a><span>(*)</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=11118#55ab6a","body_html":"<h3>عب</h3>ى<span class=\"sense\">2</span> عَبَّيْتُ الجَيْشَ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَعْبِيَةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and تَعْبِئَةٌ and تَعْبِىْءٌ, so said <abbr title=\"Yoonus (Yūnūs bin Ḥabīb)\">Yoo</abbr>; but <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr> said عَبَّأْتُهُ; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>; [see art. عبأ;]) I prepared, or made ready, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, *) or set in order, disposed, or arranged, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) the army (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) in their places. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> See also 2 in art. عبو.<span class=\"sense\">6</span> التَّعَابِى signifies The aiding, or assisting, of one party by one man, and of another party by another man, when they prepare a repast, one of the two parties making bread for this, and the other for another. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 8 الاِعْتِبَآءُ, mentioned here in the <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, as <abbr title=\"synonymous with, لُغَةٌ فِى\">syn. with</abbr> الاِحْتِشَآءُ, see 8 in art. عبأ.<br><br>عَبًا and ↓ عَبَايَةٌ, but the former the more chaste, are said to signify, as epithets applied to a man, Coarse, or rude, heavy, dull, or stupid, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and impotent: but this requires correction; for <abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr> mentions العَبَا, and ↓ العَبَآءُ as used by a poet, and says that they signify the coarse, or rude, impotent, man; but <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr> says that he had not heard العَبَآء in this sense on any authority other than that of <abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, and that he held the right reading in the verse cited as an <abbr title=\"example\">ex.</abbr> by <abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr> to be العَيَآء, with ى, meaning, as also العَيَايَآء, “the coarse, or rude, or the heavy, dull, or stupid, and impotent, who has no need of women. ” (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) عَبَآءٌ: see عَبَايَةٌ, in two places.<br><br><span class=\"sub-sense\">A2:</span> And see also عَبًا, above.<br><br>عباة [<abbr title=\"apparently\">app.</abbr> عَبَاةٌ] The [kind of plant called]<br><br>سُطَّاح that spreads upon the ground. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) عَبِىٌّ One's share of the جَزُور [or slaughtered camel for portions of which the players at the game called المَيْسِر contend]. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) عَبَايَةٌ and عَبَآءَةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) A sort of [the kind of garments called] أَكْسِيَة [<abbr title=\"plural, جَمْعٌ\">pl.</abbr> of كِسَآء], (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) wide, (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and [generally] having in it large black [or brown] stripes: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> [of the latter] عَبَاآتٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>) and ↓ عَبَآءٌ, (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) formed by the elision of the ة, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) [or rather this is a <abbr title=\"collective generic noun, اِسْمُ جِنْسٍ جِمْعِىٌّ; also called a lexicological plural, جَمْعٌ لُغَوِىُّ\">coll. gen. n.</abbr>,] and the <abbr title=\"plural, جَمْعٌ\">pl.</abbr> of عَبَايَةٌ is عُبِىٌّ, like عُتِىٌّ: or, <abbr title=\"according\">accord.</abbr> to some, ↓ عَبَآءٌ is a <abbr title=\"singular, مُفْرَدٌ and وَاحِدٌ\">sing.</abbr>; for they say that it signifies a sort of أَكْسِيَة, and that its <abbr title=\"plural, جَمْعٌ\">pl.</abbr> is أَعْبِيَةٌ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See عَبَآءَةٌ in art. عبأ.<br><br><span class=\"sub-sense\">A2:</span> See also عَبًأ, above."}]}}