{"lemma":"مُشْكِلِ","slug":"مُشْكِلِ","root":"ش.ك.ل","root_slug":"ش-ك-ل","root_link":"/words/roots/ش-ك-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n22863","n22864"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B4%D9%92%D9%83%D9%90%D9%84%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"mixed, made of different assembled contents or parts"},{"pos":"adj","gloss":"complex"},{"pos":"adj","gloss":"miscellaneous, varied, diverse"},{"pos":"adj","gloss":"dubious"},{"pos":"adj","gloss":"difficult"},{"pos":"adj","gloss":"enigmatic"},{"pos":"noun","gloss":"problem"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb أَشْكَلَ (ʔaškala)."},"ipa":["/muʃ.kil/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22863","headword_ar":"مُشْكِلٌ","root":"$kl","body":[{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"A^a$okala","text_ar":"اَشْكَلَ"},{"kind":"text","text":"in the first of the senses assigned to it above, signifies"},{"kind":"italic_en","text":"Entering among"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"confused with"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its likes."},{"kind":"text","text":"(TA.) ―         -b2-  And [hence, app., or] accord. to Sh, from"},{"kind":"arabic","text_bw":"$ukolapN","text_ar":"شُكْلَةٌ"},{"kind":"text","text":"meaning “ redness mixed with whiteness, ” it signifies (assumed tropical:)"},{"kind":"italic_en","text":"Dubious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused."},{"kind":"text","text":"(TA.) [Used as a subst.,] it has for its pl."},{"kind":"arabic","text_bw":"mu$okilaAtN","text_ar":"مُشْكِلَاتٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"ma$aAkilu","text_ar":"مَشَاكِلُ"},{"kind":"text","text":"also: for] one says,"},{"kind":"arabic","text_bw":"huwa yafuk~u Alma$aAkila","text_ar":"هُوَ يَفُكُّ المَشَاكِلَ"},{"kind":"text","text":", meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"He solves"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs, that are dubious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"m$kl","text_ar":"مشكل"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"mu$okilN","text_ar":"مُشْكِلٌ"},{"kind":"text","text":"], applied to a horse, means"},{"kind":"italic_en","text":"Having a whiteness in his flanks."},{"kind":"text","text":"(AA, TA in art."},{"kind":"arabic","text_bw":"dEm","text_ar":"دعم"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n22864","headword_ar":"مُشَكَّلٌ","root":"$kl","body":[{"kind":"italic_en","text":"Endowed with a goodly aspect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appearance,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"form."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":null}