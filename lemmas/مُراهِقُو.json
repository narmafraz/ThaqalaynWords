{"lemma":"مُراهِقُو","slug":"مُراهِقُو","root":"ر.ه.ق","root_slug":"ر-ه-ق","root_link":"/words/roots/ر-ه-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n16890"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B1%D8%A7%D9%87%D9%90%D9%82%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"adolescent, teenager"}]},"etymology":null,"ipa":["/mu.raː.hiq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16890","headword_ar":"مُرَاهِقٌ","root":"rhq","body":[{"kind":"italic_en","text":"Near to attaining puberty;"},{"kind":"text","text":"applied to a boy: (JK, Mgh, TA:) and with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"applied to a girl. (TA.) [See also"},{"kind":"arabic","text_bw":"raAhiqN","text_ar":"رَاهِقٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"daxala","text_ar":"دَخَلَ"},{"kind":"arabic","text_bw":"mak~apa muraAhiqFA","text_ar":"مَكَّةَ مُرَاهِقًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He entered Mekkeh nearly at the end of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"proper"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to do so as a pilgrim"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"so that he almost missed the halt at 'Arafát."},{"kind":"text","text":"(Nh, O, K, TA.) And"},{"kind":"arabic","text_bw":"Sal~aY AlZ~uhora muraAhiqFA","text_ar":"صَلَّى الظُّهْرَ مُرَاهِقًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He performed the noon-prayer nearly missing the time."},{"kind":"text","text":"(TA.)"}],"source_refs":["JK","Mgh","TA"]}]},"classical_definitions":null}