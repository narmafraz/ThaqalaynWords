{"lemma":"تابَ","slug":"تابَ","root":"ت.#.ب","root_slug":"ت-_-ب","root_link":"/words/roots/ت-_-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"تُبْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"تُبْتِ","in_corpus":true,"count":8,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"تُبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"تُبْتُم","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"تُبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"تابَ","in_corpus":true,"count":58,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"تابَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"تابا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"تابَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"تابُوا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"تُبْنَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَتُب","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَتُوب","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَتُوبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَتُوبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَتُوبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَتُوبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَتُوبُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتُوبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتُب","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَتُوب","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَتُوب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتُوبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتُوبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتُوبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتُوبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتُوبُوا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتُوبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"تُبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تُبْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتُوب","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتُوب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":149,"cross_references":{"qac":{"found":true,"lemma_key":"تابَ","root":"توب","pos":"V","occurrence_count":63},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3714","n4172"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to repent, to be penitent","examples":[{"text":"فَلَمَّآ أَفَاقَ قَالَ سُبۡحَـٰنَكَ تُبۡتُ إِلَيۡكَ وَأَنَا۠ أَوَّلُ ٱلۡمُؤۡمِنِينَ","english":"And when he (Moses) awoke, he said: \"Exalted are You! I have repented to You, and I am the first of believers!\""}]},{"pos":"verb","gloss":"to accept repentance","examples":[{"text":"إِنَّمَا ٱلتَّوْبَةُ عَلَى اللَّهِ لِلَّذِينَ يَعْمَلُونَ ٱلسُّوءَ بِجَهَالَةٍ ثُمَّ يَتُوبُونَ مِن قَرِيبٍ فَأُولَٰئِكَ يَتُوبُ ٱللَّهُ عَلَيْهِمْ وَكَانَ اللَّهُ عَلِيمًا حَكِيمًا"}]}]},"etymology":{"source":"wiktextract","text":"Denominal verb of تَوْبَة (tawba). Doublet of ثَابَ (ṯāba)."},"ipa":["/taː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3714","headword_ar":"تَابٌّ","root":"tb","body":[{"kind":"text","text":"(tropical:)  An"},{"kind":"italic_en","text":"old"},{"kind":"text","text":"man; (AZ, T, M, A, K;) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (AZ, T, M, A:) and (assumed tropical:)"},{"kind":"italic_en","text":"weak:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^atobaAbN","text_ar":"اَتْبَابٌ"},{"kind":"text","text":": of the dial. of Hudheyl; and extr. [with respect to analogy]. (M.) You say,"},{"kind":"arabic","text_bw":"kunotu $aAb~FA faSirotu taAb~FA","text_ar":"كُنْتُ شَابًّا فَصِرْتُ تَابًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was a young man, and I have become an old man"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^a$aAb~apN A^anoti A^amo taAb~apN","text_ar":"اَشَابَّةٌ اَنْتِ اَمْ تَابَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Art thou a young woman or an old woman?"},{"kind":"text","text":"] (A.) ―         -b2-  Also, (T, K,) or"},{"kind":"arabic","text_bw":"taAb~u AlZ~ahori","text_ar":"تَابُّ الظَّهْرِ"},{"kind":"text","text":", (T,) (assumed tropical:)  An ass, and a camel,"},{"kind":"italic_en","text":"having galls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sores, on his back:"},{"kind":"text","text":"(T, K:) pl. as above. (K.) ―         -b3-  [See also"},{"kind":"arabic","text_bw":"baAt~N","text_ar":"بَاتٌّ"},{"kind":"text","text":".]"}],"source_refs":["AZ","T","M","A","K"]},{"entry_id":"n4172","headword_ar":"تَابَ","root":"twb","body":[{"kind":"text","text":", (T, A,) or"},{"kind":"arabic","text_bw":"tAb A_ilaY A@ll~`hi","text_ar":"تاب اـِلَى ا@للّٰهِ"},{"kind":"text","text":", (S, M, K,) aor."},{"kind":"arabic","text_bw":"yatuwbu","text_ar":"يَتُوبُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tawobN","text_ar":"تَوْبٌ"},{"kind":"text","text":", (T, S, M, Msb, K,) both of these signifying the same, (T, S, M, Msb,) the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"in the former being added to denote the fem. gender, or, as some say, the former is a n. un. like"},{"kind":"arabic","text_bw":"DarobapN","text_ar":"ضَرْبَةٌ"},{"kind":"text","text":", (Msb,) or, as Akh says,"},{"kind":"arabic","text_bw":"tawobN","text_ar":"تَوْبٌ"},{"kind":"text","text":"is pl. [or a quasi-pl. n.] of"},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"EawomN","text_ar":"عَوْمٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"EawomapN","text_ar":"عَوْمَةٌ"},{"kind":"text","text":", (S,) or like as"},{"kind":"arabic","text_bw":"lawozN","text_ar":"لَوْزٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"lawozapN","text_ar":"لَوْزَةٌ"},{"kind":"text","text":", and this is the opinion of Mbr, (M,) and"},{"kind":"arabic","text_bw":"taAbapN","text_ar":"تَابَةٌ"},{"kind":"text","text":", (M, K,) which is for"},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":", (M,) and"},{"kind":"arabic","text_bw":"mataAbN","text_ar":"مَتَابٌ"},{"kind":"text","text":"(S, M, A, K) and"},{"kind":"arabic","text_bw":"tatowibapN","text_ar":"تَتْوِبَةٌ"},{"kind":"text","text":", (S, * M, * K,) of the measure"},{"kind":"arabic","text_bw":"tafoEilapN","text_ar":"تَفْعِلَةٌ"},{"kind":"text","text":", (S, M,) an anomalous form, (TA,) syn. with"},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":", mentioned in the Book of Sb; (S;) ["},{"kind":"italic_en","text":"He repented;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repented toward God;"},{"kind":"text","text":"as will be shown by what follows:] originally,"},{"kind":"italic_en","text":"he returned unto God,"},{"kind":"text","text":"(T, TA,)"},{"kind":"arabic","text_bw":"mino ka*aA","text_ar":"مِنْ كَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eano ka*aA","text_ar":"عَنْ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from such a thing"},{"kind":"text","text":"]: (TA:) or"},{"kind":"italic_en","text":"he returned,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"returned unto God,"},{"kind":"text","text":"] (S, M, A, K,)"},{"kind":"italic_en","text":"from sin,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"from his sin,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"from disobedience"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"to obedience:"},{"kind":"text","text":"(M:) or"},{"kind":"arabic","text_bw":"taAba mino *anobihi","text_ar":"تَابَ مِنْ ذَنْبِهِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he desisted from his sin:"},{"kind":"text","text":"(Msb:)"},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"repenting of sin;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"grieving for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regretting it, with the confession of having no excuse for the commission thereof."},{"kind":"text","text":"(Kull.) It is said in a trad.,"},{"kind":"arabic","text_bw":"Aln~adamu tawobapN","text_ar":"النَّدَمُ تَوْبَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Repentance is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a returning from sin."},{"kind":"text","text":"(S.) The time of El-Islám is termed"},{"kind":"arabic","text_bw":"zamanu Alt~awobapi","text_ar":"زَمَنُ التَّوْبَةِ"},{"kind":"text","text":"as being"},{"kind":"italic_en","text":"The time of returning from"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"repenting of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the belief in a plurality of gods."},{"kind":"text","text":"(A.) A poet says,"},{"kind":"quote","text":"tubotu A_ilayoka fataqab~alo taAbatiY \n                      \n                     \n                        waSumotu rab~iY fatafab~alo SaAmatiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have repented toward Thee, and accept Thou my repentance; and I have fasted, O my Lord, and accept Thou my fast"},{"kind":"text","text":"]; meaning"},{"kind":"arabic","text_bw":"tawobatiY","text_ar":"تَوْبَتِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SawomatiY","text_ar":"صَوْمَتِى"},{"kind":"text","text":". (M.) ―         -b2-"},{"kind":"arabic","text_bw":"taAba A@ll~`hu Ealayohi","text_ar":"تَابَ ا@للّٰهُ عَلَيْهِ"},{"kind":"italic_en","text":"God returned to forgiveness towards him; became again forgiving to him:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"disposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adapted, him to repentance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returning from sin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedience:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"reverted from severity to mildness towards him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returned to him with his favour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grace, and his acceptance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approbation;"},{"kind":"italic_en","text":"became again propitious to him:"},{"kind":"text","text":"(A, K:) all these meanings are correct: (TA:) or"},{"kind":"italic_en","text":"God forgave him, and saved him from acts of disobedience:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"accepted his repentance:"},{"kind":"text","text":"(Jel in ii. 35 &c.:) or"},{"kind":"italic_en","text":"returned towards him with mercy, and acceptance of repentance."},{"kind":"text","text":"(Bd ibid.)"}],"source_refs":["T","A","S","M","K","Msb","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%A7%D8%A8/","headword_ar":"تاب","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=94083#6757de","body_html":"<span class=\"title1\">تاب</span><br><span>ذَكَرَ أيضاً: التَّوابُ: القَصِيْرُ من الخَيْلِ الغَلِيْظُ اللَحْمِ الفَسِيْحُ القَدْرِ، والأنْثى تَوابَةٌ. والتَّوأبَانيُّ: خِلْفُ النّاقَةِ.</span><br><span>وهو ببابِ اللَّفِيْفِ من كتابِ الباءِ أوْلى، لأنَ أصْلَه من وَأبَ.</span>"}]}}