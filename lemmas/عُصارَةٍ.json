{"lemma":"عُصارَةٍ","slug":"عُصارَةٍ","root":"ع.ص.ر","root_slug":"ع-ص-ر","root_link":"/words/roots/ع-ص-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29322"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D8%B5%D8%A7%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"somewhat viscose liquid that one obtains by wringing, sap, juice, extract"},{"pos":"noun","gloss":"machine that is devised to wring, particularly saps – press, wringer, juicer"}]},"etymology":{"source":"wiktextract","text":"Tool noun of عَصَرَ (ʕaṣara, “to press, squeeze, wring”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29322","headword_ar":"عُصَارَةٌ","root":"ESr","body":[{"kind":"italic_en","text":"Expressed juice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like; what flows"},{"kind":"page_break","n":2063},{"kind":"text","text":"(S, O, Msb, K) from grapes and the like, (Msb, K,) of things having oil or sirup or honey, (TA,)"},{"kind":"italic_en","text":"on pressure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"squeezing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wringing;"},{"kind":"text","text":"(IDrd, S, O, Msb, TA;) ["},{"kind":"italic_en","text":"an extract;"},{"kind":"text","text":"but properly,"},{"kind":"italic_en","text":"such as is expressed;"},{"kind":"text","text":"] as also ↓"},{"kind":"arabic","text_bw":"EaSiyrN","text_ar":"عَصِيرٌ","orth_type":"arrow"},{"kind":"text","text":"(Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EuSaArN","text_ar":"عُصَارٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) or, as some say,"},{"kind":"arabic","text_bw":"EuSaArN","text_ar":"عُصَارٌ"},{"kind":"text","text":"is a pl. of [or rather a coll. gen. n. of which the n. un. is]"},{"kind":"arabic","text_bw":"EuSaArapN","text_ar":"عُصَارَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"What remains of dregs, after pressing to force out the juice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(S, O, TA.) ―         -b3-  Also The"},{"kind":"italic_en","text":"choice part,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"refuse,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"nuqaAyap","text_ar":"نُقَايَة"},{"kind":"text","text":"[which has these two contr. significations]) of a thing. (TA.) ―         -b4-  Also (tropical:)  The"},{"kind":"italic_en","text":"produce"},{"kind":"text","text":"(IF, A, O) of a land. (A.) ―         -b5-"},{"kind":"arabic","text_bw":"waladu fulaAnK EuSaArapu karamK","text_ar":"وَلَدُ فُلَانٍ عُصَارَةُ كَرَمٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino EuSaAraAti Alkarami","text_ar":"مِنْ عُصَارَاتِ الكَرَمِ"},{"kind":"text","text":"[means (tropical:)"},{"kind":"italic_en","text":"The children of such a one are of generous race,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of generous disposition"},{"kind":"text","text":"]. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"rajulN kariymu AlEuSaArapi","text_ar":"رَجُلٌ كَرِيمُ العُصَارَةِ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AlmaEoSari","text_ar":"المَعْصَرِ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) and ↓"},{"kind":"arabic","text_bw":"AlmuEotaSari","text_ar":"المُعْتَصَرِ","orth_type":"arrow"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"A man generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liberal, when asked."},{"kind":"text","text":"(S, O, K.) And ↓"},{"kind":"arabic","text_bw":"maniyEu AlmuEotaSari","text_ar":"مَنِيعُ المُعْتَصَرِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  One"},{"kind":"italic_en","text":"with whom one cannot take refuge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whose protection is unobtainable."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"kariymu AlEaSiyri","text_ar":"كَرِيمُ العَصِيرِ","orth_type":"arrow"},{"kind":"text","text":", (O, L,) or"},{"kind":"arabic","text_bw":"kaviyru","text_ar":"كَثِيرُ"},{"kind":"arabic","text_bw":"AlEaSiyri","text_ar":"العَصِيرِ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"kariymu AlEaSori","text_ar":"كَرِيمُ العَصْرِ"},{"kind":"text","text":"as in the [O and] K, (TA,) (tropical:)"},{"kind":"italic_en","text":"Of generous race."},{"kind":"text","text":"(O, L, K.) [See also"},{"kind":"arabic","text_bw":"EunoSurN","text_ar":"عُنْصُرٌ"},{"kind":"text","text":".]"}],"source_refs":["S","O","Msb","K","TA","Mgh","IF","A","L"]}]},"classical_definitions":null}