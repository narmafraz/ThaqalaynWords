p","form":"تَمَسُّونَ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَمَسُّوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَمْسَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَمَسّ","in_corpus":true,"count":45,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَمْسَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَمَسّ","in_corpus":true,"count":18,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَمْسَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَمَسّانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمَسّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَمَسّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمَسّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَمَسُّونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمَسُّوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَمْسَسْنَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَمَسّ","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَمَسّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"مَسَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مَسَسْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":163,"cross_references":{"qac":{"found":true,"lemma_key":"مَسّ","root":"مسس","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n38544"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B3%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to feel, to touch","tags":["transitive"]},{"pos":"verb","gloss":"to handle, to palpate","tags":["transitive"]},{"pos":"verb","gloss":"to violate (something sacred)","tags":["transitive"]},{"pos":"verb","gloss":"to infringe upon","tags":["transitive"]},{"pos":"verb","gloss":"to cohabit with","tags":["euphemistic","transitive"],"examples":[{"text":"أَنَّى يَكُونُ لِي غُلَامٌ وَلَمْ يَمْسَسْنِي بَشَرٌ وَلَمْ أَكُ بَغِيًّا","english":"How can I have a boy while no man has touched me and I have not been unchaste?"}]},{"pos":"verb","gloss":"to befall, to hit","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of مَسَّ (massa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"touching, touch"},{"pos":"noun","gloss":"contact"},{"pos":"noun","gloss":"misfortune, calamity"},{"pos":"noun","gloss":"attack, fit, frenzy"},{"pos":"noun","gloss":"insanity, madness"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38544","headword_ar":"مَسٌّ","root":"ms","body":[{"kind":"text","text":": see 1. ―         -b2-  It is used to denote [the first sensible effect of] anything annoying or hurtful that befalls a man. (TA.) Thus in the Kur, [liv. 48,] (TA,)"},{"kind":"arabic","text_bw":"*uwquwA mas~a saqara","text_ar":"ذُوقُوا مَسَّ سَقَرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Taste ye the first effect upon you of the fire of hell:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"the stroke thereof:"},{"kind":"text","text":"(Jel:) or"},{"kind":"italic_en","text":"the heat and pain thereof."},{"kind":"text","text":"(Bd.) In like manner you say, (K,)"},{"kind":"arabic","text_bw":"wajada mas~a AlHum~aY","text_ar":"وَجَدَ مَسَّ الحُمَّى"},{"kind":"text","text":"(M, K) (tropical:)"},{"kind":"italic_en","text":"He felt the commencement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first touch,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"access,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of fever, before its taking him forcibly, and becoming apparent."},{"kind":"text","text":"(M, L.) And"},{"kind":"arabic","text_bw":"lamo yajido mas~FA mina Aln~aSabi","text_ar":"لَمْ يَجِدْ مَسًّا مِنَ النَّصَبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He did not feel the first sensation of fatigue."},{"kind":"text","text":"(TA, from a trad.) [And hence,]"},{"kind":"arabic","text_bw":"bihi mas~N mina","text_ar":"بِهِ مَسٌّ مِنَ"},{"kind":"arabic","text_bw":"Aljunuwni","text_ar":"الجُنُونِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"In him is a touch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stroke, of madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diabolical possession"},{"kind":"text","text":"]: (S, TA:) and"},{"kind":"arabic","text_bw":"mas~N","text_ar":"مَسٌّ"},{"kind":"text","text":", alone, signifies"},{"kind":"italic_en","text":"madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diabolical possession:"},{"kind":"text","text":"(M, A, * Mgh, K:) as in the Kur, ii. 276: (TA:) and you say"},{"kind":"arabic","text_bw":"bihi mas~N","text_ar":"بِهِ مَسٌّ"},{"kind":"italic_en","text":"in him is madness,"},{"kind":"text","text":"&c.: (A, * Mgh:) for they assert that the devil touches one and his intellect in consequence becomes confused. (Mgh.) ―         -b3-  You say also,"},{"kind":"arabic","text_bw":"huwa Hasanu Almas~i fiY maAlihi","text_ar":"هُوَ حَسَنُ المَسِّ فِى مَالِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He has the impress of a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, in his camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raA^ayotu lahu mas~FA","text_ar":"رَاَيْتُ لَهُ مَسًّا"},{"kind":"arabic","text_bw":"fiY maAlihi","text_ar":"فِى مَالِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I saw him to have an impress of a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, in his camels,"},{"kind":"text","text":"&c.: like as you say"},{"kind":"arabic","text_bw":"A_iSobaEFA","text_ar":"اـِصْبَعًا"},{"kind":"text","text":". (A, TA.)"}],"source_refs":["TA","K","Jel","M","S"]}]}}