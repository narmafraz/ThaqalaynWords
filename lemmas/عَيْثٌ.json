{"lemma":"عَيْثٌ","slug":"عَيْثٌ","root":"ع.#.ث","root_slug":"ع-_-ث","root_link":"/words/roots/ع-_-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n31167"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%8A%D9%92%D8%AB%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31167","headword_ar":"عيّث","root":"Eyv","body":[{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"taEoyiyvN","text_ar":"تَعْيِيثٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"He searched"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for a thing with the hand, without his seeing it:"},{"kind":"text","text":"(S, O, K:) or, said of a blind man,"},{"kind":"italic_en","text":"he searched"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for a thing:"},{"kind":"text","text":"and, said of a man possessing sight,"},{"kind":"italic_en","text":"he searched"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for a thing in the dark:"},{"kind":"text","text":"written by Kr with"},{"kind":"arabic","text_bw":"g","text_ar":"غ"},{"kind":"text","text":". (L.) [It is said in the TA, in art."},{"kind":"arabic","text_bw":"gyv","text_ar":"غيث"},{"kind":"text","text":", that ISd thought"},{"kind":"arabic","text_bw":"Ey~v","text_ar":"عيّث"},{"kind":"text","text":", with the unpointed"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", to be a mistranscription; but that it is correct.] ―         -b2-  And hence,"},{"kind":"arabic","text_bw":"Ey~v fiY AlkinaAnapi","text_ar":"عيّث فِى الكِنَانَةِ"},{"kind":"italic_en","text":"He put his hand into the quiver to search for an arrow:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he turned about his hand in the quiver to search for the arrow."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"arabic","text_bw":"Ey~v yafoEalu ka*aA","text_ar":"عيّث يَفْعَلُ كَذَا"},{"kind":"italic_en","text":"He set about, began,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, doing such a thing."},{"kind":"text","text":"(O, K.) ―         -b4-"},{"kind":"arabic","text_bw":"Eay~avato Tayoruhu","text_ar":"عَيَّثَتْ طَيْرُهُ"},{"kind":"text","text":"[lit.]"},{"kind":"italic_en","text":"His birds"},{"kind":"text","text":"[from which he augured]"},{"kind":"italic_en","text":"became confused to him;"},{"kind":"text","text":"[meaning (assumed tropical:)"},{"kind":"italic_en","text":"his affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became confused and perplexing to him"},{"kind":"text","text":"]; syn."},{"kind":"arabic","text_bw":"AixotalaTato Ealayohi","text_ar":"اِخْتَلَطَتْ عَلَيْهِ"},{"kind":"text","text":". (O, K.) [See also"},{"kind":"arabic","text_bw":"gay~ama","text_ar":"غَيَّمَ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"Ey~v fiY Als~anaAmi","text_ar":"عيّث فِى السَّنَامِ"},{"kind":"italic_en","text":"He made a mark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an impression, upon the camel's hump"},{"kind":"text","text":"with a knife. (TA.)"}],"source_refs":["S","O","K","TA"]}]},"classical_definitions":null}