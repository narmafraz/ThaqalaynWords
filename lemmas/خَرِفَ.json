E%D8%B1%D9%90%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gather or pluck (fruit)"},{"pos":"verb","gloss":"to remain in one's orchard (during the harvest season)"},{"pos":"verb","gloss":"to graze in the fall (of sheep)"},{"pos":"verb","gloss":"to rain on (people, animals, the land, etc.) (particularly during harvest season)"},{"pos":"noun","gloss":"verbal noun of خَرَفَ (ḵarafa, “to pluck (fruit)”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"dates of lowest quality"},{"pos":"verb","gloss":"to be senile, to dote"},{"pos":"verb","gloss":"to prattle, to talk foolishly"},{"pos":"verb","gloss":"to blather, to natter senile stuff"},{"pos":"verb","gloss":"to call somebody senile"},{"pos":"noun","gloss":"verbal noun of خَرِفَ (ḵarifa, “to be senile”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَرَفَ (ḵarafa, “to be senile”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَرُفَ (ḵarufa, “to be senile”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"dementia"},{"pos":"noun","gloss":"dates of lowest quality"},{"pos":"adj","gloss":"senile, dotardly"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10388","headword_ar":"خَرَفَ","root":"xrf","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"xarofN","text_ar":"خَرْفٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"maxorafN","text_ar":"مَخْرَفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xaraAfN","text_ar":"خَرَافٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiraAfN","text_ar":"خِرَافٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axtrf","text_ar":"اخترف","orth_type":"arrow"},{"kind":"text","text":"; (S Msb, K;)"},{"kind":"italic_en","text":"He gathered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked,"},{"kind":"text","text":"fruit: (S K:) or"},{"kind":"italic_en","text":"cut"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"off."},{"kind":"text","text":"(Msb.) Accord. to the M,"},{"kind":"arabic","text_bw":"xarafa Aln~axola","text_ar":"خَرَفَ النَّخْلَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He cut off the fruit of the palm-trees:"},{"kind":"text","text":"and accord. to AHn, ↓"},{"kind":"arabic","text_bw":"AixotiraAfN","text_ar":"اِخْتِرَافٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"picking up the fruit of the palm-trees, whether unripe or ripe."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xarafa fulaAnFA","text_ar":"خَرَفَ فُلَانًا"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xarofN","text_ar":"خَرْفٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He picked up, for such a one, dates"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tamorFA","text_ar":"تَمْرًا"},{"kind":"text","text":"), or"},{"kind":"italic_en","text":"fruit"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"vamorFA","text_ar":"ثَمْرًا"},{"kind":"text","text":"), accord. to different copies of the K: from Sh. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"yaxorufu mino haAhunaA wamino haAhunaA","text_ar":"يَخْرُفُ مِنْ هَاهُنَا وَمِنْ هَاهُنَا"},{"kind":"text","text":", said of a lamb, means"},{"kind":"italic_en","text":"He depastures,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"eats, from this place and from this."},{"kind":"text","text":"(Msb, TA. *) ―         -b4-  And"},{"kind":"arabic","text_bw":"xarafa","text_ar":"خَرَفَ"},{"kind":"text","text":", said of a man, (JK, TA,) aor."},{"kind":"text","text":", (JK,) or"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He took of the"},{"kind":"arabic","text_bw":"Taraf","text_ar":"طَرَف"},{"kind":"text","text":"[app. meaning the"},{"kind":"italic_en","text":"choice part"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the fruits."},{"kind":"text","text":"(JK, TA.)       -A2-"},{"kind":"arabic","text_bw":"xarafa","text_ar":"خَرَفَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xariyf","text_ar":"خَرِيف"},{"kind":"text","text":": (Ham p. 676:) and in like manner, ↓"},{"kind":"arabic","text_bw":"AxrfwA","text_ar":"اخرفوا","orth_type":"arrow"},{"kind":"italic_en","text":"they remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"in a place"},{"kind":"italic_en","text":"during their"},{"kind":"arabic","text_bw":"xariyf","text_ar":"خَرِيف"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"xarafuwA fiY HaAy^iTihimo","text_ar":"خَرَفُوا فِى حَايِطِهِمْ"},{"kind":"italic_en","text":"They remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in their"},{"kind":"arabic","text_bw":"HAy^T","text_ar":"حايط"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"garden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walled garden of palm-trees,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the time of the gathering of the fruits."},{"kind":"text","text":"(TA, from a trad. of 'Omar.)       -A3-"},{"kind":"arabic","text_bw":"xurifonaA","text_ar":"خُرِفْنَا"},{"kind":"italic_en","text":"We were rained upon by the rain called"},{"kind":"arabic","text_bw":"Alxariyf","text_ar":"الخَرِيف"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"xurifati","text_ar":"خُرِفَتِ"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"xarofN","text_ar":"خَرْفٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The land was rained upon by the rain so called."},{"kind":"text","text":"(S, TA) And"},{"kind":"arabic","text_bw":"xurifati AlbahaAy^imu","text_ar":"خُرِفَتِ البَهَايِمُ"},{"kind":"italic_en","text":"The beasts were rained upon by the rain so called:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had that upon which they might pasture produced for them by that rain."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"xarifa","text_ar":"خَرِفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fond of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"addicted to, the eating of"},{"kind":"arabic","text_bw":"xurofap","text_ar":"خُرْفَة"},{"kind":"text","text":", (K,) i. e."},{"kind":"italic_en","text":"gathered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plucked, fruit"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"of the palm-tree."},{"kind":"text","text":"(TA.)       -A5-"},{"kind":"arabic","text_bw":"xarifa","text_ar":"خَرِفَ"},{"kind":"text","text":", (S, L, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xarafN","text_ar":"خَرَفٌ"},{"kind":"text","text":"; (S, * Msb;) and"},{"kind":"arabic","text_bw":"xarafa","text_ar":"خَرَفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"xarufa","text_ar":"خَرُفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, Msb)"},{"kind":"italic_en","text":"doted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, corrupted, rendered unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, in his intellect;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"in consequence of old age."},{"kind":"text","text":"(S, Msb.) [The first of these three verbs, in the present day, is used as meaning"},{"kind":"italic_en","text":"He doted; told stories such as are termed"},{"kind":"arabic","text_bw":"xuraAfaAt","text_ar":"خُرَافَات"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"fictions,"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"talked nonsense:"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xr~f","text_ar":"خرّف","orth_type":"arrow"},{"kind":"text","text":".]       -A6-"},{"kind":"arabic","text_bw":"xarafatohu A^axaAriyfu","text_ar":"خَرَفَتْهُ اَخَارِيفُ"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"Stories such as are termed"},{"kind":"arabic","text_bw":"AxAryf","text_ar":"اخاريف"},{"kind":"text","text":", i. e. ↓"},{"kind":"arabic","text_bw":"xuraAfaAt","text_ar":"خُرَافَات","orth_type":"arrow"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"fictions,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"caused him to dote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talk nonsense"},{"kind":"text","text":"]. (JK, TA. * [Mentioned in the former immediately after"},{"kind":"arabic","text_bw":"xuraAfapN","text_ar":"خُرَافَةٌ"},{"kind":"text","text":"explained as meaning “ a fiction that is deemed pretty. ” See also 4.])"}],"source_refs":["S","Msb","K","TA","JK","L"]},{"entry_id":"n10392","headword_ar":"خَرَفٌ","root":"xrf","body":[{"kind":"italic_en","text":"A corrupt, an unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disordered, state of the intellect; dotage."},{"kind":"text","text":"(S. [See"},{"kind":"arabic","text_bw":"xarifa","text_ar":"خَرِفَ"},{"kind":"text","text":", of which it is the inf. n.])       -A2-  The ["},{"kind":"italic_en","text":"bad sort of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"dates called"},{"kind":"arabic","text_bw":"$iyS","text_ar":"شِيص"},{"kind":"text","text":". (K, * TA.)"}],"source_refs":[]},{"entry_id":"n10393","headword_ar":"خرِفٌ","root":"xrf","body":[{"kind":"italic_en","text":"Corrupted, unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, in his intellect,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"in consequence of old age; doting:"},{"kind":"text","text":"(S, Msb:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n10394","headword_ar":"خُرُفٌ","root":"xrf","body":[{"kind":"italic_en","text":"A time of going forth"},{"kind":"text","text":"of camels, (Nh,) or of men, (O, K,)"},{"kind":"italic_en","text":"to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"herbage of the season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xariyf","text_ar":"خَرِيف"},{"kind":"text","text":": so in the saying of El-Járood,"},{"kind":"arabic","text_bw":"yaA rasuwla A@ll~`hi qado Ealimota maA yakofiynaA mina AlZ~ahori *awodN naA^otiY","text_ar":"يَا رَسُولَ ا@للّٰهِ قَدْ عَلِمْتَ مَا يَكْفِينَا مِنَ الظَّهْرِ ذَوْدٌ نَاْتِى"},{"kind":"arabic","text_bw":"Ealayohin~a fiY xurufK","text_ar":"عَلَيْهِنَّ فِى خُرُفٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O Apostle of God, verily thou knowest that a"},{"kind":"text","text":"number such as is termed"},{"kind":"arabic","text_bw":"*wd","text_ar":"ذود"},{"kind":"text","text":","},{"kind":"italic_en","text":"of camels for riding or carriage, whereon we come in a time of going forth"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"is not sufficient for us"},{"kind":"text","text":"]. (Nh, O, K.)"}],"source_refs":["Nh","O","K"]}]},"classical_definitions":null}