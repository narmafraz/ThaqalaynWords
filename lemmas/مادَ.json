ktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n38182","n38185","n39068"],"search_url":"https://lanelexicon.com/?s=%D9%85%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38182","headword_ar":"مَاَدَ","root":"mA^d","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"maA^odN","text_ar":"مَاْدٌ"},{"kind":"text","text":", (S, L,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant, L, K, and a tree, L, and a branch, S, L)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, flourishing and fresh, and soft, tender, and supple:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"it quivered, shook,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"played loosely, and was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"and flourishing and fresh, and soft, tender, and supple:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a branch or twig)"},{"kind":"italic_en","text":"became filled with its first sap:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maw^uda","text_ar":"مَوُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"became succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy."},{"kind":"text","text":"(L.)"},{"kind":"arabic","text_bw":"yamoA^adu maA^odFA HasanFA","text_ar":"يَمْاَدُ مَاْدًا حَسَنًا"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a branch)"},{"kind":"italic_en","text":"is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"beautifully"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"soft, tender, and supple, and quivering."},{"kind":"text","text":"(S, L.)"}],"source_refs":["S","L","K"]},{"entry_id":"n38185","headword_ar":"مَاْدٌ","root":"mA^d","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"yamow^uwdN","text_ar":"يَمْوُودٌ","orth_type":"arrow"},{"kind":"text","text":"A [plant or tree or] branch ["},{"kind":"italic_en","text":"flourishing and fresh, and soft, tender, and supple:"},{"kind":"text","text":"see 1: or]"},{"kind":"italic_en","text":"quivering, shaking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"playing loosely, and succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy, flourishing and fresh, and soft, tender, and supple:"},{"kind":"text","text":"(K:) or a plant [or tree] or branch"},{"kind":"italic_en","text":"soft, tender, and supple;"},{"kind":"text","text":"(S, L;) and ↓"},{"kind":"arabic","text_bw":"may^iydN","text_ar":"مَيِيدٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, (K,) applied to a branch; and so ↓"},{"kind":"arabic","text_bw":"maAy^idN","text_ar":"مَايِدٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) which last also signifies a branch"},{"kind":"italic_en","text":"succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"maA^odN","text_ar":"مَاْدٌ"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"mumoA^adN","text_ar":"مُمْاَدٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and (as some say, L)"},{"kind":"arabic","text_bw":"maA^odN","text_ar":"مَاْدٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"soft, tender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supple,"},{"kind":"text","text":"applied to anything. (L, K.) ―         -b2-  In like manner,"},{"kind":"arabic","text_bw":"maA^odN","text_ar":"مَاْدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"yamow^uwdN","text_ar":"يَمْوُودٌ","orth_type":"arrow"},{"kind":"text","text":"are applied to (assumed tropical:)  a man: (K:) and"},{"kind":"arabic","text_bw":"maA^odapN","text_ar":"مَاْدَةٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"yamow^uwdapN","text_ar":"يَمْوُودَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yamow^uwdN","text_ar":"يَمْوُودٌ"},{"kind":"text","text":"to a female. (K.) You say"},{"kind":"arabic","text_bw":"rajulN maA^odN","text_ar":"رَجُلٌ مَاْدٌ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"yamow^uwdN","text_ar":"يَمْوُودٌ"},{"kind":"text","text":", (S, L,) (assumed tropical:)"},{"kind":"italic_en","text":"A young, and soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender, man:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_imoraA^apN maA^odapN","text_ar":"اـِمْرَاَةٌ مَاْدَةٌ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"yamow^uwdapN","text_ar":"يَمْوُودَةٌ"},{"kind":"text","text":", (S, L,) and"},{"kind":"arabic","text_bw":"yamow^uwdN","text_ar":"يَمْوُودٌ"},{"kind":"text","text":", (L,) (assumed tropical:)"},{"kind":"italic_en","text":"a young, and soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender woman:"},{"kind":"text","text":"(S, L:) and"},{"kind":"arabic","text_bw":"jaAriypN maA^odapN","text_ar":"جَارِيةٌ مَاْدَةٌ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"yamow^uwdapN","text_ar":"يَمْوُودَةٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"a soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender, damsel:"},{"kind":"text","text":"(K:) and"},{"kind":"arabic","text_bw":"jArypN maA^odapu","text_ar":"جاريةٌ مَاْدَةُ"},{"kind":"arabic","text_bw":"Al$~abaAbi","text_ar":"الشَّبَابِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maAdapN","text_ar":"مَادَةٌ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"a damsel having youthful softness, thinness of skin, and plumpness."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"maA^odu Al$~abaAbi","text_ar":"مَاْدُ الشَّبَابِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The softness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tenderness, of youth."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"makaAnN vaA^odN maA^odN","text_ar":"مَكَانٌ ثَاْدٌ مَاْدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A place moist and soft"},{"kind":"text","text":"]; (S, L;) as also ↓"},{"kind":"arabic","text_bw":"vay^idN may^idN","text_ar":"ثَيِدٌ مَيِدٌ","orth_type":"arrow"},{"kind":"text","text":". (T, art."},{"kind":"arabic","text_bw":"vA^d","text_ar":"ثاد"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"maA^odN","text_ar":"مَاْدٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"moisture that exudes from the earth, before it springs forth:"},{"kind":"text","text":"(L, K:) of the dial. of Syria. (L.)"}],"source_refs":["K","TA","L","S"]},{"entry_id":"n39068","headword_ar":"مَادَ","root":"myd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamiydu","text_ar":"يَمِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"mayadaAnN","text_ar":"مَيَدَانٌ"},{"kind":"text","text":", (L, Msb, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"page_break","n":2746},{"kind":"italic_en","text":"became in a state of motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commotion; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became agitated:"},{"kind":"text","text":"(S, L, Msb, K:) or,"},{"kind":"italic_en","text":"in a state of violent motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commotion;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"violently agitated."},{"kind":"text","text":"(El-Basáïr, TA.) So in the expression in the Kur, [xvi. 15; and xxxi. 9;]"},{"kind":"arabic","text_bw":"A^ano tamiyda bikumo","text_ar":"اَنْ تَمِيدَ بِكُمْ"},{"kind":"italic_en","text":"Lest it"},{"kind":"text","text":"(the earth)"},{"kind":"italic_en","text":"should be convulsed with you, and go round with you, and move you about violently."},{"kind":"text","text":"(El-Basáïr, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"italic_en","text":"It turned"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"twisted about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became contorted and convulsed."},{"kind":"text","text":"(IKtt.) ―         -b3-"},{"kind":"arabic","text_bw":"maAda fiY Alr~umoHi","text_ar":"مَادَ فِى الرُّمْحِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man pierced)"},{"kind":"italic_en","text":"writhed upon the spear."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the mirage,"},{"kind":"arabic","text_bw":"saraAb","text_ar":"سَرَاب"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"was in a state of commotion; it quivered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trembled."},{"kind":"text","text":"(L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yamiydu","text_ar":"يَمِيدُ"},{"kind":"text","text":", TA, inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"mayadN","text_ar":"مَيَدٌ"},{"kind":"text","text":", L,) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, L,)"},{"kind":"italic_en","text":"became affected with a heaving of the stomach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tendency to vomit, and a giddiness in the head, by reason of intoxication,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of voyaging upon the sea."},{"kind":"text","text":"(L, K.) ―         -b7-  You say also"},{"kind":"arabic","text_bw":"maAda bihi AlbaHoru","text_ar":"مَادَ بِهِ البَحْرُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamiydu","text_ar":"يَمِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The sea affected him with a heaving of the stomach, &c."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"maAdato bihi AlA^aroDu","text_ar":"مَادَتْ بِهِ الاَرْضُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The ground went round with him."},{"kind":"text","text":"(A.) ―         -b8-"},{"kind":"arabic","text_bw":"maAdati AlHanoZalapu","text_ar":"مَادَتِ الحَنْظَلَةُ"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yamiydu","text_ar":"يَمِيدُ"},{"kind":"text","text":", L,)"},{"kind":"italic_en","text":"The colocynth became affected by day-dew,"},{"kind":"text","text":"(L, K,) or"},{"kind":"italic_en","text":"by moisture,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"and in consequence, changed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in odour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stinking"},{"kind":"text","text":"]: (L, K:) and in like manner a date. (L.) ―         -b9-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":", (S, A, L,) inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"mayadaAnN","text_ar":"مَيَدَانٌ"},{"kind":"text","text":"; (A;) and ↓"},{"kind":"arabic","text_bw":"tmAyd","text_ar":"تمايد","orth_type":"arrow"},{"kind":"text","text":"; (A;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a branch)"},{"kind":"italic_en","text":"inclined from side to side."},{"kind":"text","text":"(S, A, L.) ―         -b10-  (tropical:)"},{"kind":"italic_en","text":"He inclined from side to side in walking."},{"kind":"text","text":"(L.) ―         -b11-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mayadaAnN","text_ar":"مَيَدَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It inclined to one side:"},{"kind":"text","text":"as the earth is, in a trad., described to have done before the mountains were formed. (L.) ―         -b12-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S,)"},{"kind":"italic_en","text":"affected a bending of his person, body, or limbs;"},{"kind":"text","text":"(L;)"},{"kind":"italic_en","text":"he walked with an elegant and a proud and self-conceited gait, with an affected inclining of his body from side to side;"},{"kind":"text","text":"(S, L, K;) and"},{"kind":"arabic","text_bw":"maAdato","text_ar":"مَادَتْ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tmy~dt","text_ar":"تميّدت","orth_type":"arrow"},{"kind":"text","text":"signify the same, said of a woman. (A.)       -A2-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"italic_en","text":"He conferred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bestowed, a benefit"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a favour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favours."},{"kind":"text","text":"You say,"},{"kind":"arabic","text_bw":"maAdaniY fulaAnN","text_ar":"مَادَنِى فُلَانٌ"},{"kind":"italic_en","text":"Such a one conferred a benefit"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits upon me."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"maAdah","text_ar":"مَادَه"},{"kind":"text","text":", (L, Msb,) and ↓"},{"kind":"arabic","text_bw":"AmAdhu","text_ar":"امادهُ","orth_type":"arrow"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He gave him."},{"kind":"text","text":"(L, Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"italic_en","text":"He furnished"},{"kind":"text","text":"persons"},{"kind":"italic_en","text":"with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave"},{"kind":"text","text":"them,"},{"kind":"italic_en","text":"provisions for travelling;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":". (L.) [In the K,"},{"kind":"arabic","text_bw":"zaAra","text_ar":"زَارَ"},{"kind":"italic_en","text":"He visited."},{"kind":"text","text":"] ―         -b4-"},{"kind":"italic_en","text":"He brought"},{"kind":"text","text":"a people"},{"kind":"italic_en","text":"wheat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"food; i. q."},{"kind":"arabic","text_bw":"maAra","text_ar":"مَارَ"},{"kind":"text","text":", (S, L, K,) of which it is a dial. form. (S.) ―         -b5-"},{"kind":"italic_en","text":"He trafficked as a merchant."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"maAda","text_ar":"مَادَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mayodN","text_ar":"مَيْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mayadaAnN","text_ar":"مَيَدَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It increased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grew;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"raAEa","text_ar":"رَاعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zakaA","text_ar":"زَكَا"},{"kind":"text","text":". (M, L, K.) [In the copies of the K in my hands, for"},{"kind":"arabic","text_bw":"rAE","text_ar":"راع"},{"kind":"text","text":"is put"},{"kind":"arabic","text_bw":"zAg","text_ar":"زاغ"},{"kind":"text","text":".]"}],"source_refs":["S","L","Msb","K","A"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%A7%D8%AF/","headword_ar":"ماد","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=86634#97c6ea","body_html":"<span class=\"title1\">ماد</span><span>َيْتُه ومادَدْتُه.</span><br><span>والمُمْدِي: الأمْرُ المُمَادُ. ومَدى: اسْمُ وادٍ.</span>"},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=86634#d2011d","body_html":"<div>ماد</div><div>المَأدُ من النبَاتِ: ما ارْتَوى، وأمْأدَه الرِّيُّ والربِيْعُ. وجارِيَةٌ مَأدَةُ الشبَابِ: أي تارَةٌ، وهي يَمْؤُوْدٌ. والمَأدُ: النَّز الذي يَظْهَرُ قَبْلَ أنْ يَنْبُعَ الماءُ. والمَآدُ - بوَزْنِ فَعَالٍ -: مَصْدَر من مَأدَ الغُصْنُ. وامْتَأدَ الرَّجُلُ: اكْتَسَبَ خَيْراً.</div>"}]}}