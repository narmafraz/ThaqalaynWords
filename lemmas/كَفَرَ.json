{"lemma":"كَفَرَ","slug":"كَفَرَ","root":"ك.ف.ر","root_slug":"ك-ف-ر","root_link":"/words/roots/ك-ف-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"كَفَرْتَ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"كَفَرْتِ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"كَفَرْتُما","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"كَفَرْتُم","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"كَفَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"كَفَرَ","in_corpus":true,"count":34,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"كَفَرَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"كَفَرا","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"كَفَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"كَفَرُوا","in_corpus":true,"count":27,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"كَفَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَكْفِر","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَكْفِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَكْفِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَكْفِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَكْفِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَكْفِرُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَكْفِرُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْفِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكْفِر","in_corpus":true,"count":22,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكْفِر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكْفِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكْفِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكْفِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكْفِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكْفِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْفِرُوا","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْفِرْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"كَفَرْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَفَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَكْفِر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكْفِر","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":129,"cross_references":{"qac":{"found":true,"lemma_key":"كَفَرَ","root":"كفر","pos":"V","occurrence_count":289},"wiktextract":{"found":true,"entry_count":8,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":18},"lanes":{"found":true,"entry_ids":["n37101","n37102","n37103","n37104"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D9%81%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to disbelieve (in), to close oneself off to","tags":["intransitive","transitive"],"examples":[{"text":"زُيِّنَ لِلَّذِينَ كَفَرُوٱ ٱلْحَيَاةُ ٱلدُّنْيَا وَيَسْخَرُونَ مِنَ ٱلَّذِينَ آمَنُوا وَالَّذِينَ ٱتَّقَوْا فَوْقَهُمْ يَوْمَ ٱلْقِيَامَةِ وَٱللّٰهُ يَرْزُقُ مَنْ يَشَاءُ بِغَيْرِ حِسَابٍ","english":"Beautified is the life of this world for those who disbelieve, and they mock at those who believe. But those who fear [Allah] are above them on the Day of Resurrection, and Allah begifts whom He wills without account."},{"text":"لَا إِكْرَاهَ فِي ٱلدِّينِ ۖ قَدْ تَبَيَّنَ ٱلرُّشْدُ مِنَ ٱلْغَيِّ ۚ فَمَنْ يَكْفُرْ بِٱلطَّاغُوتِ وَيُؤْمِنْ بِٱللَّهِ فَقَدِ ٱسْتَمْسَكَ بِٱلْعُرْوَةِ ٱلْوُثْقَىٰ لَا ٱنْفِصَامَ لَهَا ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌ"}]},{"pos":"verb","gloss":"to be ungrateful","tags":["transitive"],"examples":[{"text":"فَٱذْكُرُونِي أَذْكُرْكُمْ وَٱشْكُرُوا لِي وَلَا تَكْفُرُونِ"}]},{"pos":"verb","gloss":"to disclaim association with, to renounce","examples":[{"text":"إِن تَدْعُوهُمْ لَا يَسْمَعُوا دُعَاءَكُمْ وَلَوْ سَمِعُوا مَا ٱسْتَجَابُوا لَكُمْۖ وَيَوْمَ ٱلْقِيَامَةِ يَكْفُرُونَ بِشِرْكِكُمْۚ وَلَا يُنَبِّئُكَ مِثْلُ خَبِيرٍ","english":"If you invoke them they will not hear your invocation, and even if they heard they cannot respond to you, and on the Day of Resurrection they will forswear your polytheism, and none can inform you like the One who is all-aware."}]},{"pos":"verb","gloss":"to cover, hide"},{"pos":"noun","gloss":"verbal noun of كَفَرَ (kafara) (form I); disbelief; disacknowledgment"},{"pos":"noun","gloss":"verbal noun of كَفَرَ (kafara) (form I); ingratitude"},{"pos":"noun","gloss":"verbal noun of كَفَرَ (kafara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"darkness, blackness"},{"pos":"noun","gloss":"earth, dust"},{"pos":"noun","gloss":"grave, sepulcher"},{"pos":"verb","gloss":"to expiate, do penance, atone","examples":[{"text":"كفّر عن ذنوبه","english":"He atoned for his sins."}]},{"pos":"verb","gloss":"to forgive, grant pardon"},{"pos":"verb","gloss":"to accuse of infidelity, charge with unbelief"},{"pos":"verb","gloss":"to make an infidel, seduce to unbelief"},{"pos":"verb","gloss":"to cover, hide","tags":["dated"]},{"pos":"noun","gloss":"open, town, village, suburb","examples":[{"text":"لَا تَسْكُنِ الْكُفُورَ، فَإِنَّ سَاكِنَ الْكُفُورِ كَسَاكِنِ الْقُبُورِ","english":"Don’t dwell in the suburbs, for he who dwells in the suburbs is like a dweller of the graves."}]},{"pos":"noun","gloss":"pitch, tar"},{"pos":"noun","gloss":"cover, case"}]},"etymology":{"source":"wiktextract","text":"Compare Classical Syriac ܟܦܲܪ (kəp̄ar).\n\nBorrowed from Aramaic כַּפְרָא / ܟܰܦܪܳܐ (kap̄rā, “village, open town, unfortified town”), from Akkadian 𒅗𒀊𒊒 (kaprum, “farm, village; a settlement outside of a city”), considered to represent a word particular to the non-Akkadian “Mari language”, that is to be formed either in the unknown East Semitic or the unknown Amorite language spoken there. Probably originally meaning an agricultural storage-room, doublet of غَفْر (ḡafr), related to the meaning of “covering” connecting the roots غ ف ر (ḡ f r), כ־פ־ר (k-p-r). Compare Hebrew כְּפָר (kp̄ār, “village”).\n\nBorrowed from Aramaic כּוּפְרָא / ܟܘܦܪܐ (kūp̄rā, “pitch, tar; asphalt”), from Akkadian 𒇒𒌓𒀀 (kupru, “bitumen, pitch”), from Akkadian 𒅗𒉺𒊒 (kapāru, “to smear or daub on”). Doublet of غُفْرَان (ḡufrān). Compare Old Armenian կուպր (kupr), a Semitic borrowing.\n\nBorrowed from English cover."},"ipa":["/ka.fa.ra/","/kufr/","/kaf.fa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37101","headword_ar":"كَفْرٌ","root":"kfr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"darkness"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"blackness of night;"},{"kind":"text","text":"[because it conceals things;] as also, sometimes, ↓"},{"kind":"arabic","text_bw":"kiforN","text_ar":"كِفْرٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) [See also"},{"kind":"arabic","text_bw":"kaAfirN","text_ar":"كَافِرٌ"},{"kind":"text","text":".] See a verse cited voce"},{"kind":"arabic","text_bw":"*ukaA='u","text_ar":"ذُكَا=ءُ"},{"kind":"text","text":".       -A2-"},{"kind":"italic_en","text":"Earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust;"},{"kind":"text","text":"because it conceals what is beneath it. (Lh.)       -A3-  [Hence also]"},{"kind":"italic_en","text":"A grave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sepulchre:"},{"kind":"text","text":"(S, K:) pl."},{"kind":"arabic","text_bw":"kufuwrN","text_ar":"كُفُورٌ"},{"kind":"text","text":". (S.) Whence the saying,"},{"kind":"arabic","text_bw":"A^all~hum~a A@gofiro liA^aholi Alkufuwri","text_ar":"اَللّهُمَّ ا@غْفِرْ لِاَهْلِ الكُفُورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O God, pardon the people of the graves"},{"kind":"text","text":"]. (S.)       -A4-  [And hence, perhaps,]"},{"kind":"italic_en","text":"A town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village;"},{"kind":"text","text":"[generally the latter;] syn."},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":": (S, Mgh, Msb, K:) a Syriac word, and mostly used by the people of Syria [and of Egypt]: or, accord. to El-Harbee,"},{"kind":"italic_en","text":"land that is far from men, by which no one passes:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"kufuwrN","text_ar":"كُفُورٌ"},{"kind":"text","text":": (S, Msb:) in the present day, it is applied in Egypt to"},{"kind":"italic_en","text":"any small"},{"kind":"arabic","text_bw":"qaroyap","text_ar":"قَرْيَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"village"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the side of a great"},{"kind":"arabic","text_bw":"qaroyap","text_ar":"قَرْيَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"town"},{"kind":"text","text":"]: they say"},{"kind":"arabic","text_bw":"Alqaroyapu AlfulaAniy~apu wakaforuhaA","text_ar":"القَرْيَةُ الفُلَانِيَّةُ وَكَفْرُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a town and its village"},{"kind":"text","text":"]: and sometimes one"},{"kind":"arabic","text_bw":"qaroyap","text_ar":"قَرْيَة"},{"kind":"text","text":"has a number of"},{"kind":"arabic","text_bw":"kufuwr","text_ar":"كُفُور"},{"kind":"text","text":". (TA.) Hence the saying of Mo'áwiyeh,"},{"kind":"arabic","text_bw":"A^aholu Alkufuwri humo A^aholu Alqubuwri","text_ar":"اَهْلُ الكُفُورِ هُمْ اَهْلُ القُبُورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of the villages are the people of the graves"},{"kind":"text","text":"]; meaning, that they are as the dead; they do not see the great towns and the performance of the congregational prayers of Friday: (S, Mgh:) by"},{"kind":"arabic","text_bw":"Alkfwr","text_ar":"الكفور"},{"kind":"text","text":"he meant"},{"kind":"italic_en","text":"the villages"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlquraY","text_ar":"القُرَى"},{"kind":"text","text":")"},{"kind":"italic_en","text":"remote from the great towns and from the places where the people of science assemble,"},{"kind":"text","text":"so that ignorance prevails among their inhabitants, and they are most quickly affected by innovations in religion and by natural desires which cause to err. (Az, TA.) Hence also the trad. (of Aboo-Hureyreh, TA),"},{"kind":"arabic","text_bw":"layuxorijan~akumu","text_ar":"لَيُخْرِجَنَّكُمُ"},{"kind":"arabic","text_bw":"A@lr~uwmu minohaA kaforFA kaforFA","text_ar":"ا@لرُّومُ مِنْهَا كَفْرًا كَفْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The Greeks will assuredly expel you from them, town by town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village by village"},{"kind":"text","text":"]; (S, * TA;) i. e. from the"},{"kind":"arabic","text_bw":"furFY","text_ar":"فُرًى"},{"kind":"text","text":"of Syria. (S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"kaforN EalaY kaforK","text_ar":"كَفْرٌ عَلَى كَفْرٍ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"One upon another;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one part upon another."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","Mgh","Msb","TA"]},{"entry_id":"n37102","headword_ar":"كُفْرٌ","root":"kfr","body":[{"kind":"text","text":": see 1. [As a simple subst.,"},{"kind":"italic_en","text":"Ingratitude,"},{"kind":"text","text":"&c. ―         -b2-  And particularly"},{"kind":"italic_en","text":"Denial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledgment, of favours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits,"},{"kind":"text","text":"and especially of those"},{"kind":"italic_en","text":"conferred by God:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"disbelief, unbelief; infidelity."},{"kind":"text","text":"] It is of four kinds:"},{"kind":"arabic","text_bw":"kuforu A_inokaArK","text_ar":"كُفْرُ اـِنْكَارٍ"},{"kind":"italic_en","text":"the denial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledgment, of God, with the heart and the tongue, having no knowledge of what is told one of the unity of God"},{"kind":"text","text":"[&c.]: and"},{"kind":"arabic","text_bw":"kuforu juHuwdK","text_ar":"كُفْرُ جُحُودٍ"},{"kind":"italic_en","text":"the acknowledgment with the heart without confessing with the tongue:"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the disacknowledgment of God with the tongue while the heart acknowledges Him:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"kuforu","text_ar":"كُفْرُ"},{"kind":"arabic","text_bw":"AlmuEaAnadapi","text_ar":"المُعَانَدَةِ"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"knowledge of God with the heart, and confession with the tongue, with refusal to accept"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the truth"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"kuforu Aln~ifaAqi","text_ar":"كُفْرُ النِّفَاقِ"},{"kind":"italic_en","text":"the confession with the tongue with disbelief in the heart:"},{"kind":"text","text":"all of these are unpardonable: (L, TA:) the greatest"},{"kind":"arabic","text_bw":"kufor","text_ar":"كُفْر"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"denial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledgment, of the unity"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of God"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"of the prophetic office"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of Mohammad and others"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"of the law of God."},{"kind":"text","text":"(El-Basáïr.) [Also,"},{"kind":"italic_en","text":"Blasphemy."},{"kind":"text","text":"Its pl., as a simple subst. in all these senses, is said to be"},{"kind":"arabic","text_bw":"kufuwrN","text_ar":"كُفُورٌ"},{"kind":"text","text":".]. Akh says, that"},{"kind":"arabic","text_bw":"kufuwrFA","text_ar":"كُفُورًا"},{"kind":"text","text":"[in the accus. case] in the Kur xvii. 101, [to which may be added v. 91 of the same ch., and xxv. 52,] is pl. of"},{"kind":"arabic","text_bw":"kuforN","text_ar":"كُفْرٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"buruwdN","text_ar":"بُرُودٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"burodN","text_ar":"بُرْدٌ"},{"kind":"text","text":". (S.)       -A2-"},{"kind":"italic_en","text":"Tar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pitch,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qiyrN","text_ar":"قِيرٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"with which ships are smeared;"},{"kind":"text","text":"(K;) of which there are three sorts,"},{"kind":"arabic","text_bw":"kuforN","text_ar":"كُفْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qiyrN","text_ar":"قِيرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ziftN","text_ar":"زِفتٌ"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"kfr","text_ar":"كفر"},{"kind":"text","text":"is melted, and then ships are smeared with it: [whence, app., its name, from its being a covering:]"},{"kind":"arabic","text_bw":"zft","text_ar":"زفت"},{"kind":"text","text":"is used for smearing skins for wine, &c. (ISh.)"}],"source_refs":["L","TA"]},{"entry_id":"n37103","headword_ar":"كِفْرٌ","root":"kfr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"kaforN","text_ar":"كَفْرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n37104","headword_ar":"كَفَرٌ","root":"kfr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"kaAfuwrN","text_ar":"كَافُورٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}