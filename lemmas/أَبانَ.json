s":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبِينُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبَنَّ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُبِنَّ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَبَنّا","in_corpus":true,"count":27,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَبَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُبان","in_corpus":true,"count":655,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبان","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبَن","in_corpus":true,"count":3452,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبَن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبِن","in_corpus":true,"count":3452,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبِين","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبِين","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":11165,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n7","n103","n3662"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D8%A7%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to explain; to account for; to expound; to elucidate"},{"pos":"verb","gloss":"to distinguish; to separate"},{"pos":"verb","gloss":"to be clear; to be evident"}]},"etymology":null,"ipa":["/ʔa.baː.na/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7","headword_ar":"اـِبَّانٌ","root":"Ab","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season,"},{"kind":"text","text":"of a thing: (Msb:) or the"},{"kind":"italic_en","text":"time of preparing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making ready,"},{"kind":"text","text":"of a thing: (Mgh:) as, for instance, of fruit: (Mgh, Msb:) it is of the measure"},{"kind":"arabic","text_bw":"fiEolaAnN","text_ar":"فِعْلَانٌ"},{"kind":"text","text":", (Mgh, Msb,) from"},{"kind":"arabic","text_bw":"A^ab~a","text_ar":"اَبَّ"},{"kind":"text","text":"in the first of the senses assigned to it above, (Mgh,) the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"being augmentative; (Msb;) or of the measure"},{"kind":"arabic","text_bw":"fiE~aAlN","text_ar":"فِعَّالٌ"},{"kind":"text","text":", (Mgh, Msb,) from"},{"kind":"arabic","text_bw":"A^ab~ana","text_ar":"اَبَّنَ"},{"kind":"text","text":"“he watched” or “observed” a thing, (Mgh,) the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"being radical: (Msb:) but the former derivation is the more correct. (Mgh.) [See also art."},{"kind":"arabic","text_bw":"Abn","text_ar":"ابن"},{"kind":"text","text":".]"}],"source_refs":["Msb","Mgh"]},{"entry_id":"n103","headword_ar":"اـِبَّانٌ","root":"Abn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"of a thing; (T, S, M, K, and Msb in art."},{"kind":"arabic","text_bw":"Ab","text_ar":"اب"},{"kind":"text","text":";) the"},{"kind":"italic_en","text":"season"},{"kind":"text","text":"of a thing; (Msb in that art.;) the"},{"kind":"italic_en","text":"time of the preparing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making ready,"},{"kind":"text","text":"of a thing; (Mgh in that art.;) as, for instance, of fruit, (S, Mgh, Msb,) of the fresh ripe dates, and of the gathering of fruits, and of heat or cold: (T.:) or the"},{"kind":"italic_en","text":"first"},{"kind":"text","text":"of a thing. (M, K.) You say,"},{"kind":"arabic","text_bw":"A^axa*a Al$~aYo'a biA_ib~aAnihi","text_ar":"اَخَذَ الشَّىْءَ بِاـِبَّانِهِ"},{"kind":"italic_en","text":"He took the thing in its time:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with, the first thereof."},{"kind":"text","text":"(M.) The"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"is radical, so that it is of the measure"},{"kind":"arabic","text_bw":"fiE~aAlN","text_ar":"فِعَّالٌ"},{"kind":"text","text":"; or, as some say, augmentative, so that it is of the measure"},{"kind":"arabic","text_bw":"fiEolaAnN","text_ar":"فِعْلَانٌ"},{"kind":"text","text":". (TA.) [See art."},{"kind":"arabic","text_bw":"Ab","text_ar":"اب"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","Msb"]},{"entry_id":"n3662","headword_ar":"ابان","root":"byn","body":[{"kind":"text","text":", intrans., inf. n."},{"kind":"arabic","text_bw":"A_ibaAnapN","text_ar":"اـِبَانَةٌ"},{"kind":"text","text":": see 1, in two places.       -A2-"},{"kind":"arabic","text_bw":"AbAnhu","text_ar":"ابانهُ"},{"kind":"text","text":", (inf. n. as above, TA,)"},{"kind":"italic_en","text":"He separated it, severed it, disunited it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut it off."},{"kind":"text","text":"(M, Msb, K, TA.) You say,"},{"kind":"arabic","text_bw":"Darabahu faA^abaAna raA^osahu","text_ar":"ضَرَبَهُ فَاَبَانَ رَاْسَهُ"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"He smote him and severed his head,"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"jasadihi","text_ar":"جَسَدِهِ"},{"kind":"italic_en","text":"from his body."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"AbAn AlmaroA^apa","text_ar":"ابان المَرْاَةَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the husband)"},{"kind":"italic_en","text":"separated the woman,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wife,"},{"kind":"text","text":"by divorce. (Msb.) And"},{"kind":"arabic","text_bw":"AbAn binotahu","text_ar":"ابان بِنْتَهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"by~nhA","text_ar":"بيّنها","orth_type":"arrow"},{"kind":"text","text":", (T, K,) inf. n. of the former as above, and of the latter"},{"kind":"arabic","text_bw":"taboyiynN","text_ar":"تَبْيِينٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He married,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave in marriage, his daughter,"},{"kind":"text","text":"(T, K,)"},{"kind":"italic_en","text":"and she went to her husband:"},{"kind":"text","text":"(T:) from"},{"kind":"arabic","text_bw":"bayonN","text_ar":"بَيْنٌ"},{"kind":"text","text":"signifying \"distance:\" as though he removed her to a distance from the house, or tent, of her mother. (TA.) And"},{"kind":"arabic","text_bw":"AbAn A@bonahu bimaAlK","text_ar":"ابان ا@بْنَهُ بِمَالٍ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"AbAnhu A^abawaAhu","text_ar":"ابانهُ اَبَوَاهُ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"He separated from himself his son,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"his two parents separated him from themselves,"},{"kind":"text","text":"(T,)"},{"kind":"italic_en","text":"by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"giving him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"property,"},{"kind":"text","text":"(T, M,)"},{"kind":"italic_en","text":"to be his alone:"},{"kind":"text","text":"(T:) mentioned on the authority of AZ. (T, M.) And"},{"kind":"arabic","text_bw":"AbAn Ald~alowa Eano TiY~i Albiy^ori","text_ar":"ابان الدَّلْوَ عَنْ طِىِّ البِيْرِ"},{"kind":"italic_en","text":"He drew away the bucket from the casing of the well, lest the latter should lacerate the former."},{"kind":"text","text":"(M.) ―         -b2-  See also 2, in three places. ―         -b3-  [Hence,"},{"kind":"arabic","text_bw":"AbAn","text_ar":"ابان"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He spoke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrote, perspicuously, clearly, plainly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinctly, as to meaning;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"with eloquence:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"bayaAnN","text_ar":"بَيَانٌ"},{"kind":"text","text":", q. v.] And"},{"kind":"arabic","text_bw":"AbAn Ealayohi","text_ar":"ابان عَلَيْهِ"},{"kind":"italic_en","text":"He spoke perspicuously, clearly, plainly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinctly, and gave his testimony,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave decisive information, against him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting it."},{"kind":"text","text":"(TA.) [The verb thus used is for"},{"kind":"arabic","text_bw":"AbAn kalaAmahu","text_ar":"ابان كَلَامَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$ahaAdatahu","text_ar":"شَهَادَتَهُ"},{"kind":"text","text":".] One says of a drunken man,"},{"kind":"arabic","text_bw":"maA yubiynu kalaAmFA","text_ar":"مَا يُبِينُ كَلَامًا"},{"kind":"italic_en","text":"He does not speak plainly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinctly;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"does not make speech plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct."},{"kind":"text","text":"(Ks, T in art."},{"kind":"arabic","text_bw":"bt","text_ar":"بت"},{"kind":"text","text":".) ―         -b4-  ["},{"kind":"arabic","text_bw":"maA A^aboyanahu","text_ar":"مَا اَبْيَنَهُ"},{"kind":"italic_en","text":"How distinct, apparent, manifest, evident, clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain, is it!"},{"kind":"text","text":"See an ex. voce"},{"kind":"arabic","text_bw":"basula","text_ar":"بَسُلَ"},{"kind":"text","text":". ―         -b5-  And"},{"kind":"italic_en","text":"How perspicuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chaste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eloquent, is he in speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"writing! how good is his"},{"kind":"arabic","text_bw":"bayaAn","text_ar":"بَيَان"},{"kind":"text","text":"!]"}],"source_refs":["S","K","T","TA","M"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%A8%D8%A7%D9%86/","headword_ar":"أبان","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=64117#577951","body_html":"أبان<br>من (ب ي ن) أظهَرَ وأوضَحَ."},{"lexicon_id":"dictionary_46","lexicon_en":"Dictionary of Arabic Baby Names (2009)","lexicon_ar":"","permalink":"https://arabiclexicon.hawramani.com/?p=64117#48aa7b","body_html":"بمعنى الفعل أي اتّضح فهو مُبين واضح، وثمة أربعة أسماء إسلامية مشهورة: أبان بن عثمان بن عفّان، وأبان بن سعيد العاص، وأبان بن الوليد بن عقبة، وأبان بن يحيى بن سعيد."}]}}