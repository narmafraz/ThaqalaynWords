{"lemma":"خَبْلِ","slug":"خَبْلِ","root":"خ.ب.ل","root_slug":"خ-ب-ل","root_link":"/words/roots/خ-ب-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n9950","","n9953","n9954","n9955"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%A8%D9%92%D9%84%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9950","headword_ar":"خَبِلَ","root":"xbl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":"(JK, K, TA) and"},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, corrupted, unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an absolute sense;"},{"kind":"text","text":"and particularly]"},{"kind":"italic_en","text":"in his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a corrupt, an unsound, a vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disordered, state, occasioning him agitation like that of possession"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity, by disease affecting the reason and thought:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":", below:) and hence,]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insane."},{"kind":"text","text":"(JK, K, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xabila","text_ar":"خَبِلَ"},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":", (q. v. voce"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the palsy termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"faAlij","text_ar":"فَالِج"},{"kind":"text","text":". (JK.) ―         -b3-  And"},{"kind":"arabic","text_bw":"xabilato yaduhu","text_ar":"خَبِلَتْ يَدُهُ"},{"kind":"italic_en","text":"His arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, became corrupted, unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, so as to be rendered motionless;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became lost;"},{"kind":"text","text":"(K, TA;) or"},{"kind":"italic_en","text":"was cut off."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xabalahu","text_ar":"خَبَلَهُ"},{"kind":"text","text":", (JK, S, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xabolN","text_ar":"خَبْلٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"xb~lhu","text_ar":"خبّلهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"taxobiylN","text_ar":"تَخْبِيلٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Axtblhu","text_ar":"اختبلهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(grief, JK, K, and love, JK, T, TA, and time, or fortune, and the ruling power, and disease, T, TA)"},{"kind":"italic_en","text":"rendered him possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insane:"},{"kind":"text","text":"(JK, K, TA:) and"},{"kind":"italic_en","text":"it corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his limb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"member:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(grief)"},{"kind":"italic_en","text":"deprived him of his heart:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, one of his limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived him of his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xabala qalobahu","text_ar":"خَبَلَ قَلْبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(love)"},{"kind":"italic_en","text":"corrupted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered unsound, his heart."},{"kind":"text","text":"(JM.) And"},{"kind":"arabic","text_bw":"xabala fulaAnN yada fulaAnK","text_ar":"خَبَلَ فُلَانٌ يَدَ فُلَانٍ"},{"kind":"italic_en","text":"Such a one corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, the arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, of such a one, so that it became motionless;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused it to dry up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived him of it."},{"kind":"text","text":"(JK.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"xabalahu","text_ar":"خَبَلَهُ"},{"kind":"text","text":", (TA,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"xabolN","text_ar":"خَبْلٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"He restrained, withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred, him:"},{"kind":"text","text":"(K, * TA:) and ↓"},{"kind":"arabic","text_bw":"Axtbl","text_ar":"اختبل","orth_type":"arrow"},{"kind":"text","text":"likewise signifies"},{"kind":"italic_en","text":"he restrained, withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"maA xabalaka Ean~aA","text_ar":"مَا خَبَلَكَ عَنَّا"},{"kind":"italic_en","text":"What withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has withheld, thee from us?"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xabalahu Eano ka*aA","text_ar":"خَبَلَهُ عَنْ كَذَا"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"He prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered, him from doing such a thing."},{"kind":"text","text":"(K, * TA.)       -A3-"},{"kind":"arabic","text_bw":"xabala Eano fiEoli A^abiyhi","text_ar":"خَبَلَ عَنْ فِعْلِ اَبِيهِ"},{"kind":"italic_en","text":"He fell short of the doing of his father."},{"kind":"text","text":"(JK, K.)"}],"source_refs":["JK","K","TA","S","Msb"]},{"entry_id":"n9953","headword_ar":"خُبْلٌ","root":"xbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"waqaEa fiY xuboliY","text_ar":"وَقَعَ فِى خُبْلِى"},{"kind":"italic_en","text":"It came into my mind;"},{"kind":"text","text":"(JK, K;) a phrase like the saying,"},{"kind":"arabic","text_bw":"saqaTa fiY yadiY","text_ar":"سَقَطَ فِى يَدِى"},{"kind":"text","text":": (JK, K: * [in the K, meaning the same as this saying:]) and sometimes (JK) one says also ↓"},{"kind":"arabic","text_bw":"fiY xaboliY","text_ar":"فِى خَبْلِى","orth_type":"arrow"},{"kind":"text","text":". (JK [and so in the K accord. to the TA, but not in the CK, nor in my MS. copy of the K].)"}],"source_refs":["JK"]},{"entry_id":"n9954","headword_ar":"خَبَلٌ","root":"xbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":", in four places: ―         -b2-  and see"},{"kind":"arabic","text_bw":"xabolN","text_ar":"خَبْلٌ"},{"kind":"text","text":", in three places.       -A2-  Also The"},{"kind":"italic_en","text":"jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii;"},{"kind":"text","text":"(IAar, Fr, S, K;) and so ↓"},{"kind":"arabic","text_bw":"xaAbilN","text_ar":"خَابِلٌ","orth_type":"arrow"},{"kind":"text","text":": (JK, K:) or the latter has this signification; and the former is a quasi-pl. n. of the latter, or, as some say, a pl., as is also"},{"kind":"arabic","text_bw":"xub~alN","text_ar":"خُبَّلٌ"},{"kind":"text","text":": (TA:) and ↓"},{"kind":"arabic","text_bw":"xaAbilN","text_ar":"خَابِلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"a devil,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"devil."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"In him is somewhat of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii, called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^aholu AlA^aroDi","text_ar":"اَهْلُ الاَرْضِ"},{"kind":"text","text":". (S. [See"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":", near the end of the paragraph: and see other explanations of"},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":", which may apply in this case.]) ―         -b2-  Accord. to IAar and Fr, it is also applied to"},{"kind":"italic_en","text":"Mankind."},{"kind":"text","text":"(TA.) ―         -b3-  Also"},{"kind":"italic_en","text":"A certain bird, that cries all the night, with one cry, resembling"},{"kind":"arabic","text_bw":"maAtato xabalo","text_ar":"مَاتَتْ خَبَلْ"},{"kind":"text","text":". (M, K, * TA.)       -A3-  Also"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"mazaAdap","text_ar":"مَزَادَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leathern water-bag"},{"kind":"text","text":"]. (Fr, K.) ―         -b2-  And"},{"kind":"italic_en","text":"A full"},{"kind":"arabic","text_bw":"qirobap","text_ar":"قِرْبَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"water-skin"},{"kind":"text","text":"]. (Fr, K.)"}],"source_refs":["JK","K","TA"]},{"entry_id":"n9955","headword_ar":"خَبِلٌ","root":"xbl","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^axobalu","text_ar":"اَخْبَلُ","orth_type":"arrow"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"Corrupted, unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an absolute sense;"},{"kind":"text","text":"and particularly]"},{"kind":"italic_en","text":"in his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"maxobuwlN","text_ar":"مَخْبُولٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) [or"},{"kind":"italic_en","text":"in a corrupt, an unsound, a vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disordered, state, occasioning him agitation like that of possession"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity, by disease affecting the reason and thought:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":", below:) and hence,]"},{"kind":"italic_en","text":"possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insane;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"muxab~alN","text_ar":"مُخَبَّلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muxotabilN","text_ar":"مُخْتَبِلٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or ↓"},{"kind":"arabic","text_bw":"muxab~alN","text_ar":"مُخَبَّلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a man"},{"kind":"italic_en","text":"having no heart;"},{"kind":"text","text":"(JK;) as also ↓"},{"kind":"arabic","text_bw":"maxobuwlN","text_ar":"مَخْبُولٌ","orth_type":"arrow"},{"kind":"text","text":": (JK, Msb:) or this last,"},{"kind":"italic_en","text":"haring one of his limbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members, corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"xabilN","text_ar":"خَبِلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muxab~alN","text_ar":"مُخَبَّلٌ","orth_type":"arrow"},{"kind":"text","text":"signify also a beast"},{"kind":"italic_en","text":"corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, in the legs, so as not to know how to walk:"},{"kind":"text","text":"(JK:) or ↓"},{"kind":"arabic","text_bw":"muxab~alN","text_ar":"مُخَبَّلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a man who is"},{"kind":"italic_en","text":"as though his extremities were amputated."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"dahorN xabilN","text_ar":"دَهْرٌ خَبِلٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A time difficult to the people thereof;"},{"kind":"text","text":"(T, S, K, TA;)"},{"kind":"italic_en","text":"in which they see not happiness."},{"kind":"text","text":"(T, TA.)"}],"source_refs":["K","TA","JK","Msb"]}]},"classical_definitions":null}