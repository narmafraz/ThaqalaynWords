{"lemma":"مُذْنِبُو","slug":"مُذْنِبُو","root":"ذ.ن.ب","root_slug":"ذ-ن-ب","root_link":"/words/roots/ذ-ن-ب","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n14103","n14104","n14106"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B0%D9%92%D9%86%D9%90%D8%A8%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"comet"},{"pos":"adj","gloss":"guilty"},{"pos":"noun","gloss":"criminal"},{"pos":"noun","gloss":"sinner"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of ذَنَّبَ (ḏannaba) from ذَنَب (ḏanab, “tail”). Approximate meaning \"long-tailed\".\n\nDerived from the active participle of أَذْنَبَ (ʔaḏnaba, “to be guilty, to commit a crime, to sin”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14103","headword_ar":"مَذْنَبٌ","root":"*nb","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n14104","headword_ar":"مِذْنَبٌ","root":"*nb","body":[{"kind":"italic_en","text":"A long tail."},{"kind":"text","text":"(IAar, T, K.) ―         -b2-  And [hence, app. for"},{"kind":"arabic","text_bw":"*uw mi*onabK","text_ar":"ذُو مِذْنَبٍ"},{"kind":"text","text":"], (T,) or ↓"},{"kind":"arabic","text_bw":"mu*an~ibN","text_ar":"مُذَنِّبٌ","orth_type":"arrow"},{"kind":"text","text":", (TA, [but see this latter below,])"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lizard of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":". (T, TA.) ―         -b3-  Also, (S, K,) or ↓"},{"kind":"arabic","text_bw":"ma*onabN","text_ar":"مَذْنَبٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"maqoEadN","text_ar":"مَقْعَدٌ"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"mi*onabapN","text_ar":"مِذْنَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"A ladle;"},{"kind":"text","text":"(S, M, A, K;) because it has a tail, or what resembles a tail: (M:) pl."},{"kind":"arabic","text_bw":"ma*aAnibu","text_ar":"مَذَانِبُ"},{"kind":"text","text":". (S, M.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"A water-course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel of a torrent, in a tract at the foot of a mountain;"},{"kind":"text","text":"(Lth, T, S, M, A, K;)"},{"kind":"italic_en","text":"not wide;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"not very wide;"},{"kind":"text","text":"(M;) or"},{"kind":"italic_en","text":"not very long and wide;"},{"kind":"text","text":"(Lth, T;) as also ↓"},{"kind":"arabic","text_bw":"*inaAbapN","text_ar":"ذِنَابَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S:) the"},{"kind":"arabic","text_bw":"taloEap","text_ar":"تَلْعَة"},{"kind":"text","text":"is in the lower part of a mountain (Lth, T, A) or in an acclivity: (Lth, T, S, A:) also"},{"kind":"italic_en","text":"a water-course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel of a torrent, between what are termed"},{"kind":"arabic","text_bw":"taloEataAni","text_ar":"تَلْعَتَانِ"},{"kind":"text","text":"; (TA; [see"},{"kind":"arabic","text_bw":"taloEapN","text_ar":"تَلْعَةٌ"},{"kind":"text","text":", and see also"},{"kind":"arabic","text_bw":"madofaEN","text_ar":"مَدْفَعٌ"},{"kind":"text","text":";]) or this is termed"},{"kind":"arabic","text_bw":"taloEap","text_ar":"تَلْعَة"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*anabu","text_ar":"ذَنَبُ","orth_type":"arrow"},{"kind":"text","text":"; (T;) or it is termed ↓"},{"kind":"arabic","text_bw":"*inaAbN","text_ar":"ذِنَابٌ","orth_type":"arrow"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"*anaAy^ibu","text_ar":"ذَنَايِبُ"},{"kind":"text","text":": (M, K:) also"},{"kind":"italic_en","text":"a water-course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel of a torrent,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"running"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to a tract of land:"},{"kind":"text","text":"(M, K:) and"},{"kind":"italic_en","text":"a rivulet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamlet,"},{"kind":"text","text":"(K,) or the"},{"kind":"italic_en","text":"like thereof,"},{"kind":"text","text":"(AHn, T, M,)"},{"kind":"italic_en","text":"flowing from one"},{"kind":"arabic","text_bw":"rawoDap","text_ar":"رَوْضَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"meadow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to another,"},{"kind":"text","text":"(AHn, T, M, K,) and separating"},{"kind":"italic_en","text":"therein;"},{"kind":"text","text":"(T;) as also ↓"},{"kind":"arabic","text_bw":"*unaAbapN","text_ar":"ذُنَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"*inaAbapN","text_ar":"ذِنَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) and the"},{"kind":"italic_en","text":"tract over which this flows"},{"kind":"text","text":"is also called"},{"kind":"arabic","text_bw":"mi*onabN","text_ar":"مِذْنَبٌ"},{"kind":"text","text":". (T.) See also"},{"kind":"arabic","text_bw":"*anabN","text_ar":"ذَنَبٌ"},{"kind":"text","text":", in the middle of the paragraph."}],"source_refs":["T","S","K","A","M","TA","Lth","AHn"]},{"entry_id":"n14106","headword_ar":"مُذَنِّبٌ","root":"*nb","body":[{"kind":"text","text":"[app. applied to a she-camel, accord. to the K, or perhaps to a lizard of the kind called"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":", as seems to be indicated in the TA,]"},{"kind":"italic_en","text":"Finding difficulty in parturition, and therefore stretching out her tail:"},{"kind":"text","text":"(K:) [but accord. to Az,] it is applied to a"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":"only when he is"},{"kind":"italic_en","text":"striking with his tail a hunter or a serpent desiring to catch him."},{"kind":"text","text":"(T.) See also"},{"kind":"arabic","text_bw":"mi*onabN","text_ar":"مِذْنَبٌ"},{"kind":"text","text":". ―         -b2-  See also 2, in two places."}],"source_refs":["K"]}]},"classical_definitions":null}