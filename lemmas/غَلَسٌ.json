{"lemma":"غَلَسٌ","slug":"غَلَسٌ","root":"غ.ل.س","root_slug":"غ-ل-س","root_link":"/words/roots/غ-ل-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n32231"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%84%D9%8E%D8%B3%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"the timespan between daybreak and sunrise; the morning twilight, the morning half-light; dawn"},{"pos":"verb","gloss":"to journey in the darkness of the last part of the night","tags":["intransitive"]},{"pos":"verb","gloss":"to perform in the darkness of the last part of the night","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Compare Tigre ቀለስ (ḳäläs, “today's morning, this morning”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32231","headword_ar":"غَلَسٌ","root":"gls","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"darkness of the last part of the night,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"when it becomes mixed with the light of the dawn:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"beginning of the dawn, until it spreads in the tracts of the horizon:"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"gabasN","text_ar":"غَبَسٌ"},{"kind":"text","text":": both signify"},{"kind":"italic_en","text":"blackness mixed with whiteness and redness;"},{"kind":"text","text":"like the dawn. (Az, TA.)"},{"kind":"arabic","text_bw":"bigalasK","text_ar":"بِغَلَسٍ"},{"kind":"italic_en","text":"In a period of the darkness so called."},{"kind":"text","text":"(S, Msb, K.) [See also"},{"kind":"arabic","text_bw":"gaba$N","text_ar":"غَبَشٌ"},{"kind":"text","text":".]"}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_