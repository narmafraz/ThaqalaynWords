"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become sincere with"},{"pos":"verb","gloss":"to drink pure milk"},{"pos":"verb","gloss":"to be pure (of origin)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38260","headword_ar":"مَحْضٌ","root":"mHD","body":[{"kind":"italic_en","text":"Milk that is pure, sheer, free from admixture, unmingled, unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear;"},{"kind":"text","text":"(Lth, S, A, K;)"},{"kind":"italic_en","text":"without froth;"},{"kind":"text","text":"(Lth, A;) or"},{"kind":"italic_en","text":"not mixed with water:"},{"kind":"text","text":"(S, Msb;)"},{"kind":"italic_en","text":"whether sweet"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sour;"},{"kind":"text","text":"no other milk being so called: (S:) but it occurs repeatedly in trads. as meaning"},{"kind":"italic_en","text":"milk absolutely:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"miHaADN","text_ar":"مِحَاضٌ"},{"kind":"text","text":". (K.) It is said in a trad. ("},{"kind":"arabic","text_bw":"baAriko lahumo fiY maHoDihaA wamaxoDihaA","text_ar":"بَارِكْ لَهُمْ فِى مَحْضِهَا وَمَخْضِهَا"},{"kind":"italic_en","text":"Do Thou bless them in their"},{"kind":"text","text":"[the beasts']"},{"kind":"italic_en","text":"pure milk and churned milk."},{"kind":"text","text":"(TA.) And in another,"},{"kind":"arabic","text_bw":"faA@EomiduwA","text_ar":"فَا@عْمِدُوا"},{"kind":"arabic","text_bw":"A_ilaY $aApK mumotaliy^apF $aHomFA wamaHoDFA","text_ar":"اـِلَى شَاةٍ مُمْتَلِيَةً شَحْمًا وَمَحْضًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And betake yourselves to a ewe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she-goat,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"fat, and abounding with milk."},{"kind":"text","text":"(TA.) [See also an ex. voce"},{"kind":"arabic","text_bw":"zubodN","text_ar":"زُبْدٌ"},{"kind":"text","text":": and another voce"},{"kind":"arabic","text_bw":"Sar~aHa","text_ar":"صَرَّحَ"},{"kind":"text","text":".] ―         -b2-  (assumed tropical:)  Anything (Az, TA)"},{"kind":"italic_en","text":"pure, sheer, free from admixture, unmingled, unmixed, genuine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear;"},{"kind":"text","text":"(Msb, TA;)"},{"kind":"italic_en","text":"that is not mixed with any other thing."},{"kind":"text","text":"(Az, Msb, TA.) You say,"},{"kind":"arabic","text_bw":"fiD~apN maHoDN","text_ar":"فِضَّةٌ مَحْضٌ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"maHoDapN","text_ar":"مَحْضَةٌ"},{"kind":"text","text":", (A, K,) and ↓"},{"kind":"arabic","text_bw":"mamoHuwDapN","text_ar":"مَمْحُوضَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"Pure, unmixed, unalloyed, silver:"},{"kind":"text","text":"(A, * K:) so says Sb: but you say,"},{"kind":"arabic","text_bw":"h`*ihi AlfiD~apu maHoDFA","text_ar":"هٰذِهِ الفِضَّةُ مَحْضًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This is silver in a pure state"},{"kind":"text","text":"]; putting the last word in the accus. case, used as an inf. n. (TA.) And"},{"kind":"arabic","text_bw":"EarabiY~N maHoDN","text_ar":"عَرَبِىٌّ مَحْضٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"An Arabian of pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, race,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parentage:"},{"kind":"text","text":"(S, A, Msb: *) ["},{"kind":"italic_en","text":"a genuine Arabian:"},{"kind":"text","text":"] and the epithet is the same as fem. [and dual] and pl., (S, Msb,) accord. to the more approved usage; (Msb;) [for it is originally an inf. n.;] but you may, if you please, use the fem. and dual and pl. forms, as in the instances of [the synonymous epithets]"},{"kind":"arabic","text_bw":"qalobN","text_ar":"قَلْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baHotN","text_ar":"بَحْتٌ"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"Aln~asabi","text_ar":"النَّسَبِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa mamoHuwDu","text_ar":"هُوَ مَمْحُوضُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he is pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, in race,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parentage:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"arabic","text_bw":"AlD~ariybapi","text_ar":"الضَّرِيبَةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mamoHuwDu","text_ar":"مَمْحُوضُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"rendered pure in nature,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposition;"},{"kind":"text","text":"(Az, O;)"},{"kind":"italic_en","text":"freed from faults"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vices:"},{"kind":"text","text":"(Az:) and"},{"kind":"arabic","text_bw":"maHoDu AlHasabi","text_ar":"مَحْضُ الحَسَبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"pure in grounds of pretension to respect:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"AlHasabi","text_ar":"الحَسَبِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mamoHuwDu","text_ar":"مَمْحُوضُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"rendered pure therein:"},{"kind":"text","text":"(O, K:) the pl. of"},{"kind":"arabic","text_bw":"maHoDN","text_ar":"مَحْضٌ"},{"kind":"text","text":"thus used is"},{"kind":"arabic","text_bw":"miHaADN","text_ar":"مِحَاضٌ"},{"kind":"text","text":"[a pl. of mult.] and"},{"kind":"arabic","text_bw":"A^amoHaADN","text_ar":"اَمْحَاضٌ"},{"kind":"text","text":"[a pl. of pauc.]. (TA.) You say also,"},{"kind":"arabic","text_bw":"A^uHib~uka Hub~FA maHoDFA","text_ar":"اُحِبُّكَ حُبًّا مَحْضًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I love thee with a pure, sincere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"true, love"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"maHoDu AlA_iyomaAni","text_ar":"مَحْضُ الاـِيْمَانِ"},{"kind":"text","text":"occurs in a trad. as meaning (tropical:)"},{"kind":"italic_en","text":"Pure faith"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"belief."},{"kind":"text","text":"(TA.) ―         -b3-  Also,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qat~N","text_ar":"قَتٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A kind of trefoil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clover"},{"kind":"text","text":"]. (IKtt)"}],"source_refs":["S","TA","Az","K","A","Msb","O","IKtt"]},{"entry_id":"n38261","headword_ar":"مَحِضٌ","root":"mHD","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who loves"},{"kind":"text","text":"["},{"kind":"italic_en","text":"milk such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"maHoD","text_ar":"مَحْض"},{"kind":"text","text":"; like as one says,"},{"kind":"arabic","text_bw":"$aHimN laHimN","text_ar":"شَحِمٌ لَحِمٌ"},{"kind":"text","text":", meaning one “ who loves fat and flesh meat: ” (O:) or one"},{"kind":"italic_en","text":"who eagerly desires"},{"kind":"arabic","text_bw":"maHoD","text_ar":"مَحْض"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"maAHiDN","text_ar":"مَاحِضٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) each is a relative epithet; (TA:) or ↓ the latter signifies"},{"kind":"italic_en","text":"a possessor of"},{"kind":"arabic","text_bw":"maHoD","text_ar":"مَحْض"},{"kind":"text","text":"; (S, K;) similar to"},{"kind":"arabic","text_bw":"laAbinN","text_ar":"لَابِنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taAmirN","text_ar":"تَامِرٌ"},{"kind":"text","text":": (S:) and the former,"},{"kind":"italic_en","text":"a drinker of"},{"kind":"arabic","text_bw":"maHoD","text_ar":"مَحْض"},{"kind":"text","text":". (TA voce"},{"kind":"arabic","text_bw":"vafilN","text_ar":"ثَفِلٌ"},{"kind":"text","text":", q. v.)"}],"source_refs":["O","K","TA","S"]}]},"classical_definitions":null}