ogy":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n7312"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AD%D9%8E%D8%AF%D9%8E%D9%91%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to speak, to talk","examples":[{"text":"يَتَحَدَّثُونَ عَنْ أُمُورٍ سِيَاسِيَّةٍ مُهِمَّةٍ.","english":"They are talking about important political matters."}]},{"pos":"noun","gloss":"verbal noun of تَحَدَّثَ (taḥaddaṯa) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7312","headword_ar":"تحدّث","root":"Hdv","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He talked; conversed in words; told,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"related, stories,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narratives"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"tHd~v bihi","text_ar":"تحدّث بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He talked of it; told it; related it"},{"kind":"text","text":"]; (S, A, Msb, K;) namely, a"},{"kind":"arabic","text_bw":"Hadiyv","text_ar":"حَدِيث"},{"kind":"text","text":", (Msb,) or what is termed"},{"kind":"arabic","text_bw":"A^uHoduwvap","text_ar":"اُحْدُوثَة"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"yataHad~avu","text_ar":"يَتَحَدَّثُ"},{"kind":"arabic","text_bw":"A_ilaY Aln~isaA='i","text_ar":"اـِلَى النِّسَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He talks to women"},{"kind":"text","text":"]. (S, A. *) [See also 2.] ―         -b2-  It is said in a trad.,"},{"kind":"arabic","text_bw":"yaboEavu A@ll~`hu Als~aHaAba","text_ar":"يَبْعَثُ ا@للّٰهُ السَّحَابَ"},{"kind":"arabic","text_bw":"fayaDoHaku A^aHosana AlD~aHiki wayataHad~avu A^aHosana AlHadiyvi","text_ar":"فَيَضْحَكُ اَحْسَنَ الضَّحِكِ وَيَتَحَدَّثُ اَحْسَنَ الحَدِيثِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"God shall send the clouds, and they shall laugh with the best laughing, and talk with the best talking"},{"kind":"text","text":"]: the talking here mentioned, says IAth, is said to mean thundering; and the laughing, lightning; thundering being likened to talking because it announces rain, and its near coming: or by laughing may be meant the smiling of the earth, and the appearing of the flowers or blossome; and by talking, the talking of men in describing and mentioning the plants or herbage: this figure of speech is termed"},{"kind":"arabic","text_bw":"majaAzN taEoliyqiY~N","text_ar":"مَجَازٌ تَعْلِيقِىٌّ"},{"kind":"text","text":", and is one of the most approved kinds of"},{"kind":"arabic","text_bw":"mjAz","text_ar":"مجاز"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb"]}]},"classical_definitions":null}