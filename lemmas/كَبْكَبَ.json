,"sense_count":2},"lanes":{"found":true,"entry_ids":["n36524","n36525"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D8%A8%D9%92%D9%83%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to topple, to capsize, to overturn","tags":["transitive"]},{"pos":"verb","gloss":"to spill","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Reduplication from the root ك ب ب (k b b)."},"ipa":["/kab.ka.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36524","headword_ar":"كِبْكِبٌ","root":"kb","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kabokabN","text_ar":"كَبْكَبٌ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"kab~apN","text_ar":"كَبَّةٌ"},{"kind":"text","text":"-A2-"},{"kind":"italic_en","text":"A certain game"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"of the Arabs."},{"kind":"text","text":"(TA.)"}],"source_refs":["K"]},{"entry_id":"n36525","headword_ar":"كُبْكُبٌ","root":"kb","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kubaAkibu","text_ar":"كُبَاكِبُ"},{"kind":"text","text":"A man (TA)"},{"kind":"italic_en","text":"of compact"},{"kind":"text","text":"("},{"kind":"italic_en","text":"and strong,"},{"kind":"text","text":"TA,)"},{"kind":"italic_en","text":"make:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"kabaAkibu","text_ar":"كَبَاكِبُ"},{"kind":"text","text":". (K.)"}],"source_refs":["TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%83%D8%A8%D9%83%D8%A8/","headword_ar":"كبكب","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=22544#ff8791","body_html":"<h3>كبكب</h3><br><br>See art. كب."},{"lexicon_id":"dictionary_16","lexicon_en":"Abu Ḥayyān al-Gharnāṭī, Tuḥfat al-Arīb bi-mā fī l-Qurʾān min al-Gharīb (d. 1344 CE)","lexicon_ar":"تحفة الأريب بما في القرآن من الغريب لأبي حيان الغرناطي الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=22544#4db46b","body_html":"<span class=\"title1\">كبكب</span><span>: {فكبكبوا}: ألقوا على رؤوسهم.</span>"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=22544#23aeae","body_html":"كبكب: كبكوب: كُبّة غزل. (بوشر).<br>مُكَبْكَب: مُكَوَّر كالكرة. (بوشر)"},{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=22544#c064fe","body_html":"<span class=\"title1\">[كبكب]</span><span> نه: في ح الإسراء: حتى مر صلى الله عليه وسلم في \"كبكبة\" من بني إسرائيل، هي بالضم والفتح: الجماعة المتضامة من الناس وغيرهم. ومنه نظر إلى \"كبكبة\" قد أقبلت. غ: \"فكبكبوا\" ألقى بعضهم على بعض أو جمعوا.</span>"},{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=22544#97fa35","body_html":"كبكب<br> كَبْكَبَ<br> a. Threw, cast down; overturned.<br> b. Collected.<br> c. [ coll. ], Scattered; spilt (<br> liquid ). <br>d. [ coll. ], Rounded, rolled into <br> balls; wound (thread). <br> تَكَبْكَبَa. Collected themselves together.<br> b. [Fī], Wrapped himself in. <br>c. Was overturned &amp;c.<br> d. [ coll. ], Pass. of I <br> (c), (d). <br> كَبْكَاْبa. A kind of date.<br> <br> كَبْكَاْبَةa. Fat (woman). <br> كَبْكَبa. see 53 <br> كَبْكَبَةa. Company; crowd, mob.<br> <br> كِبْكِبa. A certain game.<br> <br> كُبْكُب<br> (pl.<br> كَبَاْكِبُ)<br>a. Well-made, sturdy.<br> <br> كُبْكُبَةa. see 51t <br> كَبْكُوْب<br> a. [ coll. ], Ball, skein ( of <br> thread ). <br> كَبْكُوْبَة<br> a. [ coll. ], Ball of meat.<br> <br> كُبْكُوْب كُبْكُوْبَة<br> a. see 51t <br> كَِبيْكَج<br> a. Ranunculus."}]}}