m-verb"]}]}, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n19114", "headword_ar": "سَحْقٌ", "root": "sHq", "body": [{"kind": "italic_en", "text": "An old and worn-out garment,"}, {"kind": "text", "text": "(S, Mgh, O, Msb, K,)"}, {"kind": "italic_en", "text": "that has become thin,"}, {"kind": "text", "text": "(O,)"}, {"kind": "italic_en", "text": "and threadbare;"}, {"kind": "text", "text": "(Ham p. 591;) also used as a prefixed noun, (Mgh, Msb,) so that you say"}, {"kind": "arabic", "text_bw": "saHoqu", "text_ar": "سَحْقُ"}, {"kind": "arabic", "text_bw": "vawobK", "text_ar": "ثَوْبٍ"}, {"kind": "text", "text": "[meaning as above], (Mgh,) and"}, {"kind": "arabic", "text_bw": "saHoqu burodK", "text_ar": "سَحْقُ بُرْدٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "an old and worn-out"}, {"kind": "arabic", "text_bw": "burod", "text_ar": "بُرْد"}, {"kind": "text", "text": "], and"}, {"kind": "arabic", "text_bw": "saHoqu EimaAmapK", "text_ar": "سَحْقُ عِمَامَةٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "an old and worn-out turban"}, {"kind": "text", "text": "]: (Mgh, Msb:) and one says"}, {"kind": "arabic", "text_bw": "vawobN saHoqN", "text_ar": "ثَوْبٌ سَحْقٌ"}, {"kind": "text", "text": ", [using it as an epithet,] (O, TA,) and ↓"}, {"kind": "arabic", "text_bw": "vawobN saHiqN", "text_ar": "ثَوْبٌ سَحِقٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (Har p. 258, [but for this I have found no other authority, and it may be a mistranscription,]) and ↓"}, {"kind": "arabic", "text_bw": "vawobN munosaHiqN", "text_ar": "ثَوْبٌ مُنْسَحِقٌ", "orth_type": "arrow"}, {"kind": "text", "text": "likewise signifies"}, {"kind": "italic_en", "text": "an old and worn-out garment:"}, {"kind": "text", "text": "(TA:)"}, {"kind": "arabic", "text_bw": "saHoqN", "text_ar": "سَحْقٌ"}, {"kind": "text", "text": "applied to a garment is an inf. n. used as a subst.: (O, TA:) the pl. is"}, {"kind": "arabic", "text_bw": "suHuwqN", "text_ar": "سُحُوقٌ"}, {"kind": "text", "text": ". (TA.) Hence one says"}, {"kind": "arabic", "text_bw": "saHoqu dirohamK", "text_ar": "سَحْقُ دِرْهَمٍ"}, {"kind": "text", "text": ", meaning (tropical:)"}, {"kind": "italic_en", "text": "A"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "bad"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "dirhem"}, {"kind": "text", "text": "[or]"}, {"kind": "italic_en", "text": "such as is termed"}, {"kind": "arabic", "text_bw": "zaAy^ifN", "text_ar": "زَايِفٌ"}, {"kind": "text", "text": ". (Mgh.) ―         -b2-  Also"}, {"kind": "italic_en", "text": "A pastor's bag"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "kinofN", "text_ar": "كِنْفٌ"}, {"kind": "text", "text": "): so in a verse cited voce"}, {"kind": "arabic", "text_bw": "xuf~N", "text_ar": "خُفٌّ"}, {"kind": "text", "text": ". (S in art."}, {"kind": "arabic", "text_bw": "xf", "text_ar": "خف"}, {"kind": "text", "text": ".) ―         -b3-  And (tropical:)"}, {"kind": "italic_en", "text": "Thin clouds:"}, {"kind": "text", "text": "(K:) likened to an old and worn-out garment. (TA.) ―         -b4-  And The"}, {"kind": "italic_en", "text": "mark,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "scar, of a gall,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sore, on the back of a camel, when it has healed, and the place thereof has become white:"}, {"kind": "text", "text": "(TA:) [like"}, {"kind": "arabic", "text_bw": "saloqN", "text_ar": "سَلْقٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "salaqN", "text_ar": "سَلَقٌ"}, {"kind": "text", "text": ".]"}], "source_refs": ["S", "Mgh", "O", "Msb", "K", "TA"]}, {"entry_id": "n19115", "headword_ar": "سَحِقٌ", "root": "sHq", "body": [{"kind": "text", "text": ": see the next preceding paragraph."}], "source_refs": []}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-he