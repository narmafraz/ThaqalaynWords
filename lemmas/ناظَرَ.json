"},{"role":"present_2mp","form":"تُناظِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُناظِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُناظِر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُناظِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُناظِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُناظِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُناظِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُناظِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُناظِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُناظِرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُناظِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُناظِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُناظِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ناظَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ناظَرْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":true,"lemma_key":"ناظَرَ","root":"نظر","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n40057"],"search_url":"https://lanelexicon.com/?s=%D9%86%D8%A7%D8%B8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of نَظَرَ (naẓara)","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"observer, viewer, spectator, onlooker"},{"pos":"noun","gloss":"supervisor"},{"pos":"noun","gloss":"inspector"},{"pos":"noun","gloss":"manager, director, superintendent, administrator, chief; (education) principal, headmaster (of a school)"},{"pos":"noun","gloss":"minister","tags":["obsolete"]},{"pos":"noun","gloss":"eye"},{"pos":"noun","gloss":"corner of the eye next to the nose"},{"pos":"verb","gloss":"to debate","tags":["transitive"]},{"pos":"verb","gloss":"to equal, to correspond to","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of نَظَرَ (naẓara) and from نَظِير (naẓīr)."},"ipa":["/naː.ðˤir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40057","headword_ar":"نَاظِرٌ","root":"nZr","body":[{"kind":"text","text":"act. part. n. of"},{"kind":"arabic","text_bw":"naZara","text_ar":"نَظَرَ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"Looking;"},{"kind":"text","text":"&c.: pl."},{"kind":"arabic","text_bw":"nuZ~aArN","text_ar":"نُظَّارٌ"},{"kind":"text","text":". (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"Aln~aAZiru","text_ar":"النَّاظِرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The pupil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apple, of the eye,"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"smallest black of the eye,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"in which is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"seen"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what is termed"},{"kind":"arabic","text_bw":"A_inosaAnu AlEayoni","text_ar":"اـِنْسَانُ العَيْنِ"},{"kind":"text","text":", (S,) ["},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with which the man sees;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"the black spot in the eye;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"the clear black spot that is in the middle of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"main"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"black of the eye, with which the looker sees what he sees:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that part of the eye which resembles a mirror, in which, when one faces it, he sees his person:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a duct"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eiroq","text_ar":"عِرْق"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the nose, wherein is the water of sight:"},{"kind":"text","text":"(M, K:) [app. a loose description of"},{"kind":"italic_en","text":"the optic nerve:"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"the sight itself:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"the eye:"},{"kind":"text","text":"(K:) or the eye is called ↓"},{"kind":"arabic","text_bw":"Aln~aAZirapu","text_ar":"النَّاظِرَةُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A; *) the pl. of which is"},{"kind":"arabic","text_bw":"nawaAZiru","text_ar":"نَوَاظِرُ"},{"kind":"text","text":". (A.) ―         -b3-"},{"kind":"arabic","text_bw":"$adiydu Aln~aAZiri","text_ar":"شَدِيدُ النَّاظِرِ"},{"kind":"text","text":", (so in a copy of the M and of the A and in some copies of the K,) or"},{"kind":"arabic","text_bw":"sadiydu Aln~aAZiri","text_ar":"سَدِيدُ النَّاظِرِ"},{"kind":"text","text":", (so in some copies of the K and in the TA,) A man"},{"kind":"italic_en","text":"clear of suspicion, who looks with a full gaze:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"clear of that with which he is upbraided."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"Aln~aAZiraAni","text_ar":"النَّاظِرَانِ"},{"kind":"italic_en","text":"Two veins at the two edges of the nose, commencing from the inner angles of the eyes, towards the face."},{"kind":"text","text":"(Zj, in his Khalk el-Insán.) ―         -b5-  Also,"},{"kind":"arabic","text_bw":"naAZirN","text_ar":"نَاظِرٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A guardian; a keeper; a watcher:"},{"kind":"text","text":"(S, Msb:) and, as also ↓"},{"kind":"arabic","text_bw":"naAZuwrN","text_ar":"نَاظُورٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"naATuwrN","text_ar":"نَاطُورٌ"},{"kind":"text","text":", (K, TA,) [which last is] a word of the Nabathean dialect. (TA.) ―         -b6-  [The dim. is"},{"kind":"arabic","text_bw":"nuwayoZirN","text_ar":"نُوَيْظِرٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"EuyayonatiY nuwayoZirapN","text_ar":"عُيَيْنَتِى نُوَيْظِرَةٌ"},{"kind":"arabic","text_bw":"A_ilaY A@ll~`hi vum~a A_ilayokumo","text_ar":"اـِلَى ا@للّٰهِ ثُمَّ اـِلَيْكُمْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"My eye"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"my little eye"},{"kind":"text","text":")"},{"kind":"italic_en","text":"is looking to God for His bounty, then to you"},{"kind":"text","text":"for your bounty. (A.)       -A2-  In the Kur, [lxxv. 23,] the words"},{"kind":"arabic","text_bw":"A_ilaY rab~ihaA naAZirapN","text_ar":"اـِلَى رَبِّهَا نَاظِرَةٌ"},{"kind":"text","text":"have been explained as signifying"},{"kind":"italic_en","text":"Waiting for"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"munotaZirapN","text_ar":"مُنْتَظِرَةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"their Lord:"},{"kind":"text","text":"but this is a mistake; for the Arabs do not say"},{"kind":"arabic","text_bw":"naTarotu A_ilaY Al$~aYo'i","text_ar":"نَطَرْتُ اـِلَى الشَّىْءِ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"A_inotaZarotuhu","text_ar":"اـِنْتَظَرْتُهُ"},{"kind":"text","text":", but they say"},{"kind":"arabic","text_bw":"naZarotu fulaAnFA","text_ar":"نَظَرْتُ فُلَانًا"},{"kind":"text","text":"in that sense. (T.)"}],"source_refs":["S","Msb","TA","M","K"]}]}}