{"lemma":"شَمَطٌ","slug":"شَمَطٌ","root":"ش.م.ط","root_slug":"ش-م-ط","root_link":"/words/roots/ش-م-ط","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n23014"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%85%D9%8E%D8%B7%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23014","headword_ar":"شَمَطٌ","root":"$mT","body":[{"kind":"italic_en","text":"Whiteness of the hair of the head mixed with its blackness:"},{"kind":"text","text":"(S, Mgh, K:) or"},{"kind":"italic_en","text":"difference"},{"kind":"text","text":"in the hair"},{"kind":"italic_en","text":"by being of two colours, black and white:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"mixture of whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, with the blackness of youth:"},{"kind":"text","text":"(Mgh:) or in a man,"},{"kind":"italic_en","text":"whiteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, of the beard:"},{"kind":"text","text":"(Lth, Mgh, TA:) but in a woman,"},{"kind":"italic_en","text":"whiteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, of the head."},{"kind":"text","text":"(Lth, TA.) [See 1.] ―         -b2-  Also"},{"kind":"arabic","text_bw":"$amaTaAtN","text_ar":"شَمَطَاتٌ"},{"kind":"text","text":", which is its pl.,"},{"kind":"italic_en","text":"White hairs that are in the head."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","K","M","TA","Lth"]}]},"classical_definitions":null}