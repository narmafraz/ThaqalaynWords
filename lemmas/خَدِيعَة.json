{"lemma":"خَدِيعَة","slug":"خَدِيعَة","root":"خ.د.ع","root_slug":"خ-د-ع","root_link":"/words/roots/خ-د-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n10133"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%AF%D9%90%D9%8A%D8%B9%D9%8E%D8%A9"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10133","headword_ar":"خَدِيعَةٌ","root":"xdE","body":[{"kind":"italic_en","text":"Deceit, delusion, guile, circumvention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outwitting;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a desire to do to another a foul, an abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil, action, without the latter's knowing whence it proceeds;"},{"kind":"text","text":"(S, K;) a subst. from"},{"kind":"arabic","text_bw":"xadaEahu","text_ar":"خَدَعَهُ"},{"kind":"text","text":"; (S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"xidoEN","text_ar":"خِدْعٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb, TA,) or this is an inf. n.; (AZ, S, K;) and ↓"},{"kind":"arabic","text_bw":"xudoEapN","text_ar":"خُدْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"xidaAEN","text_ar":"خِدَاعٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) which [is also an inf. n. of"},{"kind":"arabic","text_bw":"xaAdaEahu","text_ar":"خَادَعَهُ"},{"kind":"text","text":", and] originally signifies"},{"kind":"italic_en","text":"concealment:"},{"kind":"text","text":"(Ham p. 541:) [and hence as above: and] also signifies"},{"kind":"italic_en","text":"prevention"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"manoEN","text_ar":"مَنْعٌ"},{"kind":"text","text":"); and"},{"kind":"italic_en","text":"art, artifice, cunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill, in the management of affairs;"},{"kind":"text","text":"(IAar, Sgh, K;) or"},{"kind":"italic_en","text":"a making another to resign,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquish, the object that he has in view, by pretending to him something the contrary of what he conceals."},{"kind":"text","text":"(Er-Rághib, B.)"}],"source_refs":["Msb","TA"]}]}}