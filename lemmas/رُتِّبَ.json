":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَتَّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَتِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُرَتَّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَتِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُرَتَّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَتِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُرَتَّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَتِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَتِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَتَّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَتَّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَتِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَتِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَتَّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَتَّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَتِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَتِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَتَّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَتَّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَتِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُرَتَّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"رُتِّبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رُتِّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَتَّبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَتَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُرَتِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَتِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرَتَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَتَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":18},"lanes":{"found":true,"entry_ids":["n14660","n14661","n14664","n14665"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D8%AA%D9%90%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become firm, solid or stable"},{"pos":"verb","gloss":"to be or become stationary or motionless (of a thing)"},{"pos":"verb","gloss":"to stand upright (of a person)"},{"pos":"verb","gloss":"to erect (e.g. a column)","tags":["transitive"]},{"pos":"verb","gloss":"to stay, to remain, to dwell (somewhere)"},{"pos":"verb","gloss":"to stand firm"},{"pos":"verb","gloss":"to make constant, firm, steady, steadfast, stable, fixed, fast, settled, established and stationary, or motionless; to fix (to make fixed and unmoving)"},{"pos":"verb","gloss":"to consolidate"},{"pos":"verb","gloss":"to arrange, to array, to order (to prescribe a particular order for)"},{"pos":"verb","gloss":"to determine, to regulate"},{"pos":"verb","gloss":"to set aside, to earmark"},{"pos":"verb","gloss":"to cause to result, to derive"},{"pos":"verb","gloss":"to set"},{"pos":"verb","gloss":"to decorate or dress (a shop window)"},{"pos":"verb","gloss":"to compose, to put together (words)"},{"pos":"verb","gloss":"to draw omens, one after another"},{"pos":"noun","gloss":"verbal noun of رَتَبَ (rataba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of رُتْبَة (rutba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":["/ra.ta.ba/","/rat.ta.ba/","/ratb/","/ru.tab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14660","headword_ar":"رَتَبَ","root":"rtb","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rutuwbN","text_ar":"رُتُوبٌ"},{"kind":"text","text":", (S, M, Msb, K, *)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, constant, firm, steady, steadfast, stable, fixed, fast, settled, established,"},{"kind":"text","text":"(S, M, A, Msb, K,) and"},{"kind":"italic_en","text":"stationary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless;"},{"kind":"text","text":"(S, * M, A, * Msb, * K;) as also ↓"},{"kind":"arabic","text_bw":"trt~b","text_ar":"ترتّب","orth_type":"arrow"},{"kind":"text","text":". (M, K.) Also, said of a thing, (T,) of a"},{"kind":"arabic","text_bw":"kaEob","text_ar":"كَعْب"},{"kind":"text","text":"[i. e. cockal-bone, or die], [aor. and] inf. n. as above, (S, M, A, TA,) and of a man, (M, TA,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"ratobN","text_ar":"رَتْبٌ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"ratabN","text_ar":"رَتَبٌ"},{"kind":"text","text":", (K, * TA,)"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he, stood erect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upright;"},{"kind":"text","text":"(T, S, M, A, TA; [but in some copies of the K,"},{"kind":"arabic","text_bw":"AlAinoSibaAbu","text_ar":"الاِنْصِبَابُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"AlAinotiSaAbu","text_ar":"الاِنْتِصَابُ"},{"kind":"text","text":"as the explanation of"},{"kind":"arabic","text_bw":"Alr~atabu","text_ar":"الرَّتَبُ"},{"kind":"text","text":";]) and (TA) so ↓"},{"kind":"arabic","text_bw":"Artb","text_ar":"ارتب","orth_type":"arrow"},{"kind":"text","text":", (K, TA, [but this I rather think to be a mistranscription,]) said of a man: mentioned in the T as on the authority of IAar. (TA. [But in the T, I find only"},{"kind":"arabic","text_bw":"rataba","text_ar":"رَتَبَ"},{"kind":"text","text":"in this sense.]) So in the saying,"},{"kind":"arabic","text_bw":"rataba rutuwba AlkaEobi fiY","text_ar":"رَتَبَ رُتُوبَ الكَعْبِ فِى"},{"kind":"arabic","text_bw":"AlmaqAmi AlS~aEobi","text_ar":"المَقامِ الصَّعْبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He stood erect like as does the cockal-bone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the die, in the difficult standingplace"},{"kind":"text","text":"]: (S, * A, TA:) occurring in a trad. of Lukmán Ibn-'Ád. (TA.) And"},{"kind":"arabic","text_bw":"rataba fiY AlS~alaApi","text_ar":"رَتَبَ فِى الصَّلَاةِ"},{"kind":"italic_en","text":"He stood erect in prayer."},{"kind":"text","text":"(A.) [Or]"},{"kind":"arabic","text_bw":"rataba","text_ar":"رَتَبَ"},{"kind":"text","text":"said of a man, [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"ratobN","text_ar":"رَتْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rutuwbN","text_ar":"رُتُوبٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"he stood firm."},{"kind":"text","text":"(Msb.) And you say also,"},{"kind":"arabic","text_bw":"rataba fiY AlA^amori","text_ar":"رَتَبَ فِى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was constant, firm,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in the affair"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","M","A","Msb","K","T","TA"]},{"entry_id":"n14661","headword_ar":"رتّب","root":"rtb","body":[{"kind":"text","text":", (S, M, A, &c.,) inf. n."},{"kind":"arabic","text_bw":"tarotiybN","text_ar":"تَرْتِيبٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered,"},{"kind":"text","text":"(a thing, S, M, or things, A,)"},{"kind":"italic_en","text":"constant, firm, steady, steadfast, stable, fixed, fast, settled, established,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"stationary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless."},{"kind":"text","text":"(S, * M, Msb, K.) You say,"},{"kind":"arabic","text_bw":"rt~b","text_ar":"رتّب"},{"kind":"arabic","text_bw":"AlT~alaAy^iEa fiY AlmaraAtibi","text_ar":"الطَّلَايِعَ فِى المَرَاتِبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He stationed the scouts upon the"},{"kind":"arabic","text_bw":"mrAtb","text_ar":"مراتب"},{"kind":"text","text":"]. (A. See"},{"kind":"arabic","text_bw":"marotabapN","text_ar":"مَرْتَبَةٌ"},{"kind":"text","text":".) ―         -b2-"},{"kind":"italic_en","text":"He set"},{"kind":"text","text":"things"},{"kind":"italic_en","text":"in order, disposed"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"regularly, arranged"},{"kind":"text","text":"them, or"},{"kind":"italic_en","text":"classified"},{"kind":"text","text":"them. (MA.) You say,"},{"kind":"arabic","text_bw":"rt~b Alr~utaba","text_ar":"رتّب الرُّتَبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He set in order, regularly disposed, arranged, classified, distributed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, the stations, posts of honour,"},{"kind":"text","text":"&c.]. (TA voce"},{"kind":"arabic","text_bw":"A^aS~ala","text_ar":"اَصَّلَ"},{"kind":"text","text":".) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"tarotiybN","text_ar":"تَرْتِيبٌ"},{"kind":"text","text":"is sometimes used as signifying The"},{"kind":"italic_en","text":"mode of construction termed"},{"kind":"arabic","text_bw":"laf~N wana$orN","text_ar":"لَفٌّ وَنَشْرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when it is regularly disposed:"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"lf","text_ar":"لف"},{"kind":"text","text":"]. (Har p. 383.) ―         -b4-  [Also The"},{"kind":"italic_en","text":"prescribing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observing, a particular order"},{"kind":"text","text":"in any performance; as, for instance, in the ablution termed"},{"kind":"arabic","text_bw":"AlwuDuwo'","text_ar":"الوُضُوْء"},{"kind":"text","text":".] ―         -b5-  And The"},{"kind":"italic_en","text":"drawing of omens, one after another."},{"kind":"text","text":"(KL.)"}],"source_refs":["S","K"]},{"entry_id":"n14664","headword_ar":"رَتْبٌ","root":"rtb","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n14665","headword_ar":"رَتَبٌ","root":"rtb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"steps of stairs."},{"kind":"text","text":"(M, TA.) ―         -b2-"},{"kind":"italic_en","text":"Rocks near together, some of them higher than others:"},{"kind":"text","text":"(M, K:) [a coll. gen. n.:] n. un. ↓"},{"kind":"arabic","text_bw":"ratabapN","text_ar":"رَتَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"; mentioned on the authority of Yaakoob as [written ↓"},{"kind":"arabic","text_bw":"rutabN","text_ar":"رُتَبٌ","orth_type":"arrow"},{"kind":"text","text":",] with damm to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"and fet-h to the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":". (M.) ―         -b3-"},{"kind":"italic_en","text":"Elevated ground,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"like a"},{"kind":"arabic","text_bw":"barozax","text_ar":"بَرْزَخ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an obstruction, between two things:"},{"kind":"text","text":"app. a coll. gen. n. in this sense also; n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; for] you say ↓"},{"kind":"arabic","text_bw":"ratabapN","text_ar":"رَتَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ratabN","text_ar":"رَتَبٌ"},{"kind":"text","text":"like as you say"},{"kind":"arabic","text_bw":"darajapN","text_ar":"دَرَجَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"darajN","text_ar":"دَرَجٌ"},{"kind":"text","text":". (S.) ―         -b4-"},{"kind":"italic_en","text":"Hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty:"},{"kind":"text","text":"(S, A, K:)"},{"kind":"italic_en","text":"coarseness, hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty, of life"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"living:"},{"kind":"text","text":"(M, K: *)"},{"kind":"italic_en","text":"fatigue, weariness, embarrassment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"marotabapN","text_ar":"مَرْتَبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (M.) You say,"},{"kind":"arabic","text_bw":"maA fiY Eayo$ihi ratabN","text_ar":"مَا فِى عَيْشِهِ رَتَبٌ"},{"kind":"text","text":"(T, S, M, A)"},{"kind":"italic_en","text":"There is no hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty, in his life"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"living:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"no coarseness, hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"maA fiY h`*aA AlA^amori ratabN","text_ar":"مَا فِى هٰذَا الاَمْرِ رَتَبٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"marotabapN","text_ar":"مَرْتَبَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"There is no fatigue, weariness, embarrassment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble, in this affair."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"maA fiY h`*aA AlA^amori","text_ar":"مَا فِى هٰذَا الاَمْرِ"},{"kind":"arabic","text_bw":"ratabN walA EatabN","text_ar":"رَتَبٌ وَلا عَتَبٌ"},{"kind":"italic_en","text":"There is not in this affair any hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"any fatigue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble:"},{"kind":"text","text":"(T:) i. e."},{"kind":"italic_en","text":"it is easy, and rightly disposed."},{"kind":"text","text":"(T, A.)       -A2-  Also The"},{"kind":"italic_en","text":"space between the little finger and that next to it,"},{"kind":"text","text":"namely,"},{"kind":"italic_en","text":"the third finger,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when they are extended apart:"},{"kind":"text","text":"] and the"},{"kind":"italic_en","text":"space between the third finger and the middle finger"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when they are so extended"},{"kind":"text","text":"]: (M, K:) or the"},{"kind":"italic_en","text":"space between the fore finger and the middle finger"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when they are so extended"},{"kind":"text","text":"]: sometimes written and pronounced ↓"},{"kind":"arabic","text_bw":"ratobN","text_ar":"رَتْبٌ","orth_type":"arrow"},{"kind":"text","text":": (S, TA:) [or it is a coll. gen. n.; and] ↓"},{"kind":"arabic","text_bw":"ratabapN","text_ar":"رَتَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"[is the n. un., and] signifies the"},{"kind":"italic_en","text":"space between"},{"kind":"text","text":"["},{"kind":"italic_en","text":"any two of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the fingers."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"rtq","text_ar":"رتق"},{"kind":"text","text":". [See also"},{"kind":"arabic","text_bw":"buSomN","text_ar":"بُصْمٌ"},{"kind":"text","text":".]) It denotes also The ["},{"kind":"italic_en","text":"space that is measured by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"putting the four fingers close together."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"EatabN","text_ar":"عَتَبٌ"},{"kind":"text","text":".])"}],"source_refs":["M","K","S","A","T","TA"]}]},"classical_definitions":null}