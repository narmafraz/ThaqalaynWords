{"lemma":"ضَحِيَ","slug":"ضَحِيَ","root":"ض.ح.#","root_slug":"ض-ح-_","root_link":"/words/roots/ض-ح-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ضَحِيْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ضَحِيْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ضَحِيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ضَحِيْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ضَحِيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ضَحِيَ","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ضَحِيَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ضَحِيا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ضَحِيَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ضَحُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ضَحِيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَضْحَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَضْحَى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَضْحَِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَضْحَِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَضْحَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَضْحَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَضْحَُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَضْحَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضْحَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضْحَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَضْحَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضْحَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَضْحَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضْحَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضْحَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضْحَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضْحَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضْحَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضْحَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضْحَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَضْحَ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضْحَ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَضْحَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضْحَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"ضَحِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ضَحِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":true,"lemma_key":"ضَحِيَ","root":"ضحو","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n25621","n25626"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%AD%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"alternative form of ضُحًا (ḍuḥan)","tags":["alt-of","alternative"],"examples":[{"text":"وَٱلضُّحَى وَٱللَّيْلِ إِذَا سَجَى مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى","english":"By the forenoon, and the night when it is the stillest, thy Lord hath not forsaken thee nor doth He hate thee."}]},{"pos":"noun","gloss":"alternative form of ضُحًا (ḍuḥan); ellipsis of صَلَاة الضُّحَى (ṣalā(t) aḍ-ḍuḥā, “morning or forenoon prayer”)","tags":["abbreviation","alt-of","ellipsis"]},{"pos":"verb","gloss":"to sacrifice"},{"pos":"verb","gloss":"to slaughter, to butcher"}]},"etymology":null,"ipa":["/dˤu.ħan/","/dˤaħ.ħaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25621","headword_ar":"ضُحًى","root":"DHw and DHY","body":[{"kind":"text","text":", also written"},{"kind":"arabic","text_bw":"DuHFA","text_ar":"ضُحًا"},{"kind":"text","text":", held by some to be of the measure"},{"kind":"arabic","text_bw":"fuEalN","text_ar":"فُعَلٌ"},{"kind":"text","text":", and by others to be [originally"},{"kind":"arabic","text_bw":"DuHowFY","text_ar":"ضُحْوًى"},{"kind":"text","text":"i. e.] of the measure"},{"kind":"arabic","text_bw":"fuEolFY","text_ar":"فُعْلًى"},{"kind":"text","text":", of the former measure accord. to Mbr, and of the latter accord. to Th, (MF, TA,) [The"},{"kind":"italic_en","text":"early part of the forenoon, after sunrise:"},{"kind":"text","text":"accord. to some,"},{"kind":"italic_en","text":"when the sun is yet low:"},{"kind":"text","text":"accord. to others,"},{"kind":"italic_en","text":"when the sun is somewhat high:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to most authorities: (MF, TA, and so in one place in the K:) or this latter signifies the"},{"kind":"italic_en","text":"period"},{"kind":"text","text":"of the day"},{"kind":"italic_en","text":"after sunrise:"},{"kind":"text","text":"(S:) or this signifies the"},{"kind":"italic_en","text":"advanced state of the day"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AirotifaAEu Aln~ahaAri","text_ar":"اِرْتِفَاعُ النَّهَارِ"},{"kind":"text","text":"[which is said by the doctors of the law in the present day to mean"},{"kind":"italic_en","text":"when the sun has risen the measure of a"},{"kind":"arabic","text_bw":"rumoH","text_ar":"رُمْح"},{"kind":"text","text":", q. v., or"},{"kind":"italic_en","text":"more"},{"kind":"text","text":"]); as also ↓"},{"kind":"arabic","text_bw":"DaHowN","text_ar":"ضَحْوٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"DaHiy~apN","text_ar":"ضَحِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) and the"},{"kind":"arabic","text_bw":"DuHaY","text_ar":"ضُحَى"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"after the"},{"kind":"arabic","text_bw":"DaHowap","text_ar":"ضَحْوَة"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"a little,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"when the sun shines brightly:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"from sunrise to the time when the day is advanced and very white:"},{"kind":"text","text":"thus in the M: (TA:) or it is the"},{"kind":"italic_en","text":"spreading of the sun"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon the earth"},{"kind":"text","text":"], and the"},{"kind":"italic_en","text":"extending of the day:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"] is thus named: (Er-Rághib, TA:) or"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"is pl. of ↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"qurFY","text_ar":"قُرًى"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":"; and its sing. is like ↓"},{"kind":"arabic","text_bw":"DaHaA='N","text_ar":"ضَحَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", which means the"},{"kind":"italic_en","text":"extending of the day,"},{"kind":"text","text":"and is of the masc. gender, as though a name of the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]: then"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"became used as a sing., and the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"was thus called: (Msb:) it is fem. and masc.: (S, K: *) he who makes it fem. holds it to be pl. of ↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and he who makes it masc. holds it to be [a sing.] noun of the measure"},{"kind":"arabic","text_bw":"fuEalN","text_ar":"فُعَلٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"SuradN","text_ar":"صُرَدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nugarN","text_ar":"نُغَرٌ"},{"kind":"text","text":": (S:) its dim. is ↓"},{"kind":"arabic","text_bw":"DuHaY~N","text_ar":"ضُحَىٌّ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (Fr, Msb, K;) for they disapproved the affixing the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"lest it should be confounded with the dim. of"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ"},{"kind":"text","text":". (Fr, Msb.) Using it as an adv. noun, you say,"},{"kind":"arabic","text_bw":"laqiytuhu DuHaY","text_ar":"لَقِيتُهُ ضُحَى"},{"kind":"text","text":", when you mean ["},{"kind":"italic_en","text":"I met him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"DHY","text_ar":"ضحى"},{"kind":"italic_en","text":"of this day;"},{"kind":"text","text":"without tenween. (S, TA.) See also"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ"},{"kind":"text","text":". [See also De Sacy's Chrest. Ar., sec. ed., i. 162-167, respecting the prayer that is performed in the time thus called,"},{"kind":"page_break","n":1774},{"kind":"text","text":"i. e. the prayer termed"},{"kind":"arabic","text_bw":"SalaApu AlD~uHaY","text_ar":"صَلَاةُ الضُّحَى"},{"kind":"text","text":", mentioned above, voce"},{"kind":"arabic","text_bw":"A^aDoHaY","text_ar":"اَضْحَى"},{"kind":"text","text":".] ―         -b2-  Also The"},{"kind":"italic_en","text":"sun:"},{"kind":"text","text":"(M, Msb, K:) because of its appearing in the time thus called. (M, TA.) One says,"},{"kind":"arabic","text_bw":"AirotafaEati AlD~aHaY","text_ar":"اِرْتَفَعَتِ الضَّحَى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The sun became high."},{"kind":"text","text":"(Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"DuHaY Al$~amosi","text_ar":"ضُحَى الشَّمْسِ"},{"kind":"italic_en","text":"The light of the sun:"},{"kind":"text","text":"thus is expl. xci. 1. of the Kur. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"maA likalaAmihi","text_ar":"مَا لِكَلَامِهِ"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"His speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, has no perspicuity:"},{"kind":"text","text":"thus in the M and K: but in the A, ↓"},{"kind":"arabic","text_bw":"A^ano$adaniY $aEorFA layosa fiyhi HalaAwapN walaA DaHaA='N","text_ar":"اَنْشَدَنِى شَعْرًا لَيْسَ فِيهِ حَلَاوَةٌ وَلَا ضَحَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"He recited to me poetry"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in which was no"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sweetness nor"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"plainness of meaning."},{"kind":"text","text":"(TA.)"}],"source_refs":["MF","TA","S","K","Msb","M"]},{"entry_id":"n25626","headword_ar":"ضُحَىٌّ","root":"DHw and DHY","body":[{"kind":"text","text":"dim. of"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":", q. v. (Fr, Msb, K.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D8%AD%D9%8A/","headword_ar":"ضحي","entries":[{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=16208#2f91dd","body_html":"ضحي<br> ضَحِيَ(n. ac. ضَحًى [ ])<br>a. Was smitten by the sun.<br> b. ( n. ac.<br> <br> ضَحَآء [] )<br>a. Stood in, exposed himself to, the sun; was <br> exposed.<br> <br> ضَحَّيَa. Made to eat, made to graze in the morning.<br> b. [Bi], Slaughtered, sacrificed in the morning.<br> c. ['An], Acted slowly, deliberately over. <br> ضَاْحَيَa. Visited, came to in the morning.<br> <br> أَضْحَيَa. Was, did &amp;c. in the morning.<br> b. Showed, disclosed, revealed, brought to light.<br> <br> تَضَحَّيَa. see I (a)b. Breakfasted.<br> <br> ضَحْو [ ]ضَحْوَة [] <br>a. see 9 <br> ضُحًيa. Early morning, dawn; morning, forenoon.<br> <br> أَضْحَاة [] (pl.<br> أَضْحَى<br> [ ] )<br>a. Sheep offered as a sacrifice.<br> <br> مَضْحَاة []<br>a. Sunny (place). <br> ضَاحٍa. Exposed, open; outer, exterior; visible.<br> <br> ضَاحِيَة [] (pl.<br> ضَوَاحِى<br> a. [ 411 ]), fem. of <br> ضَاْحِيb. Side; outside.<br> b. Out-lying district, frontier, province.<br> <br> ضَحَآء []<br>a. see 9 <br> ضَحِيَّة [] (pl.<br> ضَحَايَا)<br>a. see 14tb. Victim, sacrifice; holocaust, burnt-offering.<br> <br> ضَاحِيَةً<br> a. Openly, publicly.<br> <br> يَوْم الأَضْحَى<br> a. The day of the sacrifice ( Muhammadan <br> festival ). <br> إِضْحِيَان<br> a. Cloudless.<br> <br> لَا أَضْحَى اللّٰهُ ظِلَّكَ<br> a. May your shadow never pass away!"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=16208#abe94e","body_html":"<span class=\"title1\">(ض ح ي)</span><br><br><span>الضَّحْيانُ من كل شَيْء: البارز للشمس، قَالَ سَاعِدَة بن جؤية:</span><br><br><span>وَلَو أَن الَّذِي يُتْقَى عَلَيْهِ </span><span class=\"red\">...</span><span> بضَيْحان أشَمَّ بِهِ الوُعولُ</span><br><br><span>قَالَ ابْن جني: كَانَ الْقيَاس فِي ضَحْيانٍ ضَحْوانٌ لِأَنَّهُ من الضَّحْوةِ، أَلا ترَاهُ بارزا ظَاهرا وَهَذَا هُوَ معنى الضَّحوةِ؟ إِلَّا انه استخف بِالْيَاءِ.</span><br><br><span>وَالْأُنْثَى ضَحْيانَةٌ.</span><br><br><span>وَقَوله، انشده ابْن الْأَعرَابِي:</span><br><br><span>يَكفيكَ جَهْلَ الأحمقِ المُستَجهلِ</span><br><br><span>ضَحْيانَةٌ من عقَداتِ السَّلْسَلِ</span><br><br><span>فسره فَقَالَ: ضَحْيانَةٌ، عصى نَبتَت فِي الشَّمْس حَتَّى طبختها وأنضجتها فَهِيَ أَشد مَا تكون، وسلسل جبل من الدهناء، وشجرة طلح، فَإِذا كَانَت ضَحْيانةً وَكَانَت من طلح، ذهبت فِي الشدَّة كل مَذْهَب. وضَحِىَ للشمس وضَحَى يَضْحَى ضُحِيًّا وضُحُوّا، برز.</span><br><br><span>واستَضْحَى للشمس، برز لَهَا وَقعد عِنْدهَا فِي الشتَاء خَاصَّة.</span><br><br><span>وضواحي الرجل: مَا ضَحَى مِنْهُ للشمس وبرز، كالمنكبين والكتفين، قَالَ الشَّاعِر:</span><br><br><span>سَمينُ الضواحِي لم تُؤَرِّقْه لَيْلَة </span><span class=\"red\">...</span><span> وأنعَمَ، أبكارُ الهمومِ وعُونُها </span><span>وضواحِي كلِّ شَيْء: نواحيه البارزة للشمس.</span><br><br><span>والضواحِي من النّخل: مَا كَانَ خَارج السُّور، صفة غالبة لِأَنَّهَا تضْحَى للشمس. وَفِي كتاب النَّبِي عَلَيْهِ الصَّلَاة وَالسَّلَام ل \" أكيدر بن عبد الْملك \": \" لكم الضامنة من النّخل، وَلنَا الضاحِيَةُ من البعل. يَعْنِي بالضامنة مَا أطاف بِهِ سور الْمَدِينَة.</span><br><br><span>وضَواحِي الرّوم: مَا ظهر من بِلَادهمْ وبرز.</span><br><br><span>وَلَيْلَة ضَحْياءُ وضَحْيا وضَحْيانٌ وضَحْيانةٌ وإضْحِيانٌ وإضحيانَةٌ مضيئة لَا غيم فِيهَا، وَخص بَعضهم بِهِ اللَّيْلَة الَّتِي يكون الْقَمَر فِيهَا من أَولهَا إِلَى آخرهَا.</span><br><br><span>وَيَوْم إضْحِيانٌ: مضيء لَا غيم فِيهِ، وَكَذَلِكَ قمر ضَحيانٌ: قَالَ:</span><br><br><span>مَاذَا تُلاقينَ بِسَهِب إنسانْ</span><br><br><span>من الجَعلاتِ بِهِ والعرفانْ</span><br><br><span>من ظُلُماتٍ وسِراج ضَحيانْ</span><br><br><span>وقمر إضحِيانٌ، كضَحيانٍ.</span><br><br><span>وَبَنُو ضحيانَ: بطن.</span><br><br><span>وعامر الضَّحيانُ: مَعْرُوف.</span><br><br><span>وَفَارِس الضحياءِ، مَمْدُود، من فرسانهم.</span><br><br><span>والضَّحياءُ: فرس عَمْرو بن عَامر.</span><br><br><span>وضَحياءُ: مَوضِع، قَالَ أَبُو صَخْر الْهُذلِيّ:</span><br><br><span>عفَت ذاتُ عِرق عَصْلُها فرِئامُها </span><span class=\"red\">...</span><span> فضحياؤها قَفْرٌ قد اجْلىَ سَوامُها</span>"}]}}