{"lemma":"مَحَطَّيْ","slug":"مَحَطَّيْ","root":"ح.ط.ط","root_slug":"ح-ط-ط","root_link":"/words/roots/ح-ط-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n8362","n8363"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AD%D9%8E%D8%B7%D9%8E%D9%91%D9%8A%D9%92"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8362","headword_ar":"مَحَطٌّ","root":"HT","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A place where loads, &c., are put down."},{"kind":"text","text":"―         -b2-  And hence,] (assumed tropical:)"},{"kind":"italic_en","text":"A place where one alights,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alights and abides;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"maHaT~aAtN","text_ar":"مَحَطَّاتٌ","orth_type":"arrow"},{"kind":"text","text":": pl. [of either]"},{"kind":"arabic","text_bw":"maHaAT~u","text_ar":"مَحَاطُّ"},{"kind":"text","text":"and [of the latter]"},{"kind":"arabic","text_bw":"maHaT~aAtN","text_ar":"مَحَطَّاتٌ"},{"kind":"text","text":". (TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"maHaT~u sufunK","text_ar":"مَحَطُّ سُفُنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A place for unloading of ships"},{"kind":"text","text":"]. (S and K in art."},{"kind":"arabic","text_bw":"frD","text_ar":"فرض"},{"kind":"text","text":".) ―         -b4-  [Hence also,]"},{"kind":"arabic","text_bw":"h`*aA maHaT~u AlkalaAmi","text_ar":"هٰذَا مَحَطُّ الكَلَامِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This is the meaning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intent, of the saying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentence:"},{"kind":"text","text":"used in this sense in the present day]. (TA.)"}],"source_refs":[]},{"entry_id":"n8363","headword_ar":"مِحَطٌّ","root":"HT","body":[{"kind":"text","text":"(S, O, K) and ↓"},{"kind":"arabic","text_bw":"miHaT~apN","text_ar":"مِحَطَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"An instrument of iron,"},{"kind":"text","text":"(O, K,) or"},{"kind":"italic_en","text":"of wood, prepared"},{"kind":"text","text":"(K, in some copies of which, for"},{"kind":"arabic","text_bw":"muEad~apN","text_ar":"مُعَدَّةٌ"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"muEad~ilapN","text_ar":"مُعَدِّلَةٌ"},{"kind":"text","text":", which is a mistake, TA,)"},{"kind":"italic_en","text":"for the polishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smoothing, of skins,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"to make them soft and beautiful;"},{"kind":"text","text":"(O;) and"},{"kind":"italic_en","text":"for figuring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decorating, them;"},{"kind":"text","text":"(K;) [and"},{"kind":"italic_en","text":"for ruling them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making lines upon them:"},{"kind":"text","text":"see 1; last sentence:] or"},{"kind":"italic_en","text":"an instrument with which tattooing is performed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an iron instrument used by sewers of boots &c., with which they figure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decorate, the leather:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"an instrument"},{"kind":"text","text":"(T, A, TA)"},{"kind":"italic_en","text":"with a pointed extremity,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"used by binders of books,"},{"kind":"text","text":"(T, A, TA,)"},{"kind":"italic_en","text":"and by others."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["S","O","K","T","A","TA"]}]}}