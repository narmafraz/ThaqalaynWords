"verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n23945"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B5%D9%92%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23945","headword_ar":"اَصْدَرُ","root":"Sdr","body":[{"kind":"text","text":"A man (M)"},{"kind":"italic_en","text":"having a large breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest;"},{"kind":"text","text":"(M, K, TA;) i. e."},{"kind":"italic_en","text":"having the breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the upper part thereof, prominent;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muSad~arN","text_ar":"مُصَدَّرٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"AlA^aSodaraAni","text_ar":"الاَصْدَرَانِ"},{"kind":"italic_en","text":"Two veins"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"that beat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulse,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"beneath the temples:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"the two sides"},{"kind":"text","text":"of a man: or"},{"kind":"italic_en","text":"the two shoulder-joints:"},{"kind":"text","text":"(TA:) the word has no singular. (M.) [Hence the saying,]"},{"kind":"arabic","text_bw":"jaA='a yaDoribu A^aSodarayohi","text_ar":"جَا=ءَ يَضْرِبُ اَصْدَرَيْهِ"},{"kind":"text","text":"; (M, Meyd, K, TA;) and some say"},{"kind":"arabic","text_bw":"A^asodarayohi","text_ar":"اَسْدَرَيْهِ"},{"kind":"text","text":"[q. v.], (Meyd, TA,) and this is the original; (Meyd;) and some,"},{"kind":"arabic","text_bw":"A^azodarayohi","text_ar":"اَزْدَرَيْهِ"},{"kind":"text","text":"; (Meyd, TA;) a prov.; (M, Meyd, TA;) meaning"},{"kind":"italic_en","text":"He came beating"},{"kind":"text","text":"[with his hand]"},{"kind":"italic_en","text":"his two sides,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"his two shoulderjoints:"},{"kind":"text","text":"(Meyd, TA:) i. e."},{"kind":"italic_en","text":"he came empty"},{"kind":"text","text":"["},{"kind":"italic_en","text":"-handed"},{"kind":"text","text":"]; (M, Meyd, K, * TA;)"},{"kind":"italic_en","text":"not having accomplished the object of his desire:"},{"kind":"text","text":"(Meyd:) or"},{"kind":"italic_en","text":"he came exulting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaving insolently,"},{"kind":"text","text":"(Meyd, and Har p. 603,)"},{"kind":"italic_en","text":"not knowing where were his"},{"kind":"arabic","text_bw":"A^aSodaraAni","text_ar":"اَصْدَرَانِ"},{"kind":"text","text":": so accord. to Yoo: and some say,"},{"kind":"arabic","text_bw":"jaA='a baDoribu biA^aSodarayohi","text_ar":"جَا=ءَ بَضْرِبُ بِاَصْدَرَيْهِ"},{"kind":"text","text":". (Har.)"}],"source_refs":["M","K","TA","Meyd"]}]}}