":"verb","gloss":"to bend one's head forward"},{"pos":"verb","gloss":"to lower the flag"},{"pos":"noun","gloss":"verbal noun of نُكِسَ (nukisa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of نَكَسَ (nakasa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40538","headword_ar":"نِكْسٌ","root":"nks","body":[{"kind":"text","text":"An arrow"},{"kind":"italic_en","text":"having its notch broken, and its top therefore made its bottom:"},{"kind":"text","text":"(S, A, K:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^anokaAsN","text_ar":"اَنْكَاسٌ"},{"kind":"text","text":"(A, TA) and [of mult.]"},{"kind":"arabic","text_bw":"nukusN","text_ar":"نُكُسٌ"},{"kind":"text","text":". (A.) ―         -b2-  A head, or blade, of an arrow &c.,"},{"kind":"italic_en","text":"having its tongue"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sinox","text_ar":"سِنْخ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"broken, and its point therefore made its tongue:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"A^anokaAsN","text_ar":"اَنْكَاسٌ"},{"kind":"text","text":". (TA.) ―         -b3-  A bow"},{"kind":"italic_en","text":"of which the foot is made"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the head of the branch;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"manokuwsapN","text_ar":"مَنْكُوسَةٌ","orth_type":"arrow"},{"kind":"text","text":". This peculiarity is a fault. (K.) ―         -b4-  A child"},{"kind":"italic_en","text":"such as is termed"},{"kind":"arabic","text_bw":"yatonN","text_ar":"يَتْنٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"born preposterously, feet foremost;"},{"kind":"text","text":"but"},{"kind":"arabic","text_bw":"yatonN","text_ar":"يَتْنٌ"},{"kind":"text","text":"is an inf. n., and I have not found it used as an epithet anywhere but in this instance]; (K;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"manokuwsN","text_ar":"مَنْكُوسٌ"},{"kind":"text","text":"; and mentioned by IDrd; but he says that it is not of established authority. (TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"Low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble; base; vile; mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid:"},{"kind":"text","text":"See a verse cited voce"},{"kind":"arabic","text_bw":"A^a$~aEala","text_ar":"اَشَّعَلَ"},{"kind":"text","text":": (A:) (tropical:)  one"},{"kind":"italic_en","text":"who falls short of the utmost point of generosity;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"of courage and generosity:"},{"kind":"text","text":"(TA:) (assumed tropical:)"},{"kind":"italic_en","text":"weak;"},{"kind":"text","text":"(S, K;) applied to a man: (S:) (assumed tropical:)"},{"kind":"italic_en","text":"short:"},{"kind":"text","text":"(AHn:) pl."},{"kind":"arabic","text_bw":"A^anokaAsN","text_ar":"اَنْكَاسٌ"},{"kind":"text","text":". (A, K.) ―         -b6-  See also"},{"kind":"arabic","text_bw":"munak~isN","text_ar":"مُنَكِّسٌ"},{"kind":"text","text":": ―         -b7-  and"},{"kind":"arabic","text_bw":"nukusN","text_ar":"نُكُسٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","K","TA","AHn"]},{"entry_id":"n40539","headword_ar":"نُكَسٌ","root":"nks","body":[{"kind":"text","text":", [app. pl. of"},{"kind":"arabic","text_bw":"nikosN","text_ar":"نِكْسٌ"},{"kind":"text","text":",] (assumed tropical:)  Old men"},{"kind":"italic_en","text":"tottering by reason of age"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mudorahim~uwna","text_ar":"مُدْرَهِمُّونَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"after attaining to extreme old age."},{"kind":"text","text":"(K.)"}],"source_refs":[]}]},"classical_definitions":null}