{"lemma":"مُدَمّاةٌ","slug":"مُدَمّاةٌ","root":"د.م.#","root_slug":"د-م-_","root_link":"/words/roots/د-م-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n13173"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AF%D9%8E%D9%85%D9%91%D8%A7%D8%A9%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13173","headword_ar":"مُدَمًّى","root":"(dmw or dmY)","body":[{"kind":"italic_en","text":"Red;"},{"kind":"text","text":"applied to a garment, or piece of cloth: (M:) or anything"},{"kind":"italic_en","text":"in the colour of which is blackness and redness"},{"kind":"text","text":": (T:) ["},{"kind":"italic_en","text":"of a dark red colour, like blood"},{"kind":"text","text":":] or anything"},{"kind":"italic_en","text":"intensely red"},{"kind":"text","text":": (S:) applied in this last sense [particularly] to a horse &c.: (S, K:) or, applied to a horse,"},{"kind":"italic_en","text":"of a sorrel colour"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^a$oqaru","text_ar":"اَشْقَرُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"intensely red, like the colour of blood"},{"kind":"text","text":": (T:) or, so applied,"},{"kind":"italic_en","text":"of an intense sorrel colour"},{"kind":"text","text":": (M:) and"},{"kind":"arabic","text_bw":"kumayotN mudam~FY","text_ar":"كُمَيْتٌ مُدَمًّى"},{"kind":"italic_en","text":"of an intensely red bay colour"},{"kind":"text","text":": (S, TA:) or"},{"kind":"italic_en","text":"of an intense red colour like that of blood"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"intensely red in the back"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"as far as the thin and soft parts of the belly"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A^a$oqaru mudam~FY","text_ar":"اَشْقَرُ مُدَمًّى"},{"kind":"italic_en","text":"of which the sorrel colour is overspread, in its upper portion, with a yellowness like the colour of the yellow"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"gilded"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"bay"},{"kind":"text","text":": (A 'Obeyd, T:) and"},{"kind":"arabic","text_bw":"lawonN mudam~FY","text_ar":"لَوْنٌ مُدَمًّى"},{"kind":"italic_en","text":"a colour in which is blackness."},{"kind":"text","text":"(M.)"},{"kind":"arabic","text_bw":"sahomN mudam~FY","text_ar":"سَهْمٌ مُدَمًّى"},{"kind":"italic_en","text":"An arrow upon which is the redness of blood"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"that has adhered to it so that it inclines to blackness"},{"kind":"text","text":": a man, when he shot at the enemy with an arrow, and hit, and the enemy then shot it at him with blood upon it, used to put it in his quiver, auguring good from it: or, as some say, it means"},{"kind":"italic_en","text":"an arrow which the archers shoot by turns, one at another;"},{"kind":"text","text":"an explanation reducible to that before mentioned: (S:) or"},{"kind":"italic_en","text":"an arrow which one shoots at his enemy and the latter then shoots at the former:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"an arrow shot once."},{"kind":"text","text":"(T.)"}],"source_refs":["M","T","S","K","TA"]}]},"classical_definitions":null}