ry_ids":["n29560"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%B7%D9%8E%D8%B4%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29560","headword_ar":"اعطش","root":"ET$","body":[{"kind":"italic_en","text":"His camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cattle, thirsted."},{"kind":"text","text":"(T, S, M, O, K.)       -A2-"},{"kind":"arabic","text_bw":"AET$ fulaAnFA","text_ar":"اعطش فُلَانًا"},{"kind":"italic_en","text":"He made such a one to thirst."},{"kind":"text","text":"(O, * K, * TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AET$ AlA_ibila","text_ar":"اعطش الاـِبِلَ"},{"kind":"italic_en","text":"He increased the intervals between the two drinkings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waterings, of the camels, and withheld them from coming to the water,"},{"kind":"text","text":"(O, K,) or"},{"kind":"italic_en","text":"from the water on the day of their coming thereto:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"ET~$hA","text_ar":"عطّشها","orth_type":"arrow"},{"kind":"text","text":", [in like manner,]"},{"kind":"italic_en","text":"he increased their"},{"kind":"text","text":"thirsting: (A:) or the latter, of which the inf. n. is"},{"kind":"arabic","text_bw":"taEoTiy$N","text_ar":"تَعْطِيشٌ"},{"kind":"text","text":", has a more intensive signification than the former verb: (O, K, TA:) or it signifies"},{"kind":"italic_en","text":"he kept them thirsty;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"did not water them at all;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"watered them little, so that they were not satisfied:"},{"kind":"text","text":"(TA, voce"},{"kind":"arabic","text_bw":"vaA^ovaA^a","text_ar":"ثَاْثَاَ"},{"kind":"text","text":":) when a man has been accustomed to bring his camels to water on the third day, or the fourth, and waters them one day beyond that, you say"},{"kind":"arabic","text_bw":"A^aEoTa$ahaA","text_ar":"اَعْطَشَهَا"},{"kind":"text","text":". (TA.)"}],"source_refs":["O","K","TA","A"]}]},"classical_definitions":null}