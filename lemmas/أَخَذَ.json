{"lemma":"أَخَذَ","slug":"أَخَذَ","root":"#.خ.ذ","root_slug":"_-خ-ذ","root_link":"/words/roots/_-خ-ذ","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَخَذْتَ","in_corpus":true,"count":13,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَخَذْتِ","in_corpus":true,"count":76,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَخَذْتُما","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَخَذْتُم","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَخَذْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَخَذَ","in_corpus":true,"count":246,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَخَذَت","in_corpus":true,"count":76,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَخَذا","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَخَذَتا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَخَذُوا","in_corpus":true,"count":32,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَخَذْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَأْخُذ","in_corpus":true,"count":45,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَأْخُذِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَأْخُذِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَأْخُذانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَأْخُذا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَأْخُذُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَأْخُذُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَأْخُذْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَأْخُذ","in_corpus":true,"count":136,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَأْخُذ","in_corpus":true,"count":45,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَأْخُذانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَأْخُذا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْخُذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْخُذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْخُذُونَ","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْخُذُوا","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْخُذْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"imperative_2ms","form":"خُذْ","in_corpus":true,"count":38,"asp":"c","per":"2","gen":"m","num":"s"},{"role":"imperative_2fs","form":"خُذِي","in_corpus":true,"count":4,"asp":"c","per":"2","gen":"f","num":"s"},{"role":"imperative_2mp","form":"خُذُوا","in_corpus":true,"count":17,"asp":"c","per":"2","gen":"m","num":"p"},{"role":"present_1mp","form":"نَأْخُذ","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَخَذْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَخَذْتُ","in_corpus":true,"count":12,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"آخُذ","in_corpus":true,"count":351,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1157,"cross_references":{"qac":{"found":true,"lemma_key":"أَخَذَ","root":"أخذ","pos":"V","occurrence_count":127},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":22},"lanes":{"found":true,"entry_ids":["n346","n352","n353","n354","n355","n356","n357"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%8E%D8%B0%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take","examples":[{"text":"وَلَمَّا سَكَتَ عَنْ مُوسَى الْغَضَبُ أَخَذَ الأَلْوَاحَ[…]","english":"When Moses’ anger subsided, he took up the tablets..."}]},{"pos":"verb","gloss":"to take along"},{"pos":"verb","gloss":"to get, to receive, to obtain"},{"pos":"verb","gloss":"to seize, to grab, to take hold","examples":[{"text":"[…]وَأَخَذَ بِرَأْسِ أَخِيهِ يَجُرُّهُ إِلَيْهِ[…]","english":"And he (Moses) threw down the Tablets and seized his brother (Aaron) by [the hair of] his head, pulling him toward him."}]},{"pos":"verb","gloss":"to capture, to seize, to take captive","examples":[{"text":"فَإِذَا ٱنْسَلَخَ الْأَشْهُرُ الْحُرُمُ فَاقْتُلُوا الْمُشْرِكِينَ حَيْثُ وَجَدتُّمُوهُمْ وَخُذُوهُمْ وَاحْصُرُوهُمْ وَاقْعُدُوا لَهُمْ كُلَّ مَرْصَدٍ[…]","english":"But once the Sacred Months have passed, kill the polytheists ˹who violated their treaties and fought˺ wherever you find them, capture them, besiege them, and lie in wait for them on every way."}]},{"pos":"verb","gloss":"to perceive, to notice"},{"pos":"verb","gloss":"to gather, to understand, to infer, to deduce"},{"pos":"verb","gloss":"to grip, to captivate, to spellbind"},{"pos":"verb","gloss":"to keep, to observe, to adopt, to embrace, to follow","examples":[{"text":"أَخَذَ بِرَأْيِ صَدِيقِهِ","english":"He took his friend's advice."}]},{"pos":"verb","gloss":"to accept","examples":[{"text":"[…]قَالَ أَأَقْرَرْتُمْ وَأَخَذْتُمْ عَلَىٰ ذَٰلِكُمْ إِصْرِي قَالُوا أَقْرَرْنَا[…]","english":"[God] said, “Do you affirm and accept upon that My Burden (i.e. Allah’s Covenant)?” They [the prophets] said, “We affirm.”"}]},{"pos":"verb","gloss":"to admonish, to urge, to drive"},{"pos":"verb","gloss":"to enjoin, to impose"},{"pos":"verb","gloss":"to strip, to deprive, to cut off, to bar"},{"pos":"verb","gloss":"to reproach, to blame, to criticize","examples":[{"text":"أَخَذَ عَلَى الْمُؤَلِّفِ إِهْمَالَهُ المَصَادِرَ","english":"The author was reproached for his neglect of the sources."}]},{"pos":"verb","gloss":"to obligate"},{"pos":"verb","gloss":"to learn, to study"},{"pos":"verb","gloss":"to begin, to start, to prepare to, to set out to, to be about to, to get ready to (followed by a non-past verb)","examples":[{"text":"أَخَذْتُ أَبْكِي","english":"I began to cry"}]},{"pos":"noun","gloss":"verbal noun of أَخَذَ (ʔaḵaḏa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"acceptance, reception"},{"pos":"noun","gloss":"seizure"},{"pos":"noun","gloss":"taking away, removal"},{"pos":"verb","gloss":"to put under a spell, to enchant, to bewitch"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ʔaḫaḏ-. Cognate with Hebrew אָחַז (aḥáz), Aramaic ܐܚܕ (ʾeḥaḏ), Sabaean 𐩱𐩭𐩹 (ʾḵḏ)."},"ipa":["/ʔa.xa.ða/","/ʔaxð/","/ʔax.xa.ða/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n346","headword_ar":"اخَذَ","root":"Ax*","body":[{"kind":"text","text":", (S, A, L, &c.,) in the first pers. of which,"},{"kind":"arabic","text_bw":"A^axa*otu","text_ar":"اَخَذْتُ"},{"kind":"text","text":", [and the like,] the"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":"is generally changed into"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":", and incorporated into the [augmentative]"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":", [but in pronunciation only, for one writes"},{"kind":"arabic","text_bw":"A^axa*t~u","text_ar":"اَخَذتُّ"},{"kind":"text","text":"and the like,] aor."},{"kind":"text","text":", imperative"},{"kind":"arabic","text_bw":"xu*o","text_ar":"خُذْ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"A@w^oxu*o","text_ar":"ا@وْخُذْ"},{"kind":"text","text":", (S, L,) which latter form sometimes occurs, [but with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"w^o","text_ar":"وْ"},{"kind":"text","text":"when the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"is pronounced with damm,] (TA,) inf. n."},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":"(S, L, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"taA^oxaA*N","text_ar":"تَاْخَاذٌ"},{"kind":"text","text":", (S, L, K,) the latter having an intensive signification; (MF;) and"},{"kind":"arabic","text_bw":"waxa*a","text_ar":"وَخَذَ"},{"kind":"text","text":"is a dial. var., as mentioned by Ibn-Umm-Kásim and others on the authority of AHei; (MF in art."},{"kind":"arabic","text_bw":"tx*","text_ar":"تخذ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"He took; he took with his hand; he took hold of;"},{"kind":"text","text":"(S, A, L, Msb, K;) a thing. (S, L.) You say,"},{"kind":"arabic","text_bw":"xu*i AlxiTaAma","text_ar":"خُذِ الخِطَامَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xu*o biAlxiTaAma","text_ar":"خُذْ بِالخِطَامَ"},{"kind":"italic_en","text":"Take thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"take thou with thy hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"take thou hold of, the nose-rein"},{"kind":"text","text":"of the camel: (S, L, Msb:) the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"in the latter phrase being redundant. (Msb.) [And"},{"kind":"arabic","text_bw":"A^axa*a biyadihi","text_ar":"اَخَذَ بِيَدِهِ"},{"kind":"text","text":", lit."},{"kind":"italic_en","text":"He took his hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm;"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"he aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assisted, him:"},{"kind":"text","text":"a phrase of frequent occurrence.] And"},{"kind":"arabic","text_bw":"A^axa*a EalaYyadi fulaAnK","text_ar":"اَخَذَ عَلَىيَدِ فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He prevented, restrained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld, such a one from doing that which he desired; as though he laid hold upon his hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm:"},{"kind":"text","text":"(L:) and"},{"kind":"arabic","text_bw":"A^axa*a EalaY yadihi duwna maA yuriyudhu","text_ar":"اَخَذَ عَلَى يَدِهِ دُونَ مَا يُرِيُدهُ"},{"kind":"text","text":"[signifies the same]. (K in art."},{"kind":"arabic","text_bw":"lgd","text_ar":"لغد"},{"kind":"text","text":".) ―         -b2-  Also, inf. n."},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received; contr. of"},{"kind":"arabic","text_bw":"A^aEoTay","text_ar":"اَعْطَي"},{"kind":"text","text":". (L.) [Hence,]"},{"kind":"arabic","text_bw":"A^axa*a Eanohu","text_ar":"اَخَذَ عَنْهُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He received from him traditions,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(TA passim.) ―         -b3-  (assumed tropical:)  ["},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"derived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deduced,"},{"kind":"text","text":"a word, a phrase, and a meaning.] ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"He took, received,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admitted, willingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with approbation; he accepted."},{"kind":"text","text":"(B, MF.) So in the Kur [vii. 198],"},{"kind":"arabic","text_bw":"xu*i AlEafowa","text_ar":"خُذِ العَفْوَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Take thou willingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accept thou, superfluous property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as is easily spared"},{"kind":"text","text":"by others]. (MF.) So too in the same [iii. 75],"},{"kind":"arabic","text_bw":"wa A^axa*t~umo Ealay *`likumo A_iSoriY","text_ar":"وَ اَخَذتُّمْ عَلَي ذٰلِكُمْ اـِصْرِى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"And do ye accept my covenant to that effect?"},{"kind":"text","text":"]. (B.) [And in the phrases,"},{"kind":"arabic","text_bw":"A^axa*onaA miyvaAqakumo biAlEamali bimaA fiy Alt~awoAraApi","text_ar":"اَخَذْنَا مِيثَاقَكُمْ بِالعَمَلِ بِمَا فِي التَّوْارَاةِ"},{"kind":"text","text":", (Jel ii. 60,) and"},{"kind":"arabic","text_bw":"Ealay AlEam~li bmA fy AltwArp","text_ar":"عَلَي العَمّلِ بما في التوارة"},{"kind":"text","text":", (Idem ii. 87,) (assumed tropical:)"},{"kind":"italic_en","text":"We accepted your covenant to do according to what is in the Book of the Law revealed to Moses."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xu*o Eanoka","text_ar":"خُذْ عَنْكَ"},{"kind":"text","text":"[is elliptical, and] means"},{"kind":"arabic","text_bw":"xu*o maA A^aquwlu wadaE Eanoka Al$~aka wAlmirA='a","text_ar":"خُذْ مَا اَقُولُ وَدَع عَنْكَ الشَّكَ والمِرا=ءَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Accept thou what I say, and dismiss from thee doubt and obstinate disputation"},{"kind":"text","text":"]. (S, L.) ―         -b5-"},{"kind":"italic_en","text":"He took"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, himself; took possession of"},{"kind":"text","text":"it;"},{"kind":"italic_en","text":"got,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired,"},{"kind":"text","text":"it; syn."},{"kind":"arabic","text_bw":"HaAza","text_ar":"حَازَ"},{"kind":"text","text":"; (Z, Er-Rághib, B;) which, accord. to Z and Er-Rághib and others, is the primary signification; (MF;) and"},{"kind":"arabic","text_bw":"HaS~ala","text_ar":"حَصَّلَ"},{"kind":"text","text":". (B.) [See also 8.] ―         -b6-  ["},{"kind":"italic_en","text":"He took and kept;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he retained; he detained:"},{"kind":"text","text":"as in the Kur [xii. 78],"},{"kind":"arabic","text_bw":"faxu*o A^aHadanaA makaAnahu","text_ar":"فَخُذْ اَحَدَنَا مَكَانَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Therefore retain thou one of us in his stead"},{"kind":"text","text":"]. (B.) ―         -b7-  ["},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"he took away."},{"kind":"text","text":"Hence,]"},{"kind":"arabic","text_bw":"A^axa*a minohu Als~ayoru","text_ar":"اَخَذَ مِنْهُ السَّيْرُ"},{"kind":"italic_en","text":"Journeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travel, took from him strength;"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alquw~apa","text_ar":"القُوَّةَ"},{"kind":"text","text":"being understood;)"},{"kind":"italic_en","text":"weakened him."},{"kind":"text","text":"(Har p. 529.) And"},{"kind":"arabic","text_bw":"A^axa*a mina Al$~aAribi","text_ar":"اَخَذَ مِنَ الشَّارِبِ"},{"kind":"text","text":", (Mgh,) and"},{"kind":"arabic","text_bw":"mina Al$~aEari","text_ar":"مِنَ الشَّعَرِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He clipped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut off from,"},{"kind":"text","text":"(Mgh, Msb,)"},{"kind":"italic_en","text":"the mustache,"},{"kind":"text","text":"(Mgh,) and"},{"kind":"italic_en","text":"the hair."},{"kind":"text","text":"(Msb.) ―         -b8-"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, took by force;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seized:"},{"kind":"text","text":"(B:) (assumed tropical:)"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, overcame, overpowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"subdued:"},{"kind":"text","text":"said by some to be the primary signification. (MF.) [See also"},{"kind":"arabic","text_bw":"A^axa*ahu Ealow~aA","text_ar":"اَخَذَهُ عَلْوَّا"},{"kind":"text","text":", &c., in art."},{"kind":"arabic","text_bw":"Elw","text_ar":"علو"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A^axa*ahu mino fawoqu","text_ar":"اَخَذَهُ مِنْ فَوْقُ"},{"kind":"text","text":", &c., in art."},{"kind":"arabic","text_bw":"fwq","text_ar":"فوق"},{"kind":"text","text":".] It is said in the Kur [ii. 256],"},{"kind":"arabic","text_bw":"laA taA^oxu*uhu sinapi wa laA nawomN","text_ar":"لَا تَاْخُذُهُ سِنَةِ وَ لَا نَوْمٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Neither drowsiness nor sleep shall seize"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"overcome"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Him."},{"kind":"text","text":"(B.) [And you say,"},{"kind":"arabic","text_bw":"A^axa*atohu riEodapN","text_ar":"اَخَذَتْهُ رِعْدَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A tremour seized, took, affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"influenced, him."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"A^axa*ahu baTonuhu","text_ar":"اَخَذَهُ بَطْنُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His belly affected him with a desire to evacuate it."},{"kind":"text","text":"] You say also,"},{"kind":"arabic","text_bw":"A^axa*a fiyhi Al$~araAbu","text_ar":"اَخَذَ فِيهِ الشَّرَابُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wine affected him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"influenced him, so that he became intoxicated."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"vml","text_ar":"ثمل"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A^axa*a Alr~aA^osa","text_ar":"اَخَذَ الرَّاْسَ"},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"swr","text_ar":"سور"},{"kind":"text","text":", &c.) and"},{"kind":"arabic","text_bw":"A^axa*a biAlr~aA^osi","text_ar":"اَخَذَ بِالرَّاْسِ"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"HmY","text_ar":"حمى"},{"kind":"text","text":", &c.) (assumed tropical:)  ["},{"kind":"italic_en","text":"It had an overpowering influence upon the head"},{"kind":"text","text":"]; meaning wine. (Msb, K.) And"},{"kind":"arabic","text_bw":"A^axa*a biAlHaloqi","text_ar":"اَخَذَ بِالحَلْقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(food, &c.)"},{"kind":"italic_en","text":"choked"},{"kind":"text","text":"]. (IAar in art."},{"kind":"arabic","text_bw":"n$b","text_ar":"نشب"},{"kind":"text","text":"in the TA, and S in art."},{"kind":"arabic","text_bw":"b$E","text_ar":"بشع"},{"kind":"text","text":", &c.) And"},{"kind":"arabic","text_bw":"laA yaA^oxu*u fiyhi qawolu qaAy^ilK","text_ar":"لَا يَاْخُذُ فِيهِ قَوْلُ قَايِلٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Nothing that any one may say will have any power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"influence, upon him"},{"kind":"text","text":"]; meaning that he obeyeth no one. (L in art."},{"kind":"arabic","text_bw":"lyt","text_ar":"ليت"},{"kind":"text","text":".) ―         -b9-"},{"kind":"italic_en","text":"He took captive."},{"kind":"text","text":"(L, Msb, B.) So in the Kur [ix. 5],"},{"kind":"arabic","text_bw":"faA@qotuluwA A@lmu$orikiyna","text_ar":"فَا@قْتُلُوا ا@لمُشْرِكِينَ"},{"kind":"arabic","text_bw":"Hayovu wajadt~umuwhumo waxu*uwhumo","text_ar":"حَيْثُ وَجَدتُّمُوهُمْ وَخُذُوهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Then slay ye the believers in a plurality of gods wherever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whenever, ye find them, and take them captives"},{"kind":"text","text":"]. (Bd, L, B.) ―         -b10-  See also 2, in three places. ―         -b11-"},{"kind":"italic_en","text":"He gained the mastery over"},{"kind":"text","text":"a person,"},{"kind":"italic_en","text":"and killed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slew,"},{"kind":"text","text":"him; (Zj, L;) as also ↓"},{"kind":"arabic","text_bw":"A=xa*a","text_ar":"ا=خَذَ","orth_type":"arrow"},{"kind":"text","text":": (L:) or simply, (assumed tropical:)"},{"kind":"italic_en","text":"he killed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slew."},{"kind":"text","text":"(B.) It is said in the Kur [xl. 5],"},{"kind":"arabic","text_bw":"waham~ato k~ulu A^um~apK birasuwlihimo liyaA^oxu*uwhu","text_ar":"وَهَمَّتْ كُّلُ اُمَّةٍ بِرَسُولِهِمْ لِيَاْخُذُوهُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"And every nation hath purposed against their apostle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that they might gain the mastery over him, and slay him;"},{"kind":"text","text":"(Zj, L;) or (assumed tropical:)"},{"kind":"italic_en","text":"that they might slay him."},{"kind":"text","text":"(B.) ―         -b12-  (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God, Msb)"},{"kind":"italic_en","text":"destroyed"},{"kind":"text","text":"a person: (Msb, MF:) and (assumed tropical:)"},{"kind":"italic_en","text":"extirpated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exterminated."},{"kind":"text","text":"(MF.)"},{"kind":"arabic","text_bw":"faA^axa*ahumu A@ll~`hu bi*unuwbihimo","text_ar":"فَاَخَذَهُمُ ا@للّٰهُ بِذُنُوبِهِمْ"},{"kind":"text","text":"[in the Kur iii. 9 and xl. 22] means"},{"kind":"italic_en","text":"But God destroyed them for their sins."},{"kind":"text","text":"(Jel.) ―         -b13-  (tropical:)"},{"kind":"italic_en","text":"He punished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chastised;"},{"kind":"text","text":"(L, Msb, B, K, MF;) as also ↓"},{"kind":"arabic","text_bw":"A=xa*a","text_ar":"ا=خَذَ","orth_type":"arrow"},{"kind":"text","text":": (L, Msb, MF:) as in the phrases,"},{"kind":"arabic","text_bw":"A^axa*ahu bi*anobihi","text_ar":"اَخَذَهُ بِذَنْبِهِ"},{"kind":"page_break","n":29},{"kind":"text","text":"(Msb, K *) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A=xa*ahu","text_ar":"ا=خَذَهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n. of the latter"},{"kind":"arabic","text_bw":"muw^aAxa*apN","text_ar":"مُوَاخَذَةٌ"},{"kind":"text","text":", (S, L, Msb, K,) (tropical:)"},{"kind":"italic_en","text":"he punished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chastised, him for his sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"A^uxi*a bi*anobihi","text_ar":"اُخِذَ بِذَنْبِهِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"he was restrained and requited and punished for his sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence:"},{"kind":"text","text":"(L:) or, accord. to some,"},{"kind":"arabic","text_bw":"A^axa*a","text_ar":"اَخَذَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he extirpated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exterminated;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A=x*","text_ar":"ا=خذ","orth_type":"arrow"},{"kind":"italic_en","text":"he punished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chastised, without extirpating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exterminating."},{"kind":"text","text":"(MF.) [For ↓"},{"kind":"arabic","text_bw":"A=x*","text_ar":"ا=خذ","orth_type":"arrow"},{"kind":"text","text":",] some say"},{"kind":"arabic","text_bw":"waAxa*a","text_ar":"وَاخَذَ"},{"kind":"text","text":", (S, L,) which is not allowable, (K,) accord. to some; but accord. to others, it is a chaste form; (MF;) of the dial. of El-Yemen, and used by certain of the seven readers [of the Kur-án] in the instance of"},{"kind":"arabic","text_bw":"laA yuwaAxi*ukumu A@ll~`hu","text_ar":"لَا يُوَاخِذُكُمُ ا@للّٰهُ"},{"kind":"text","text":"[ii. 225 and v. 91]; and the inf. N. in that dial. Is"},{"kind":"arabic","text_bw":"muwaAxa*apN","text_ar":"مُوَاخَذَةٌ"},{"kind":"text","text":", and the imperative is"},{"kind":"arabic","text_bw":"waAxi*o","text_ar":"وَاخِذْ"},{"kind":"text","text":". (Msb.) ―         -b14-  (tropical:)"},{"kind":"italic_en","text":"He made a violent assault upon"},{"kind":"text","text":"a person,"},{"kind":"italic_en","text":"and wounded"},{"kind":"text","text":"him"},{"kind":"italic_en","text":"much."},{"kind":"text","text":"(K, TA.) [You say also,"},{"kind":"arabic","text_bw":"A^axa*ahu bilisaAnihi","text_ar":"اَخَذَهُ بِلِسَانِهِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He assailed him with his tongue; vituperated him; spoke against him."},{"kind":"text","text":"] ―         -b15-  ["},{"kind":"italic_en","text":"He took, took to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adopted."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"A^axa*a A^axa*ahumo","text_ar":"اَخَذَ اَخَذَهُمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ixo*ahumo","text_ar":"اـِخْذَهُمْ"},{"kind":"text","text":"&c.: see"},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":", below. And"},{"kind":"arabic","text_bw":"A^axa*a fiY Tariyqi ka*aA","text_ar":"اَخَذَ فِى طَرِيقِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took such a road"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"A^axa*a Eano yamiynihi A^awo yasaArihi","text_ar":"اَخَذَ عَنْ يَمِينِهِ اَوْ يَسَارِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he took the way by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on, the right of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, or the left of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"nZr","text_ar":"نظر"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"A^axa*a biAlHazomi","text_ar":"اَخَذَ بِالحَزْمِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiy AlHazomi","text_ar":"فِي الحَزْمِ"},{"kind":"text","text":", (the former the more common, the latter occurring in art."},{"kind":"arabic","text_bw":"HwT","text_ar":"حوط"},{"kind":"text","text":"in the K,) (assumed tropical:)"},{"kind":"italic_en","text":"He took the course prescribed by prudence, discretion, precaution,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good judgment; he used precaution:"},{"kind":"text","text":"and, like"},{"kind":"arabic","text_bw":"A^axa*a biAlv~iqahi","text_ar":"اَخَذَ بِالثِّقَهِ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"he took the sure course"},{"kind":"text","text":"in his affair.] And"},{"kind":"arabic","text_bw":"A^axa*a Hi*orahu","text_ar":"اَخَذَ حِذْرَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He took care; became cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant."},{"kind":"text","text":"(Bd in iv. 73 and 103.) [And"},{"kind":"arabic","text_bw":"A^axa*a","text_ar":"اَخَذَ"},{"kind":"arabic","text_bw":"bimaA qaAla fulaAnN","text_ar":"بِمَا قَالَ فُلَانٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He took to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adopted and followed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adhered to, what such a one said:"},{"kind":"text","text":"see Har p. 367; where it is said that"},{"kind":"arabic","text_bw":"Ax*","text_ar":"اخذ"},{"kind":"text","text":"when thus used is made trans. by means of"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"because it implies the meaning of"},{"kind":"arabic","text_bw":"ta$ab~ava","text_ar":"تَشَبَّثَ"},{"kind":"text","text":".] ―         -b16-"},{"kind":"italic_en","text":"He took to, set about, began,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced;"},{"kind":"text","text":"as in the saying,"},{"kind":"arabic","text_bw":"A^axa*a yafoEalu","text_ar":"اَخَذَ يَفْعَلُ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"italic_en","text":"He took to, set about, began,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, doing such a thing;"},{"kind":"text","text":"in which case, accord. to Sb,"},{"kind":"arabic","text_bw":"Ax*","text_ar":"اخذ"},{"kind":"text","text":"is one of those verbs which do not admit of one's putting the act. part. n. in the place of the verb which is its enunciative: [i. e., one may not say"},{"kind":"arabic","text_bw":"faAEilFA","text_ar":"فَاعِلًا"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"yfEl","text_ar":"يفعل"},{"kind":"text","text":"in the phrase above:] and as in"},{"kind":"arabic","text_bw":"A^axa*a fiY ka*aA","text_ar":"اَخَذَ فِى كَذَا"},{"kind":"italic_en","text":"He began, commenced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon, such a thing."},{"kind":"text","text":"(L.) ―         -b17-  [It is used in a variety of other phrases, in which the primary meaning is more or less apparent; and several of these will be found explained with other words occurring therein. The following instances may be here added.] ―         -b18-"},{"kind":"arabic","text_bw":"TariyqN yaA^oxu*u fiY ramolapK","text_ar":"طَرِيقٌ يَاْخُذُ فِى رَمْلَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A road leading into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"through, a tract of sand"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"frz","text_ar":"فرز"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A^axa*a bihimu AlT~ariyqu fiY gayori AlmaHaj~api","text_ar":"اَخَذَ بِهِمُ الطَّرِيقُ فِى غَيْرِ المَحَجَّةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The road lead them otherwise than in the beaten track"},{"kind":"text","text":"]. (T * and A in art."},{"kind":"arabic","text_bw":"bhrj","text_ar":"بهرج"},{"kind":"text","text":".) ―         -b19-"},{"kind":"arabic","text_bw":"maA A^axa*atoka","text_ar":"مَا اَخَذَتْكَ"},{"kind":"arabic","text_bw":"EayoniY muno*u HiynK","text_ar":"عَيْنِى مُنْذُ حِينٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"My eye hath not seen thee for some time;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"maAZafiratoka","text_ar":"مَاظَفِرَتْكَ"},{"kind":"text","text":". (T in art."},{"kind":"arabic","text_bw":"Zfr","text_ar":"ظفر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"maA fiy AlHaY~i A^aHadN taA^oxu*uhu Eayoniy","text_ar":"مَا فِي الحَىِّ اَحَدٌ تَاْخُذُهُ عَيْنِي"},{"kind":"text","text":"[explained to me by Ibr D as meaning (assumed tropical:)"},{"kind":"italic_en","text":"There is not in the tribe any one whom my eye regards as worthy of notice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respect"},{"kind":"text","text":"by reason of his greatness therein]. (TA in art."},{"kind":"arabic","text_bw":"jhr","text_ar":"جهر"},{"kind":"text","text":".) ―         -b20-"},{"kind":"arabic","text_bw":"A^axa*otu Einodahu yadaY","text_ar":"اَخَذْتُ عِنْدَهُ يَدَى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maEorwfAF","text_ar":"مَعْروفاً"},{"kind":"text","text":": see 8.       -A2-"},{"kind":"arabic","text_bw":"A^axi*a","text_ar":"اَخِذَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^axa*N","text_ar":"اَخَذٌ"},{"kind":"text","text":", (S, L, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a young camel)"},{"kind":"italic_en","text":"suffered heaviness of the stomach, and indigestion, from the milk:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"became disordered in his belly, and affected with heaviness of the stomach, and indigestion, from taking much milk."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel, L, K, or a sheep or goat, L)"},{"kind":"italic_en","text":"became affected by madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demoniacal possession;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"by what resembled that."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"A^axi*ato Eayonuhu","text_ar":"اَخِذَتْ عَيْنُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^axa*N","text_ar":"اَخَذٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"His eye became affected by inflammation, pain, and swelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ophthalmia."},{"kind":"text","text":"(Ibn-Es-Seed, L, K. *)       -A3-"},{"kind":"arabic","text_bw":"A^axu*a","text_ar":"اَخُذَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^uxuw*apN","text_ar":"اُخُوذَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(milk)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sour."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"A=xi*N","text_ar":"ا=خِذٌ"},{"kind":"text","text":".]"}],"source_refs":["S","L","TA","K","Msb","Mgh","B","God","MF"]},{"entry_id":"n352","headword_ar":"اَخْذٌ","root":"Ax*","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"A^axa*a","text_ar":"اَخَذَ"},{"kind":"text","text":", q. v. ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"A way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of life;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A_ixo*N","text_ar":"اـِخْذٌ","orth_type":"arrow"},{"kind":"text","text":". (S, L, K.) You say,"},{"kind":"arabic","text_bw":"*ahaba banuw fulaAnK wamano A^axa*a A^axo*ahumo","text_ar":"ذَهَبَ بَنُو فُلَانٍ وَمَنْ اَخَذَ اَخْذَهُمْ"},{"kind":"text","text":", (S, L, K, *) and ↓"},{"kind":"arabic","text_bw":"A_ixo*ahumo","text_ar":"اـِخْذَهُمْ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) the former of the dial. of Temeem, and the latter of the dial. of El-Hijáz, (TA,) meaning (assumed tropical:)"},{"kind":"italic_en","text":"The sons of such a one went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed away, and those who took to their way of life,"},{"kind":"text","text":"(S, L, K,)"},{"kind":"italic_en","text":"and adopted their manners,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispositions:"},{"kind":"text","text":"(K:) and"},{"kind":"arabic","text_bw":"mano A^axa*a A^axo*uhumo","text_ar":"مَنْ اَخَذَ اَخْذُهُمْ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_ixo*uhumo","text_ar":"اـِخْذُهُمْ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mano A^axa*a A^axo*uhumo","text_ar":"مَنْ اَخَذَ اَخْذُهُمْ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Aaxo*uhumo","text_ar":"اَخْذُهُمْ"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"A_ixo*uhumo","text_ar":"اـِخْذُهُمْ","orth_type":"arrow"},{"kind":"text","text":", signify [virtually] the same: (K:) or"},{"kind":"arabic","text_bw":"mano A^axa*ahu A^axo*uhumo","text_ar":"مَنْ اَخَذَهُ اَخْذُهُمْ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_ixo*uhumo","text_ar":"اـِخْذُهُمْ","orth_type":"arrow"},{"kind":"text","text":"signify [properly]"},{"kind":"arabic","text_bw":"mano A^axa*ahu A^axo*uhumo wasiyratuhumo","text_ar":"مَنْ اَخَذَهُ اَخْذُهُمْ وَسِيرَتُهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"those whom their way of life took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"influenced"},{"kind":"text","text":"]. (ISk, S L.) One says also,"},{"kind":"arabic","text_bw":"A@sotuEomila fulaAnN Eala Al$~aAmi","text_ar":"ا@سْتُعْمِلَ فُلَانٌ عَلَ الشَّامِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wamaA A^axa*a A_ixo*ahu","text_ar":"وَمَا اَخَذَ اـِخْذَهُ","orth_type":"arrow"},{"kind":"text","text":", with kesr, meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"Such a one was appointed prefect over Syria,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and he did not take to that good way of life which it was incumbent on him to adopt:"},{"kind":"text","text":"you should not say"},{"kind":"arabic","text_bw":"A^axo*ahu","text_ar":"اَخْذَهُ"},{"kind":"text","text":": (AA, S, L:) or it means"},{"kind":"italic_en","text":"and what was adjacent to it:"},{"kind":"text","text":"(Fr, L:) or, accord. to the Wá'ee, one says, in this case, ↓"},{"kind":"arabic","text_bw":"wamaA A^axa*a A_ixo*ahu","text_ar":"وَمَا اَخَذَ اـِخْذَهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^axo*uhu","text_ar":"اَخْذُهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^uxo*uhu","text_ar":"اُخْذُهُ","orth_type":"arrow"},{"kind":"text","text":", with kesr and fet-h and damm [to the hemzeh, and with the"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":"marfooah, as in instances before]. (Et-Tedmuree, MF.) One also says, ↓"},{"kind":"arabic","text_bw":"lawo kunota min~aA laA^axa*t~a biA_xo*inaA","text_ar":"لَوْ كُنْتَ مِنَّا لَاَخَذتَّ بِاـخْذِنَا","orth_type":"arrow"},{"kind":"text","text":", (S, L,) with kesr to the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", (L,) [in a copy of the S"},{"kind":"arabic","text_bw":"biA^axo*inaA","text_ar":"بِاَخْذِنَا"},{"kind":"text","text":", which seems to be also allowable, accord. to the dial. of Temeem,] meaning"},{"kind":"italic_en","text":"Wert thou of us, then thou hadst taken to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wouldst take to, our manners,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispositions, and fashion,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"and garb, and way of life."},{"kind":"text","text":"(L.) The words of the poet,"},{"kind":"quote","text":"falawo kunotumo mun~aA A^axa*onaA biA_ixo*ikumo"},{"kind":"text","text":"IAar explains as meaning"},{"kind":"italic_en","text":"And were ye of us, we had caught and restored to you your camels:"},{"kind":"text","text":"but no other says so. (L.) ―         -b3-"},{"kind":"arabic","text_bw":"nujuwmu AlA^axo*i","text_ar":"نُجُومُ الاَخْذِ"},{"kind":"italic_en","text":"The Mansions of the Moon;"},{"kind":"text","text":"(S, L, K;) also called"},{"kind":"arabic","text_bw":"nujuwmu","text_ar":"نُجُومُ"},{"kind":"arabic","text_bw":"AlA^anowaA='N","text_ar":"الاَنْوَا=ءٌ"},{"kind":"text","text":"; (L; [see art."},{"kind":"arabic","text_bw":"nw'","text_ar":"نوء"},{"kind":"text","text":";]) called by the former appellation because the moon every night enters ("},{"kind":"arabic","text_bw":"yaA^oxu*u fiY","text_ar":"يَاْخُذُ فِى"},{"kind":"text","text":") one of those mansions: (S, L:) or"},{"kind":"italic_en","text":"the stars which are cast at those"},{"kind":"text","text":"["},{"kind":"italic_en","text":"devils"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who listen by stealth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the conversations of the angels"},{"kind":"text","text":"]: (L, K:) but the former explanation is the more correct. (L.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"A_ixaA*o","text_ar":"اـِخَاذْ"},{"kind":"text","text":"."}],"source_refs":["L","K","TA","S","AA","Fr"]},{"entry_id":"n353","headword_ar":"اُخْذٌ","root":"Ax*","body":[{"kind":"text","text":", whence"},{"kind":"arabic","text_bw":"maA A^axa*a A^uxo*uhu","text_ar":"مَا اَخَذَ اُخْذُهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":". ―         -b2-  It is also a pl. of"},{"kind":"arabic","text_bw":"A_ixaA*N","text_ar":"اـِخَاذٌ"},{"kind":"text","text":"; (S, L;) and of"},{"kind":"arabic","text_bw":"A_ixo*N","text_ar":"اـِخْذٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A_ixo*apN","text_ar":"اـِخْذَةٌ"},{"kind":"text","text":", explained below with"},{"kind":"arabic","text_bw":"A_ixaA*N","text_ar":"اـِخَاذٌ"},{"kind":"text","text":". (L.)"}],"source_refs":[]},{"entry_id":"n354","headword_ar":"اـِخْذٌ","root":"Ax*","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"act of taking, taking with the hand,"},{"kind":"text","text":"&c.], a subst. from"},{"kind":"arabic","text_bw":"A^axa*a","text_ar":"اَخَذَ"},{"kind":"text","text":". (S, L, Msb.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"A^axo*N","text_ar":"اَخْذٌ"},{"kind":"text","text":", in nine places. ―         -b3-  And see"},{"kind":"arabic","text_bw":"A_ixaA*N","text_ar":"اـِخَاذٌ"},{"kind":"text","text":". ―         -b4-  Also"},{"kind":"italic_en","text":"A mark made with a hot iron upon a camel's side when a disease therein is feared."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n355","headword_ar":"اَخَذٌ","root":"Ax*","body":[{"kind":"italic_en","text":"Heaviness of the stomach, and indigestion,"},{"kind":"text","text":"of a young camel,"},{"kind":"italic_en","text":"from the milk."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"A^axi*a","text_ar":"اَخِذَ"},{"kind":"text","text":".] ―         -b2-  See also"},{"kind":"arabic","text_bw":"A^uxu*N","text_ar":"اُخُذٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n356","headword_ar":"اَخِذٌ","root":"Ax*","body":[{"kind":"text","text":"A young camel"},{"kind":"italic_en","text":"disordered in his belly, and affected with heaviness of the stomach, and indigestion, from taking much milk."},{"kind":"text","text":"(AZ, Fr, L.) [See also"},{"kind":"arabic","text_bw":"SaboHaAnu","text_ar":"صَبْحَانُ"},{"kind":"text","text":".] ―         -b2-  A camel, or a young camel, or a sheep or goat,"},{"kind":"italic_en","text":"affected by what resembles madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demoniacal possession."},{"kind":"text","text":"(L.) ―         -b3-  A man"},{"kind":"italic_en","text":"affected with inflammation of the eye; with pain and swelling of the eye; with ophthalmia;"},{"kind":"text","text":"(S, L;) as also ↓"},{"kind":"arabic","text_bw":"musotaA^oxi*N","text_ar":"مُسْتَاْخِذٌ","orth_type":"arrow"},{"kind":"text","text":". (L.) See also this latter. ―         -b4-  See also"},{"kind":"arabic","text_bw":"A=xi*N","text_ar":"ا=خِذٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n357","headword_ar":"اُخُذٌ","root":"Ax*","body":[{"kind":"text","text":"(S, L, K) and ↓"},{"kind":"arabic","text_bw":"A^axa*N","text_ar":"اَخَذٌ","orth_type":"arrow"},{"kind":"text","text":", (Ibn-Es-Seed, L, K,) which latter is the regular form, (L,)"},{"kind":"italic_en","text":"Inflammation of the eye; pain and swelling of the eye; ophthalmia."},{"kind":"text","text":"(S, L, K.)"}],"source_refs":["S","L","K"]}]}}