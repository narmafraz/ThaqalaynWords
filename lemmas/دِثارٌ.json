xt":"]"},{"kind":"italic_en","text":"people are the vulgar."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"$iEaArN","text_ar":"شِعَارٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"A^abuw divaArK","text_ar":"اَبُو دِثَارٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bayotu A^abiY divaArK","text_ar":"بَيْتُ اَبِى دِثَارٍ"},{"kind":"italic_en","text":"The thin curtain"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"kil~ap","text_ar":"كِلَّة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by which one protects himself from gnats,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"musquitoes; the musquito-curtain:"},{"kind":"text","text":"[see an ex. in the first paragraph of art."},{"kind":"arabic","text_bw":"bED","text_ar":"بعض"},{"kind":"text","text":":], or"},{"kind":"arabic","text_bw":"Abw dvAr","text_ar":"ابو دثار"},{"kind":"text","text":"is an appellation of"},{"kind":"italic_en","text":"the gnat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"musquito;"},{"kind":"text","text":"because it is concealed in the daytime; or because a"},{"kind":"arabic","text_bw":"dvAr","text_ar":"دثار"},{"kind":"text","text":"is wanted to protect one from its annoyance. (TA.)"}],"source_refs":["Mgh","Msb","S","M","A","K","T","TA"]}]},"classical_definitions":null}