","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُصَوَّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصَوِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُصَوَّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صَوَّرْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَوَّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصَوِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصَوِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصَوَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصَوَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صُوِّرْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صُوِّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":true,"lemma_key":"صَوَّرَ","root":"صور","pos":"N","occurrence_count":10},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["name","noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n25169","n25174","n25175","n25176"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%88%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to form, to create"},{"pos":"verb","gloss":"to paint, to draw"},{"pos":"verb","gloss":"to illustrate"},{"pos":"verb","gloss":"to depict"},{"pos":"verb","gloss":"to represent"},{"pos":"verb","gloss":"to photograph"},{"pos":"noun","gloss":"plural of صُورَة (ṣūra)","tags":["form-of","plural"]},{"pos":"noun","gloss":"horn (instrument used to signal others)","examples":[{"text":"وَنُفِخَ فِي الصُّورِ فَصَعِقَ مَنْ فِي السَّمَاوَاتِ وَمَنْ فِي الْأَرْضِ إِلَّا مَنْ شَاءَ اللّٰهُ ثُمَّ نُفِخَ فِيهِ أُخْرَى فَإِذَا هُمْ قِيَامٌ يَنْظُرُونَ","english":"And the trumpet is blown, and all who are in the heavens and all who are in the earth swoon away, save him whom Allah willeth. Then it is blown a second time, and behold them standing waiting!"}]},{"pos":"name","gloss":"Tyre (a city in Lebanon)"},{"pos":"noun","gloss":"small palm-tree","tags":["obsolete"]},{"pos":"noun","gloss":"what is plucked from the palm-tree sitting in the ground, the root of a palm-tree, a palm-trunk","tags":["obsolete"]},{"pos":"noun","gloss":"bank of a river, riverside","tags":["obsolete"]},{"pos":"noun","gloss":"side of the neck","tags":["obsolete"]},{"pos":"noun","gloss":"forelock","tags":["obsolete"]}]},"etymology":{"source":"wiktextract","text":"Denominal verb from صُورَة (ṣūra, “form, image”).\n\nSeemingly a literary corruption of Hebrew שׁוֹפָּר (šōp̄ārā), hence doublet of شَبُّور (šabbūr).\n\nFrom Phoenician 𐤑𐤓 (ṣr /⁠ṣūr⁠/, “rock”).\n\nBorrowed from Aramaic צוּרָא (ṣūrā), variant of צַרְיָא (ṣaryā), צַארְא (ṣarā, “palm-band”), from Akkadian 𒍝𒊒𒌋 (ṣa-ru-ú /⁠ṣarû⁠/, “a part of the date-palm”).\n\nResultative to يَصُورُ (yaṣūru, “to bend towards a shape”)."},"ipa":["/sˤu.war/","/sˤuːr/","/sˤi.war/","/sˤawr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25169","headword_ar":"صوّر","root":"Swr","body":[{"kind":"text","text":"[inf. n."},{"kind":"arabic","text_bw":"taSowiyrN","text_ar":"تَصْوِيرٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He formed, fashioned, figured, shaped, sculptured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pictured,"},{"kind":"text","text":"him, or it; (S, M, K;) and ↓"},{"kind":"arabic","text_bw":"tSw~r","text_ar":"تصوّر","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (Msb, and Bd in iii. 4;) and so does ↓"},{"kind":"arabic","text_bw":"SAr","text_ar":"صار","orth_type":"arrow"},{"kind":"text","text":", accord. to Aboo-'Alec, in the saying,"},{"kind":"quote","text":"banaAhu waSal~aba fiyhi waSaAraA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Which"},{"kind":"text","text":"(referring to a church)"},{"kind":"italic_en","text":"he has built, and in which he has made a cross,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crosses, and has made sculptured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"painted, work"},{"kind":"text","text":"]. (M.) One says,"},{"kind":"arabic","text_bw":"Saw~arahu A@ll~`hu SuwrapF HasanapF","text_ar":"صَوَّرَهُ ا@للّٰهُ صُورَةً حَسَنَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God formed him a goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful, form"},{"kind":"text","text":"]. (S.) ―         -b2-  See also 5, in two places."}],"source_refs":[]},{"entry_id":"n25174","headword_ar":"صَوْرٌ","root":"Swr","body":[{"kind":"italic_en","text":"Small palm-trees:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"a collection of small palm-trees:"},{"kind":"text","text":"(S, M, K:) a word having no proper sing.: (S, M:) [but see"},{"kind":"arabic","text_bw":"SaworapN","text_ar":"صَوْرَةٌ"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"SiyraAnN","text_ar":"صِيرَانٌ"},{"kind":"text","text":": (Sh, M, K:) and"},{"kind":"italic_en","text":"other trees:"},{"kind":"text","text":"pl. as above. (Sh, TA.) ―         -b2-  Also The"},{"kind":"italic_en","text":"root"},{"kind":"text","text":"of a palmtree, (M, K,) or of a palm-trunk. (M.) ―         -b3-  And The"},{"kind":"italic_en","text":"bank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"side,"},{"kind":"text","text":"of a river or rivulet. (M, K.) ―         -b4-  And The"},{"kind":"italic_en","text":"side of the neck."},{"kind":"text","text":"(O, * K, * TA. [In the CK,"},{"kind":"arabic","text_bw":"wAll~iyti","text_ar":"واللِّيتِ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"waAll~iytu","text_ar":"وَاللِّيتُ"},{"kind":"text","text":".]) ―         -b5-  And The"},{"kind":"italic_en","text":"forelock:"},{"kind":"text","text":"so in the saying of a rájiz,"},{"kind":"quote","text":"kaA^an~a EurofFA maAy^ilFA mino Saworihi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"As though a mane inclining from his forelock"},{"kind":"text","text":"]. (S.)"}],"source_refs":["M","K","S","Sh"]},{"entry_id":"n25175","headword_ar":"صُورٌ","root":"Swr","body":[{"kind":"italic_en","text":"A horn:"},{"kind":"text","text":"(S, M:) and"},{"kind":"italic_en","text":"a horn in which one blows:"},{"kind":"text","text":"(S, M, K:) so in the Kur [vi. 73, &c.],"},{"kind":"arabic","text_bw":"yawoma yunofaxu fiY A@lS~uwri","text_ar":"يَوْمَ يُنْفَخُ فِى ا@لصُّورِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"On the day when the horn shall be blown in"},{"kind":"text","text":"]: El-Kelbee says, I know not what is"},{"kind":"arabic","text_bw":"AlSwr","text_ar":"الصور"},{"kind":"text","text":": and it is said to be pl. of"},{"kind":"arabic","text_bw":"SuwrapN","text_ar":"صُورَةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"busorN","text_ar":"بُسْرٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"busorapN","text_ar":"بُسْرَةٌ"},{"kind":"text","text":"; [or rather a coll. gen. n., of which"},{"kind":"arabic","text_bw":"SuwrapN","text_ar":"صُورَةٌ"},{"kind":"text","text":"is the n. un.;] i. e., [the phrase means]"},{"kind":"italic_en","text":"when"},{"kind":"text","text":"the souls"},{"kind":"italic_en","text":"shall be blown into the forms"},{"kind":"text","text":"of the dead: and El-Hasan read"},{"kind":"arabic","text_bw":"fiY AlS~uwari","text_ar":"فِى الصُّوَرِ"},{"kind":"text","text":": (S, L, TA:) this is related on the authority of AO; but AHeyth asserts him to have said wrong. (L, TA.)"}],"source_refs":["S","M","K","L","TA"]},{"entry_id":"n25176","headword_ar":"صَوَرٌ","root":"Swr","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"Sawira","text_ar":"صَوِرَ"},{"kind":"text","text":"[q. v.]. (M, A.) ―         -b2-  Also"},{"kind":"italic_en","text":"An itching"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^ukaAlN","text_ar":"اُكَالٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the head."},{"kind":"text","text":"(IAar, TA.) [See also"},{"kind":"arabic","text_bw":"SaworapN","text_ar":"صَوْرَةٌ"},{"kind":"text","text":".]"}],"source_refs":[]}]}}