{"lemma":"تَرَبُّص","slug":"تَرَبُّص","root":"ر.ب.ص","root_slug":"ر-ب-ص","root_link":"/words/roots/ر-ب-ص","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"تَرَبُّص","root":"ربص","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14481"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D9%8E%D8%A8%D9%8F%D9%91%D8%B5"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be ambuscade, lurk, waylay, ambush, lay"}]},"etymology":null,"ipa":["/ta.rab.ba.sˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14481","headword_ar":"تربّص","root":"rbS","body":[{"kind":"italic_en","text":"He expected;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"awaited:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"he tarried;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tarried expecting."},{"kind":"text","text":"(IAth.) You say"},{"kind":"arabic","text_bw":"trb~S AlA^amora","text_ar":"تربّص الاَمْرَ"},{"kind":"italic_en","text":"He looked for, expected, awaited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited for, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"trb~S bihi Al$~aYo'a","text_ar":"تربّص بِهِ الشَّىْءَ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He looked for, expected, awaited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited for, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, to befall him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betide him."},{"kind":"text","text":"(M, Msb.) It is said in the Kur [ix. 52],"},{"kind":"arabic","text_bw":"halo tarab~aSuwna binaA A_il~aA","text_ar":"هَلْ تَرَبَّصُونَ بِنَا اـِلَّا"},{"kind":"arabic","text_bw":"A_iHodaY A@loHusonayayoni","text_ar":"اـِحْدَى ا@لْحُسْنَيَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Do ye look for,"},{"kind":"text","text":"&c., aught"},{"kind":"italic_en","text":"save one of the two best things"},{"kind":"text","text":"(namely victory or martyrdom)"},{"kind":"italic_en","text":"to betide us?"},{"kind":"text","text":"]. (M.) And a poet says,"},{"kind":"quote","text":"tarab~aSo bihaA rayoba Almanuwni laEal~ahaA\n                      \n                     \n                        tuTal~aqu yawomFA A^awo yamuwtu HaliyluhaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Wait thou for the vicissitudes of fortune to befall her: perhaps she may be divorced some day,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"her husband may die"},{"kind":"text","text":"]. (TA.) You say also,"},{"kind":"arabic","text_bw":"trb~S bisiloEatihi AlgalaA='a","text_ar":"تربّص بِسِلْعَتِهِ الغَلَا=ءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He looked for,"},{"kind":"text","text":"&c., a time of"},{"kind":"italic_en","text":"dearness for his commodity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"article of merchandise"},{"kind":"text","text":"]. (A.) And, [elliptically,)"},{"kind":"arabic","text_bw":"trb~S","text_ar":"تربّص"},{"kind":"arabic","text_bw":"bifulaAnK","text_ar":"بِفُلَانٍ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"biAl$~aYo'i","text_ar":"بِالشَّىْءِ"},{"kind":"text","text":"; (M;) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rabaSa","text_ar":"رَبَصَ","orth_type":"arrow"},{"kind":"text","text":", (M, A, K,) aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"raboSN","text_ar":"رَبْصٌ"},{"kind":"text","text":"; (M, A, K;)"},{"kind":"italic_en","text":"He looked for, expected, awaited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited for,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"something"},{"kind":"text","text":"] good or evil"},{"kind":"italic_en","text":"to befall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betide,"},{"kind":"text","text":"(M, A, K,)"},{"kind":"italic_en","text":"such a one,"},{"kind":"text","text":"(A, K,) or"},{"kind":"italic_en","text":"the thing:"},{"kind":"text","text":"(M:) or"},{"kind":"arabic","text_bw":"trb~F biAl$~aYo'a","text_ar":"تربًّ بِالشَّىْءَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he looked for, expected, awaited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited for, a day for the thing."},{"kind":"text","text":"(Lth.)"}],"source_refs":["S","M","Msb","K","A","TK"]}]}}