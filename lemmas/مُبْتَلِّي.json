used in like manner as a pl. ; i. e., the"},{"kind":"page_break","n":151},{"kind":"text","text":"first is also used as a pl.: (S:) or the first signifies"},{"kind":"italic_en","text":"solitary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"isolated:"},{"kind":"text","text":"(Ibn-Habeeb, TA:) or"},{"kind":"italic_en","text":"of which the racemes are pendulous."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"batiyylN","text_ar":"بَتِييلٌ"},{"kind":"text","text":".])"}],"source_refs":["As","T","S","M"]},{"entry_id":"n1738","headword_ar":"مُبَتَّلٌ","root":"btl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"batyilN","text_ar":"بَتيِلٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"mubat~alapN","text_ar":"مُبَتَّلَةٌ"},{"kind":"text","text":", applied to a woman,"},{"kind":"italic_en","text":"Beautiful, elegant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pretty;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"as though her beauty were divided into portions"},{"kind":"text","text":"(↓"},{"kind":"arabic","text_bw":"but~ila","text_ar":"بُتِّلَ","orth_type":"arrow"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"quT~iEa","text_ar":"قُطِّعَ"},{"kind":"text","text":",) ["},{"kind":"italic_en","text":"and distributed in due proportions"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon her limbs:"},{"kind":"text","text":"(M, * K:) or"},{"kind":"italic_en","text":"perfect in make,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"whose flesh is not accumulated, one portion upon another,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"but distinctly disposed;"},{"kind":"text","text":"this latter being said by some to be the meaning: (M:) or, accord. to Lh, (M, TA,)"},{"kind":"italic_en","text":"having a lankness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looseness, in her limbs;"},{"kind":"text","text":"(M, K, TA;)"},{"kind":"italic_en","text":"not having them compressed, one upon another;"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"as though the flesh were cut off from them:"},{"kind":"text","text":"(TA:) and in like manner,"},{"kind":"arabic","text_bw":"mubat~alN","text_ar":"مُبَتَّلٌ"},{"kind":"text","text":"applied to a camel: (M, K:) not applied as an epithet to a man: (S, M, K:) or"},{"kind":"arabic","text_bw":"mubat~alapu Alxaloqi","text_ar":"مُبَتَّلَةُ الخَلْقِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"distinct in make from the generality of women; excelling them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therein"},{"kind":"text","text":"]: (Aboo-Sa'eed, T, TA:) or"},{"kind":"italic_en","text":"perfect in make:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having every part beautiful in itself; not dependent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for its beauty"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon another part:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"beautiful in make; not with one part falling short of another"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in beauty"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"not being beautiful in the eye and ugly in the nose, nor beautiful in the nose and ugly in the eye; but perfect."},{"kind":"text","text":"(IAar, TA.)"}],"source_refs":["S","M","K","TA","T"]}]},"classical_definitions":null}