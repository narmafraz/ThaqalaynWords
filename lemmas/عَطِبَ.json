"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be damaged, to be ruined, to perish"},{"pos":"verb","gloss":"to damage, to ruin, to spoil"},{"pos":"noun","gloss":"verbal noun of عَطِبَ (ʕaṭiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"damage, injury, harm, injustice"},{"pos":"noun","gloss":"cotton","tags":["Classical","collective"]}]},"etymology":null,"ipa":["/ʕa.tˤi.ba/","/ʕatˤ.tˤa.ba/","/ʕa.tˤab/","/ʕutˤb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29514","headword_ar":"عَطِبَ","root":"ETb","body":[{"kind":"text","text":", (S, A, Mgh, O, Msb, K,) aor."},{"kind":"text","text":", (A, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EaTabN","text_ar":"عَطَبٌ"},{"kind":"text","text":", (S, * Mgh, * O, * Msb,) and"},{"kind":"arabic","text_bw":"maEoTabN","text_ar":"مَعْطَبٌ"},{"kind":"text","text":"also may be an inf. n. of the same, (Har p. 196,)"},{"kind":"italic_en","text":"He perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S, A, Mgh, O, Msb, K:) [Freytag mentions"},{"kind":"arabic","text_bw":"EaTaba","text_ar":"عَطَبَ"},{"kind":"text","text":"also in the same sense, as from the K, in which I do not find it:] it is said of a man, and of other than man: in a trad. it is said of seed-produce. (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel, and a horse,)"},{"kind":"italic_en","text":"flagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became powerless:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"stopped with his master"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rider"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from fatigue."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EaTiba Ealayohi","text_ar":"عَطِبَ عَلَيْهِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, violently,"},{"kind":"text","text":"(O,) or"},{"kind":"italic_en","text":"most violently,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"angry with him."},{"kind":"text","text":"(O, K.)       -A2-"},{"kind":"arabic","text_bw":"AlEaTobu","text_ar":"العَطْبُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"liynu AlquToni","text_ar":"لِينُ القُطْنِ"},{"kind":"text","text":"(O, * K) and"},{"kind":"arabic","text_bw":"AlS~uwfi","text_ar":"الصُّوفِ"},{"kind":"text","text":", (O,) and"},{"kind":"arabic","text_bw":"nuEuwmatuhu","text_ar":"نُعُومَتُهُ"},{"kind":"text","text":": (K:) you say,"},{"kind":"arabic","text_bw":"EaTaba","text_ar":"عَطَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (A, O, K,) inf. n."},{"kind":"arabic","text_bw":"EaTobN","text_ar":"عَطْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuTuwbN","text_ar":"عُطُوبٌ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[i. e. cotton, and wool,]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft."},{"kind":"text","text":"(A, O, * K. [See also"},{"kind":"arabic","text_bw":"EuTobN","text_ar":"عُطْبٌ"},{"kind":"text","text":", below.])"}],"source_refs":["S","A","Mgh","O","Msb","K","TA"]}]},"classical_definitions":null}