tance:"},{"kind":"text","text":"(M, K:) and this ↓ same word, when the object is God, signifies"},{"kind":"italic_en","text":"aid of God's servants;"},{"kind":"text","text":"&c.; as explained above: see 1. (El-Basáïr.) ―         -b2-"},{"kind":"italic_en","text":"Spoil; plunder; booty."},{"kind":"text","text":"(Bd, ubi supra.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"Rain;"},{"kind":"text","text":"(A, TA;) as also ↓"},{"kind":"arabic","text_bw":"nuSorapN","text_ar":"نُصْرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) in like manner as it is called"},{"kind":"arabic","text_bw":"fatoH","text_ar":"فَتْح"},{"kind":"text","text":": (A, TA:) or the ↓ latter signifies"},{"kind":"italic_en","text":"a complete rain."},{"kind":"text","text":"(IAar.) ―         -b4-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"A gift:"},{"kind":"text","text":"(S, TA:) and"},{"kind":"arabic","text_bw":"naSaAy^iru","text_ar":"نَصَايِرُ"},{"kind":"italic_en","text":"gifts."},{"kind":"text","text":"(M.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"naASirN","text_ar":"نَاصِرٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","M","K","TA","A"]},{"entry_id":"n39916","headword_ar":"نُصَرٌ","root":"nSr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"naASirN","text_ar":"نَاصِرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}