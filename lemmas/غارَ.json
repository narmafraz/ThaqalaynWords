{"lemma":"غارَ","slug":"غارَ","root":"غ.#.ر","root_slug":"غ-_-ر","root_link":"/words/roots/غ-_-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"غُرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"غُرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"غُرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"غُرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"غُرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"غارَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"غارَت","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"غارا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"غارَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"غارُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"غُرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَغُر","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَغُور","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَغُورِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَغُورِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَغُورا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَغُورانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَغُورُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَغُورُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَغُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَغُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَغُور","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَغُر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَغُور","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَغُورا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَغُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَغُورا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَغُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَغُورُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَغُورُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَغُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"غُرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غُرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغُور","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَغُور","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"غار","root":"غور","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n31596","n32605","n32610"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be jealous","tags":["intransitive"],"examples":[{"text":"إِذَا وَجَدْتُمُ السَّعَادَةَ، قَدْ يَغَارُ مِنْكُمُ النَّاسُ.","english":"If you find happiness, people may be jealous."},{"text":"وَحَسَدُ النِّسَاءِ بَعْضِهِنَّ لِبَعْضٍ كَثِيرٌ غَالِبٌ لَا سِيَّمَا الْمُتَزَوِّجَاتُ بِزَوْجٍ وَاحِدٍ فَإِنَّ الْمَرْأَةَ تَغَارُ عَلَى زَوْجِهَا لِحَظِّهَا مِنْهُ فَإِنَّهُ بِسَبَبِ الْمُشَارَكَةِ يَفُوتُ بَعْضُ حَظِّهَا.","english":"Envy among women is preponderant, especially when married to the same man. This is because the woman becomes jealous of her husband because of her share of him, and so when he is split, she misses some of her [original] share."}]},{"pos":"verb","gloss":"to feel discontent or bitterness [with مِنْ (min) ‘at’]; to be envious of, to envy; to resent","tags":["intransitive"]},{"pos":"verb","gloss":"to be watchful or protective [with عَلَى (ʕalā) ‘of’] [with مِن (min) ‘from’]; to keep, to guard","tags":["intransitive"]},{"pos":"verb","gloss":"to display zeal or vie","tags":["intransitive"]},{"pos":"verb","gloss":"to enter, to penetrate deeply","tags":["intransitive"]},{"pos":"verb","gloss":"to sink in, to become depressed (of the eyes)","tags":["intransitive"]},{"pos":"verb","gloss":"to seep away, to trickle away, to ooze away, to peter out (of water)","tags":["intransitive"]},{"pos":"noun","gloss":"cavern","tags":["intransitive"]},{"pos":"noun","gloss":"palate","tags":["intransitive"]},{"pos":"noun","gloss":"bay laurel (Laurus nobilis); laurel (Laurus gen.)","tags":["collective","intransitive"]}]},"etymology":{"source":"wiktextract","text":"If it is true that the bay laurel has dispersed over the Mediterranean regions from further west, be it Asia Minor or even Western Europe, then the Arabic plant name غَار (ḡār) has been borrowed in the earlier 1st millennium BC or before from Aramaic עָרָא / ܥܳܪܳܐ (ʿārā), also Hebrew עָר (ʿār), of the same meaning, the merger of /ʁ/ and /ʕ/ not having happened in Northwest Semitic yet—if not old enough to be ascribed to Proto-West Semitic unity."},"ipa":["/ɣaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31596","headword_ar":"غَارٌّ","root":"gr","body":[{"kind":"italic_en","text":"Deceiving; beguiling; causing to desire what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false; a deceiver."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"guruwrN","text_ar":"غُرُورٌ"},{"kind":"text","text":".       -A2-  And"},{"kind":"italic_en","text":"Negligent; inattentive; inadvertent; inconsiderate; heedless; unprepared."},{"kind":"text","text":"(S, K.) See also"},{"kind":"arabic","text_bw":"gir~N","text_ar":"غِرٌّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n32605","headword_ar":"غَارَ","root":"gwr","body":[{"kind":"text","text":", (As, Fr, IAar, S, Msb, &c.,) aor."},{"kind":"arabic","text_bw":"yaguwru","text_ar":"يَغُورُ"},{"kind":"text","text":", (S, &c.,) inf. n."},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"guw^uwrN","text_ar":"غُوُورٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار","orth_type":"arrow"},{"kind":"text","text":", (Fr, Msb,) inf. n."},{"kind":"arabic","text_bw":"A_igaArapN","text_ar":"اـِغَارَةٌ"},{"kind":"text","text":"; (K;) but IAth says that this form of the verb is of rare occurrence, (TA,) and As disallows it; (S, Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"gw~r","text_ar":"غوّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tagowiyrN","text_ar":"تَغْوِيرٌ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"tgw~r","text_ar":"تغوّر","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"He came to the"},{"kind":"arabic","text_bw":"gawor","text_ar":"غَوْر"},{"kind":"text","text":", (As, Fr, IAar, S, Msb, K,) i. e.,"},{"kind":"italic_en","text":"low land"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"(Msb,) [or the"},{"kind":"italic_en","text":"region so called, in Arabia:"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he journeyed in the region of the"},{"kind":"arabic","text_bw":"gwr","text_ar":"غور"},{"kind":"text","text":": (As, TA:) or"},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"he took his way towards the"},{"kind":"arabic","text_bw":"gawor","text_ar":"غَوْر"},{"kind":"text","text":". (TA.) There is a difference of opinion respecting the saying of El-Aashà,"},{"kind":"quote","text":"nabiY~N yaraY maA laA tarawona wa*ikoruhu\n                      \n                     \n                        laEamoriY fiY AlbilaAdi waA^anojadaA ↓ \n      A^agaAra"},{"kind":"text","text":"[meaning, accord. to the first explanation of"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار"},{"kind":"text","text":","},{"kind":"italic_en","text":"A prophet who seeth what ye see not, and whose fame has come to the low lands, by my life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by my religion, in the"},{"kind":"text","text":"several"},{"kind":"italic_en","text":"regions, and has come to the high lands"},{"kind":"text","text":"]: As says that"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"has gone quickly;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Anjd","text_ar":"انجد"},{"kind":"text","text":","},{"kind":"italic_en","text":"has risen;"},{"kind":"text","text":"and that the poet does not mean"},{"kind":"italic_en","text":"has come to the low lands"},{"kind":"text","text":"nor"},{"kind":"italic_en","text":"to the high lands;"},{"kind":"text","text":"holding"},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"only to signify the coming to the low land: but Fr asserts that"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار"},{"kind":"text","text":"is a dial. var. of"},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"; and cites this verse as authority: and some say"},{"kind":"arabic","text_bw":"AgAr wAnjd","text_ar":"اغار وانجد"},{"kind":"text","text":", but when they do not conjoin the two verbs they say"},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"; like as they say"},{"kind":"arabic","text_bw":"hanaA^aniY AlT~aEaAmu wamaraA^aniY","text_ar":"هَنَاَنِى الطَّعَامُ وَمَرَاَنِى"},{"kind":"text","text":", but when they do not conjoin these two verbs they say"},{"kind":"arabic","text_bw":"A^amoraA^aniY","text_ar":"اَمْرَاَنِى"},{"kind":"text","text":": (S:) As also mentions another relation of the second hemistich, commencing"},{"kind":"arabic","text_bw":"AgAm","text_ar":"اغام"},{"kind":"text","text":"[app. a mistake for"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"text","text":"or some other word]: (IKtt:) and there is another relation, accord. to which the second hemistich is"},{"kind":"arabic","text_bw":"maxoruwm","text_ar":"مَخْرُوم"},{"kind":"text","text":", commencing with"},{"kind":"arabic","text_bw":"gaAra","text_ar":"غَارَ"},{"kind":"text","text":". (L.) You say also"},{"kind":"arabic","text_bw":"gaAra waA^anojada","text_ar":"غَارَ وَاَنْجَدَ"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"He became famous in the low countries and the high."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"njd","text_ar":"نجد"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"gAr fiY $aYo'K","text_ar":"غار فِى شَىْءٍ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"guw^uwrN","text_ar":"غُوُورٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"giyaArN","text_ar":"غِيَارٌ"},{"kind":"text","text":", (Sb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, entered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"entered deeply"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"into a thing."},{"kind":"text","text":"(K.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"gAr fiY A^amorK","text_ar":"غار فِى اَمْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He examined minutely"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"deeply"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"into an affair;"},{"kind":"text","text":"(IKtt, Msb;) as also ↓"},{"kind":"arabic","text_bw":"AgAr","text_ar":"اغار","orth_type":"arrow"},{"kind":"text","text":". (IKtt.) You say"},{"kind":"arabic","text_bw":"fulaAnN biEiydu Algawori","text_ar":"فُلَانٌ بِعِيدُ الغَوْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one is a deep examiner:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"acquainted"},{"kind":"text","text":"["},{"kind":"italic_en","text":"deeply"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with affairs:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very rancorous, malevolent, malicious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spiteful."},{"kind":"text","text":"(Msb.) [See also"},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":", below.] ―         -b4-"},{"kind":"arabic","text_bw":"gAr AlmaA='u","text_ar":"غار المَا=ءُ"},{"kind":"text","text":", (Lh, S, Msb, K,)"},{"kind":"arabic","text_bw":"fiY AlA^aroDi","text_ar":"فِى الاَرْضِ"},{"kind":"text","text":"(K,) inf. n."},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":"(Lh, S, K, &c.) and"},{"kind":"arabic","text_bw":"guw^uwrN","text_ar":"غُوُورٌ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"gw~r","text_ar":"غوّر","orth_type":"arrow"},{"kind":"text","text":", (Lh, TA,) inf. n."},{"kind":"arabic","text_bw":"tagowiyrN","text_ar":"تَغْوِيرٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"The water sank,"},{"kind":"text","text":"(S, IKtt,) or"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"into the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"went away into the sources,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"springs."},{"kind":"text","text":"(Lh.) ―         -b5-"},{"kind":"arabic","text_bw":"gaArati","text_ar":"غَارَتِ"},{"kind":"page_break","n":2307},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"arabic","text_bw":"taguwru","text_ar":"تَغُورُ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"giyaArN","text_ar":"غِيَارٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"guw^uwrN","text_ar":"غُوُورٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"gw~rt","text_ar":"غوّرت","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"The sun set:"},{"kind":"text","text":"(S, K:) and in like manner one says ["},{"kind":"arabic","text_bw":"gAr","text_ar":"غار"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gw~r","text_ar":"غوّر","orth_type":"arrow"},{"kind":"text","text":"] of the moon and of a star. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"gaArato","text_ar":"غَارَتْ"},{"kind":"arabic","text_bw":"Eayonuhu","text_ar":"عَيْنُهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taguwru","text_ar":"تَغُورُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"guw^uwrN","text_ar":"غُوُورٌ"},{"kind":"text","text":"; (S, Msb, TA;) and"},{"kind":"arabic","text_bw":"gaArato","text_ar":"غَارَتْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tagaAru","text_ar":"تَغَارُ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"gw~rt","text_ar":"غوّرت","orth_type":"arrow"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"His eye sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became depressed,"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"entered,"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the head;"},{"kind":"text","text":"(S, TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ainoxasafato","text_ar":"اِنْخَسَفَتْ"},{"kind":"text","text":". (Msb.) ―         -b7-"},{"kind":"arabic","text_bw":"gAr Aln~ahaAru","text_ar":"غار النَّهَارُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The day became intensely hot"},{"kind":"text","text":"[app., like"},{"kind":"arabic","text_bw":"gaw~ara","text_ar":"غَوَّرَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"when the sun had declined from the meridian"},{"kind":"text","text":"]: (K:) hence"},{"kind":"arabic","text_bw":"AlgaAy^irapu","text_ar":"الغَايِرَةُ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b8-  See also 2.       -A2-"},{"kind":"arabic","text_bw":"gaAra $ayoy^FA","text_ar":"غَارَ شَيْيًا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaguwru","text_ar":"يَغُورُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He sought for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, a thing."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"gaArahumo","text_ar":"غَارَهُمْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"gaAra lahumo","text_ar":"غَارَ لَهُمْ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yaguwru","text_ar":"يَغُورُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"giyaArN","text_ar":"غِيَارٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"bestowed upon them"},{"kind":"arabic","text_bw":"giyrap","text_ar":"غِيرَة"},{"kind":"text","text":", (K,) i. e."},{"kind":"arabic","text_bw":"miyrap","text_ar":"مِيرَة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a provision of corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wheat,"},{"kind":"text","text":"&c.]. (TA.) [See also art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"He benefited them;"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":", and TA;) and so"},{"kind":"arabic","text_bw":"gaArahumo bixayorK","text_ar":"غَارَهُمْ بِخَيْرٍ"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"gaArahumo","text_ar":"غَارَهُمْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaguwru","text_ar":"يَغُورُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"giyaArN","text_ar":"غِيَارٌ"},{"kind":"text","text":"; (TA;) or"},{"kind":"arabic","text_bw":"gaArahumo bixayorK","text_ar":"غَارَهُمْ بِخَيْرٍ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"bestowed upon them abundance of the produce of the earth, and rain:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"arabic","text_bw":"gaArahumo birizoqK","text_ar":"غَارَهُمْ بِرِزْقٍ"},{"kind":"italic_en","text":"He bestowed upon them means of subsistence."},{"kind":"text","text":"(TA.) You say also"},{"kind":"arabic","text_bw":"Aall~`hum~a guronaA bigayovK","text_ar":"اَللّٰهُمَّ غُرْنَا بِغَيْثٍ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"bimaTarK","text_ar":"بِمَطَرٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bixayorK","text_ar":"بِخَيْرٍ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"guronaA minoka bigayovK","text_ar":"غُرْنَا مِنْكَ بِغَيْثٍ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"O God, aid us,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour us, with rain"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"from Thee,"},{"kind":"text","text":"(S,) and"},{"kind":"italic_en","text":"with prosperity."},{"kind":"text","text":"(TA.) [See also art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":".]       -A4-"},{"kind":"arabic","text_bw":"gaAra Alr~ajula","text_ar":"غَارَ الرَّجُلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaguwruhu","text_ar":"يَغُورُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yagiyruhu","text_ar":"يَغِيرُهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He gave the man the bloodwit"},{"kind":"text","text":"[which is termed"},{"kind":"arabic","text_bw":"giwarN","text_ar":"غِوَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"giyarN","text_ar":"غِيَرٌ"},{"kind":"text","text":"]: (ISk, TA:) and so"},{"kind":"arabic","text_bw":"gay~arahu","text_ar":"غَيَّرَهُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":".)       -A5-"},{"kind":"arabic","text_bw":"gaAra EalaY A^aholihi","text_ar":"غَارَ عَلَى اَهْلِهِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagaAru","text_ar":"يَغَارُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"giyrapN","text_ar":"غِيرَةٌ"},{"kind":"text","text":"[or rather"},{"kind":"arabic","text_bw":"gayorapN","text_ar":"غَيْرَةٌ"},{"kind":"text","text":"(see art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":")] and"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He was jealous of his wife."},{"kind":"text","text":"] (IKtt.)"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gayorapN","text_ar":"غَيْرَةٌ"},{"kind":"text","text":", (S, so in my two copies,) or"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"giyrapN","text_ar":"غِيرَةٌ"},{"kind":"text","text":", with kesr, (K,) signify the same. (S, K.) You say"},{"kind":"arabic","text_bw":"fulaAnN $adiydu AlgaAri EalaY","text_ar":"فُلَانٌ شَدِيدُ الغَارِ عَلَى"},{"kind":"arabic","text_bw":"A^aholihi","text_ar":"اَهْلِهِ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"Algyrp","text_ar":"الغيرة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is vehemently jealous of his wife"},{"kind":"text","text":"]. (TA.) See also art."},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":"."}],"source_refs":["S","K","Fr","Msb","TA","As","IAar","IKtt","Sb","Lh","God","ISk"]},{"entry_id":"n32610","headword_ar":"غَارٌ","root":"gwr","body":[{"kind":"italic_en","text":"A cave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavern;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kahofN","text_ar":"كَهْفٌ"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"in a mountain;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"magaArapN","text_ar":"مَغَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"magaArN","text_ar":"مَغَارٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"mugaArapN","text_ar":"مُغَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mugaArN","text_ar":"مُغَارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ","orth_type":"arrow"},{"kind":"text","text":": (K: [but"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":"in this sense is omitted in the CK:]) or"},{"kind":"italic_en","text":"what resembles a"},{"kind":"arabic","text_bw":"khf","text_ar":"كهف"},{"kind":"italic_en","text":"in a mountain,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"only differing in being less large,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like a"},{"kind":"arabic","text_bw":"sarab","text_ar":"سَرَب"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"what is hewn out in a mountain, resembling a"},{"kind":"arabic","text_bw":"magaArap","text_ar":"مَغَارَة"},{"kind":"text","text":": when it is large, or spacious, it is called"},{"kind":"arabic","text_bw":"khf","text_ar":"كهف"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"what resembles a house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chamber, in a mountain:"},{"kind":"text","text":"(Lh, K:) or"},{"kind":"italic_en","text":"a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, place in a mountain:"},{"kind":"text","text":"(Th, K:) or"},{"kind":"italic_en","text":"any low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, land, country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground:"},{"kind":"text","text":"(K:) see also"},{"kind":"arabic","text_bw":"gaworN","text_ar":"غَوْرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"xaworN","text_ar":"خَوْرٌ"},{"kind":"text","text":"]: or the"},{"kind":"italic_en","text":"hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burrow, to which a wild animal betakes itself:"},{"kind":"text","text":"(K: [see an instance in art."},{"kind":"arabic","text_bw":"smw","text_ar":"سمو"},{"kind":"text","text":", conj. 8:]) and sometimes ↓"},{"kind":"arabic","text_bw":"magaArN","text_ar":"مَغَارٌ","orth_type":"arrow"},{"kind":"text","text":"is applied to the"},{"kind":"italic_en","text":"coverts of gazelles, among trees:"},{"kind":"text","text":"(S:) the dim. of"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"guwayorN","text_ar":"غُوَيْرٌ"},{"kind":"text","text":": (S, K:) [of which see two exs. (a prov. and a verse) voce"},{"kind":"arabic","text_bw":"buw^osN","text_ar":"بُوْسٌ"},{"kind":"text","text":":] and the pl. (of pauc., TA)"},{"kind":"arabic","text_bw":"A^agowaArN","text_ar":"اَغْوَارٌ"},{"kind":"text","text":"(IJ, K) and (of mult., TA)"},{"kind":"arabic","text_bw":"giyraAnN","text_ar":"غِيرَانٌ"},{"kind":"text","text":". (S, Msb, K.) ―         -b2-  Also The"},{"kind":"italic_en","text":"portion of the upper part of the mouth which is behind the"},{"kind":"arabic","text_bw":"faraA$ap","text_ar":"فَرَاشَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"thin bone"},{"kind":"text","text":"of the palate]: or the"},{"kind":"italic_en","text":"hollow"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^uxoduwd","text_ar":"اُخْدُود"},{"kind":"text","text":")"},{"kind":"italic_en","text":"which is between the two jaws:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"interior of the mouth:"},{"kind":"text","text":"(K: [for"},{"kind":"arabic","text_bw":"daAxila Alfami","text_ar":"دَاخِلَ الفَمِ"},{"kind":"text","text":", in the CK, I read"},{"kind":"arabic","text_bw":"daAxilu Alfm","text_ar":"دَاخِلُ الفم"},{"kind":"text","text":", as in the TA:]) or, as some say, the"},{"kind":"italic_en","text":"two parts whereof each is called"},{"kind":"arabic","text_bw":"niToEN","text_ar":"نِطْعٌ"},{"kind":"text","text":", [app. meaning the"},{"kind":"italic_en","text":"anterior part of the palate and"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"corresponding"},{"kind":"page_break","n":2308},{"kind":"italic_en","text":"part next the lower gums,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"HanakaAni","text_ar":"حَنَكَانِ"},{"kind":"text","text":"[or the"},{"kind":"italic_en","text":"palate and"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"part corresponding to it below"},{"kind":"text","text":"]. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlgaAraAni","text_ar":"الغَارَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sockets of the eyes;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"two bones in which are the eyes."},{"kind":"text","text":"(ISd, K.) ―         -b4-  And"},{"kind":"italic_en","text":"The belly and the pudendum:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"the mouth and the pudendum."},{"kind":"text","text":"(K.) Hence the saying of a poet,"},{"kind":"arabic","text_bw":"yasoEaY ligaArayohi","text_ar":"يَسْعَى لِغَارَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He works,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earns, for his belly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mouth, and his pudendum"},{"kind":"text","text":"]. (S, TA.)       -A2-  Also ("},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"An army:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"a numerous army."},{"kind":"text","text":"(TA.) You say"},{"kind":"arabic","text_bw":"AilotaqaY AlgaAraAni","text_ar":"اِلْتَقَى الغَارَانِ"},{"kind":"italic_en","text":"The two armies met."},{"kind":"text","text":"(S.) ―         -b2-  And"},{"kind":"italic_en","text":"A company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body, of men:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a numerous company"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of men."},{"kind":"text","text":"(ISd, K.)       -A3-  And"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"gayorapN","text_ar":"غَيْرَةٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"giyrapN","text_ar":"غِيرَةٌ"},{"kind":"text","text":". (K.) [See 1, last signification.]       -A4-  And"},{"kind":"italic_en","text":"A kind of tree,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"of large size,"},{"kind":"text","text":"(Mgh, K,)"},{"kind":"italic_en","text":"having leaves longer than those of the"},{"kind":"arabic","text_bw":"xilaAf","text_ar":"خِلَاف"},{"kind":"text","text":", (Mgh, TA,)"},{"kind":"italic_en","text":"and a fruit"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"berry"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"smaller than the hazel-nut, which is black, and which, being divested of its covering, discloses a heart that is employed in medicine"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that is designed to produce a narcotic or an intoxicating effect: the berries are called"},{"kind":"arabic","text_bw":"Hab~u AlgaAri","text_ar":"حَبُّ الغَارِ"},{"kind":"text","text":"]:"},{"kind":"italic_en","text":"its leaves have a sweet odour,"},{"kind":"text","text":"(Mgh, TA,)"},{"kind":"italic_en","text":"and are employed in perfume:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"its fruit is called"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in Persian"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"dahomasot","text_ar":"دَهْمَسْت"},{"kind":"text","text":": (Mgh, TA:)"},{"kind":"italic_en","text":"and it has an oil,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"which is called"},{"kind":"arabic","text_bw":"duhonu AlgaAri","text_ar":"دُهْنُ الغَارِ"},{"kind":"text","text":": (S:) [it is the"},{"kind":"italic_en","text":"bay-tree;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"female laurel-tree;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"laurus nobilis;"},{"kind":"text","text":"also called the"},{"kind":"italic_en","text":"sweet bay;"},{"kind":"text","text":"of which there are several sorts, as the broad-leaved bay, the narrow-leaved bay, &c.: it is commonly supposed to be the laurus of the ancients:] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (TA.) ―         -b2-  And The"},{"kind":"italic_en","text":"leaves of the grapevine."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","TA","Msb","Lh","Th","IJ","Mgh"]}]},"classical_definitions":null}