sp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤَمَّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَمَّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤَمَّرُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَمَّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَمِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَمِّرُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤَمَّرْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُؤَمِّرْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَمَّرْنا","in_corpus":true,"count":46,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَمَّرْتُ","in_corpus":true,"count":46,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَمَّر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَمَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَمِّر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَمِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":873,"cross_references":{"qac":{"found":true,"lemma_key":"أَمَّرَ","root":"أمر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n1212","n1213","n1214","n1215","n1224","n1225","n38384"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"lamb","tags":["obsolete"]},{"pos":"adj","gloss":"simple-minded, stupid","tags":["obsolete"]},{"pos":"adj","gloss":"afflictive, grave, abominable","tags":["obsolete"],"examples":[{"text":"لَقَدْ جِئْتَ شَيْئًا إِمْرًا","english":"You have done a grave thing!"}]}]},"etymology":{"source":"wiktextract","text":"From Aramaic אִימְּרָא / אִמְּרָא (ʾimmərā) / ܐܶܡܪܳܐ (ʾemmərā, “lamb”), absolute state אִימַּר / אִמַּר (ʾimmar) / ܐܶܡܱܪ (ʾemmar), from Akkadian 𒇻 (immerum, “sheep”). Note also an Aramaic diminutive having been borrowed as Arabic عَمْرُوسَة (ʕamrūsa, “small lamb”), and the transferred semantics being mirrored in Old Armenian յիմար (yimar, “foolish”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1212","headword_ar":"اَمْرٌ","root":"Amr","body":[{"kind":"italic_en","text":"A command; an order; a bidding; an injunction; a decree; an ordinance; a prescript:"},{"kind":"text","text":"(S, * Msb, * TA, &c.:) pl."},{"kind":"arabic","text_bw":"A^awaAmiru","text_ar":"اَوَامِرُ"},{"kind":"text","text":": (S, Msb, &c.:) so accord. to common usage; and some writers of authority justify and explain it by saying that"},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":"is [originally]"},{"kind":"arabic","text_bw":"maA^omuwurN bihi","text_ar":"مَاْمُوُرٌ بِهِ"},{"kind":"text","text":"; that it is then changed to the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":"; [i. e., to"},{"kind":"arabic","text_bw":"A=mirN","text_ar":"ا=مِرٌ"},{"kind":"text","text":";] like"},{"kind":"arabic","text_bw":"A^amorN EaArifN","text_ar":"اَمْرٌ عَارِفٌ"},{"kind":"text","text":", which is originally"},{"kind":"arabic","text_bw":"maEoruwfN","text_ar":"مَعْرُوفٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Eiy$apN rADiyapN","text_ar":"عِيشَةٌ راضِيَةٌ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"maroDiy~apN","text_ar":"مَرْضِيَّةٌ"},{"kind":"text","text":"; &c.; [and then, to"},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":";] and that"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":"becomes in the pl."},{"kind":"arabic","text_bw":"fawaAEilu","text_ar":"فَوَاعِلُ"},{"kind":"text","text":"; so that"},{"kind":"arabic","text_bw":"A^awaAmaru","text_ar":"اَوَامَرُ"},{"kind":"text","text":"is the pl. of"},{"kind":"arabic","text_bw":"maA_omuwrN","text_ar":"مَاـْمُورٌ"},{"kind":"text","text":": others say that it has this form of pl. to distinguish it from"},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"HaAlN","text_ar":"حَالٌ"},{"kind":"text","text":"[&c.], in which sense it has for its pl."},{"kind":"arabic","text_bw":"A^umuwrN","text_ar":"اُمُورٌ"},{"kind":"text","text":". (Msb, TA.) [But I think that"},{"kind":"arabic","text_bw":"A^awaAmiru","text_ar":"اَوَامِرُ"},{"kind":"text","text":"may be properly and originally pl. of"},{"kind":"arabic","text_bw":"A=mirapN","text_ar":"ا=مِرَةٌ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"A=yapN A=mirapN","text_ar":"ا=يَةٌ ا=مِرَةٌ"},{"kind":"text","text":", or the like. MF says that, accord. to the T and M, the pl. of"},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":"in the sense explained in the beginning of this paragraph is"},{"kind":"arabic","text_bw":"A^umuwrN","text_ar":"اُمُورٌ"},{"kind":"text","text":": but he seems to have founded his assertion upon corrupted copies of those works; for in the M, I find nothing on this point; and in the T, not, as he says,"},{"kind":"arabic","text_bw":"AlA^amoruDid~u","text_ar":"الاَمْرُضِدُّ"},{"kind":"arabic","text_bw":"Aln~ahoYa waAHidu AlA^umuwr","text_ar":"النَّهْىَ وَاحِدُ الاُمُور"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"qaAla All~ayovu AlA^amoru maEoruwfN","text_ar":"قَالَ اللَّيْثُ الاَمْرُ مَعْرُوفٌ"},{"kind":"arabic","text_bw":"naqiyDu Aln~ahoYi waAHidu AlA^umuwri","text_ar":"نَقِيضُ النَّهْىِ وَاحِدُ الاُمُورِ"},{"kind":"text","text":", evidently meaning that"},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":"signifies the contr. of"},{"kind":"arabic","text_bw":"nahoYN","text_ar":"نَهْىٌ"},{"kind":"text","text":", and is also, in another sense, the sing. of"},{"kind":"arabic","text_bw":"A^umuwrN","text_ar":"اُمُورٌ"},{"kind":"text","text":".] [Hence,]"},{"kind":"arabic","text_bw":"A^uwluw","text_ar":"اُولُو"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"italic_en","text":"Those who hold command"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rule,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the learned men."},{"kind":"text","text":"(M, K. [See Kur iv. 62.]) And"},{"kind":"arabic","text_bw":"A^amoruAll~`hi","text_ar":"اَمْرُاللّٰهِ"},{"kind":"italic_en","text":"The threatened punishment of God:"},{"kind":"text","text":"so in the Kur x. 25, and xi. 42, and xvi.1; in which last place occur the words,"},{"kind":"arabic","text_bw":"A^atay A^amoru All~`hi falaA tasotaEojiluwhu","text_ar":"اَتَي اَمْرُ اللّٰهِ فَلَا تَسْتَعْجِلُوهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The threatened punishment ordained of God hath, as it were, come:"},{"kind":"text","text":"so near is it, that it is as though it had already come:"},{"kind":"italic_en","text":"therefore desire not ye to hasten it."},{"kind":"text","text":"(Zj, M, TA.) And"},{"kind":"italic_en","text":"The purpose of God."},{"kind":"text","text":"(Bd and Jel in lxv. 3; &c.) And"},{"kind":"arabic","text_bw":"AlA^amoru qariybN","text_ar":"الاَمْرُ قَرِيبٌ"},{"kind":"italic_en","text":"The resurrection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the time thereof, is near."},{"kind":"text","text":"(Mgh, from a trad.) And"},{"kind":"arabic","text_bw":"maA faEalotuhu Eano","text_ar":"مَا فَعَلْتُهُ عَنْ"},{"kind":"arabic","text_bw":"A^amoriY","text_ar":"اَمْرِى"},{"kind":"text","text":", in the Kur xviii. 81,"},{"kind":"italic_en","text":"I did it not of my own judgment:"},{"kind":"text","text":"(Bd:) or,"},{"kind":"italic_en","text":"of my own choice."},{"kind":"text","text":"(Jel.) [Hence also"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":", in grammar, signifies"},{"kind":"italic_en","text":"The imperative form"},{"kind":"text","text":"of a verb.] ―         -b2-  Also"},{"kind":"italic_en","text":"A thing; an affair; a business; a matter; a concern: a state, of a person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of persons"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"things"},{"kind":"page_break","n":97},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs or circumstances; a condition; a case: an accident; an event: an action:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$aA^onN","text_ar":"شَاْنٌ"},{"kind":"text","text":": (M, F, TA:) and"},{"kind":"arabic","text_bw":"HaAlN","text_ar":"حَالٌ"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"HaAlapN","text_ar":"حَالَةٌ"},{"kind":"text","text":": (Msb:) and"},{"kind":"arabic","text_bw":"HaAdivapN","text_ar":"حَادِثَةٌ"},{"kind":"text","text":": (K:) and"},{"kind":"arabic","text_bw":"fiEolN","text_ar":"فِعْلٌ"},{"kind":"text","text":": (MF, TA:) and"},{"kind":"italic_en","text":"a thing that is said; a saying:"},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"A^uwluw","text_ar":"اُولُو"},{"kind":"text","text":", at the end of art."},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":":) pl."},{"kind":"arabic","text_bw":"A^umuwrN","text_ar":"اُمُورٌ"},{"kind":"text","text":"; (S, M, K, &c.;) its only pl. in the senses here explained. (TA.) You say,"},{"kind":"arabic","text_bw":"A^amoru fulaAnK musotaqiymN","text_ar":"اَمْرُ فُلَانٍ مُسْتَقِيمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, of such a one is in a right state"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Amuwruhu musotaqiymapN","text_ar":"امُورُهُ مُسْتَقِيمَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His affairs are in a right state"},{"kind":"text","text":"]. (S, A.) And"},{"kind":"arabic","text_bw":"$at~ata A^amorahu","text_ar":"شَتَّتَ اَمْرَهُ"},{"kind":"italic_en","text":"He dissipated, disorganized, disordered, unsettled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke up, his state of things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs."},{"kind":"text","text":"(As, TA in art."},{"kind":"arabic","text_bw":"$Eb","text_ar":"شعب"},{"kind":"text","text":".) ["},{"kind":"arabic","text_bw":"Amr","text_ar":"امر"},{"kind":"text","text":"seems to be here used, as in many other instances, rather in the sense of the pl. than in that of the sing.] ―         -b3-"},{"kind":"arabic","text_bw":"A^amorN kul~iY~N","text_ar":"اَمْرٌ كُلِّىٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A universal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"general, prescript, rule,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"canon"},{"kind":"text","text":"]. (Msb voce"},{"kind":"arabic","text_bw":"qaAEidapN","text_ar":"قَاعِدَةٌ"},{"kind":"text","text":", KT voce"},{"kind":"arabic","text_bw":"qaAnuwnN","text_ar":"قَانُونٌ"},{"kind":"text","text":", &c.)"}],"source_refs":["Bd","M","F","TA","Msb","K","MF"]},{"entry_id":"n1213","headword_ar":"اـِمْرٌ","root":"Amr","body":[{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"A^amiraAliA^amoru","text_ar":"اَمِرَالِاَمْرُ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"Ai$otad~a","text_ar":"اِشْتَدَّ"},{"kind":"text","text":"; (S;) or a subst. from"},{"kind":"arabic","text_bw":"A^amira","text_ar":"اَمِرَ"},{"kind":"text","text":"as signifying"},{"kind":"arabic","text_bw":"kavura","text_ar":"كَثُرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tam~a","text_ar":"تَمَّ"},{"kind":"text","text":"; (M;) (assumed tropical:)  ["},{"kind":"italic_en","text":"A severe, a distressful, a grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an afflictive, thing:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a terrible, and foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very foul, thing:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a wonderful thing."},{"kind":"text","text":"(TA,) Hence, [used as an epithet, like"},{"kind":"arabic","text_bw":"A^amirN","text_ar":"اَمِرٌ"},{"kind":"text","text":", q. v.,] in the Kur [xviii. 70],"},{"kind":"arabic","text_bw":"laqado jiy^ota $ayoy^FA A_imorFA","text_ar":"لَقَدْ جِيْتَ شَيْيًا اـِمْرًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Verily thou hast done a severe, a distressful, a grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an afflictive, thing:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"a terrible, and foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very foul, thing:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a wonderful thing:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"an abominable, a foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil, and a wonderful, thing:"},{"kind":"text","text":"(Ks, M, K: *) or"},{"kind":"italic_en","text":"a terrible and an abominable thing;"},{"kind":"text","text":"signifying more than"},{"kind":"arabic","text_bw":"nakorFA","text_ar":"نَكْرًا"},{"kind":"text","text":", [which occurs after, in verse 73,] inasmuch as the [presumed] drowning of the persons in the ship was more abominable than the slaying of one person: (Zj, T:) or"},{"kind":"italic_en","text":"a crafty, and an abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil, and a wonderful, thing;"},{"kind":"text","text":"and derived from"},{"kind":"arabic","text_bw":"A^amira Alqawomu","text_ar":"اَمِرَ القَوْمُ"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"kavuruwA","text_ar":"كَثُرُوا"},{"kind":"text","text":". (Ks.)"}],"source_refs":["TA","S","Zj","T"]},{"entry_id":"n1214","headword_ar":"اَمَرٌ","root":"Amr","body":[{"kind":"text","text":"a coll. gen. n. of which"},{"kind":"arabic","text_bw":"A^amarapN","text_ar":"اَمَرَةٌ"},{"kind":"text","text":"(q. v.) is the n. un.       -A2-  See also"},{"kind":"arabic","text_bw":"taA^omuwrN","text_ar":"تَاْمُورٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1215","headword_ar":"اَمِرٌ","root":"Amr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A_im~arN","text_ar":"اـِمَّرٌ"},{"kind":"text","text":".       -A2-  (assumed tropical:)"},{"kind":"italic_en","text":"Multiplied;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant."},{"kind":"text","text":"(M, K.) [See"},{"kind":"arabic","text_bw":"A^amira","text_ar":"اَمِرَ"},{"kind":"text","text":".] You say"},{"kind":"arabic","text_bw":"zaroEN A^amirN","text_ar":"زَرْعٌ اَمِرٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Abundant seed-produce."},{"kind":"text","text":"(Lh, M.) ―         -b2-  (assumed tropical:)  A man"},{"kind":"italic_en","text":"whose beasts have multiplied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become many"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant."},{"kind":"text","text":"(M.) (assumed tropical:)  A man"},{"kind":"italic_en","text":"blessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prospered,"},{"kind":"text","text":"(Ibn-Buzurj, M, K, *)"},{"kind":"italic_en","text":"in his property:"},{"kind":"text","text":"(M:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (Ibn-Buzurj.) And with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", (assumed tropical:)  A woman"},{"kind":"italic_en","text":"blessed to her husband"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by her being prolific"},{"kind":"text","text":"]: from the signification of"},{"kind":"arabic","text_bw":"kavorapN","text_ar":"كَثْرَةٌ"},{"kind":"text","text":". (M.)       -A3-  (assumed tropical:)"},{"kind":"italic_en","text":"Severe; distressful; afflictive."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"A_imorN","text_ar":"اـِمْرٌ"},{"kind":"text","text":".]"}],"source_refs":["M"]},{"entry_id":"n1224","headword_ar":"اَمَّرٌ","root":"Amr","body":[{"kind":"text","text":": see the next paragraph, in two places."}],"source_refs":[]},{"entry_id":"n1225","headword_ar":"اـِمَّرٌ","root":"Amr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who consults every one respecting his case;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^amirN","text_ar":"اَمِرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^am~aArapN","text_ar":"اَمَّارَةٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) or a man"},{"kind":"italic_en","text":"resembling"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in stupidity"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a kid:"},{"kind":"text","text":"[see the latter part of this paragraph:] (Th, M:) or, as also ↓"},{"kind":"arabic","text_bw":"A_im~arapN","text_ar":"اـِمَّرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K, &c.) and ↓"},{"kind":"arabic","text_bw":"A^am~arN","text_ar":"اَمَّرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^am~arapN","text_ar":"اَمَّرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) a man"},{"kind":"italic_en","text":"having weak judgment,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"stupid,"},{"kind":"text","text":"(T, M,) or"},{"kind":"italic_en","text":"weak, without judgment,"},{"kind":"text","text":"(M, L,) or"},{"kind":"italic_en","text":"without intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence,"},{"kind":"text","text":"(T,)"},{"kind":"italic_en","text":"who obeys the command of every one,"},{"kind":"text","text":"(T, S,)"},{"kind":"italic_en","text":"who complies with what every one desires to do in all his affairs;"},{"kind":"text","text":"(K;) a"},{"kind":"italic_en","text":"stupid"},{"kind":"text","text":"man,"},{"kind":"italic_en","text":"of weak judgment, who says to another, Command me to execute thine affair."},{"kind":"text","text":"(IAth.) It is said in a trad.,"},{"kind":"arabic","text_bw":"mano","text_ar":"مَنْ"},{"kind":"arabic","text_bw":"yuTiEo A_im~arapF laA yaA^okulo vamarapF","text_ar":"يُطِعْ اـِمَّرَةً لَا يَاْكُلْ ثَمَرَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who obeys a stupid man,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"shall not eat fruit:"},{"kind":"text","text":"or the meaning is]"},{"kind":"page_break","n":98},{"kind":"italic_en","text":"he who obeys a stupid woman shall be debarred from good."},{"kind":"text","text":"(IAth.) ↓"},{"kind":"arabic","text_bw":"A_im~arapN","text_ar":"اـِمَّرَةٌ","orth_type":"arrow"},{"kind":"text","text":"is applied to a woman and to a man: when it is applied to a man, the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is added to give intensiveness to the signification. (ISh.) The following saying,"},{"kind":"arabic","text_bw":"A_i*aA TalaEati Al$~iEoraY","text_ar":"اـِذَا طَلَعَتِ الشِّعْرَى"},{"kind":"arabic","text_bw":"walaA A_im~arFA","text_ar":"وَلَا اـِمَّرًا"},{"kind":"text","text":", ↓"},{"kind":"arabic","text_bw":"safarFA falaA turosilo fiyhaA A_im~arapF","text_ar":"سَفَرًا فَلَا تُرْسِلْ فِيهَا اـِمَّرَةً","orth_type":"arrow"},{"kind":"text","text":", in rhyming prose, means ["},{"kind":"italic_en","text":"When Sirius rises in the clear twilight,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"send not thou among them"},{"kind":"text","text":"("},{"kind":"italic_en","text":"meaning the camels"},{"kind":"text","text":")"},{"kind":"italic_en","text":"a man without intelligence"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a great degree, nor one who is so in a less degree;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a woman without intelligence, nor a man without intelligence;"},{"kind":"text","text":"] to manage them. (Sh.) ―         -b2-  Also, (M, K,) and ↓"},{"kind":"arabic","text_bw":"A_im~arapN","text_ar":"اـِمَّرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^am~ara","text_ar":"اَمَّرَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^um~arN","text_ar":"اُمَّرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"A young lamb:"},{"kind":"text","text":"(M, K:) or the first ("},{"kind":"arabic","text_bw":"A_imarN","text_ar":"اـِمَرٌ"},{"kind":"text","text":") and the second,"},{"kind":"italic_en","text":"a young kid:"},{"kind":"text","text":"(M, TA:) or the former of these two,"},{"kind":"italic_en","text":"a male lamb:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"a young male lamb:"},{"kind":"text","text":"(S:) and the latter of them,"},{"kind":"italic_en","text":"a female lamb:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"a young female lamb."},{"kind":"text","text":"(S, M.) One says, ↓"},{"kind":"arabic","text_bw":"maA lahu A_im~arN walaA A_im~arapN","text_ar":"مَا لَهُ اـِمَّرٌ وَلَا اـِمَّرَةٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He has not a male lamb nor a female lamb:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"he has not anything."},{"kind":"text","text":"(T, S, M.)"}],"source_refs":["M","Th","K","S","T","L","TA"]},{"entry_id":"n38384","headword_ar":"اَمَرُّ","root":"mr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, tightly twisted"},{"kind":"text","text":"]. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"fulaAnN A^amar~u EaqodFA mino fulaAnK","text_ar":"فُلَانٌ اَمَرُّ عَقْدًا مِنْ فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one is firmer, and more faithful to his compact, than such a one."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, bitter:"},{"kind":"text","text":"fem."},{"kind":"arabic","text_bw":"mur~aY","text_ar":"مُرَّى"},{"kind":"text","text":": of which the dual is"},{"kind":"arabic","text_bw":"mur~ayaAni","text_ar":"مُرَّيَانِ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"h`*aA A^amar~u mino *aA","text_ar":"هٰذَا اَمَرُّ مِنْ ذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is more bitter than that"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"xu*i AlHalowaY waA^aEoTihi Almur~aY","text_ar":"خُذِ الحَلْوَى وَاَعْطِهِ المُرَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Take thou the sweeter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sweetest, and give to him the bitterer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bitterest"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"Hlw","text_ar":"حلو"},{"kind":"text","text":".) And it is said in a prov., (A,) by a certain Arab woman, (S,)"},{"kind":"arabic","text_bw":"SugoraAhaA mur~aAhaA","text_ar":"صُغْرَاهَا مُرَّاهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The youngest of them is the most bitter of them"},{"kind":"text","text":"]. (S, A.) See Freytag's Arab. Prov., i. 720; where another reading is given,"},{"kind":"arabic","text_bw":"$ur~aAhaA","text_ar":"شُرَّاهَا"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"muraAh~aA","text_ar":"مُرَاهَّا"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"AlA^amar~aAni","text_ar":"الاَمَرَّانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Poverty and decrepitude:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"decrepitude and disease."},{"kind":"text","text":"(A.) ―         -b3-  Also, (tropical:)"},{"kind":"italic_en","text":"Aloes"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlS~abiru","text_ar":"الصَّبِرُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"Alv~uf~aA='u","text_ar":"الثُّفَّا=ءُ"},{"kind":"text","text":", (A, K,) i. e.,"},{"kind":"italic_en","text":"mustard:"},{"kind":"text","text":"(TA:) so in a trad. (A, TA.) ―         -b4-  You say also,"},{"kind":"arabic","text_bw":"laqiytu minohu AlA^amar~iyna","text_ar":"لَقِيتُ مِنْهُ الاَمَرِّينَ"},{"kind":"text","text":", (T, S, M, K,) with the pl."},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":", (T, S,) and with kesr to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"AlA^amar~ayoni","text_ar":"الاَمَرَّيْنِ"},{"kind":"text","text":", (IAar, M, A, K,) dual of"},{"kind":"arabic","text_bw":"A^amar~u","text_ar":"اَمَرُّ"},{"kind":"text","text":", (M,) with fet-h to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"Almur~ayayoni","text_ar":"المُرَّيَيْنِ"},{"kind":"text","text":", dual of"},{"kind":"arabic","text_bw":"mur~aY","text_ar":"مُرَّى"},{"kind":"text","text":", (M,) or ↓"},{"kind":"arabic","text_bw":"Almur~atayoni","text_ar":"المُرَّتَيْنِ","orth_type":"arrow"},{"kind":"text","text":", (as in copies of the K,) (tropical:)"},{"kind":"italic_en","text":"I experienced from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, calamities:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"evil, and a grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, thing."},{"kind":"text","text":"(M, K.)"}],"source_refs":["A","S","K","TA","T","M","IAar"]}]}}