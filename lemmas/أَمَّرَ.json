{"lemma":"أَمَّرَ","slug":"أَمَّرَ","root":"#.م.ر","root_slug":"_-م-ر","root_link":"/words/roots/_-م-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَمَّرْتَ","in_corpus":true,"count":46,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَمَّرْتِ","in_corpus":true,"count":46,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَمَّرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَمَّرْتُم","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَمَّرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَمَّرَ","in_corpus":true,"count":541,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَمَّرَت","in_corpus":true,"count":46,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَمَّرا","in_corpus":true,"count":47,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَمَّرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَمَّرُوا","in_corpus":true,"count":15,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَمَّرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُؤَمَّر","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُؤَمِّر","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُؤَمَّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤَمَّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤَمِّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤَمِّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f",