:"text","text":"),"},{"kind":"italic_en","text":"resembling the"},{"kind":"arabic","text_bw":"HuroquwS","text_ar":"حُرْقُوص"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"well known:"},{"kind":"text","text":"(K:) [a coll. gen. n.: n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"baraAgiyvu","text_ar":"بَرَاغِيثُ"},{"kind":"text","text":". (S.)"}],"source_refs":["S","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D8%B1%D8%BA%D9%88%D8%AB/","headword_ar":"بُرْغُوث","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=137843#7591cc","body_html":"بُرْغُوث:<br>بلفظ البرغوث من الحيوان: بلد بالروم قريب من عمّورية."}]}}