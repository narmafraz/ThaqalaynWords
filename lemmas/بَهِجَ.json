%D8%A8%D9%8E%D9%87%D9%90%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to rejoice in, to cheer at, to be happy about"},{"pos":"verb","gloss":"to be beautiful, to be delightful, to be handsome"},{"pos":"noun","gloss":"verbal noun of بَهِجَ (bahija) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"delightful, joyous"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3397","headword_ar":"بَهُجَ","root":"bhj","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (AZ, S, Msb, &c.,) inf. n."},{"kind":"arabic","text_bw":"bahaAjapN","text_ar":"بَهَاجَةٌ"},{"kind":"text","text":"(AZ, S, L, K) and"},{"kind":"arabic","text_bw":"bahojapN","text_ar":"بَهْجَةٌ"},{"kind":"text","text":"(AZ, L, [but some seem to regard this as a simple subst.,]) and"},{"kind":"arabic","text_bw":"bahajaAnN","text_ar":"بَهَجَانٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly:"},{"kind":"text","text":"(AZ, S, L, Msb, K:) or"},{"kind":"italic_en","text":"beautiful in colour:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful and bright"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"splendid:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful and bright;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, characterized by a laughing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy, appearance of the beautiful parts of the face, as the cheeks, and the lines of the forehead:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by the appearance of joy, gladness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happiness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by a joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy, aspect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appearance."},{"kind":"text","text":"(L.) You say also,"},{"kind":"arabic","text_bw":"bahija","text_ar":"بَهِجَ"},{"kind":"arabic","text_bw":"Aln~abaAtu","text_ar":"النَّبَاتُ"},{"kind":"text","text":", with kesr, meaning (assumed tropical:)"},{"kind":"italic_en","text":"The plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful"},{"kind":"text","text":"[&c.]. (TA, [but this is probably a tropical signification, from"},{"kind":"arabic","text_bw":"bahija","text_ar":"بَهِجَ"},{"kind":"text","text":"in the sense here following.]) ―         -b2-"},{"kind":"arabic","text_bw":"bahija","text_ar":"بَهِجَ"},{"kind":"text","text":", (S, A, L, K,) with kesr, (S,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"bahajN","text_ar":"بَهَجٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"Abthj","text_ar":"ابتهج","orth_type":"arrow"},{"kind":"text","text":"; (S, A, L, Msb, K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy."},{"kind":"text","text":"(S, A, L, Msb, K.) You say,"},{"kind":"arabic","text_bw":"bahija bihi","text_ar":"بَهِجَ بِهِ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Abthj","text_ar":"ابتهج","orth_type":"arrow"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"; (A, Msb;)"},{"kind":"italic_en","text":"He rejoiced in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became rejoiced by it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at it."},{"kind":"text","text":"(S, A, Msb, TA.) [See also 10.]       -A2-"},{"kind":"arabic","text_bw":"bahaja","text_ar":"بَهَجَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Abhj","text_ar":"ابهج","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K;) the latter of which is the more approved; (TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, TA, or an affair or event, S, A)"},{"kind":"italic_en","text":"rejoiced;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy;"},{"kind":"text","text":"(S, A, K;) a person. (S, A.)"}],"source_refs":["AZ","S","L","K","Msb","A"]},{"entry_id":"n3398","headword_ar":"بهّج","root":"bhj","body":[{"kind":"text","text":", (ISd, L,) inf. n."},{"kind":"arabic","text_bw":"tabohiyjN","text_ar":"تَبْهِيجٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He beautified; rendered beautiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly."},{"kind":"text","text":"(ISd, L, K.) ISd says, I have not heard this, except in the saying of El-'Ajjáj,"},{"kind":"quote","text":"daEo *aA wabah~ijo HasabFA mubah~ajaA"},{"kind":"text","text":"as though meaning ["},{"kind":"italic_en","text":"Leave thou this"},{"kind":"text","text":"subject,"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"beautify,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adorn,"},{"kind":"text","text":"the more this"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"["},{"kind":"italic_en","text":"already beautified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adorned,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by thy describing it."},{"kind":"text","text":"(L.)"}],"source_refs":["ISd","L","K"]},{"entry_id":"n3402","headword_ar":"بَهْجٌ","root":"bhj","body":[{"kind":"text","text":", fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bahiyjN","text_ar":"بَهِيجٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n3403","headword_ar":"بَهِجٌ","root":"bhj","body":[{"kind":"italic_en","text":"Joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"bahiyjN","text_ar":"بَهِيجٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"mubotahijN","text_ar":"مُبْتَهِجٌ","orth_type":"arrow"},{"kind":"text","text":". (A, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"bahiyjN","text_ar":"بَهِيجٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","K"]}]},"classical_definitions":null}