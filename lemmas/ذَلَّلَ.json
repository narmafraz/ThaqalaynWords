n":"m","num":"p"},{"role":"present_2mp","form":"تُذَلِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُذَلِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُذَلِّل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُذَلِّل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُذَلِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُذَلِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُذَلِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُذَلِّلا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُذَلِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُذَلِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُذَلِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُذَلِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُذَلِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ذَلَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ذَلَّلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":true,"lemma_key":"ذَلَّلَ","root":"ذلل","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n13966"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D9%84%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to degrade, to make humble"},{"pos":"verb","gloss":"to defeat, to overpower"}]},"etymology":null,"ipa":["/ðal.la.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13966","headword_ar":"ذلّل","root":"*l","body":[{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"ta*oliylN","text_ar":"تَذْلِيلٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered,"},{"kind":"text","text":"(M, Msb,) a man, (M,) and a beast, such as a horse and the like, (M, Msb,)"},{"kind":"italic_en","text":"easy, tractable, submissive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manageable:"},{"kind":"text","text":"(M, Msb:) [said of the former, it may be rendered"},{"kind":"italic_en","text":"he brought under,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into, subjection;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he subdued:"},{"kind":"text","text":"and said of the latter,"},{"kind":"italic_en","text":"he broke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trained:"},{"kind":"text","text":"and said of any animal,"},{"kind":"italic_en","text":"he tamed."},{"kind":"text","text":"―         -b2-  Hence, (assumed tropical:)"},{"kind":"italic_en","text":"He beat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trod,"},{"kind":"text","text":"a road,"},{"kind":"italic_en","text":"so as to render it even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy to be travelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to walk or ride upon:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"*aliylN","text_ar":"ذَلِيلٌ"},{"kind":"text","text":".] ―         -b3-  And"},{"kind":"arabic","text_bw":"*l~l lahu A^amorFA","text_ar":"ذلّل لَهُ اَمْرًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made an affair easy to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"raw~aDahu","text_ar":"رَوَّضَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saw~asahu","text_ar":"سَوَّسَهُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"sws","text_ar":"سوس"},{"kind":"text","text":".) ―         -b4-  And"},{"kind":"arabic","text_bw":"*il~ila Alkaromu","text_ar":"ذِلِّلَ الكَرْمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The bunches of the grape-vine were made to hang down"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so that they might be easily plucked"},{"kind":"text","text":"]: (M, K:) or"},{"kind":"italic_en","text":"were evenly disposed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the same purpose"},{"kind":"text","text":"]; syn."},{"kind":"arabic","text_bw":"suw~iyato","text_ar":"سُوِّيَتْ"},{"kind":"text","text":": (K:) or, accord. to AHn,"},{"kind":"arabic","text_bw":"Alt~a*oliylu","text_ar":"التَّذْلِيلُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the disposing evenly the bunches"},{"kind":"page_break","n":973},{"kind":"italic_en","text":"of the grape-vine, and making them to hang down."},{"kind":"text","text":"(M.)"},{"kind":"arabic","text_bw":"wa*ul~ilato quTuwfuhaA","text_ar":"وَذُلِّلَتْ قُطُوفُهَا"},{"kind":"text","text":", in the Kur [lxxvi. 14], means (assumed tropical:)"},{"kind":"italic_en","text":"The bunches being evenly disposed, and made to hang down,"},{"kind":"text","text":"(S, JM,)"},{"kind":"italic_en","text":"exposed to be plucked:"},{"kind":"text","text":"(JM:) or"},{"kind":"italic_en","text":"being well disposed, and made near:"},{"kind":"text","text":"(IAmb, TA:) or"},{"kind":"italic_en","text":"being within the reach of the seeker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirer:"},{"kind":"text","text":"(Ibn-'Arafeh, TA:) or"},{"kind":"italic_en","text":"being easy to reach by those who will pluck them, in whatever manner they may desire to do so:"},{"kind":"text","text":"(Bd:) accord. to Mujáhid, it means that if one stand, the bunch will rise to him; and if one sit, it will hang down to him. (TA.) [In like manner,]"},{"kind":"arabic","text_bw":"Alt~a*oliylu","text_ar":"التَّذْلِيلُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"The putting the raceme of the palm-tree upon the branch"},{"kind":"text","text":"["},{"kind":"italic_en","text":"near it"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in order that it"},{"kind":"text","text":"[the branch]"},{"kind":"italic_en","text":"may support it:"},{"kind":"text","text":"(AHn, M:) or"},{"kind":"arabic","text_bw":"ta*oliylu AlEu*uwqi","text_ar":"تَذْلِيلُ العُذُوقِ"},{"kind":"text","text":", as practised in the present world, is (assumed tropical:)"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"trimmer's"},{"kind":"italic_en","text":"making straight, and fecundating before the usual time, the racemes of the palm-tree, when they come forth from their spathes that covered them, these having slit open and disclosed them, by which means one makes them to hang out from among the branches and prickles, so that the fruit is easily plucked when it ripens."},{"kind":"text","text":"(T. [See also"},{"kind":"arabic","text_bw":"mu*al~alN","text_ar":"مُذَلَّلٌ"},{"kind":"text","text":".]) [Hence it is said in the K that"},{"kind":"arabic","text_bw":"*ul~ila Aln~axolu","text_ar":"ذُلِّلَ النَّخْلُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"wuDiEa","text_ar":"وُضِعَ"},{"kind":"arabic","text_bw":"Ei*oquhaA EalaY Aljariydapi litaHomilahu","text_ar":"عِذْقُهَا عَلَى الجَرِيدَةِ لِتَحْمِلَهُ"},{"kind":"text","text":": the explanation should be"},{"kind":"arabic","text_bw":"wuDiEato Eu*uwquhaA EalaY Aljariydi litaHomilahaA","text_ar":"وُضِعَتْ عُذُوقُهَا عَلَى الجَرِيدِ لِتَحْمِلَهَا"},{"kind":"text","text":", i. e. (assumed tropical:)"},{"kind":"italic_en","text":"The palm-trees had their racemes put upon the branches in order that these might support them."},{"kind":"text","text":"] ―         -b5-  See also what next follows."}],"source_refs":["M","Msb","K","S","JM","IAmb","TA","Bd","AHn"]}]}}