","text":"A rope undone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"untwisted,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"at its end."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","Msb","TA","K"]}]},"classical_definitions":null}