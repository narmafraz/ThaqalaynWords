{"lemma":"تَحَرِّي","slug":"تَحَرِّي","root":"ح.ر.#","root_slug":"ح-ر-_","root_link":"/words/roots/ح-ر-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n7798"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AD%D9%8E%D8%B1%D9%90%D9%91%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to seek, pursue, strive for, aspire to"},{"pos":"verb","gloss":"to examine, investigate"},{"pos":"verb","gloss":"to inquire into"},{"pos":"verb","gloss":"to be intent on, take care of"},{"pos":"verb","gloss":"to attend to, look after"},{"pos":"verb","gloss":"to see to it that"}]},"etymology":null,"ipa":["/ta.ħar.raː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7798","headword_ar":"تحرّى","root":"HrY","body":[{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"qaSada AlHaraY","text_ar":"قَصَدَ الحَرَى"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"He sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repaired to, the vicinage, quarter, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region, of a people:"},{"kind":"text","text":"this is said to be the primary signification: (Mgh:) and"},{"kind":"arabic","text_bw":"tHr~Ahu","text_ar":"تحرّاهُ"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repaired to, his vicinage,"},{"kind":"text","text":"&c.; ("},{"kind":"arabic","text_bw":"qaSada HaraAhu","text_ar":"قَصَدَ حَرَاهُ"},{"kind":"text","text":";) as also ↓"},{"kind":"arabic","text_bw":"HaraAhu","text_ar":"حَرَاهُ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHoriY","text_ar":"يَحْرِى"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"he aimed at it; made it his object; sought, endeavoured after, pursued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured to reach"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtain, it; intended"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed it;"},{"kind":"text","text":"namely, a thing. (S, Mgh, Msb, K, TA.) Hence, in the Kur [lxxii. 14],"},{"kind":"arabic","text_bw":"faA^uwlaAy^ika","text_ar":"فَاُولَايِكَ"},{"kind":"arabic","text_bw":"taHar~awoA ra$adFA","text_ar":"تَحَرَّوْا رَشَدًا"},{"kind":"italic_en","text":"Those have aimed at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"a right course."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"taHar~ayotu maroDaAtahu","text_ar":"تَحَرَّيْتُ مَرْضَاتَهُ"},{"kind":"italic_en","text":"I aimed at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"his approval."},{"kind":"text","text":"(Mgh.) And the trad.,"},{"kind":"arabic","text_bw":"taHar~awoA layolapa Alqadori fiY AlEa$ori AlA^awaAxiri","text_ar":"تَحَرَّوْا لَيْلَةَ القَدْرِ فِى العَشْرِ الاَوَاخِرِ"},{"kind":"italic_en","text":"Seek ye the Night of"},{"kind":"arabic","text_bw":"Alqdr","text_ar":"القدر"},{"kind":"italic_en","text":"in the last ten"},{"kind":"text","text":"[nights of Ramadán]. (TA.) — Also"},{"kind":"italic_en","text":"He sought what was most meet, suitable, fit, proper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deserving,"},{"kind":"text","text":"(S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"to be done,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"of two things,"},{"kind":"text","text":"(Mgh, Msb,)"},{"kind":"italic_en","text":"according to the opinion predominating in his mind,"},{"kind":"text","text":"(S,)"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case"},{"kind":"text","text":"]: (Msb:) or"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"strove in seeking, and deciding upon, the singling out of a thing, by deed"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"by word."},{"kind":"text","text":"(TA.) — And"},{"kind":"italic_en","text":"He tarried, waited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused in expectation,"},{"kind":"arabic","text_bw":"biAlmakaAni","text_ar":"بِالمَكَانِ"},{"kind":"italic_en","text":"in the place."},{"kind":"text","text":"(S, K.)"}],"source_refs":["Mgh","TA","S","Msb","K"]}]},"classical_definitions":null}