:"present_3fd","form":"تَسْهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسْهَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسْهَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْهُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْهُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُسْهَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَهَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَهَوْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْهُو","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْهُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْه","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسْهَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسْهَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":79,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to overlook , to become inattentive"},{"pos":"verb","gloss":"to neglect"}]},"etymology":null,"ipa":["/sa.haː/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D9%87%D8%A7/","headword_ar":"سها","entries":[{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=11099#7b70bb","body_html":"<span class=\"title1\">س هـ ا :</span><span> (السُّهَا) كَوْكَبٌ خَفِيٌّ يَمْتَحِنُ النَّاسُ بِهِ أَبْصَارَهُمْ. وَ (السَّهْوُ) الْغَفْلَةُ وَقَدْ (سَهَا) عَنِ الشَّيْءِ مِنْ بَابِ عَدَا وَسَمَا فَهُوَ (سَاهٍ) وَ (سَهْوَانُ) . </span>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=11099#56eaa9","body_html":"<span class=\"title1\">(سها)</span><span> - قوله عز وجل: {الَّذِينَ هُمْ عَنْ صَلَاتِهِمْ سَاهُونَ} .</span><br><span>السَّهْو عن الشيء: تَركُه، والسَّهْو في الشيء إثباتُه، وقد سَهَا النّبىّ - صلى الله عليه وسلم - في الصَّلاةِ، والمُنافِق يَسْهو عَنْها في السِّرِّ، ويُرائِى بها في الظَّاهر؛ فلهذا أَوعدَهم بالوَيْل.</span>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=11099#ed58f1","body_html":"<span class=\"title1\">سها</span><br><span>السَّهْوُ: خطأ عن غفلة، وذلك ضربان:</span><br><span>أحدهما أن لا يكون من الإنسان جوالبه ومولّداته، كمجنون سبّ إنسانا، والثاني أن يكون منه مولّداته، كمن شرب خمرا، ثم ظهر منه منكر لا عن قصد إلى فعله. والأوّل معفوّ عنه، والثاني مأخوذ به، وعلى نحو الثاني ذمّ الله تعالى فقال:</span><br><span>فِي غَمْرَةٍ ساهُونَ</span><br><span>[الذاريات/ 11] ، عَنْ صَلاتِهِمْ ساهُونَ [الماعون/ 5] .</span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=11099#c883c2","body_html":"<span class=\"title1\">[سها]</span><span> السُها: كوكبٌ خفيّ في بنات نعشٍ الكبرى والناس يمتحنون به أبصارهم. وفي المثل: \" أُرِيها السُها وتُرِيني القمر \". الأصمعي: السَهْوَةُ كالصُفَّةِ تكون بين يدي البيوت. قال أبو عبيد: سمعتُ غير واحدٍ من أهل اليمن يقولون: السَهْوَةُ عندنا بيتٌ صغيرٌ منحدرٌ في الأرض، وسَمْكُه مرتفعٌ من الأرض شبيه بالخِزانة الصغيرة يكون فيها المتاع. والسَهْوَةُ من النوق: الليِّنة السير. والسَهْوُ: السكون واللِينُ، والجمع سهاء مثل دلو ودلاء. قال الشاعر: تناوحت الرياحُ لفقد عَمْروٍ * وكانت قبل مهلكه سهاء أي ساكنة لينة. والمساهاة في العشرة: ترك الاستقصاء. والسَهْواءُ: ساعةٌ من الليل وصدرٌ منه. وفي المثل: \" إنَّ المُوصَّينَ بنو سَهْوانَ \"، معناه أنّك لا تحتاج إلى أن توصِيَ إلاَّ من كان غافلاً ساهياً. والسَهْوُ: الغفلة. وقد سَها عن الشئ يسهو فهو ساه وسهوان. </span><a></a><span>أبو عمرو: يقال عليه من المال ما لا يُسْهى ولا ينهى، أي لا تبلغ غايته. وحَمَلَتِ المرأة سَهْواً، إذا حبلت على حيض.</span>"}]}}