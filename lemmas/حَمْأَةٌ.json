 "text": "or"}, {"kind": "italic_en", "text": "became, angry with him."}, {"kind": "text", "text": "(S, TA.) And"}, {"kind": "arabic", "text_bw": "HamiYa A^anofuhu", "text_ar": "حَمِىَ اَنْفُهُ"}, {"kind": "italic_en", "text": "He became vehemently angry,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "enraged."}, {"kind": "text", "text": "(IAth, TA in art."}, {"kind": "arabic", "text_bw": "Anf", "text_ar": "انف"}, {"kind": "text", "text": ".) And"}, {"kind": "arabic", "text_bw": "HamiYa Eanohu", "text_ar": "حَمِىَ عَنْهُ"}, {"kind": "text", "text": ", (S,) or"}, {"kind": "arabic", "text_bw": "minohu", "text_ar": "مِنْهُ"}, {"kind": "text", "text": ", (K,) or both, (TA,) aor."}, {"kind": "text", "text": ", (K,) inf. n."}, {"kind": "arabic", "text_bw": "Hamiy~apN", "text_ar": "حَمِيَّةٌ"}, {"kind": "text", "text": "(S, Mgh, * Msb, * K) and"}, {"kind": "arabic", "text_bw": "maHomiyapN", "text_ar": "مَحْمِيَةٌ"}, {"kind": "text", "text": ", (S, Mgh, * K,)"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "A^anifa", "text_ar": "اَنِفَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He disdained it; scorned it;"}, {"kind": "text", "text": "&c.]; (S, Mgh, * Msb, * K;)"}, {"kind": "italic_en", "text": "he was ashamed,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "he disdained,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "scorned, to do it."}, {"kind": "text", "text": "(S, TA.) And"}, {"kind": "arabic", "text_bw": "HamiYa mino *`lika A^anofFA", "text_ar": "حَمِىَ مِنْ ذٰلِكَ اَنْفًا"}, {"kind": "italic_en", "text": "He was seized,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "affected, thereat,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "by reason of that, with disdain, scorn,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "indignation."}, {"kind": "text", "text": "(TA, from a trad.) And"}, {"kind": "arabic", "text_b