{"lemma":"جُحْرَيْ","slug":"جُحْرَيْ","root":"ج.ح.ر","root_slug":"ج-ح-ر","root_link":"/words/roots/ج-ح-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n5103","n5106","n5107"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8F%D8%AD%D9%92%D8%B1%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"burrow, den, lair"},{"pos":"noun","gloss":"hole, aperture"},{"pos":"noun","gloss":"vulva, pudendum","tags":["archaic"]}]},"etymology":null,"ipa":["/d͡ʒuħr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5103","headword_ar":"جَحَرَ","root":"jHr","body":[{"kind":"text","text":", (A, K,) aor."},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AnjHr","text_ar":"انجحر","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"tjH~r","text_ar":"تجحّر","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AstjHr","text_ar":"استجحر","orth_type":"arrow"},{"kind":"text","text":", (A,) said of a [lizard of the kind called]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":", (A, Msb, K,) and of a jerboa, and of a serpent, (Msb,) [&c., (see"},{"kind":"arabic","text_bw":"juHorN","text_ar":"جُحْرٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"It entered its burrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hole;"},{"kind":"text","text":"(S, A, K;)"},{"kind":"italic_en","text":"betook itself to it for refuge;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resorted to it."},{"kind":"text","text":"(Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"jaHarato Eayonuhu","text_ar":"جَحَرَتْ عَيْنُهُ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"tjH~rt","text_ar":"تجحّرت","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"AnjHrt","text_ar":"انجحرت","orth_type":"arrow"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"jaHoraA='u","text_ar":"جَحْرَا=ءُ"},{"kind":"text","text":")] (tropical:)"},{"kind":"italic_en","text":"His eye sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became depressed, in his head."},{"kind":"text","text":"(S, A, K.) ―         -b3-"},{"kind":"arabic","text_bw":"jaHarati Al$~amosu liloguyuwbi","text_ar":"جَحَرَتِ الشَّمْسُ لِلْغُيُوبِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The sun set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became near to setting"},{"kind":"text","text":"]. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"jaHarati","text_ar":"جَحَرَتِ"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sun rose high,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so that the shade receded and contracted."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Hajara","text_ar":"حَجَرَ"},{"kind":"text","text":"said of a man, (assumed tropical:)"},{"kind":"italic_en","text":"He retreated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retired; remained behind;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back."},{"kind":"text","text":"(S, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"jaHara Alr~abiyEu","text_ar":"جَحَرَ الرَّبِيعُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"[rain called]"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"italic_en","text":"withheld itself:"},{"kind":"text","text":"(A:) [or]"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"[season called]"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"italic_en","text":"did not give us rain."},{"kind":"text","text":"(K.) ―         -b7-  And"},{"kind":"arabic","text_bw":"jaHara Ean~aA Alxayoru","text_ar":"جَحَرَ عَنَّا الخَيْرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity, kept back from us,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"and did not betide us."},{"kind":"text","text":"(TA.)       -A2-  See also 4."}],"source_refs":["A","K","S","Msb"]},{"entry_id":"n5106","headword_ar":"جَحْرٌ","root":"jHr","body":[{"kind":"italic_en","text":"A deep-bottomed cavern."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n5107","headword_ar":"جُحْرٌ","root":"jHr","body":[{"kind":"text","text":"(S, A, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"juHoraAnN","text_ar":"جُحْرَانٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) The"},{"kind":"italic_en","text":"burrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hole,"},{"kind":"text","text":"(M, K,) of a [lizard of the kind called]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":", (A, Mgh, Msb, MF,) and (tropical:)  of a jerboa, and (tropical:)  of a serpent, (Mgh, Msb, MF, *) and (assumed tropical:)  of any venomous reptile or the like, and wild beast, (M, K,) or of any creature that is not of a large size; (TA;) and [the"},{"kind":"italic_en","text":"den"},{"kind":"text","text":"] of a hyena: (K in art."},{"kind":"arabic","text_bw":"wjr","text_ar":"وجر"},{"kind":"text","text":":) pl. [of mult.] of the former,"},{"kind":"arabic","text_bw":"jiHarapN","text_ar":"جِحَرَةٌ"},{"kind":"text","text":"(S, Msb, K [in the CK"},{"kind":"arabic","text_bw":"jaHarapN","text_ar":"جَحَرَةٌ"},{"kind":"text","text":"]) and [of pauc.]"},{"kind":"arabic","text_bw":"A^ajoHaArN","text_ar":"اَجْحَارٌ"},{"kind":"text","text":". (S, K.) ―         -b2-  And [hence,] the former, (A,) or ↓ the latter, or both, (IAth, TA,) (tropical:)  The"},{"kind":"italic_en","text":"vulva"},{"kind":"text","text":"of a woman; the"},{"kind":"italic_en","text":"pudendum muliebre:"},{"kind":"text","text":"and (tropical:)  the"},{"kind":"italic_en","text":"anus."},{"kind":"text","text":"(IAth, TA.) ―         -b3-  You say,"},{"kind":"arabic","text_bw":"HaS~iniY juHoraki","text_ar":"حَصِّنِى جُحْرَكِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Protect thou"},{"kind":"text","text":"(O woman)"},{"kind":"italic_en","text":"thy pudendum"},{"kind":"text","text":"]. (A.) And it is said in a trad., (by 'Áïsheh, A,) ↓"},{"kind":"arabic","text_bw":"A_i*aA HaADati AlmaroA^apu Haruma AljuHoraAnu","text_ar":"اـِذَا حَاضَتِ المَرْاَةُ حَرُمَ الجُحْرَانُ","orth_type":"arrow"},{"kind":"text","text":"(S, TA) (tropical:)"},{"kind":"italic_en","text":"When a woman has the menstrual discharge, the vulva is forbidden:"},{"kind":"text","text":"(TA:) or, (accord. to one reading, TA,)"},{"kind":"arabic","text_bw":"Haruma AljuHoraAn","text_ar":"حَرُمَ الجُحْرَان"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"both"},{"kind":"text","text":"(A)"},{"kind":"italic_en","text":"the vulva and the anus"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"are forbidden;"},{"kind":"text","text":"(A, TA;) one having been forbidden before. (TA.) ―         -b4-  [Hence likewise,] the former signifies also (assumed tropical:)"},{"kind":"italic_en","text":"A hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aperture,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"vaEolabN","text_ar":"ثَعْلَبٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"whence rainwater flows."},{"kind":"text","text":"(K and TA in art."},{"kind":"arabic","text_bw":"vElb","text_ar":"ثعلب"},{"kind":"text","text":".)"}],"source_refs":["S","A","Mgh","Msb","K","M","MF","IAth","TA"]}]}}