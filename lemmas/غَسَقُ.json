{"lemma":"غَسَقُ","slug":"غَسَقُ","root":"غ.س.ق","root_slug":"غ-س-ق","root_link":"/words/roots/غ-س-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"غَسَق","root":"غسق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n31838","n31840"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B3%D9%8E%D9%82%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"nightfall; dusk","examples":[{"text":"قِمِ ٱلصَّلَوٰةَ لِدُلُوكِ ٱلشَّمۡسِ إِلَىٰ غَسَقِ ٱلَّیۡلِ وَقُرۡءَانَ ٱلۡفَجۡرِۖ إِنَّ قُرۡءَانَ ٱلۡفَجۡرِ كَانَ مَشۡهُودࣰا.","english":"Establish prayer at the decline of the sun [from its meridian] until the fall of night and the recitation of dawn. Indeed, the recitation of dawn is ever witnessed."}]},{"pos":"verb","gloss":"said of the night, it became dark"}]},"etymology":null,"ipa":["/ɣa.saq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31838","headword_ar":"غَسَقَ","root":"gsq","body":[{"kind":"text","text":", said of the night, aor."},{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"gusuwqN","text_ar":"غُسُوقٌ"},{"kind":"text","text":"(O, K, * TA) and"},{"kind":"arabic","text_bw":"gasoqN","text_ar":"غَسْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gasaqN","text_ar":"غَسَقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It became dark;"},{"kind":"text","text":"(S, O;) as also ↓"},{"kind":"arabic","text_bw":"Agsq","text_ar":"اغسق","orth_type":"arrow"},{"kind":"text","text":", (Th, O,) said by Z to be of the dial. of the Benoo-Temeem: (TA:) or both signify"},{"kind":"italic_en","text":"it became intensely dark."},{"kind":"text","text":"(K.) Hence, in a trad.,"},{"kind":"arabic","text_bw":"gasaqa","text_ar":"غَسَقَ"},{"kind":"arabic","text_bw":"All~ayolu EalaY AlZ~iraAbi","text_ar":"اللَّيْلُ عَلَى الظِّرَابِ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"The night poured down upon the small mountains and covered them with its darkness."},{"kind":"text","text":"(TA.) ―         -b2-  And, said of the moon,"},{"kind":"italic_en","text":"It lost its light, and became black and dark."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"gasaqato Eayonuhu","text_ar":"غَسَقَتْ عَيْنُهُ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"text","text":"; (O, K;) and"},{"kind":"arabic","text_bw":"gasiqato","text_ar":"غَسِقَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n."},{"kind":"arabic","text_bw":"gasoqN","text_ar":"غَسْقٌ"},{"kind":"text","text":", (S, O,) or"},{"kind":"page_break","n":2258},{"kind":"arabic","text_bw":"gusuwqN","text_ar":"غُسُوقٌ"},{"kind":"text","text":", (K,) or both, (TA,) and"},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":"; (K, TA;) (assumed tropical:)"},{"kind":"italic_en","text":"His eye became dark:"},{"kind":"text","text":"(S, O, K, TA:) or (assumed tropical:)"},{"kind":"italic_en","text":"shed tears:"},{"kind":"text","text":"(K, TA:) or (tropical:)"},{"kind":"italic_en","text":"poured forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tears"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"gsqt AlEayonu","text_ar":"غسقت العَيْنُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"the eye overflowed with water."},{"kind":"text","text":"(AZ, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"gasaqa AljuroHu","text_ar":"غَسَقَ الجُرْحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"gasoqN","text_ar":"غَسْقٌ"},{"kind":"text","text":"also, (TA,)"},{"kind":"italic_en","text":"The wound had yellow water flowing from it;"},{"kind":"text","text":"(S, O, K;) and so"},{"kind":"arabic","text_bw":"gasiqa","text_ar":"غَسِقَ"},{"kind":"text","text":". (K, by implication.) And"},{"kind":"arabic","text_bw":"gasaqati","text_ar":"غَسَقَتِ"},{"kind":"arabic","text_bw":"Als~amaA='u","text_ar":"السَّمَا=ءُ"},{"kind":"text","text":", (O, K, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gasoqN","text_ar":"غَسْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"The sky rained;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let fall a little rain, such as is termed"},{"kind":"arabic","text_bw":"ra$~N","text_ar":"رَشٌّ"},{"kind":"text","text":": (O, K, TA:) and ["},{"kind":"italic_en","text":"the rain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"poured forth;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AinoSab~at","text_ar":"اِنْصَبَّت"},{"kind":"text","text":": (TA:) [and in this latter sense"},{"kind":"arabic","text_bw":"gasaqa","text_ar":"غَسَقَ"},{"kind":"text","text":"is app. said of any fluid; for,] accord. to Th, (O, TA,)"},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"AinoSibaAbN","text_ar":"اِنْصِبَابٌ"},{"kind":"text","text":". (O, K, TA.) [Hence,]"},{"kind":"arabic","text_bw":"gasaqa","text_ar":"غَسَقَ"},{"kind":"arabic","text_bw":"All~abanu","text_ar":"اللَّبَنُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"gasoqN","text_ar":"غَسْقٌ"},{"kind":"text","text":"(TA) [and app."},{"kind":"arabic","text_bw":"gasaqaAnN","text_ar":"غَسَقَانٌ"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"The milk poured forth from the udder."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","O","K","Th","TA"]},{"entry_id":"n31840","headword_ar":"غَسَقٌ","root":"gsq","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"beginning of the darkness of night:"},{"kind":"text","text":"(Fr, S, O:) or the"},{"kind":"italic_en","text":"darkness"},{"kind":"text","text":"of the night: (Akh, TA:) or the"},{"kind":"italic_en","text":"darkness of the beginning of the night:"},{"kind":"text","text":"(K:) or [the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when the"},{"kind":"arabic","text_bw":"$afaq","text_ar":"شَفَق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"redness in the horizon after sunset"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"disappears:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"time of the blending of the"},{"kind":"arabic","text_bw":"Ei$aAA=ni","text_ar":"عِشَاا=نِ"},{"kind":"text","text":", [see"},{"kind":"arabic","text_bw":"ruwaAn","text_ar":"رُوَان"},{"kind":"text","text":", last sentence,] which is"},{"kind":"italic_en","text":"when the darkness becomes confused, and obstructs"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the view of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the aspects of things:"},{"kind":"text","text":"or, accord. to Sh, the"},{"kind":"italic_en","text":"entering-in of the beginning of the darkness."},{"kind":"text","text":"(TA.)       -A2-  Also"},{"kind":"italic_en","text":"Refuse that is found among wheat, such as"},{"kind":"arabic","text_bw":"ruwaAn","text_ar":"رُوَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"darnel-grass, &c."},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and the like."},{"kind":"text","text":"(Fr, O, K.)"}],"source_refs":["Fr","S","O","Akh","TA","K"]}]}}