n":"m","num":"p"},{"role":"present_2mp","form":"تُغامِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُغامِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُغامِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُغامِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُغامِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُغامِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغامِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغامِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغامِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغامِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغامِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُغامِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغامِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"غامَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غامَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32403"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D8%A7%D9%85%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take a chance or risks, to venture"},{"pos":"verb","gloss":"to put at stake"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32403","headword_ar":"غَامِرٌ","root":"gmr","body":[{"kind":"italic_en","text":"Much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant:"},{"kind":"text","text":"applied in this sense to property. (Ham p. 593.) [See also"},{"kind":"arabic","text_bw":"gamorN","text_ar":"غَمْرٌ"},{"kind":"text","text":".]       -A2-  ["},{"kind":"italic_en","text":"In a state of immersion; immerged."},{"kind":"text","text":"(See"},{"kind":"arabic","text_bw":"A^ataAnN","text_ar":"اَتَانٌ"},{"kind":"text","text":"; and see also a verse cited voce"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":", p. 106, first col.)] ―         -b2-  And [hence, perhaps,]"},{"kind":"arabic","text_bw":"gaAmirapN","text_ar":"غَامِرَةٌ"},{"kind":"text","text":"signifies Palm-trees ("},{"kind":"arabic","text_bw":"naxolN","text_ar":"نَخْلٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"not requiring irrigation:"},{"kind":"text","text":"(AHn, K:) but Az did not find this to be known. (TA.) [See also"},{"kind":"arabic","text_bw":"mugotamirN","text_ar":"مُغْتَمِرٌ"},{"kind":"text","text":".] ―         -b3-  Applied to land, (S, Msb, TA,) and to a house, (TA,) [but written with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"when"},{"kind":"arabic","text_bw":"A^aroDN","text_ar":"اَرْضٌ"},{"kind":"text","text":"is mentioned, or"},{"kind":"arabic","text_bw":"daArN","text_ar":"دَارٌ"},{"kind":"text","text":",] it signifies the"},{"kind":"italic_en","text":"Contr. of"},{"kind":"arabic","text_bw":"EaAmirN","text_ar":"عَامِرٌ"},{"kind":"text","text":"; (S, TA;) and thus, (TA,)"},{"kind":"italic_en","text":"waste; desolate; in a state the contrary of flourishing; in a state of ruin;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xaraAbN","text_ar":"خَرَابٌ"},{"kind":"text","text":": (Msb, K, TA:) [land to which this term is applied is thus called] because overflowed by water, so that it cannot be sown; or because it is covered with sand or dust; or because water generally exudes from it, so that it produces only reeds and the"},{"kind":"arabic","text_bw":"barodiY~","text_ar":"بَرْدِىّ"},{"kind":"text","text":"[i. e. papyrus or other rushes]: by"},{"kind":"arabic","text_bw":"gaAmirN","text_ar":"غَامِرٌ"},{"kind":"text","text":"is meant"},{"kind":"arabic","text_bw":"*uw gamorK","text_ar":"ذُو غَمْرٍ"},{"kind":"text","text":"; like as one says"},{"kind":"arabic","text_bw":"ham~N naASibN","text_ar":"هَمٌّ نَاصِبٌ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"*uw naSabK","text_ar":"ذُو نَصَبٍ"},{"kind":"text","text":": (TA:) or any land"},{"kind":"italic_en","text":"that is not tilled"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"lamo yusotaxorajo","text_ar":"لَمْ يُسْتَخْرَجْ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"so as to be fit for sowing"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"and planting:"},{"kind":"text","text":"(TA:) or land"},{"kind":"italic_en","text":"that is unsown, but capable of being sown:"},{"kind":"text","text":"so called because the water reaches it and comes over it: of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":"; (S, Msb;) like the epithets in"},{"kind":"arabic","text_bw":"sir~N kaAtimN","text_ar":"سِرٌّ كَاتِمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA='N daAfiqN","text_ar":"مَا=ءٌ دَافِقٌ"},{"kind":"text","text":"; and made of the measure"},{"kind":"arabic","text_bw":"fAl","text_ar":"فال"},{"kind":"text","text":"only to correspond to"},{"kind":"arabic","text_bw":"EaAmirN","text_ar":"عَامِرٌ"},{"kind":"text","text":"as its opposite: (S, TA:) waste land which water does not reach is not called"},{"kind":"arabic","text_bw":"gaAmirN","text_ar":"غَامِرٌ"},{"kind":"text","text":"; (S;) but such is called"},{"kind":"arabic","text_bw":"qaforN","text_ar":"قَفْرٌ"},{"kind":"text","text":". (Msb.) It is said in a trad., [which shows that the last two explanations given above are correct,] that 'Omar imposed a tax of a"},{"kind":"arabic","text_bw":"diroham","text_ar":"دِرْهَم"},{"kind":"text","text":"and a"},{"kind":"arabic","text_bw":"qafiyz","text_ar":"قَفِيز"},{"kind":"text","text":"upon every"},{"kind":"arabic","text_bw":"jariyb","text_ar":"جَرِيب"},{"kind":"text","text":"[of land], both"},{"kind":"arabic","text_bw":"EaAmir","text_ar":"عَامِر"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gaAmir","text_ar":"غَامِر"},{"kind":"text","text":": and this he did in order that the people might not be remiss in sowing. (Az, TA.)"}],"source_refs":["AHn","K","S","Msb","TA"]}]},"classical_definitions":null}