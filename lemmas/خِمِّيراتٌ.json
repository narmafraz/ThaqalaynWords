{"lemma":"خِمِّيراتٌ","slug":"خِمِّيراتٌ","root":"خ.م.ر","root_slug":"خ-م-ر","root_link":"/words/roots/خ-م-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n11487","n11490"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%90%D9%85%D9%90%D9%91%D9%8A%D8%B1%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"drunkard, tippler"},{"pos":"adj","gloss":"fermented, leavened"},{"pos":"noun","gloss":"something fermented, particularly leavened bread"},{"pos":"noun","gloss":"ferment, leaven"}]},"etymology":null,"ipa":["/xim.miːr/","/xa.miːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11487","headword_ar":"خَمِيرٌ","root":"xmr","body":[{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"maxomuwrN","text_ar":"مَخْمُورٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muxam~arN","text_ar":"مُخَمَّرٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) applied to dough, ["},{"kind":"italic_en","text":"Leavened;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having had"},{"kind":"arabic","text_bw":"xamiyr","text_ar":"خَمِير"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"leaven"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"put into it:"},{"kind":"text","text":"(TA:) or, applied to dough, and to clay or mud ("},{"kind":"arabic","text_bw":"Tiyn","text_ar":"طِين"},{"kind":"text","text":", as in the K, but accord. to other lexicons perfume,"},{"kind":"arabic","text_bw":"Tiyb","text_ar":"طِيب"},{"kind":"text","text":", TA), and the like,"},{"kind":"italic_en","text":"left until it has become good"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mature"},{"kind":"text","text":"]: (K:) pl. [of the first]"},{"kind":"arabic","text_bw":"xamoraY","text_ar":"خَمْرَى"},{"kind":"text","text":". (TA.) You say also"},{"kind":"arabic","text_bw":"xubozN xamiyrN","text_ar":"خُبْزٌ خَمِيرٌ"},{"kind":"italic_en","text":"Bread"},{"kind":"text","text":"["},{"kind":"italic_en","text":"leavened,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"into which leaven"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xamiyr","text_ar":"خَمِير"},{"kind":"text","text":")"},{"kind":"italic_en","text":"has been put:"},{"kind":"text","text":"(Lh, TA:) or"},{"kind":"italic_en","text":"yesterday's bread; bread that has been kept over a night:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"xubozapN xamiyrN","text_ar":"خُبْزَةٌ خَمِيرٌ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"[in the epithet]. (Lh, TA.) And"},{"kind":"arabic","text_bw":"xamiyrN","text_ar":"خَمِيرٌ"},{"kind":"text","text":"is also applied to"},{"kind":"italic_en","text":"Bread itself:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leavened bread."},{"kind":"text","text":"(Sh, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xamiyrN","text_ar":"خَمِيرٌ"},{"kind":"text","text":"[used as a subst.] (S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"xamiyrapN","text_ar":"خَمِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xumorapN","text_ar":"خُمْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, K) signify"},{"kind":"italic_en","text":"Leaven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ferment,"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"maA xum~ira bihi","text_ar":"مَا خُمِّرَ بِهِ"},{"kind":"text","text":", (K,) of dough, and of perfume; (TA;)"},{"kind":"italic_en","text":"what is put into dough,"},{"kind":"text","text":"(S, A, Msb,)"},{"kind":"italic_en","text":"and into the beverage called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":"; (A;) and ↓"},{"kind":"arabic","text_bw":"xumorapN","text_ar":"خُمْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"what is put into perfume,"},{"kind":"text","text":"as well as what is put into dough and into"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":": (Ks:) the"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":"is its"},{"kind":"italic_en","text":"dregs,"},{"kind":"text","text":"(K,) and its ["},{"kind":"italic_en","text":"ferment which is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"durodiY~","text_ar":"دُرْدِىّ"},{"kind":"text","text":"; (TA;) or"},{"kind":"italic_en","text":"what is put into it, of wine"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and of"},{"kind":"arabic","text_bw":"durodiY~","text_ar":"دُرْدِىّ"},{"kind":"text","text":"; and so too of perfume; (S;) and the"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"text","text":"of milk is its"},{"kind":"italic_en","text":"ferment"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ruwbap","text_ar":"رُوبَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"which is poured upon it in order that it may quickly curdle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coagulate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thicken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become thick and fit for churning."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"AijoEalohu fiY sir~i xamiyrika","text_ar":"اِجْعَلْهُ فِى سِرِّ خَمِيرِكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Conceal thou it"},{"kind":"text","text":"(i. e. a secret, A)"},{"kind":"italic_en","text":"in thy mind."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"A^axoraja mino sir~i xamiyrihi sir~FA","text_ar":"اَخْرَجَ مِنْ سِرِّ خَمِيرِهِ سِرًّا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He revealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disclosed, a secret."},{"kind":"text","text":"(TA.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"maxomuwrN","text_ar":"مَخْمُورٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA","Lh","S","A","Msb","Ks"]},{"entry_id":"n11490","headword_ar":"خِمِّيرٌ","root":"xmr","body":[{"kind":"text","text":"(S) and ↓"},{"kind":"arabic","text_bw":"musotaxomirN","text_ar":"مُسْتَخْمِرٌ","orth_type":"arrow"},{"kind":"text","text":"(K) One"},{"kind":"italic_en","text":"who constantly drinks wine;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"a great drinker; devoted to drink."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}