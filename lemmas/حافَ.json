text","text":",)"},{"kind":"italic_en","text":"beneath the tongue:"},{"kind":"text","text":"(O, Msb:) there are two veins of this description, called the"},{"kind":"arabic","text_bw":"HaAfaAni","text_ar":"حَافَانِ"},{"kind":"text","text":": (K:) accord. to some, the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"is with teshdeed. (TA.)"}],"source_refs":["O","Msb","K"]},{"entry_id":"n9761","headword_ar":"حَافَ","root":"Hyf","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHiyfu","text_ar":"يَحِيفُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"HayofN","text_ar":"حَيْفٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a judge, or any other person, Msb)"},{"kind":"italic_en","text":"acted wrongfully, unjustly, injuriously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tyrannically,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"against him:"},{"kind":"text","text":"(S:) or, as some say,"},{"kind":"italic_en","text":"he inclined"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to that which was wrong"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"declined"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from that which was right"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"in his judgment."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"Hayofu Aln~aAHili","text_ar":"حَيْفُ النَّاحِلِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A man's giving to certain of his children exclusively of others:"},{"kind":"text","text":"he should treat them equally, and not prefer some before others. (T, TA.)"}],"source_refs":["S","Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AD%D8%A7%D9%81/","headword_ar":"حَافّ","entries":[{"lexicon_id":"dictiona