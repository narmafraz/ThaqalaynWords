{"lemma":"لَبَّدَ","slug":"لَبَّدَ","root":"ل.ب.د","root_slug":"ل-ب-د","root_link":"/words/roots/ل-ب-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"لَبَّدْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"لَبَّدْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"لَبَّدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"لَبَّدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"لَبَّدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"لَبَّدَ","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"لَبَّدَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"لَبَّدا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"لَبَّدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"لَبَّدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"لَبَّدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُلَبِّد","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُلَبِّدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُلَبِّدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُلَبِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُلَبِّدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُلَبِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُلَبِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُلَبِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُلَبِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُلَبِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُلَبِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُلَبِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُلَبِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُلَبِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُلَبِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُلَبِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُلَبِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"لَبَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"لَبَّدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُلَبِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُلَبِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"لَبَّدَ","root":"لبد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n37478","n37481","n37482","n37483","n37484","n37485"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D8%A8%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"felt","examples":[{"text":"ومن أرمينية وأذربيجان: اللُّبُود … والبراذع والفُرُش والبُسُط الرِّقاق والتِّكَك والصوف.","english":"And from Armenia and Azerbayjān one gets felts, … (something unreadable) pack-saddles, furnishing fabrics, fine carpets, girdles, and wool."}]},{"pos":"noun","gloss":"wool"},{"pos":"adj","gloss":"clinging firmly together, compact or coherent"},{"pos":"noun","gloss":"plural of لِبْدَة (libda, “felt-cap; the hair collected at the neck of a lion, mane”)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of لُبْدَة (lubda, “mane”)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to stick, to cling, to adhere"},{"pos":"verb","gloss":"to cause to stick together, to fix upon"},{"pos":"verb","gloss":"to cover or mat with felt or wool, to make a felt structure"},{"pos":"verb","gloss":"to waulk, to full"}]},"etymology":{"source":"wiktextract","text":"Borrowed from Aramaic לִיבְדָּא (liḇdā, “felt”), with everything else under the root from this noun, as sensibly also Classical Syriac ܠܒܕ (“to compact, to press together”) and related verb stems."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37478","headword_ar":"لَبِدَ","root":"lbd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"labadN","text_ar":"لَبَدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"stuck, clave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adhered."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"labada biAlA^aroDi","text_ar":"لَبَدَ بِالاَرْضِ"},{"kind":"text","text":", aor,"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lubuwdN","text_ar":"لُبُودٌ"},{"kind":"text","text":"; (S, L;) and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Albd","text_ar":"البد","orth_type":"arrow"},{"kind":"text","text":"; (L;) and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tlb~d","text_ar":"تلبّد","orth_type":"arrow"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"stuck, clave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adhered, to the ground."},{"kind":"text","text":"(S, L.) ―         -b3-"},{"kind":"arabic","text_bw":"biAlA^aroDi","text_ar":"بِالاَرْضِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tlb~d","text_ar":"تلبّد","orth_type":"arrow"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bird)"},{"kind":"italic_en","text":"lay upon his breast, cleaving to the ground."},{"kind":"text","text":"(S, L, K.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"He clave to the ground, concealing his person."},{"kind":"text","text":"(A.) ―         -b5-  Hence the proverb"},{"kind":"arabic","text_bw":"taSay~adiY","text_ar":"تَصَيَّدِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"talab~adiY","text_ar":"تَلَبَّدِى","orth_type":"arrow"},{"kind":"text","text":", [for"},{"kind":"arabic","text_bw":"tataSay~adiY","text_ar":"تَتَصَيَّدِى"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Cleave thou"},{"kind":"text","text":"(addressed to a female)"},{"kind":"italic_en","text":"to the ground: thou wilt take,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"catch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"snare,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entrap, game"},{"kind":"text","text":"]. (A.) ―         -b6-  Hence also, ↓"},{"kind":"arabic","text_bw":"tlb~d","text_ar":"تلبّد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He remained fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, and looked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"considered."},{"kind":"text","text":"(A.) ―         -b7-"},{"kind":"arabic","text_bw":"labada biAlmakaAni","text_ar":"لَبَدَ بِالمَكَانِ"},{"kind":"text","text":", (L, K, *) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lubuwdN","text_ar":"لُبُودٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"labida","text_ar":"لَبِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"labadN","text_ar":"لَبَدٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"Albd","text_ar":"البد","orth_type":"arrow"},{"kind":"text","text":"; (S, L, K;;) (tropical:)"},{"kind":"italic_en","text":"He remained, continued, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, in the place;"},{"kind":"text","text":"(S, L, K; *)"},{"kind":"italic_en","text":"and clave to it."},{"kind":"text","text":"(L, K. *) ―         -b8-"},{"kind":"arabic","text_bw":"labada EalaY EaSaAhu","text_ar":"لَبَدَ عَلَى عَصَاهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lubuwdN","text_ar":"لُبُودٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a pastor)"},{"kind":"italic_en","text":"leaned upon his staff, remaining fixed to his place."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"labida","text_ar":"لَبِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L,) inf. n."},{"kind":"arabic","text_bw":"labadN","text_ar":"لَبَدٌ"},{"kind":"text","text":", (S, L, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"became choked by eating much of the plant called"},{"kind":"arabic","text_bw":"Sil~iyaAn","text_ar":"صِلِّيَان"},{"kind":"text","text":","},{"kind":"italic_en","text":"suffering a contortion in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"part of the chest called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hayozuwm","text_ar":"حَيْزُوم"},{"kind":"italic_en","text":"and in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"part of the throat called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"galoSamap","text_ar":"غَلْصَمَة"},{"kind":"text","text":": (ISk, S, L, K: *) or"},{"kind":"italic_en","text":"had a complaint of the belly from eating of the"},{"kind":"arabic","text_bw":"qataAd","text_ar":"قَتَاد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tragacantha"},{"kind":"text","text":"]. (AHn, L.) ―         -b10-  See 4."}],"source_refs":["S","L","K"]},{"entry_id":"n37481","headword_ar":"لِبْدٌ","root":"lbd","body":[{"kind":"italic_en","text":"Hair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wool commingled, and compacted together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coherent;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"felt;"},{"kind":"text","text":"] (L, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (L, K;) or this is a more particular term; [meaning"},{"kind":"italic_en","text":"a portion of such hair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wool; a piece of felt;"},{"kind":"text","text":"] (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"lubodapN","text_ar":"لُبْدَةٌ","orth_type":"arrow"},{"kind":"text","text":": (L, K:) pl. of"},{"kind":"arabic","text_bw":"libodN","text_ar":"لِبْدٌ"},{"kind":"text","text":", (or of"},{"kind":"arabic","text_bw":"lbdp","text_ar":"لبدة"},{"kind":"text","text":", as though the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"were imagined to be elided, M,)"},{"kind":"arabic","text_bw":"lubuwdN","text_ar":"لُبُودٌ"},{"kind":"text","text":"(S, A, L, K) and"},{"kind":"arabic","text_bw":"A^alobaAdN","text_ar":"اَلْبَادٌ"},{"kind":"text","text":". (L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"libodN","text_ar":"لِبْدٌ"},{"kind":"italic_en","text":"A well-known kind of carpet"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and cloth, made of felt"},{"kind":"text","text":"]. (L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"libodN","text_ar":"لِبْدٌ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ"},{"kind":"text","text":", (S, art."},{"kind":"arabic","text_bw":"wvr","text_ar":"وثر"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"What is beneath the saddle;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a saddle-cloth; a housing; a cloth of felt, which is placed beneath the saddle, and also used as a covering without the saddle"},{"kind":"text","text":"]. (S, * L, * K.)"}],"source_refs":["L","K","S","A"]},{"entry_id":"n37482","headword_ar":"لَبَدٌ","root":"lbd","body":[{"kind":"italic_en","text":"Wool."},{"kind":"text","text":"(S, K.) Hence the saying"},{"kind":"arabic","text_bw":"maA lahu","text_ar":"مَا لَهُ"},{"kind":"arabic","text_bw":"sabadN walaA labadN","text_ar":"سَبَدٌ وَلَا لَبَدٌ"},{"kind":"italic_en","text":"He has neither hair nor wool:"},{"kind":"text","text":"(S:) or,"},{"kind":"italic_en","text":"neither what has hair nor what has wool:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"neither little nor much:"},{"kind":"text","text":"(TA:) or,"},{"kind":"italic_en","text":"he has not anything:"},{"kind":"text","text":"(S:) for the wealth of the Arabs consisted of horses, camels, sheep and goats, and cows; and all of these are included in this saying (TA.) See also"},{"kind":"arabic","text_bw":"sabadN","text_ar":"سَبَدٌ"},{"kind":"text","text":"."}],"source_refs":["S","TA"]},{"entry_id":"n37483","headword_ar":"لبد","root":"lbd","body":[{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"labidN","text_ar":"لَبِدٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cohering,"},{"kind":"text","text":"ground, upon which one may walk, or journey, quickly. (L.)"}],"source_refs":[]},{"entry_id":"n37484","headword_ar":"لَبِدٌ","root":"lbd","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"lubadN","text_ar":"لُبَدٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, L, K,) the former of which is preferable, accord. to A'Obeyd, (S,) (tropical:)  One"},{"kind":"italic_en","text":"who does not travel,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"nor quit his abode,"},{"kind":"text","text":"(S, * L, K,) or"},{"kind":"italic_en","text":"place,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"nor seek sustenance."},{"kind":"text","text":"(L, K.) Hence, (A,) the last of Lukmán's [seven] vultures [with whose life his own was to terminate] was called ↓"},{"kind":"arabic","text_bw":"lubadN","text_ar":"لُبَدٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, L, K,) because he thought that is would not go away nor die. (L.) Thus applied, it is perfectly decl., because it is a word not made to deviate from its original form. (S, L.) ―         -b2-  Also ↓"},{"kind":"arabic","text_bw":"lubadN","text_ar":"لُبَدٌ","orth_type":"arrow"},{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who does not quit his camel's saddle."},{"kind":"text","text":"(L.)"}],"source_refs":["S","K","A","L"]},{"entry_id":"n37485","headword_ar":"لُبَدٌ","root":"lbd","body":[{"kind":"text","text":"(S, L) and"},{"kind":"arabic","text_bw":"libadN","text_ar":"لِبَدٌ"},{"kind":"text","text":", which is pl. of ↓"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"lub~adaY","text_ar":"لُبَّدَى","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"lubodapN","text_ar":"لُبْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) (tropical:)  A number of men"},{"kind":"italic_en","text":"collected together,"},{"kind":"text","text":"(S, L, K,)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as it were"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"compacted, one upon another:"},{"kind":"text","text":"so the first and second of these words, accord. to different readings, signify in the Kur., lxxii., 19: (L:) or"},{"kind":"arabic","text_bw":"libadN","text_ar":"لِبَدٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"collected together like locusts,"},{"kind":"text","text":"(T, L,) which are app. thus called as being likened to a congregation of men; (ISd, L;) pl. of"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ"},{"kind":"text","text":", (L,) which signifies"},{"kind":"italic_en","text":"a locust."},{"kind":"text","text":"(K.) [See a verse cited voce"},{"kind":"arabic","text_bw":"SaAba","text_ar":"صَابَ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"maAlN lubadN","text_ar":"مَالٌ لُبَدٌ"},{"kind":"text","text":", (S, A, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"lub~adN","text_ar":"لُبَّدٌ","orth_type":"arrow"},{"kind":"text","text":", (Aboo-Jaafar, K,) and ↓"},{"kind":"arabic","text_bw":"lubudN","text_ar":"لُبُدٌ","orth_type":"arrow"},{"kind":"text","text":", (El-Hasan and Mujáhid,) and ↓"},{"kind":"arabic","text_bw":"lubodN","text_ar":"لُبْدٌ","orth_type":"arrow"},{"kind":"text","text":", (Mujáhid,) (tropical:)"},{"kind":"italic_en","text":"Much wealth;"},{"kind":"text","text":"(S, K, &c.;) so in the Kur., xc., 6; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"laAbidN","text_ar":"لَابِدٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"wealth so abundant that one fears not its coming to an end:"},{"kind":"text","text":"(A, L:) some say that"},{"kind":"arabic","text_bw":"lubadN","text_ar":"لُبَدٌ"},{"kind":"text","text":"is a pl., and that its sing. is"},{"kind":"arabic","text_bw":"lubodapN","text_ar":"لُبْدَةٌ"},{"kind":"text","text":": others, that it is sing., like"},{"kind":"arabic","text_bw":"quvamN","text_ar":"قُثَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuSamN","text_ar":"حُصَمٌ"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"A^amowaAlN","text_ar":"اَمْوَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maAlN","text_ar":"مَالٌ"},{"kind":"text","text":"are sometimes used in the same sense:"},{"kind":"arabic","text_bw":"lub~adN","text_ar":"لُبَّدٌ"},{"kind":"text","text":"seems to be pl. of"},{"kind":"arabic","text_bw":"laAbidN","text_ar":"لَابِدٌ"},{"kind":"text","text":": (L:) so is"},{"kind":"arabic","text_bw":"lubudN","text_ar":"لُبُدٌ"},{"kind":"text","text":", and so"},{"kind":"arabic","text_bw":"lubodN","text_ar":"لُبْدٌ"},{"kind":"text","text":": (El-Basáïr:) also,"},{"kind":"arabic","text_bw":"mAl libadN","text_ar":"مال لِبَدٌ"},{"kind":"text","text":", which is accord. to the reading of Zeyd Ibn-'Alee and Ibn-'Omeyr and 'Ásim, signifies"},{"kind":"italic_en","text":"collected wealth;"},{"kind":"arabic","text_bw":"libadN","text_ar":"لِبَدٌ"},{"kind":"text","text":"being pl. of"},{"kind":"arabic","text_bw":"libodapN","text_ar":"لِبْدَةٌ"},{"kind":"text","text":". (TA.)       -A2-  See"},{"kind":"arabic","text_bw":"lubadN","text_ar":"لُبَدٌ"},{"kind":"text","text":"."}],"source_refs":["S","L","K","T","A"]}]}}