ا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَعَزَّزُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَعَزَّزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَعَزَّز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَعَزَّز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَعَزَّزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَعَزَّزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَعَزَّزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَعَزَّزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَعَزَّزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَعَزَّزُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَعَزَّزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَتَعَزَّز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَعَزَّز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"تَعَزَّزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تَعَزَّزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n28913"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D8%B2%D9%8E%D9%91%D8%B2%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28913","headword_ar":"تعزّز","root":"Ez","body":[{"kind":"text","text":": see 1, first quarter, in four places. [It is sometimes changed to"},{"kind":"arabic","text_bw":"tEz~Y","text_ar":"تعزّى"},{"kind":"text","text":".] It is said in a trad.,"},{"kind":"arabic","text_bw":"mano lamo yataEaz~a biEiz~i A@ll~`hi falayosa min~aA","text_ar":"مَنْ لَمْ يَتَعَزَّ بِعِزِّ ا@للّٰهِ فَلَيْسَ مِنَّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such as does not strengthen himself by the strength of God, he is not of us"},{"kind":"text","text":"]; expl. by Th as meaning"},{"kind":"italic_en","text":"he who does not refer his affair to God is not of us."},{"kind":"text","text":"(TA. [See another reading voce"},{"kind":"arabic","text_bw":"taEaz~aY","text_ar":"تَعَزَّى"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"EzY","text_ar":"عزى"},{"kind":"text","text":".]) You say also,"},{"kind":"arabic","text_bw":"taEaz~ayotu Eanohu","text_ar":"تَعَزَّيْتُ عَنْهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I constrained myself to endure the loss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with patience;"},{"kind":"text","text":"originally"},{"kind":"arabic","text_bw":"taEaz~azotu","text_ar":"تَعَزَّزْتُ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"I exerted my strength"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"energy"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to divert myself from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; like"},{"kind":"arabic","text_bw":"taZan~ayotu","text_ar":"تَظَنَّيْتُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"taZan~anotu","text_ar":"تَظَنَّنْتُ"},{"kind":"text","text":". (TA.) [But see art."},{"kind":"arabic","text_bw":"EzY","text_ar":"عزى"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"He magnified and hardened himself; he behaved in a proud and hard manner,"},{"kind":"text","text":"towards others. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"tEz~z bihi","text_ar":"تعزّز بِهِ"},{"kind":"italic_en","text":"He gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prided himself, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of, him"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; (TA;) as also"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AEtz~","text_ar":"اعتزّ","orth_type":"arrow"},{"kind":"text","text":"; (O, TA;) [and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstEz~","text_ar":"استعزّ","orth_type":"arrow"},{"kind":"text","text":".] ―         -b4-"},{"kind":"arabic","text_bw":"tEz~z laHomu Aln~aAqapi","text_ar":"تعزّز لَحْمُ النَّاقَةِ"},{"kind":"italic_en","text":"The flesh of the she-camel became hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough."},{"kind":"text","text":"(S, * A, O, * L, K. *) ―         -b5-"},{"kind":"arabic","text_bw":"tEz~zt","text_ar":"تعزّزت"},{"kind":"text","text":"said of a camel and of a ewe: see 1, last sentence."}],"source_refs":[]}]},"classical_definitions":null}