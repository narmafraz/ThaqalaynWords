rences":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n34946"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D8%B4%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of فَشَا (fašā)","tags":["active","form-of","participle"]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of فَشَا (fašā, “to disperse”)."},"ipa":["/faː.ʃin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34946","headword_ar":"فَاشَ","root":"fy$","body":[{"kind":"text","text":", (O, K,) aor."},{"kind":"arabic","text_bw":"yafiy$u","text_ar":"يَفِيشُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayo$N","text_ar":"فَيْشٌ"},{"kind":"text","text":", (O, TA,)"},{"kind":"italic_en","text":"He gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"and magnified himself, imagining"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in himself"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what he did not possess;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"fa$~a","text_ar":"فَشَّ"},{"kind":"text","text":"; like as you say"},{"kind":"arabic","text_bw":"*aAma","text_ar":"ذَامَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*iymu","text_ar":"يَذِيمُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"*am~a","text_ar":"ذَمَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*um~u","text_ar":"يَذُمُّ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"he was boastful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proud, pretending to possess a thing and not being as he pretended;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"fAy$","text_ar":"فايش","orth_type":"arrow"},{"kind":"text","text":"[signifies the same; or]"},{"kind":"italic_en","text":"he gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted, vainly, and praised himself for that which was not in him."},{"kind":"text","text":"(AHeyth, in L, art."},{"kind":"arabic","text_bw":"Trm*","text_ar":"طرمذ"},{"kind":"text","text":".) [See also 5.]       -A2-"},{"kind":"arabic","text_bw":"fA$ AlA^ataAna","text_ar":"فاش الاَتَانَ"},{"kind":"text","text":", aor. as above, (IDrd, O, K,) and so the inf. n. (IDrd, O,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the ass)"},{"kind":"italic_en","text":"mounted the she-ass:"},{"kind":"text","text":"(IDrd:) said by Yoo to be from"},{"kind":"arabic","text_bw":"Alfayo$apu","text_ar":"الفَيْشَةُ"},{"kind":"text","text":". (O, K. *)"}],"source_refs":["O","K","TA","IDrd"]}]},"classical_definitions":null}