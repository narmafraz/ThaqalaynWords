","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتِيهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتُهْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَتِهْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"تِهْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تِهْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تُهْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تُهْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتُوه","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتُوه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتِيه","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتِيه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n4210","n4265"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D8%A7%D9%87%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lose one's way"},{"pos":"verb","gloss":"to perish"},{"pos":"verb","gloss":"to depart and disappear"},{"pos":"verb","gloss":"to wander"},{"pos":"verb","gloss":"to wander in mind, to be confused in mind, to be absent-minded"},{"pos":"verb","gloss":"to lose one's way","examples":[{"text":"قَالَ فَإِنَّهَا مُحَرَّمَةٌ عَلَيْهِمْ أَرْبَعِينَ سَنَةً يَتِيهُونَ فِي الْأَرْضِ","english":"[God] said \"Then indeed, it is forbidden to them for forty years in which they will wander throughout the land."}]},{"pos":"verb","gloss":"to perish"},{"pos":"verb","gloss":"to depart and disappear"},{"pos":"verb","gloss":"to wander"},{"pos":"verb","gloss":"to wander in mind, to be confused in mind, to be absent-minded"},{"pos":"verb","gloss":"to be proud, haughty, supercilious"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4210","headword_ar":"تَاهَ","root":"twh","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yatuwhu","text_ar":"يَتُوهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tawo'N","text_ar":"تَوْءٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"tuwhN","text_ar":"تُوهٌ"},{"kind":"text","text":", (AZ, K,) is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"italic_en","text":"having for its aor."},{"kind":"arabic","text_bw":"yatiyhu","text_ar":"يَتِيهُ"},{"kind":"text","text":"; (Msb, and TA in the present art. and in art."},{"kind":"arabic","text_bw":"tyh","text_ar":"تيه"},{"kind":"text","text":";) [and with"},{"kind":"arabic","text_bw":"TaAHa","text_ar":"طَاحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTuwHu","text_ar":"يَطُوحُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaTiyHu","text_ar":"يَطِيحُ"},{"kind":"text","text":";] signifying"},{"kind":"italic_en","text":"He deviated from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"missed, the right way; he lost his way;"},{"kind":"text","text":"(Msb, TA;) in the desert: (Msb:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unable to see his right course:"},{"kind":"text","text":"(TA in the present art.:) or"},{"kind":"italic_en","text":"he went away"},{"kind":"text","text":"(K, TA) in the land,"},{"kind":"italic_en","text":"confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unable to see his right course:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"tyh","text_ar":"تيه"},{"kind":"text","text":":) or, as some say, (TA,)"},{"kind":"italic_en","text":"his mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disordered, confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"italic_en","text":"he perished:"},{"kind":"text","text":"(K TA:) accord. to ISd, the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"yatiyhu","text_ar":"يَتِيهُ"},{"kind":"text","text":"is shown to be originally"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"by their saying,"},{"kind":"arabic","text_bw":"maA A^atowahahu","text_ar":"مَا اَتْوَهَهُ"},{"kind":"text","text":", as syn. with"},{"kind":"arabic","text_bw":"maA A^atoyahahu","text_ar":"مَا اَتْيَهَهُ"},{"kind":"text","text":". (TA.) AZ says, A man of the Benoo-Kiláb said to me,"},{"kind":"arabic","text_bw":"A^aloqayotaniY fiY Alt~uwhi","text_ar":"اَلْقَيْتَنِى فِى التُّوهِ"},{"kind":"text","text":", with damm, meaning ["},{"kind":"italic_en","text":"Thou hast thrown me into"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"destruction."},{"kind":"text","text":"(TA.) ―         -b2-  Also, [like"},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"text","text":"aor."},{"kind":"arabic","text_bw":"yatiyhu","text_ar":"يَتِيهُ"},{"kind":"text","text":", q. v.,]"},{"kind":"italic_en","text":"He magnified himself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved proudly, haughtily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insolently."},{"kind":"text","text":"(K.)"}],"source_refs":["Msb","K","AZ","TA"]},{"entry_id":"n4265","headword_ar":"تَاهَ","root":"tyn","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"arabic","text_bw":"yatiyhu","text_ar":"يَتِيهُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"tiyhN","text_ar":"تِيهٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"tayohN","text_ar":"تَيْهٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"tayahaAnN","text_ar":"تَيَهَانٌ"},{"kind":"text","text":", (S, K,) is"},{"kind":"italic_en","text":"syn. with taAha having for its aor."},{"kind":"arabic","text_bw":"yatuwhu","text_ar":"يَتُوهُ"},{"kind":"text","text":"; (Msb, TA;) [and with"},{"kind":"arabic","text_bw":"TaAHa","text_ar":"طَاحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTiyHu","text_ar":"يَطِيحُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaTuwHu","text_ar":"يَطُوحُ"},{"kind":"text","text":";] signifying"},{"kind":"italic_en","text":"He deviated from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"missed, the right way; he lost his way;"},{"kind":"text","text":"(Mgh, Msb, K, TA;) in the desert: (Mgh, Msb:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course:"},{"kind":"text","text":"(Mgh:)"},{"kind":"italic_en","text":"he went away"},{"kind":"text","text":"in the land,"},{"kind":"italic_en","text":"confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course:"},{"kind":"text","text":"(S, TA:) [or"},{"kind":"italic_en","text":"his mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disordered, confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"twh","text_ar":"توه"},{"kind":"text","text":":)] and"},{"kind":"italic_en","text":"he perished."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"twh","text_ar":"توه"},{"kind":"text","text":".) You say also,"},{"kind":"arabic","text_bw":"taAhato bihi safiynatuhu","text_ar":"تَاهَتْ بِهِ سَفِينَتُهُ"},{"kind":"italic_en","text":"His ship deviated from the right course with him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"taAha Ean~iY baSaruka","text_ar":"تَاهَ عَنِّى بَصَرُكَ"},{"kind":"italic_en","text":"Thine eye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy sight, passed me over;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taxaT~aY","text_ar":"تَخَطَّى"},{"kind":"text","text":". (Aboo-Turáb, TA.)"},{"kind":"arabic","text_bw":"taAha baSarahu","text_ar":"تَاهَ بَصَرَهُ"},{"kind":"text","text":"[in the CK, erroneously,"},{"kind":"arabic","text_bw":"qaSoruhu","text_ar":"قَصْرُهُ"},{"kind":"text","text":"] signifies also"},{"kind":"arabic","text_bw":"taAfa","text_ar":"تَافَ"},{"kind":"text","text":", (K, TA, [in the CK"},{"kind":"arabic","text_bw":"nAfa","text_ar":"نافَ"},{"kind":"text","text":",] i. e., accord. to 'Arrám,"},{"kind":"italic_en","text":"He looked at a thing continually,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuously"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"fiY dawaAmK","text_ar":"فِى دَوَامٍ"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"as one confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see aright"},{"kind":"text","text":"]). (Aboo-Turáb, TA.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"arabic","text_bw":"yatiyhu","text_ar":"يَتِيهُ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"tiyhN","text_ar":"تِيهٌ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"tiyahN","text_ar":"تِيَهٌ"},{"kind":"text","text":"is said to be a dial. var. of this, but is doubtful; (MF;) [like"},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"text","text":"having for its aor."},{"kind":"arabic","text_bw":"yatuwhu","text_ar":"يَتُوهُ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"He magnified himself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved proudly, haughtily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insolently:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"he affected to be commended for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"praised for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he gloried in, that which he did not possess;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, conceited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain-glorious;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he overpassed the due bounds in elegance of mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manners"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"address"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attire"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like, and arrogated to himself superiority therein, through pride:"},{"kind":"text","text":"(K:) [or rather,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vain;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he behaved vainly:"},{"kind":"text","text":"for] Er-Rághib makes a distinction between"},{"kind":"arabic","text_bw":"muEojabN","text_ar":"مُعْجَبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taAy^ihN","text_ar":"تَايِهٌ"},{"kind":"text","text":"; saying that the"},{"kind":"arabic","text_bw":"mEjb","text_ar":"معجب"},{"kind":"text","text":"believes himself with respect to the opinion or judgment that he forms of himself indecisively, from evidence outweighed in probability; whereas the"},{"kind":"arabic","text_bw":"tAy^h","text_ar":"تايه"},{"kind":"text","text":"believes himself decisively. (MF and TA in art."},{"kind":"arabic","text_bw":"Ejb","text_ar":"عجب"},{"kind":"text","text":".) One says,"},{"kind":"arabic","text_bw":"huwa yatiyhu EalaY qawomihi","text_ar":"هُوَ يَتِيهُ عَلَى قَوْمِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He behaves proudly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceitedly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vainly, towards his people"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Mgh","Msb","K","TA"]}]}}