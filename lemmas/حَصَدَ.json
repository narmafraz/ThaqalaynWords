s_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n8193"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B5%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to harvest, to reap"},{"pos":"verb","gloss":"to mow"},{"pos":"noun","gloss":"verbal noun of حَصَدَ (ḥaṣada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of حَصَدَ (ḥaṣada) (form I); mowing, reaping"}]},"etymology":{"source":"wiktextract","text":"Borrowed from Classical Syriac ܚܨܕ (ḥṣeḏ) or back-formed from حَصَّاد (ḥaṣṣād, “reaper”) borrowed from Syriac ܚܳܨܽܘܕܳܐ (ḥaṣṣāḏā), now belonging to a productive root ح ص د (ḥ ṣ d). Doublet of native Arabic خَضَدَ (ḵaḍada, “to cut off”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8193","headword_ar":"حَصَدَ","root":"HSd","body":[{"kind":"text","text":", (S, A, Mgh, &c.,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaSodN","text_ar":"حَصْدٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"HaSaAdN","text_ar":"حَصَادٌ"},{"kind":"text","text":"(Lh, Mgh, K) and"},{"kind":"arabic","text_bw":"HiSaAdN","text_ar":"حِصَادٌ"},{"kind":"text","text":", (Lh, K,)"},{"kind":"italic_en","text":"He reaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut"},{"kind":"text","text":"(A, Mgh, K)"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"minojal","text_ar":"مِنْجَل"},{"kind":"text","text":", (K,) seed-produce, (S, A, Mgh, Msb, K,) and plants, or herbage; (S, * K;) originally used in relation to seed-produce; (TA;) as also ↓"},{"kind":"arabic","text_bw":"AHtSd","text_ar":"احتصد","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HaSadahumo","text_ar":"حَصَدَهُمْ"},{"kind":"arabic","text_bw":"biAls~ayofi","text_ar":"بِالسَّيْفِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He reaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mowed, them down with the sword"},{"kind":"text","text":"]: (A:)"},{"kind":"italic_en","text":"he slew them:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he exerted his utmost power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exceeded the ordinary bounds, in slaying them:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he exterminated them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with the sword"},{"kind":"text","text":"]. (Msb, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"mano zaraEa Al$~ar~a HaSada Aln~adaAmapa","text_ar":"مَنْ زَرَعَ الشَّرَّ حَصَدَ النَّدَامَةَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He who sows evil reaps repentance"},{"kind":"text","text":"]. (A.)       -A2-"},{"kind":"arabic","text_bw":"HaSida","text_ar":"حَصِدَ"},{"kind":"text","text":", (L,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"HaSadN","text_ar":"حَصَدٌ"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a rope, and a bow-string,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strongly twisted, and firmly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compactly, made;"},{"kind":"text","text":"(L, K; *) as also ↓"},{"kind":"arabic","text_bw":"AstHSd","text_ar":"استحصد","orth_type":"arrow"},{"kind":"text","text":": (S, * A, L, K: *) and it (a coat of mail)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"close in its rings,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"HaSida","text_ar":"حَصِدَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"firm, and compactly made."},{"kind":"text","text":"(L, K. *)"}],"source_refs":["S","Mgh","Msb","K","Lh","A","TA","L"]}]}}