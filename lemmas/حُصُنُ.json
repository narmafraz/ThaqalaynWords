{"lemma":"حُصُنُ","slug":"حُصُنُ","root":"ح.ص.ن","root_slug":"ح-ص-ن","root_link":"/words/roots/ح-ص-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n8267","n8271"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D8%B5%D9%8F%D9%86%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"horse"},{"pos":"noun","gloss":"stallion, stud, sire"},{"pos":"noun","gloss":"knight"},{"pos":"noun","gloss":"horsepower"}]},"etymology":null,"ipa":["/ħi.sˤaːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8267","headword_ar":"حَصُنَ","root":"HSn","body":[{"kind":"text","text":", (Mgh, Msb, K,) aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"HaSaAnapN","text_ar":"حَصَانَةٌ"},{"kind":"text","text":", (S, Mgh, Msb, TA,) said of a"},{"kind":"arabic","text_bw":"HiSon","text_ar":"حِصْن"},{"kind":"text","text":"[or fortress], (S,) or of a place, (Mgh, Msb, TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"manuEa","text_ar":"مَنُعَ"},{"kind":"text","text":", [for which the CK erroneously substitutes"},{"kind":"arabic","text_bw":"wamanaEa","text_ar":"وَمَنَعَ"},{"kind":"text","text":", after"},{"kind":"arabic","text_bw":"kakaruma","text_ar":"كَكَرُمَ"},{"kind":"text","text":", as though the verb were"},{"kind":"arabic","text_bw":"HaSuna","text_ar":"حَصُنَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaSana","text_ar":"حَصَنَ"},{"kind":"text","text":",] (K, TA,) [i. e.]"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"maniyE","text_ar":"مَنِيع"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"inaccessible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unapproachable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult of access"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unattainable, by reason of its height;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"it was fortified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected against attack, so that one could not gain access to what was within it."},{"kind":"text","text":"(Mgh.) ―         -b2-  Hence, (Mgh,)"},{"kind":"arabic","text_bw":"HaSunato","text_ar":"حَصُنَتْ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HuSonN","text_ar":"حُصْنٌ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"HaSonN","text_ar":"حَصْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HiSonN","text_ar":"حِصْنٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"HaSaAnapN","text_ar":"حَصَانَةٌ"},{"kind":"text","text":"; (S, * Msb, * TA;) and ↓"},{"kind":"arabic","text_bw":"A^aHoSanato","text_ar":"اَحْصَنَتْ","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, K,) inf. n."},{"kind":"arabic","text_bw":"A_iHoSaAnN","text_ar":"اـِحْصَانٌ"},{"kind":"text","text":"; (Mgh;) and ↓"},{"kind":"arabic","text_bw":"tHS~nt","text_ar":"تحصّنت","orth_type":"arrow"},{"kind":"text","text":"; (K;) said of a woman,"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, continent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chaste;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she abstained from what was not lawful nor decorous;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Eaf~ato","text_ar":"عَفَّتْ"},{"kind":"text","text":": (S, Mgh, Msb, K:) or"},{"kind":"italic_en","text":"she was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, married;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she had a husband;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"HaSanato","text_ar":"حَصَنَتْ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^uHoSinato","text_ar":"اُحْصِنَتْ","orth_type":"arrow"},{"kind":"text","text":": (Ham p. 101, in which"},{"kind":"arabic","text_bw":"HaSunato","text_ar":"حَصُنَتْ"},{"kind":"text","text":"is likewise mentioned in this sense:) or ↓"},{"kind":"arabic","text_bw":"A^aHoSanato","text_ar":"اَحْصَنَتْ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"she was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, pregnant;"},{"kind":"text","text":"(K;) as though pregnancy protected her from a man's going in to her. (TA.)       -A2-"},{"kind":"arabic","text_bw":"HaSanahu","text_ar":"حَصَنَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaSonN","text_ar":"حَصْنٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He preserved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarded, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in places inaccessible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unapproachable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult of access, as in a"},{"kind":"arabic","text_bw":"HiSon","text_ar":"حِصْن"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fortress"},{"kind":"text","text":"]. (TA.) [See also 2 and 4.]"}],"source_refs":["Mgh","Msb","K","TA","S"]},{"entry_id":"n8271","headword_ar":"حِصْنٌ","root":"HSn","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A fortress; a fort; a fortified place;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a place of which the interior is inaccessible;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"any place that is fortified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected against attack, so that one cannot gain access to what is within it;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"a place that is unattainable, by reason of its height;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"a fortified city:"},{"kind":"text","text":"(TA:) pl. [of mult.]"},{"kind":"arabic","text_bw":"HuSuwnN","text_ar":"حُصُونٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"HiSanapN","text_ar":"حِصَنَةٌ"},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^aHoSaAnN","text_ar":"اَحْصَانٌ"},{"kind":"text","text":". (K.) [Hence,]"},{"kind":"arabic","text_bw":"A^abuw AlHiSoni","text_ar":"اَبُو الحِصْنِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^abuw AlHuSayni","text_ar":"اَبُو الحُصَينِ"},{"kind":"text","text":", below. [Hence, also,]"},{"kind":"arabic","text_bw":"xayolu AlEarabi HuSuwnuhaA *ukuruhaA waA_inaAvuhaA","text_ar":"خَيْلُ العَرَبِ حُصُونُهَا ذُكُرُهَا وَاـِنَاثُهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The horses of the Arabs are their"},{"kind":"arabic","text_bw":"HuSuwn","text_ar":"حُصُون"},{"kind":"text","text":";"},{"kind":"italic_en","text":"the males thereof and the females thereof"},{"kind":"text","text":"]. (TA.) A man said to 'Abd-Allah Ibn-El-Hasan, “ My father has left the third of his property for the"},{"kind":"arabic","text_bw":"HuSuwn","text_ar":"حُصُون"},{"kind":"text","text":": ” and he replied “ Buy thou horses: ” so in the A: in the M, “ Buy thou therewith horses, and mount [men] on them [to fight] in the cause of God. ” (TA.) ―         -b2-  [Hence, also,] (tropical:)"},{"kind":"italic_en","text":"Arms."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"jaA='a yaHomilu HiSonFA","text_ar":"جَا=ءَ يَحْمِلُ حِصْنًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He came bearing arms."},{"kind":"text","text":"(TA.) ―         -b3-  Also The ["},{"kind":"italic_en","text":"new moon;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"moon when it is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hilaAl","text_ar":"هِلَال"},{"kind":"text","text":": in the K,"},{"kind":"arabic","text_bw":"AlhalaAku","text_ar":"الهَلَاكُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"AlhilaAlu","text_ar":"الهِلَالُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["TA","S","Msb","K"]}]}}