s":["n23454","n23455","n23456"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%8A%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"grey hair","tags":["uncountable"],"examples":[{"text":"قَالَ رَبِّ إِنِّي وَهَنَ ٱلْعَظْمُ مِنِّي وَٱشْتَعَلَ ٱلرَّأْسُ شَيْبًا"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23454","headword_ar":"شَيْبٌ","root":"$yb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"hair"},{"kind":"text","text":"(K, TA) itself: sometimes it is thus called: (TA:) [but app. only"},{"kind":"italic_en","text":"when white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary;"},{"kind":"text","text":"in which sense it is often used; as in the TA in arts."},{"kind":"arabic","text_bw":"xDb","text_ar":"خضب"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Sbg","text_ar":"صبغ"},{"kind":"text","text":"&c.:] or (K, TA, in the CK “ and ”)"},{"kind":"italic_en","text":"whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness;"},{"kind":"text","text":"(A, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"ma$iybN","text_ar":"مَشِيبٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) both signify the same [and are thus used as simple substs. and are also inf. ns.]: (S:) or the former has the latter of the two significations given above; (As, S, Mgh, Msb;) and is"},{"kind":"italic_en","text":"little"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"much"},{"kind":"text","text":"["},{"kind":"italic_en","text":"whiteness of the hair"},{"kind":"text","text":"]: one says,"},{"kind":"arabic","text_bw":"EalaAhu Al$~ayobu","text_ar":"عَلَاهُ الشَّيْبُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, came upon him"},{"kind":"text","text":"]: (TA:) but ↓"},{"kind":"arabic","text_bw":"ma$iybN","text_ar":"مَشِيبٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a man's"},{"kind":"italic_en","text":"entering upon the period of whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness:"},{"kind":"text","text":"(As, S, Msb:) see an ex. of this latter in the first paragraph. In the phrase in the Kur [xix. 3],"},{"kind":"arabic","text_bw":"waA@$otaEala Alr~aA^osu $ayobFA","text_ar":"وَا@شْتَعَلَ الرَّاْسُ شَيْبًا"},{"kind":"text","text":", (S,) meaning"},{"kind":"italic_en","text":"And whiteness of the hair of the head hath spread therein like as the radiance of fire spreads in firewood,"},{"kind":"text","text":"(Jel,) [or"},{"kind":"italic_en","text":"the head has become glistening with whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"$ybA","text_ar":"شيبا"},{"kind":"text","text":"is in the accus. case as a specificative: or, accord. to Akh, as an inf. n., as though it were said"},{"kind":"arabic","text_bw":"wa$aAba Alr~aA^osu $ayobFA","text_ar":"وَشَابَ الرَّاْسُ شَيْبًا"},{"kind":"text","text":". (S, TA. *)"}],"source_refs":["K","TA","S","As","Msb","Jel"]},{"entry_id":"n23455","headword_ar":"شِيبٌ","root":"$yb","body":[{"kind":"text","text":", of a whip, a genuine Arabic word of wellknown meaning; (S;) The"},{"kind":"italic_en","text":"thong"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"at the upper extremity"},{"kind":"text","text":"(TA) of a whip: (K, TA:) there are two of such thongs, called"},{"kind":"arabic","text_bw":"$iybaAni","text_ar":"شِيبَانِ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"A word imitative of the sounds made by the lips of camels"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"in drinking."},{"kind":"text","text":"(S.)       -A3-  And pl. of"},{"kind":"arabic","text_bw":"A^a$oyabu","text_ar":"اَشْيَبُ"},{"kind":"text","text":"[q. v.]. (S, K, &c.)"}],"source_refs":["K","TA","S"]},{"entry_id":"n23456","headword_ar":"شُيُبٌ","root":"$yb","body":[{"kind":"text","text":"a pl. of which the sing. is doubted: see"},{"kind":"arabic","text_bw":"A^a$oyabu","text_ar":"اَشْيَبُ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}