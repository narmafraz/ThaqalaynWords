{"lemma":"دالٍّ","slug":"دالٍّ","root":"د.ل.ل","root_slug":"د-ل-ل","root_link":"/words/roots/د-ل-ل","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11929","n11930","n12897","n13020","n13444","n13450"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D9%84%D9%8D%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dalet; dal, name of the eighth letter of the Arabic alphabet (د (d)), representing the sound /d/"}]},"etymology":null,"ipa":["/daːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11929","headword_ar":"دَاَلَ","root":"dA^l","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"daA^olN","text_ar":"دَاْلٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"daA^alN","text_ar":"دَاَلٌ"},{"kind":"text","text":"(K [perhaps a mistake for the next, which is well known but not mentioned in the K, but see"},{"kind":"arabic","text_bw":"*aA^ala","text_ar":"ذَاَلَ"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"daA^alaAnN","text_ar":"دَاَلَانٌ"},{"kind":"text","text":"(S, M) and"},{"kind":"arabic","text_bw":"daA^alaY","text_ar":"دَاَلَى"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, in a weak manner,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"and with haste:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"he ran with short steps:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, in a brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly, manner:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, as though labouring in his gait, by reason of briskness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness:"},{"kind":"text","text":"(M:) [or"},{"kind":"italic_en","text":"he went along by little and little, stealthily, lest he should make a sound to be heard:"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"daA^olN","text_ar":"دَاْلٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xatolN","text_ar":"خَتْلٌ"},{"kind":"text","text":": or, accord. to AZ, it signifies the"},{"kind":"italic_en","text":"walking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going, in a manner resembling that which is termed"},{"kind":"arabic","text_bw":"xatolN","text_ar":"خَتْلٌ"},{"kind":"text","text":"; and"},{"kind":"italic_en","text":"in the manner of him who is heavily burdened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overburdened:"},{"kind":"text","text":"and As, in describing the manner in which horses go, explains"},{"kind":"arabic","text_bw":"daA^alaAnN","text_ar":"دَاَلَانٌ"},{"kind":"text","text":"as signifying the"},{"kind":"italic_en","text":"walking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going, with short steps, and in an unusual manner, as though heavily burdened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overburdened."},{"kind":"text","text":"(S.) [See also"},{"kind":"arabic","text_bw":"*aA^ala","text_ar":"ذَاَلَ"},{"kind":"text","text":".] ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"daA^ala lahu","text_ar":"دَاَلَ لَهُ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"daA^olN","text_ar":"دَاْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daA^alaAnN","text_ar":"دَاَلَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He deceived, deluded, beguiled, circumvented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outwitted, him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xatalahu","text_ar":"خَتَلَهُ"},{"kind":"text","text":": (M, K:) [and ↓"},{"kind":"arabic","text_bw":"daAA^alahu","text_ar":"دَااَلَهُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: or"},{"kind":"italic_en","text":"he practised with him mutual deceit, delusion,"},{"kind":"text","text":"&c.: for]"},{"kind":"arabic","text_bw":"mudaAA^alapN","text_ar":"مُدَااَلَةٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"muxaAtalapN","text_ar":"مُخَاتَلَةٌ"},{"kind":"text","text":"; and sometimes it is"},{"kind":"italic_en","text":"with a quick pace:"},{"kind":"text","text":"(AA, T, K:) you say,"},{"kind":"arabic","text_bw":"daA^alotu lahu","text_ar":"دَاَلْتُ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daAA^alotuhu","text_ar":"دَااَلْتُهُ"},{"kind":"text","text":": (AA, T, TA:) and"},{"kind":"arabic","text_bw":"Al*~iy^obu badoA^alu lilogazaAli liyaA^okulahu","text_ar":"الذِّيْبُ بَدْاَلُ لِلْغَزَالِ لِيَاْكُلَهُ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"yaxotuluhu","text_ar":"يَخْتُلُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The wolf deceives,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the gazelle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young gazelle, that he may eat him"},{"kind":"text","text":"]. (AZ, T, TA.)"}],"source_refs":["S","M","K","AA","T","TA"]},{"entry_id":"n11930","headword_ar":"دَاْلٌ","root":"dA^l","body":[{"kind":"text","text":": see the next paragraph, in four places."}],"source_refs":[]},{"entry_id":"n12897","headword_ar":"دَالٌّ","root":"dl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daliylN","text_ar":"دَلِيلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13020","headword_ar":"دَالٍ","root":"dlw","body":[{"kind":"italic_en","text":"Pulling up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out,"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"dalow","text_ar":"دَلْو"},{"kind":"text","text":"[or bucket] from a well: (T:) and occurring in poetry in the sense of"},{"kind":"arabic","text_bw":"mudolK","text_ar":"مُدْلٍ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"letting down"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"dalow","text_ar":"دَلْو"},{"kind":"text","text":"into a well]: (S:) pl."},{"kind":"arabic","text_bw":"dulaApN","text_ar":"دُلَاةٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["T","S"]},{"entry_id":"n13444","headword_ar":"دَالَ","root":"dwl","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"daAra","text_ar":"دَارَ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"dAlti AlA^ay~aAmu","text_ar":"دالتِ الاَيَّامُ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"arabic","text_bw":"taduwlu","text_ar":"تَدُولُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"dawolN","text_ar":"دَوْلٌ"},{"kind":"text","text":", (KL,) meaning"},{"kind":"arabic","text_bw":"daArat","text_ar":"دَارَت"},{"kind":"text","text":"; (S, Msb, K;) [i. e.]"},{"kind":"italic_en","text":"The days came round"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in their turns"},{"kind":"text","text":"]. (KL.) ―         -b2-"},{"kind":"arabic","text_bw":"dawolN","text_ar":"دَوْلٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"changing of time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, from one state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, to another;"},{"kind":"text","text":"(K;) and so"},{"kind":"arabic","text_bw":"dawolapN","text_ar":"دَوْلَةٌ"},{"kind":"text","text":". (TA.) [Hence,] one says,"},{"kind":"arabic","text_bw":"dAlt lahu Ald~awolapu","text_ar":"دالت لَهُ الدَّوْلَةُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The turn of fortune was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in his favour;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"good fortune came to him:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dAlt Ealayohi Ald~awolapu","text_ar":"دالت عَلَيْهِ الدَّوْلَةُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The turn of fortune was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, against him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"good fortune departed from him."},{"kind":"text","text":"(MA.) ―         -b3-  [Golius assigns to"},{"kind":"arabic","text_bw":"dAl","text_ar":"دال"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"dawolapN","text_ar":"دَوْلَةٌ"},{"kind":"text","text":"for its inf. n., as on the authority of the S and KL, two significations app. from two meanings of"},{"kind":"arabic","text_bw":"dawolapN","text_ar":"دَوْلَةٌ"},{"kind":"text","text":", one of which he seems to have misunderstood, and to neither of which do I find any corresponding verb: they are “ Obivit alter alterum in bello: ” and “ superior evasit. ” There are many inf. ns. that have no corresponding verbs.] ―         -b4-"},{"kind":"arabic","text_bw":"dAl","text_ar":"دال"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaduwilu","text_ar":"يَدُوِلُ"},{"kind":"text","text":", (T, K,) inf. n."},{"kind":"arabic","text_bw":"dawolN","text_ar":"دَوْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daAlapN","text_ar":"دَالَةٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"dawolapN","text_ar":"دَوْلَةٌ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"He became notorious"},{"kind":"text","text":"[either"},{"kind":"italic_en","text":"in a bad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a good sense"},{"kind":"text","text":"]; expl. by"},{"kind":"arabic","text_bw":"SaAra $uhorapF","text_ar":"صَارَ شُهْرَةً"},{"kind":"text","text":", (IAar, T, K,) i. e."},{"kind":"arabic","text_bw":"ma$ohuwrFA","text_ar":"مَشْهُورًا"},{"kind":"text","text":". (TK.) ―         -b5-"},{"kind":"arabic","text_bw":"dAl Alv~awobu","text_ar":"دال الثَّوْبُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaduwlu","text_ar":"يَدُولُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, old, and worn out."},{"kind":"text","text":"(AZ, S.) [Hence,]"},{"kind":"arabic","text_bw":"jaEala wud~uhu yaduwlu","text_ar":"جَعَلَ وُدُّهُ يَدُولُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection, was beginning to become,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the point of becoming, worn out."},{"kind":"text","text":"(AZ, S, TA.) ―         -b6-  See also 7."}],"source_refs":["S","Msb","K","KL","T","IAar"]},{"entry_id":"n13450","headword_ar":"دَالٌ","root":"dwl","body":[{"kind":"italic_en","text":"One of the letters of the alphabet,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"the place of utterance of which is near to that of"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":": masc. and fem.; so that you say"},{"kind":"arabic","text_bw":"daAlN HasanN","text_ar":"دَالٌ حَسَنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HasanapN","text_ar":"حَسَنَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a beautiful"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":"]: the pl. is"},{"kind":"arabic","text_bw":"A^adowaAlN","text_ar":"اَدْوَالٌ"},{"kind":"text","text":"if masc., and"},{"kind":"arabic","text_bw":"daAlaAtN","text_ar":"دَالَاتٌ"},{"kind":"text","text":"[if fem.; the latter the more common]. (TA.)       -A2-  Also A"},{"kind":"italic_en","text":"fat"},{"kind":"text","text":"woman. (Kh, TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"daAlapN","text_ar":"دَالَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}