um":"d"}],"frequency_in_corpus":1628,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"varnish, lacquer","examples":[{"text":"أما قسم الأواني والأدوات المطلية باللك، فيضم أعمال منطقة «جوبوجي» موقع إنتاج اللك الخام، حيث حافظت المنطقة على طريقة تقليدية لجمع عصارة اللك وتناقلتها عبر الأجيال، وهي تنطوي على شق الشجرة التي تفرز اللك لجمع العصارة بطريقة تحمي الأشجار القديمة من التلف. وتعد الأعمال المطلية باللك ذات حرفة فريدة من نوعها في اليابان، حتى أنه أصبح يُشار إليها الآن باسم «يابان» في جميع أنحاء العالم."}]},{"pos":"noun","gloss":"Rhus tripartita syn. Rhus oxyacantha because its bark tints the skin red"}]},"etymology":{"source":"wiktextract","text":"From Persian لاک (lâk), from Urdu لاکھ (lākh) / Hindi लाख (lākh), from Sanskrit लाक्षा (lākṣā)."},"ipa":["/lakk/"],"lanes_definition":null}