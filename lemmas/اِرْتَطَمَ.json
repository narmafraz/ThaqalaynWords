":["n15814"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B1%D9%92%D8%AA%D9%8E%D8%B7%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to collide, clash, crash, or smash into"}]},"etymology":null,"ipa":["/ir.ta.tˤa.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15814","headword_ar":"ارتطم","root":"rTm","body":[{"kind":"italic_en","text":"He stuck fast"},{"kind":"arabic","text_bw":"fiY AlwaHoli","text_ar":"فِى الوَحْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the mire"},{"kind":"text","text":"]. (TA.) You say,"},{"kind":"arabic","text_bw":"ArtTmt Ald~aAb~apu fiY AlwaHoli","text_ar":"ارتطمت الدَّابَّةُ فِى الوَحْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The beast stuck fast in the mire"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"fY AlxabaAri","text_ar":"فى الخَبَارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the soft ground"},{"kind":"text","text":"], (TA in art."},{"kind":"arabic","text_bw":"tE","text_ar":"تع"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"arabic","text_bw":"Alr~amoli","text_ar":"الرَّمْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the sand"},{"kind":"text","text":"]. (S and K in that art.) And"},{"kind":"arabic","text_bw":"ArtTmt bihi farasuhu","text_ar":"ارتطمت بِهِ فَرَسُهُ"},{"kind":"italic_en","text":"His mare's feet sank"},{"kind":"text","text":"[in the mire, or soft ground, or sand,]"},{"kind":"italic_en","text":"with him."},{"kind":"text","text":"(TA.) ―         -b2-  And hence, (TA,)"},{"kind":"arabic","text_bw":"ArtTm fiY A^amorK","text_ar":"ارتطم فِى اَمْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became involved in an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a case, from which he could not extricate himself"},{"kind":"text","text":"(K, * TA)"},{"kind":"italic_en","text":"unless with confusion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexity, cleaving to him."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"ArtTm Ealayohi A^amorN","text_ar":"ارتطم عَلَيْهِ اَمْرٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"An affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, was such that he could not extricate himself from it;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"it wearied him, and the ways thereof were obstructed against him, so that he could not extricate himself from it."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"ArtTm","text_ar":"ارتطم"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, pressed together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compressed:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heaped up, piled up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accumulated, one part upon another;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"trATm","text_ar":"تراطم","orth_type":"arrow"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"ArtTm Als~aloHa","text_ar":"ارتطم السَّلْحَ"},{"kind":"italic_en","text":"He suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retained, the excrement;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"trT~mhu","text_ar":"ترطّمهُ"},{"kind":"text","text":". (K.)"}],"source_refs":["TA","S","K"]}]},"classical_definitions":null}