"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْفِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْفُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْفِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْفِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْفُقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْفُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْفِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَصْفُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَصْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"صَفَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَفَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَصْفُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْفُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n24496","n24502","n24505","","n24503","n24504"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to slap, to smack"},{"pos":"verb","gloss":"to set into motion"},{"pos":"verb","gloss":"to flap, to clap"},{"pos":"verb","gloss":"to shut, to slam, to bang (a door)"},{"pos":"verb","gloss":"to be insolent, to be cheeky, to be impertinent, to be impolite"},{"pos":"verb","gloss":"to be thick, to be heavy"},{"pos":"verb","gloss":"to flap, to clap, to smack"},{"pos":"verb","gloss":"to clap one’s hands"},{"pos":"verb","gloss":"to applaud"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24496","headword_ar":"صَفْقٌ","root":"Sfq","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"Safaqa","text_ar":"صَفَقَ"},{"kind":"text","text":"] signifies The"},{"kind":"italic_en","text":"striking"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"so as to cause a sound to be heard in consequence thereof;"},{"kind":"text","text":"(S, O, K;) as also"},{"kind":"arabic","text_bw":"taSofiyqN","text_ar":"تَصْفِيقٌ"},{"kind":"text","text":"[inf. n. of ↓"},{"kind":"arabic","text_bw":"Sf~q","text_ar":"صفّق","orth_type":"arrow"},{"kind":"text","text":", but this has an intensive signification]: (S:) and"},{"kind":"arabic","text_bw":"taSofaAqN","text_ar":"تَصْفَاقٌ"},{"kind":"text","text":"is [also] an inf. n. of"},{"kind":"arabic","text_bw":"Safaqa","text_ar":"صَفَقَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Safoq","text_ar":"صَفْق"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"Safoqu Alkaf~i EalaY","text_ar":"صَفْقُ الكَفِّ عَلَى"},{"kind":"arabic","text_bw":"AlA^uxoraY","text_ar":"الاُخْرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the striking of the hand upon the other"},{"kind":"text","text":"hand], but denoting muchness of the action. (Sb, M, TA.) [Hence several meanings of both of these verbs, here following.] ―         -b2-"},{"kind":"arabic","text_bw":"Safaqa raA^osahu","text_ar":"صَفَقَ رَاْسَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eayonahu","text_ar":"عَيْنَهُ"},{"kind":"text","text":", (M,) and"},{"kind":"arabic","text_bw":"Safaqahu EalaY raA^osihi","text_ar":"صَفَقَهُ عَلَى رَاْسِهِ"},{"kind":"text","text":", (Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (M, Msb,)"},{"kind":"italic_en","text":"He struck his head,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his eye,"},{"kind":"text","text":"(M,) and"},{"kind":"italic_en","text":"he struck him on his head with the hand."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Safaqahu biAls~ayofi","text_ar":"صَفَقَهُ بِالسَّيْفِ"},{"kind":"text","text":", (O, K,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"He struck him with the sword."},{"kind":"text","text":"(O, K.) And"},{"kind":"arabic","text_bw":"Safaqa bihi AlA^aroDa","text_ar":"صَفَقَ بِهِ الاَرْضَ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He smote the ground with him;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he flung him upon the ground"},{"kind":"text","text":"]. (L, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Safaqa bijanaAHayohi","text_ar":"صَفَقَ بِجَنَاحَيْهِ"},{"kind":"text","text":", (M, K,) aor. as above, (M,) [inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":",] said of a bird,"},{"kind":"italic_en","text":"He beat"},{"kind":"text","text":"[his sides, or the air,]"},{"kind":"italic_en","text":"with his wings;"},{"kind":"text","text":"(M, L, K; *) as also ↓"},{"kind":"arabic","text_bw":"Sif~q","text_ar":"صِفّق","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"taSofiyqN","text_ar":"تَصْفِيقٌ"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Safaqatohu Alr~iyHu","text_ar":"صَفَقَتْهُ الرِّيحُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Sf~qthu","text_ar":"صفّقتهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The wind smote it so as to cause a sound to be heard:"},{"kind":"text","text":"(S:) or the latter signifies [simply]"},{"kind":"italic_en","text":"the wind smote it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat it:"},{"kind":"text","text":"(Ham p. 719:) [or"},{"kind":"italic_en","text":"the wind beat upon it;"},{"kind":"text","text":"namely, a sail &c.: (see"},{"kind":"arabic","text_bw":"$iraAEN","text_ar":"شِرَاعٌ"},{"kind":"text","text":":)] [and] both signify"},{"kind":"italic_en","text":"the wind shifted it to the right and left, and turned it back:"},{"kind":"text","text":"(TA: [in the CK,"},{"kind":"arabic","text_bw":"Alt~atoliybu","text_ar":"التَّتْلِيبُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Alt~aqoliybu","text_ar":"التَّقْلِيبُ"},{"kind":"text","text":"as an explanation of"},{"kind":"arabic","text_bw":"Alt~aSofiyqu","text_ar":"التَّصْفِيقُ"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"Alr~iyHu AlmaA='a","text_ar":"الرِّيحُ المَا=ءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sf~qt","text_ar":"صفّقت","orth_type":"arrow"},{"kind":"italic_en","text":"The wind beat the water so that it made it clear:"},{"kind":"text","text":"(M:) and"},{"kind":"arabic","text_bw":"Safaqati Alr~iyHu AlA^a$ojaAra","text_ar":"صَفَقَتِ الرِّيحُ الاَشْجَارَ"},{"kind":"text","text":", (K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"The wind put the trees in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into a state of commotion,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"and shook them:"},{"kind":"text","text":"(O, TA:) and"},{"kind":"arabic","text_bw":"Alr~iyHu","text_ar":"الرِّيحُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sf~qt","text_ar":"صفّقت","orth_type":"arrow"},{"kind":"arabic","text_bw":"Als~aHaAba","text_ar":"السَّحَابَ"},{"kind":"italic_en","text":"The wind smote the clouds,"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"Saramatohu","text_ar":"صَرَمَتْهُ"},{"kind":"text","text":"in my original, an obvious mistranscription, I read"},{"kind":"arabic","text_bw":"Darabatohu","text_ar":"ضَرَبَتْهُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"and blew in different directions upon them."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Safaqa AlEuwda","text_ar":"صَفَقَ العُودَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He put in motion"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by striking them"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the chords of the lute."},{"kind":"text","text":"(S, O, K.) ―         -b6-"},{"kind":"arabic","text_bw":"Safaqa yadahu biAlbayoEapi","text_ar":"صَفَقَ يَدَهُ بِالبَيْعَةِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Safaqa EalaY yadihi","text_ar":"صَفَقَ عَلَى يَدِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"SafoqapN","text_ar":"صَفْقَةٌ"},{"kind":"text","text":", (K,) [or the latter, which see below, is a simple subst.,]"},{"kind":"italic_en","text":"He struck his hand upon his"},{"kind":"text","text":"[another's]"},{"kind":"italic_en","text":"hand by way of ratifying the sale,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the covenant;"},{"kind":"text","text":"(M, K;) and so"},{"kind":"arabic","text_bw":"Safaqa lahu AlbayoEa","text_ar":"صَفَقَ لَهُ البَيْعَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"Safaqotu lahu biAlbayoEi","text_ar":"صَفَقْتُ لَهُ بِالبَيْعِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biAlbayoEapi","text_ar":"بِالبَيْعَةِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I struck my hand upon his hand"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by way of ratifying the sale"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the covenant"},{"kind":"text","text":"]. (S, O, Msb.) [See also"},{"kind":"arabic","text_bw":"safaqa","text_ar":"سَفَقَ"},{"kind":"text","text":". And see an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"radaAdN","text_ar":"رَدَادٌ"},{"kind":"text","text":".] ―         -b7-"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":"(S, O, K) as inf. n. of"},{"kind":"arabic","text_bw":"Safaqotuhu","text_ar":"صَفَقْتُهُ"},{"kind":"text","text":", (S, O,) also signifies The"},{"kind":"italic_en","text":"shutting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"closing"},{"kind":"text","text":"[a thing]; and the"},{"kind":"italic_en","text":"turning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"putting,"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"A_iSofaAqN","text_ar":"اـِصْفَاقٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Safaqa Eayonahu","text_ar":"صَفَقَ عَيْنَهُ"},{"kind":"italic_en","text":"He shut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"closed, his eye."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"Safaqa AlbaAba","text_ar":"صَفَقَ البَابَ"},{"kind":"text","text":", (S, M, O, Msb, K,) aor."},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (M, Msb,)"},{"kind":"italic_en","text":"He shut"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"closed, the door;"},{"kind":"text","text":"(S, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"ASfqhu","text_ar":"اصفقهُ","orth_type":"arrow"},{"kind":"text","text":": (S, O:) or both signify"},{"kind":"italic_en","text":"he locked the door:"},{"kind":"text","text":"(M, K:) and in like manner"},{"kind":"arabic","text_bw":"safaqahu","text_ar":"سَفَقَهُ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"Asfqhu","text_ar":"اسفقهُ"},{"kind":"text","text":"]. (TA.) And"},{"kind":"italic_en","text":"He opened the door:"},{"kind":"text","text":"(ADk, O, Msb, K:) thus having two contr. significations. (Msb.) And"},{"kind":"arabic","text_bw":"Safaqa maA$iyatahu","text_ar":"صَفَقَ مَاشِيَتَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent, his cattle back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away."},{"kind":"text","text":"(M, TA.) And"},{"kind":"arabic","text_bw":"Safaqahumo Eano ka*aA","text_ar":"صَفَقَهُمْ عَنْ كَذَا"},{"kind":"italic_en","text":"He turned them"},{"kind":"text","text":"[i. e. men]"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, from such a thing."},{"kind":"text","text":"(TA.) And one says,"},{"kind":"arabic","text_bw":"maA zaAluwA yaSofiquwnaniY","text_ar":"مَا زَالُوا يَصْفِقُونَنِى"},{"kind":"italic_en","text":"They ceased not to turn me about in an affair:"},{"kind":"text","text":"[meaning that] they endeavoured to induce him to do it. (Ibn-'Abbád, O.) ―         -b8-"},{"kind":"arabic","text_bw":"Safaqahumo mino baladK A_ilaY","text_ar":"صَفَقَهُمْ مِنْ بَلَدٍ اـِلَى"},{"kind":"arabic","text_bw":"baladK","text_ar":"بَلَدٍ"},{"kind":"italic_en","text":"They expelled them from town to town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from country to country, forcibly and ignominiously."},{"kind":"text","text":"(TA.) ―         -b9-"},{"kind":"arabic","text_bw":"Safaqa Al$~araAba","text_ar":"صَفَقَ الشَّرَابَ"},{"kind":"text","text":": see 2. ―         -b10-"},{"kind":"arabic","text_bw":"Safaqa AlqadaHa","text_ar":"صَفَقَ القَدَحَ"},{"kind":"text","text":", (O, K,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (O, TA,)"},{"kind":"italic_en","text":"He filled the drinking-vessel;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"ASfqhu","text_ar":"اصفقهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, K;) and ↓"},{"kind":"arabic","text_bw":"Sf~qhu","text_ar":"صفّقهُ","orth_type":"arrow"},{"kind":"text","text":": (O:) or"},{"kind":"arabic","text_bw":"AlkaA^osa","text_ar":"الكَاْسَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sf~q","text_ar":"صفّق","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"ASfqhA","text_ar":"اصفقها","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he filled the drinking-cup,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wine-cup:"},{"kind":"text","text":"(Lh, M:) and"},{"kind":"arabic","text_bw":"AlHawoDa","text_ar":"الحَوْضَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ASfqnA","text_ar":"اصفقنا","orth_type":"arrow"},{"kind":"italic_en","text":"We collected the water in the watering-trough."},{"kind":"text","text":"(TA.) ―         -b11-  And"},{"kind":"arabic","text_bw":"SafaqahaA","text_ar":"صَفَقَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He compressed her;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jaAmaEahaA","text_ar":"جَامَعَهَا"},{"kind":"text","text":". (TA.) ―         -b12-  And"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"collecting together"},{"kind":"text","text":"[a thing or things]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Safaqa Alr~ajulu","text_ar":"صَفَقَ الرَّجُلُ"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"The man went away."},{"kind":"text","text":"(M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"mina","text_ar":"مِنَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Safaqato EalayonaA SaAfiqapN","text_ar":"صَفَقَتْ عَلَيْنَا صَافِقَةٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Aln~aAsi","text_ar":"النَّاسِ"},{"kind":"italic_en","text":"A company of men alighted at our abode."},{"kind":"text","text":"(IDrd, M, * O, K. *) ―         -b3-"},{"kind":"arabic","text_bw":"Safaqato","text_ar":"صَفَقَتْ"},{"kind":"text","text":", (IDrd, O, K,) inf. n."},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":", (TA,) said of a she-camel,"},{"kind":"italic_en","text":"Her womb closed against the passage of her fœtus,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^arotajato raHimuhaA Eano waladihaA","text_ar":"اَرْتَجَتْ رَحِمُهَا عَنْ وَلَدِهَا"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"A^urotijato","text_ar":"اُرْتِجَتْ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"became closed,"},{"kind":"text","text":"the syll. signs of this word in the O being doubtful, in the CK erroneously written"},{"kind":"arabic","text_bw":"Artaxato","text_ar":"ارتَخَتْ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"so that the fœtus died."},{"kind":"text","text":"(IDrd, O, K, TA.)       -A3-"},{"kind":"arabic","text_bw":"Safuqa","text_ar":"صَفُقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (M, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"SafaAqapN","text_ar":"صَفَاقَةٌ"},{"kind":"text","text":", said of a garment, or piece of cloth, (S, M, O, Msb, K,)"},{"kind":"italic_en","text":"It was strong, stout,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firm;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"thick, substantial, close,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact, in texture:"},{"kind":"text","text":"(O, Msb, K:) and so"},{"kind":"arabic","text_bw":"safuqa","text_ar":"سَفُقَ"},{"kind":"text","text":". (T, S, &c., in art."},{"kind":"arabic","text_bw":"sfq","text_ar":"سفق"},{"kind":"text","text":".) ―         -b2-  And, said of a face, (S, O, K, TA,) (tropical:)"},{"kind":"italic_en","text":"It was impudent;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had little shame."},{"kind":"text","text":"(O, K, TA.)"}],"source_refs":["S","M","Msb","O","K","TA","ADk","Lh","IDrd"]},{"entry_id":"n24502","headword_ar":"صَفْقٌ","root":"Sfq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SafoqapN","text_ar":"صَفْقَةٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"A side; a lateral part"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion;"},{"kind":"text","text":"(S, M, O, K;) and so ↓"},{"kind":"arabic","text_bw":"SufoqN","text_ar":"صُفْقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) and ↓"},{"kind":"arabic","text_bw":"SafaqN","text_ar":"صَفَقٌ","orth_type":"arrow"},{"kind":"text","text":"; (M, O, K;) syn."},{"kind":"arabic","text_bw":"naAHiyapN","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":", (S, M, O, K,) and"},{"kind":"arabic","text_bw":"jaAnibN","text_ar":"جَانِبٌ"},{"kind":"text","text":". (M, TA.) Of a mountain, (S, O, K,) it signifies in like manner, (O,) its"},{"kind":"arabic","text_bw":"SafoH","text_ar":"صَفْح"},{"kind":"text","text":", (S, O, K,) and its"},{"kind":"arabic","text_bw":"naAHiyap","text_ar":"نَاحِيَة"},{"kind":"text","text":": (S:) [both of which signify as above: or by the former may be meant what here follows:] or its"},{"kind":"italic_en","text":"face,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"in the upper part"},{"kind":"text","text":"thereof,"},{"kind":"italic_en","text":"above the"},{"kind":"arabic","text_bw":"HaDiyD","text_ar":"حَضِيض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"low ground at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by, the base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot"},{"kind":"text","text":"]: (M:) pl."},{"kind":"arabic","text_bw":"SufuwqN","text_ar":"صُفُوقٌ"},{"kind":"text","text":". (S, O.) [In like manner also,]"},{"kind":"arabic","text_bw":"SafoqaA AlEunuqi","text_ar":"صَفْقَا العُنُقِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The two sides of the neck."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"SafoqaA Alfarasi","text_ar":"صَفْقَا الفَرَسِ"},{"kind":"italic_en","text":"The two cheeks of the horse."},{"kind":"text","text":"(M, K.) ―         -b2-  Also"},{"kind":"italic_en","text":"A place."},{"kind":"text","text":"(K.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"SifoqN","text_ar":"صِفْقٌ"},{"kind":"text","text":".       -A3-  And see"},{"kind":"arabic","text_bw":"SafaqN","text_ar":"صَفَقٌ"},{"kind":"text","text":", in two places."}],"source_refs":["S","O","K","M"]},{"entry_id":"n24505","headword_ar":"صَفْقٌ","root":"Sfq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"Water that is poured into a new skin, and shaken in it, and in consequence becomes yellow;"},{"kind":"text","text":"(S, O, K;) or"},{"kind":"italic_en","text":"yellow water that comes forth from a new skin upon which water has been poured;"},{"kind":"text","text":"(M;) and so ↓"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ","orth_type":"arrow"},{"kind":"text","text":". (M, K.) Hence, (TA,) one says,"},{"kind":"arabic","text_bw":"waradonaA","text_ar":"وَرَدْنَا"},{"kind":"arabic","text_bw":"maA='F kaA^an~ahu SafaqN","text_ar":"مَا=ءً كَاَنَّهُ صَفَقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We came for the purpose of drinking to water as though it were the yellow water that comes forth from a new skin"},{"kind":"text","text":"]. (S, O.) ―         -b2-  And"},{"kind":"italic_en","text":"A new skin upon"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"into"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which water is poured, in consequence whereof yellow water comes forth from it."},{"kind":"text","text":"(M.) ―         -b3-  Also, accord. to AHn, (M,) or so ↓"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) The"},{"kind":"italic_en","text":"odour,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"savour, of"},{"kind":"arabic","text_bw":"dibaAg","text_ar":"دِبَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tan"},{"kind":"text","text":"]. (M, K.) ―         -b4-  And The former, accord. to Ibn-'Abbád, The"},{"kind":"italic_en","text":"last of"},{"kind":"arabic","text_bw":"dibaAg","text_ar":"دِبَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tan"},{"kind":"text","text":"]: (O, TA:) in the K,"},{"kind":"arabic","text_bw":"A=xiru Ald~imaAgi","text_ar":"ا=خِرُ الدِّمَاغِ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"A=xr Ald~ibaAg","text_ar":"ا=خر الدِّبَاغ"},{"kind":"text","text":". (TA.)"}],"source_refs":["TA","M","K","O"]},{"entry_id":"n24503","headword_ar":"صُفْقٌ","root":"Sfq","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]},{"entry_id":"n24504","headword_ar":"صِفْقٌ","root":"Sfq","body":[{"kind":"text","text":", with kesr, The"},{"kind":"arabic","text_bw":"miSoraAE","text_ar":"مِصْرَاع"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"either half,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaf,"},{"kind":"text","text":"] of a door [meaning of a folding door]: (K:) [or, accord. to the O, it is ↓"},{"kind":"arabic","text_bw":"SafoqN","text_ar":"صَفْقٌ","orth_type":"arrow"},{"kind":"text","text":", for it is there said that"},{"kind":"arabic","text_bw":"SafoqaA AlbaAbi","text_ar":"صَفْقَا البَابِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"miSoraAEaAhu","text_ar":"مِصْرَاعَاهُ"},{"kind":"text","text":"; but SM follows the reading in the K without remarking upon the difference in the O; and adds,] and one says,"},{"kind":"arabic","text_bw":"baAbu daArihi SifoqN waAHidN","text_ar":"بَابُ دَارِهِ صِفْقٌ وَاحِدٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"The door of his house is one leaf;"},{"kind":"text","text":"i. e.] when it does not consist of what are termed"},{"kind":"arabic","text_bw":"miSoraAEaAni","text_ar":"مِصْرَاعَانِ"},{"kind":"text","text":". (TA.)"}],"source_refs":["K"]}]},"classical_definitions":null}