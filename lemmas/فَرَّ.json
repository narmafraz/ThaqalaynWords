ent_2mp","form":"تَفِرُّونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفِرّ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَفْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفِرّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَفْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَفِرّ","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفِرّ","in_corpus":true,"count":89,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"فَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":113,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n33305"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to flee, run away, run off, escape"},{"pos":"noun","gloss":"verbal noun of فَرَّ (farra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"quail (Coturnix coturnix)","tags":["collective"],"examples":[{"text":"قررت لجنة الأحياء البرية في الجمعية الملكية لحماية الطبيعة فتح موسم صيد فصل الخريف في مناطق غرب سكة الحديد لطائري الفر والحمام البري يومي الجمعة والأحد بواقع 15 طيراً لكل صياد مرخص، اعتباراً من الرابع عشر من أيلول الجاري وحتى نهاية تشرين الأول المقبل."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33305","headword_ar":"فَرَّ","root":"fr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"firaArF","text_ar":"فِرَارً"},{"kind":"text","text":"(T, S, M, K, &c.) and"},{"kind":"arabic","text_bw":"farN","text_ar":"فَرٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"mafarN","text_ar":"مَفَرٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"mafirN","text_ar":"مَفِرٌ"},{"kind":"text","text":", (K,) or the last is a n. of place [and of time], (S, M,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, T)"},{"kind":"italic_en","text":"fled:"},{"kind":"text","text":"(T, S:) or"},{"kind":"italic_en","text":"he turned away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aside, to elude, and fled,"},{"kind":"text","text":"(M, K, TA,) from a thing that he feared. (TA.)"},{"kind":"arabic","text_bw":"A^ayona A@lomafar~u","text_ar":"اَيْنَ ا@لْمَفَرُّ"},{"kind":"text","text":"[in the Kur lxxv. 10] means"},{"kind":"italic_en","text":"Whither is the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fleeing"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"turning away"},{"kind":"text","text":"&c.? (M, TA:) or it may mean"},{"kind":"italic_en","text":"when is the time thereof?"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"Ayn Almafir~u","text_ar":"اين المَفِرُّ"},{"kind":"text","text":", another reading,"},{"kind":"italic_en","text":"where is the place of fleeing"},{"kind":"text","text":"&c.? (I'Ab, Zj, S, M, TA,) as also"},{"kind":"arabic","text_bw":"Almifar~u","text_ar":"المِفَرُّ"},{"kind":"text","text":", (Zj, K, TA,) which is an instrumental noun used as a noun of place: (K, TA:) but the first is the common reading. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"far~a","text_ar":"فَرَّ"},{"kind":"arabic","text_bw":"mino Eaduwihi","text_ar":"مِنْ عَدُوِهِ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"far~N","text_ar":"فَرٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He wheeled about widely from his enemy, to turn again."},{"kind":"text","text":"(Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"far~a A_ilaY Al$~aYo'i","text_ar":"فَرَّ اـِلَى الشَّىْءِ"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself, to the thing."},{"kind":"text","text":"(Msb.) ―         -b4-  And [hence]"},{"kind":"arabic","text_bw":"far~ato yaduhu","text_ar":"فَرَّتْ يَدُهُ"},{"kind":"italic_en","text":"His arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, fell off;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"Tar~ato","text_ar":"طَرَّتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tar~ato","text_ar":"تَرَّتْ"},{"kind":"text","text":". (O.)       -A2-"},{"kind":"arabic","text_bw":"far~a Alfarasa","text_ar":"فَرَّ الفَرَسَ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"Ald~aAb~apa","text_ar":"الدَّابَّةَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", (S, M, O,) i. e. with damm, (O,) [in copies of the K"},{"kind":"text","text":", but afterwards in those copies"},{"kind":"text","text":", which is the regular and correct form,] inf. n."},{"kind":"arabic","text_bw":"far~N","text_ar":"فَرٌّ"},{"kind":"text","text":"(S, M, O, K) and"},{"kind":"arabic","text_bw":"furaArN","text_ar":"فُرَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"firaArN","text_ar":"فِرَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faraArN","text_ar":"فَرَارٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"furaArN","text_ar":"فُرَارٌ"},{"kind":"text","text":"is a simple subst., and"},{"kind":"arabic","text_bw":"firaArN","text_ar":"فِرَارٌ"},{"kind":"text","text":"is an inf. n., (Meyd, in explanation of the prov. which here follows,)"},{"kind":"italic_en","text":"He looked at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined, the teeth of the horse,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"he exposed to view the teeth of the beast that he might see what was its age."},{"kind":"text","text":"(M, K.) Hence, (TA,)"},{"kind":"quote","text":"A_in~a AljawaAda Eayonuhu furaAruhu"},{"kind":"text","text":"(S, M, * Meyd, K, *) and"},{"kind":"arabic","text_bw":"firaAruhu","text_ar":"فِرَارُهُ"},{"kind":"text","text":", (M, Meyd, K,) and"},{"kind":"arabic","text_bw":"faraAruhu","text_ar":"فَرَارُهُ"},{"kind":"text","text":", (S, K,) sometimes thus pronounced with fet-h, (S,) (tropical:)  ["},{"kind":"italic_en","text":"Verily the fleet and excellent horse, his aspect"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EayonN","text_ar":"عَيْنٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"is"},{"kind":"text","text":"("},{"kind":"italic_en","text":"equivalent to"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the examination of his teeth,"},{"kind":"text","text":"i. e. he is known by his aspect], is a prov., applied to him whose external state indicates his internal qualities; (Meyd, O, K;) meaning that one knows his excellence from his"},{"kind":"arabic","text_bw":"Eayon","text_ar":"عَيْن"},{"kind":"text","text":"[i. e. aspect] like as one knows the age of a beast by examining his teeth; (TA;) his external appearance rendering it needless for thee to test him, (S, Meyd, O, K,) and to examine ("},{"kind":"arabic","text_bw":"A^ano tafur~a","text_ar":"اَنْ تَفُرَّ"},{"kind":"text","text":") his teeth: (S, O, K:) and [with the same meaning] one says,"},{"kind":"arabic","text_bw":"far~u AljawaAdi Eayonuhu","text_ar":"فَرُّ الجَوَادِ عَيْنُهُ"},{"kind":"text","text":": (A, TA:) and [in like manner]"},{"kind":"arabic","text_bw":"Alxabiyvu Eaynuhu furiAaruhu","text_ar":"الخَبِيثُ عَينُهُ فُرِاَرُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The bad, his aspect"},{"kind":"text","text":"&c.]; (Meyd, O, TA;) i. e. thou knowest his badness by his"},{"kind":"arabic","text_bw":"Eayon","text_ar":"عَيْن"},{"kind":"text","text":"when thou seest him. (TA.) And one says also,"},{"kind":"arabic","text_bw":"fararotu fama Alfarasi","text_ar":"فَرَرْتُ فَمَ الفَرَسِ"},{"kind":"italic_en","text":"I opened the mouth of the horse that I might know his age."},{"kind":"text","text":"(Har p. 28.) And"},{"kind":"arabic","text_bw":"far~a Eano A^asonaAni Ald~aAb~api","text_ar":"فَرَّ عَنْ اَسْنَانِ الدَّابَّةِ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He examined the teeth of the beast."},{"kind":"text","text":"(Har p. 233.) ―         -b2-  [Hence the saying of El-Hajjáj,"},{"kind":"arabic","text_bw":"furirotu","text_ar":"فُرِرْتُ"},{"kind":"arabic","text_bw":"Eano *akaA='K","text_ar":"عَنْ ذَكَا=ءٍ"},{"kind":"text","text":", expl. in art."},{"kind":"arabic","text_bw":"*kw","text_ar":"ذكو"},{"kind":"text","text":".] And [hence also] one says,"},{"kind":"arabic","text_bw":"far~ahu Eano A^a$oyaA='i","text_ar":"فَرَّهُ عَنْ اَشْيَا=ءِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He examined him respecting things"},{"kind":"text","text":"(O, * TA.) And"},{"kind":"arabic","text_bw":"far~a AlA^amora","text_ar":"فَرَّ الاَمْرَ"},{"kind":"text","text":", (M, TA,) and"},{"kind":"arabic","text_bw":"far~a Eani AlA^amori","text_ar":"فَرَّ عَنِ الاَمْرِ"},{"kind":"text","text":", (S, M, O, K, TA,) (tropical:)"},{"kind":"italic_en","text":"He examined, looked into, scrutinized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"investigated, the affair; searched into it; inquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought information, respecting it."},{"kind":"text","text":"(S, M, O, K, TA.) And"},{"kind":"arabic","text_bw":"far~a fulaAnN Eam~aA fiY nafosiY","text_ar":"فَرَّ فُلَانٌ عَمَّا فِى نَفْسِى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one interrogated me in order that he might know, from what I should say, what was in my mind."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"fur~a AlA^amoru","text_ar":"فُرَّ الاَمْرُ"},{"kind":"arabic","text_bw":"ja*aEFA","text_ar":"جَذَعًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The thing returned to its first state; it recommenced."},{"kind":"text","text":"(M, O, K.) And"},{"kind":"arabic","text_bw":"fur~a AlA^amora ja*aEFA","text_ar":"فُرَّ الاَمْرَ جَذَعًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Commence thou the affair from the first thereof."},{"kind":"text","text":"(M, in the TT. [But the MS. has in this case, as in that here immediately preceding,"},{"kind":"arabic","text_bw":"AlAmru","text_ar":"الامرُ"},{"kind":"text","text":": the right reading is evidently"},{"kind":"arabic","text_bw":"AlAmra","text_ar":"الامرَ"},{"kind":"text","text":"; as in a similar phrase voce"},{"kind":"arabic","text_bw":"ja*aEN","text_ar":"جَذَعٌ"},{"kind":"text","text":", q. v.])       -A3-"},{"kind":"arabic","text_bw":"far~a","text_ar":"فَرَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafir~u","text_ar":"يَفِرُّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"yafar~u","text_ar":"يَفَرُّ"},{"kind":"text","text":", (accord. to different copies of the T,)"},{"kind":"italic_en","text":"He became intelligent after being weak"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in mind"},{"kind":"text","text":"]. (IAar, T, TA.)"}],"source_refs":["M","K","S","T","TA","Zj","O","Meyd","A"]}]}}