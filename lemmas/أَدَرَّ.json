3md","form":"يُدَرّا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدَرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدِرُّونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدِرُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَرُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَرُّونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُدِرّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدِرّ","in_corpus":true,"count":16,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُدَرّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَرّ","in_corpus":true,"count":16,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَدْرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَدْرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":362,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n435","n12320"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause to flow"},{"pos":"verb","gloss":"to bestow lavishly, to heap, to shower, to overwhelm"},{"pos":"verb","gloss":"to yield (profit)","examples":[{"text":"الْقِطْعَاتُ الرَّئِيسِيَّةُ تُنْتِجُ مِنْ أَجْلِ التَّصْدِيرِ، الَّذِي يُدِرُّ الْعُمْلَةَ الصَّعْبَةَ لِٱسْتِيرَادِ الْمَوَادِّ الْحَيَوِيَّةِ.","english":"The key sectors produce for export, which generates hard currency for vital imports."}]},{"pos":"verb","gloss":"to pass around (wine)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n435","headword_ar":"اَدِرَ","root":"Adr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (T, M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A^adarN","text_ar":"اَدَرٌ"},{"kind":"text","text":"(Lth, T, S, Mgh) and"},{"kind":"arabic","text_bw":"A^adarapN","text_ar":"اَدَرَةٌ"},{"kind":"text","text":", (Lth, TA,) or"},{"kind":"arabic","text_bw":"A^udorapN","text_ar":"اُدْرَةٌ"},{"kind":"text","text":", (as in the TT,) or"},{"kind":"arabic","text_bw":"A^udorapN","text_ar":"اُدْرَةٌ"},{"kind":"text","text":"is a simple subst., (M, K,) and so is"},{"kind":"arabic","text_bw":"A^udorapN","text_ar":"اُدْرَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"had the disorder termed"},{"kind":"arabic","text_bw":"A^udorapN","text_ar":"اُدْرَةٌ"},{"kind":"text","text":". (T, S, M, &c.)"}],"source_refs":["T","M","Msb","K","Lth","S","Mgh","TA"]},{"entry_id":"n12320","headword_ar":"ادرّ","root":"dr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"milk"},{"kind":"italic_en","text":"to flow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to flow copiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundantly:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he drew forth"},{"kind":"text","text":"milk. (Msb.) See also 1, in three places. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^adar~uwA AlxaraAja","text_ar":"اَدَرُّوا الخَرَاجَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They"},{"kind":"text","text":"(the collectors)"},{"kind":"italic_en","text":"made the produce of the tax called"},{"kind":"arabic","text_bw":"xrAj","text_ar":"خراج"},{"kind":"italic_en","text":"to come in abundantly."},{"kind":"text","text":"(TA.) ―         -b3-  [And"},{"kind":"arabic","text_bw":"Adr~ Albawola","text_ar":"ادرّ البَوْلَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a medicine, &c.,)"},{"kind":"italic_en","text":"caused the urine to flow plentifully; acted as a diuretic;"},{"kind":"text","text":"(see the act. part. n. below;) as also ↓"},{"kind":"arabic","text_bw":"Astdrhu","text_ar":"استدرهُ","orth_type":"arrow"},{"kind":"text","text":".] ―         -b4-"},{"kind":"arabic","text_bw":"Adr~ A^um~ahu","text_ar":"ادرّ اُمَّهُ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a young camel)"},{"kind":"italic_en","text":"sucked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew the milk of, his mother."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Adr~hA","text_ar":"ادرّها"},{"kind":"italic_en","text":"He stroked her"},{"kind":"text","text":"(a camel's)"},{"kind":"italic_en","text":"dugs, to draw her milk: he milked her;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AstdrhA","text_ar":"استدرها","orth_type":"arrow"},{"kind":"text","text":", referring to a ewe or she-goat: (Msb: and the latter,"},{"kind":"italic_en","text":"he stroked her dugs with his hand, causing the milk to flow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to flow copiously:"},{"kind":"text","text":"and the same verb,"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, her milk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the flowing of her milk."},{"kind":"text","text":"(TA.) ―         -b5-  [Hence,]"},{"kind":"arabic","text_bw":"A^adiruwA liqoHapa A@lmusolimiyna","text_ar":"اَدِرُوا لِقْحَةَ ا@لمُسْلِمِينَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Make ye. the tribute, or taxes, pertaining to the Muslims to pour in abundantly:"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"make ye the milchcamel of the Muslims to yield milk abundantly"},{"kind":"text","text":"]: said by 'Omar to the collector of the taxes. (TA.) ―         -b6-  [Hence, also,] one says to a man, when he seeks a thing, and begs for it importunately,"},{"kind":"arabic","text_bw":"A^adir~ahaA wa A_ino A^abato","text_ar":"اَدِرَّهَا وَ اـِنْ اَبَتْ"},{"kind":"text","text":", meaning, [lit.,]"},{"kind":"italic_en","text":"Ply her, though she refuse, until she yield her milk abundantly."},{"kind":"text","text":"(TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"A^adar~a A@ll~`hu lahu A^axolaAfa Alr~izoqi","text_ar":"اَدَرَّ ا@للّٰهُ لَهُ اَخْلَافَ الرِّزْقِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"God milked for him the dugs of sustenance;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"provided for him the means of subsistence"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"niEomapa A@ll~`hi biAl$~ukori","text_ar":"نِعْمَةَ ا@للّٰهِ بِالشُّكْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Astd~r","text_ar":"استدّر","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He drew the favour, or blessing, of God, by thankfulness"},{"kind":"text","text":"]. (A.) ―         -b8-"},{"kind":"arabic","text_bw":"Alr~iyHu tudir~u Als~aHaAba","text_ar":"الرِّيحُ تُدِرُّ السَّحَابَ"},{"kind":"text","text":", (S, L, K,) and ↓"},{"kind":"arabic","text_bw":"tasotadir~uhu","text_ar":"تَسْتَدِرُّهُ","orth_type":"arrow"},{"kind":"text","text":", (S, L,) (assumed tropical:)"},{"kind":"italic_en","text":"The wind draws forth a shower of fine rain from the clouds:"},{"kind":"text","text":"(S, L, K: in some copies of the last, we find, as the explanation of"},{"kind":"arabic","text_bw":"A^adar~ati Alr~iyHu Als~aHaAba","text_ar":"اَدَرَّتِ الرِّيحُ السَّحَابَ"},{"kind":"text","text":", instead of"},{"kind":"arabic","text_bw":"Halabatohu","text_ar":"حَلَبَتْهُ"},{"kind":"text","text":", [agreeably with the above explanation,]"},{"kind":"arabic","text_bw":"jalabatohu","text_ar":"جَلَبَتْهُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":": the explanation in the [S and] L is"},{"kind":"arabic","text_bw":"tasotaHolibuhu","text_ar":"تَسْتَحْلِبُهُ"},{"kind":"text","text":": TA:) and"},{"kind":"arabic","text_bw":"Als~aHaAba","text_ar":"السَّحَابَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nasotadir~u","text_ar":"نَسْتَدِرُّ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"We desire, or look for, a shower of rain from the clouds"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"Hlb","text_ar":"حلب"},{"kind":"text","text":".) ―         -b9-  And"},{"kind":"arabic","text_bw":"bayona Eayonayohi","text_ar":"بَيْنَ عَيْنَيْهِ"},{"kind":"arabic","text_bw":"EiroqN yudir~uhu AlgaDabu","text_ar":"عِرْقٌ يُدِرُّهُ الغَضَبُ"},{"kind":"text","text":"(said in a trad., TA) (tropical:)"},{"kind":"italic_en","text":"Between his eyes was a vein which anger caused to flow;"},{"kind":"text","text":"(S; *) or"},{"kind":"italic_en","text":"to fill with blood;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"to become thick and full:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"which anger put in motion:"},{"kind":"text","text":"(S:) for (TA)"},{"kind":"arabic","text_bw":"A^adar~a Al$~aYo'a","text_ar":"اَدَرَّ الشَّىْءَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he put the thing in motion."},{"kind":"text","text":"(K, TA.) ―         -b10-"},{"kind":"arabic","text_bw":"Adr~t Almigozala","text_ar":"ادرّت المِغْزَلَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"She twisted the spindle vehemently,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"so that it seemed to be still in consequence of its vehement twirling."},{"kind":"text","text":"(K, * TA.) ―         -b11-  And"},{"kind":"arabic","text_bw":"Adr~ Als~ahoma","text_ar":"ادرّ السَّهْمَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made the arrow to turn round well upon the nail"},{"kind":"text","text":"(AHn, K *)"},{"kind":"italic_en","text":"of his left thumb, turning it with the thumb and fore finger of his right hand."},{"kind":"text","text":"(AHn. [See 1, latter part.]) ―         -b12-  And"},{"kind":"arabic","text_bw":"A^adorarotu Ealayohi","text_ar":"اَدْرَرْتُ عَلَيْهِ"},{"kind":"arabic","text_bw":"AlD~arobu","text_ar":"الضَّرْبُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I inflicted upon him an uninterrupted beating."},{"kind":"text","text":"(A.)"}],"source_refs":["S","L","K","TA","A"]}]}}