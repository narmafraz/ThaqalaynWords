{"lemma":"تَواتُرِ","slug":"تَواتُرِ","root":"#.ت.ر","root_slug":"_-ت-ر","root_link":"/words/roots/_-ت-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n41598"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%88%D8%A7%D8%AA%D9%8F%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to follow in uninterrupted succession"},{"pos":"verb","gloss":"to repeat, to recur"},{"pos":"noun","gloss":"verbal noun of تَوَاتَرَ (tawātara) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"narration in succession (without interruption)"},{"pos":"noun","gloss":"consensus of various reporters of a tradition"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of تَوَاتَرَ (tawātara)."},"ipa":["/ta.waː.ta.ra/","/ta.waː.tur/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41598","headword_ar":"تواتر","root":"wtr","body":[{"kind":"italic_en","text":"It was consecutive:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was so with intervals:"},{"kind":"text","text":"(M, A, K:) or"},{"kind":"italic_en","text":"was so with separation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interruption."},{"kind":"text","text":"(Msb.) You say,"},{"kind":"arabic","text_bw":"twAtrt AlA_ibilu","text_ar":"تواترت الاـِبِلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlqaTaA","text_ar":"القَطَا"},{"kind":"text","text":", and so of any other things,"},{"kind":"italic_en","text":"The camels,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the birds of the kind called"},{"kind":"arabic","text_bw":"AlqTA","text_ar":"القطا"},{"kind":"text","text":", &c.,"},{"kind":"italic_en","text":"came one near after another, not in a rank."},{"kind":"text","text":"(Lh, M.) And"},{"kind":"arabic","text_bw":"twAtrt Alxayolu","text_ar":"تواترت الخَيْلُ"},{"kind":"italic_en","text":"The horses came following one another."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"twAtrt Alkutubu","text_ar":"تواترت الكُتُبُ"},{"kind":"italic_en","text":"The writings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"letters, came one near after another, separately."},{"kind":"text","text":"(S.)"}],"source_refs":["M","A","K"]}]},"classical_definitions":null}