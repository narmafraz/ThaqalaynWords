n":"m","num":"p"},{"role":"present_2mp","form":"تَبْرُكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْرُكْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْرُك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْرُك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْرُكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْرُكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْرُكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْرُكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْرُكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْرُكُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْرُكْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"بَرَكْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَرَكْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَبْرُك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبْرُك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n2352"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B1%D9%8E%D9%83%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to kneel down"},{"pos":"verb","gloss":"to make kneel"},{"pos":"verb","gloss":"to invoke a blessing"}]},"etymology":{"source":"wiktextract","text":"Derived from Proto-Semitic *birk-, *bark- (“knee”) (ب ر ك (b r k)). Compare رُكْبَة (rukba, “knee”), from the variant root.\n\nFor etymology 2 sense 2, it is a denominal verb of بَرَكَة (baraka, “blessing”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2352","headword_ar":"بَرَكَ","root":"brk","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"buruwkN","text_ar":"بُرُوكٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"taboraAkN","text_ar":"تَبْرَاكٌ"},{"kind":"text","text":", (K,) said of a camel, (S, Mgh, Msb,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AisotanaAxa","text_ar":"اِسْتَنَاخَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He lay down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kneeled and lay down, upon his breast, with his legs folded"},{"kind":"text","text":"]; (S, K;)"},{"kind":"italic_en","text":"he made his breast to cleave to the ground;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"he fell upon his"},{"kind":"arabic","text_bw":"barok","text_ar":"بَرْك"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"breast;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he threw his"},{"kind":"arabic","text_bw":"brk","text_ar":"برك"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"breast, upon the ground;"},{"kind":"text","text":"(TA;) and in like manner, ↓"},{"kind":"arabic","text_bw":"br~k","text_ar":"برّك","orth_type":"arrow"},{"kind":"text","text":", (TA, and so in some copies of the K,) inf. n."},{"kind":"arabic","text_bw":"taboriykN","text_ar":"تَبْرِيكٌ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"barakati Aln~aEaAmapu","text_ar":"بَرَكَتِ النَّعَامَةُ"},{"kind":"italic_en","text":"The ostrich lay upon its breast."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"baraka","text_ar":"بَرَكَ"},{"kind":"text","text":"is also said of a lion, and of a man. (K voce"},{"kind":"arabic","text_bw":"rbD","text_ar":"ربض"},{"kind":"text","text":".) [Of the latter, one also says,"},{"kind":"arabic","text_bw":"baraka EalaY rukobatayohi","text_ar":"بَرَكَ عَلَى رُكْبَتَيْهِ"},{"kind":"italic_en","text":"He fell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"set himself, upon his knees; he kneeled."},{"kind":"text","text":"] The"},{"kind":"arabic","text_bw":"buruwk","text_ar":"بُرُوك"},{"kind":"text","text":"of a man praying, which is forbidden, is The"},{"kind":"italic_en","text":"putting down the hands before the knees,"},{"kind":"text","text":"after the manner of the camel [when he lies down; for the latter falls first upon his knees, and then upon his stiflejoints]. (Mgh.) ―         -b2-  Hence, i. e., from the verb said of a camel, inf. n."},{"kind":"arabic","text_bw":"buruwkN","text_ar":"بُرُوكٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(i. e. anything, S,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm, steady, steadfast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed; continued, remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed;"},{"kind":"text","text":"(S, K;) in a place: (TK:) [and so, app., with"},{"kind":"text","text":"for its aor.; for] you say,"},{"kind":"arabic","text_bw":"baraka liloqitaAli","text_ar":"بَرَكَ لِلْقِتَالِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for the purpose of fighting,"},{"kind":"text","text":"] and in like manner"},{"kind":"arabic","text_bw":"barika","text_ar":"بَرِكَ"},{"kind":"text","text":", aor."},{"kind":"text","text":". (TA. [See also a similar signification of 8.]) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the night)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protracted; as though it did not quit its place."},{"kind":"text","text":"(A and TA in art."},{"kind":"arabic","text_bw":"qEs","text_ar":"قعس"},{"kind":"text","text":".) ―         -b4-  See also 8, in two places."}],"source_refs":["S","Msb","K","TA","Mgh","TK"]}]},"classical_definitions":null}