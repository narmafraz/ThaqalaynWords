{"lemma":"شُهْرَةٌ","slug":"شُهْرَةٌ","root":"ش.ه.ر","root_slug":"ش-ه-ر","root_link":"/words/roots/ش-ه-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23209"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8F%D9%87%D9%92%D8%B1%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of شَهَرَ (šahara) (form I)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"fame, renown"}]},"etymology":null,"ipa":["/ʃuh.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23209","headword_ar":"شُهْرَةٌ","root":"$hr","body":[{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"AlAi$otihaAru","text_ar":"الاِشْتِهَارُ"},{"kind":"text","text":", (Mgh,) signifying The"},{"kind":"italic_en","text":"appearance, conspicuousness, manifestness, notoriousness, notableness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"publicity,"},{"kind":"text","text":"of a thing: (S, O, Msb:) or [generally] its"},{"kind":"italic_en","text":"appearance,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"as bad, evil, abominable, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unseemly;"},{"kind":"text","text":"its"},{"kind":"italic_en","text":"notoriousness in a bad sense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infamousness."},{"kind":"text","text":"(A, K.) ―         -b2-"},{"kind":"italic_en","text":"Any evil thing that exposes its author to disgrace; any disgraceful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shameful, thing; a vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(IAar, O, TA.) ―         -b3-"},{"kind":"italic_en","text":"A dress of the most excellent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superb kind;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"one of the vilest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meanest kind:"},{"kind":"text","text":"both of which are forbidden. (Mgh.) ―         -b4-  [It is also used in the sense of"},{"kind":"arabic","text_bw":"ma$ohuwrN","text_ar":"مَشْهُورٌ"},{"kind":"text","text":".] One says,"},{"kind":"arabic","text_bw":"jaEalahu $uhorapF","text_ar":"جَعَلَهُ شُهْرَةً"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He rendered him notorious,"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"in a bad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a good sense"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"SaAra $uhorapF","text_ar":"صَارَ شُهْرَةً"},{"kind":"text","text":", (K in art."},{"kind":"arabic","text_bw":"dwl","text_ar":"دول"},{"kind":"text","text":",) i. e."},{"kind":"arabic","text_bw":"ma$ohuwrFA","text_ar":"مَشْهُورًا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He became notorious,"},{"kind":"text","text":"&c.]; said of a man. (TK in that art.)"}],"source_refs":["Mgh","S","O","Msb"]}]},"classical_definitions":null}