{"lemma":"ضَنِيَ","slug":"ضَنِيَ","root":"ض.ن.#","root_slug":"ض-ن-_","root_link":"/words/roots/ض-ن-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ضَنِيْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ضَنِيْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ضَنِيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ضَنِيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ضَنِيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ضَنِيَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ضَنِيَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ضَنِيا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ضَنِيَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ضَنُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ضَنِيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَضْنَى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَضْنَِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَضْنَِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَضْنَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَضْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَضْنَُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَضْنَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضْنَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَضْنَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَضْنَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضْنَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضْنَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضْنَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضْنَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضْنَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ضَنِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَنِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَضْنَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَضْنَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n26088","n26093","n26095"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D9%86%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26088","headword_ar":"ضَنِىَ","root":"DnY","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"DanFY","text_ar":"ضَنًى"},{"kind":"text","text":"; (S, M, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"ADTnY","text_ar":"اضطنى","orth_type":"arrow"},{"kind":"text","text":"signifies the same;"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slender, and small in body:"},{"kind":"text","text":"and hence, (Ham p. 112,)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, diseased, disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sick;"},{"kind":"text","text":"(S, and Ham ibid.;) because disease occasions leanness, or emaciation: (Ham:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"(so accord. to the explanation of the inf. n. in the Mgh:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with a disease, disorder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sickness,"},{"kind":"text","text":"(M, Msb, K,)"},{"kind":"italic_en","text":"of long continuance, and settled,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"constant, so that he was at the point of death,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"such as infected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pervaded, him, and so that, whenever he thought himself to be recovering, he relapsed."},{"kind":"text","text":"(K.)       -A2-  [See also 1 in art."},{"kind":"arabic","text_bw":"Dnw","text_ar":"ضنو"},{"kind":"text","text":".]"}],"source_refs":["S","M","Msb","K","Ham"]},{"entry_id":"n26093","headword_ar":"ضَنًى","root":"DnY","body":[{"kind":"text","text":": inf. n. of 1. (S, M, &c.) ―         -b2-  Also, [in some copies of the K erroneously written"},{"kind":"arabic","text_bw":"DaniY~N","text_ar":"ضَنِىٌّ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"DanK","text_ar":"ضَنٍ","orth_type":"arrow"},{"kind":"text","text":"; (S, M, Msb, K;) the former applied alike to a man (Fr, IAar, T, S, Msb) and to a woman (IAar, T, S, Msb) and to two persons (Msb) and to a pl. number, (Fr, IAar, T, S, Msb,) because originally an inf. n., (S, Msb,) for"},{"kind":"arabic","text_bw":"*uw DanFY","text_ar":"ذُو ضَنًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*aAtu DanFY","text_ar":"ذَاتُ ضَنًى"},{"kind":"text","text":"[&c.]; (Msb;) or some do not dualize it nor pluralize it, because it is [originally] an inf. n., and others dualize it and pluralize it; (M;) but ↓"},{"kind":"arabic","text_bw":"DanK","text_ar":"ضَنٍ","orth_type":"arrow"},{"kind":"text","text":"has a fem. (Msb) and a dual and a pl., (S,) its fem. being"},{"kind":"arabic","text_bw":"DaniyapN","text_ar":"ضَنِيَةٌ"},{"kind":"text","text":"(Msb, TA) [and its dual"},{"kind":"arabic","text_bw":"DaniyaAni","text_ar":"ضَنِيَانِ"},{"kind":"text","text":"] and the pl. is"},{"kind":"arabic","text_bw":"A^aDonaA='N","text_ar":"اَضْنَا=ءٌ"},{"kind":"text","text":"; (TA;) ["},{"kind":"italic_en","text":"Slender, and small in body:"},{"kind":"text","text":"and hence, (see 1,)]"},{"kind":"italic_en","text":"diseased, disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sick:"},{"kind":"text","text":"(S:) [or"},{"kind":"italic_en","text":"lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"(see again 1:)] or"},{"kind":"italic_en","text":"affected with a disease, disorder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sickness,"},{"kind":"text","text":"(M, Msb, K,)"},{"kind":"italic_en","text":"of long continuance, and settled,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"constant, so that he is at the point of death,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"such as infects,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pervades, him, and so that, whenever he thinks himself to be recovering, he relapses."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"tarakotuhu DanFY","text_ar":"تَرَكْتُهُ ضَنًى"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"DaniyFA","text_ar":"ضَنِيًا","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I left him lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diseased,"},{"kind":"text","text":"&c.]. (S.)"}],"source_refs":["Fr","IAar","T","S","Msb","TA","M","K"]},{"entry_id":"n26095","headword_ar":"ضِنًى","root":"DnY","body":[{"kind":"text","text":", [written in the TA"},{"kind":"arabic","text_bw":"DnA","text_ar":"ضنا"},{"kind":"text","text":", but the final radical is"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":",] with kesr, accord to IAar, signifies"},{"kind":"italic_en","text":"Pains that cause fear."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D9%86%D9%8A/","headword_ar":"ضني","entries":[{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=17237#7c4020","body_html":"<span class=\"title1\">ض ن ي</span><br><br><span>ضني فلان ضنًى شديداً، وهو ضنٍ: به داء مخامر كلما ظن أنه قد بريء نكس، وأضناه المرض. وتقول: هو بين سفر ينضيه، ومرض يضنيه.</span>"},{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=17237#21e2d4","body_html":"<span class=\"title1\">ض ن ي</span><span>: (الضَّنَى) الْمَرَضُ وَبَابُهُ صَدِيَ فَهُوَ رَجُلٌ (ضَنًى) وَ (ضَنٍ) يُقَالُ: تَرَكْتُهُ ضَنًى وَضَنِيًا. وَ (أَضْنَاهُ) الْمَرَضُ أَثْقَلَهُ. </span>"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=17237#f09cfa","body_html":"ضني: ضنّي (بالتشديد): أنحل أهزل جسمه (فوك).<br>انضني: نحل، هزل، ضمُر، ومرض حتى نحل جسمه، ضِنيَ (بوشر).<br>ضَنَى: تستعمل مجازاً بمعنى بؤس، شقاء، ألم، عذاب، وجَع (رسالة إلى السيد فليشر ص176).<br>ضِنْئ: تصحيف ضِنْأ: أصل (معجم مسلم).<br>مُضْئ: ضَنِي، مُحْتضر، مشرف على الموت، منازع (بوشر)."},{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=17237#7c9d1f","body_html":"ضني<br> ضَنِيَ(n. ac. ضَنَي)<br>a. Was sickly, ailing.<br> <br> ضَاْنَيَأَضْنَيَa. Weakened, wasted, reduced (illness).<br> <br> إِنْضَنَيَ<br> a. [ coll. ], Wasted away.<br> <br> إِضْتَنَيَ<br> (ط)<br>a. see I <br> ضَِنْو [ضَنْي]<br>a. Children, offspring.<br> <br> ضَنًىa. Sickliness, weakness, languor.<br> b. Sickly, ailing; invalid.<br> <br> ضَنٍ (pl.<br> أَضْنَآء [] )<br>a. see 4 (b)<br> ضَانِي<br> a. see under <br> ضَأَنَ"},{"lexicon_id":"dictionary_17","lexicon_en":"Al-Fayyūmī, Al-Miṣbāḥ al-Munīr fī Gharīb al-Sharḥ al-Kabīr (d. 1368 CE)","lexicon_ar":"المصباح المنير للفيّومي","permalink":"https://arabiclexicon.hawramani.com/?p=17237#95f38e","body_html":"<span class=\"title1\">ض ن ي</span><span> : ضَنِيَ ضَنًى مِنْ بَابِ تَعِبَ مَرِضَ مَرَضًا مُلَازِمًا حَتَّى أَشْرَفَ عَلَى الْمَوْتِ فَهُوَ ضَنٍ بِالنَّقْصِ وَامْرَأَةٌ ضَنِيَةٌ وَيَجُوزُ الْوَصْفُ بِالْمَصْدَرِ فَيُقَالُ هُوَ وَهِيَ وَهُمْ وَهُنَّ ضَنًى وَالْأَصْلُ ذُو ضَنًى أَوْ ذَاتُ ضَنًى وَالضَّنَاءُ بِالْفَتْحِ وَالْمَدِّ اسْمٌ مِنْهُ وَأَضْنَاهُ الْمَرَضُ بِالْأَلِفِ فَهُوَ مُضْنًى وَضَنَأَتْ الْمَرْأَةُ تَضْنَأُ مَهْمُوزٌ بِفَتْحَتَيْنِ كَثُرَ وَلَدُهَا فَهِيَ ضَانِئَةٌ. </span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=17237#2f258d","body_html":"<span class=\"title1\">الضاد والنون والياء ض ن ي</span><br><br><span>الضَّنَى السَّقيمُ الذي طال مَرَضُه وَثَبَتَ فيه بعضُهم لا يُثَنِّيه ولا يَجْمَعُه قال عَوْفُ بن الأَحْوَصِ الجَعْفَريُّ</span><br><br><span>(أَوْدَى بَنِيَّ فَمَا بِرَحْلِي مِنهُمُ </span><span class=\"red\">...</span><span> إلا غُلاَمَا بِيَئةٍ ضَنَيانِ) </span><span>هكذا أنشده أبو عليٍّ الفارسيُّ بفتح النون وقد ضَنِيَ ضَنىً فهو ضَنٍ وأضْنَاه المرضُ وضَنَتِ المرأةُ تَضْنِي ضَناً وضَنَاءً كَثُرَ ولَدُها ض ي ن</span>"},{"lexicon_id":"dictionary_11","lexicon_en":"Ibn al-Athīr al-Jazarī, al-Nihāya fī Gharīb al-Ḥadīth wa-l-Athar (d. 1210 CE) النهاية في غريب الحديث والأثر لأبي السعادات ابن الأثير الجزري","lexicon_ar":"","permalink":"https://arabiclexicon.hawramani.com/?p=17237#c6f43f","body_html":"<span class=\"title1\">(ضني)</span><br><span>(س) فِي حَدِيثِ الحدُود «إنَّ مَرِيضاً اشْتَكَى حَتَّى أَضْنَى» أَيْ أصابَه الضَّنَى وَهُوَ شدُة المَرَض حَتَّى نَحَل جسْمُه.</span><br><span>(س) وَفِيهِ «لَا تَضْطَنِي عَنِّي» أَيْ لَا تَبُخَلي بانبِساطِك إليَّ، وَهُوَ افْتِعَالٌ مِنَ الضَّنَى:</span><br><span>الَمَرض، والطاءُ بدلٌ مِنَ التَّاءِ.</span><br><span>(هـ) وَفِي حَدِيثِ ابْنِ عُمَرَ «قَالَ لَهُ أعْرَابي: إِنِّي أعطيتُ بعضَ بَنِيَّ نَاقَةً حيَاتَه، وإنَّها أَضْنَتْ واضْطَربت، فَقَالَ: هِيَ لَهُ حياتَه ومَوْتَه» .</span><br><span>قَالَ الْهَرَوِيُّ والخطَّابي: هَكَذَا رُوي. والصَّواب: ضَنَتْ، أَيْ كَثُر أولادُها. يُقَالُ امْرَأَةٌ ماشيةٌ وضَانِيَة، وَقَدْ مَشَت وضَنَتْ: أَيْ كَثُرَ أولادُها.</span><br><span>وَقَالَ غَيرُهما: يُقَالُ ضَنَتِ المرأةُ تَضْنِي ضَنًى، وأَضْنَتْ، وضَنَأَتْ، وأَضْنَأَتْ، إِذَا كَثُر أولادها. </span>"}]}}