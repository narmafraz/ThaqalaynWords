es":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14804","n15002","n16968"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to have currency, to circulate, to sell well, to be in demand, to burgeon, to be buoyant"}]},"etymology":{"source":"wiktextract","text":"Back-formation from رَوَاج (rawāj)."},"ipa":["/raː.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14804","headword_ar":"رَاجٌّ","root":"rj","body":[{"kind":"italic_en","text":"Having a confusion of voices,"},{"kind":"text","text":"by reason of the multitude of the people therein. (Aboo-Moosà, TA in art."},{"kind":"arabic","text_bw":"zj","text_ar":"زج"},{"kind":"text","text":")"}],"source_refs":[]},{"entry_id":"n15002","headword_ar":"رَاجٍ","root":"rjw","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Hoping:"},{"kind":"text","text":"―         -b2-  and"},{"kind":"italic_en","text":"Fearing"},{"kind":"text","text":"]. (Msb.)"}],"source_refs":[]},{"entry_id":"n16968","headword_ar":"رَاجَ","root":"rwj","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaruwju","text_ar":"يَرُوجُ"},{"kind":"text","text":", (S, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"rawaAjN","text_ar":"رَوَاجٌ"},{"kind":"text","text":", (S, A, K,) or this is a simple subst., and the inf. n. is"},{"kind":"arabic","text_bw":"rawojN","text_ar":"رَوْجٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, or a commodity, Msb)"},{"kind":"italic_en","text":"had an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a ready, sale; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, saleable; easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready, of sale;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand."},{"kind":"text","text":"(S, * A, * Msb, K. *) ―         -b2-  And"},{"kind":"arabic","text_bw":"raAjati Ald~araAhimu","text_ar":"رَاجَتِ الدَّرَاهِمُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rawojN","text_ar":"رَوْجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The dirhems,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"money, passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had currency, among men, in buying and selling."},{"kind":"text","text":"(Msb, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"rAj AlA^amoru","text_ar":"راج الاَمْرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rawojN","text_ar":"رَوْجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rawaAjN","text_ar":"رَوَاجٌ"},{"kind":"text","text":", accord. to IKoot,"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quick, speedy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expeditious:"},{"kind":"text","text":"(L, Msb:) or"},{"kind":"italic_en","text":"came quickly."},{"kind":"text","text":"(MF.) ―         -b4-  And"},{"kind":"arabic","text_bw":"rAj","text_ar":"راج"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"prepared:"},{"kind":"text","text":"so in the saying,"},{"kind":"arabic","text_bw":"xu*o maA raAja","text_ar":"خُذْ مَا رَاجَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Take thou what is present,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"prepared"},{"kind":"text","text":"]. (Har p. 116.) ―         -b5-  See also 2. ―         -b6-"},{"kind":"arabic","text_bw":"rAjt Alr~iyHu","text_ar":"راجت الرِّيحُ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"rw~jt","text_ar":"روّجت","orth_type":"arrow"},{"kind":"text","text":", (Msb, [app. a mistranscription, unless"},{"kind":"arabic","text_bw":"ruw~ijat","text_ar":"رُوِّجَت"},{"kind":"text","text":"be meant,])"},{"kind":"italic_en","text":"The wind was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confused,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"not continuing from one direction,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"so that one knew not whence it came."},{"kind":"text","text":"(K.)"}],"source_refs":["S","A","Msb","K","L"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%A7%D8%AC/","headword_ar":"راجا","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=125693#f961fe","body_html":"راجا<br>عن الهندية راجا بمعنى أمير إقطاعي، وسلطان الإقليم."}]}}