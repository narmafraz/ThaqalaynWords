{"lemma":"فَخِّ","slug":"فَخِّ","root":"ف.خ.خ","root_slug":"ف-خ-خ","root_link":"/words/roots/ف-خ-خ","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n33180","n33181"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AE%D9%90%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to snore"},{"pos":"verb","gloss":"to lie resupine"},{"pos":"verb","gloss":"to diffuse, to be respired"},{"pos":"noun","gloss":"verbal noun of فَخَّ (faḵḵa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"trap, snare, gin"}]},"etymology":{"source":"wiktextract","text":"Compare فَاحَ (fāḥa), فَاخَ (fāḵa), نَفَحَ (nafaḥa), نَفَخَ (nafaḵa), فَحَّ (faḥḥa).\n\nBorrowed from Aramaic פחא / ܦܚܐ (paḥḥā, “trap, snare, gin”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33180","headword_ar":"فَخَّ","root":"fx","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faxiyxN","text_ar":"فَخِيخٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"fax~N","text_ar":"فَخٌّ"},{"kind":"text","text":"; and so ↓"},{"kind":"arabic","text_bw":"Aftx~","text_ar":"افتخّ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"AifotixaAxN","text_ar":"اِفْتِخَاخٌ"},{"kind":"text","text":"; (TA;) said of one sleeping,"},{"kind":"italic_en","text":"He snored;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a sound in breathing, audible by persons around him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gaT~a","text_ar":"غَطَّ"},{"kind":"text","text":": (S, L, K:) or"},{"kind":"arabic","text_bw":"fax~N","text_ar":"فَخٌّ"},{"kind":"text","text":"in sleep is [the"},{"kind":"italic_en","text":"making a sound"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"less than what is termed"},{"kind":"arabic","text_bw":"gaTiyTN","text_ar":"غَطِيطٌ"},{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"gaT~a","text_ar":"غَطَّ"},{"kind":"text","text":"]: and it signifies also a man's"},{"kind":"italic_en","text":"sleeping, and blowing in sleep."},{"kind":"text","text":"(L.)"}],"source_refs":["S","K","TA","L"]},{"entry_id":"n33181","headword_ar":"فَخٌّ","root":"fx","body":[{"kind":"italic_en","text":"A snare, trap, gin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"net, for catching game"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any kind of wild animals"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"birds;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"miSoyadapN","text_ar":"مِصْيَدَةٌ"},{"kind":"text","text":": (S, A, L, Msb, * K:) said to be a Pers., or foreign, word, arabicized: (TA:) [from the Pers."},{"kind":"arabic","text_bw":"faxo","text_ar":"فَخْ"},{"kind":"text","text":":] AM says that the Arabs called it"},{"kind":"arabic","text_bw":"TaroqN","text_ar":"طَرْقٌ"},{"kind":"text","text":"[q. v.; and see also"},{"kind":"arabic","text_bw":"TiboqN","text_ar":"طِبْقٌ"},{"kind":"text","text":"]: (TA:) and ↓"},{"kind":"arabic","text_bw":"fax~apN","text_ar":"فَخَّةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (L:) pl. of the former"},{"kind":"arabic","text_bw":"fixaAxN","text_ar":"فِخَاخٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"fuxuwxN","text_ar":"فُخُوخٌ"},{"kind":"text","text":". (S, A, K.)"},{"kind":"arabic","text_bw":"wavaba fulaAnN mino fax~i A_iboliysa","text_ar":"وَثَبَ فُلَانٌ مِنْ فَخِّ اـِبْلِيسَ"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"Such a one leaped from the snare of Iblees"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"such a one repented."},{"kind":"text","text":"(A.)"}],"source_refs":["TA","L","S","A","Msb","K"]}]},"classical_definitions":null}