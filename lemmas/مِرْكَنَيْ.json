kind":"italic_en","text":"having"},{"kind":"arabic","text_bw":"A^arokaAn","text_ar":"اَرْكَان"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"corners,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"angles"},{"kind":"text","text":"]. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"DaroEN murak~anN","text_ar":"ضَرْعٌ مُرَكَّنٌ"},{"kind":"italic_en","text":"A great udder;"},{"kind":"text","text":"as though having"},{"kind":"arabic","text_bw":"ArkAn","text_ar":"اركان"},{"kind":"text","text":": (S, TA:) and"},{"kind":"italic_en","text":"an udder that has opened"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"expanded"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in its place so as to fill the"},{"kind":"arabic","text_bw":"A^arofaAg","text_ar":"اَرْفَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groins"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and is not very long."},{"kind":"text","text":"(TA.) Tarafeh says,"},{"kind":"quote","text":"waDar~atuhaA murak~anapN daruwru"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And her udder is great, having much milk:"},{"kind":"text","text":"or,] accord. to AA,"},{"kind":"arabic","text_bw":"mrk~np","text_ar":"مركّنة"},{"kind":"text","text":"[here] signifies"},{"kind":"arabic","text_bw":"mjm~Ep","text_ar":"مجمّعة"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"collecting much"},{"kind":"text","text":"]. (TA.) And you say also"},{"kind":"arabic","text_bw":"naAqapN murak~anapu AlD~aroEi","text_ar":"نَاقَةٌ مُرَكَّنَةُ الضَّرْعِ"},{"kind":"text","text":"(S, TA) ["},{"kind":"italic_en","text":"A she-camel great in the udder;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"whose udder has"},{"kind":"arabic","text_bw":"A^arokaAn","text_ar":"اَرْكَان"},{"kind":"italic_en","text":"by reason of its greatness."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","TA"]}]}}