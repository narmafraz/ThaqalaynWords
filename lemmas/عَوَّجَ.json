{"lemma":"عَوَّجَ","slug":"عَوَّجَ","root":"ع.#.ج","root_slug":"ع-_-ج","root_link":"/words/roots/ع-_-ج","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَوَّجْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَوَّجْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَوَّجْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَوَّجْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَوَّجْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَوَّجَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَوَّجَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَوَّجا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَوَّجَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَوَّجُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَوَّجْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَوِّج","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَوِّجِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَوِّجِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَوِّجُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَوِّجُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَوِّجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَوِّج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَوِّج","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَوِّجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَوِّجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَوِّجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"عَوَّجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَوَّجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعَوِّج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَوِّج","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"عَوَّجَ","root":"عوج","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n30915","n30918","n30919"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%88%D9%8E%D9%91%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"crookedness"},{"pos":"noun","gloss":"deviation"},{"pos":"verb","gloss":"to bend, crook"}]},"etymology":null,"ipa":["/ʕi.wad͡ʒ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30915","headword_ar":"عَوِجَ","root":"Ewj","body":[{"kind":"text","text":", (S, O, L, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaEowaju","text_ar":"يَعْوَجُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":"(S, O, L, Msb) and"},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ"},{"kind":"text","text":", (L,) or the latter is a simple subst.; (S, O, K;) and ↓"},{"kind":"arabic","text_bw":"AiEowaj~a","text_ar":"اِعْوَجَّ","orth_type":"arrow"},{"kind":"text","text":", [which is more common,] inf. n."},{"kind":"arabic","text_bw":"AiEowijaAjN","text_ar":"اِعْوِجَاجٌ"},{"kind":"text","text":"; (S, O, L, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AnEAj","text_ar":"انعاج","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tEw~j","text_ar":"تعوّج","orth_type":"arrow"},{"kind":"text","text":"; (L;)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, crooked, curved, bent, winding, wry, contorted, distorted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uneven:"},{"kind":"text","text":"(L:) or ["},{"kind":"arabic","text_bw":"Eawija","text_ar":"عَوِجَ"},{"kind":"text","text":"and] ↓"},{"kind":"arabic","text_bw":"AEwj~","text_ar":"اعوجّ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, so of itself;"},{"kind":"text","text":"and [↓"},{"kind":"arabic","text_bw":"AnEAj","text_ar":"انعاج","orth_type":"arrow"},{"kind":"text","text":"and] ↓"},{"kind":"arabic","text_bw":"tEw~j","text_ar":"تعوّج","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, so by the operation of an external agent;"},{"kind":"text","text":"(L, Msb;) as is said by Az: (L:) ↓"},{"kind":"arabic","text_bw":"AnEAj","text_ar":"انعاج","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"Eujotuhu","text_ar":"عُجْتُهُ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"tEw~j","text_ar":"تعوّج","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"Eaw~ajotuhu","text_ar":"عَوَّجْتُهُ"},{"kind":"text","text":": (Az, S, O, L, Msb, K:) and"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ"},{"kind":"text","text":"are said to be used in relation to different things: (S, O, L, Msb, K, &c.:) [for instance,] one says,"},{"kind":"arabic","text_bw":"Eawija","text_ar":"عَوِجَ"},{"kind":"arabic","text_bw":"AlEuwdu","text_ar":"العُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, crooked, curved, bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distorted:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eawija AlA^amoru","text_ar":"عَوِجَ الاَمْرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult, arduous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome."},{"kind":"text","text":"(MA.) [See"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":"below.] ―         -b2-"},{"kind":"arabic","text_bw":"laA Eiwaja lahu","text_ar":"لَا عِوَجَ لَهُ"},{"kind":"text","text":", in the Kur xx. 107, means"},{"kind":"italic_en","text":"There shall be no evading it."},{"kind":"text","text":"(Jel.) ―         -b3-"},{"kind":"arabic","text_bw":"Eujotu A_ilayohi","text_ar":"عُجْتُ اـِلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^aEuwju","text_ar":"اَعُوجُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EiyaAjN","text_ar":"عِيَاجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, towards it;"},{"kind":"text","text":"namely, a place of abode. (L.) And"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnEAj","text_ar":"انعاج","orth_type":"arrow"},{"kind":"italic_en","text":"He turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, towards it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"(S, O.) And ↓"},{"kind":"arabic","text_bw":"AnEAjt","text_ar":"انعاجت","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tEw~jt","text_ar":"تعوّجت","orth_type":"arrow"},{"kind":"text","text":", said of a she-camel,"},{"kind":"italic_en","text":"She turned aside;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became turned aside;"},{"kind":"text","text":"the former quasi-pass. of"},{"kind":"arabic","text_bw":"EaAjahaA","text_ar":"عَاجَهَا"},{"kind":"text","text":"; and the latter, of"},{"kind":"arabic","text_bw":"Eaw~ajahaA","text_ar":"عَوَّجَهَا"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"EAj bihi","text_ar":"عاج بِهِ"},{"kind":"italic_en","text":"He inclined, and came to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to him and alighted at his abode as a guest:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he passed by him."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Eujotu biAlmakaAni","text_ar":"عُجْتُ بِالمَكَانِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^aEuwju","text_ar":"اَعُوجُ"},{"kind":"text","text":", (S, O, K, *) inf. n."},{"kind":"arabic","text_bw":"EawojN","text_ar":"عَوْجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEaAjN","text_ar":"مَعَاجٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Ew~jtu","text_ar":"عوّجتُ","orth_type":"arrow"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"I remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place."},{"kind":"text","text":"(S, O, K. *) And"},{"kind":"arabic","text_bw":"EAj Ealayohi","text_ar":"عاج عَلَيْهِ"},{"kind":"italic_en","text":"He stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused, at it."},{"kind":"text","text":"(S, * O, * K, * TA.) A poet says,"},{"kind":"quote","text":"EujonaA EalaY raboEi salomaY A^aY~a taEoriyji"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We stopped at the abode of Selmà, with what a staying!"},{"kind":"text","text":"]: putting"},{"kind":"arabic","text_bw":"tEryj","text_ar":"تعريج"},{"kind":"text","text":"[in some copies of the S"},{"kind":"arabic","text_bw":"tEwyj","text_ar":"تعويج"},{"kind":"text","text":"] in the place of"},{"kind":"arabic","text_bw":"Eawoj","text_ar":"عَوْج"},{"kind":"text","text":"because their meaning is one. (S, O, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"fulaAnN maA yaEuwju Eano","text_ar":"فُلَانٌ مَا يَعُوجُ عَنْ"},{"kind":"arabic","text_bw":"$aYo'K","text_ar":"شَىْءٍ"},{"kind":"italic_en","text":"Such a one does not revert from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquish, anything."},{"kind":"text","text":"(IAar, S, O, K. *) ―         -b6-  Accord. to AA, [the inf. n.]"},{"kind":"arabic","text_bw":"EiyaAjN","text_ar":"عِيَاجٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"returning to that upon which one had been intent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employed."},{"kind":"text","text":"(O and TA in art."},{"kind":"arabic","text_bw":"Eyj","text_ar":"عيج"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"Eujotuhu","text_ar":"عُجْتُهُ"},{"kind":"text","text":": see 2. ―         -b2-"},{"kind":"arabic","text_bw":"Eujotu AlbaEiyra","text_ar":"عُجْتُ البَعِيرَ"},{"kind":"text","text":", (S, A, * O, K, *) and"},{"kind":"arabic","text_bw":"Eujotu","text_ar":"عُجْتُ"},{"kind":"arabic","text_bw":"raA^osa AlbaEiyri","text_ar":"رَاْسَ البَعِيرِ"},{"kind":"text","text":", (L,) aor."},{"kind":"arabic","text_bw":"A^aEuwjuhu","text_ar":"اَعُوجُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EawojN","text_ar":"عَوْجٌ"},{"kind":"text","text":"(S, O, L) and"},{"kind":"arabic","text_bw":"maEaAjN","text_ar":"مَعَاجٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"I turned the camel's head by means of the nose-rein:"},{"kind":"text","text":"(S, A, * O, L, K: *) and in like manner one says of a horse: and"},{"kind":"arabic","text_bw":"EAj","text_ar":"عاج"},{"kind":"arabic","text_bw":"naAqatahu","text_ar":"نَاقَتَهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Ew~jhA","text_ar":"عوّجها","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He turned aside his she-camel."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"EAj raA^osahu A_ilaY AlmaroA^api","text_ar":"عاج رَاْسَهُ اـِلَى المَرْاَةِ"},{"kind":"text","text":"(O and TA from a trad.)"},{"kind":"italic_en","text":"He inclined his head towards the woman, and looked towards her."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlmaroA^apu taEuwju","text_ar":"المَرْاَةُ تَعُوجُ"},{"kind":"arabic","text_bw":"raA^osahaA A_ilaY DajiyEihaA","text_ar":"رَاْسَهَا اـِلَى ضَجِيعِهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The woman turns her head towards her bedfellow"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"EAj Eunuqahu","text_ar":"عاج عُنُقَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EawojN","text_ar":"عَوْجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent, his neck."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eujo lisaAnaka Ean~iY walaA tukoviro","text_ar":"عُجْ لِسَانَكَ عَنِّى وَلَا تُكْثِرْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Turn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withhold, thy tongue from me, and do not multiply"},{"kind":"text","text":"words]. (A.) And"},{"kind":"arabic","text_bw":"bihi AlT~ariyqu","text_ar":"بِهِ الطَّرِيقُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Eaw~aja","text_ar":"عَوَّجَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The road led him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned him, aside"},{"kind":"text","text":"]. (K in explanation of"},{"kind":"arabic","text_bw":"Haw~aja","text_ar":"حَوَّجَ"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"maA A^aEuwju bikalaAmihi","text_ar":"مَا اَعُوجُ بِكَلَامِهِ"},{"kind":"italic_en","text":"I do not pay regard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attention, to his speech,"},{"kind":"text","text":"(ISk, S in art."},{"kind":"arabic","text_bw":"Eyj","text_ar":"عيج"},{"kind":"text","text":", A, * and O,) is a phrase of the Benoo-Asad, who take it from"},{"kind":"arabic","text_bw":"Eujotu Aln~aAqapa","text_ar":"عُجْتُ النَّاقَةَ"},{"kind":"text","text":": (ISk, S, O:) others say"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"A^aEiyju","text_ar":"اَعِيجُ"},{"kind":"text","text":". (O.) And one says,"},{"kind":"arabic","text_bw":"maA Eujotu biHadiyvihi","text_ar":"مَا عُجْتُ بِحَدِيثِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I did not pay regard to his discourse"},{"kind":"text","text":"]. (A.) ―         -b4-"},{"kind":"arabic","text_bw":"Eujotuhu biAlmakaAni","text_ar":"عُجْتُهُ بِالمَكَانِ"},{"kind":"italic_en","text":"I made him to remain, stay, dwell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abide, in the place:"},{"kind":"text","text":"the verb being trans. as well as intrans. (S, O.)"}],"source_refs":["S","O","L","Msb","K","TA","Az","ISk"]},{"entry_id":"n30918","headword_ar":"عَوَجٌ","root":"Ewj","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ","orth_type":"arrow"},{"kind":"text","text":"[are inf. ns. of"},{"kind":"arabic","text_bw":"Eawija","text_ar":"عَوِجَ"},{"kind":"text","text":", q. v., or the latter is a simple subst.; and both, used as simple substs.,] signify"},{"kind":"italic_en","text":"Crookedness, curvity, a bending, a winding, wryness, contortion, distortion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unevenness:"},{"kind":"text","text":"(L:) or the former is peculiar to objects of the sight, as bodies; and the latter, to what are not seen, as opinion, and a saying, and religion: or, as some say, the latter is used in both of these cases; but the distinction is more common: (IAth, TA:) AZ makes the same distinction; but adds that some of the Arabs used the latter word in relation to a road: (Msb:) accord. to ISk, (S, O,) the former is in anything erect, (S, O, K,) or in anything that was erect and has inclined, (TA,) as a wall, (S, O, K, TA,) and a stick, (S, O, Msb,) or a staff, (K, TA,) and a spear; (TA;) and the latter, in land, or ground, and in religion, (S, O, Msb, K, TA,) and in means of subsistence: (S, O:) in land, or ground, the latter means"},{"kind":"italic_en","text":"unevenness;"},{"kind":"text","text":"thus in the Kur xx. 106: in a road,"},{"kind":"italic_en","text":"deflection;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":": in religion, and in natural disposition,"},{"kind":"italic_en","text":"corruptness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviation from rectitude:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":", (S, O, TA, [thus accord. to both of my copies of the S,]) or"},{"kind":"arabic","text_bw":"EiwajN","text_ar":"عِوَجٌ"},{"kind":"text","text":", (accord. to a copy of the A, [which"},{"kind":"page_break","n":2188},{"kind":"text","text":"I incline to regard as the right, in consideration of its consistency with explanations here preceding, notwithstanding the apparent preponderance of authority in favour of"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":",]) in a man, signifies"},{"kind":"italic_en","text":"evilness of natural disposition:"},{"kind":"text","text":"(S, A, O: [and so, app.,"},{"kind":"arabic","text_bw":"hawajN","text_ar":"هَوَجٌ"},{"kind":"text","text":":]) or"},{"kind":"arabic","text_bw":"EawajN","text_ar":"عَوَجٌ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", as an inf. n., signifies the"},{"kind":"italic_en","text":"being evil in natural disposition."},{"kind":"text","text":"(KL.)"}],"source_refs":["L","IAth","TA","Msb","S","O","K"]},{"entry_id":"n30919","headword_ar":"عِوَجٌ","root":"Ewj","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]},"classical_definitions":null}