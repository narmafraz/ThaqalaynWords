%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fondle, to caress, to stroke"},{"pos":"verb","gloss":"to treat with kindness, benevolence"},{"pos":"adj","gloss":"active participle of لَطَفَ (laṭafa)","tags":["active","form-of","participle"]}]},"etymology":null,"ipa":["/laː.tˤa.fa/","/laː.tˤif/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43308","headword_ar":"لَاطَفَ","root":"lTf","body":[{"kind":"italic_en","text":"He caressed; treated with blandishment; soothed; coaxed; wheedled; cajoled: i. q."},{"kind":"arabic","text_bw":"baAr~ahu","text_ar":"بَارَّهُ"},{"kind":"text","text":". (S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"laATafahu","text_ar":"لَاطَفَهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He spoke softly, gently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blandly, to him."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"He acted in a good manner with him:"},{"kind":"text","text":"(KL:)"},{"kind":"italic_en","text":"manifested goodness towards him:"},{"kind":"text","text":"(PS:)"},{"kind":"italic_en","text":"he acted towards him with goodness:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he did so, experiencing from him the same:"},{"kind":"text","text":"(TK:) or rather, as syn. with"},{"kind":"arabic","text_bw":"baAr~ahu","text_ar":"بَارَّهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he behaved towards him with goodness and affection and gentleness, and regard for his circumstances;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did so, experiencing from him the same behaviour."}],"source_refs":["KL","PS","TK"]}]}}