":"p"},{"role":"present_1ms","form":"أَجْس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"جَسَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَسَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَجْسُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْسُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5775","n5814"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B3%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be rough, hard, stiff, callous","tags":["obsolete"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5775","headword_ar":"جَسَاَ","root":"jsA^","body":[{"kind":"text","text":", aor"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"jusuwo'N","text_ar":"جُسُوْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jusoA^apN","text_ar":"جُسْاَةٌ"},{"kind":"text","text":", (K,) thus in the corrected copies of the K, but in some copies the latter inf. n. is written"},{"kind":"arabic","text_bw":"jusaA='apN","text_ar":"جُسَا=ءَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, tough, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff;"},{"kind":"text","text":"(K, TA;) as also"},{"kind":"arabic","text_bw":"jasaA","text_ar":"جَسَا"},{"kind":"text","text":", aor"},{"kind":"text","text":"(Msb and K in art."},{"kind":"arabic","text_bw":"jsw","text_ar":"جسو"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"jasaA^ato yaduhu","text_ar":"جَسَاَتْ يَدُهُ"},{"kind":"text","text":", aor"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"jaso'N","text_ar":"جَسْءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"His hand became hard, tough, callous,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough,"},{"kind":"text","text":"(TA,) from work. (S, TA.)―         -b3-"},{"kind":"arabic","text_bw":"jasaA^ato mafaASiluhu","text_ar":"جَسَاَتْ مَفَاصِلُهُ"},{"kind":"italic_en","text":"His joints became rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"jusiy^ati AlA^aroDu","text_ar":"جُسِيَتِ الاَرْضُ"},{"kind":"italic_en","text":"The ground became hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard and level, and rough:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"jaso'N","text_ar":"جَسْءٌ"},{"kind":"text","text":", explained below. (Ks, K.)"}],"source_refs":["K","TA","S"]},{"entry_id":"n5814","headword_ar":"جَسَا","root":"jsm","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jasowN","text_ar":"جَسْوٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"jusuw~N","text_ar":"جُسُوٌّ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a man, M, TA, or a thing, Msb,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, tough, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff:"},{"kind":"text","text":"(M, Msb, K:) [see also"},{"kind":"arabic","text_bw":"jasaA^a","text_ar":"جَسَاَ"},{"kind":"text","text":": or, said of a man,]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, rough, harsh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungentle; contr. of"},{"kind":"arabic","text_bw":"laTufa","text_ar":"لَطُفَ"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"jasati Alyadu","text_ar":"جَسَتِ اليَدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jusuw~N","text_ar":"جُسُوٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jasFA","text_ar":"جَسًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"The hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"in the bones, with little flesh;"},{"kind":"text","text":"(TA;) and in the same sense the verb is said of other things. (S.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"congealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"froze."},{"kind":"text","text":"(S, TA.) ―         -b3-  Also, inf. n."},{"kind":"arabic","text_bw":"jusuw~N","text_ar":"جُسُوٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an old man)"},{"kind":"italic_en","text":"attained the utmost age"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so that his limbs became rigid"},{"kind":"text","text":"]. (S, TA.)"}],"source_refs":["S","M","Msb","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AC%D8%B3%D8%A7/","headword_ar":"جسا","entries":[{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=3619#99d02f","body_html":"<span class=\"title1\">[جسا]</span><span> جَسا: ضدُّ لَطُفَ. وجَسِيّتِ اليدُ وغيرها جُسُوًّا: يَبِسَتْ. وجَسا الشيخُ جُسُوًّا: بلغ غاية السنّ. والماء: جمد.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=3619#b40f9d","body_html":"<p>جسا: جَسَا: ضِدُّ لَطُفَ، وجَسَا الرجلُ جَسْواً وجُسُوّاً: صَلُبَ.</p><p>ويَدٌ جاسِيَةٌ:يابسة العظام قليلة اللحم. وجَسِيَتِ اليَدُ وغيرُها</p><p>جُسُوّاً وجَساً: يَبِسَتْ. وجَسا جُسُوّاً: بلغ غاية السِّنِّ. وجَسا الماءُ:</p><p>جَمُدَ. ودابَّةٌ جاسِيَةُ القوائم: يابستُها. ورِماحٌ جاسِيَةٌ: كَزَّةٌ</p><p>صُلْبة، وقد ذكر بعض ذلك في باب الهمز.</p><p>والجَيْسُوانُ، بضم السين: جنس من النَّخْلِ له بُسْرٌ جَيِّدٌ، واحدته</p><p>جَيْسُوانةٌ؛ عن أَبي حنيفة. وقال مرة: سمي الجَيْسُوانَ لطُول شَماريخه،</p><p>شُبِّه بالذَّوائب، قال: والذَّوائبُ بالفارسية كَيْسُوان.</p>"}]}}