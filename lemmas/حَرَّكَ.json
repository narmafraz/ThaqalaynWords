false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n7740"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D9%8E%D9%91%D9%83%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to move","tags":["intransitive"]},{"pos":"verb","gloss":"to be impotent (of a man)","tags":["intransitive"]},{"pos":"verb","gloss":"to move","tags":["transitive"]},{"pos":"verb","gloss":"to awaken, to activate"},{"pos":"verb","gloss":"to begin, to start (a war, a fight, etc.)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7740","headword_ar":"حَرُكَ","root":"Hrk","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (IKtt, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HarakN","text_ar":"حَرَكٌ"},{"kind":"text","text":", (IKtt, Msb, MF,) or"},{"kind":"arabic","text_bw":"HarokN","text_ar":"حَرْكٌ"},{"kind":"text","text":", with fet-h, (K,) as in the 'Eyn and O, but disallowed by MF, (TA,) [and probably transcribed from some lexicon in which, as is often the case, “ with fet-h ” relates to the medial radical letter,] and"},{"kind":"arabic","text_bw":"HarakapN","text_ar":"حَرَكَةٌ"},{"kind":"text","text":", (K,) or this is an inf. n. of un.; (Msb; [but in general usage it is not thus restricted;]) and ↓"},{"kind":"arabic","text_bw":"tHr~k","text_ar":"تحرّك","orth_type":"arrow"},{"kind":"text","text":"[which is the more common]: (S, Msb, K:) [both signify the same;"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, moved; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of motion. commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation; shook, shook about, wabbled, tottered, waggled, wagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nodded:"},{"kind":"text","text":"or the latter verb, more properly,"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it put itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he put himself, in a state of motion, commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation:"},{"kind":"text","text":"and the latter also signifies"},{"kind":"italic_en","text":"he became active;"},{"kind":"text","text":"said of a growing child, and of a young gazelle &c.: (see"},{"kind":"arabic","text_bw":"HarikN","text_ar":"حَرِكٌ"},{"kind":"text","text":":)] the former is the"},{"kind":"italic_en","text":"contr."},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":"; (Msb, K;) and the latter is"},{"kind":"italic_en","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"Har~akotuhu","text_ar":"حَرَّكْتُهُ"},{"kind":"text","text":". (S, Msb, K.)       -A2-"},{"kind":"arabic","text_bw":"Harakahu","text_ar":"حَرَكَهُ"},{"kind":"text","text":", (AA, S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HarokN","text_ar":"حَرْكٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, his"},{"kind":"text","text":"(a man's, AA, K)"},{"kind":"arabic","text_bw":"HaArik","text_ar":"حَارِك"},{"kind":"text","text":". (AA, S, K.) Accord. to Fr,"},{"kind":"arabic","text_bw":"Haraka HaArikahu","text_ar":"حَرَكَ حَارِكَهُ"},{"kind":"italic_en","text":"He cut his"},{"kind":"arabic","text_bw":"HaArik","text_ar":"حَارِك"},{"kind":"text","text":". (TA.) And accord. to AZ,"},{"kind":"arabic","text_bw":"Harakahu biAls~ayofi","text_ar":"حَرَكَهُ بِالسَّيْفِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Haroko","text_ar":"حَرْكْ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He smote"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"severed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his neck with the sword."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"Harika","text_ar":"حَرِكَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (IAar, K,) inf. n."},{"kind":"arabic","text_bw":"HarakN","text_ar":"حَرَكٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, incapable of coition"},{"kind":"text","text":"(IAar, K)"},{"kind":"italic_en","text":"with women."},{"kind":"text","text":"(IAar, TA.)"}],"source_refs":["IKtt","Msb","K","MF","TA","S","AA","IAar","TK"]}]}}