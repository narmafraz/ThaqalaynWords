1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْشَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْشَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":true,"lemma_key":"عَشِيَ","root":"عشو","pos":"N","occurrence_count":10},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n29237","n29259","n29250"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B4%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"late evening","examples":[{"text":"وَٱصْبِرْ نَفْسَكَ مَعَ ٱلَّذِينَ يَدْعُونَ رَبَّهُم بِٱلْغَدَوٰةِ وَٱلْعَشِىِّ يُرِيدُونَ وَجْهَهُۥ ۖ","english":"And patiently stick with those who call upon their Lord in early morning and late evening, seeking His pleasure."}]},{"pos":"noun","gloss":"evening, time between sunset and isha"},{"pos":"noun","gloss":"afternoon, latter part of the day"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of عَشِيَ (ʕašiya, “to develop poor eyesight especially at night”)."},"ipa":["/ʕa.ʃijj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29237","headword_ar":"عِشْىٌ","root":"E$w","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Ea$aA='N","text_ar":"عَشَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n29259","headword_ar":"عِشْىٌ","root":"Quasi E$Y","body":[{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":", &c.: see in art."},{"kind":"arabic","text_bw":"E$w","text_ar":"عشو"},{"kind":"text","text":"."},{"kind":"page_break","n":2057}],"source_refs":[]},{"entry_id":"n29250","headword_ar":"عَشِىٌّ","root":"E$w","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"late part of the evening:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"evening:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"afternoon:"},{"kind":"text","text":"i. e.] the"},{"kind":"italic_en","text":"last,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"latter, part of the day;"},{"kind":"text","text":"(Mgh, Msb, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) this is the meaning commonly known: (Mgh:) or [the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the prayer of sunset to the"},{"kind":"arabic","text_bw":"Eatamap","text_ar":"عَتَمَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"darkness after nightfall"},{"kind":"text","text":"]; (S, Msb, TA;) like"},{"kind":"arabic","text_bw":"Ei$aA='N","text_ar":"عِشَا=ءٌ"},{"kind":"text","text":"; (Msb;) and so ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": you say,"},{"kind":"arabic","text_bw":"A^atayotuhu Ea$iY~a A^amosi","text_ar":"اَتَيْتُهُ عَشِىَّ اَمْسِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amosi","text_ar":"اَمْسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ea$iy~apa","text_ar":"عَشِيَّةَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came to him late in the evening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the time between sunset and nightfall,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of yesterday"},{"kind":"text","text":"]: (S, TA:) or"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"has the meaning expl. in the K [and mentioned above]; but ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"relates to one day: and one says,"},{"kind":"arabic","text_bw":"jiy^otuhu","text_ar":"جِيْتُهُ"},{"kind":"arabic","text_bw":"Ea$iy~apF","text_ar":"عَشِيَّةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came to him late in an evening,"},{"kind":"text","text":"&c.] and"},{"kind":"arabic","text_bw":"Ea$iy~apa","text_ar":"عَشِيَّةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"late this evening,"},{"kind":"text","text":"&c.], and"},{"kind":"arabic","text_bw":"A^atayotuhu AlEa$iy~apa","text_ar":"اَتَيْتُهُ العَشِيَّةَ"},{"kind":"italic_en","text":"I came to him in the"},{"kind":"arabic","text_bw":"E$y~p","text_ar":"عشيّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"late part of the evening,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"of this day;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=tiyhi Ea$iY~a gadK","text_ar":"ا=تِيهِ عَشِىَّ غَدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will come to him in the late part of the evening,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of to-morrow"},{"kind":"text","text":"(in my original"},{"kind":"arabic","text_bw":"Atyth","text_ar":"اتيته"},{"kind":"text","text":", an obvious mistranscription,)] without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"when relating to the future; and"},{"kind":"arabic","text_bw":"A^atayotuka Ea$iy~FA","text_ar":"اَتَيْتُكَ عَشِيًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came to thee in the late part of an evening,"},{"kind":"text","text":"&c.]; and"},{"kind":"arabic","text_bw":"A^atayotuhu biAlgadaApi","text_ar":"اَتَيْتُهُ بِالغَدَاةِ"},{"kind":"arabic","text_bw":"waAlEa$iY~i","text_ar":"وَالعَشِىِّ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"I came to him early in the morning and late in the evening,"},{"kind":"text","text":"&c., meaning,]"},{"kind":"italic_en","text":"every"},{"kind":"arabic","text_bw":"Ea$iy~ap","text_ar":"عَشِيَّة"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"Ea$iY~","text_ar":"عَشِىّ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"gadaAp","text_ar":"غَدَاة"},{"kind":"text","text":": (TA:) or, as some say, ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"is a sing. [or n. un.] and"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"is its pl. [or a coll. gen. n.]: and, as IAmb says, sometimes the Arabs make ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"masc., as meaning"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"time between the declining of the sun"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the meridian"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and sunset:"},{"kind":"text","text":"(Az, Mgh, Msb, TA:) or [the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the declining of the sun"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the meridian"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the"},{"kind":"arabic","text_bw":"SabaAH","text_ar":"صَبَاح"},{"kind":"text","text":"[app. here, as generally, meaning"},{"kind":"italic_en","text":"morning"},{"kind":"text","text":"]: (Er-Rághib, Msb, TA:) and sometimes it means the"},{"kind":"italic_en","text":"night:"},{"kind":"text","text":"(TA:) the pl. is"},{"kind":"arabic","text_bw":"Ea$aAyaA","text_ar":"عَشَايَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ea$iy~aAtN","text_ar":"عَشِيَّاتٌ"},{"kind":"text","text":", (K, TA,) the former of which [is pl. of ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":", like the latter, or perhaps of"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"also, and] is originally"},{"kind":"arabic","text_bw":"Ea$aAyiwu","text_ar":"عَشَايِوُ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"Ea$aAyiYu","text_ar":"عَشَايِىُ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"Ea$aAy^iYu","text_ar":"عَشَايِىُ"},{"kind":"text","text":", then"},{"kind":"arabic","text_bw":"Ea$aA'aY","text_ar":"عَشَاءَى"},{"kind":"text","text":", and then"},{"kind":"arabic","text_bw":"Ea$aAyaA","text_ar":"عَشَايَا"},{"kind":"text","text":": (TA:) the dim, of"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"Eu$ay~aAnN","text_ar":"عُشَيَّانٌ","orth_type":"arrow"},{"kind":"text","text":", irreg., as though formed from"},{"kind":"arabic","text_bw":"Ea$oyaAnN","text_ar":"عَشْيَانٌ"},{"kind":"text","text":", and its pl. is"},{"kind":"arabic","text_bw":"Eu$ay~aAnaAtN","text_ar":"عُشَيَّانَاتٌ"},{"kind":"text","text":"; and another form of its dim. is ↓"},{"kind":"arabic","text_bw":"Eu$ayo$iyaAnN","text_ar":"عُشَيْشِيَانٌ","orth_type":"arrow"},{"kind":"text","text":", pl."},{"kind":"arabic","text_bw":"Eu$ayo$iyaAnaAtN","text_ar":"عُشَيْشِيَانَاتٌ"},{"kind":"text","text":": and the dim. of ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"Eu$ayo$iyapN","text_ar":"عُشَيْشِيَةٌ","orth_type":"arrow"},{"kind":"text","text":", pl."},{"kind":"arabic","text_bw":"Eu$ayo$iyaAtN","text_ar":"عُشَيْشِيَاتٌ"},{"kind":"text","text":": (S, TA:) one says, ↓"},{"kind":"arabic","text_bw":"laqiytuhu Eu$ayo$apF","text_ar":"لَقِيتُهُ عُشَيْشَةً","orth_type":"arrow"},{"kind":"text","text":"[another form of dim., properly meaning"},{"kind":"italic_en","text":"I met him in a short period of a late part of an evening,"},{"kind":"text","text":"&c.], and [in like manner] ↓"},{"kind":"arabic","text_bw":"Eu$ayo$aAnFA","text_ar":"عُشَيْشَانًا","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Eu$ay~aAnFA","text_ar":"عُشَيَّانًا","orth_type":"arrow"},{"kind":"text","text":"[in some copies of the K"},{"kind":"arabic","text_bw":"E$~AnA","text_ar":"عشّانا"},{"kind":"text","text":"], and ↓"},{"kind":"arabic","text_bw":"Eu$ayo$iyapF","text_ar":"عُشَيْشِيَةً","orth_type":"arrow"},{"kind":"text","text":"[accord. to the Mgh meaning"},{"kind":"arabic","text_bw":"Ei$aA='F","text_ar":"عِشَا=ءً"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Eu$ayo$aAtK","text_ar":"عُشَيْشَاتٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eu$ayo$iyaAnaAtK","text_ar":"عُشَيْشِيَانَاتٍ"},{"kind":"text","text":". (K.)"},{"kind":"arabic","text_bw":"SalaAtaA AlEa$iY~i","text_ar":"صَلَاتَا العَشِىِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The two prayers of the afternoon"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"the two prayers of the"},{"kind":"arabic","text_bw":"Zuhor","text_ar":"ظُهْر"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"EaSor","text_ar":"عَصْر"},{"kind":"text","text":"; (Az, Mgh, Msb, K;) because they are in the latter part of the day ("},{"kind":"arabic","text_bw":"fiY A=xiri Aln~ahaAri","text_ar":"فِى ا=خِرِ النَّهَارِ"},{"kind":"text","text":"), after the"},{"kind":"arabic","text_bw":"zawaAl","text_ar":"زَوَال"},{"kind":"text","text":"[or declining of the sun from the meridian]. (TA.) In the phrase"},{"kind":"arabic","text_bw":"A^awoDuHaAhaA","text_ar":"اَوْضُحَاهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ea$iy~apF","text_ar":"عَشِيَّةً","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"A late part of an evening,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"its early portion of the forenoon,"},{"kind":"text","text":"meaning or"},{"kind":"italic_en","text":"an early portion of the forenoon of the same civil day"},{"kind":"text","text":"], in the Kur lxxix. last verse, the"},{"kind":"arabic","text_bw":"DHY","text_ar":"ضحى"},{"kind":"text","text":"is prefixed to [the pronoun referring to] the"},{"kind":"arabic","text_bw":"E$y~p","text_ar":"عشيّة"},{"kind":"text","text":"because the"},{"kind":"arabic","text_bw":"DHY","text_ar":"ضحى"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"E$y~p","text_ar":"عشيّة"},{"kind":"text","text":"belong to the same [civil] day, [for this day is reckoned as the period from sunset to sunset,] (Ksh Bd, Jel, *) and also [by a kind of poetic license, for the sake of the rhyme, i. e.] because"},{"kind":"arabic","text_bw":"DHAhA","text_ar":"ضحاها"},{"kind":"text","text":"occurs as a"},{"kind":"arabic","text_bw":"faASilap","text_ar":"فَاصِلَة"},{"kind":"text","text":"[q. v.]. (Jel.) ―         -b2-"},{"kind":"arabic","text_bw":"Ea$iY~N","text_ar":"عَشِىٌّ"},{"kind":"text","text":"also signifies, (K, TA,) and so does ↓"},{"kind":"arabic","text_bw":"Ea$iy~apN","text_ar":"عَشِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Clouds"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"coming late in the evening"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at eventide"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Ea$iy~FA","text_ar":"عَشِيًّا"},{"kind":"text","text":"). (TA.) ―         -b3-  And the former, as an epithet applied to a camel,"},{"kind":"italic_en","text":"That continues long eating the"},{"kind":"arabic","text_bw":"Ea$aA='","text_ar":"عَشَا=ء"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"evening-pasture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evening-feed"},{"kind":"text","text":"]: fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (K. [See also"},{"kind":"arabic","text_bw":"Ea$K","text_ar":"عَشٍ"},{"kind":"text","text":".])"}],"source_refs":["K","TA","Mgh","S","Msb","Az"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D8%B4%D9%8A/","headword_ar":"عشي","entries":[{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=16095#9b1ba6","body_html":"عشي<br> عَشِيَ(n. ac. عَشًا [ ])<br>a. Was weaksighted, night-blind.<br> b. see V <br> عَشَّيَa. Gave supper to; pastured at night ( camels). <br>b. Caught by means of a fire (birds).<br> <br> أَعْشَيَa. see II (a)b. Dazzled, blinded; rendered weaksighted.<br> <br> تَعَشَّيَa. Supped, took supper; pastured by night (<br> camels ). <br> تَعَاْشَيَa. Feigned blindness; feigned ignorance.<br> <br> إِعْتَشَيَa. Journeyed, set out at night-fall.<br> b. [acc.<br> or <br> Bi]<br>see I (c)<br> إِسْتَعْشَيَa. Guided himself by (watchfire).<br> <br> عَشْوَة []<br>a. Darkness.<br> <br> عُِشْوَة [عِشْيَة]<br>a. Watch-fire.<br> <br> عَشَوِيّ []<br>a. Evening, belonging to the evening.<br> <br> أَعْشَى []<br>a. Night-blind.<br> <br> عَاشِيَة [] (pl.<br> عَوَاشٍ [] )<br>a. Pasturing at night (camel). <br> عَشَآء [] (pl.<br> أَعْشِيَة [] )<br>a. Supper.<br> b. Weaksight; nightblindness; sightlessness.<br> <br> عَشَاوَة []<br>a. see 22 (b)<br> عِشَآء []<br>a. Night-fall.<br> <br> عَشِيّ []<br>a. see 25t <br> عَشِيَّة [] ( pl.<br> reg. &amp; <br>a. عَشَايَا ), Evening, even;<br> night-fall. <br> عَشْوَآء []<br>a. Blind camel.<br> b. Darkness.<br> <br> عَشِّي<br> a. [ coll. ], Cook. <br> عَشِيَّة أَمْسٍ<br> a. Last night, yesternight, yesterday evening.<br> <br> العَشَآء السِّرِّيّ<br> a. [ coll. ], The Holy Communion.<br> <br> خَبَطَهُ خَبْطَ عَشْوَآء<br> a. He did it without aim, without perception, at <br> random."},{"lexicon_id":"dictionary_17","lexicon_en":"Al-Fayyūmī, Al-Miṣbāḥ al-Munīr fī Gharīb al-Sharḥ al-Kabīr (d. 1368 CE)","lexicon_ar":"المصباح المنير للفيّومي","permalink":"https://arabiclexicon.hawramani.com/?p=16095#1ea30e","body_html":"<span class=\"title1\">ع ش ي</span><span> : الْعَشِيُّ قِيلَ مَا بَيْنَ الزَّوَالِ إلَى الْغُرُوبِ وَمِنْهُ يُقَالُ لِلظُّهْرِ وَالْعَصْرِ صَلَاتَا الْعَشِيِّ وَقِيلَ هُوَ آخِرُ النَّهَارِ وَقِيلَ الْعَشِيُّ مِنْ الزَّوَالِ إلَى الصَّبَاحِ وَقِيلَ الْعَشِيُّ وَالْعِشَاءُ مِنْ صَلَاةِ الْمَغْرِبِ إلَى الْعَتَمَةِ وَعَلَيْهِ قَوْلُ ابْنِ فَارِسٍ الْعِشَاءَانِ الْمَغْرِبُ وَالْعَتَمَةُ قَالَ ابْنُ الْأَنْبَارِيِّ الْعَشِيَّةُ مُؤَنَّثَةٌ وَرُبَّمَا ذَكَّرَتْهَا الْعَرَبُ عَلَى مَعْنَى الْعَشِيِّ وَقَالَ بَعْضُهُمْ الْعَشِيَّةُ وَاحِدَةٌ جَمْعُهَا عَشِيٌّ.</span><br><br><span>وَالْعِشَاءُ بِالْكَسْرِ وَالْمَدِّ أَوَّلُ ظَلَامِ اللَّيْلِ.</span><br><br><span>وَالْعَشَاءُ بِالْفَتْحِ وَالْمَدِّ الطَّعَامُ الَّذِي يُتَعَشَّى بِهِ وَقْتَ الْعِشَاءِ وَعَشَّيْتُ فُلَانًا بِالتَّثْقِيلِ وَعَشَوْتُهُ أَطْعَمْتُهُ الْعَشَاءَ وَتَعَشَّيْتُ أَنَا أَكَلْت الْعَشَاءَ وَعَشِيَ عشى مِنْ بَابِ تَعِبَ ضَعُفَ بَصَرُهُ فَهُوَ أَعْشَى وَالْمَرْأَةُ عَشْوَاءُ. </span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=16095#03fd49","body_html":"<span class=\"title1\">الْعين والشين وَالْيَاء</span><br><br><span>العَيْشُ: الْحَيَاة. عاشَ عَيْشا وعِيشَةً ومَعِيشا ومَعاشا وعَيْشُوشةً وأعاشه الله. قَالَ ابْن أبي دَاوُد وَسَأَلَهُ أَبوهُ: مَا الَّذِي أعاشك بعدِي؟ فَأَجَابَهُ:</span><br><br><span>أعاشني بَعْدَكَ وادٍ مُبْقِلُ </span><span class=\"red\">...</span><span> آكُلُ مِنْ حَوْذَانِه وأَنْسِلُ</span><br><br><span>وعايَشَهُ: عَاشَ مَعَه، كَقَوْلِك عامره. قَالَ قعنب بن أم صَاحب:</span><br><br><span>وَقد علمْتُ على أَنِّي أُعايِشُهُمْ </span><span class=\"red\">...</span><span> لَا نَبرَحُ الدَّهْرَ إلاَّ بَيْنَنا إحَنُ</span><br><br><span>والعِيشَةُ: ضرب من الْعَيْش.</span><br><br><span>والمَعاشُ والمَعِيشُ والمعِيَشُة: مَا يُعاشُ بِهِ. وَجمع المَعِيشَةِ مَعايِشُ على الْقيَاس، ومعائش على غير قِيَاس وَقد قريء بهما. وَرويت عَن نَافِع مَهْمُوزَة وَجَمِيع النَّحْوِيين الْبَصرِيين يَزْعمُونَ أَن همزها خطأ.</span><br><br><span>والمعاش: مَظَنَّة ذَلِك، وَفِي التَّنْزِيل (وجعلنَا النَّهار مَعَاشا) أَي </span><span>ملتمسا للْعَيْشِ.</span><br><br><span>والمُتَعَيِّشُ: ذُو الْبلْغَة من العَيْش.</span><br><br><span>والعائِشُ: ذُو الْحَالة الْحَسَنَة.</span><br><br><span>والعَيْشُ: الطَّعَام، يَمَانِية.</span><br><br><span>وَفِي مثل \" أَنْت مرّة عَيْش وَمرَّة جَيش \" أَي تَنْفَع مرّة وتضر أُخْرَى. وَقَالَ أَبُو عبيد: مَعْنَاهُ أَنْت مرّة فِي عَيْش رخي وَمرَّة فِي جَيش غزي. وَقَالَ ابْن الْأَعرَابِي: قيل لرجل: كَيفَ فلَان؟ قَالَ: عَيْش وجيش. أَي مرّة معي وَمرَّة عَليّ.</span><br><br><span>وعائِشَةُ اسْم امْرَأَة.</span><br><br><span>وَبَنُو عائِشَةَ قَبيلَة من تيم اللات.</span><br><br><span>وعَيَّاشٌ ومُعَيِّشٌ اسمان.</span>"}]}}