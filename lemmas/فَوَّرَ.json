","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفَوِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفَوِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفَوِّر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفَوِّر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفَوِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفَوِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفَوِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفَوِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفَوِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفَوِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفَوِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفَوِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفَوِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَوَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَوَّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"فَوَّرَ","root":"فور","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","prep"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32824","n34794","n34795"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D9%88%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of فَارَ (fāra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"prep","gloss":"immediately at, immediately after","examples":[{"text":"وخطف اللبنانيون الثلاثة وأحدهم رجل أعمال فور وصولهم الأحد الماضي إلى العاصمة العراقية.","english":"And the three Lebanese – one of them a man of business – have been kidnapped immediately after their arrival last Sunday at the Iraqi capital."},{"text":"كَانَ يُرِيدُ أَنْ يَعُودَ إِلَى ٱلْبَصْرَةِ فَوْرَ أَنْ يَسْتَرِدَّ صِحَّتَهُ، وَيَعُودَ إِلَيْهَا عَبْرَ ٱلصَّحْرَاءِ أَيْضًا إِذَا لَزِمَ ٱلْأَمْرُ","english":"He wanted to go back to Basra as soon as he recovered, even if it meant going back through the desert."}]}]},"etymology":{"source":"wiktextract","text":"Adverbial accusative of فَوْر (fawr)."},"ipa":["/fawr/","/faw.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32824","headword_ar":"فُوَرٌ","root":"fA^r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faA^orN","text_ar":"فَاْرٌ"},{"kind":"text","text":", first sentence."}],"source_refs":[]},{"entry_id":"n34794","headword_ar":"فَوْرٌ","root":"fwr","body":[{"kind":"text","text":"[originally an inf. n.: see 1.] The"},{"kind":"italic_en","text":"burning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heat, and boiling,"},{"kind":"text","text":"of Hell. (TA.) And"},{"kind":"italic_en","text":"Intenseness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemence,"},{"kind":"text","text":"of heat; (TA;) as also ↓"},{"kind":"arabic","text_bw":"faworapN","text_ar":"فَوْرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (S.) ―         -b2-"},{"kind":"arabic","text_bw":"faworu Al$~afaqi","text_ar":"فَوْرُ الشَّفَقِ"},{"kind":"italic_en","text":"The remains of the redness in the western horizon after sunset:"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"vaworuhu","text_ar":"ثَوْرُهُ"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"faworapN","text_ar":"فَوْرَةٌ"},{"kind":"text","text":".]       -A2-  And"},{"kind":"italic_en","text":"A time:"},{"kind":"text","text":"(TA:) [or rather] the"},{"kind":"italic_en","text":"present time in which is no delaying."},{"kind":"text","text":"(Msb.) Thus in the saying,"},{"kind":"arabic","text_bw":"Al$~ufoEapu","text_ar":"الشُّفْعَةُ"},{"kind":"arabic","text_bw":"EalaY Alfawori","text_ar":"عَلَى الفَوْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The right of pre-emption is to be had"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the present time in which is no delaying."},{"kind":"text","text":"(Msb.) ―         -b2-  And hence,"},{"kind":"italic_en","text":"A state in which is no delay."},{"kind":"text","text":"(Msb.) You say,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN fiY HaAjatihi vum~a rajaEa","text_ar":"جَا=ءَ فُلَانٌ فِى حَاجَتِهِ ثُمَّ رَجَعَ"},{"kind":"arabic","text_bw":"mino faworihi","text_ar":"مِنْ فَوْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one came for the object of his want,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"then returned immediately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at once:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"with the same motion with which he came, not ceasing from motion after it;"},{"kind":"text","text":"properly,"},{"kind":"italic_en","text":"conjoining what was before the coming with what was after it, without tarrying."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^atawoA mino faworihimo","text_ar":"اَتَوْا مِنْ فَوْرِهِمْ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"mino wajohihimo","text_ar":"مِنْ وَجْهِهِمْ"},{"kind":"text","text":"[i. e., app.,"},{"kind":"italic_en","text":"They came in a headlong manner;"},{"kind":"text","text":"like the phrase"},{"kind":"arabic","text_bw":"maDaY EalaY wajohihi","text_ar":"مَضَى عَلَى وَجْهِهِ"},{"kind":"text","text":"]; (M, K, TA; but the M has"},{"kind":"arabic","text_bw":"jaAw^uwA","text_ar":"جَاوُوا"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"A^atawoA","text_ar":"اَتَوْا"},{"kind":"text","text":";) and this is said by Zj to be the meaning of"},{"kind":"arabic","text_bw":"mino faworihimo","text_ar":"مِنْ فَوْرِهِمْ"},{"kind":"text","text":"in the Kur iii. 121: (M, TA:) or"},{"kind":"arabic","text_bw":"qabola A^ano yasokunuwA","text_ar":"قَبْلَ اَنْ يَسْكُنُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"before their resting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceasing from motion"},{"kind":"text","text":"]: (K, TA:) or"},{"kind":"arabic","text_bw":"mino faworihimo","text_ar":"مِنْ فَوْرِهِمْ"},{"kind":"text","text":"in the Kur ubi suprà means"},{"kind":"italic_en","text":"in the commencement of their procedure:"},{"kind":"text","text":"(O:) or"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at, their instant of time;"},{"kind":"text","text":"(Ksh, Bd;) i. e. ["},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at, the same instant,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"immediately:"},{"kind":"text","text":"(Bd:) and"},{"kind":"arabic","text_bw":"A^atayotu fulaAnFA","text_ar":"اَتَيْتُ فُلَانًا"},{"kind":"arabic","text_bw":"mino faworiY","text_ar":"مِنْ فَوْرِى"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"qabola A^ano A^asokuna","text_ar":"قَبْلَ اَنْ اَسْكُنَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I came to such a one before my resting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceasing from motion"},{"kind":"text","text":"]. (S, O.) And you say,"},{"kind":"arabic","text_bw":"faEalotuhu mino faworiY","text_ar":"فَعَلْتُهُ مِنْ فَوْرِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I did it at once,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"instantly."},{"kind":"text","text":"(T, TA.)"}],"source_refs":["TA","M","K","O","Bd"]},{"entry_id":"n34795","headword_ar":"فُورٌ","root":"fwr","body":[{"kind":"italic_en","text":"Gazelles:"},{"kind":"text","text":"(T, S, M, K:) a word having no sing.; (T, S, M, TA;) accord. to IAar and Yaakoob: (TA:) or its sing. is ↓"},{"kind":"arabic","text_bw":"faAy^irN","text_ar":"فَايِرٌ","orth_type":"arrow"},{"kind":"text","text":"; (M, K, TA;) accord. to Kr. (TA.) One says,"},{"kind":"arabic","text_bw":"laA A^afoEalu","text_ar":"لَا اَفْعَلُ"},{"kind":"arabic","text_bw":"ka*aA maA laA^olaA^ati Alfuwru","text_ar":"كَذَا مَا لَاْلَاَتِ الفُورُ"},{"kind":"italic_en","text":"I will not do such a thing while the gazelles wag their tails."},{"kind":"text","text":"(IAar, T, S.)"}],"source_refs":["T","S","M","K","TA"]}]},"classical_definitions":null}