en":"m","num":"p"},{"role":"present_2mp","form":"تَدْرُجُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدْرُجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدْرُج","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدْرُج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدْرُجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدْرُجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدْرُجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدْرُجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدْرُجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْرُجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْرُجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَدْرُج","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدْرُج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"دَرَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَرَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":28},"lanes":{"found":true,"entry_ids":["n12379"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%B1%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to step, step onward, walk"},{"pos":"verb","gloss":"to proceed or ascend gradually"},{"pos":"verb","gloss":"to graduate"},{"pos":"verb","gloss":"to be or become customary"},{"pos":"verb","gloss":"to be a custom, be the fashion"},{"pos":"verb","gloss":"to be current, have currency"},{"pos":"verb","gloss":"to be used to, to be accustomed, to have the habit"},{"pos":"verb","gloss":"to pass, depart, disappear, get destroyed"},{"pos":"verb","gloss":"to die","tags":["euphemistic"]},{"pos":"verb","gloss":"to roll up or close a book"},{"pos":"verb","gloss":"to gradate, to divide up"},{"pos":"verb","gloss":"to circulate, to float"},{"pos":"verb","gloss":"to fold up, to curl up"},{"pos":"noun","gloss":"verbal noun of دَرَجَ (daraja, “to roll up”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"roll of paper"},{"pos":"noun","gloss":"volume"},{"pos":"noun","gloss":"fold"},{"pos":"noun","gloss":"entering into a book or register"},{"pos":"noun","gloss":"putting in"},{"pos":"noun","gloss":"road, path"},{"pos":"noun","gloss":"staircase, ladder"},{"pos":"noun","gloss":"mediator"},{"pos":"noun","gloss":"copybook"},{"pos":"noun","gloss":"drawer"},{"pos":"noun","gloss":"plural of دُرَجَة (duraja)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of دَرَجَة (daraja)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of دُرْجَة (durja)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of دُرَجَّة (durajja)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Compare Ge'ez ድርገት (dərgät), Hebrew דֶּרֶג (déreḡ), Classical Syriac ܕܪܓܐ, Aramaic דרגא."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12379","headword_ar":"دَرَجَ","root":"drj","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"duruwjN","text_ar":"دُرُوجٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"darajaAnN","text_ar":"دَرَجَانٌ"},{"kind":"text","text":", (K,) said of a man, and of a [lizard of the kind called]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He went on foot;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"went step by step; stepped along;"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"walked:"},{"kind":"text","text":"(S, K:) and said of a child,"},{"kind":"italic_en","text":"he walked a little, at his first beginning to walk:"},{"kind":"text","text":"(Msb, TA: *) or, said of an old man, and of a child, and of a bird of the kind called"},{"kind":"arabic","text_bw":"qaTFA","text_ar":"قَطًا"},{"kind":"text","text":", aor. as above, inf. n. ["},{"kind":"arabic","text_bw":"duruwjN","text_ar":"دُرُوجٌ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"darojN","text_ar":"دَرْجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"darajaAnN","text_ar":"دَرَجَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dariyjN","text_ar":"دَرِيجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he walked with a weak gait; crept along;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walked, leisurely, slowly, softly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gently."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"daraja qaronN baEoda","text_ar":"دَرَجَ قَرْنٌ بَعْدَ"},{"kind":"arabic","text_bw":"qaronK","text_ar":"قَرْنٍ"},{"kind":"italic_en","text":"Generation after generation passed away."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"daraja Alqawomu","text_ar":"دَرَجَ القَوْمُ"},{"kind":"italic_en","text":"The people passed away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished, none of them remaining;"},{"kind":"text","text":"(S, A, K;) as also ↓"},{"kind":"arabic","text_bw":"AndrjwA","text_ar":"اندرجوا","orth_type":"arrow"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"daraja","text_ar":"دَرَجَ"},{"kind":"italic_en","text":"He left no progeny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring:"},{"kind":"text","text":"(As, S, K:)"},{"kind":"italic_en","text":"he died, and left no progeny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring:"},{"kind":"text","text":"[opposed to"},{"kind":"arabic","text_bw":"A^aEoqaba","text_ar":"اَعْقَبَ"},{"kind":"text","text":":] but you do not say so of every one who has died: (TA:) or it signifies also [simply]"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(Aboo-Tálib, S, A, Msb:) so in the prov.,"},{"kind":"arabic","text_bw":"A^ako*abu","text_ar":"اَكْذَبُ"},{"kind":"arabic","text_bw":"mano dab~a wadaraja","text_ar":"مَنْ دَبَّ وَدَرَجَ"},{"kind":"text","text":"(S, Msb)"},{"kind":"italic_en","text":"The most lying of the living and the dead."},{"kind":"text","text":"(S.) Or"},{"kind":"arabic","text_bw":"daraja","text_ar":"دَرَجَ"},{"kind":"text","text":"signifies, (K,) or signifies also, (S,)"},{"kind":"italic_en","text":"He went his way;"},{"kind":"text","text":"(S, K;) and so"},{"kind":"arabic","text_bw":"darija","text_ar":"دَرِجَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"samiEa","text_ar":"سَمِعَ"},{"kind":"text","text":". (K.)"},{"kind":"arabic","text_bw":"layosa h`*aA","text_ar":"لَيْسَ هٰذَا"},{"kind":"arabic","text_bw":"biEu$~iki faA@dorujiY","text_ar":"بِعُشِّكِ فَا@دْرُجِى"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"This is not thy nest, therefore"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"go thou away,"},{"kind":"text","text":"is a saying occurring in a"},{"kind":"arabic","text_bw":"xuTobap","text_ar":"خُطْبَة"},{"kind":"text","text":"of El-Hajjáj, addressed to him who applies himself to a thing not of his business to do; or to him who is at ease in an improper time; wherefore he is thus ordered to be diligent and in motion. (TA. [See also art."},{"kind":"arabic","text_bw":"E$","text_ar":"عش"},{"kind":"text","text":".]) ―         -b3-"},{"kind":"arabic","text_bw":"darajato","text_ar":"دَرَجَتْ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^adorajato","text_ar":"اَدْرَجَتْ","orth_type":"arrow"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"went beyond the year"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the day when she was covered"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without bringing forth."},{"kind":"text","text":"(S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"darajati Alr~iyHu","text_ar":"دَرَجَتِ الرِّيحُ"},{"kind":"italic_en","text":"The wind left marks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lines,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ripples,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon the sand."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"darajati Alr~iyHu biAlHaSaA","text_ar":"دَرَجَتِ الرِّيحُ بِالحَصَا"},{"kind":"italic_en","text":"The wind passed violently over the pebbles"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"so as to make them move along:"},{"kind":"text","text":"see also 10]. (K.)       -A2-"},{"kind":"arabic","text_bw":"darija","text_ar":"دَرِجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He rose in grade, degree, rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"station."},{"kind":"text","text":"(K, TA.) ―         -b2-"},{"kind":"italic_en","text":"He kept to the plain and manifest way"},{"kind":"text","text":"in religion or in speech. (K, TA.)       -A3-  Also (i. e."},{"kind":"arabic","text_bw":"darija","text_ar":"دَرِجَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"He continued to eat the kind of bird called"},{"kind":"arabic","text_bw":"dur~aAj","text_ar":"دُرَّاج"},{"kind":"text","text":". (K.)       -A4-"},{"kind":"arabic","text_bw":"daraja","text_ar":"دَرَجَ"},{"kind":"text","text":"as a trans. v.: see 4, in two places."}],"source_refs":["S","Msb","K","As","TA"]}]}}