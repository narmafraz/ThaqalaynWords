ons":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7299","headword_ar":"حَدِبَ","root":"Hdb","body":[{"kind":"text","text":", aor"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadabN","text_ar":"حَدَبٌ"},{"kind":"text","text":"; (S, * A, Mgh, * Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AHdb~","text_ar":"احدبّ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tHAdb","text_ar":"تحادب","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AHdwdb","text_ar":"احدودب","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, humpbaked;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"italic_en","text":"he had a prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant, back, and a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receding, chest"},{"kind":"text","text":"(A, * K)"},{"kind":"italic_en","text":"and belly:"},{"kind":"text","text":"(K:) [accord. to the Msb, from"},{"kind":"arabic","text_bw":"HadabN","text_ar":"حَدَبٌ"},{"kind":"text","text":"signifying “ elevated ground; ” but the reverse is indicated in the A:] and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the back)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, humped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant;"},{"kind":"text","text":"(S, A; *) as also ↓"},{"kind":"arabic","text_bw":"AnHdb","text_ar":"انحدب","orth_type":"arrow"},{"kind":"text","text":". (KL.) ―         -b2-  And the first, (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grew up"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out, high:"},{"kind":"text","text":"(KL:) ["},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gibbous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"convex;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHdwdb","text_ar":"احدودب","orth_type":"arrow"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"Hadiba Ealyohi","text_ar":"حَدِبَ عَليْهِ"},{"kind":"text","text":", (S, A, K,) inf. n. as above; (KL, TA;) and ↓"},{"kind":"arabic","text_bw":"tHd~b","text_ar":"تحدّب","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K;) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affectionate, favourable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind, to him."},{"kind":"text","text":"(S, A, * K, KL, TA.) And"},{"kind":"arabic","text_bw":"Hadibato EalaY waladihaA","text_ar":"حَدِبَتْ عَلَى وَلَدِهَا"},{"kind":"text","text":", (K, * TA,) inf. n. as above; (TA;) and ↓"},{"kind":"arabic","text_bw":"tHd~bt","text_ar":"تحدّبت","orth_type":"arrow"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"applied herself constantly to the care of her child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"children, after the loss of her husband, not marrying again."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"Hadaba","text_ar":"حَدَبَ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadobN","text_ar":"حَدْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He repelled from him, and defended him."},{"kind":"text","text":"(MF, TA.)"}],"source_refs":["K","KL","S","A"]}]},"classical_definitions":null}