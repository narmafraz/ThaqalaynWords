arabic","text_bw":"nakovN","text_ar":"نَكْثٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"He dissolved, violated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke,"},{"kind":"text","text":"a covenant, or compact, (S, K,) or an act of inauguration, &c. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"nakava Eani AlA^amori","text_ar":"نَكَثَ عَنِ الاَمْرِ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nakaSa","text_ar":"نَكَصَ"},{"kind":"text","text":"(Aboo-Turáb, in TA, art."},{"kind":"arabic","text_bw":"nkS","text_ar":"نكص"},{"kind":"text","text":".)"}],"source_refs":["S","K","Msb","TA"]}]},"classical_definitions":null}