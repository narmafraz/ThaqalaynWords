gy":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n30516"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B9%D9%92%D8%AA%D9%8E%D9%85%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30516","headword_ar":"اعتمر","root":"Emr","body":[{"kind":"italic_en","text":"He visited."},{"kind":"text","text":"(Msb, K: in some copies of the K"},{"kind":"arabic","text_bw":"AEtmrhu","text_ar":"اعتمرهُ"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"AEtmrhu","text_ar":"اعتمرهُ"},{"kind":"text","text":", (S, O,) and ↓"},{"kind":"arabic","text_bw":"AEmrhu","text_ar":"اعمرهُ","orth_type":"arrow"},{"kind":"text","text":", (ISk, Msb,)"},{"kind":"italic_en","text":"He visited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(S, O;)"},{"kind":"italic_en","text":"he repaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(ISk, S, O, Msb;) as also ↓"},{"kind":"arabic","text_bw":"Eamarahu","text_ar":"عَمَرَهُ","orth_type":"arrow"},{"kind":"text","text":", accord. to one explanation of a passage in the Kur ix. 18, quoted above: [see 1:] but Z says, I know not"},{"kind":"arabic","text_bw":"Eamara","text_ar":"عَمَرَ"},{"kind":"text","text":"as occurring in the sense of"},{"kind":"arabic","text_bw":"AEtmr","text_ar":"اعتمر"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"italic_en","text":"He performed the religious visit called"},{"kind":"arabic","text_bw":"Eumorap","text_ar":"عُمْرَة"},{"kind":"text","text":". (O, TA.) You say"},{"kind":"arabic","text_bw":"AEtmr fiY AlHaj~i","text_ar":"اعتمر فِى الحَجِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He performed the visit so called in the pilgrimage"},{"kind":"text","text":"]. (S.) ―         -b3-"},{"kind":"arabic","text_bw":"AEtmr A^amorFA","text_ar":"اعتمر اَمْرًا"},{"kind":"italic_en","text":"He betook himself to a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair;"},{"kind":"text","text":"as, for instance, a warring and plundering expedition;"},{"kind":"italic_en","text":"aimed at it; purposed it."},{"kind":"text","text":"(TA.)       -A2-  Also"},{"kind":"italic_en","text":"He attired his head"},{"kind":"text","text":"(i. e. his own head)"},{"kind":"italic_en","text":"with an"},{"kind":"arabic","text_bw":"EamaArap","text_ar":"عَمَارَة"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"a turban,"},{"kind":"text","text":"&c. (S, K.)"}],"source_refs":["S","O","ISk","Msb"]}]},"classical_definitions":null}