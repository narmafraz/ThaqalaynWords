: "text", "text": "[this is the primary signification: and hence,]"}, {"kind": "italic_en", "text": "he adduced an indication,"}, {"kind": "text", "text": "&c.: and"}, {"kind": "italic_en", "text": "he drew an inference,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a deduction:"}, {"kind": "text", "text": "(KL:) or"}, {"kind": "italic_en", "text": "he established an indication for the purpose of obtaining a certain knowledge of a thing indicated,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "for the purpose of affirming a thing indicated:"}, {"kind": "text", "text": "and sometimes it is quasi-pass. of"}, {"kind": "arabic", "text_bw": "dal~ahu AlT~ariyqa", "text_ar": "دَلَّهُ الطَّرِيقَ"}, {"kind": "text", "text": "[explained above, so that it signifies"}, {"kind": "italic_en", "text": "he was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, directed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rightly directed,"}, {"kind": "text", "text": "to the way]. (TA. See 1.) [You say,"}, {"kind": "arabic", "text_bw": "Astdl~ bi$aYo'KEalaY $aYo'K A=xara", "text_ar": "استدلّ بِشَىْءٍعَلَى شَىْءٍ ا=خَرَ"}, {"kind": "italic_en", "text": "He desired,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sought, to be directed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "guided, by a thing, to another thing: he adduced,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "took,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regarded, a thing as an indication, an evidence,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a proof, of another thing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "as an argument in favour of another thing: he inferred, from a thing, another thing: he sought,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "found,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "perceived,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "saw, in a thing, an indication, an evidence,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a proof, of another thing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an argument in favour of another thing: he was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, directed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "guided,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "he directed"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "guided himself, by a thing, to another thing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "to the knowledge of another thing."}, {"kind": "arabic", "text_bw": "Ald~aliylu maA yusotadal~a bihi", "text_ar": "الدَّلِيلُ مَا يُسْتَدَلَّ بِهِ"}, {"kind": "text", "text": ", occurring in the S, means"}, {"kind": "italic_en", "text": "The"}, {"kind": "arabic", "text_bw": "dlyl", "text_ar": "دليل"}, {"kind": "italic_en", "text": "is that whereby one is directed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "guided."}, {"kind": "text", "text": "]"}], "source_refs": ["KL"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%A7%D8%B3%D8%AA%D8%AF%D9%84/", "headword_ar": "استدلال", "entries": [{"lexicon_id": "dictionary_18", "lexicon_en": "Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)", "lexicon_ar": "كتاب التعريفات للشريف الجرجاني", "permalink": "https://arabiclexicon.hawramani.com/?p=22818#9a8bbd", "body_html": "<span>الاستدلال: هو تقرير الدليل لإثبات المدلول، سواء كان ذلك من الأثر إلى المؤثر أو العكس، أو من أحد الأثرين إلى الآخر. </span>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}