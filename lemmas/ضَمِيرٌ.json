{"lemma":"ضَمِيرٌ","slug":"ضَمِيرٌ","root":"ض.م.ر","root_slug":"ض-م-ر","root_link":"/words/roots/ض-م-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n26028"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D9%85%D9%90%D9%8A%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"inner, innermost, heart, secrets of the mind"},{"pos":"noun","gloss":"conscience"},{"pos":"noun","gloss":"pronoun"}]},"etymology":null,"ipa":["/dˤa.miːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26028","headword_ar":"ضَمِيرٌ","root":"Dmr","body":[{"kind":"italic_en","text":"A thing that thou concealest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceivest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determinest upon,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tuDomiruhu","text_ar":"تُضْمِرُهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in thy heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind:"},{"kind":"text","text":"(Lth, TA:)"},{"kind":"italic_en","text":"a secret;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":": (K:) a subst. from"},{"kind":"arabic","text_bw":"A^aDomara fiY nafosihi $ayoy^FA","text_ar":"اَضْمَرَ فِى نَفْسِهِ شَيْيًا"},{"kind":"text","text":": (S:) pl."},{"kind":"arabic","text_bw":"DamaAy^iru","text_ar":"ضَمَايِرُ"},{"kind":"text","text":". (S, K.) ―         -b2-  [Hence used as meaning"},{"kind":"italic_en","text":"A pronoun;"},{"kind":"text","text":"which is also termed ↓"},{"kind":"arabic","text_bw":"muDomarN","text_ar":"مُضْمَرٌ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AisomN muDomarN","text_ar":"اِسْمٌ مُضْمَرٌ"},{"kind":"text","text":", lit."},{"kind":"italic_en","text":"a concealed noun,"},{"kind":"text","text":"i. e. a noun of which the signification is not shown by itself alone; opposed to"},{"kind":"arabic","text_bw":"muZoharN","text_ar":"مُظْهَرٌ"},{"kind":"text","text":": pl. of the first as above; and of the second"},{"kind":"arabic","text_bw":"muDomaraAtN","text_ar":"مُضْمَرَاتٌ"},{"kind":"text","text":".] ―         -b3-  See also"},{"kind":"arabic","text_bw":"DamorN","text_ar":"ضَمْرٌ"},{"kind":"text","text":". ―         -b4-  And"},{"kind":"arabic","text_bw":"AlD~amiyru","text_ar":"الضَّمِيرُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The heart"},{"kind":"text","text":"[itself];"},{"kind":"italic_en","text":"the mind; the recesses of the mind; the secret thoughts;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the soul;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qalobu AlA_inosaAni","text_ar":"قَلْبُ الاـِنْسَانِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"baATinuhu","text_ar":"بَاطِنُهُ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"daAxilu","text_ar":"دَاخِلُ"},{"kind":"arabic","text_bw":"AlxaATiri","text_ar":"الخَاطِرِ"},{"kind":"text","text":": (A, K:) pl. as above, (Msb, K,) the sing. being likened to"},{"kind":"arabic","text_bw":"sariyrapN","text_ar":"سَرِيرَةٌ"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"saraAy^iru","text_ar":"سَرَايِرُ"},{"kind":"text","text":". (Msb.) [See also"},{"kind":"arabic","text_bw":"muDomarN","text_ar":"مُضْمَرٌ"},{"kind":"text","text":". And see an ex. in a verse cited in art."},{"kind":"arabic","text_bw":"syH","text_ar":"سيح"},{"kind":"text","text":", 7th conj.]       -A2-  Also"},{"kind":"italic_en","text":"Withered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shrivelled, grapes,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"that are neither fresh grapes nor raisins."},{"kind":"text","text":"(O.)"}],"source_refs":["Lth","TA","K","S","Msb","A","O"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D9%85%D9%8A%D8%B1/","headword_ar":"ضمير","entries":[{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10198#4dba4a","body_html":"<span class=\"title1\">ضمير</span><span> وَقَالَ [أَبُو عبيد -] : فِي حَدِيث عُمَر [بْن عَبْد الْعَزِيز -] أَنه كتب إِلَى مَيْمُون بن مهْرَان فِي مظالم كَانَت فِي بَيت المَال أَن يردّها إِلَى أَرْبَابهَا ويأخُذَ مِنْهَا زكاةَ عامها فانَّه كَانَ مَالا ضمارًا. [قَوْله: ضمارًا -] الضِمار هُوَ الْغَائِب الَّذِي لَا يُرْجَى فَإِذا رُجِيَ فَلَيْسَ بِضمارٍ [قَالَ الرَّاعِي: (الوافر) </span><span>طلَبْنَ مزارَه فأصَبْنَ منْهُ </span><span class=\"red\">...</span><span> عطاءُ لَمْ يَكُن عِدَةً ضمارا -]</span><br><br><span>وَفِي هَذَا الحَدِيث من الْفِقْه أَنه لم ير على المَال زَكَاة إِذا كَانَ لَا يُرْجى وَإِن مرت عَلَيْهِ السِّنون أَلا ترَاهُ [إِنَّمَا -] قَالَ [لَهُ -] : خُذ مِنْهَا زَكَاة عامها.</span>"}]}}