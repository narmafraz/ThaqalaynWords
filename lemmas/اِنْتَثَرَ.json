ntry_ids":["n39318"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AA%D9%8E%D8%AB%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become dispersed, to become dissipated, to become scattered.","examples":[{"text":"إِذَا السَّمَاء انْفَطَرَتْ\nوَإِذَا الْكَوَاكِبُ انْتَثَرَتْ\nوَإِذَا الْبِحَارُ فُجِّرَتْ\nوَإِذَا الْقُبُورُ بُعْثِرَتْ\nعَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ","english":"When the sky breaks apart,\nAnd when the stars commence to scatter,\nAnd when the seas gush forth,\nAnd when the graves are strewn,\nA soul will know what it has put forward and what it has set back."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39318","headword_ar":"انتثر","root":"nvr","body":[{"kind":"text","text":"(S, M, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"ntAvr","text_ar":"نتاثر","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K) and ↓"},{"kind":"arabic","text_bw":"tnv~r","text_ar":"تنثّر","orth_type":"arrow"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"It became scattered, strewn, dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thrown dispersedly:"},{"kind":"text","text":"(S, * M, A, Msb, K:) [or the second more properly signifies"},{"kind":"italic_en","text":"it became scattered,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"by degrees, gradually,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part after part;"},{"kind":"text","text":"resembling"},{"kind":"arabic","text_bw":"tasaAqaTa","text_ar":"تَسَاقَطَ"},{"kind":"text","text":"&c.: and the third, being quasi-pass. of 2, denotes muchness, or frequency, or repetition, of the action; or its application to many things.] You say,"},{"kind":"arabic","text_bw":"Antvrt AlkawaAkibu","text_ar":"انتثرت الكَوَاكِبُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The stars became dispersed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became scattered like grain."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AntvrwA","text_ar":"انتثروا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tnv~rwA","text_ar":"تنثّروا","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"They"},{"kind":"text","text":"(meaning men)"},{"kind":"italic_en","text":"became as though they were scattered by the hand"},{"kind":"text","text":"]. (A.) [And"},{"kind":"arabic","text_bw":"Al$~aEaru","text_ar":"الشَّعَرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tnAvr","text_ar":"تناثر","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alwaraqu","text_ar":"الوَرَقُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The hair,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the leaves, fell off, and became scattered, by degrees."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"Alqawomu","text_ar":"القَوْمُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tnAvr","text_ar":"تناثر","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The people fell sick and died"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one after another"},{"kind":"text","text":"]: (M, K: *) or you say"},{"kind":"arabic","text_bw":"mawotFA","text_ar":"مَوْتًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mariDuwA fatanaAvaruwA","text_ar":"مَرِضُوا فَتَنَاثَرُوا","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"they fell sick and became separated by death, one after another"},{"kind":"text","text":"]. (A.)       -A2-  See also 1, latter half, throughout."}],"source_refs":["S","M","A","Msb","K"]}]}}