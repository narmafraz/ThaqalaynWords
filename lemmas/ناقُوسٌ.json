{"lemma":"ناقُوسٌ","slug":"ناقُوسٌ","root":"ن.ق.س","root_slug":"ن-ق-س","root_link":"/words/roots/ن-ق-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n40397"],"search_url":"https://lanelexicon.com/?s=%D9%86%D8%A7%D9%82%D9%8F%D9%88%D8%B3%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"handbell"},{"pos":"noun","gloss":"handbell; bell"},{"pos":"noun","gloss":"handbell; bell; bell jar"},{"pos":"noun","gloss":"semantron; clapper"},{"pos":"noun","gloss":"semantron; gong; tam-tam"}]},"etymology":{"source":"wiktextract","text":"From Classical Syriac ܢܩܘܫܐ (nāqūšā)."},"ipa":["/naː.quːs/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40397","headword_ar":"نَاقوُسٌ","root":"nqs","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"thing which the Christians strike,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat,"},{"kind":"text","text":"(S, A, Mgh, Msb, K,)"},{"kind":"italic_en","text":"to notify the times of prayer,"},{"kind":"text","text":"(S, A, Mgh, K,)"},{"kind":"italic_en","text":"as a sign for commencing their prayer;"},{"kind":"text","text":"(Msb;) being"},{"kind":"italic_en","text":"a piece of wood, long,"},{"kind":"text","text":"(A, Mgh, K,)"},{"kind":"italic_en","text":"and large"},{"kind":"text","text":"(K,) ["},{"kind":"italic_en","text":"suspended to two cords,"},{"kind":"text","text":"(Golius,)]"},{"kind":"italic_en","text":"with another which is short,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with which the former is struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beaten,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and which is called"},{"kind":"arabic","text_bw":"wabiylN","text_ar":"وَبِيلٌ"},{"kind":"text","text":": (A, K