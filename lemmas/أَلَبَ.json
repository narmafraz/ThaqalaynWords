,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْلُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْلِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْلُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْلُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْلِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْلِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْلُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَأْلِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَلَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَلَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَأْلُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَأْلِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n1046","","n1048","n1049","n1050"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%84%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1046","headword_ar":"اَلَبَ","root":"Alb","body":[{"kind":"text","text":", (Th, M, K,) aor."},{"kind":"text","text":", and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^alobN","text_ar":"اَلْبٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Th, M)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, collected;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AijotamaEa","text_ar":"اِجْتَمَعَ"},{"kind":"text","text":"; (Th, K;) or"},{"kind":"arabic","text_bw":"tajam~aEa","text_ar":"تَجَمَّعَ"},{"kind":"text","text":". (M.) ―         -b2-"},{"kind":"arabic","text_bw":"A^alaba A_ilayohi Alqawomu","text_ar":"اَلَبَ اـِلَيْهِ القَوْمُ"},{"kind":"italic_en","text":"The people came to him from every direction:"},{"kind":"text","text":"(M, K:) or"},{"kind":"arabic","text_bw":"A^alaba Alqawomu","text_ar":"اَلَبَ القَوْمُ"},{"kind":"text","text":"[signifies"},{"kind":"italic_en","text":"the people multiplied themselves, and hastened;"},{"kind":"text","text":"for it] denotes"},{"kind":"arabic","text_bw":"AlA_ikovaAru","text_ar":"الاـِكْثَارُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA_isoraAE","text_ar":"الاـِسْرَاع"},{"kind":"text","text":": (T in art."},{"kind":"arabic","text_bw":"Dhb","text_ar":"ضهب"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"A^alaba","text_ar":"اَلَبَ"},{"kind":"text","text":", (T, K,) aor. as above, (T,) signifies"},{"kind":"italic_en","text":"he hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went quickly."},{"kind":"text","text":"(T, K.) ―         -b3-"},{"kind":"arabic","text_bw":"A^alabati AlA_ibilu","text_ar":"اَلَبَتِ الاـِبِلُ"},{"kind":"italic_en","text":"The camels obeyed the driver, and collected themselves together."},{"kind":"text","text":"(M, K.) [See also 5.] ―         -b4-"},{"kind":"arabic","text_bw":"A^alaba A_ilayohi","text_ar":"اَلَبَ اـِلَيْهِ"},{"kind":"italic_en","text":"He returned to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K, * TA.) ―         -b5-"},{"kind":"arabic","text_bw":"A^alabati Als~amaA='u","text_ar":"اَلَبَتِ السَّمَا=ءُ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"The sky rained with long continuance."},{"kind":"text","text":"(M, K.)       -A2-"},{"kind":"arabic","text_bw":"A^alaba","text_ar":"اَلَبَ"},{"kind":"text","text":", (S Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^alobN","text_ar":"اَلْبٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"(S Msb, K) an army, (S,) or a people; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"A^l~b","text_ar":"الّب","orth_type":"arrow"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"taA^oliybN","text_ar":"تَاْلِيبٌ"},{"kind":"text","text":": (TA:) and camels also: (TA:) or"},{"kind":"arabic","text_bw":"A^alaba AlA_ibila","text_ar":"اَلَبَ الاـِبِلَ"},{"kind":"text","text":"aor."},{"kind":"text","text":"(T, * S, M, K) and"},{"kind":"text","text":", (S, M, K,) inf. n."},{"kind":"arabic","text_bw":"A^alobN","text_ar":"اَلْبٌ"},{"kind":"text","text":", (T, S,) signifies"},{"kind":"italic_en","text":"he collected the camels, and drove them"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"vehemently:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he drove them:"},{"kind":"text","text":"(T, * K:) or"},{"kind":"italic_en","text":"he drove them vehemently."},{"kind":"text","text":"(M.) ―         -b2-"},{"kind":"arabic","text_bw":"A^alaba","text_ar":"اَلَبَ"},{"kind":"text","text":", (TA,) inf. n. as above, (K, TA,) also signifies"},{"kind":"italic_en","text":"He drove, pursued, chased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hunted, with vehemence:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"italic_en","text":"he drove away"},{"kind":"text","text":"a people. (Msb.) You say,"},{"kind":"arabic","text_bw":"A^alaba AlHimaAru Tariydatahu","text_ar":"اَلَبَ الحِمَارُ طَرِيدَتَهُ"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"[wild]"},{"kind":"italic_en","text":"ass chased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursued, the object of his chase"},{"kind":"text","text":"[i. e. his female, as is shown by MF,]"},{"kind":"italic_en","text":"with vehemence;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^al~abahaA","text_ar":"اَلَّبَهَا","orth_type":"arrow"},{"kind":"text","text":"(K.)"}],"source_refs":["Th","M","K","T","Msb","S","TA"]},{"entry_id":"n1048","headword_ar":"اَلْبٌ","root":"Alb","body":[{"kind":"text","text":"(T, S, Msb) and ↓"},{"kind":"arabic","text_bw":"A_ilobN","text_ar":"اـِلْبٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb)"},{"kind":"italic_en","text":"Persons, or people, collected together;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"an assembly; a collected body:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a collection of many people:"},{"kind":"text","text":"(T:) and ↓"},{"kind":"arabic","text_bw":"A^alobN A^aluwbN","text_ar":"اَلْبٌ اَلُوبٌ","orth_type":"arrow"},{"kind":"text","text":"a"},{"kind":"italic_en","text":"great assembly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"congregation."},{"kind":"text","text":"(M.) ―         -b2-  Also"},{"kind":"italic_en","text":"A people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, combining in hostility"},{"kind":"text","text":"against a man. (TA, from a trad.) You say,"},{"kind":"arabic","text_bw":"humo Ealayohi","text_ar":"هُمْ عَلَيْهِ"},{"kind":"arabic","text_bw":"A^alobN waAHidN","text_ar":"اَلْبٌ وَاحِدٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A_ilobN","text_ar":"اـِلْبٌ","orth_type":"arrow"},{"kind":"text","text":", (but the former is the better known, M,)"},{"kind":"italic_en","text":"They are [one body of men] assembled against him with injustice and enmity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hostility:"},{"kind":"text","text":"(Lth, T, M, K:) like"},{"kind":"arabic","text_bw":"waEolN waAHidN","text_ar":"وَعْلٌ وَاحِدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SadoEN waAHidN","text_ar":"صَدْعٌ وَاحِدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DilaEN waAHidN","text_ar":"ضِلَعٌ وَاحِدٌ"},{"kind":"text","text":". (T, TA.)"}],"source_refs":["T","S","Msb","Lth","M","K"]},{"entry_id":"n1049","headword_ar":"اـِلْبٌ","root":"Alb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^alobN","text_ar":"اَلْبٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n1050","headword_ar":"اَلَبٌ","root":"Alb","body":[{"kind":"text","text":"a dial. var. of"},{"kind":"arabic","text_bw":"yalabN","text_ar":"يَلَبٌ"},{"kind":"text","text":"; (M;)"},{"kind":"italic_en","text":"Helmets of camels' shins:"},{"kind":"text","text":"or, as some say, it signifies"},{"kind":"italic_en","text":"steel:"},{"kind":"text","text":"(T:)"},{"kind":"arabic","text_bw":"A^alabapN","text_ar":"اَلَبَةٌ"},{"kind":"text","text":"is [its n. un., being] a dial. var. of"},{"kind":"arabic","text_bw":"yalabapN","text_ar":"يَلَبَةٌ"},{"kind":"text","text":". (K, * TA.) [See also"},{"kind":"arabic","text_bw":"yalabN","text_ar":"يَلَبٌ"},{"kind":"text","text":".]"}],"source_refs":["T"]}]}}