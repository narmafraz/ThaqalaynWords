{"lemma":"مُخْلِد","slug":"مُخْلِد","root":"خ.ل.د","root_slug":"خ-ل-د","root_link":"/words/roots/خ-ل-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُخْلِد","root":"خلد","pos":"N","occurrence_count":2},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n11245","n11246","n11247"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AE%D9%92%D9%84%D9%90%D8%AF"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11245","headword_ar":"مُخْلَدٌ","root":"xld","body":[{"kind":"text","text":": see the next paragraph, in two places."}],"source_refs":[]},{"entry_id":"n11246","headword_ar":"مُخْلِدٌ","root":"xld","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Slow in becoming hoary;"},{"kind":"text","text":"(A;) as also ↓"},{"kind":"arabic","text_bw":"muxoladN","text_ar":"مُخْلَدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muxal~adN","text_ar":"مُخَلَّدٌ","orth_type":"arrow"},{"kind":"text","text":": (Har p. 588:)"},{"kind":"italic_en","text":"whose teeth do not fall out"},{"kind":"text","text":"(T, A)"},{"kind":"italic_en","text":"by reason of extreme old age:"},{"kind":"text","text":"(T:) or, as some say, it is ↓"},{"kind":"arabic","text_bw":"muxoladN","text_ar":"مُخْلَدٌ","orth_type":"arrow"},{"kind":"text","text":"; as though [meaning] made by God to continue for ever in such a state: (A:) a man"},{"kind":"italic_en","text":"who is not hoary when advanced in age:"},{"kind":"text","text":"(ISk, S:)"},{"kind":"italic_en","text":"whose hair of his head and beard remains black in old age."},{"kind":"text","text":"(T.) ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Still; motionless."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"xmd","text_ar":"خمد"},{"kind":"text","text":".)"}],"source_refs":["T","A","ISk","S"]},{"entry_id":"n11247","headword_ar":"مُخَلَّدٌ","root":"xld","body":[{"kind":"text","text":": see the paragraph next receding. ―         -b2-"},{"kind":"arabic","text_bw":"muxal~aduwna","text_ar":"مُخَلَّدُونَ"},{"kind":"text","text":"in the Kur [lvi. 17 and lxxvi. 19] means"},{"kind":"italic_en","text":"Always of the same age; never altering in age:"},{"kind":"text","text":"(Fr:) or ["},{"kind":"italic_en","text":"endowed with perpetual vigour;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that never become decrepit:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"that never exceed the fit age for service:"},{"kind":"text","text":"(L, K:)       -A2-  or it means"},{"kind":"italic_en","text":"adorned with earrings:"},{"kind":"text","text":"(L, K:) or,"},{"kind":"italic_en","text":"with bracelets;"},{"kind":"text","text":"(AO, L, K;) accord. to the dial. of El-Yemen: (L:) or,"},{"kind":"italic_en","text":"with ornaments."},{"kind":"text","text":"(Zj.)"}],"source_refs":["Fr","K","L"]}]}}