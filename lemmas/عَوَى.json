d"},{"role":"present_2md","form":"تَعْوِيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْوُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْوُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْوِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعْوَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعْوِي","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعْو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعْوَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعْوِي","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعْو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْوِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْوِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْوِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْوِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْوُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْوُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْوِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَوَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَوَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُعْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30900"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%88%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to howl","tags":["intransitive"],"examples":[{"text":"عَوَى الذِّئْبُ عَلَى الْقَمَرِ","english":"The wolf bayed at the moon."}]}]},"etymology":null,"ipa":["/ʕa.waː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30900","headword_ar":"عَوَى","root":"Ew","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEowiY","text_ar":"يَعْوِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuwaA='N","text_ar":"عُوَا=ءٌ"},{"kind":"text","text":"(S, K, TA) and"},{"kind":"arabic","text_bw":"EaY~N","text_ar":"عَىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eaw~apN","text_ar":"عَوَّةٌ"},{"kind":"text","text":"(K, TA) and"},{"kind":"arabic","text_bw":"EawoyapN","text_ar":"عَوْيَةٌ"},{"kind":"text","text":", with fet-h and then sukoon, thus in the M, but in the copies of the K"},{"kind":"arabic","text_bw":"Eawiy~apN","text_ar":"عَوِيَّةٌ"},{"kind":"text","text":", (TA,) said of a dog, (S, CK, TA,) and of a wolf, and of a jackal, (S, TA,)"},{"kind":"italic_en","text":"He cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried loudly:"},{"kind":"text","text":"(S:) [meaning"},{"kind":"italic_en","text":"he howled:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he twisted his muzzle, then uttered a cry:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he prolonged his cry, not doing so with clearness:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AEtwY","text_ar":"اعتوى","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K, TA:) [in the Ham p. 693, the former is expl. as signifying"},{"kind":"arabic","text_bw":"nabaHa","text_ar":"نَبَحَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SaAHa","text_ar":"صَاحَ"},{"kind":"text","text":"; but] it is said that"},{"kind":"arabic","text_bw":"Eaw~apN","text_ar":"عَوَّةٌ"},{"kind":"text","text":"signifies a prolonged crying; and is not the same as"},{"kind":"arabic","text_bw":"naboHN","text_ar":"نَبْحٌ"},{"kind":"text","text":"[which means “ a barking ”]. (TA.) It is said in a prov."},{"kind":"arabic","text_bw":"lawo laka A^aEowiY maA Eawayotu","text_ar":"لَوْ لَكَ اَعْوِى مَا عَوَيْتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If to thee I were howling, I had not howled"},{"kind":"text","text":"]; (TA;) or"},{"kind":"arabic","text_bw":"lawo laka","text_ar":"لَوْ لَكَ"},{"kind":"arabic","text_bw":"Eawayotu lamo A^aEowiho","text_ar":"عَوَيْتُ لَمْ اَعْوِهْ"},{"kind":"text","text":", in which the"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"may be the"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"of pausation, or it may be put by metonymy for the inf. n. so that the meaning is"},{"kind":"arabic","text_bw":"lamo A^aEowi AlEuwaA='a","text_ar":"لَمْ اَعْوِ العُوَا=ءَ"},{"kind":"text","text":": (Meyd:) it originated from the fact that a man used, [and still uses, as I have had occasion to do,] when becoming benighted, in the desert, to howl, in order that the dogs, if any person by whose presence he might be cheered were near him, might hear, and reply to him, and he might be guided by their howling: so this man howled, and the wolf came to him, whereupon he said thus: it relates to the seeker of succour from him who will not succour him. (Meyd, * TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"kaA^an~iY A^asomaEu EuwaA='a A^aholi","text_ar":"كَاَنِّى اَسْمَعُ عُوَا=ءَ اَهْلِ"},{"kind":"arabic","text_bw":"Aln~aAri","text_ar":"النَّارِ"},{"kind":"text","text":"i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"As though I heard"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the crying"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loud crying"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"howling"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the people of the fire"},{"kind":"text","text":"[of Hell]: (TA:) [for]"},{"kind":"arabic","text_bw":"EawaYa","text_ar":"عَوَىَ"},{"kind":"text","text":"is used metaphorically as meaning"},{"kind":"italic_en","text":"he suffered distress, and complained;"},{"kind":"text","text":"from the"},{"kind":"arabic","text_bw":"EuwaA='","text_ar":"عُوَا=ء"},{"kind":"text","text":"of the dog: (Har p. 634:) as IAth says, it is more especially used in relation to the wolf and the dog. (TA.) And one says of him who is esteemed, or found to be, weak,"},{"kind":"arabic","text_bw":"maA yaEowiY","text_ar":"مَا يَعْوِى"},{"kind":"arabic","text_bw":"wamaA yanobaHu","text_ar":"وَمَا يَنْبَحُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He does not howl nor does he bark"},{"kind":"text","text":"]. (Ham p. 693.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EawaY A_ilaY Alfitonapi","text_ar":"عَوَى اـِلَى الفِتْنَةِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"He called"},{"kind":"text","text":"(K, TA) people, or a party, (TA,) ["},{"kind":"italic_en","text":"to conflict and faction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EawaY","text_ar":"عَوَى"},{"kind":"text","text":"being used in this sense by way of likening the person who does so to a dog, or in contempt of him. (Ham p. 693.) [See also 10.] ―         -b3-"},{"kind":"arabic","text_bw":"EuwaA='N","text_ar":"عُوَا=ءٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"grumbling cry"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"rugaA='","text_ar":"رُغَا=ء"},{"kind":"text","text":") of a weak young camel: used in this sense by a poet. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"EuwaA='u AlmugotaAbi","text_ar":"عُوَا=ءُ المُغْتَابِ"},{"kind":"text","text":"; and the phrase"},{"kind":"arabic","text_bw":"EawaY Eani Alr~ajuli","text_ar":"عَوَى عَنِ الرَّجُلِ"},{"kind":"text","text":"; see in the next paragraph.       -A2-"},{"kind":"arabic","text_bw":"EawaY","text_ar":"عَوَى"},{"kind":"text","text":", (S, K, TA,) inf. n."},{"kind":"arabic","text_bw":"EaY~N","text_ar":"عَىٌّ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He bent"},{"kind":"text","text":"a thing; as also ↓"},{"kind":"arabic","text_bw":"AEtwY","text_ar":"اعتوى","orth_type":"arrow"},{"kind":"text","text":"; and likewise a bow; as also ↓"},{"kind":"arabic","text_bw":"Ew~Y","text_ar":"عوّى","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"taEowiyapN","text_ar":"تَعْوِيَةٌ"},{"kind":"text","text":": (TA:) and (TA)"},{"kind":"italic_en","text":"he twisted"},{"kind":"text","text":"hair, and a rope; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"Ew~Y","text_ar":"عوّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEowiyapN","text_ar":"تَعْوِيَةٌ"},{"kind":"text","text":". (S.) One says also"},{"kind":"arabic","text_bw":"EawaY AlEimaAmapa","text_ar":"عَوَى العِمَامَةَ"},{"kind":"page_break","n":2186},{"kind":"arabic","text_bw":"Eay~apF","text_ar":"عَيَّةً"},{"kind":"italic_en","text":"He twisted the turban with a single twisting."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eawayotu raA^osa Aln~aAqapi","text_ar":"عَوَيْتُ رَاْسَ النَّاقَةِ"},{"kind":"italic_en","text":"I turned the head of the she-camel by means of the nose-rein."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"Alqawomu Suduwra rikaAbhimo","text_ar":"القَوْمُ صُدُورَ رِكَابهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ew~Y","text_ar":"عوّى","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EawawohaA","text_ar":"عَوَوْهَا"},{"kind":"italic_en","text":"The party inclined the breasts of their camels that they were riding."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"EawaY Alburapa","text_ar":"عَوَى البُرَةَ"},{"kind":"italic_en","text":"He bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, the nose-ring"},{"kind":"text","text":"of the she-camel. (K, * TA.) And"},{"kind":"arabic","text_bw":"Aln~aAqapu taEowiY buratahaA fiY sayorihaA","text_ar":"النَّاقَةُ تَعْوِى بُرَتَهَا فِى سَيْرِهَا"},{"kind":"italic_en","text":"The she-camel twists her nose-ring with her"},{"kind":"arabic","text_bw":"xiTaAm","text_ar":"خِطَام"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"halter"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in her going."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"EawaAhu Eani Al$~aYo'i","text_ar":"عَوَاهُ عَنِ الشَّىْءِ"},{"kind":"italic_en","text":"He turned him from the thing."},{"kind":"text","text":"(TA.) And one says of the man who possesses prudence, or discretion, and precaution, or good judgment, and who is hardy, strong, or sturdy,"},{"kind":"arabic","text_bw":"mA ynhY wlA yEwY","text_ar":"ما ينهى ولا يعوى"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"maA yunohaY walaA yuEowaY","text_ar":"مَا يُنْهَى وَلَا يُعْوَى"},{"kind":"italic_en","text":"He is not forbidden nor is he turned"},{"kind":"text","text":"]. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EawaY","text_ar":"عَوَى"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"attained to the age of thirty years, so that his arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, became strong, and he twisted vehemently the arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, of another."},{"kind":"text","text":"(ISd, K.)"}],"source_refs":["S","K","TA","CK","Meyd"]}]},"classical_definitions":null}