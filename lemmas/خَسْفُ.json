{"lemma":"خَسْفُ","slug":"خَسْفُ","root":"خ.س.ف","root_slug":"خ-س-ف","root_link":"/words/roots/خ-س-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَسْفُ","root":"خسف","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n10613","n10615","n10616","n10617"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B3%D9%92%D9%81%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sink"},{"pos":"verb","gloss":"to be eclipsed"},{"pos":"verb","gloss":"to cause to sink or to cause to swallow"},{"pos":"noun","gloss":"verbal noun of خَسَفَ (ḵasafa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"baseness, inferiority"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10613","headword_ar":"خَسَفَ","root":"xsf","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":", (JK,) or"},{"kind":"arabic","text_bw":"xusuwfN","text_ar":"خُسُوفٌ"},{"kind":"text","text":", (S, K,) or both; (Msb;) [and ↓"},{"kind":"arabic","text_bw":"Anxsf","text_ar":"انخسف","orth_type":"arrow"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a place)"},{"kind":"italic_en","text":"sank,"},{"kind":"text","text":"(JK, Msb,) or"},{"kind":"italic_en","text":"went away, into the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"with what was upon it."},{"kind":"text","text":"(JK.) You say,"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Anxsf","text_ar":"انخسف","orth_type":"arrow"},{"kind":"text","text":", [and"},{"kind":"arabic","text_bw":"xasafat","text_ar":"خَسَفَت"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"The ground sank"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into the earth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with what was upon it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"bihi AlA^aroDu","text_ar":"بِهِ الاَرْضُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Anxsft","text_ar":"انخسفت","orth_type":"arrow"},{"kind":"text","text":", (JK,) or"},{"kind":"arabic","text_bw":"bh AlArD","text_ar":"به الارض"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Anxsf","text_ar":"انخسف","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"xusifa bh AlArD","text_ar":"خُسِفَ به الارض"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"xasafato","text_ar":"خَسَفَتْ"},{"kind":"text","text":", (Msb in art."},{"kind":"arabic","text_bw":"swx","text_ar":"سوخ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"The ground sank with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"swallowed up him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"took and enclosed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Albiy^oru","text_ar":"البِيْرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Anxsft","text_ar":"انخسفت","orth_type":"arrow"},{"kind":"italic_en","text":"The well"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sank and collapsed;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"went away into the earth with its casing of stones and wood."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"xasafa fiY AlA^aroDi","text_ar":"خَسَفَ فِى الاَرْضِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xusifa bihi","text_ar":"خُسِفَ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, sank into the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth, and became swallowed up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enclosed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, therein"},{"kind":"text","text":"]. (S.) It is said in the Kur [xxviii. 82], accord. to one reading,"},{"kind":"arabic","text_bw":"laxusifa binaA","text_ar":"لَخُسِفَ بِنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We had been swallowed up by the earth"},{"kind":"text","text":"]: (S:) accord. to another reading, (that of 'Abd-Allah, S, i. e. Ibn-Mes'ood, TA,)"},{"kind":"arabic","text_bw":"bnA","text_ar":"بنا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"laA@noxusifa","text_ar":"لَا@نْخُسِفَ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) in the pass. form; (K;) [meaning the same;] like as one says,"},{"kind":"arabic","text_bw":"AunoTuliqa bnA","text_ar":"اُنْطُلِقَ بنا"},{"kind":"text","text":". (S.) You say also,"},{"kind":"arabic","text_bw":"xasafato Eayonu AlmaA='i","text_ar":"خَسَفَتْ عَيْنُ المَا=ءِ"},{"kind":"italic_en","text":"The spring of water sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, into the earth."},{"kind":"text","text":"(Msb, K. *) And"},{"kind":"arabic","text_bw":"AlEayonu","text_ar":"العَيْنُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Anxsft","text_ar":"انخسفت","orth_type":"arrow"},{"kind":"italic_en","text":"The eye sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became depressed, in the head;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gaArato","text_ar":"غَارَتْ"},{"kind":"text","text":"; (Msb in art."},{"kind":"arabic","text_bw":"gwr","text_ar":"غور"},{"kind":"text","text":";) [and so"},{"kind":"arabic","text_bw":"xasafat","text_ar":"خَسَفَت"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xusuwfN","text_ar":"خُسُوفٌ"},{"kind":"text","text":"; for]"},{"kind":"arabic","text_bw":"xusuwfu AlEayoni","text_ar":"خُسُوفُ العَيْنِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The eye's going away into the head:"},{"kind":"text","text":"(S:) or ↓"},{"kind":"arabic","text_bw":"Anxsft","text_ar":"انخسفت","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"its black,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part surrounded by the white, disappeared in the head:"},{"kind":"text","text":"(Mgh:) or this last, (K,) as quasi-pass. of the trans. v."},{"kind":"arabic","text_bw":"xasafa","text_ar":"خَسَفَ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the eye)"},{"kind":"italic_en","text":"became blind;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^axosafat","text_ar":"اَخْسَفَت","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;) and [in like manner]"},{"kind":"arabic","text_bw":"xasafat","text_ar":"خَسَفَت"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the eye)"},{"kind":"italic_en","text":"lost its light"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sight"},{"kind":"text","text":"]. (Msb.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"xasafa Alqamaru","text_ar":"خَسَفَ القَمَرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xusuwfN","text_ar":"خُسُوفٌ"},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"xusifa","text_ar":"خُسِفَ"},{"kind":"text","text":"; (TA;) (assumed tropical:)"},{"kind":"italic_en","text":"The moon"},{"kind":"text","text":"["},{"kind":"italic_en","text":"suffered eclipse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became eclipsed,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"lost its light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part of its light;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"kasafa","text_ar":"كَسَفَ"},{"kind":"text","text":": (S, * Msb, * K:) and"},{"kind":"arabic","text_bw":"xasafati Al$~amosu","text_ar":"خَسَفَتِ الشَّمْسُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kasafat","text_ar":"كَسَفَت"},{"kind":"text","text":"both signify the same [i. e."},{"kind":"italic_en","text":"the sun suffered eclipse,"},{"kind":"text","text":"&c.]: (Mgh:) or one says"},{"kind":"arabic","text_bw":"kasafat","text_ar":"كَسَفَت"},{"kind":"text","text":"of the sun, and"},{"kind":"arabic","text_bw":"xasafa","text_ar":"خَسَفَ"},{"kind":"text","text":"of the moon, (Th, S, Msb, K,) accord. to the more approved usage: (Th, S, Msb:) or, in the common conventional language,"},{"kind":"arabic","text_bw":"Alkusuwfu","text_ar":"الكُسُوفُ"},{"kind":"text","text":"is the partial loss of the light of the sun, and"},{"kind":"arabic","text_bw":"Alxusuwfu","text_ar":"الخُسُوفُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the total loss of the light"},{"kind":"text","text":"thereof: (AHát, Msb:) or"},{"kind":"arabic","text_bw":"Alxswf","text_ar":"الخسوف"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the partial loss of the light"},{"kind":"text","text":"of the sun, and"},{"kind":"arabic","text_bw":"Alkswf","text_ar":"الكسوف"},{"kind":"text","text":"is the total loss thereof, (K, TA,) accord. to AHát: (TA:)"},{"kind":"arabic","text_bw":"Alxswf","text_ar":"الخسوف"},{"kind":"text","text":"often occurs in the trads., as said of the sun; though the term commonly known in the classical language is"},{"kind":"arabic","text_bw":"Alkswf","text_ar":"الكسوف"},{"kind":"text","text":"[in this case]: and it is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a Al$~amosa wa Alqamara laAyaxosifaAni","text_ar":"اـِنَّ الشَّمْسَ وَ القَمَرَ لَايَخْسِفَانِ"},{"kind":"arabic","text_bw":"limawoti A^aHadK A^awo liHayaAtihi","text_ar":"لِمَوْتِ اَحَدٍ اَوْ لِحَيَاتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily the sun and the moon suffer not eclipse for the death of any one or for his life"},{"kind":"text","text":"]; predominance being in this instance attributed to the moon, as being masc., over the sun, which is fem. (IAth.) ―         -b3-  Also, inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became defective"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient; suffered loss"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diminution."},{"kind":"text","text":"(K.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the body)"},{"kind":"italic_en","text":"became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xasafato","text_ar":"خَسَفَتْ"},{"kind":"text","text":", said of camels and of sheep or goats, (tropical:)"},{"kind":"italic_en","text":"They became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated."},{"kind":"text","text":"(TA. [This meaning is there indicated, but not clearly expressed. See"},{"kind":"arabic","text_bw":"xasofapN","text_ar":"خَسْفَةٌ"},{"kind":"text","text":". Accord. to the KL, the inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"being vile, abject,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contemptible:"},{"kind":"text","text":"and also the"},{"kind":"italic_en","text":"being lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"and hence Golius, on that authority, has rendered the verb as meaning"},{"kind":"italic_en","text":"vilis et macer fuit."},{"kind":"text","text":"]) ―         -b5-  Also (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the colour, or complexion, of a person)"},{"kind":"italic_en","text":"became altered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altered for the worse."},{"kind":"text","text":"(TA.) ―         -b6-  And (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, K, as, for instance, a roof, TA)"},{"kind":"italic_en","text":"became pierced with a hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Anxsf","text_ar":"انخسف","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b7-  And,"},{"kind":"arabic","text_bw":"xasafat","text_ar":"خَسَفَت"},{"kind":"text","text":", said of a she-camel, (tropical:)"},{"kind":"italic_en","text":"She, after yielding abundant milk, soon stopped"},{"kind":"text","text":"["},{"kind":"italic_en","text":"its flow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in winter."},{"kind":"text","text":"(K, TA.) ―         -b8-  And, said of a well,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"xasiyfN","text_ar":"خَسِيفٌ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b9-  And"},{"kind":"arabic","text_bw":"xasafa","text_ar":"خَسَفَ"},{"kind":"text","text":", said of a man, (tropical:)"},{"kind":"italic_en","text":"He recovered from a disease."},{"kind":"text","text":"(IDrd, K, TA.)       -A2-"},{"kind":"arabic","text_bw":"xasafa","text_ar":"خَسَفَ"},{"kind":"text","text":", (JK, Msb, TA,) aor."},{"kind":"text","text":", (Kur xvi. 47, &c,) inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"made"},{"kind":"text","text":"a place, (JK, Msb,) or the ground, (TA,)"},{"kind":"italic_en","text":"to sink,"},{"kind":"text","text":"(JK, Msb, TA,) or"},{"kind":"italic_en","text":"go away, into the earth,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"with what was upon it."},{"kind":"text","text":"(JK, TA.) And"},{"kind":"arabic","text_bw":"xasafa bihi","text_ar":"خَسَفَ بِهِ"},{"kind":"arabic","text_bw":"AlA^aroDa","text_ar":"الاَرْضَ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, to disappear in the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground:"},{"kind":"text","text":"(S, K:) [or"},{"kind":"italic_en","text":"made the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, to sink with, and swallow up, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"] whence, in the Kur [xxviii. 81],"},{"kind":"arabic","text_bw":"faxasafonaA bihi wabidaArihi AlA^aroDa","text_ar":"فَخَسَفْنَا بِهِ وَبِدَارِهِ الاَرْضَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we made the ground to sink with, and swallow up, him and his mansion"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"xasafotu Eayona AlmaA='i","text_ar":"خَسَفْتُ عَيْنَ المَا=ءِ"},{"kind":"italic_en","text":"I made the spring of water to sink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"go away, into the earth."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"xasafa Eayona fulaAnK","text_ar":"خَسَفَ عَيْنَ فُلَانٍ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He put out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blinded, the eye of such a one,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"so that the black,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part surrounded by the white, disappeared in the head."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xasafa Al$~aYo'a","text_ar":"خَسَفَ الشَّىْءَ"},{"kind":"text","text":", (K,) aor. and inf. n. as above, (TA,) (tropical:)"},{"kind":"italic_en","text":"He made a hole in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent, the thing."},{"kind":"text","text":"(K, TA.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut off, the thing."},{"kind":"text","text":"(K.) ―         -b5-"},{"kind":"arabic","text_bw":"xasafa Albiy^ora","text_ar":"خَسَفَ البِيْرَ"},{"kind":"text","text":", (K,) inf. n. as above, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He dug the well in stones, so that it yielded an abundant and unceasing flow of water:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"he dug the well by piercing through its mountain"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rock"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the water beneath so that it would never become exhausted:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he dug the well so as to reach an unceasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a copious, source of water."},{"kind":"text","text":"(TA.) Hence the saying of 'Omar, in reply to a question of El-'Abbás respecting the poets,"},{"kind":"arabic","text_bw":"AimoraA^u Alqayosi saAbiquhumo xasafa lahumo","text_ar":"اِمْرَاُ القَيْسِ سَابِقُهُمْ خَسَفَ لَهُمْ"},{"kind":"arabic","text_bw":"Eayona Al$~iEori","text_ar":"عَيْنَ الشِّعْرِ"},{"kind":"text","text":", i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"Imra-el-Keys is he who has the precedence of them:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he has made the source of poetry to well forth abundantly to them."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"xasafa Aln~aAqapa","text_ar":"خَسَفَ النَّاقَةَ"},{"kind":"text","text":", inf. n. as above, (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"made the she-camel, after yielding abundant milk, soon to stop"},{"kind":"text","text":"["},{"kind":"italic_en","text":"its flow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in winter."},{"kind":"text","text":"(K, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"confining"},{"kind":"text","text":"a beast"},{"kind":"italic_en","text":"without fodder:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"a beast"},{"kind":"italic_en","text":"to pass the night without fodder:"},{"kind":"text","text":"(Ham p. 290:) and (hence, TA) (tropical:)  the"},{"kind":"italic_en","text":"constraining"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"to do that which he dislikes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hates;"},{"kind":"text","text":"(JK, Ham ibid., K, TA;) as also"},{"kind":"arabic","text_bw":"xusofN","text_ar":"خُسْفٌ"},{"kind":"text","text":": (JK:) and (hence, Ham) (tropical:)  the"},{"kind":"italic_en","text":"lowering, humbling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abasing,"},{"kind":"text","text":"another: (Ham, * K, TA:) whence,"},{"kind":"arabic","text_bw":"sumotuhu Alxasofa","text_ar":"سُمْتُهُ الخَسْفَ"},{"kind":"text","text":", (Ham,) or"},{"kind":"arabic","text_bw":"saAmahu xasofFA","text_ar":"سَامَهُ خَسْفًا"},{"kind":"text","text":", &c.: [explained below: see"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":":] (TA:) and the verb of"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"in these three senses is"},{"kind":"arabic","text_bw":"xasafa","text_ar":"خَسَفَ"},{"kind":"text","text":". (T, K.)"}],"source_refs":["JK","S","Msb","K","TA","Mgh","Th","God","Ham"]},{"entry_id":"n10615","headword_ar":"خَسْفٌ","root":"xsf","body":[{"kind":"text","text":"[an inf. n. of 1: and hence several of the significations here following.]"},{"kind":"italic_en","text":"Deep places in the ground"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eumuwqu ZaAhiri AlA^aroDi","text_ar":"عُمُوقُ ظَاهِرِ الاَرْضِ"},{"kind":"text","text":"; in the CK"},{"kind":"arabic","text_bw":"Eumuwqu mA'i","text_ar":"عُمُوقُ ماءِ"},{"kind":"arabic","text_bw":"AlArDi","text_ar":"الارضِ"},{"kind":"text","text":"); as also ↓"},{"kind":"arabic","text_bw":"xusofN","text_ar":"خُسْفٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) ―         -b2-  The"},{"kind":"italic_en","text":"place whence the water"},{"kind":"text","text":"of a well"},{"kind":"italic_en","text":"issues."},{"kind":"text","text":"(AZ, S, K.) In the following saying of Sá'ideh El-Hudhalee,"},{"kind":"quote","text":"A^alaA yaA fataY maA Eabodu $amosK bimivolihi\n                      \n                     \n                        yubal~u EalaY AlEaAdiY wa tuw^obiY AlmaxaAsifu"},{"kind":"text","text":"the last word is pl. of"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"[app. as signifying"},{"kind":"italic_en","text":"A source of water"},{"kind":"text","text":"], after the manner of"},{"kind":"arabic","text_bw":"ma$aAbihu","text_ar":"مَشَابِهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"malaAmiHu","text_ar":"مَلَامِحُ"},{"kind":"text","text":": (TA:) the meaning is, ["},{"kind":"italic_en","text":"Truly, O young man, what is 'Abd-Shems?"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"how great a person is 'Abd-Shems! by the like of him the enemy is overcome"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and the sources of water become difficult of access"},{"kind":"text","text":"]. (M in art."},{"kind":"arabic","text_bw":"bl","text_ar":"بل"},{"kind":"text","text":".) ―         -b3-"},{"kind":"italic_en","text":"A cloud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collection of clouds, that has risen and appeared from the direction of the extreme west,"},{"kind":"text","text":"[as North-western Africa is called by the Arabs,]"},{"kind":"italic_en","text":"from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the quarter of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the right of the Kibleh"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to one who is on the north-east of Mekkeh, towards El-'Irák"},{"kind":"text","text":"]: (Lth, K:) or it signifies, (JK, TA,) [and] so ↓"},{"kind":"arabic","text_bw":"xisofN","text_ar":"خِسْفٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xasiyfN","text_ar":"خَسِيفٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"a cloud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collection of clouds, that has risen and appeared"},{"kind":"arabic","text_bw":"mino qibali AlEayoni","text_ar":"مِنْ قِبَلِ العَيْنِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"bearing much water;"},{"kind":"text","text":"(JK, K, TA;) i. e.,"},{"kind":"italic_en","text":"from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the quarter of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the right of the Kibleh"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as explained above"},{"kind":"text","text":"]. (TA.)       -A2-  (tropical:)"},{"kind":"italic_en","text":"Deficiency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection; a fault;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"base, quality;"},{"kind":"text","text":"(S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"xasiyfapN","text_ar":"خَسِيفَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"raDiYa fulaAnN biAlxasofi","text_ar":"رَضِىَ فُلَانٌ بِالخَسْفِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one was content with deficiency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection;"},{"kind":"text","text":"&c. (S, TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"Leanness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciation;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"xasiyfapN","text_ar":"خَسِيفَةٌ","orth_type":"arrow"},{"kind":"text","text":". (JK.) ―         -b3-  [See also 1, last sentence. ―         -b4-  Hence,]"},{"kind":"arabic","text_bw":"baAta Alqawomu EalaY Alxasofi","text_ar":"بَاتَ القَوْمُ عَلَى الخَسْفِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The party passed the night in a state of hunger, not having anything wherewith to feed themselves:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"baAta fulaAnN Alxasofa","text_ar":"بَاتَ فُلَانٌ الخَسْفَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one passed"},{"kind":"page_break","n":739},{"kind":"italic_en","text":"the night hungry:"},{"kind":"text","text":"(S, K, TA:) and"},{"kind":"arabic","text_bw":"$aribonaA EalaY`","text_ar":"شَرِبْنَا عَلَىٰ"},{"kind":"arabic","text_bw":"Alxasofi","text_ar":"الخَسْفِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We drank without eating."},{"kind":"text","text":"(IAar, IDrd, K, TA.) A poet says,"},{"kind":"quote","text":"batonaA EalaY Alxasofi laA risolN nuqaAtu bihi\n                      \n                     \n                        Hat~aY jaEalonaA HibaAla Alr~aHoli fuSolaAnaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We passed the night in a state of hunger: there was no milk wherewith we might be fed, until we made the ropes of the camel's saddle"},{"kind":"text","text":"to serve as"},{"kind":"italic_en","text":"young camels"},{"kind":"text","text":"]: i. e. we had no food until we bound the she-camels with ropes in order that they might yield us milk [as though they had young ones to suckle], and we might feed ourselves with their milk. (O, TA.) [See also another ex., in a verse of Dhu-r-Rummeh, cited voce"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":", p. 78.] ―         -b5-  [Hence, also,]"},{"kind":"arabic","text_bw":"saAmahu xasofFA","text_ar":"سَامَهُ خَسْفًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xusofFA","text_ar":"خُسْفًا","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"saAmahu Alxasofa","text_ar":"سَامَهُ الخَسْفَ"},{"kind":"text","text":", (S, Msb,) (tropical:)"},{"kind":"italic_en","text":"He brought upon him abasement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"he required,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained, him to do an affair of difficulty;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to become in a state of abasement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy."},{"kind":"text","text":"(S, TA.) [See also two similar phrases voce"},{"kind":"arabic","text_bw":"xuT~apN","text_ar":"خُطَّةٌ"},{"kind":"text","text":".] ―         -b6-  [And hence,]"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"Wrong, wrongdoing, injustice, injuriousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tyranny."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"saAmahu xasofFA","text_ar":"سَامَهُ خَسْفًا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Alxasofa","text_ar":"الخَسْفَ"},{"kind":"text","text":", sometimes means (assumed tropical:)"},{"kind":"italic_en","text":"He brought upon him wrong,"},{"kind":"text","text":"&c.]       -A3-  See also the next paragraph."}],"source_refs":["TA","Lth","K","JK","S","Msb"]},{"entry_id":"n10616","headword_ar":"خُسْفٌ","root":"xsf","body":[{"kind":"text","text":": [see 1, last sentence: and] see"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":", in two places. ―         -b2-"},{"kind":"arabic","text_bw":"daEi AlA^amora bixusofK","text_ar":"دَعِ الاَمْرَ بِخُسْفٍ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Leave thou the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, as it is."},{"kind":"text","text":"(Sgh, K.)       -A2-  The ["},{"kind":"italic_en","text":"fruit called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jawoz","text_ar":"جَوْز"},{"kind":"text","text":","},{"kind":"italic_en","text":"which is eaten;"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"walnut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walnuts;"},{"kind":"text","text":"] (AA, AHn, K;) of the dial. of the people of Esh-Shihr; (AA;) as also ↓"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ","orth_type":"arrow"},{"kind":"text","text":": (AA, K:) accord. to ISd, the former is the correct word: (TA:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (JK.)"}],"source_refs":["AA","K","TA"]},{"entry_id":"n10617","headword_ar":"خِسْفٌ","root":"xsf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}