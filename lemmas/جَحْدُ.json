{"lemma":"جَحْدُ","slug":"جَحْدُ","root":"ج.ح.د","root_slug":"ج-ح-د","root_link":"/words/roots/ج-ح-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"جَحْدُ","root":"جحد","pos":"V","occurrence_count":12},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n5095","n5096","n5097","n5098","n5099"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%AD%D9%92%D8%AF%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5095","headword_ar":"جَحَدَ","root":"jHd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"juHuwdN","text_ar":"جُحُودٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He denied"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"disacknowledged it;"},{"kind":"text","text":"(L, MF;) in an absolute sense, whether knowing it to be otherwise than as he represented it to be or not. (MF.) [It is used by grammarians, and often by others, as relating to something past, or supposed or asserted to be past; and thus, in a more restricted sense than"},{"kind":"arabic","text_bw":"nafaY","text_ar":"نَفَى"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"jaHadahu Haq~ahu","text_ar":"جَحَدَهُ حَقَّهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biHaq~ihi","text_ar":"بِحَقِّهِ"},{"kind":"text","text":", inf. ns. as above; [and ↓"},{"kind":"arabic","text_bw":"jAHdhu","text_ar":"جاحدهُ","orth_type":"arrow"},{"kind":"text","text":"; (see 3 in art."},{"kind":"arabic","text_bw":"kbr","text_ar":"كبر"},{"kind":"text","text":", where"},{"kind":"arabic","text_bw":"jAHadahu","text_ar":"جاحَدَهُ"},{"kind":"text","text":"is used in explaining"},{"kind":"arabic","text_bw":"kaAbarahu","text_ar":"كَابَرَهُ"},{"kind":"text","text":"; and see what follows;)]"},{"kind":"italic_en","text":"He denied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledged, his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, knowing it to be such,"},{"kind":"text","text":"(S, A, * Msb, K, MF,) and also,"},{"kind":"italic_en","text":"not knowing it;"},{"kind":"text","text":"(MF;) the doing of which is also termed"},{"kind":"arabic","text_bw":"mukaAbarapN","text_ar":"مُكَابَرَةٌ"},{"kind":"text","text":": (TA:) but accord. to some, it is made trans. by means of"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"only by its being made to imply the meaning of"},{"kind":"arabic","text_bw":"kafara","text_ar":"كَفَرَ"},{"kind":"text","text":". (MF.)       -A2-  Also"},{"kind":"arabic","text_bw":"jaHadahu","text_ar":"جَحَدَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He found him to be niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he found him to possess little good;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"to be either niggardly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"poor."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"jaHida","text_ar":"جَحِدَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"possessed little good;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"AjHd","text_ar":"اجحد","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"his property became dissipated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, and passed away;"},{"kind":"text","text":"and so ↓ the latter verb. (AA, TA.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, little in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty."},{"kind":"text","text":"(K, TA.) ―         -b3-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a person's life, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strait, and difficult."},{"kind":"text","text":"(K, * TA.) ―         -b4-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, scanty;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"did not grow tall."},{"kind":"text","text":"(S, K.) ―         -b5-"},{"kind":"arabic","text_bw":"jaHidati AlA^aroDu","text_ar":"جَحِدَتِ الاَرْضُ"},{"kind":"italic_en","text":"The land became dry, and of no good."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"jaHada EaAmunaA","text_ar":"جَحَدَ عَامُنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Our year was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, one of little rain:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"jaHidN","text_ar":"جَحِدٌ"},{"kind":"text","text":"]. (A.)"}],"source_refs":["TA","K","S"]},{"entry_id":"n5096","headword_ar":"جَحْدٌ","root":"jHd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"juHodN","text_ar":"جُحْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jaHadN","text_ar":"جَحَدٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Paucity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scantiness, of good;"},{"kind":"text","text":"(S, K;) which means both"},{"kind":"italic_en","text":"niggardliness"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"poverty:"},{"kind":"text","text":"(A:)"},{"kind":"italic_en","text":"straitness of the means of subsistence;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"juHuwdN","text_ar":"جُحُودٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) One says, ↓"},{"kind":"arabic","text_bw":"nakadFA lahu wajaHadFA","text_ar":"نَكَدًا لَهُ وَجَحَدًا","orth_type":"arrow"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"nukodFA lahu","text_ar":"نُكْدًا لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wajuHodFA","text_ar":"وَجُحْدًا","orth_type":"arrow"},{"kind":"text","text":"(L in art."},{"kind":"arabic","text_bw":"nkd","text_ar":"نكد"},{"kind":"text","text":") [May God decree"},{"kind":"italic_en","text":"straitness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty, to him, and poverty"},{"kind":"text","text":"]: a form of imprecation. (TA.)       -A2-"},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":"as an epithet, fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":", in three places."}],"source_refs":["A","S"]},{"entry_id":"n5097","headword_ar":"جُحْدٌ","root":"jHd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":", in four places."}],"source_refs":[]},{"entry_id":"n5098","headword_ar":"جَحَدٌ","root":"jHd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jajodN","text_ar":"جَجْدٌ"},{"kind":"text","text":", in four places."}],"source_refs":[]},{"entry_id":"n5099","headword_ar":"جَحِدٌ","root":"jHd","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"jajodN","text_ar":"جَجْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ajoHadu","text_ar":"اَجْحَدُ","orth_type":"arrow"},{"kind":"text","text":"(K) A man"},{"kind":"italic_en","text":"niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"possessing little good."},{"kind":"text","text":"(S, K.) [Hence,] ↓"},{"kind":"arabic","text_bw":"A^aroDN jaHodapN","text_ar":"اَرْضٌ جَحْدَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Dry land, in which is no good."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"EaAmN jaHidN","text_ar":"عَامٌ جَحِدٌ"},{"kind":"text","text":", (S,) or ↓"},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ","orth_type":"arrow"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"A year in which is little rain."},{"kind":"text","text":"(S.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"jaHidN","text_ar":"جَحِدٌ"},{"kind":"text","text":", A"},{"kind":"italic_en","text":"thick and short"},{"kind":"text","text":"horse: fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"jiHaAdN","text_ar":"جِحَادٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","K","A"]}]}}