{"lemma":"خَلِيَّةُ","slug":"خَلِيَّةُ","root":"خ.ل.#","root_slug":"خ-ل-_","root_link":"/words/roots/خ-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n11427"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D9%90%D9%8A%D9%8E%D9%91%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"cell (all senses)"},{"pos":"noun","gloss":"hive, beehive"}]},"etymology":null,"ipa":["/xa.lij.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11427","headword_ar":"خَلِيَّةٌ","root":"xlw","body":[{"kind":"text","text":"[as fem. of the epithet"},{"kind":"arabic","text_bw":"xaliY~N","text_ar":"خَلِىٌّ"},{"kind":"text","text":": see the next preceding paragraph, and the places there referred to in its first sentence.       -A2-  As a subst. it signifies]"},{"kind":"italic_en","text":"A great ship:"},{"kind":"text","text":"(T, S, K:) or"},{"kind":"italic_en","text":"a ship that goes of itself, without its being made to do so by the sailor:"},{"kind":"text","text":"(JK, K:) or"},{"kind":"italic_en","text":"one that is followed by a small boat:"},{"kind":"text","text":"(K:) the first held by Az to be the right meaning: (TA:) pl."},{"kind":"arabic","text_bw":"xalaAyaA","text_ar":"خَلَايَا"},{"kind":"text","text":". (JK, S.) ―         -b2-  Also, (S, Mgh, Msb, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"xaliY~N","text_ar":"خَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (JK, Msb, K,) The"},{"kind":"italic_en","text":"habitation"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bayot","text_ar":"بَيْت"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of bees,"},{"kind":"text","text":"[whether it be"},{"kind":"italic_en","text":"a manufactured hive"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a hollow in the trunk of a tree"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a rock,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in which they deposit their honey;"},{"kind":"text","text":"(S;) the"},{"kind":"italic_en","text":"place in which bees deposit their honey:"},{"kind":"text","text":"(Mgh:) or the"},{"kind":"italic_en","text":"thing in which bees deposit their honey,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"not manufactured for them:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a thing like the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of jar called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raAquwd","text_ar":"رَاقُود"},{"kind":"text","text":","},{"kind":"italic_en","text":"of clay,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"made for bees:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a certain thing for bees, well known, of clay"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of wood:"},{"kind":"text","text":"(Msb:) or, accord. to Lth, if made of clay, it is called"},{"kind":"arabic","text_bw":"kwArp","text_ar":"كوارة"},{"kind":"text","text":", (Msb, TA,) i. e. ["},{"kind":"arabic","text_bw":"kuwaArapN","text_ar":"كُوَارَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kuw~aArapN","text_ar":"كُوَّارَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kiwaArapN","text_ar":"كِوَارَةٌ"},{"kind":"text","text":"] with kesr: (Msb:) or"},{"kind":"italic_en","text":"a piece of wood hollowed out for honey to be deposited therein"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by bees"},{"kind":"text","text":"]: or the"},{"kind":"italic_en","text":"lower part of a tree that is called"},{"kind":"arabic","text_bw":"xazamapN","text_ar":"خَزَمَةٌ"},{"kind":"text","text":", [n. un. of"},{"kind":"arabic","text_bw":"xazamN","text_ar":"خَزَمٌ"},{"kind":"text","text":", q. v.,"},{"kind":"italic_en","text":"hollowed out for that purpose,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"resembling the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of jar called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raAquwd","text_ar":"رَاقُود"},{"kind":"text","text":": (K:) or ↓"},{"kind":"arabic","text_bw":"xaliY~N","text_ar":"خَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"part of the"},{"kind":"arabic","text_bw":"kuw~aArap","text_ar":"كُوَّارَة"},{"kind":"italic_en","text":"which is the place of the honey:"},{"kind":"text","text":"(JK:) pl. as above. (Msb, TA.)"}],"source_refs":["T","S","K","JK","TA","Msb","Mgh"]}]},"classical_definitions":null}