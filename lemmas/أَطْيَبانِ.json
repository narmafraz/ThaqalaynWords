ic_en","text":"most pleasant,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of things,"},{"kind":"text","text":"] means (assumed tropical:)"},{"kind":"italic_en","text":"Eating and coïtus:"},{"kind":"text","text":"(IAar, S, A, O, K:) or"},{"kind":"italic_en","text":"sleep and coïtus:"},{"kind":"text","text":"(ISk, O, TA:) or"},{"kind":"italic_en","text":"the mouth and the vulva of a woman:"},{"kind":"text","text":"(Yaakoob, A, O, K:) or"},{"kind":"italic_en","text":"fat and youthfulness:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"strength and appetence:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"youthfulness and briskness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liveliness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness:"},{"kind":"text","text":"(Har p. 88:) or"},{"kind":"italic_en","text":"fresh ripe dates and the"},{"kind":"arabic","text_bw":"xirbiz","text_ar":"خِربِز"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"water-melon"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"milk and dates."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A^aTaAyibu","text_ar":"اَطَايِبُ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"best,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"best parts,"},{"kind":"text","text":"of a thing, (K, TA,) as of flesh-meat, &c.; (TA;) as also ↓"},{"kind":"arabic","text_bw":"maTaAyibu","text_ar":"مَطَايِبُ","orth_type":"arrow"},{"kind":"text","text":", a pl. which has no sing., (K, TA,) of the same class as"},{"kind":"arabic","text_bw":"maHaAsinu","text_ar":"مَحَاسِنُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"malaAmiHu","text_ar":"مَلَامِحُ"},{"kind":"text","text":", (TA,) or its pl. is ↓"},{"kind":"arabic","text_bw":"maToyabN","text_ar":"مَطْيَبٌ","orth_type":"arrow"},{"kind":"text","text":", (Ks, O, K,) or ↓"},{"kind":"arabic","text_bw":"maTaAbN","text_ar":"مَطَابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maTaAbapN","text_ar":"مَطَابَةٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) or you say,"},{"kind":"arabic","text_bw":"A^aToEamanaA mino","text_ar":"اَطْعَمَنَا مِنْ"},{"kind":"arabic","text_bw":"A^aTaAyibi Aljazuwri","text_ar":"اَطَايِبِ الجَزُورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fed us from the best parts of the slaughtered camel"},{"kind":"text","text":"], but not"},{"kind":"arabic","text_bw":"Aljzwr","text_ar":"الجزور"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mn maTaAyibi","text_ar":"من مَطَايِبِ","orth_type":"arrow"},{"kind":"text","text":"; (S, O;) or you say,"},{"kind":"arabic","text_bw":"mino A^aTaAyibihaA","text_ar":"مِنْ اَطَايِبِهَا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maTaAyibihaA","text_ar":"مَطَايِبِهَا","orth_type":"arrow"},{"kind":"text","text":"; (As, A, O;) or the latter, but not the former; (Yaakoob, TA;) or you say"},{"kind":"arabic","text_bw":"A^aTaAyibu Aljazuwri","text_ar":"اَطَايِبُ الجَزُورِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alr~uTabi","text_ar":"الرُّطَبِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maTaAyibu","text_ar":"مَطَايِبُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the best of fresh ripe dates"},{"kind":"text","text":"]; (IAar, K;) and AHn uses the phrase"},{"kind":"arabic","text_bw":"A^aTaAyibu","text_ar":"اَطَايِبُ"},{"kind":"arabic","text_bw":"AlkalaA^i","text_ar":"الكَلَاِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the best portions of the herbage"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["ISd","K","S","IAar","A","O","ISk","TA","Ks","M"]}]},"classical_definitions":null}