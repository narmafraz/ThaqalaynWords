{"lemma":"خِلْقَة","slug":"خِلْقَة","root":"خ.ل.ق","root_slug":"خ-ل-ق","root_link":"/words/roots/خ-ل-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n11382","n11391","n11392","n11393"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%90%D9%84%D9%92%D9%82%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"creation"},{"pos":"noun","gloss":"innate nature"}]},"etymology":{"source":"wiktextract","text":"Compare خَلَقَ (ḵalaqa, “to create”), خَلُقَ (ḵaluqa, “to be suitable”)."},"ipa":["/xil.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11382","headword_ar":"خلّقهُ","root":"xlq","body":[{"kind":"text","text":": see 1, latter half, in two places.       -A2-  Also, (S, K,) inf. n."},{"kind":"arabic","text_bw":"taxoliyqN","text_ar":"تَخْلِيقٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He rubbed him over with"},{"kind":"arabic","text_bw":"xaluwq","text_ar":"خَلُوق"},{"kind":"text","text":"[q. v.]: (S:) or"},{"kind":"italic_en","text":"he perfumed him:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"xl~qhu bixaluwqK","text_ar":"خلّقهُ بِخَلُوقٍ"},{"kind":"italic_en","text":"he perfumed him with"},{"kind":"arabic","text_bw":"xlwq","text_ar":"خلوق"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xal~aqotu AlmaroA^apa biAlxaluwqi","text_ar":"خَلَّقْتُ المَرْاَةَ بِالخَلُوقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I perfumed the woman,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rubbed her over, with the"},{"kind":"arabic","text_bw":"xlwq","text_ar":"خلوق"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"xal~aqato jisomahaA","text_ar":"خَلَّقَتْ جِسْمَهَا"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"rubbed her body and limbs over with"},{"kind":"arabic","text_bw":"xlwq","text_ar":"خلوق"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K"]},{"entry_id":"n11391","headword_ar":"خُلْقَةٌ","root":"xlq","body":[{"kind":"italic_en","text":"Smoothness;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"xuluwqapN","text_ar":"خُلُوقَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xalaAqapN","text_ar":"خَلَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) but the second of these three, correctly speaking, [as also the third, accord. to analogy, and perhaps the first also,] is an inf. n. of"},{"kind":"arabic","text_bw":"xaluqa","text_ar":"خَلُقَ"},{"kind":"text","text":". (TA.)"}],"source_refs":["K"]},{"entry_id":"n11392","headword_ar":"خِلْقَةٌ","root":"xlq","body":[{"kind":"text","text":"[primarily signifies"},{"kind":"italic_en","text":"A mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner,"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"xaloq","text_ar":"خَلْق"},{"kind":"text","text":", generally as meaning"},{"kind":"italic_en","text":"creation; a particular make:"},{"kind":"text","text":"and hence,]"},{"kind":"italic_en","text":"constitution;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tarokiybN","text_ar":"تَرْكِيبٌ"},{"kind":"text","text":": (Mgh:) [and particularly the"},{"kind":"italic_en","text":"natural constitution"},{"kind":"text","text":"of an animated being,"},{"kind":"italic_en","text":"as created in the womb of the mother;"},{"kind":"text","text":"also termed"},{"kind":"arabic","text_bw":"fiTorapN","text_ar":"فِطْرَةٌ"},{"kind":"text","text":":] see also"},{"kind":"arabic","text_bw":"xuluqN","text_ar":"خُلُقٌ"},{"kind":"text","text":". You say"},{"kind":"arabic","text_bw":"rajulN Hasanu Alxiloqapi","text_ar":"رَجُلٌ حَسَنُ الخِلْقَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A man goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful, in respect of make"},{"kind":"text","text":"]. (A, TA.)"},{"kind":"arabic","text_bw":"fiY masolakK huwa xiloqapN","text_ar":"فِى مَسْلَكٍ هُوَ خِلْقَةٌ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"fiY TariyqK","text_ar":"فِى طَرِيقٍ"},{"kind":"arabic","text_bw":"A^aSoliY~K","text_ar":"اَصْلِىٍّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xiloqiY~K","text_ar":"خِلْقِىٍّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In a way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"road, that is natural,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"original"},{"kind":"text","text":"]. (Mgh.)"}],"source_refs":["Mgh"]},{"entry_id":"n11393","headword_ar":"خَلَقَةٌ","root":"xlq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xaliqN","text_ar":"خَلِقٌ"},{"kind":"text","text":"."},{"kind":"page_break","n":802}],"source_refs":[]}]}}