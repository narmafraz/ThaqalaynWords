:"p"},{"role":"present_2mp","form":"تَشْهَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْهَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْهَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْهَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْهَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْهَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْهَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْهَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْهَقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْهَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْهَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَشْهَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشْهَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"شَهِقْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"شَهِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23217"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%87%D9%90%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to inhale","tags":["intransitive"]},{"pos":"verb","gloss":"to be high, to rise","tags":["intransitive"]}]},"etymology":null,"ipa":["/ʃa.ha.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23217","headword_ar":"شَهَقَ","root":"$hq","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"$uhuwqN","text_ar":"شُهُوقٌ"},{"kind":"text","text":", (Msb,) [said of a mountain, and of a building, &c., (see"},{"kind":"arabic","text_bw":"$aAhiqN","text_ar":"شَاهِقٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"It rose high;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lofty."},{"kind":"text","text":"(S, Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"$ahaqa","text_ar":"شَهَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"ta$ohaAqN","text_ar":"تَشْهَاقٌ"},{"kind":"text","text":"], said of an ass, ["},{"kind":"italic_en","text":"He uttered the ending of his braying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the final sounds thereof;"},{"kind":"text","text":"] (S;) [for]"},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"ending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"final part, of the crying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"braying,"},{"kind":"text","text":"of the ass; (S, O;) and to this the cries of the punished in Hell are likened in the Kur xi. 108; (O;) and"},{"kind":"arabic","text_bw":"zafiyrN","text_ar":"زَفِيرٌ"},{"kind":"text","text":"signifies the “ beginning, or commencing part, thereof: ” (S:) or"},{"kind":"arabic","text_bw":"$hyq","text_ar":"شهيق"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"drawing back of the breath;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zfyr","text_ar":"زفير"},{"kind":"text","text":"the “ emitting thereof: ” (Lth, S: [but the reverse is said by Lth and in the S in art."},{"kind":"arabic","text_bw":"zfr","text_ar":"زفر"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"ta$ohaAqN","text_ar":"تَشْهَاقٌ"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":": (S:) or both of these words signify [absolutely] the"},{"kind":"italic_en","text":"crying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"braying,"},{"kind":"text","text":"of the ass: (O, K:) Zj says that"},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":"as denoting one of the cries of the afflicted [in Hell] means"},{"kind":"italic_en","text":"a very high-sounding moaning:"},{"kind":"text","text":"and that, accord. to some,"},{"kind":"arabic","text_bw":"zafiyrN","text_ar":"زَفِيرٌ"},{"kind":"text","text":"[as used in the Kur ubi suprà] is similar to the beginning of the cry of the ass, termed"},{"kind":"arabic","text_bw":"$ahiyq","text_ar":"شَهِيق"},{"kind":"text","text":"; and that"},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"in the chest."},{"kind":"text","text":"(TA.) [Said of a man,]"},{"kind":"arabic","text_bw":"$ahaqa","text_ar":"شَهَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"$ahiqa","text_ar":"شَهِقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$uhaAqN","text_ar":"شُهَاقٌ"},{"kind":"text","text":"(O, K) and"},{"kind":"arabic","text_bw":"$uhuwqN","text_ar":"شُهُوقٌ"},{"kind":"text","text":"(O) and"},{"kind":"arabic","text_bw":"ta$ohaAqN","text_ar":"تَشْهَاقٌ"},{"kind":"text","text":"; signify"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sound of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"weeping became reiterated in his chest:"},{"kind":"text","text":"(O, K:) or, as in the L,"},{"kind":"italic_en","text":"he reiterated the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sound of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"weeping in his chest."},{"kind":"text","text":"(TA.) [Or]"},{"kind":"arabic","text_bw":"$ahaqa","text_ar":"شَهَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ahiyqN","text_ar":"شَهِيقٌ"},{"kind":"text","text":", signifies [or signifies also]"},{"kind":"italic_en","text":"He reiterated his breath, making his voice audible, naturally."},{"kind":"text","text":"(Msb.) One says also,"},{"kind":"arabic","text_bw":"$ahaqa fulaAnN $ahoqapF famaAta","text_ar":"شَهَقَ فُلَانٌ شَهْقَةً فَمَاتَ"},{"kind":"italic_en","text":"Such a one uttered a single cry and died."},{"kind":"text","text":"(S, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$ahaqato Eayonu Aln~aAZiri","text_ar":"شَهَقَتْ عَيْنُ النَّاظِرِ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The eye of the looker smote him with evil influence:"},{"kind":"text","text":"(O, K, TA:) or,"},{"kind":"italic_en","text":"was pleased with him, and therefore continued looking at him."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["S","Msb","O","K","TA"]}]},"classical_definitions":null}