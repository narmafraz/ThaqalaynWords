ry_ids":["n10234","n10257"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%92%D8%B1%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10234","headword_ar":"اخرب","root":"xrb","body":[{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_ixoraAbN","text_ar":"اـِخْرَابٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He reduced to ruin;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered waste, uninhabited, depopulated, deserted, desolate, uncultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state the contrary of flourishing;"},{"kind":"text","text":"(S, A, K;) a house, (S, K,) or a dwelling, or place of abode, (Msb,) or a country; (A;) as also ↓"},{"kind":"arabic","text_bw":"xr~b","text_ar":"خرّب","orth_type":"arrow"},{"kind":"text","text":", (A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"taxoriybN","text_ar":"تَخْرِيبٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"xaraba","text_ar":"خَرَبَ","orth_type":"arrow"},{"kind":"text","text":", (K,) [inf. n."},{"kind":"arabic","text_bw":"xaraAbN","text_ar":"خَرَابٌ"},{"kind":"text","text":", as in the Kur ii. 108:] or ↓"},{"kind":"arabic","text_bw":"xr~b","text_ar":"خرّب","orth_type":"arrow"},{"kind":"text","text":"signifies the same, but in a more extensive, or a superlative or an intensive sense: you say,"},{"kind":"arabic","text_bw":"xar~abuwA buyuwtahumo","text_ar":"خَرَّبُوا بُيُوتَهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They ruined their houses;"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"being doubled because the verb has many objects: or"},{"kind":"italic_en","text":"they demolished their houses"},{"kind":"text","text":"]. (S, TA.)"},{"kind":"arabic","text_bw":"buyuwtahumo","text_ar":"بُيُوتَهُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yuxar~ibuwna","text_ar":"يُخَرِّبُونَ","orth_type":"arrow"},{"kind":"text","text":", in the Kur [lix. 2],"},{"kind":"page_break","n":716},{"kind":"text","text":"means"},{"kind":"italic_en","text":"They demolishing their houses:"},{"kind":"text","text":"this is the reading of AA: all others read"},{"kind":"arabic","text_bw":"yuxoribuwna bywthm","text_ar":"يُخْرِبُونَ بيوتهم"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"they going forth from their houses, and leaving them;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"evacuating their houses;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaving them in a state of ruin."},{"kind":"text","text":"(Bd.) ―         -b2-  [Hence the saying,]"},{"kind":"arabic","text_bw":"AlA^amaAnaAtu","text_ar":"الاَمَانَاتُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Einodahu tuxar~abu","text_ar":"عِنْدَهُ تُخَرَّبُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Deposits entrusted to him become lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perish"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n10257","headword_ar":"اَخْرَبُ","root":"xrb","body":[{"kind":"italic_en","text":"Slit:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having a round hole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforation:"},{"kind":"text","text":"(S:) [fem."},{"kind":"arabic","text_bw":"xarobaA='u","text_ar":"خَرْبَا=ءُ"},{"kind":"text","text":"; as in]"},{"kind":"arabic","text_bw":"A^u*unN xarobaA='u","text_ar":"اُذُنٌ خَرْبَا=ءُ"},{"kind":"italic_en","text":"An ear having the lobe slit."},{"kind":"text","text":"(K.) ―         -b2-  A man, (S,) or a ram, (Msb,)"},{"kind":"italic_en","text":"having his ear slit;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"muxar~abN","text_ar":"مُخَرَّبٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muxar~amN","text_ar":"مُخَرَّمٌ"},{"kind":"text","text":"; (TA;) from ↓"},{"kind":"arabic","text_bw":"maxoruwbN","text_ar":"مَخْرُوبٌ","orth_type":"arrow"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"slit:"},{"kind":"text","text":"(S:) and (so in the S and TA, but in the Msb “ or ” )"},{"kind":"italic_en","text":"having his ear pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored:"},{"kind":"text","text":"when it is slit (after the piercing, S, TA), he is said to be"},{"kind":"arabic","text_bw":"A^axoramu","text_ar":"اَخْرَمُ"},{"kind":"text","text":": (S, Msb, TA: [but see this last in art."},{"kind":"arabic","text_bw":"xrm","text_ar":"خرم"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"A^axorabu","text_ar":"اَخْرَبُ"},{"kind":"arabic","text_bw":"AlA^u*unayoni","text_ar":"الاُذُنَيْنِ"},{"kind":"italic_en","text":"having the ears pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored:"},{"kind":"text","text":"(AM, TA in art."},{"kind":"arabic","text_bw":"xrt","text_ar":"خرت"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"xarobaA='u","text_ar":"خَرْبَا=ءُ"},{"kind":"text","text":"a female slave"},{"kind":"italic_en","text":"having the lobe of her ear slit"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"muxar~abapN","text_ar":"مُخَرَّبَةٌ","orth_type":"arrow"},{"kind":"text","text":"a female slave"},{"kind":"italic_en","text":"having her ear"},{"kind":"text","text":"["},{"kind":"italic_en","text":"slit"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"xarobaA='u","text_ar":"خَرْبَا=ءُ"},{"kind":"text","text":"a she-goat"},{"kind":"italic_en","text":"having her ear slit, but so that the slit is not long nor wide."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"A^axorabN","text_ar":"اَخْرَبٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xurobapN","text_ar":"خُرْبَةٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","TA"]}]},"classical_definitions":null}