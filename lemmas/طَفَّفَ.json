":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُطَفِّفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُطَفِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُطَفِّف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُطَفِّف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُطَفِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطَفِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُطَفِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطَفِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُطَفِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطَفِّفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُطَفِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طَفَّفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَفَّفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُطَفِّف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطَفِّف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n26787","n26792"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D9%81%D9%8E%D9%91%D9%81%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26787","headword_ar":"طفّف","root":"Tf","body":[{"kind":"italic_en","text":"He made defective,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"Tf~f","text_ar":"طفّف"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"Tf~f AlmikoyaAla","text_ar":"طفّف المِكْيَالَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlmiyzaAna","text_ar":"المِيزَانَ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"taTofiyfN","text_ar":"تَطْفِيفٌ"},{"kind":"text","text":", (S, O, Msb,)"},{"kind":"italic_en","text":"He gave short measure,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"short weight;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he made the contents of the measure to be defective,"},{"kind":"text","text":"(S, O, Msb, K,) and in like manner,"},{"kind":"italic_en","text":"of the balance;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"not filling the former to its uppermost parts:"},{"kind":"text","text":"(S, TA:) i. e."},{"kind":"italic_en","text":"he did thus, cheating his companion in measure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in weight."},{"kind":"text","text":"(TA.) [Hence,]"},{"kind":"arabic","text_bw":"Tf~f EalaY EiyaAlihi","text_ar":"طفّف عَلَى عِيَالِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He scanted his household, stinted them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was niggardly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parsimonious towards them, in expenditure."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Tf~f EalaY Alr~ajuli","text_ar":"طفّف عَلَى الرَّجُلِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He gave to the man less than he had taken from him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Tf~f AlA_inaA='a","text_ar":"طفّف الاـِنَا=ءَ"},{"kind":"italic_en","text":"He took what was upon"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"above"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the vessel"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"its"},{"kind":"arabic","text_bw":"TufaAf","text_ar":"طُفَاف"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"TufaAfap","text_ar":"طُفَافَة"},{"kind":"text","text":"]. (TA. [See also 4, last sentence.]) ―         -b2-  Also"},{"kind":"italic_en","text":"He made full,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complete."},{"kind":"text","text":"(TA.) [Thus it has two contr. significations.]       -A2-"},{"kind":"arabic","text_bw":"Tf~ft Al$~amosu","text_ar":"طفّفت الشَّمْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The sun drew near to setting:"},{"kind":"text","text":"(TA:) [but this may be a mistranscription for ↓"},{"kind":"arabic","text_bw":"Taf~at","text_ar":"طَفَّت","orth_type":"arrow"},{"kind":"text","text":", mentioned by Golius in this sense on the authority of Z: or each may be correct: that the latter is correct, and that ↓"},{"kind":"arabic","text_bw":"TafaAfN","text_ar":"طَفَافٌ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"TifaAfN","text_ar":"طِفَافٌ","orth_type":"arrow"},{"kind":"text","text":"is its inf. n., seems to be indicated by the fact that SM adds immediately after the explanation of the former phrase,]"},{"kind":"arabic","text_bw":"A^ataAnaA Einoda TfAfi Al$~amosi","text_ar":"اَتَانَا عِنْدَ طفافِ الشَّمْسِ"},{"kind":"text","text":"means (tropical:)  ["},{"kind":"italic_en","text":"He came to us"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"at the sun's drawing near to setting."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Tf~f","text_ar":"طفّف"},{"kind":"text","text":", said of a bird, [or ↓"},{"kind":"arabic","text_bw":"Taf~a","text_ar":"طَفَّ","orth_type":"arrow"},{"kind":"text","text":", mentioned by Freytag from Hamaker's Specim. catal. p. 49, 1. 4, of the Arabic text, or both may be correct,]"},{"kind":"italic_en","text":"The bird expanded his wings:"},{"kind":"text","text":"(O, K:) so says Ibn-'Abbád. (O.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Tf~f bihi Alfarasu","text_ar":"طفّف بِهِ الفَرَسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The horse leaped with him."},{"kind":"text","text":"(Ibn-'Abbád, O, K. [Golius has omitted this; and has assigned to"},{"kind":"arabic","text_bw":"Tf~f","text_ar":"طفّف"},{"kind":"text","text":", followed by"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"with the person who is the object, as on the authority of the S and K, the signification of"},{"kind":"arabic","text_bw":"AdnA","text_ar":"ادنا"},{"kind":"text","text":"(properly"},{"kind":"arabic","text_bw":"A^adonaY","text_ar":"اَدْنَى"},{"kind":"text","text":"), meaning “ prope admovit, ” a signification belonging to"},{"kind":"arabic","text_bw":"A^aTaf~a","text_ar":"اَطَفَّ"},{"kind":"text","text":", but not assigned to either of these verbs in the S nor in the K.])"},{"kind":"arabic","text_bw":"Taf~afa biYa Alfarasu masojida baniY","text_ar":"طَفَّفَ بِىَ الفَرَسُ مَسْجِدَ بَنِى"},{"kind":"arabic","text_bw":"zurayoqK","text_ar":"زُرَيْقٍ"},{"kind":"text","text":", in a saying of Ibn-'Omar respecting a horse-race, means (tropical:)"},{"kind":"italic_en","text":"The horse leaped with me"},{"kind":"text","text":"(S, O, TA)"},{"kind":"italic_en","text":"so that he passed beyond the mosque of the Sons of Zureyk."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["K","Msb","S","O","TA"]},{"entry_id":"n26792","headword_ar":"طَفَفٌ","root":"Tf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TafaAf","text_ar":"طَفَاف"},{"kind":"text","text":"."}],"source_refs":[]}]}}