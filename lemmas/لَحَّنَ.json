,"entry_ids":["n43262","n43264"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D8%AD%D9%8E%D9%91%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to mispronounce; to smatter (a language)"},{"pos":"verb","gloss":"to give [with لِ (li) ‘someone’] a veiled hint of","tags":["obsolete","rhetoric"]},{"pos":"verb","gloss":"to articulate eloquently (an argument)"},{"pos":"verb","gloss":"to be intelligent, to have a good grasp"},{"pos":"verb","gloss":"to make music, to compose"},{"pos":"verb","gloss":"to set to music"},{"pos":"verb","gloss":"to remix"},{"pos":"verb","gloss":"to chant, to intone; to psalmodize"},{"pos":"verb","gloss":"to rhyme"},{"pos":"verb","gloss":"to accuse of mispronouncing or employing barbarisms in speaking"},{"pos":"noun","gloss":"tone or mode of speech, idiom, the characteristic way any animal or group sounds like","tags":["archaic"],"examples":[{"text":"فَلَعَرَفْتَهُم بِسِيمَاهُمْ وَلَتَعْرِفَنَّهُمْ فِي لَحْنِ ٱلْقَوْلِ","english":"Thou shouldst know them by their marks and thou shalt know them by the manner of their talk."}]},{"pos":"noun","gloss":"mispronunciation, barbarism","examples":[{"text":"وقد وقعت لحون في قراءة القرآن الكريم في عهد الصحابة رضوان الله عليهم ، فاستنكروها، لأنها قد أفسدت المعني"}]},{"pos":"noun","gloss":"melody, tune"},{"pos":"noun","gloss":"overtone, insinuation, hint, dog whistle","tags":["obsolete","rhetoric"]},{"pos":"noun","gloss":"intelligence, quickwittedness, nimbleness, verbal noun of لَحِنَ (laḥina)"},{"pos":"adj","gloss":"intelligent, quick-witted, nimble"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43262","headword_ar":"لَحَنَ","root":"lHn","body":[{"kind":"italic_en","text":"He erred in speech; spoke incorrectly."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"laHana lahu","text_ar":"لَحَنَ لَهُ"},{"kind":"italic_en","text":"He said to him something which he"},{"kind":"text","text":"("},{"kind":"italic_en","text":"the latter"},{"kind":"text","text":")"},{"kind":"italic_en","text":"understood, but which was unintelligible to others:"},{"kind":"text","text":"(Az, S, Msb, K:)"},{"kind":"italic_en","text":"he intimated to him something which he"},{"kind":"text","text":"("},{"kind":"italic_en","text":"the latter"},{"kind":"text","text":")"},{"kind":"italic_en","text":"alone understood."}],"source_refs":["Az","S","Msb","K"]},{"entry_id":"n43264","headword_ar":"لَحْنٌ","root":"lHn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"meaning"},{"kind":"text","text":"of speech; its"},{"kind":"italic_en","text":"intended sense"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"import:"},{"kind":"text","text":"(S, K, TA:) its"},{"kind":"italic_en","text":"intent:"},{"kind":"text","text":"(TA:) [it is"},{"kind":"italic_en","text":"direct:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"indirect:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"an indication"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"whereby the person addressed is made to understand one's intent;"},{"kind":"text","text":"so says Az (Msb: [and the like is said in the TA on the authority of AHeyth:])"},{"kind":"italic_en","text":"an oblique,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ambiguous, mode"},{"kind":"text","text":"of speech: (Msb:)"},{"kind":"italic_en","text":"an inclining"},{"kind":"text","text":"of speech"},{"kind":"italic_en","text":"to obliqueness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ambiguity, and equivocal allusion."},{"kind":"text","text":"(Bd, in xlvii. 32.) ―         -b2-"},{"kind":"italic_en","text":"A barbarism, an incorrect word."},{"kind":"text","text":"―         -b3-"},{"kind":"arabic","text_bw":"Earafotuhu fiY laHoni kalaAmihi","text_ar":"عَرَفْتُهُ فِى لَحْنِ كَلَامِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fY naHowi klAmh","text_ar":"فى نَحْوِ كلامه"},{"kind":"text","text":". and"},{"kind":"arabic","text_bw":"fY miEoraADi klAmh","text_ar":"فى مِعْرَاضِ كلامه"},{"kind":"text","text":"signify the same. (Msb in art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":".) See the last of these voce"},{"kind":"arabic","text_bw":"EaruwDN","text_ar":"عَرُوضٌ"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"laHonN","text_ar":"لَحْنٌ"},{"kind":"italic_en","text":"A modulated sound;"},{"kind":"text","text":"expl. as being"},{"kind":"arabic","text_bw":"mina AlA^aSowaAti AlmaSuwgapi AlmawoDuwEapi","text_ar":"مِنَ الاَصْوَاتِ المَصُوغَةِ المَوْضُوعَةِ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"A^aloHaAnN","text_ar":"اَلْحَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"luHuwnN","text_ar":"لُحُونٌ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"A^aloHaAnu","text_ar":"اَلْحَانُ"},{"kind":"arabic","text_bw":"AlA^agaAniY","text_ar":"الاَغَانِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The modulated sounds of songs"},{"kind":"text","text":"]. (Mgh.)"}],"source_refs":["S","K","TA","Msb"]}]},"classical_definitions":null}