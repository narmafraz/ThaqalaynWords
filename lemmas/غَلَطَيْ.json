{"lemma":"غَلَطَيْ","slug":"غَلَطَيْ","root":"غ.ل.ط","root_slug":"غ-ل-ط","root_link":"/words/roots/غ-ل-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n32239","n32243"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%84%D9%8E%D8%B7%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to err"},{"pos":"verb","gloss":"to make a mistake"},{"pos":"noun","gloss":"verbal noun of غَلِطَ (ḡaliṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"error, mistake"},{"pos":"adj","gloss":"wrong, incorrect, mistaken"}]},"etymology":null,"ipa":["/ɣa.li.tˤa/","/ɣa.latˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32239","headword_ar":"غَلِطَ","root":"glT","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"galaTN","text_ar":"غَلَطٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^ugoluwTapN","text_ar":"اُغْلُوطَةٌ"},{"kind":"text","text":", (JK,)"},{"kind":"italic_en","text":"He made a mistake; committed an error;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"missed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erred from, the right way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mode"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he was unable to find the right way,"},{"kind":"text","text":"(JK, M, K,) and"},{"kind":"italic_en","text":"knew it not:"},{"kind":"text","text":"(M, K:)"},{"kind":"italic_en","text":"in an affair;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"in anything;"},{"kind":"text","text":"(JK;)"},{"kind":"italic_en","text":"in reckoning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"computation,"},{"kind":"text","text":"&c.: (K:) or"},{"kind":"italic_en","text":"in his speech,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"in particular;"},{"kind":"text","text":"(K;) and"},{"kind":"arabic","text_bw":"galita","text_ar":"غَلِتَ"},{"kind":"text","text":"in reckoning, or computation: (S, and so in some copies of the K:) but some of the Arabs make these two verbs to be syn. dial. variants. (S.)"}],"source_refs":["S","Msb","K","M","JK"]},{"entry_id":"n32243","headword_ar":"غَلَطٌ","root":"glT","body":[{"kind":"text","text":"[an inf. n. used as a simple subst.,"},{"kind":"italic_en","text":"Mistake; error;"},{"kind":"text","text":"in speech; or in that and also in reckoning, or computation, &c.;] has for its pl."},{"kind":"arabic","text_bw":"A^agolaATN","text_ar":"اَغْلَاطٌ"},{"kind":"text","text":"; and ISd says, “ I see that IJ has made"},{"kind":"arabic","text_bw":"gilaATN","text_ar":"غِلَاطٌ"},{"kind":"text","text":"its pl.; but I know not the reason of that. ” (TA.) ↓"},{"kind":"arabic","text_bw":"magolaTapN","text_ar":"مَغْلَطَةٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies the same in the saying,"},{"kind":"arabic","text_bw":"waqaEa","text_ar":"وَقَعَ"},{"kind":"arabic","text_bw":"fulaAnN fiY AlmagolaTapi","text_ar":"فُلَانٌ فِى المَغْلَطَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one fell into mistake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"error"},{"kind":"text","text":"]. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"magoluwTN","text_ar":"مَغْلُوطٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}