{"lemma":"وُجُودٌ","slug":"وُجُودٌ","root":"#.ج.د","root_slug":"_-ج-د","root_link":"/words/roots/_-ج-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of وُجِدَ (wujida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of وَجَدَ (wajada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"existence"}]},"etymology":null,"ipa":["/wu.d͡ʒuːd/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%88%D8%AC%D9%88%D8%AF/","headword_ar":"وجود","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23818#e9d9b5","body_html":"<span>الوجود: فقدان العبد بمحاق أوصاف البشرية، ووجود الحق؛ لأنه لا بقاء للبشرية عند ظهور سلطان الحقيقة، وهذا معنى قول أبي الحسين النوري: أنا منذ عشرين سنة بين الوجد والفقد، إذا وجدت ربي فقدت قلبي، وهذا معنى قول الجنيد: علم التوحيد مباين لوجوده، ووجود التوحيد مباين لعلمه، فالتوحيد بداية، والوجود نهاية، والوجد واسطة بينهما.</span>"}]}}