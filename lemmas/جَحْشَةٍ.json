{"lemma":"جَحْشَةٍ","slug":"جَحْشَةٍ","root":"ج.ح.ش","root_slug":"ج-ح-ش","root_link":"/words/roots/ج-ح-ش","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n5115"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%AD%D9%92%D8%B4%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"young donkey"},{"pos":"noun","gloss":"trestle, horse"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5115","headword_ar":"جَحَشَهُ","root":"jH$","body":[{"kind":"text","text":", (Ks, S, Mgh, K, *) aor."},{"kind":"text","text":", (Mgh, K,) inf. n."},{"kind":"arabic","text_bw":"jaHo$N","text_ar":"جَحْشٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"It scratched it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(namely the skin, S, Mgh, K, or a man's side, Ks,)"},{"kind":"italic_en","text":"so as to abrade the surface,"},{"kind":"text","text":"(Mgh, K,) or"},{"kind":"italic_en","text":"so as to abrade the skin;"},{"kind":"text","text":"(Ks;) syn."},{"kind":"arabic","text_bw":"saHajahu","text_ar":"سَحَجَهُ"},{"kind":"text","text":", (Ks, K,) and"},{"kind":"arabic","text_bw":"qa$arahu","text_ar":"قَشَرَهُ"},{"kind":"text","text":": (Mgh, K:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xada$ahu","text_ar":"خَدَشَهُ"},{"kind":"text","text":": or it signifies"},{"kind":"italic_en","text":"more than this last:"},{"kind":"text","text":"(Ks, K:) or"},{"kind":"italic_en","text":"less than this last:"},{"kind":"text","text":"(Lth, K:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(an arrow)"},{"kind":"italic_en","text":"made a mark upon it;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"grazed it;"},{"kind":"text","text":"] namely, a wall. (Mgh.) You say,"},{"kind":"arabic","text_bw":"A^aSaAbahu $aYo'N fajaHa$a wajohahu","text_ar":"اَصَابَهُ شَىْءٌ فَجَحَشَ وَجْهَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A thing struck him, and abraded the surface of the skin of his face"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"bihi jaHo$N","text_ar":"بِهِ جَحْشٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is an abrasion of the skin"},{"kind":"text","text":"]: (S, TA:) or"},{"kind":"arabic","text_bw":"jaHo$N","text_ar":"جَحْشٌ"},{"kind":"text","text":"is not in the face, nor [anywhere] in the body [except in the side]. (L, TA.) It is said in a trad., respecting Mohammad,"},{"kind":"arabic","text_bw":"saqaTa mino farasK fajuHi$a","text_ar":"سَقَطَ مِنْ فَرَسٍ فَجُحِشَ"},{"kind":"arabic","text_bw":"$iq~ahu","text_ar":"شِقَّهُ"},{"kind":"italic_en","text":"He fell from a horse, and the skin of his side was scratched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lacerated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abraded."},{"kind":"text","text":"(Mgh, * TA.) [See also"},{"kind":"arabic","text_bw":"majoHuw$N","text_ar":"مَجْحُوشٌ"},{"kind":"text","text":".]"}],"source_refs":["Mgh","K","S","Ks","Lth","TA"]}]},"classical_definitions":null}