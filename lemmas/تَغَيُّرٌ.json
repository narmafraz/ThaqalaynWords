{"lemma":"تَغَيُّرٌ","slug":"تَغَيُّرٌ","root":"غ.#.ر","root_slug":"غ-_-ر","root_link":"/words/roots/غ-_-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32716"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%BA%D9%8E%D9%8A%D9%8F%D9%91%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to change, to be altered","tags":["intransitive"],"examples":[{"text":"سَيَتَغَيَّرُ عَالَمُنَا لَٰكِنَّهُ لَنْ يَنْتَهِيَ.","english":"Our world will change, but it will not end."},{"text":"وَأَنْهَارٌ مِنْ لَبَنٍ لَمْ يَتَغَيَّرْ طَعْمُهُ"}]},{"pos":"noun","gloss":"verbal noun of تَغَيَّرَ (taḡayyara) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32716","headword_ar":"تغيّر","root":"gyr","body":[{"kind":"text","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"gy~r","text_ar":"غيّر"},{"kind":"text","text":", (S, Msb,) ["},{"kind":"italic_en","text":"It became other than it was;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it ceased to have the quality which it had;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"it became altered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"changed,"},{"kind":"arabic","text_bw":"Eano HaAlihi","text_ar":"عَنْ حَالِهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"from its state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(K.)"},{"kind":"italic_en","text":"It became altered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"changed, in odour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise, for the worse; turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned bad; became corrupted, spoiled, tainted, infected, illsmelling, stinking, fetid, rancid, rank, fusty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frouzy."},{"kind":"text","text":"(The lexicons passim.) ―         -b2-  [And"},{"kind":"italic_en","text":"It became exchanged for another thing."},{"kind":"text","text":"] ―         -b3-  See also 1, last signification."}],"source_refs":["S","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%BA%D9%8A%D8%B1/","headword_ar":"تغير","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22505#ceee49","body_html":"<span>التغير: هو انتقال الشيء من حالة إلى حالة أخرى.</span>"},{"lexicon_id":"dictionary_15","lexicon_en":"Ibn Mālik, al-Alfāẓ al-Mukhtalifa fī l-Maʿānī al-Muʾtalifa (d. 1274 CE)","lexicon_ar":"الألفاظ المختلفة في المعاني المؤتلفة لابن مالك","permalink":"https://arabiclexicon.hawramani.com/?p=22505#fa4599","body_html":"<span class=\"title1\">بَاب التَّغَيُّر</span><br><br><span>تغير وَحَال وتنكر وتبدل وشحب وكسف ولاجه </span>"}]}}