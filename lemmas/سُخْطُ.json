{"lemma":"سُخْطُ","slug":"سُخْطُ","root":"س.خ.ط","root_slug":"س-خ-ط","root_link":"/words/roots/س-خ-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"سُخْطُ","root":"سخط","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n19202","n19204","n19205","n19206"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8F%D8%AE%D9%92%D8%B7%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be angry at, to be annoyed at, to resent"},{"pos":"noun","gloss":"verbal noun of سَخِطَ (saḵiṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"anger, resentment"}]},"etymology":null,"ipa":["/sa.xi.tˤa/","/sa.xatˤ/","/suxtˤ/","/su.xutˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19202","headword_ar":"سَخِطَ","root":"sxT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxaTN","text_ar":"سَخَطٌ"},{"kind":"text","text":"(S, * Msb, K *) [and"},{"kind":"arabic","text_bw":"masoxaTN","text_ar":"مَسْخَطٌ"},{"kind":"text","text":", (see"},{"kind":"arabic","text_bw":"suxoTN","text_ar":"سُخْطٌ"},{"kind":"text","text":", below,)]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, displeased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discontented;"},{"kind":"text","text":"(S, * K, TA;) as also ↓"},{"kind":"arabic","text_bw":"tsx~T","text_ar":"تسخّط","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;) syns."},{"kind":"arabic","text_bw":"kariha","text_ar":"كَرِهَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"takar~aha","text_ar":"تَكَرَّهَ"},{"kind":"text","text":"[the latter of which, app. referring particularly to ↓"},{"kind":"arabic","text_bw":"tsx~T","text_ar":"تسخّط","orth_type":"arrow"},{"kind":"text","text":", properly and generally signifies, when intrans.,"},{"kind":"italic_en","text":"he expressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed, dislike, displeasure, disapprobation, discontent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred"},{"kind":"text","text":"]: (TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, angry;"},{"kind":"text","text":"(S, Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"tsx~T","text_ar":"تسخّط","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the same;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became angered;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tagaD~aba","text_ar":"تَغَضَّبَ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"saxiTa Ealayohi","text_ar":"سَخِطَ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, displeased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discontented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"angry, with him"},{"kind":"text","text":"]. (Kur v. 83.) And"},{"kind":"arabic","text_bw":"saxiTahu","text_ar":"سَخِطَهُ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, displeased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discontented, with him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tsx~Thu","text_ar":"تسخّطهُ","orth_type":"arrow"},{"kind":"text","text":"; both expl. by"},{"kind":"arabic","text_bw":"lamo","text_ar":"لَمْ"},{"kind":"arabic","text_bw":"yaroDa bihi","text_ar":"يَرْضَ بِهِ"},{"kind":"text","text":"; (Ham p. 502;) and the latter by"},{"kind":"arabic","text_bw":"takar~ahahu","text_ar":"تَكَرَّهَهُ"},{"kind":"text","text":"[which signifies as above, like"},{"kind":"arabic","text_bw":"karihahu","text_ar":"كَرِهَهُ"},{"kind":"text","text":", and also"},{"kind":"italic_en","text":"he expressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed, dislike of it, displeasure with it, disapprobation of it, discontent with it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred of it"},{"kind":"text","text":"]; (K, TA;) and"},{"kind":"arabic","text_bw":"lamo yaroDahu","text_ar":"لَمْ يَرْضَهُ"},{"kind":"text","text":"; (TA;) as in the saying, ↓"},{"kind":"arabic","text_bw":"kul~amaA Eamilotu lahu EamalFA tasax~aTahu","text_ar":"كُلَّمَا عَمِلْتُ لَهُ عَمَلًا تَسَخَّطَهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Every time that I did for him a deed, he expressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed, dislike of it,"},{"kind":"text","text":"&c.]; and in like manner, ↓"},{"kind":"arabic","text_bw":"A^aEoTaAhu qaliylFA fatasax~aTahu","text_ar":"اَعْطَاهُ قَلِيلًا فَتَسَخَّطَهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He gave him little and he expressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed, dislike of it,"},{"kind":"text","text":"&c.]: (TA:) and [hence,]"},{"kind":"arabic","text_bw":"EaTaA='ahu","text_ar":"عَطَا=ءَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tasax~aTa","text_ar":"تَسَخَّطَ","orth_type":"arrow"},{"kind":"italic_en","text":"He deemed his gift little, and it did not stand with him in any stead;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"Aisotaqal~ahu walamo yaqaEo minohu","text_ar":"اِسْتَقَلَّهُ وَلَمْ يَقَعْ مِنْهُ"},{"kind":"arabic","text_bw":"mawoqiEFA","text_ar":"مَوْقِعًا"},{"kind":"text","text":". (S, K.) You say also,"},{"kind":"arabic","text_bw":"Aall~`hu yasoxaTu lakumo ka*aA","text_ar":"اَللّٰهُ يَسْخَطُ لَكُمْ كَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"God forbiddeth you such a thing:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will punish you for such a thing:"},{"kind":"text","text":"or it may refer to the desire of punishing for it. (TA.)"}],"source_refs":["TA"]},{"entry_id":"n19204","headword_ar":"سُخْطٌ","root":"sxT","body":[{"kind":"text","text":", (S, Msb, K,) a subst. from"},{"kind":"arabic","text_bw":"saxiTa","text_ar":"سَخِطَ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"Dislike, displeasure, disapprobation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discontent;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"; (S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"suxuTN","text_ar":"سُخُطٌ","orth_type":"arrow"},{"kind":"text","text":"(Sgh, K) and ↓"},{"kind":"arabic","text_bw":"saxaTN","text_ar":"سَخَطٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"masoxaTN","text_ar":"مَسْخَطٌ","orth_type":"arrow"},{"kind":"text","text":": (Sgh, K:) [the last two of which are inf. ns.:]"},{"kind":"italic_en","text":"anger;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"saxaTN","text_ar":"سَخَطٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K","Sgh"]},{"entry_id":"n19205","headword_ar":"سَخَطٌ","root":"sxT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"suxoTN","text_ar":"سُخْطٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n19206","headword_ar":"سُخُطٌ","root":"sxT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"suxoTN","text_ar":"سُخْطٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}