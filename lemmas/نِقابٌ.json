rabic", "text_bw": "nqaAbN", "text_ar": "نقَابٌ"}, {"kind": "text", "text": "The"}, {"kind": "italic_en", "text": "bello,"}, {"kind": "text", "text": "Hence the proverb,"}, {"kind": "arabic", "text_bw": "faroxaAni fiY niqaAbK", "text_ar": "فَرْخَانِ فِى نِقَابٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Two young birds in one belly"}, {"kind": "text", "text": "]: applied to two things that resemble one another, (K.) In like manner one says"}, {"kind": "arabic", "text_bw": "kaAnaA fiY nqAb waAHd", "text_ar": "كَانَا فِى نقاب وَاحد"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "They were in one belly"}, {"kind": "text", "text": "]; meaning"}, {"kind": "italic_en", "text": "they were like each other,"}, {"kind": "text", "text": "(A.)"}], "source_refs": ["Msb", "T", "K", "S"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}