{"lemma": "حَدٌّ", "slug": "حَدٌّ", "root": "ح.د.د", "root_slug": "ح-د-د", "root_link": "/words/roots/ح-د-د", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 7, "pos_tags": ["adj", "noun", "verb"], "has_etymology": false, "sense_count": 39}, "lanes": {"found": true, "entry_ids": ["n7271"], "search_url": "https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AF%D9%8C%D9%91"}}, "translations": {"en": "limit, punishment", "fa": "حد، مجازات", "ur": "حد، سزا", "tr": "sınır, ceza", "id": "batas, hukuman", "bn": "সীমা, শাস্তি", "es": "límite, castigo", "fr": "limite, châtiment", "de": "Grenze, Strafe", "ru": "предел, наказание", "zh": "界限，刑罚"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to prevent, to restrain, to check, to hinder", "examples": [{"text": "حَدَّ اللَّهُ عَنَّا الشَّرَّ", "english": "God protected us from evil"}]}, {"pos": "verb", "gloss": "to restrict, to limit, to confine"}, {"pos": "verb", "gloss": "to stop, to halt"}, {"pos": "verb", "gloss": "to delineate, to delimit (esp. land)"}, {"pos": "verb", "gloss": "to define (a word)"}, {"pos": "verb", "gloss": "to sharpen (a knife, etc.)"}, {"pos": "verb", "gloss": "to punish, to chastise"}, {"pos": "verb", "gloss": "to fix (one's gaze)"}, {"pos": "verb", "gloss": "to separate"}, {"pos": "verb", "gloss": "to deprive (someone) of their livelihood"}, {"pos": "verb", "gloss": "to remove all ornaments and wear mourning apparel"}, {"pos": "verb", "gloss": "to mourn"}, {"pos": "verb", "gloss": "to be sharp, to be cutting (of a knife)"}, {"pos": "verb", "gloss": "to be strong (of a smell)"}, {"pos": "verb", "gloss": "to be strong, to be active (of a person)"}, {"pos": "verb", "gloss": "to be sharp, to be intelligent (of a person)"}, {"pos": "verb", "gloss": "to be quick to anger (of a person)"}, {"pos": "verb", "gloss": "to fly into a rage against, to be angry or furious with"}, {"pos": "noun", "gloss": "verbal noun of حَدَّ (ḥadda) (form I)", "tags": ["form-of", "noun-from-verb"]}, {"pos": "noun", "gloss": "limit"}, {"pos": "noun", "gloss": "boundary, border"}, {"pos": "noun", "gloss": "frontier"}, {"pos": "noun", "gloss": "term"}, {"pos": "noun", "gloss": "end, goal, aim"}, {"pos": "noun", "gloss": "district"}, {"pos": "noun", "gloss": "reach, sphere of action"}, {"pos": "noun", "gloss": "difference"}, {"pos": "noun", "gloss": "definition"}, {"pos": "noun", "gloss": "rule"}, {"pos": "noun", "gloss": "punishment"}, {"pos": "noun", "gloss": "edge, point"}, {"pos": "noun", "gloss": "passion"}, {"pos": "noun", "gloss": "intoxicating strength of liquors"}, {"pos": "noun", "gloss": "strength, bravery"}, {"pos": "noun", "gloss": "energy"}, {"pos": "noun", "gloss": "manner, way"}, {"pos": "noun", "gloss": "hindrance"}, {"pos": "noun", "gloss": "side", "tags": ["Arabic", "Modern", "Standard"]}, {"pos": "adj", "gloss": "violent, passionate"}]}, "etymology": null, "ipa": ["/ħad.da/", "/ħadd/", "/ħid/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n7271", "headword_ar": "حَدٌّ", "root": "Hd", "body": [{"kind": "italic_en", "text": "Prevention, hinderance, an impediment, a withholding, restraint, a debarring, inhibition, forbiddance, prohibition,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "interdiction;"}, {"kind": "text", "text": "(S, Mgh, L, Msb, K, TA;) as also ↓"}, {"kind": "arabic", "text_bw": "HadadN", "text_ar": "حَدَدٌ", "orth_type": "arrow"}, {"kind": "text", "text": ": (S, L, K:) and, both words,"}, {"kind": "italic_en", "text": "a repelling,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an averting."}, {"kind": "text", "text": "(K. [See 1.]) A poet says, (S,) namely, Zeyd Ibn-' Amr Ibn-Nufeyl, (TA,)"}, {"kind": "quote", "text": "laA taEobudan~a A_il`hFA gayora xaAliqikumo\n                      \n                     ↓ \n      waA_ino duEiytumo faquwluwA duwnahu Hadadu"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Ye shall by no means worship any deity except your Creator; and if ye be invited"}, {"kind": "text", "text": "to do so,"}, {"kind": "italic_en", "text": "say ye, There is an impediment in the way of it,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a prohibition against it"}, {"kind": "text", "text": "]. (S, TA.) And one says, ↓"}, {"kind": "arabic", "text_bw": "duwna maA saA^alota Eanohu HadadN", "text_ar": "دُونَ مَا سَاَلْتَ عَنْهُ حَدَدٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(A, * L)"}, {"kind": "italic_en", "text": "There is an impediment,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a prohibition, in the way of that respecting which thou hast asked."}, {"kind": "text", "text": "(L.) And"}, {"kind": "arabic", "text_bw": "Eanohu", "text_ar": "عَنْهُ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "laAHadada", "text_ar": "لَاحَدَدَ", "orth_type": "arrow"}, {"kind": "italic_en", "text": "There is nothing to prevent,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "hinder, one from it."}, {"kind": "text", "text": "(L. [But this admits of another meaning, as will be seen, under the word"}, {"kind": "arabic", "text_bw": "HadadN", "text_ar": "حَدَدٌ"}, {"kind": "text", "text": ", below.]) ―         -b2-  [Hence,]"}, {"kind": "italic_en", "text": "A restrictive ordinance,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "statute,"}, {"kind": "text", "text": "of God,"}, {"kind": "italic_en", "text": "respecting things lawful and things unlawful:"}, {"kind": "text", "text": "pl."}, {"kind": "arabic", "text_bw": "HuduwdN", "text_ar": "حُدُودٌ"}, {"kind": "text", "text": ". (L.) The"}, {"kind": "arabic", "text_bw": "Huduwd", "text_ar": "حُدُود"}, {"kind": "text", "text": "of God are of two kinds: first, those"}, {"kind": "italic_en", "text": "ordinances prescribed to men"}, {"kind": "text", "text": "(T, Mgh, L)"}, {"kind": "italic_en", "text": "respecting eatables and drinkables and marriages"}, {"kind": "text", "text": "&c.;"}, {"kind": "italic_en", "text": "what are lawful thereof and what are unlawful:"}, {"kind": "text", "text": "(T, L:) the second kind,"}, {"kind": "italic_en", "text": "castigations,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "punishments, prescribed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "appointed, to be inflicted upon him who does that which he has been forbidden to do;"}, {"kind": "text", "text": "(T, Mgh, L;) as the"}, {"kind": "arabic", "text_bw": "Hd~", "text_ar": "حدّ"}, {"kind": "text", "text": "of the thief, which is the cutting off of his right hand for stealing a thing of the value of a quarter of a deenár or more; and that of the fornicator or fornicatress, which is flogging with a hundred stripes and banishment for a year; and that of the adulterer or adulteress, which is stoning; and that of the person who [falsely] charges an honest or a married woman with adultery, which is flogging with eighty stripes [as is also that of the person who has committed the crime of drunkenness]: (T, L:) the first kind are called"}, {"kind": "arabic", "text_bw": "Hdwd", "text_ar": "حدود"}, {"kind": "text", "text": "because they denote limits which God has forbidden to transgress: the second, because they prevent one's committing again those acts for which they are appointed as punishments; (T, Mgh, L;) or because the limits thereof are determined: (Mgh:) the latter kind of"}, {"kind": "arabic", "text_bw": "Hd~", "text_ar": "حدّ"}, {"kind": "text", "text": "is also explained as being"}, {"kind": "italic_en", "text": "that"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "castigation,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "punishment,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "which prevents the criminal from returning to his crime, and prevents others from committing his crime."}, {"kind": "text", "text": "(L, K. *)"}, {"kind": "arabic", "text_bw": "lawo raA^ayotahu EalaY Had~K", "text_ar": "لَوْ رَاَيْتَهُ عَلَى حَدٍّ"}, {"kind": "text", "text": ", in a saying of ' Omar, means"}, {"kind": "italic_en", "text": "Hadst thou seen him engaged in an affair requiring the infliction of the"}, {"kind": "arabic", "text_bw": "Hd~", "text_ar": "حدّ"}, {"kind": "text", "text": ". (Mgh.) ―         -b3-"}, {"kind": "italic_en", "text": "A bar, an obstruction, a partition,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a separation,"}, {"kind": "text", "text": "(S, A, Mgh, L, Msb, * K,)"}, {"kind": "italic_en", "text": "between two things,"}, {"kind": "text", "text": "(S, A, L, K,) or"}, {"kind": "italic_en", "text": "between two places,"}, {"kind": "text", "text": "(Mgh,) [or"}, {"kind": "italic_en", "text": "between two persons,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "to prevent their commixture,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "confusion, or the encroachment of one upon the other:"}, {"kind": "text", "text": "(L:) an inf. n. used as a subst.: (Mgh:) pl."}, {"kind": "arabic", "text_bw": "HuduwdN", "text_ar": "حُدُودٌ"}, {"kind": "text", "text": ". (L.) ―         -b4-"}, {"kind": "italic_en", "text": "A limit,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "boundary,"}, {"kind": "text", "text": "of a land or territory: pl. as above. (L.) [Hence,"}, {"kind": "arabic", "text_bw": "jaAwaza AlHad~a", "text_ar": "جَاوَزَ الحَدَّ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, exceeded the proper, due,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "common, limit; was excessive, immoderate, beyond measure, enormous, inordinate,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "exorbitant."}, {"kind": "text", "text": "] ―         -b5-  [And hence, in logic, (assumed tropical:)"}, {"kind": "italic_en", "text": "A definition."}, {"kind": "text", "text": "] It is applied by the learned to the"}, {"kind": "arabic", "text_bw": "Haqiyqap", "text_ar": "حَقِيقَة"}, {"kind": "text", "text": "of a thing, [or"}, {"kind": "italic_en", "text": "that by being which a thing is what it is,"}, {"kind": "text", "text": "] because it is [a term] collective and restrictive. (Mgh.) ―         -b6-  The"}, {"kind": "italic_en", "text": "end, extremity,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "utmost point,"}, {"kind": "text", "text": "of a thing: (S, L, K:) pl. as above. (L.) ―         -b7-  [(assumed tropical:)  The"}, {"kind": "italic_en", "text": "point,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "verge,"}, {"kind": "text", "text": "of an event.] The saying"}, {"kind": "arabic", "text_bw": "musolimapN mawoquwfapN EalaY Had~i maHoramK", "text_ar": "مُسْلِمَةٌ مَوْقُوفَةٌ عَلَى حَدِّ مَحْرَمٍ"}, {"kind": "text", "text": "means (assumed tropical:)"}, {"kind": "italic_en", "text": "A Muslimeh brought to the point,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "verge, of being subjected to an infidel's lying with her:"}, {"kind": "text", "text": "and in like manner,"}, {"kind": "arabic", "text_bw": "musolimN mawoquwfN EalaY Had~i kuforK", "text_ar": "مُسْلِمٌ مَوْقُوفٌ عَلَى حَدِّ كُفْرٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "A Muslim brought,"}, {"kind": "text", "text": "by beating or slaughter,"}, {"kind": "italic_en", "text": "to"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "the point,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "verge, of"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "denying God."}, {"kind": "text", "text": "(Mgh.) ―         -b8-  The"}, {"kind": "italic_en", "text": "edge,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "extremity of the edge,"}, {"kind": "text", "text": "(S, L,) and"}, {"kind": "italic_en", "text": "point,"}, {"kind": "text", "text": "(L,) of anything, (S, L,) as of a sword, a knife, a spear-head, and an arrow: (L:) the"}, {"kind": "italic_en", "text": "part"}, {"kind": "text", "text": "of a sword [&c.]"}, {"kind": "italic_en", "text": "with which one cuts:"}, {"kind": "text", "text": "(MF:) pl. as above. (L.) ―         -b9-  See also"}, {"kind": "arabic", "text_bw": "Hid~apN", "text_ar": "حِدَّةٌ"}, {"kind": "text", "text": ", in four places. ―         -b10-  [And hence, app.,]"}, {"kind": "italic_en", "text": "Arms,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "weapons;"}, {"kind": "text", "text": "as in the phrase"}, {"kind": "arabic", "text_bw": "*awuw Had~K", "text_ar": "ذَوُو حَدٍّ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Possessors of arms"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "weapons:"}, {"kind": "text", "text": "or this may mean (tropical:)"}, {"kind": "italic_en", "text": "persons endowed with valour"}, {"kind": "text", "text": "]. (Ham p. 143.) ―         -b11-"}, {"kind": "italic_en", "text": "A side, region, quarter,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "tract."}, {"kind": "text", "text": "(L.) ―         -b12-  (assumed tropical:)"}, {"kind": "italic_en", "text": "Station, standing, rank, condition,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "marotabapN", "text_ar": "مَرْتَبَةٌ"}, {"kind": "text", "text": ". (KL.) ―         -b13-  [(assumed tropical:)"}, {"kind": "italic_en", "text": "A case:"}, {"kind": "text", "text": "as when a noun is said to be"}, {"kind": "arabic", "text_bw": "fiY Had~i Alr~afoEi", "text_ar": "فِى حَدِّ الرَّفْعِ"}, {"kind": "italic_en", "text": "in the nominative case."}, {"kind": "text", "text": "―         -b14-  And (assumed tropical:)"}, {"kind": "italic_en", "text": "A class,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "category:"}, {"kind": "text", "text": "as when a verb is said to be"}, {"kind": "arabic", "text_bw": "mino Had~i Daraba", "text_ar": "مِنْ حَدِّ ضَرَبَ"}, {"kind": "italic_en", "text": "of the class,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "category, of"}, {"kind": "arabic", "text_bw": "Daraba", "text_ar": "ضَرَبَ"}, {"kind": "text", "text": ".] ―         -b15-  [(tropical:)"}, {"kind": "italic_en", "text": "A quarter"}, {"kind": "text", "text": "of the year.] You say,"}, {"kind": "arabic", "text_bw": "A^aqaAma Had~a Alr~abiyEi", "text_ar": "اَقَامَ حَدَّ الرَّبِيعِ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "He remained, stayed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "abode, during the quarter of the"}, {"kind": "arabic", "text_bw": "rbyE", "text_ar": "ربيع"}, {"kind": "text", "text": ". (A.)       -A2-  See also"}, {"kind": "arabic", "text_bw": "maHoduwdN", "text_ar": "مَحْدُودٌ"}, {"kind": "text", "text": "."}], "source_refs": ["S", "L", "K", "TA", "T", "Mgh", "A", "MF"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-14", "pipeline_version": "words.translation.v1.spark"}}