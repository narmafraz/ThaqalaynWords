inition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"bored, weary"}]},"etymology":null,"ipa":["/dˤa.d͡ʒir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25545","headword_ar":"ضَجِرَ","root":"Djr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, A, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"DajarN","text_ar":"ضَجَرٌ"},{"kind":"text","text":"; (S, Mgh, Msb;) and ↓"},{"kind":"arabic","text_bw":"tDj~r","text_ar":"تضجّر","orth_type":"arrow"},{"kind":"text","text":"; (A, Mgh, Msb, K;)"},{"kind":"italic_en","text":"He was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted by grief:"},{"kind":"text","text":"(S:) or, followed by"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":", (A, Mgh, Msb, K,) and by"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"he was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted by grief, at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it, and by distress of mind, and complained:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"he was grieved at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"and distressed in mind,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and complained:"},{"kind":"text","text":"(A, Msb:) or"},{"kind":"italic_en","text":"he was disgusted"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tabar~ama","text_ar":"تَبَرَّمَ"},{"kind":"text","text":", A, K)"},{"kind":"italic_en","text":"at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by it, and was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"by grief."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Dajira","text_ar":"ضَجِرَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grumbled, much:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"Dajirato","text_ar":"ضَجِرَتْ"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grumbled,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"on being milked,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"being distressed thereby."},{"kind":"text","text":"(A.) In a verse, (of El-Akhtal, TA,)"},{"kind":"arabic","text_bw":"Dajira","text_ar":"ضَجِرَ"},{"kind":"text","text":"is contracted into"},{"kind":"arabic","text_bw":"Dajora","text_ar":"ضَجْرَ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"faxi*N","text_ar":"فَخِذٌ"},{"kind":"text","text":", among nouns, is contracted [into"},{"kind":"arabic","text_bw":"faxo*N","text_ar":"فَخْذٌ"},{"kind":"text","text":"]. (S, TA.)"}],"source_refs":["S","A","Mgh","Msb","K"]}]}}