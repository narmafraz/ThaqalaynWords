{"lemma":"سُباتِ","slug":"سُباتِ","root":"س.ب.ت","root_slug":"س-ب-ت","root_link":"/words/roots/س-ب-ت","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"سُبات","root":"سبت","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n18654"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8F%D8%A8%D8%A7%D8%AA%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"stupor, lethargy, ailment of excessive sleep","tags":["historical"]},{"pos":"noun","gloss":"hibernation"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18654","headword_ar":"سُبَاتٌ","root":"sbt","body":[{"kind":"text","text":"primarily signifies"},{"kind":"italic_en","text":"Rest"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"]: (S, Msb:) and hence,"},{"kind":"italic_en","text":"sleep:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"heavy sleep:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"sleep that is hardly perceptible"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xafiY~","text_ar":"خَفِىّ"},{"kind":"text","text":", M, K, [in some copies of the K, as mentioned by Freytag,"},{"kind":"arabic","text_bw":"xafiyf","text_ar":"خَفِيف"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"]),"},{"kind":"italic_en","text":"like a swoon:"},{"kind":"text","text":"(M:) or the"},{"kind":"italic_en","text":"commencement of sleep in the head"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and its continuance"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"until it reaches the heart:"},{"kind":"text","text":"(Th, M, K:) or the"},{"kind":"italic_en","text":"sleep of one who is sick;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"light sleep:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"subaAtN","text_ar":"سُبَاتٌ"},{"kind":"text","text":". (T, TA.) Hence, in the Kur [lxxviii. 9, and in like manner the word is used in xxv. 49],"},{"kind":"arabic","text_bw":"wajaEalonaA nawomakumo subaAtFA","text_ar":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"},{"kind":"text","text":"; (S;) i. e."},{"kind":"arabic","text_bw":"qaToEFA","text_ar":"قَطْعًا"},{"kind":"text","text":"; as though a man, when he slept, were cut off from [the rest of] mankind: (IAar, TA:) or"},{"kind":"arabic","text_bw":"sbAt","text_ar":"سبات"},{"kind":"text","text":"is when one is cut off, or ceases, from motion, while the soul still remains in the body; i. e., the text means,"},{"kind":"italic_en","text":"And we have made your sleep to be rest unto you:"},{"kind":"text","text":"(Zj, TA:) or"},{"kind":"italic_en","text":"we have made your sleep to be a cutting off from sensation and motion, for rest to the animal forces, and for causing their weariness to cease:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"to be death:"},{"kind":"text","text":"(Bd:) or,"},{"kind":"italic_en","text":"to be rest unto your bodies by the interruption of labour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"work."},{"kind":"text","text":"(Jel.)       -A2-  See also"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", latter half, in three places."}],"source_refs":["S","Msb","K","M","Th","TA","IAar","Zj","Bd"]}]},"classical_definitions":null}