","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشْرِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرَفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرَفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشْرِفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرِفُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرَفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرَفُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشْرِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُشْرَفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُشْرِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْرِف","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْرَف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْرَف","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"أَشْرَفْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَشْرَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":67,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n22160","n22175"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D8%B1%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22160","headword_ar":"اشرف","root":"$rf","body":[{"kind":"italic_en","text":"It rose;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to overtop,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overlook, what was around it"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adjacent to it: overtopped, surmounted, overpeered, overlooked, overhung; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, protuberant, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"projecting:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"rose into view, came within sight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"view,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became within a commanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near, view:"},{"kind":"text","text":"] said of a place [&c.]. (Msb.) One says of a piece of ground,"},{"kind":"arabic","text_bw":"A^a$orafa EalaY maA Hawolahu","text_ar":"اَشْرَفَ عَلَى مَا حَوْلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It rose above,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overtopped, what was around it"},{"kind":"text","text":"]. (Sh, TA.) And"},{"kind":"arabic","text_bw":"A^a$orafa liY $arafN famaA zilotu A^arokuDu Hat~aY","text_ar":"اَشْرَفَ لِى شَرَفٌ فَمَا زِلْتُ اَرْكُضُ حَتَّى"},{"kind":"arabic","text_bw":"Ealawotuhu","text_ar":"عَلَوْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An eminence rose into view to me, and I ceased not to urge on"},{"kind":"text","text":"my beast"},{"kind":"italic_en","text":"until I ascended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted, upon it"},{"kind":"text","text":"]. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^a$orafotu","text_ar":"اَشْرَفْتُ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"I looked upon it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"viewed it,"},{"kind":"text","text":"(S, O, Msb, K, *)"},{"kind":"italic_en","text":"from above;"},{"kind":"text","text":"(S, O, K;) ["},{"kind":"italic_en","text":"I overlooked it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looked down upon it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I came in sight of it: got a view of it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"got knowledge of it; became acquainted with it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knew it:"},{"kind":"text","text":"all of which meanings may be intended to be conveyed by the explanation in the Msb, which is"},{"kind":"arabic","text_bw":"AiT~alaEotu Ealayohi","text_ar":"اِطَّلَعْتُ عَلَيْهِ"},{"kind":"text","text":":]"},{"kind":"page_break","n":1537},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$aArafotu","text_ar":"شَارَفْتُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"A^a$orafotu Ealayohi","text_ar":"اَشْرَفْتُ عَلَيْهِ"},{"kind":"text","text":"[app. in the first of the senses expl. in this sentence, as well as in another sense expl. in what follows]: (S, O:) and ↓"},{"kind":"arabic","text_bw":"$aArafuwhumo","text_ar":"شَارَفُوهُمْ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"A^a$orafuwA Ealayohimo","text_ar":"اَشْرَفُوا عَلَيْهِمْ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A$rf EalaY Almawoti","text_ar":"اشرف عَلَى المَوْتِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a sick man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, on the brink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the point, of death."},{"kind":"text","text":"(O, K.) And"},{"kind":"arabic","text_bw":"A$rf bihi EalaY Almawoti","text_ar":"اشرف بِهِ عَلَى المَوْتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made him to be on the brink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the point, of death"},{"kind":"text","text":"]. (T and K in art."},{"kind":"arabic","text_bw":"*rf","text_ar":"ذرف"},{"kind":"text","text":".) ―         -b4-  And"},{"kind":"arabic","text_bw":"A^a$orafato nafosuhu EalaY $aYo'K","text_ar":"اَشْرَفَتْ نَفْسُهُ عَلَى شَىْءٍ"},{"kind":"italic_en","text":"His soul was vehemently eager for a thing."},{"kind":"text","text":"(Mgh. [See also 10.])"},{"kind":"arabic","text_bw":"A_i$oraAfN","text_ar":"اـِشْرَافٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"being eager,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"being vehemently eager:"},{"kind":"text","text":"and hence the saying, in a trad.,"},{"kind":"arabic","text_bw":"mano A^axa*a Ald~unoyaA biA_i$oraAfi nafosK","text_ar":"مَنْ اَخَذَ الدُّنْيَا بِاـِشْرَافِ نَفْسٍ"},{"kind":"arabic","text_bw":"lamo yubaArako lahu fiyhaA","text_ar":"لَمْ يُبَارَكْ لَهُ فِيهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whoso takes the enjoyments of the present world with eagerness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement eagerness, of soul, he will not be blessed therein"},{"kind":"text","text":"]. (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"A$rf Ealayohi","text_ar":"اشرف عَلَيْهِ"},{"kind":"italic_en","text":"He regarded him with solicitous affection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion."},{"kind":"text","text":"(O, *  K.) ―         -b6-  [And"},{"kind":"arabic","text_bw":"A$rf liY","text_ar":"اشرف لِى"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came within sight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"view, to me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came within a commanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near, view of me:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"A^ajohada","text_ar":"اَجْهَدَ"},{"kind":"text","text":"; and another voce"},{"kind":"arabic","text_bw":"rabaA^a","text_ar":"رَبَاَ"},{"kind":"text","text":".] ―         -b7-  And [hence,]"},{"kind":"arabic","text_bw":"A$rf laka","text_ar":"اشرف لَكَ"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"italic_en","text":"The thing became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has become, within thy power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reach;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possible, practicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy, to thee."},{"kind":"text","text":"(TA.)       -A2-  See also 5, in two places."}],"source_refs":["S","O"]},{"entry_id":"n22175","headword_ar":"اَشْرَفُ","root":"$rf","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, high, elevated, exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eminent, in rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation;"},{"kind":"text","text":"&c.; generally meaning"},{"kind":"italic_en","text":"more,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, high-born"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noble;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"$ariyfN","text_ar":"شَرِيفٌ"},{"kind":"text","text":";)]"},{"kind":"italic_en","text":"surpassing in"},{"kind":"arabic","text_bw":"$araf","text_ar":"شَرَف"},{"kind":"text","text":". (S, O.) ―         -b2-"},{"kind":"arabic","text_bw":"manokibN A^a$orafu","text_ar":"مَنْكِبٌ اَشْرَفُ"},{"kind":"italic_en","text":"A high shoulder;"},{"kind":"text","text":"(S, O, K;)"},{"kind":"italic_en","text":"such as has a goodly rising;"},{"kind":"text","text":"which implies what is termed"},{"kind":"arabic","text_bw":"A_ihodaA='","text_ar":"اـِهْدَا=ء"},{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"A^ahodaA^ahu","text_ar":"اَهْدَاَهُ"},{"kind":"text","text":", and here app. meaning the “ being curved in the back ”]. (TA.) And"},{"kind":"arabic","text_bw":"A^u*unN $arofaA='u","text_ar":"اُذُنٌ شَرْفَا=ءُ"},{"kind":"italic_en","text":"A long ear;"},{"kind":"text","text":"(S, O, K;)"},{"kind":"italic_en","text":"standing up; rising above what is next to it:"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"A*n","text_ar":"اذن"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$uraAfiy~apN","text_ar":"شُرَافِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"$uraAfiY~N","text_ar":"شُرَافِىٌّ"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"A^a$orafu","text_ar":"اَشْرَفُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Having a prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an apparent, ear:"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"A^asak~u","text_ar":"اَسَكُّ"},{"kind":"text","text":", q. v. ―         -b4-  Hence,]"},{"kind":"arabic","text_bw":"AlA^a$orafu","text_ar":"الاَشْرَفُ"},{"kind":"text","text":"is an appellation of"},{"kind":"italic_en","text":"The bat;"},{"kind":"text","text":"(O, K, TA;) because its ears are prominent and apparent: it is bare of downy and other feathers, and is viviparous, not oviparous: so in the saying of Bishr Ibn-ElMoatemir,"},{"kind":"quote","text":"waTaAy^irN layosa lahu wakoru\n                      \n                     \n                        waTaAy^irN A^a$orafu *uw jurodapK"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And a flying thing that has prominent and apparent ears and a denuded body, and a flying thing that has no nest"},{"kind":"text","text":"]: (O, TA:) in the K is added, and"},{"kind":"italic_en","text":"another bird, that has no nest,"},{"kind":"text","text":"&c.: but this is taken from an explanation of the latter hemistich of the verse cited above; which explanation is as follows: (TA:) the bird that has no nest is one of which the Bahránees [so in the TA, but accord. to the O “ the sailors, ”] tell that it does not alight save while it makes, of the dust, or earth, a place in which it lays its eggs, and which it covers over; then it flies into the air, and its eggs break open of themselves at the expiration of the term thereof; and when its young ones are able to fly, they do after the habit of their parents. (O, L, TA: and the same is said, less fully, in the K.) ―         -b5-"},{"kind":"arabic","text_bw":"madiynapN $arofaA='u","text_ar":"مَدِينَةٌ شَرْفَا=ءُ"},{"kind":"italic_en","text":"A city having"},{"kind":"arabic","text_bw":"$uraf","text_ar":"شُرَف"},{"kind":"text","text":", (Mgh, O, K, *) pl. of"},{"kind":"arabic","text_bw":"$urofapN","text_ar":"شُرْفَةٌ"},{"kind":"text","text":"[q. v.]: (O:) the pl. of"},{"kind":"arabic","text_bw":"A^a$orafu","text_ar":"اَشْرَفُ"},{"kind":"text","text":"and of"},{"kind":"arabic","text_bw":"$arofaA='u","text_ar":"شَرْفَا=ءُ"},{"kind":"text","text":", accord. to rule, is"},{"kind":"arabic","text_bw":"$urofN","text_ar":"شُرْفٌ"},{"kind":"text","text":". (Mgh. [In the copies of the K,"},{"kind":"arabic","text_bw":"Al$~urufu","text_ar":"الشُّرُفُ"},{"kind":"text","text":"is erroneously said to be pl. of"},{"kind":"arabic","text_bw":"Al$~arofaA='u","text_ar":"الشَّرْفَا=ءُ"},{"kind":"text","text":".]) It is said in a trad. of Ibn- ' Abbás,"},{"kind":"arabic","text_bw":"A^umironaA A^ano naboniYa AlmadaAy^ina $urofFA waAlmasaAjida jum~FA","text_ar":"اُمِرْنَا اَنْ نَبْنِىَ المَدَايِنَ شُرْفًا وَالمَسَاجِدَ جُمًّا"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"We have been commanded to build cities with"},{"kind":"arabic","text_bw":"$uraf","text_ar":"شُرَف"},{"kind":"italic_en","text":"and mosques without"},{"kind":"arabic","text_bw":"$uraf","text_ar":"شُرَف"},{"kind":"text","text":". (Mgh, O. *)"}],"source_refs":["O","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%B4%D8%B1%D9%81/","headword_ar":"أَشْرَفُ","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=136884#581578","body_html":"<span class=\"title1\">أَشْرَفُ:</span><br><span>بالفتح: موضع بالحجاز في ديار بني نصر ابن معاوية.</span>"}]}}