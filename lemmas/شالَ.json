": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "present_1ms", "form": "أَشِيل", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَشِيل", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 43, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 3, "pos_tags": ["noun", "verb"], "has_etymology": true, "sense_count": 6}, "lanes": {"found": true, "entry_ids": ["n23370", "n23373"], "search_url": "https://lanelexicon.com/?s=%D8%B4%D8%A7%D9%84%D9%8E"}}, "translations": {"en": "to rise", "fa": "بلند شدن", "ur": "اٹھنا", "tr": "kalkmak", "id": "terangkat", "bn": "উঠা", "es": "elevarse", "fr": "s'élever", "de": "sich erheben", "ru": "подниматься", "zh": "升起"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to rise, to become elevated"}, {"pos": "verb", "gloss": "to raise, to elevate, to lift", "examples": [{"text": "تَأَبَّرِي مِنْ حَنَذٍ فَشُولِي"}, {"text": "إِذْ شَالَتِ الحَرْبُ غَرِيمَ أَمْرِي"}]}, {"pos": "noun", "gloss": "shawl, scarf, fichu"}, {"pos": "noun", "gloss": "certain fishes; Synodontis spp."}, {"pos": "noun", "gloss": "certain fishes; Silurus spp."}, {"pos": "noun", "gloss": "certain fishes; Lycodontis syn. Gymnothorax spp."}]}, "etymology": {"source": "wiktextract", "text": "Borrowed from Persian شال (šāl /šâl).\n\nFrom Sahidic Coptic ϫⲏⲗ (jēl, “a fish”), also borrowed as قِيل (gīl) from Bohairic Coptic ⲕⲏⲗ (kēl)."}, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n23370", "headword_ar": "شَالَ", "root": "$wl", "body": [{"kind": "text", "text": ", [aor."}, {"kind": "arabic", "text_bw": "ya$uwlu", "text_ar": "يَشُولُ"}, {"kind": "text", "text": ",] (S, O, Msb, K,) inf. n."}, {"kind": "arabic", "text_bw": "$uwolN", "text_ar": "شُوْلٌ"}, {"kind": "text", "text": ", (TK,)"}, {"kind": "italic_en", "text": "It rose;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became raised,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "elevated;"}, {"kind": "text", "text": "(S, O, Msb, K;) said, in this sense, of a she-camel's tail; (S, O, K;) [and in like manner of a star; (see Ham p. 239;)] and ↓"}, {"kind": "arabic", "text_bw": "An$Al", "text_ar": "انشال", "orth_type": "arrow"}, {"kind": "text", "text": "signifies the"}, {"kind": "page_break", "n": 1622}, {"kind": "text", "text": "same, (O, K,) said of a stone, (K,) and so"}, {"kind": "arabic", "text_bw": "An$Alt", "text_ar": "انشالت"}, {"kind": "text", "text": "said of a jar ("}, {"kind": "arabic", "text_bw": "jar~ap", "text_ar": "جَرَّة"}, {"kind": "text", "text": "); (S, O;) and likewise ↓"}, {"kind": "arabic", "text_bw": "A$tAl", "text_ar": "اشتال", "orth_type": "arrow"}, {"kind": "text", "text": ". (TA.) ―         -b2-  [Hence,]"}, {"kind": "arabic", "text_bw": "$Al AlmiyozaAnu", "text_ar": "شال المِيْزَانُ"}, {"kind": "italic_en", "text": "The balance had one of its two scales higher than the other,"}, {"kind": "text", "text": "(S, O, Msb, TA,)"}, {"kind": "italic_en", "text": "by reason of its lightness."}, {"kind": "text", "text": "(Msb.) Whence the saying,"}, {"kind": "arabic", "text_bw": "$Al miyzaAnu fulaAnK", "text_ar": "شال مِيزَانُ فُلَانٍ"}, {"kind": "text", "text": ", aor."}, {"kind": "arabic", "text_bw": "ya$uwlu", "text_ar": "يَشُولُ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "$awalaAnN", "text_ar": "شَوَلَانٌ"}, {"kind": "text", "text": ", meaning (tropical:)"}, {"kind": "italic_en", "text": "Such a one was overcome in contending with another for superiority in glory"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like."}, {"kind": "text", "text": "(TA.) ―         -b3-  And"}, {"kind": "arabic", "text_bw": "$Alt Alqirobapu", "text_ar": "شالت القِرْبَةُ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "$Al Alz~iq~u", "text_ar": "شال الزِّقُّ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "The legs of the water-skin,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "of the skin for wine &c., became raised,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "elevated, on the occasion of its being filled,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "inflated."}, {"kind": "text", "text": "(TA.) ―         -b4-  And"}, {"kind": "arabic", "text_bw": "$aAla labanuhaA", "text_ar": "شَالَ لَبَنُهَا"}, {"kind": "text", "text": "[meaning"}, {"kind": "italic_en", "text": "Her milk became drawn up,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "withdrawn,"}, {"kind": "text", "text": "] is said of a camel. (TA.) ―         -b5-  One says also,"}, {"kind": "arabic", "text_bw": "$Alt naEaAmatuhu", "text_ar": "شالت نَعَامَتُهُ"}, {"kind": "text", "text": ", meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "He was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, flurried, agitated,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "excited,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "xaf~a", "text_ar": "خَفَّ"}, {"kind": "text", "text": ",)"}, {"kind": "italic_en", "text": "and angry, and then became calm."}, {"kind": "text", "text": "(K.) And"}, {"kind": "arabic", "text_bw": "$Alt naEaAmatuhumo", "text_ar": "شالت نَعَامَتُهُمْ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "Their might"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "Eiz~uhumo", "text_ar": "عِزُّهُمْ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "departed:"}, {"kind": "text", "text": "(O, K:) or"}, {"kind": "italic_en", "text": "their abodes became clear of them, as though lightened of them,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "xaf~ato", "text_ar": "خَفَّتْ"}, {"kind": "arabic", "text_bw": "manaAziluhumo minohumo", "text_ar": "مَنَازِلُهُمْ مِنْهُمْ"}, {"kind": "text", "text": ", K, TA,)"}, {"kind": "italic_en", "text": "and they went away:"}, {"kind": "text", "text": "(TA:) or"}, {"kind": "italic_en", "text": "their expression of opinion was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, discordant:"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "tafar~aqato kalimatuhumo", "text_ar": "تَفَرَّقَتْ كَلِمَتُهُمْ"}, {"kind": "text", "text": ": K:) or"}, {"kind": "italic_en", "text": "they died:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "they became scattered,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "dispersed; as though there remained not of them save a remnant;"}, {"kind": "text", "text": "[see"}, {"kind": "arabic", "text_bw": "$awolN", "text_ar": "شَوْلٌ"}, {"kind": "text", "text": ";]"}, {"kind": "arabic", "text_bw": "Aln~aEaAmapu", "text_ar": "النَّعَامَةُ"}, {"kind": "text", "text": "signifying"}, {"kind": "arabic", "text_bw": "AljamaAEapu", "text_ar": "الجَمَاعَةُ"}, {"kind": "text", "text": ": (TA:) or"}, {"kind": "italic_en", "text": "they became irresolute, by reason of fear, and fled:"}, {"kind": "text", "text": "(Msb:) or"}, {"kind": "italic_en", "text": "they were frightened, and fled."}, {"kind": "text", "text": "(M in art."}, {"kind": "arabic", "text_bw": "rA^l", "text_ar": "رال"}, {"kind": "text", "text": ".) [See also"}, {"kind": "arabic", "text_bw": "naEaAmapN", "text_ar": "نَعَامَةٌ"}, {"kind": "text", "text": ": and see a verse cited voce"}, {"kind": "arabic", "text_bw": "A_im~aA", "text_ar": "اـِمَّا"}, {"kind": "text", "text": ".]       -A2-"}, {"kind": "arabic", "text_bw": "$ulotu bihi", "text_ar": "شُلْتُ بِهِ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "$ulotuhu", "text_ar": "شُلْتُهُ"}, {"kind": "text", "text": "; (Msb;) and ↓"}, {"kind": "arabic", "text_bw": "A^a$alotuhu", "text_ar": "اَشَلْتُهُ", "orth_type": "arrow"}, {"kind": "text", "text": "; (O, Msb;) or"}, {"kind": "arabic", "text_bw": "$ulotu biAljar~api", "text_ar": "شُلْتُ بِالجَرَّةِ"}, {"kind": "text", "text": ", for which one should not say"}, {"kind": "arabic", "text_bw": "$ilotu", "text_ar": "شِلْتُ"}, {"kind": "text", "text": "[which the vulgar say in the present day, making it trans. by itself]; (S, O;) and ↓"}, {"kind": "arabic", "text_bw": "A^a$alotuhaA", "text_ar": "اَشَلْتُهَا", "orth_type": "arrow"}, {"kind": "text", "text": "; (S;) or"}, {"kind": "arabic", "text_bw": "$Al biAlHajari", "text_ar": "شال بِالحَجَرِ"}, {"kind": "text", "text": "; and ↓"}, {"kind": "arabic", "text_bw": "A$Alhu", "text_ar": "اشالهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (K,) inf. n."}, {"kind": "arabic", "text_bw": "A_i$aAlapN", "text_ar": "اـِشَالَةٌ"}, {"kind": "text", "text": "; (TA;) and ↓"}, {"kind": "arabic", "text_bw": "$Awlhu", "text_ar": "شاولهُ", "orth_type": "arrow"}, {"kind": "text", "text": "; (K;) aor. of the first as above, inf. n."}, {"kind": "arabic", "text_bw": "$awolN", "text_ar": "شَوْلٌ"}, {"kind": "text", "text": "; (S, O, Msb;)"}, {"kind": "italic_en", "text": "I raised,"}, {"kind": "text", "text": "(S, O, Msb,) or"}, {"kind": "italic_en", "text": "he raised,"}, {"kind": "text", "text": "(K,)"}, {"kind": "italic_en", "text": "it,"}, {"kind": "text", "text": "(O, Msb,) namely, a thing, (O,) or"}, {"kind": "italic_en", "text": "the jar,"}, {"kind": "text", "text": "(S, O,) or"}, {"kind": "italic_en", "text": "the stone."}, {"kind": "text", "text": "(K.) And"}, {"kind": "arabic", "text_bw": "$Alt bi*anabihaA", "text_ar": "شالت بِذَنَبِهَا"}, {"kind": "text", "text": ", (S, O, Msb, K,) aor. as above, (S, O, K,) inf. n."}, {"kind": "arabic", "text_bw": "$awolN", "text_ar": "شَوْلٌ"}, {"kind": "text", "text": "(O, Msb, K) and"}, {"kind": "arabic", "text_bw": "$awalaAnN", "text_ar": "شَوَلَانٌ"}, {"kind": "text", "text": "; (O, K;) and ↓"}, {"kind": "arabic", "text_bw": "A$Althu", "text_ar": "اشالتهُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S, Msb, K,) inf. n."}, {"kind": "arabic", "text_bw": "A_i$aAlapN", "text_ar": "اـِشَالَةٌ"}, {"kind": "text", "text": "; and ↓"}, {"kind": "arabic", "text_bw": "Ast$Althu", "text_ar": "استشالتهُ", "orth_type": "arrow"}, {"kind": "text", "text": "; (TA;)"}, {"kind": "italic_en", "text": "She"}, {"kind": "text", "text": "(a camel)"}, {"kind": "italic_en", "text": "raised her tail,"}, {"kind": "text", "text": "(S, O, Msb, K, TA,)"}, {"kind": "italic_en", "text": "having become pregnant."}, {"kind": "text", "text": "(Msb. [See"}, {"kind": "arabic", "text_bw": "$aAy^ilN", "text_ar": "شَايِلٌ"}, {"kind": "text", "text": ": and see also 2.]) And"}, {"kind": "arabic", "text_bw": "$Alt bi*anabihaA", "text_ar": "شالت بِذَنَبِهَا"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a scorpion)"}, {"kind": "italic_en", "text": "raised its tail."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "$Al yadahu", "text_ar": "شال يَدَهُ"}, {"kind": "italic_en", "text": "He raised his arm"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "hand;"}, {"kind": "text", "text": "like"}, {"kind": "arabic", "text_bw": "$Al bihaA", "text_ar": "شال بِهَا"}, {"kind": "text", "text": ". (Msb.) And"}, {"kind": "arabic", "text_bw": "biDaboEihi", "text_ar": "بِضَبْعِهِ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "A$Al", "text_ar": "اشال", "orth_type": "arrow"}, {"kind": "italic_en", "text": "He raised his"}, {"kind": "arabic", "text_bw": "DaboE", "text_ar": "ضَبْع"}, {"kind": "text", "text": "[generally expl. as meaning the"}, {"kind": "italic_en", "text": "upper half of the arm, from the elbow to the shoulder-blade"}, {"kind": "text", "text": "]. (TA.)"}], "source_refs": ["S", "O", "Msb", "K", "TK", "TA"]}, {"entry_id": "n23373", "headword_ar": "شَالٌ", "root": "$wl", "body": [{"kind": "italic_en", "text": "A certain fish of the sea,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "of great rivers"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "samakapN baHoriy~apN", "text_ar": "سَمَكَةٌ بَحْرِيَّةٌ"}, {"kind": "text", "text": "): (TA:) [in Egypt this name is applied to"}, {"kind": "italic_en", "text": "a fish of the genus silurus, found in the Nile:"}, {"kind": "text", "text": "it is well described by Sonnini, in p. 407 of the 4to Engl. ed. of his Travels in Upper and Lower Egypt.]       -A2-  Also"}, {"kind": "italic_en", "text": "A certain kind of"}, {"kind": "arabic", "text_bw": "ridaA='", "text_ar": "رِدَا=ء"}, {"kind": "text", "text": "[here meaning"}, {"kind": "italic_en", "text": "shawl"}, {"kind": "text", "text": "],"}, {"kind": "italic_en", "text": "made in Cashmere and Lahore, and brought for sale to other countries;"}, {"kind": "text", "text": "[erroneously] said to be made of camels' fur; and so called because raised to the shoulders, if it be an Arabic word [which is not the case, for it is from the Pers."}, {"kind": "arabic", "text_bw": "$aAlN", "text_ar": "شَالٌ"}, {"kind": "text", "text": ", whence our word “ shawl ”]: pl."}, {"kind": "arabic", "text_bw": "$iylaAnN", "text_ar": "شِيلَانٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "$aAlaAtN", "text_ar": "شَالَاتٌ"}, {"kind": "text", "text": ". (TA.)"}], "source_refs": ["TA"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%B4%D8%A7%D9%84/", "headword_ar": "شال", "entries": [{"lexicon_id": "dictionary_48", "lexicon_en": "Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)", "lexicon_ar": "موسوعة السلطان قابوس لأسماء العرب", "permalink": "https://arabiclexicon.hawramani.com/?p=61034#0633e0", "body_html": "شال<br>عن التركية شال بمعنى قماش من صوف.<br>شال<br>عن الفارسية بمعنى قطعة من قماش مربعة توضع على المنكبين، ونوع من السمك. يستخدم للذكور."}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generat