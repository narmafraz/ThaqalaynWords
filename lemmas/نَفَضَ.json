{"lemma":"نَفَضَ","slug":"نَفَضَ","root":"ن.ف.ض","root_slug":"ن-ف-ض","root_link":"/words/roots/ن-ف-ض","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"نَفَضْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"نَفَضْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"نَفَضْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"نَفَضْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"نَفَضْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"نَفَضَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"نَفَضَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"نَفَضا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"نَفَضَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"نَفَضُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"نَفَضْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَنْفُض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَنْفُضِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَنْفُضِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَنْفُضا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْفُضانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَنْفُضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْفُضُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْفُضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْفُض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْفُض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْفُضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْفُضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْفُضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفُضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْفُضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفُضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْفُضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"نَفَضْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَفَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَنْفُض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْفُض","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40284"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%81%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to shake, to dust off","examples":[{"text":"نَفَضْتُ ٱلْوَرَقَ مِنَ ٱلشَّجَرَةِ","english":"I shook off the leaves from the tree."},{"text":"نَفَضَتْ عَنْهُ ٱلْغُبَارَ","english":"She dusted it off."}]},{"pos":"noun","gloss":"verbal noun of نَفَضَ (nafaḍa)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to shake violently, to dust off"}]},"etymology":{"source":"wiktextract","text":"Cognate with Aramaic ܢܦܨ."},"ipa":["/na.fa.dˤa/","/naf.fa.dˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40284","headword_ar":"نَفَضَ","root":"nfD","body":[{"kind":"text","text":", (S, A, Mgh, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":", (S, Mgh, Msb,)"},{"kind":"italic_en","text":"He shook"},{"kind":"text","text":"(S, A, Mgh, Msb, K) a thing, (Mgh, Msb,) or a garment, or piece of cloth, (S, A, K,)"},{"kind":"italic_en","text":"in order that what was upon it, of dust &c., might fall off"},{"kind":"text","text":"(S, * A, * Mgh, K, *) or"},{"kind":"italic_en","text":"to remove from it dust and the like;"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"he took"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with his hand, and shook"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"shook"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"violently, to remove the dust from it:"},{"kind":"text","text":"(TA:) and in like manner a tree,"},{"kind":"italic_en","text":"in order that what was upon it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of face"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of leaves"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"might fall of;"},{"kind":"text","text":"(S, A;) as, for instance,] a tree of the kind called"},{"kind":"arabic","text_bw":"EiDAh","text_ar":"عِضاه"},{"kind":"text","text":","},{"kind":"italic_en","text":"to shake off its leaves."},{"kind":"text","text":"(TA) You say also,"},{"kind":"arabic","text_bw":"nafaDa Eanahu","text_ar":"نَفَضَ عَنَهُ"},{"kind":"arabic","text_bw":"AlgubaAra","text_ar":"الغُبَارَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alt~uraAba","text_ar":"التُّرَابَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He shook off from it the dust"},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"nafaDatu Alwaraqa mino Al$~ajarap","text_ar":"نَفَضَتُ الوَرَقَ مِنْ الشَّجَرَة"},{"kind":"text","text":". inf. n. as above, ["},{"kind":"italic_en","text":"He shook off the leaves from the tree;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"be made the leaves to fall from the tree."},{"kind":"text","text":"(Msb,) And"},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"sprinkling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattering in drops,"},{"kind":"text","text":"(syn."},{"kind":"arabic","text_bw":"ra$~N","text_ar":"رَشٌّ"},{"kind":"text","text":",) water and blood. (A, K, in art."},{"kind":"arabic","text_bw":"r$","text_ar":"رش"},{"kind":"text","text":",) and tears, (K, ibid.) &c. (A,ibid.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"nafaDatohu AlHum~aY","text_ar":"نَفَضَتْهُ الحُمَّى"},{"kind":"text","text":"(S, A, K) (tropical:)"},{"kind":"italic_en","text":"The fever made him to shiver,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tremble"},{"kind":"text","text":"(As, TA ―         -b3-  And"},{"kind":"arabic","text_bw":"nafaDati AlmaroA^apu","text_ar":"نَفَضَتِ المَرْاَةُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"nafDatN kar$ahaA","text_ar":"نَفضَتٌ كَرشَهَا"},{"kind":"text","text":"(S,) or"},{"kind":"arabic","text_bw":"nafaDato waladahaA mino baTonhA","text_ar":"نَفَضَتْ وَلَدَهَا مِنْ بَطْنها"},{"kind":"text","text":", (A,)‡"},{"kind":"italic_en","text":"The woman bore many children; was prolific"},{"kind":"text","text":"(S, K. TA) And"},{"kind":"arabic","text_bw":"nafaDat AlA_ibilu","text_ar":"نَفَضَت الاـِبِلُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The she-camels brought forth,"},{"kind":"text","text":"(S, L, K,)"},{"kind":"italic_en","text":"all of them:"},{"kind":"text","text":"(L;) and ↓"},{"kind":"arabic","text_bw":"AnEDt","text_ar":"انعضت","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (IDrd, S, K.) And"},{"kind":"arabic","text_bw":"bayoDahA nagaDati Ald~aHaAjaPu","text_ar":"بَيْضَها نَغَضَتِ الدَّحَاجَپُ"},{"kind":"text","text":"(tropical:) ["},{"kind":"italic_en","text":"The hen laid her eggs."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all her eggs"},{"kind":"text","text":"A. TA.) ―         -b4-  Hence also,]"},{"kind":"arabic","text_bw":"faAma yanafuDu AlkraY","text_ar":"فَامَ يَنَفُضُ الكرَى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He arose, shaking off drowsiness"},{"kind":"text","text":"]. (A. TA.) And"},{"kind":"arabic","text_bw":"nafaDa AlA^asofaAma Eanohu waA@sotaSaH~","text_ar":"نَفَضَ الاَسْفَامَ عَنْهُ وَا@سْتَصَحّ"},{"kind":"text","text":"; ["},{"kind":"italic_en","text":"He shook off maladies from him, and recovered from his sickness]"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"his health became in a sound state"},{"kind":"text","text":"(A. TA.) And"},{"kind":"arabic","text_bw":"nafaDa mino maraDihi","text_ar":"نَفَضَ مِنْ مَرَضِهِ"},{"kind":"text","text":"(A,) inf. n."},{"kind":"arabic","text_bw":"nufuwDN","text_ar":"نُفُوضٌ"},{"kind":"text","text":", (TA, K,) (tropical:)"},{"kind":"italic_en","text":"He recovered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became free, from his disease"},{"kind":"text","text":"(A, K, * TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"nafaDotu lahu maA fiY jiraAbiY","text_ar":"نَفَضْتُ لَهُ مَا فِى جِرَابِى"},{"kind":"text","text":"†"},{"kind":"italic_en","text":"I showed him what was in my heart."},{"kind":"text","text":"(Er-Rághib, TA, in art."},{"kind":"arabic","text_bw":"$kw","text_ar":"شكو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$kY","text_ar":"شكى"},{"kind":"text","text":"―         -b6-  And"},{"kind":"arabic","text_bw":"nafaDa AlT~ariyqa","text_ar":"نَفَضَ الطَّرِيقَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He cleared the road of robbers, and intercepters of travellers:"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he guarded the road."},{"kind":"text","text":"(A, TA. [The latter signification is shown by an explanation or the act. part. n.] It is said in the trad. of Aboo-Bekr and the cave ["},{"kind":"italic_en","text":"in"},{"kind":"text","text":"which Mohammad was hiding himself],"},{"kind":"arabic","text_bw":"A^anaA A^anafuDu maA Hawolaka","text_ar":"اَنَا اَنَفُضُ مَا حَوْلَكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I will guard what is around thee, and go round about to try if I can see a pursuer."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"nafaDa AlmakaAn","text_ar":"نَفَضَ المَكَان"},{"kind":"text","text":", (S, K,) aor. as above, (TA.) inf. n."},{"kind":"arabic","text_bw":"nafaDN","text_ar":"نَفَضٌ"},{"kind":"text","text":"(S, TA.) and ↓"},{"kind":"arabic","text_bw":"AstnfDhu","text_ar":"استنفضهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tnf~Dhu","text_ar":"تنفّضهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) (tropical:)"},{"kind":"italic_en","text":"He looked trying to see all that was in the place:"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"he looked at all that was in the place so as to know it."},{"kind":"text","text":"(K) And hence"},{"kind":"arabic","text_bw":"nafaDa","text_ar":"نَفَضَ"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"He searched to the at most."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"A_i*aA takal~amut nahaArFA faA@nofuDo waA_i*aA takal~amota layolFA","text_ar":"اـِذَا تَكَلَّمُت نَهَارًا فَا@نْفُضْ وَاـِذَا تَكَلَّمْتَ لَيْلًا"},{"kind":"arabic","text_bw":"faA@xofiDo","text_ar":"فَا@خْفِضْ"},{"kind":"text","text":"(S, K, * TA) (tropical:)"},{"kind":"italic_en","text":"When thou speakest by day, look aside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, to try if thou see any one whom thou dislikest;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"and when thou speakest by night, lower thy voice."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Alqawoma","text_ar":"القَوْمَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstnfD","text_ar":"استنفض","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He looked at the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, endeavouring to obtain a clear"},{"kind":"page_break","n":2831},{"kind":"italic_en","text":"knowledge of them;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"considered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined, them repeatedly, in order to know them."},{"kind":"text","text":"(TA.) The saying of El-'Ojeyr Es-Saloolee,"},{"kind":"quote","text":"Alqawoma Tarofuhu ↓ \n      A_ilaY malikK yasotanofiDu"},{"kind":"text","text":"means (tropical:)  ["},{"kind":"italic_en","text":"To a king whose eye"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"looks at the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, and knows who among them has the right on his side:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looks to see in whom among them is mental perception, sagacity, intelligence, forecast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill in affairs, and which of them is of the contrary description:"},{"kind":"text","text":"(TA:) [or]"},{"kind":"arabic","text_bw":"Tarofuhu Alqawoma","text_ar":"طَرْفُهُ القَوْمَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fulaAnN yasotanofiDu","text_ar":"فُلَانٌ يَسْتَنْفِضُ","orth_type":"arrow"},{"kind":"text","text":"means (tropical:)  ["},{"kind":"italic_en","text":"The eye of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"such a one makes the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, to tremble, by reason of his awfulness."},{"kind":"text","text":"(A, TA.) ―         -b7-  You also say,"},{"kind":"arabic","text_bw":"AlA_ibilu tanofuDu AlA^aroDa","text_ar":"الاـِبِلُ تَنْفُضُ الاَرْضَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The camels traverse the land."},{"kind":"text","text":"(IAar.) ―         -b8-  And"},{"kind":"arabic","text_bw":"nafaDa","text_ar":"نَفَضَ"},{"kind":"arabic","text_bw":"AlquroA=na","text_ar":"القُرْا=نَ"},{"kind":"text","text":", (IAar,) or"},{"kind":"arabic","text_bw":"Als~uwara","text_ar":"السُّوَرَ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":", (IAar,) (tropical:)"},{"kind":"italic_en","text":"He read,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recited,"},{"kind":"text","text":"(IAar, K,)"},{"kind":"italic_en","text":"the Kur-án,"},{"kind":"text","text":"(IAar,) or"},{"kind":"italic_en","text":"the chapters thereof."},{"kind":"text","text":"(K.) ―         -b9-  And"},{"kind":"arabic","text_bw":"nafaDonaA HalaAy^ibanaA","text_ar":"نَفَضْنَا حَلَايِبَنَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AisotanofaDonaAhaA","text_ar":"اِسْتَنْفَضْنَاهَا","orth_type":"arrow"},{"kind":"text","text":"; (tropical:)"},{"kind":"italic_en","text":"We milked our milch beasts to the uttermost, not leaving any milk in their udders:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"AlfaSiylu maA fiY AlD~aroEi","text_ar":"الفَصِيلُ مَا فِى الضَّرْعِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AntfD","text_ar":"انتفض","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"the young camel sucked out all that was in the udder."},{"kind":"text","text":"(A, TA.)       -A2-  [It is also used intransitively in the following exs., as well as in some instances given above. Thus"},{"kind":"arabic","text_bw":"nafaDa Al$~ajaru","text_ar":"نَفَضَ الشَّجَرُ"},{"kind":"text","text":"app. signifies"},{"kind":"italic_en","text":"The trees shook off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dropped, their leaves"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fruit."},{"kind":"text","text":"(See an ex. voce"},{"kind":"arabic","text_bw":"EatiyqN","text_ar":"عَتِيقٌ"},{"kind":"text","text":", last sentence but one.) ―         -b2-  And hence] one says,"},{"kind":"arabic","text_bw":"nafaDa maA fiY Aljul~api","text_ar":"نَفَضَ مَا فِى الجُلَّةِ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"What was in the palm-leaf basket became exhausted;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"nafida","text_ar":"نَفِدَ"},{"kind":"text","text":"; or it may be syn. with"},{"kind":"arabic","text_bw":"AntfD","text_ar":"انتفض"},{"kind":"text","text":"]; (A, K;) or"},{"kind":"arabic","text_bw":"jamiyEu maA fiyhaA","text_ar":"جَمِيعُ مَا فِيهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"all that was in it;"},{"kind":"text","text":"which shows that"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"in the former instance is virtually in the nom. case]. (TA.) See also 4, in two places. ―         -b3-  And"},{"kind":"arabic","text_bw":"nafaDa AlS~ibogu","text_ar":"نَفَضَ الصِّبْغُ"},{"kind":"text","text":", (ISh, Mgh, K,) inf. n."},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":", (ISh, TA,) or"},{"kind":"arabic","text_bw":"nufuwDN","text_ar":"نُفُوضٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The dye"},{"kind":"text","text":"(ISh, K, TA,) of a red or yellow garment, or piece of cloth, (ISh, TA,)"},{"kind":"italic_en","text":"lost somewhat of its colour."},{"kind":"text","text":"(ISh, K, TA.) And hence, (Mgh,)"},{"kind":"arabic","text_bw":"nafaDa Alv~awobu","text_ar":"نَفَضَ الثَّوْبُ"},{"kind":"text","text":", (A, Mgh,) aor."},{"kind":"text","text":", (A,) inf. n."},{"kind":"arabic","text_bw":"nufuwDN","text_ar":"نُفُوضٌ"},{"kind":"text","text":", (A, Mgh,) (tropical:)"},{"kind":"italic_en","text":"The garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, lost its dye:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"lost somewhat of its colour, of redness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"yellowness:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"the colour of its dye faded away so that there remained nothing but the trace."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"nafoDN","text_ar":"نَفْضٌ"},{"kind":"text","text":", accord. to the lawyers, signifies (assumed tropical:)  The"},{"kind":"italic_en","text":"being scattered, strewn, strewed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed:"},{"kind":"text","text":"and accord. to [the Hanafee Imám] Mohammad, the"},{"kind":"italic_en","text":"non-transition of the trace of the dye to another thing:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its exhaling a sweet odour."},{"kind":"text","text":"(Mgh [but it seems that the particle"},{"kind":"arabic","text_bw":"lA","text_ar":"لا"},{"kind":"text","text":", which I have rendered “ non, ” is inserted by mistake in my copy of the Mgh.]) ―         -b4-"},{"kind":"arabic","text_bw":"nafaDa Alz~aroEu","text_ar":"نَفَضَ الزَّرْعُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"nafaDa Alz~aroEu sabalFA","text_ar":"نَفَضَ الزَّرْعُ سَبَلًا"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The seed-produce put forth the last of its ears."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"nafaDa Alkaromu","text_ar":"نَفَضَ الكَرْمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The grape-vine opened its bunches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"racemes."},{"kind":"text","text":"(K.) [See also 8.]"}],"source_refs":["S","A","Mgh","Msb","K","TA","L","IAar","ISh"]}]},"classical_definitions":null}