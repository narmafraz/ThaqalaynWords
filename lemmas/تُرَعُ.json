ext":"or"},{"kind":"italic_en","text":"became, very full,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much filled."},{"kind":"text","text":"(Lth, in TA. [But it is said in the TA, in one place, that Lth ignored the verb in this sense; and in another place, that he said, I have not heard them say,"},{"kind":"arabic","text_bw":"tariEa AlA_inaA='u","text_ar":"تَرِعَ الاـِنَا=ءُ"},{"kind":"text","text":".])       -A2-"},{"kind":"italic_en","text":"He hastened to do evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief;"},{"kind":"text","text":"(Ks, K;) and"},{"kind":"italic_en","text":"to do a thing:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"bahi A_ilaY Al$~ar~i","text_ar":"بَهِ اـِلَى الشَّرِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ttr~E","text_ar":"تترّع","orth_type":"arrow"},{"kind":"text","text":", accord. to the K; but accord. to the S and O and L, ↓"},{"kind":"arabic","text_bw":"ttr~E","text_ar":"تترّع","orth_type":"arrow"},{"kind":"arabic","text_bw":"A_ilayohi biAl$~ar~i","text_ar":"اـِلَيْهِ بِالشَّرِّ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"he hastened to him to do evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief."},{"kind":"text","text":"(S, O, L, K.) ―         -b2-"},{"kind":"italic_en","text":"He rushed headlong into affairs by reason of excessive briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness."},{"kind":"text","text":"(Lth, K.)       -A3-"},{"kind":"arabic","text_bw":"taraEahu","text_ar":"تَرَعَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taraEN","text_ar":"تَرَعٌ"},{"kind":"text","text":", [app. a mistake for"},{"kind":"arabic","text_bw":"taroEN","text_ar":"تَرْعٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He hastened to him, forbidding"},{"kind":"text","text":"["},{"kind":"italic_en","text":"him to do a thiug"},{"kind":"text","text":"]. (L.) ―         -b2-"},{"kind":"arabic","text_bw":"taraEahu Eano","text_ar":"تَرَعَهُ عَنْ"},{"kind":"arabic","text_bw":"wajohihi","text_ar":"وَجْهِهِ"},{"kind":"italic_en","text":"He averted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned him back, from his course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner of acting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proceeding."},{"kind":"text","text":"(Ibn-'Abbád, Sgh, L, K.)"}],"source_refs":["Sgh","K","TA"]},{"entry_id":"n3886","headword_ar":"تَرَعٌ","root":"trE","body":[{"kind":"italic_en","text":"Full;"},{"kind":"text","text":"applied to a watering-trough or tank for beasts &c.; (S, K;) and to a mug: (S:) an inf. n. used as an epithet: (TA:) the regular form is ↓"},{"kind":"arabic","text_bw":"tariEN","text_ar":"تَرِعٌ","orth_type":"arrow"},{"kind":"text","text":", which signifies the same. (K.)"}],"source_refs":["S","TA"]},{"entry_id":"n3887","headword_ar":"تَرِعٌ","root":"trE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"taraEN","text_ar":"تَرَعٌ"},{"kind":"text","text":". ―         -b2-  Also A cloud"},{"kind":"italic_en","text":"containing much rain."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Eu$obN tariEN","text_ar":"عُشْبٌ تَرِعٌ"},{"kind":"italic_en","text":"Fresh, juicy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy, herbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(Sgh in art."},{"kind":"arabic","text_bw":"drE","text_ar":"درع"},{"kind":"text","text":", and L.)       -A2-  A man"},{"kind":"italic_en","text":"quick to do evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief,"},{"kind":"text","text":"(Ks, S,)"},{"kind":"italic_en","text":"and to become angry:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"ready and quick to become angry:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mutotariEN","text_ar":"مُتْتَرِعٌ","orth_type":"arrow"},{"kind":"italic_en","text":"evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischievous, hastening to do what is not fit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, for him."},{"kind":"text","text":"(TA.) ―         -b2-  One"},{"kind":"italic_en","text":"who rushes headlong into affairs by reason of excessive briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness:"},{"kind":"text","text":"(O, L, TA:) thus correctly written; but in the copies of the K, ↓"},{"kind":"arabic","text_bw":"tariyEN","text_ar":"تَرِيعٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"italic_en","text":"Lightwitted; weak and stupid; deficient in intellect;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light and hasty in disposition"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deportment."},{"kind":"text","text":"(TA.) ―         -b4-  And, with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", A woman"},{"kind":"italic_en","text":"who transgresses the proper bounds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limits, and is light"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in conduct"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Ks","S","O","L","TA"]}]}}