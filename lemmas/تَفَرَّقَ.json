nt":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَفَرَّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَفَرَّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَفَرَّق","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَفَرَّق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَفَرَّقا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَفَرَّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَفَرَّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَفَرَّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَفَرَّقُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَفَرَّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَفَرَّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتَفَرَّق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَفَرَّق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَفَرَّقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَفَرَّقْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":30,"cross_references":{"qac":{"found":true,"lemma_key":"تَفَرَّقَ","root":"فرق","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n33660"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%81%D9%8E%D8%B1%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to go apart, to disperse, scatter","tags":["intransitive"]},{"pos":"noun","gloss":"verbal noun of تَفَرَّقَ (tafarraqa) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ta.far.ra.qa/","/ta.far.ruq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33660","headword_ar":"تفرّق","root":"frq","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tafar~aqN","text_ar":"تَفَرَّقٌ"},{"kind":"text","text":"(O, K) and"},{"kind":"arabic","text_bw":"tifir~aAqN","text_ar":"تِفِرَّاقٌ"},{"kind":"text","text":", (K, TA,) with two kesrehs, but accord. to the “ Nawádir ” of Lh"},{"kind":"arabic","text_bw":"taforiyqN","text_ar":"تَفْرِيقٌ"},{"kind":"text","text":", (TA,) [and in the CK"},{"kind":"arabic","text_bw":"taforAq","text_ar":"تَفْراق"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunited:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"widely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into several,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, portions;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissipated: contr. of"},{"kind":"arabic","text_bw":"tajam~aEa","text_ar":"تَجَمَّعَ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"Aftrq","text_ar":"افترق","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K, TA:) and so does ↓"},{"kind":"arabic","text_bw":"Anfrq","text_ar":"انفرق","orth_type":"arrow"},{"kind":"text","text":": (TA:) all are quasi-pass. of"},{"kind":"arabic","text_bw":"far~aqotuhu","text_ar":"فَرَّقْتُهُ"},{"kind":"text","text":": (S, * TA:) [or rather the second and third have the former of the meanings mentioned above: and"},{"kind":"arabic","text_bw":"tfr~q","text_ar":"تفرّق"},{"kind":"text","text":"has the latter of those meanings:] or ↓"},{"kind":"arabic","text_bw":"AifotaraqaA","text_ar":"اِفْتَرَقَا","orth_type":"arrow"},{"kind":"text","text":"is said of two sayings, as quasi-pass. of"},{"kind":"arabic","text_bw":"faraqotu bayonahumaA","text_ar":"فَرَقْتُ بَيْنَهُمَا"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"tafar~aqaA","text_ar":"تَفَرَّقَا"},{"kind":"text","text":", of two men, as quasi-pass. of"},{"kind":"arabic","text_bw":"far~aqotu bayonahamaA","text_ar":"فَرَّقْتُ بَيْنَهَمَا"},{"kind":"text","text":": (Mgh, * Msb, TA:) so says IAar: (Msb:) [but] one says also,"},{"kind":"arabic","text_bw":"Aftrq Alqawomu","text_ar":"افترق القَوْمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The party,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, became separated;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they separated themselves:"},{"kind":"text","text":"] (Msb:) and Esh-Sháfi'ee has used ↓"},{"kind":"arabic","text_bw":"AifotaraqaA","text_ar":"اِفْتَرَقَا","orth_type":"arrow"},{"kind":"text","text":"as relating to two persons buying and selling; (Msb, TA;) and so have Ahmad [Ibn-Hambal] and Aboo-Haneefeh and Málik and others. (TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"Albay~aEaAni biAlxiyaAri maA yatafar~aqaA","text_ar":"البَيَّعَانِ بِالخِيَارِ مَا يَتَفَرَّقَا"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"The buyer and seller have the option"},{"kind":"text","text":"to annul their contract]"},{"kind":"italic_en","text":"as long as they have not become separated"},{"kind":"text","text":"bodily; (Mgh, Msb;) originally,"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"lamo yatafar~aqo A^abodaAnuhumaA","text_ar":"لَمْ يَتَفَرَّقْ اَبْدَانُهُمَا"},{"kind":"text","text":"; for this is the proper meaning. (Msb.)"},{"kind":"arabic","text_bw":"tafar~aqato bihimu AlT~uruqu","text_ar":"تَفَرَّقَتْ بِهِمُ الطُّرُقُ"},{"kind":"text","text":"[properly"},{"kind":"italic_en","text":"The roads became separate with them,"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"every one of them went one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"separate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"way."},{"kind":"text","text":"(TA.) [And one says,"},{"kind":"arabic","text_bw":"tfr~qt AlA^agoSaAnu","text_ar":"تفرّقت الاَغْصَانُ"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"$*b","text_ar":"شذب"},{"kind":"text","text":", &c.,)"},{"kind":"italic_en","text":"The branches were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grew out, apart, one from another; divaricated; diverged; forked; straggled;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread widely and dispersedly."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"tfr~q A^amoruhu","text_ar":"تفرّق اَمْرُهُ"},{"kind":"italic_en","text":"His affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state of affairs, became discomposed, deranged, disorganized, disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, so that he considered what might be its issues,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"results, saying at one time, I will do thus, and at another time, I will do thus:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^ajomaEa","text_ar":"اَجْمَعَ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"$at~a","text_ar":"شَتَّ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"Aftrq","text_ar":"افترق","orth_type":"arrow"},{"kind":"text","text":"signifies the same: see an ex. voce"},{"kind":"arabic","text_bw":"fa$aA","text_ar":"فَشَا"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"f$w","text_ar":"فشو"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"tfr~qt","text_ar":"تفرّقت"},{"kind":"arabic","text_bw":"kalimatuhumo","text_ar":"كَلِمَتُهُمْ"},{"kind":"text","text":"(K voce"},{"kind":"arabic","text_bw":"$aAla","text_ar":"شَالَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"$wl","text_ar":"شول"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"Their expression of opinion was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, discordant:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tfr~qt A=raAw^uhumo","text_ar":"تفرّقت ا=رَاوُهُمْ"},{"kind":"italic_en","text":"Their opinions were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, so."},{"kind":"text","text":"]"}],"source_refs":["O","K","TA","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D9%81%D8%B1%D9%82/","headword_ar":"تفرق","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=45272#9e2f81","body_html":"<h3>تفرق</h3><br><br>تُفْرُوقٌ The قِمَع [or base] of a date; (Ibn-'Abbád, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) a <abbr title=\"dialect, لُغَةٌ\">dial.</abbr> var. of ثُفْرُوقٌ [<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>]: <abbr title=\"plural, جَمْعٌ\">pl.</abbr> تَفَارِيقُ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"},{"lexicon_id":"dictionary_25","lexicon_en":"Murtaḍa al-Zabīdī, Tāj al-ʿArūs fī Jawāhir al-Qamūs (d. 1790 CE)","lexicon_ar":"تاج العروس لمرتضى الزبيدي","permalink":"https://arabiclexicon.hawramani.com/?p=45272#0e2cfe","body_html":"<span class=\"title1\">تفرق</span><br><span>التفروق كعصفور أهمله الْجَمَاعَة وَقَالَ ابْن عباد هُوَ قمع التمرة لُغَة فِي الثفروق بِالْمُثَلثَةِ وَالْجمع بِالتَّفْرِيقِ. قلت: وَأما قَول الْعَامَّة التفاريق لمن ثمن من الْمَتَاع فغلط صَوَابه التفاريج.</span>"}]}}