{"lemma":"مَهَّدَ","slug":"مَهَّدَ","root":"م.ه.د","root_slug":"م-ه-د","root_link":"/words/roots/م-ه-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"مَهَّدْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"مَهَّدْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"مَهَّدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"مَهَّدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"مَهَّدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"مَهَّدَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"مَهَّدَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"مَهَّدا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"مَهَّدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"مَهَّدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"مَهَّدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُمَهِّد","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُمَهِّدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُمَهِّدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُمَهِّدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُمَهِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُمَهِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُمَهِّدُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُمَهِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُمَهِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُمَهِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُمَهِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُمَهِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُمَهِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمَهِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُمَهِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمَهِّدُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُمَهِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُمَهِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمَهِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"مَهَّدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"مَهَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"مَهَّد","root":"مهد","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n38976","n38977","n38981","n38982"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%87%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to spread, to expand"},{"pos":"verb","gloss":"to expand, to spread out"},{"pos":"verb","gloss":"to pave"},{"pos":"verb","gloss":"to pave the way, to adjust, to prepare","examples":[{"text":"وتعمل وحدات الهندسة في الجيش على تمشيط الأحياء السكنية في المنطقة ورفع مخلفات الإرهابيين من أسلحة وذخائر وعبوات ناسفة والكشف عن الأنفاق والتحصينات والأوكار التي اتخذها الارهابيون منطلقا لاعتداءاتهم ضد المدنيين ، تمهيدا لدخول ورشات الجهات المعنية في المحافظة لإعادة البنى التحتية والخدمات الاساسية إلى منطقة درعا البلد."}]},{"pos":"noun","gloss":"cradle"},{"pos":"noun","gloss":"sowbread (Cyclamen spp., especially Cyclamen persicum the leaves of which are filled and eaten as rolls, the roots are used for saponin)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38976","headword_ar":"مَهَدَ","root":"mhd","body":[{"kind":"text","text":", (S, L, K,) aor."},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"mahodN","text_ar":"مَهْدٌ"},{"kind":"text","text":"[q. v. infra]; (S, L;) and ↓"},{"kind":"arabic","text_bw":"mh~d","text_ar":"مهّد","orth_type":"arrow"},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"tamohiydN","text_ar":"تَمْهِيدٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He made plain, even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth,"},{"kind":"text","text":"this is the original signification:"},{"kind":"italic_en","text":"he made a place plain, even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth,"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"makaAnFA","text_ar":"مَكَانًا"},{"kind":"text","text":"being understood,]"},{"kind":"arabic","text_bw":"linafosihi","text_ar":"لِنَفْسِهِ"},{"kind":"italic_en","text":"for himself:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he spread"},{"kind":"text","text":"a bed, (S, L, K,)"},{"kind":"italic_en","text":"and made"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"plain, even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth."},{"kind":"text","text":"(S, L.) ―         -b2-"},{"kind":"arabic","text_bw":"mahada lahu","text_ar":"مَهَدَ لَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He did well,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kindly, in his affair in his absence;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"fahada","text_ar":"فَهَدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faA^ada","text_ar":"فَاَدَ"},{"kind":"text","text":". (L, art."},{"kind":"arabic","text_bw":"fhd","text_ar":"فهد"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"mahada","text_ar":"مَهَدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"mahodN","text_ar":"مَهْدٌ"},{"kind":"text","text":", L,)"},{"kind":"italic_en","text":"He gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to gain sustenance, and worked,"},{"kind":"text","text":"(L, K,)"},{"kind":"arabic","text_bw":"linafosihi","text_ar":"لِنَفْسِهِ"},{"kind":"italic_en","text":"for himself."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"mahada linafosihi xayorFA","text_ar":"مَهَدَ لِنَفْسِهِ خَيْرًا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Amthdhu","text_ar":"امتهدهُ","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He prepared for himself good, good things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"lahu manozilapF saniy~apF","text_ar":"لَهُ مَنْزِلَةً سَنِيَّةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mh~d","text_ar":"مهّد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He prepared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established, for him a high station"},{"kind":"text","text":"]. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"fulaAnN EinodiY yadFA","text_ar":"فُلَانٌ عِنْدِى يَدًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A@motahada","text_ar":"مَا ا@مْتَهَدَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one has not prepared for himself, with me, a benefit, for me to owe it him"},{"kind":"text","text":"]: you say this when one has not conferred upon you a favour or kindness. (AZ, L.) And"},{"kind":"arabic","text_bw":"fulaAnN EinodiY","text_ar":"فُلَانٌ عِنْدِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A@motahada","text_ar":"مَا ا@مْتَهَدَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"mahoda *aAka","text_ar":"مَهْدَ ذَاكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one has not prepared for himself, with me, that thing, that I should owe it him"},{"kind":"text","text":"]; is said on one's asking a kindness without having previously conferred a benefit; (AZ, JK, L;) and with reference to one who acts in an evil manner, when asking a kindness, or when a kindness is asked for him. (AZ, L.)"}],"source_refs":["S","L","K"]},{"entry_id":"n38977","headword_ar":"مهّد","root":"mhd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tamohiydN","text_ar":"تَمْهِيدٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He adjusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged,"},{"kind":"text","text":"an affair, (S, A, L, Msb, K,)"},{"kind":"italic_en","text":"and made"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"plain,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"and easy."},{"kind":"text","text":"(Msb.) See 1. ―         -b2-"},{"kind":"arabic","text_bw":"mh~d","text_ar":"مهّد"},{"kind":"arabic","text_bw":"nafosahu lifiEoli AlA^amori","text_ar":"نَفْسَهُ لِفِعْلِ الاَمْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He disposed and subjected his mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"himself, to do the thing."},{"kind":"text","text":"(S, * K, * Msb, art."},{"kind":"arabic","text_bw":"wTn","text_ar":"وطن"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"mh~d","text_ar":"مهّد"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tamohiydN","text_ar":"تَمْهِيدٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He accepted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admitted,"},{"kind":"text","text":"an excuse. (S, L, Msb, K.) You say,"},{"kind":"arabic","text_bw":"mah~adotu lahu AlEu*ora","text_ar":"مَهَّدْتُ لَهُ العُذْرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I accepted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admitted, his excuse."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","A","L","Msb","K"]},{"entry_id":"n38981","headword_ar":"مَهْدٌ","root":"mhd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A child's cradle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bed;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a place prepared for a child, and made plain, even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smooth,"},{"kind":"text","text":"(S, * L, K,)"},{"kind":"italic_en","text":"that he may sleep in it:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"a bed; a thing spread to lie, recline,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sit, upon;"},{"kind":"text","text":"(A, Msb;) as also ↓"},{"kind":"arabic","text_bw":"mihaAdN","text_ar":"مِهَادٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, L, Msb, K;) so called because of its plainness, evenness, or smoothness: (L:) Az says, that the latter word is more comprehensive than the former: (L:) it is applied to the"},{"kind":"italic_en","text":"ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth;"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"a plain, an even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a smooth expanse;"},{"kind":"text","text":"see a verse of Lebeed cited voce"},{"kind":"arabic","text_bw":"xawaAliqu","text_ar":"خَوَالِقُ"},{"kind":"text","text":":] (Az, L, K:) and so is"},{"kind":"arabic","text_bw":"mahodN","text_ar":"مَهْدٌ"},{"kind":"text","text":": (K:) some say, that"},{"kind":"arabic","text_bw":"mahodN","text_ar":"مَهْدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mihaAdN","text_ar":"مِهَادٌ","orth_type":"arrow"},{"kind":"text","text":"are [originally] two inf. ns., of the same meaning: or that the former is an inf. n., and the latter a simple subst.: or that the former is sing., and the latter pl.: (MF:) the pl. of the former [in common use] is"},{"kind":"arabic","text_bw":"muhuwdN","text_ar":"مُهُودٌ"},{"kind":"text","text":", (L, Msb, K,) and"},{"kind":"arabic","text_bw":"mihaAdN","text_ar":"مِهَادٌ"},{"kind":"text","text":"; and of the latter, [pl. of pauc.,]"},{"kind":"arabic","text_bw":"A^amohidapN","text_ar":"اَمْهِدَةٌ"},{"kind":"text","text":"(L, K) and [of mult.,]"},{"kind":"arabic","text_bw":"muhudN","text_ar":"مُهُدٌ"},{"kind":"text","text":". (L, Msb, K.) ―         -b2-  ↓"},{"kind":"arabic","text_bw":"A^alamo najoEali A@loA^aroDa mihaAdFA","text_ar":"اَلَمْ نَجْعَلِ ا@لْاَرْضَ مِهَادًا","orth_type":"arrow"},{"kind":"text","text":"[Kur, lxxviii. 6,]"},{"kind":"italic_en","text":"Have we not made the earth an expanse"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bisaAT","text_ar":"بِسَاط"},{"kind":"text","text":")"},{"kind":"italic_en","text":"adapted to be travelled over."},{"kind":"text","text":"(K, TA.) ―         -b3-  ↓"},{"kind":"arabic","text_bw":"labiy^osa AlmihaAdu","text_ar":"لَبِيْسَ المِهَادُ","orth_type":"arrow"},{"kind":"text","text":"[Kur. ii. 202,] (tropical:)"},{"kind":"italic_en","text":"Evil is that which he hath prepared for himself in his final place."},{"kind":"page_break","n":2740},{"kind":"text","text":"(K.) Such is said to be the meaning. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"sahodN mahodN","text_ar":"سَهْدٌ مَهْدٌ"},{"kind":"italic_en","text":"Good; goodly:"},{"kind":"text","text":"the latter word is an imitative sequent. (L.)"}],"source_refs":["L","Az","K","MF","Msb"]},{"entry_id":"n38982","headword_ar":"مُهْدٌ","root":"mhd","body":[{"kind":"italic_en","text":"Elevated ground"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land:"},{"kind":"text","text":"(IAar, L, K:) or"},{"kind":"italic_en","text":"depressed and smooth and even ground"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"muhodapN","text_ar":"مُهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":": (En-Nadr, K:) pl."},{"kind":"arabic","text_bw":"mihadapN","text_ar":"مِهَدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amohaAdN","text_ar":"اَمْهَادٌ"},{"kind":"text","text":": (K:) but the former of these pls. is doubtful. (TA.)"}],"source_refs":["IAar","L","K"]}]},"classical_definitions":null}