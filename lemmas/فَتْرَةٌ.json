{"lemma":"فَتْرَةٌ","slug":"فَتْرَةٌ","root":"ف.ت.ر","root_slug":"ف-ت-ر","root_link":"/words/roots/ف-ت-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"فَتْرَة","root":"فتر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n32915"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AA%D9%92%D8%B1%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"interval, a while, a period of time","examples":[{"text":"بَعْد فَتْرَة","english":"after a while"}]},{"pos":"noun","gloss":"interregnum"},{"pos":"noun","gloss":"weariness, relaxedness, languidness, weakness"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32915","headword_ar":"فَتْرَةٌ","root":"ftr","body":[{"kind":"italic_en","text":"Languor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remissness;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"weakness, feebleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faintness;"},{"kind":"text","text":"(S, O;)"},{"kind":"italic_en","text":"an affection like a weakness, feebleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faintness:"},{"kind":"text","text":"(T:) and ↓"},{"kind":"arabic","text_bw":"fatarN","text_ar":"فَتَرٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"weakness, feebleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faintness."},{"kind":"text","text":"(M, K.) One says,"},{"kind":"arabic","text_bw":"A^ajidu fiY nafosiY fatorapF","text_ar":"اَجِدُ فِى نَفْسِى فَتْرَةً"},{"kind":"italic_en","text":"I experience in myself an affection like a weakness,"},{"kind":"text","text":"&c. (T.) ―         -b2-"},{"kind":"italic_en","text":"An interval of time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"between things:"},{"kind":"text","text":"(S and K in art."},{"kind":"arabic","text_bw":"wtr","text_ar":"وتر"},{"kind":"text","text":"; &c.:) or]"},{"kind":"italic_en","text":"between any two prophets,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"between two of God's apostles,"},{"kind":"text","text":"(S, O, TA,)"},{"kind":"italic_en","text":"during which there is a cessation of the apostolic function:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a cessation of the mission of apostles, and a state of effacement of the signs of their religion:"},{"kind":"text","text":"so in the Kur v. 22. (Msb.)       -A2-  See also what next follows."}],"source_refs":["T","M","K","S","O","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%AA%D8%B1%D8%A9/","headword_ar":"فترة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23460#7a6fd5","body_html":"<span>الفترة: خمود نار البداية المحرقة بتردد آثار الطبيعة المخدرة للقوة الطلبية.</span>"}]}}