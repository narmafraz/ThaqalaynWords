{"lemma":"أَزْهَرِ","slug":"أَزْهَرِ","root":"ز.ه.ر","root_slug":"ز-ه-ر","root_link":"/words/roots/ز-ه-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n18303","","n18312"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B2%D9%92%D9%87%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18303","headword_ar":"ازهر","root":"zhr","body":[{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a fire, (S, K,) and a lamp, (A,)"},{"kind":"italic_en","text":"to give light, to shine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to shine brightly."},{"kind":"text","text":"(S, A, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A^azoharota zanodiY","text_ar":"اَزْهَرْتَ زَنْدِى"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"Thou hast made my piece of stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wood, for producing fire to emit shining fire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant fire;"},{"kind":"text","text":"meaning, (tropical:)"},{"kind":"italic_en","text":"thou hast made me to accomplish my want:"},{"kind":"text","text":"see 1]. (A.) ―         -b3-"},{"kind":"arabic","text_bw":"Azhr","text_ar":"ازهر"},{"kind":"text","text":"(AHn, T, S, M, A, Msb, [and so in the CK and in my MS. copy of the K, but SM says that in all the copies of the K it is written ↓"},{"kind":"arabic","text_bw":"Aizohar~a","text_ar":"اِزْهَرَّ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"AiHomar~a","text_ar":"اِحْمَرَّ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant, or herbage, S, K, &c., and a tree, TA)"},{"kind":"italic_en","text":"flowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blossomed;"},{"kind":"text","text":"(AHn, T, S, Msb, &c.;) as also ↓"},{"kind":"arabic","text_bw":"zahara","text_ar":"زَهَرَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"AzhAr~","text_ar":"ازهارّ","orth_type":"arrow"},{"kind":"text","text":". (AHn, K.) ―         -b4-"},{"kind":"arabic","text_bw":"A^azoharati","text_ar":"اَزْهَرَتِ"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"zaharat","text_ar":"زَهَرَت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The land abounded with flowers."},{"kind":"text","text":"(Zj, TA.)"}],"source_refs":["S","K","A"]},{"entry_id":"n18312","headword_ar":"اَزْهَرُ","root":"zhr","body":[{"kind":"italic_en","text":"Shining; giving light; bright."},{"kind":"text","text":"(Sudot;, K.) Hence, (TA,)"},{"kind":"arabic","text_bw":"AlA^azoharu","text_ar":"الاَزْهَرُ"},{"kind":"italic_en","text":"The moon."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"AlA^azoharaAni","text_ar":"الاَزْهَرَانِ"},{"kind":"italic_en","text":"The sun and the moon."},{"kind":"text","text":"(ISk, S, A, K.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"White;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"and beautiful:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"of a bright white colour:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"of any shining colour:"},{"kind":"text","text":"(AHn, R:) as also ↓"},{"kind":"arabic","text_bw":"zaAhirN","text_ar":"زَاهِرٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-  (tropical:)  A man"},{"kind":"italic_en","text":"white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, in face:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"having a bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shining, face:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"having a white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, and bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shining, face:"},{"kind":"text","text":"(S:) a man"},{"kind":"italic_en","text":"having a white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, complexion, characteristic of good birth:"},{"kind":"text","text":"(Sh, S: *) or"},{"kind":"italic_en","text":"of a bright white"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair complexion, with a shining face:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed with redness:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"zahoraA='u","text_ar":"زَهْرَا=ءُ"},{"kind":"text","text":"a woman"},{"kind":"italic_en","text":"white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, in face:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"having a bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shining, face:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"having a white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, and bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shining, face:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"of a bright white"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair complexion intermixed with redness."},{"kind":"text","text":"(TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"Bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shining,"},{"kind":"text","text":"applied to an animal and to a plant. (AA.) ―         -b5-  Applied also to water [app. as meaning"},{"kind":"italic_en","text":"Bright and clear"},{"kind":"text","text":"] (TA.) ―         -b6-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HuwaAr","text_ar":"حُوَار"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"Huw~aAraY","text_ar":"حُوَّارَى"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"White,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whitened,"},{"kind":"text","text":"applied to flour]. (TA.) ―         -b7-  (assumed tropical:)"},{"kind":"italic_en","text":"A wild bull:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zahoraA='u","text_ar":"زَهْرَا=ءُ"},{"kind":"italic_en","text":"a wild cow."},{"kind":"text","text":"(S, K.) ―         -b8-  (assumed tropical:)"},{"kind":"italic_en","text":"A white lion."},{"kind":"text","text":"(K.) ―         -b9-"},{"kind":"italic_en","text":"A white ewer"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jug, in which wine is made."},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"garabN","text_ar":"غَرَبٌ"},{"kind":"text","text":".) ―         -b10-  (assumed tropical:)"},{"kind":"italic_en","text":"Milk just drawn."},{"kind":"text","text":"(AA, K.) ―         -b11-"},{"kind":"arabic","text_bw":"Alz~ahoraA='u","text_ar":"الزَّهْرَا=ءُ"},{"kind":"text","text":"is applied by Ru-beh to"},{"kind":"italic_en","text":"The white cloud"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saHaAbap","text_ar":"سَحَابَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"lightning in the evening."},{"kind":"text","text":"(O, K.) ―         -b12-"},{"kind":"arabic","text_bw":"dur~apN zahoraA='u","text_ar":"دُرَّةٌ زَهْرَا=ءُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A white and clear pearl."},{"kind":"text","text":"(TA.) ―         -b13-"},{"kind":"arabic","text_bw":"Alz~uhoru","text_ar":"الزُّهْرُ"},{"kind":"italic_en","text":"Three nights of the beginning of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lunar"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"month:"},{"kind":"text","text":"(TA:) or so ↓"},{"kind":"arabic","text_bw":"Alz~uharu","text_ar":"الزُّهَرُ","orth_type":"arrow"},{"kind":"text","text":". (Har p. 299.) ―         -b14-"},{"kind":"arabic","text_bw":"Alyawomu AlA^azoharu","text_ar":"اليَوْمُ الاَزْهَرُ"},{"kind":"italic_en","text":"Friday."},{"kind":"text","text":"(O, K, * TA.) ―         -b15-"},{"kind":"arabic","text_bw":"Alz~ahoraAwaAni","text_ar":"الزَّهْرَاوَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The two chapters of the Kur-án entitled"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Albaqarapu","text_ar":"البَقَرَةُ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"A=lu EimoraAna","text_ar":"ا=لُ عِمْرَانَ"},{"kind":"text","text":". (O, K.)       -A2-  A camel"},{"kind":"italic_en","text":"parting his legs wide, cropping the trees."},{"kind":"text","text":"(K.)"}],"source_refs":["TA","K","AHn","R","Msb","S"]}]},"classical_definitions":null}