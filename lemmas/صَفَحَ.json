},{"role":"present_2mp","form":"تَصْفَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْفَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْفَح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْفَح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْفَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْفَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْفَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْفَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْفَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْفَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْفَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَصْفَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْفَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"صَفَحْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَفَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":true,"lemma_key":"صَفَحَ","root":"صفح","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n24421","n24427","n24428","n24429"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%81%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make flat"},{"pos":"verb","gloss":"to overlook, to pardon, to remit"},{"pos":"verb","gloss":"to flatten, to roll out"},{"pos":"verb","gloss":"to outfit, to rig"},{"pos":"noun","gloss":"verbal noun of صَفَحَ (ṣafaḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"pardon, remission"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24421","headword_ar":"صفّح","root":"SfH","body":[{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taSofiyHN","text_ar":"تَصْفِيحٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broad;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"SafaHa","text_ar":"صَفَحَ","orth_type":"arrow"},{"kind":"text","text":"; (K;) [and ↓"},{"kind":"arabic","text_bw":"ASfH","text_ar":"اصفح","orth_type":"arrow"},{"kind":"text","text":";] see"},{"kind":"arabic","text_bw":"muSofaHN","text_ar":"مُصْفَحٌ"},{"kind":"text","text":". One says of a sword,"},{"kind":"arabic","text_bw":"Suf~iHa","text_ar":"صُفِّحَ"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"It was made broad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wide, and lengthened out,"},{"kind":"text","text":"in the forging. (IAar, S, TA.)       -A2-"},{"kind":"arabic","text_bw":"taSofiyHN","text_ar":"تَصْفِيحٌ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"taSofiyqN","text_ar":"تَصْفِيقٌ"},{"kind":"text","text":", (S, Msb, K,) meaning The"},{"kind":"italic_en","text":"clapping with the hands."},{"kind":"text","text":"(S, IAth, TA.) One says,"},{"kind":"arabic","text_bw":"Saf~aH biyadayohi","text_ar":"صَفَّح بِيَدَيْهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Saf~aqa","text_ar":"صَفَّقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He clapped with his hands"},{"kind":"text","text":"]; (A, TA;)"},{"kind":"italic_en","text":"he struck one of his hands upon the other:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"he struck with the outer side of the right hand upon the inner side of the left hand."},{"kind":"text","text":"(O in art."},{"kind":"arabic","text_bw":"Sfq","text_ar":"صفق"},{"kind":"text","text":".) [Golius gives"},{"kind":"arabic","text_bw":"SafaHa","text_ar":"صَفَحَ"},{"kind":"text","text":"in this sense, erroneously, as from the S; and Freytag, this form as well as"},{"kind":"arabic","text_bw":"Sf~H","text_ar":"صفّح"},{"kind":"text","text":".] And it is said in a trad.,"},{"kind":"arabic","text_bw":"Alt~asobiyHu lilr~ijaAli waAlt~aSofiyHu liln~isaA='i","text_ar":"التَّسْبِيحُ لِلرِّجَالِ وَالتَّصْفِيحُ لِلنِّسَا=ءِ"},{"kind":"text","text":", or, as some relate it,"},{"kind":"arabic","text_bw":"Alt~aSofiyqu","text_ar":"التَّصْفِيقُ"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"AltSfyH","text_ar":"التصفيح"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The saying"},{"kind":"arabic","text_bw":"suboHaAna A@ll~`hi","text_ar":"سُبْحَانَ ا@للّٰهِ"},{"kind":"italic_en","text":"is for men, and the clapping with the hands is for women;"},{"kind":"text","text":"] (S, Mgh, * TA;) i. e., when the Imám is inadvertent, the person whom he leads should, if a man, rouse him by saying"},{"kind":"arabic","text_bw":"sbHAn All~`h","text_ar":"سبحان اللّٰه"},{"kind":"text","text":"; and if a woman, should clap with her hands, instead of speaking. (IAth, TA.)"}],"source_refs":["K","S","Msb","Mgh"]},{"entry_id":"n24427","headword_ar":"صَفْحٌ","root":"SfH","body":[{"kind":"text","text":", (S, A, Mgh, Msb, K,) of a thing, (S, A, Mgh,) or of anything; (Msb;) and ↓"},{"kind":"arabic","text_bw":"SafoHapN","text_ar":"صَفْحَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, Mgh, Msb,) of a thing, (Mgh,) or of anything; (S, A, Msb;) The"},{"kind":"italic_en","text":"side;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lateral,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outward, part"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion;"},{"kind":"text","text":"syn. of the former"},{"kind":"arabic","text_bw":"naAHiyapN","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":"; (S, A;) or of the same, (K,) or of the latter, (S, A,) or of each, (Mgh, Msb,)"},{"kind":"arabic","text_bw":"jaAnibN","text_ar":"جَانِبٌ"},{"kind":"text","text":": (S, A, Mgh, Msb, K:) and both signify also the"},{"kind":"italic_en","text":"face,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surface,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"front,"},{"kind":"text","text":"of a thing: (Mgh:) pl. [of the former"},{"kind":"arabic","text_bw":"SifaAHN","text_ar":"صِفَاحٌ"},{"kind":"text","text":", as below, and] of the latter"},{"kind":"arabic","text_bw":"SafaHaAtN","text_ar":"صَفَحَاتٌ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"SafoHaA Al$~aYo'i","text_ar":"صَفْحَا الشَّىْءِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The two sides of the thing;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jaAnibaAhu","text_ar":"جَانِبَاهُ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"SafoHu AlA_inosaAni","text_ar":"صَفْحُ الاـِنْسَانِ"},{"kind":"italic_en","text":"The side of the human being;"},{"kind":"text","text":"(S, O, K; *) as also ↓"},{"kind":"arabic","text_bw":"SafoHatuhu","text_ar":"صَفْحَتُهُ","orth_type":"arrow"},{"kind":"text","text":". (O.) And hence,"},{"kind":"arabic","text_bw":"baEiyrihi","text_ar":"بَعِيرِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sal~aY A_ilaY SafoHapi","text_ar":"صَلَّى اـِلَى صَفْحَةِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He prayed towards the side of his camel"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"SafoHN","text_ar":"صَفْحٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SufoHN","text_ar":"صُفْحٌ","orth_type":"arrow"},{"kind":"text","text":"signify The"},{"kind":"arabic","text_bw":"EuroD","text_ar":"عُرْض"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"side"},{"kind":"text","text":"] (S, O, and K accord. to the TA, but in the CK and in my MS. copy of the K"},{"kind":"arabic","text_bw":"EaroD","text_ar":"عَرْض"},{"kind":"text","text":", [which in this instance I think a mistake,]) of the face: (S, O, K:) and so of a sword; (K, TA; [in the former of which, in art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"EuroD","text_ar":"عُرْض"},{"kind":"text","text":"of a sword is said to be its"},{"kind":"arabic","text_bw":"SafoH","text_ar":"صَفْح"},{"kind":"text","text":";]) or the"},{"kind":"arabic","text_bw":"EaroD","text_ar":"عَرْض"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"breadth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"width,"},{"kind":"text","text":"] (S, O, Msb, and so accord. to the CK and my MS. copy of the K,) of a sword; (S, O, Msb, K;) i. e."},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"Tuwl","text_ar":"طُول"},{"kind":"text","text":"; (Msb;) [but it may be well rendered its"},{"kind":"italic_en","text":"side,"},{"kind":"text","text":"or its"},{"kind":"italic_en","text":"flat,"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"SafoHapN","text_ar":"صَفْحَةٌ","orth_type":"arrow"},{"kind":"text","text":", for SM says that]"},{"kind":"arabic","text_bw":"SafoHataA Als~ayofi","text_ar":"صَفْحَتَا السَّيْفِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the two faces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surfaces, of the sword:"},{"kind":"text","text":"(TA:) one says,"},{"kind":"arabic","text_bw":"naZara A_ilayohi biSafoHi wajohihi","text_ar":"نَظَرَ اـِلَيْهِ بِصَفْحِ وَجْهِهِ"},{"kind":"text","text":"(S, A) and ↓"},{"kind":"arabic","text_bw":"biSufoHi","text_ar":"بِصُفْحِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"wjhh","text_ar":"وجهه"},{"kind":"text","text":"(S) ["},{"kind":"italic_en","text":"He looked towards him with the side of his face"},{"kind":"text","text":"turned towards him] and ↓"},{"kind":"arabic","text_bw":"biSafoHatihi","text_ar":"بِصَفْحَتِهِ","orth_type":"arrow"},{"kind":"text","text":"[which means the same]: (A:) but accord. to AO, one says,"},{"kind":"arabic","text_bw":"Als~ayofi","text_ar":"السَّيْفِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Darabahu biSufoHi","text_ar":"ضَرَبَهُ بِصُفْحِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He struck him with the side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flat, of the sword"},{"kind":"text","text":"], and the vulgar say"},{"kind":"arabic","text_bw":"biSafoHi Alsyf","text_ar":"بِصَفْحِ السيف"},{"kind":"text","text":", with fet-h: (S:) the pl. [of"},{"kind":"arabic","text_bw":"SafoHN","text_ar":"صَفْحٌ"},{"kind":"text","text":"] is"},{"kind":"arabic","text_bw":"SifaAHN","text_ar":"صِفَاحٌ"},{"kind":"text","text":"(K, TA) and [that of ↓"},{"kind":"arabic","text_bw":"SufoHN","text_ar":"صُفْحٌ","orth_type":"arrow"},{"kind":"text","text":"is]"},{"kind":"arabic","text_bw":"A^aSofaAHN","text_ar":"اَصْفَاحٌ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"Alr~ajuli","text_ar":"الرَّجُلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SafoHapN","text_ar":"صَفْحَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The side"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EuroD","text_ar":"عُرْض"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the breast of the man."},{"kind":"text","text":"(L.) And one says,"},{"kind":"arabic","text_bw":"janobihi","text_ar":"جَنْبِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Darabahu EalaY SafoHapi","text_ar":"ضَرَبَهُ عَلَى صَفْحَةِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He struck him on the surface,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flat part, of his side;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"arabic","text_bw":"SafoHi jnbh","text_ar":"صَفْحِ جنبه"},{"kind":"text","text":"; but the former is the more common]. (A.) And"},{"kind":"arabic","text_bw":"Als~ayofi","text_ar":"السَّيْفِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jalaA SafoHataY","text_ar":"جَلَا صَفْحَتَى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He polished the two sides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surfaces, of the sword"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Alwaraqapi","text_ar":"الوَرَقَةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kataba fiY SafoHataYi","text_ar":"كَتَبَ فِى صَفْحَتَىِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He wrote upon the two sides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faces, of the piece of paper"},{"kind":"text","text":"]. (A.)"},{"kind":"arabic","text_bw":"AlkitaAbi","text_ar":"الكِتَابِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SafaHaAtu","text_ar":"صَفَحَاتُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The pages,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faces of the leaves, of the book."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"SafoHu Alkaf~i","text_ar":"صَفْحُ الكَفِّ"},{"kind":"italic_en","text":"The face"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"palm"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the hand."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"SafoHaA Alkatifi","text_ar":"صَفْحَا الكَتِفِ"},{"kind":"italic_en","text":"The two parts of the scapula that slope down from the"},{"kind":"arabic","text_bw":"Eayor","text_ar":"عَيْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"spine thereof"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"SifaAHN","text_ar":"صِفَاحٌ"},{"kind":"text","text":". (L.) And"},{"kind":"arabic","text_bw":"SafoHu Aljabali","text_ar":"صَفْحُ الجَبَلِ"},{"kind":"italic_en","text":"The part of the mountain where the side thereof rests upon the ground;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"its"},{"kind":"arabic","text_bw":"safoH","text_ar":"سَفْح"},{"kind":"text","text":"[q. v.]: (JM:) pl."},{"kind":"arabic","text_bw":"SifaAHN","text_ar":"صِفَاحٌ"},{"kind":"text","text":". (S.)"}],"source_refs":["S","A","Mgh","Msb","K","O","TA","JM"]},{"entry_id":"n24428","headword_ar":"صُفْحٌ","root":"SfH","body":[{"kind":"text","text":": see the next preceding paragraph, in four places."}],"source_refs":[]},{"entry_id":"n24429","headword_ar":"صَفَحٌ","root":"SfH","body":[{"kind":"italic_en","text":"Excessive width"},{"kind":"text","text":"in the forehead. (IAar, K.)"}],"source_refs":[]}]},"classical_definitions":null}