D9%92%D9%81%D9%8E%D8%B1%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33370","headword_ar":"انفرج","root":"frj","body":[{"kind":"italic_en","text":"It opened;"},{"kind":"text","text":"[and particularly"},{"kind":"italic_en","text":"by diduction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"so as to form an intervening space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breach; it gaped; it became unclosed;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"tafar~aja","text_ar":"تَفَرَّجَ","orth_type":"arrow"},{"kind":"text","text":"; (see exs. in art."},{"kind":"arabic","text_bw":"fyD","text_ar":"فيض"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A^afaASa","text_ar":"اَفَاصَ"},{"kind":"text","text":", in three places;) and"},{"kind":"italic_en","text":"it became unknit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loosened,"},{"kind":"text","text":"said of a bone, and of a limb or member, and of a joint; (see"},{"kind":"arabic","text_bw":"fariyjN","text_ar":"فَرِيجٌ"},{"kind":"text","text":", in two places; and see also"},{"kind":"arabic","text_bw":"fakikota","text_ar":"فَكِكْتَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ainofak~a","text_ar":"اِنْفَكَّ"},{"kind":"text","text":"in three places, and"},{"kind":"arabic","text_bw":"fakakN","text_ar":"فَكَكٌ"},{"kind":"text","text":";)] syn."},{"kind":"arabic","text_bw":"AnftH","text_ar":"انفتح"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"ftH","text_ar":"فتح"},{"kind":"text","text":"; &c. [See also"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ"},{"kind":"text","text":".]) ―         -b2-"},{"kind":"arabic","text_bw":"Ainofarajato siyataAhaA","text_ar":"اِنْفَرَجَتْ سِيَتَاهَا"},{"kind":"text","text":"is said of a bow such as is termed ↓"},{"kind":"arabic","text_bw":"faruwjN","text_ar":"فَرُوجٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K, TA,) as also"},{"kind":"arabic","text_bw":"Ainofaj~ato","text_ar":"اِنْفَجَّتْ"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"Anfj~t hiYa","text_ar":"انفجّت هِىَ"},{"kind":"text","text":", which shows that the meaning is,"},{"kind":"italic_en","text":"Its two curved extremities were such as to have an open space between them and between the intermediate portion and the string"},{"kind":"text","text":"]. (TA.) ―         -b3-  See also 4, second sentence: ―         -b4-  and the same, last sentence; and"},{"kind":"arabic","text_bw":"fariyjN","text_ar":"فَرِيجٌ"},{"kind":"text","text":", in two places; and"},{"kind":"arabic","text_bw":"faArijN","text_ar":"فَارِجٌ"},{"kind":"text","text":". ―         -b5-  ["},{"kind":"arabic","text_bw":"Ainofarajotu Eani AlkalaAmi","text_ar":"اِنْفَرَجْتُ عَنِ الكَلَامِ"},{"kind":"text","text":"occurs in the L, in art."},{"kind":"arabic","text_bw":"fS","text_ar":"فص"},{"kind":"text","text":", app. meaning"},{"kind":"italic_en","text":"I broke off from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intermitted, speaking."},{"kind":"text","text":"] ―         -b6-"},{"kind":"arabic","text_bw":"Anfrj","text_ar":"انفرج"},{"kind":"text","text":"said of grief, or sorrow, or anxiety, [and the like,] signifies"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, removed, cleared away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispelled;"},{"kind":"text","text":"(A, O, TA;) as also ↓"},{"kind":"arabic","text_bw":"tfr~j","text_ar":"تفرّج","orth_type":"arrow"},{"kind":"text","text":"; (S, * O, * TA;) and so ↓"},{"kind":"arabic","text_bw":"faraja","text_ar":"فَرَجَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"furuwjN","text_ar":"فُرُوجٌ"},{"kind":"text","text":". (TA.) Aboo-Dhu-eyb says,"},{"kind":"quote","text":"↓ \n      walil$~ar~i baEoda AlqaAriEaAti furuwju"},{"kind":"text","text":"meaning ["},{"kind":"italic_en","text":"And to evil, after striking and agitating calamities, there is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall be,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a removing, clearing away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispelling:"},{"kind":"text","text":"(S, O, TA:) the last word being the inf. n. of the last of the verbs above mentioned; or it may be a pl. of ↓"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"SuxuwrN","text_ar":"صُخُورٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"SaxorapN","text_ar":"صَخْرَةٌ"},{"kind":"text","text":". (TA.) ―         -b7-  Also"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, happy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful."},{"kind":"text","text":"(KL. [See also 5.])"}],"source_refs":["O","K","TA","S"]}]},"classical_definitions":null}