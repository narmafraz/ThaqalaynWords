{"lemma":"سَبْتُ","slug":"سَبْتُ","root":"NTWS","root_slug":"NTWS","root_link":"/words/roots/NTWS","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"سَبْت","root":"سبت","pos":"N","occurrence_count":6},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n18643","","n18645","n18646","n18647","n18648"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%A8%D9%92%D8%AA%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18643","headword_ar":"سَبَتَ","root":"sbt","body":[{"kind":"text","text":", (S, M, Msb,) aor."},{"kind":"text","text":"(S, Msb) only, (S,) or"},{"kind":"text","text":", (so written in a copy of the M,) [both of which are said by MF to be indicated, or implied, in the K, but this is not clearly the case,] inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", (M, K, * TA,)"},{"kind":"italic_en","text":"He rested:"},{"kind":"text","text":"(S, M, Msb, K: *) and"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstained, from works:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quiet, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless:"},{"kind":"text","text":"(M, TA:) and ↓"},{"kind":"arabic","text_bw":"Asbt","text_ar":"اسبت","orth_type":"arrow"},{"kind":"text","text":"signifies [the same, or]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, motionless:"},{"kind":"text","text":"(S, TA:) Az says that"},{"kind":"arabic","text_bw":"sabata","text_ar":"سَبَتَ"},{"kind":"text","text":"in the first of these senses is not known in the language of the Arabs: (TA:) [but J says that] the primary signification of"},{"kind":"arabic","text_bw":"subaAtN","text_ar":"سُبَاتٌ"},{"kind":"text","text":"is “ rest: ” and hence the former of these verbs signifies"},{"kind":"italic_en","text":"he slept."},{"kind":"text","text":"(S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"sabatati Alyahuwdu","text_ar":"سَبَتَتِ اليَهُودُ"},{"kind":"text","text":", (S, * A, K,) aor."},{"kind":"text","text":"(S, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"The Jews kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed, the ordinances of their"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sabbath"},{"kind":"text","text":"]: (S, K: *) or"},{"kind":"arabic","text_bw":"sabatuwA","text_ar":"سَبَتُوا"},{"kind":"text","text":", aor."},{"kind":"text","text":"(M, Msb) and"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"AsbtwA","text_ar":"اسبتوا","orth_type":"arrow"},{"kind":"text","text":"; (S, M, Msb;)"},{"kind":"italic_en","text":"they entered upon the"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sabbath"},{"kind":"text","text":"]: (S, M:) or"},{"kind":"italic_en","text":"they"},{"kind":"text","text":"(the Jews)"},{"kind":"italic_en","text":"ceased from seeking the means of subsistence, and the labouring to acquire gain."},{"kind":"text","text":"(Msb.) It is said in the Kur [vii. 163],"},{"kind":"arabic","text_bw":"wayawoma laA yasobituwna","text_ar":"وَيَوْمَ لَا يَسْبِتُونَ"},{"kind":"italic_en","text":"And on the day when they were not keeping the ordinances of their"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"text","text":": (S:) where some read ↓"},{"kind":"arabic","text_bw":"lA yusobituwna","text_ar":"لا يُسْبِتُونَ","orth_type":"arrow"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"A^asobata","text_ar":"اَسْبَتَ"},{"kind":"text","text":"; and some, ↓"},{"kind":"arabic","text_bw":"lA yusobatuwna","text_ar":"لا يُسْبَتُونَ","orth_type":"arrow"},{"kind":"text","text":", in the pass. form, meaning"},{"kind":"italic_en","text":"when they were not made to enter upon"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the observance of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"text","text":". (Bd.)       -A2-"},{"kind":"arabic","text_bw":"sabatato","text_ar":"سَبَتَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"went the pace termed"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"meaning as expl. below. (M.) ―         -b2-  And"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"outstripping in running."},{"kind":"text","text":"(M.)       -A3-  And as inf. n. of"},{"kind":"arabic","text_bw":"sabata","text_ar":"سَبَتَ"},{"kind":"text","text":"said of a man, (TK,)"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"being confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, unable to see one's right course,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therefore"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"silent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowering the eyes, looking towards the ground."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"sabata Al$~aYo'a","text_ar":"سَبَتَ الشَّىْءَ"},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", (M, A, Mgh, K,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaTaEahu","text_ar":"قَطَعَهُ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"He cut the thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut it off; severed it;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"intercepted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interrupted, it; put a stop,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an end, to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it to cease;"},{"kind":"text","text":"relating to ideal as well as real objects; for instance, to work, or action, as is shown in the TA]; (M, A, Mgh, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"sb~thu","text_ar":"سبّتهُ","orth_type":"arrow"},{"kind":"text","text":": expl. by Lh as relating particularly to necks. (M, TA.) [Hence,]"},{"kind":"arabic","text_bw":"sabata EilaAwatahu","text_ar":"سَبَتَ عِلَاوَتَهُ"},{"kind":"text","text":", (S, M,) inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He smote his neck"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to decapitate him"},{"kind":"text","text":"]: (S, M, K:) and"},{"kind":"arabic","text_bw":"subitato EilaAwatuhu","text_ar":"سُبِتَتْ عِلَاوَتُهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"His head was cut off."},{"kind":"text","text":"(A. [This is there said to be tropical; but why, I do not see.]) ―         -b2-  And"},{"kind":"arabic","text_bw":"sabatati All~uqomapu HaloqiY","text_ar":"سَبَتَتِ اللُّقْمَةُ حَلْقِى"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sab~atatohu","text_ar":"سَبَّتَتْهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaTaEatohu","text_ar":"قَطَعَتْهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The morsel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gobbet, obstructed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped, my fauces"},{"kind":"text","text":"]: but the verb without teshdeed is the more usual. (M, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"sabata raA^osahu","text_ar":"سَبَتَ رَاْسَهُ"},{"kind":"text","text":", (M, A, Mgh, Msb,) aor."},{"kind":"text","text":", (M, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":", (S, M, A, Msb, K,)"},{"kind":"italic_en","text":"He shaved his head:"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K:) and in like manner,"},{"kind":"arabic","text_bw":"sabata","text_ar":"سَبَتَ"},{"kind":"arabic","text_bw":"$aEarahu","text_ar":"شَعَرَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he shaved off his hair;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"sb~thu","text_ar":"سبّتهُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Asbthu","text_ar":"اسبتهُ","orth_type":"arrow"},{"kind":"text","text":". (AA, TA in art."},{"kind":"arabic","text_bw":"sbd","text_ar":"سبد"},{"kind":"text","text":".) ―         -b4-  And"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"letting down"},{"kind":"text","text":"the hair, or"},{"kind":"italic_en","text":"letting"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"fall"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hang down, after"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"from,"},{"kind":"arabic","text_bw":"Ean","text_ar":"عَن"},{"kind":"text","text":",) ["},{"kind":"italic_en","text":"the twisting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plaiting, termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AlEaqoS","text_ar":"العَقْص"},{"kind":"text","text":". (S, K.)       -A5-"},{"kind":"arabic","text_bw":"subita","text_ar":"سُبِتَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with"},{"kind":"text","text":"[the"},{"kind":"italic_en","text":"kind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"semblance, of sleep termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"subaAt","text_ar":"سُبَات"},{"kind":"text","text":"[q. v.]: (IAar, M, TA:) and (TA)"},{"kind":"italic_en","text":"he swooned:"},{"kind":"text","text":"(Msb, TA:) and"},{"kind":"italic_en","text":"he became prostrated like him who is sleeping, generally closing his eyes;"},{"kind":"text","text":"said of a sick man: (TA:) and also"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(Msb, TA.)"}],"source_refs":["S","M","Msb","TA","K","TK","A","Mgh","IAar"]},{"entry_id":"n18645","headword_ar":"سَبْتٌ","root":"sbt","body":[{"kind":"italic_en","text":"Rest:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"quiet, stillness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freedom from motion."},{"kind":"text","text":"(TA.) [See 1, of which it is an inf. n.] See also"},{"kind":"arabic","text_bw":"subaAtN","text_ar":"سُبَاتٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"Als~abotu","text_ar":"السَّبْتُ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"yawomu Als~aboti","text_ar":"يَوْمُ السَّبْتِ"},{"kind":"text","text":", (S, Msb,) ["},{"kind":"italic_en","text":"The sabbath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Saturday;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one of the days of the week;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"the seventh of those days:"},{"kind":"text","text":"(M:) so called because the creation commenced on the first day of the week and continued to [the end of] Friday, and on the"},{"kind":"arabic","text_bw":"sbt","text_ar":"سبت"},{"kind":"text","text":"there was no creation, the work having ceased thereon: or, as some say, because the Jews ceased thereon from work, and the management of affairs: (M, TA:) or because the days [of the week] end thereon: (S, TA:) Az says that he errs who asserts it to have been so called because God commanded the Children of Israel to rest thereon, and that God created the heavens and the earth in six days, whereof the last was Friday, then rested, and the work ceased, and therefore He named the seventh day"},{"kind":"arabic","text_bw":"ywm","text_ar":"يوم"},{"kind":"arabic","text_bw":"Alsbt","text_ar":"السبت"},{"kind":"text","text":": this, he says, is an error, because [he affirms that]"},{"kind":"arabic","text_bw":"sabata","text_ar":"سَبَتَ"},{"kind":"text","text":"as meaning “ he rested ” is not known in the language of the Arabs, but signifies"},{"kind":"arabic","text_bw":"qaTaEa","text_ar":"قَطَعَ"},{"kind":"text","text":"; and rest cannot be attributed to God, because He knows not fatigue, and rest is only after fatigue and work: (TA:) the pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A^asobutN","text_ar":"اَسْبُتٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"subuwtN","text_ar":"سُبُوتٌ"},{"kind":"text","text":": (S, M, Msb, K:)"},{"kind":"page_break","n":1288},{"kind":"text","text":"it has no dim. (Sb, S in art."},{"kind":"arabic","text_bw":"Ams","text_ar":"امس"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ"},{"kind":"text","text":"also means"},{"kind":"italic_en","text":"A week; from the"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"italic_en","text":"to the"},{"kind":"arabic","text_bw":"sabot","text_ar":"سَبْت"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"from the sabbath to the sabbath"},{"kind":"text","text":"]: so in the saying, in a trad.,"},{"kind":"arabic","text_bw":"famaA raA^ayonaA Al$~amosa sabotFA","text_ar":"فَمَا رَاَيْنَا الشَّمْسَ سَبْتًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we saw not the sun for a week"},{"kind":"text","text":"]: as when one says “ twenty autumns ” meaning “ twenty years: ” or it means in this instance"},{"kind":"italic_en","text":"a space of time, whether short or long."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"burohapN","text_ar":"بُرْهَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"A space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a long space"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period,"},{"kind":"text","text":"] (M, K, TA)"},{"kind":"arabic","text_bw":"mina Ald~ahori","text_ar":"مِنَ الدَّهْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of time"},{"kind":"text","text":"]: (TA:) so in the saying,"},{"kind":"arabic","text_bw":"A^aqamotu sabotFA","text_ar":"اَقَمْتُ سَبْتًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I remained, staid, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, a space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a long space, of time"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"sabotapF","text_ar":"سَبْتَةً","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sanobatFA","text_ar":"سَنْبَتًا","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sanobatatFA","text_ar":"سَنْبَتَتًا","orth_type":"arrow"},{"kind":"text","text":". (M, K.) ―         -b5-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dahorN","text_ar":"دَهْرٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Time;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a long time;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period, of time, whether long or short;"},{"kind":"text","text":"&c.]; as also ↓"},{"kind":"arabic","text_bw":"subaAtN","text_ar":"سُبَاتٌ","orth_type":"arrow"},{"kind":"text","text":". (S, M, K.) And [hence] ↓"},{"kind":"arabic","text_bw":"AibonaA subaAtK","text_ar":"اِبْنَا سُبَاتٍ","orth_type":"arrow"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The night and the day:"},{"kind":"text","text":"(S, M, K:) Ibn Ahmar says,"},{"kind":"quote","text":"wakun~aA wahumo kaA@bonaYo subaAtK tafar~aqaA\n                      \n                     \n                        siwFY vum~a kaAnaA munojidFA watahaAmiyaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we were, with them, like the night and the day that parted asunder alike, then became one going towards Nejd and one going towards Tihámeh"},{"kind":"text","text":"]: (S, K:) such, they say, is the meaning: (S:) or, as IB says, on the authority of Aboo-Jaafar Mohammad Ibn-Habeeb,"},{"kind":"arabic","text_bw":"AbnA sbAt","text_ar":"ابنا سبات"},{"kind":"text","text":"were two men, one of whom saw the other in a dream, and then one of them awoke in Nejd, and the other in Tihámeh: or they were two brothers, one of whom went to the east to see where the sun rose, and the other to the west to see where it set. (L, TA.)       -A2-  Also"},{"kind":"italic_en","text":"A certain pace"},{"kind":"text","text":"(S, M, K)"},{"kind":"italic_en","text":"of camels:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"a quick pace:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EanaqN","text_ar":"عَنَقٌ"},{"kind":"text","text":"[q. v.]: (AA, S:) or"},{"kind":"italic_en","text":"a pace exceeding that termed"},{"kind":"arabic","text_bw":"AlEanaqu","text_ar":"العَنَقُ"},{"kind":"text","text":". (M.)       -A3-  A"},{"kind":"italic_en","text":"swift,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"excellent,"},{"kind":"text","text":"horse; (K, TA;)"},{"kind":"italic_en","text":"that runs much."},{"kind":"text","text":"(TA.) ―         -b2-  A boy, or young man,"},{"kind":"italic_en","text":"of bad disposition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illnatured, and bold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"daring."},{"kind":"text","text":"(K) ―         -b3-  A man"},{"kind":"italic_en","text":"cunning,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"possessing intelligence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sagacity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence mixed with craft and forecast; and excellent in judgment;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very cunning"},{"kind":"text","text":"&c.; (K, TA;)"},{"kind":"italic_en","text":"silent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowering his eyes, looking towards the ground;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"subaAtN","text_ar":"سُبَاتٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (K, TA.) ―         -b4-  A man"},{"kind":"italic_en","text":"who sleeps much;"},{"kind":"text","text":"(K;) i. e."},{"kind":"arabic","text_bw":"kaviyru Als~ubaAti","text_ar":"كَثِيرُ السُّبَاتِ"},{"kind":"text","text":". (TA.) See also"},{"kind":"arabic","text_bw":"masobuwtN","text_ar":"مَسْبُوتٌ"},{"kind":"text","text":".       -A4-  See also what next follows."}],"source_refs":["S","K","M","Msb","TA","AA"]},{"entry_id":"n18646","headword_ar":"سُبْتٌ","root":"sbt","body":[{"kind":"italic_en","text":"A certain plant, resembling the"},{"kind":"arabic","text_bw":"xiTomiY~","text_ar":"خِطْمِىّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"marsh-mallow"},{"kind":"text","text":"]; (Kr, M, K;) as also ↓"},{"kind":"arabic","text_bw":"sabotN","text_ar":"سَبْتٌ","orth_type":"arrow"},{"kind":"text","text":", (K [there expressly said to be with fet-h],) or ↓"},{"kind":"arabic","text_bw":"sibotN","text_ar":"سِبْتٌ","orth_type":"arrow"},{"kind":"text","text":": (M [so written in a copy of that work]:) said to be"},{"kind":"italic_en","text":"a certain plant used for tanning."},{"kind":"text","text":"(MF.) See the next paragraph."}],"source_refs":[]},{"entry_id":"n18647","headword_ar":"سِبْتٌ","root":"sbt","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"hides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skins, of oxen;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"whether tanned or not tanned:"},{"kind":"text","text":"so some say: (M:) or (so accord. to the M, in the K and TA “ and, ” but the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is omitted in the CK,)"},{"kind":"italic_en","text":"any tanned hide;"},{"kind":"text","text":"(As, AA, M, K;) said to be so called [because the tanning removes the hair,] from"},{"kind":"arabic","text_bw":"Als~abotu","text_ar":"السَّبْتُ"},{"kind":"text","text":", “ the act of shaving: ” (AA, TA:) or"},{"kind":"italic_en","text":"such. as is tanned with"},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":"[q. v.]: (M, K:) or only"},{"kind":"italic_en","text":"ox-hides tanned:"},{"kind":"text","text":"so says AHn on the authority of As and AZ: (TA:) or"},{"kind":"italic_en","text":"ox-hides tanned with"},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":", (S, Mgh,)"},{"kind":"italic_en","text":"whereof are made"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the sandals called"},{"kind":"text","text":"] ↓"},{"kind":"arabic","text_bw":"niEaAlN siboty~apN","text_ar":"نِعَالٌ سِبْتيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (S) these are hence thus called: (Mgh:) they are"},{"kind":"italic_en","text":"sandals having no hair upon them:"},{"kind":"text","text":"(M, Msb:) or"},{"kind":"italic_en","text":"sandals tanned with"},{"kind":"arabic","text_bw":"qraZ","text_ar":"قرَظ"},{"kind":"text","text":": (AA, TA:) accord. to Az, they are thus called because their hair has been shaven off ("},{"kind":"arabic","text_bw":"subita","text_ar":"سُبِتَ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"Huliqa","text_ar":"حُلِقَ"},{"kind":"text","text":",) and removed by a wellknown process in tanning, (Mgh, * TA,) so that they are soft; and they are of the sandals of people that lead a life of ease and softness: (Mgh:) IAar says that they are thus called because of their having become soft by the tanning: accord. to this, they should be called ↓"},{"kind":"arabic","text_bw":"sabotiy~ap","text_ar":"سَبْتِيَّة","orth_type":"arrow"},{"kind":"text","text":"; and so accord. to a saying of EdDáwoodee, that they are called in relation to"},{"kind":"arabic","text_bw":"suwqu Als~aboti","text_ar":"سُوقُ السَّبْتِ"},{"kind":"text","text":"[“ the Market of the Sabbath ”]: it is also said that they are called in relation to the ↓"},{"kind":"arabic","text_bw":"subot","text_ar":"سُبْت","orth_type":"arrow"},{"kind":"text","text":", with damm, which is a plant used for tanning therewith; so that they should be called ↓"},{"kind":"arabic","text_bw":"subotiy~ap","text_ar":"سُبْتِيَّة","orth_type":"arrow"},{"kind":"text","text":", unless the appellation be an instance of a rel. n. deviating from its source of derivation [or unless this plant be also termed"},{"kind":"arabic","text_bw":"sibotN","text_ar":"سِبْتٌ"},{"kind":"text","text":", as it is accord. to a copy of the M]: (TA:) see"},{"kind":"arabic","text_bw":"subotN","text_ar":"سُبْتٌ"},{"kind":"text","text":". It is related of the Prophet, that he saw a man walking among the graves wearing his sandals, and said,"},{"kind":"arabic","text_bw":"yaA SaAHiba Als~ibotayni AixolaEo sibotayoka","text_ar":"يَا صَاحِبَ السِّبْتَينِ اِخْلَعْ سِبْتَيْكَ"},{"kind":"text","text":"[meaning (tropical:)"},{"kind":"italic_en","text":"O wearer of the pair of sandals of"},{"kind":"arabic","text_bw":"sibot","text_ar":"سِبْت"},{"kind":"text","text":","},{"kind":"italic_en","text":"pull off thy pair of sandals of"},{"kind":"arabic","text_bw":"sibot","text_ar":"سِبْت"},{"kind":"text","text":"]: (S, * TA:) and accord. to the A, they are thus termed tropically: it is like the saying “ Such a one wears wool, and cotton, and silk; ” meaning “ garments made thereof; ” as is said in the Nh: but, as some relate it, what he said was, ↓"},{"kind":"arabic","text_bw":"yaA SaAHiba Als~ibotiy~ayoni","text_ar":"يَا صَاحِبَ السِّبْتِيَّيْنِ","orth_type":"arrow"},{"kind":"text","text":", the last of these words being a rel. n.; and thus it is found in the handwriting of Az, in his book. (TA.)"}],"source_refs":["M","AA","TA","K","S","Mgh","Msb"]},{"entry_id":"n18648","headword_ar":"سِبِتٌّ","root":"sbt","body":[{"kind":"text","text":", (M, L, K,) like"},{"kind":"arabic","text_bw":"filiz~N","text_ar":"فِلِزٌّ"},{"kind":"text","text":", (TA,) [in a copy of the M erroneously written"},{"kind":"arabic","text_bw":"sibot","text_ar":"سِبْت"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"A certain plant;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"anethum graveolens,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dill, of the common garden-species;"},{"kind":"text","text":"] an arabicized word, from [the Pers.]"},{"kind":"arabic","text_bw":"$ibit~","text_ar":"شِبِتّ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"$ibito","text_ar":"شِبِتْ"},{"kind":"text","text":"]: (AHn, M, L:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$ibit~N","text_ar":"شِبِتٌّ"},{"kind":"text","text":"; both words arabicized from"},{"kind":"arabic","text_bw":"$iwi*o","text_ar":"شِوِذْ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"$iwido","text_ar":"شِوِدْ"},{"kind":"text","text":"]: (K:) asserted by some to be"},{"kind":"italic_en","text":"the same as"},{"kind":"arabic","text_bw":"san~uwtN","text_ar":"سَنُّوتٌ"},{"kind":"text","text":"[q. v.]: (M, L:) Az says that"},{"kind":"arabic","text_bw":"$ibit~N","text_ar":"شِبِتٌّ"},{"kind":"text","text":", the name of"},{"kind":"italic_en","text":"a well-known herb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leguminous plant,"},{"kind":"text","text":"is an arabicized word; that he had heard the people of El-Bahreyn call it"},{"kind":"arabic","text_bw":"sibit~N","text_ar":"سِبِتٌّ"},{"kind":"text","text":", with the unpointed"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":", and with"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"; that it is originally, in Pers.,"},{"kind":"arabic","text_bw":"$iwi*o","text_ar":"شِوِذْ"},{"kind":"text","text":"; and that it has another dial. var., namely,"},{"kind":"arabic","text_bw":"sbT","text_ar":"سبط"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"sibiT~N","text_ar":"سِبِطٌّ"},{"kind":"text","text":"]. (El-Jawáleekee, TA.)"}],"source_refs":["M","L","K","TA","AHn"]}]}}