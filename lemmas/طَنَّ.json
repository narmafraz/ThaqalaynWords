per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْنِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْنِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْنِنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"طَنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27138"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hum, to buzz, to drone"},{"pos":"verb","gloss":"to ring, to clang"},{"pos":"verb","gloss":"to move with buzzing sound, to whiz"},{"pos":"noun","gloss":"tonne, metric ton"},{"pos":"noun","gloss":"the human body","tags":["collective","obsolete"]},{"pos":"noun","gloss":"load carried on the camel's back between the loads on both sides","tags":["collective","obsolete"]},{"pos":"noun","gloss":"bundle of reeds used as a bearing","tags":["collective","obsolete"]}]},"etymology":{"source":"wiktextract","text":"Onomatopoeic.\n\nFrom English ton and French tonne (“ton”), from Latin tunna.\n\nThe meaning of a bundle of reed is considered from Aramaic טוּנַּס (ṭunnas, “reed”), which is attested once in Jewish Literary Aramaic and agrees with Ancient Greek δόναξ (dónax, “reed”), otherwise compare אֲטוּנָא (ʔăṭūnā), אֲטְוָנָא (ʔăṭwānā, “twisted strap”), which occurs in Jewish Babylonian Aramaic sometimes without the aleph prothesis.\nThe meaning of a load, as which also the human body is easily understood, is from the common Aramaic טוּנָא (ṭūna, ṭunnā), an assimilated form of טְוּעֲנָא (ṭūʕănā), טְעוּנָא (ṭəʕūnā, “load, burden”), which or a similar form is also the source of طَاعُون (ṭāʕūn, “plague”)."},"ipa":["/tˤann/","/tˤunn/"]}