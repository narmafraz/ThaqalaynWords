{"lemma":"طَنَّ","slug":"طَنَّ","root":"ط.ن.ن","root_slug":"ط-ن-ن","root_link":"/words/roots/ط-ن-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"طَنَنْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"طَنَنْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"طَنَنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"طَنَنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"طَنَنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"طَنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"طَنَّت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"طَنّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"طَنَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"طَنُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"طَنَنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَطِنِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَطِنِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَطْنِنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَطْنِنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَطِنّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطْنِنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَطِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطْنِنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطْنِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطْنِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْنِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْنِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْنِنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْنِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طَنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27138"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hum, to buzz, to drone"},{"pos":"verb","gloss":"to ring, to clang"},{"pos":"verb","gloss":"to move with buzzing sound, to whiz"},{"pos":"noun","gloss":"tonne, metric ton"},{"pos":"noun","gloss":"the human body","tags":["collective","obsolete"]},{"pos":"noun","gloss":"load carried on the camel's back between the loads on both sides","tags":["collective","obsolete"]},{"pos":"noun","gloss":"bundle of reeds used as a bearing","tags":["collective","obsolete"]}]},"etymology":{"source":"wiktextract","text":"Onomatopoeic.\n\nFrom English ton and French tonne (“ton”), from Latin tunna.\n\nThe meaning of a bundle of reed is considered from Aramaic טוּנַּס (ṭunnas, “reed”), which is attested once in Jewish Literary Aramaic and agrees with Ancient Greek δόναξ (dónax, “reed”), otherwise compare אֲטוּנָא (ʔăṭūnā), אֲטְוָנָא (ʔăṭwānā, “twisted strap”), which occurs in Jewish Babylonian Aramaic sometimes without the aleph prothesis.\nThe meaning of a load, as which also the human body is easily understood, is from the common Aramaic טוּנָא (ṭūna, ṭunnā), an assimilated form of טְוּעֲנָא (ṭūʕănā), טְעוּנָא (ṭəʕūnā, “load, burden”), which or a similar form is also the source of طَاعُون (ṭāʕūn, “plague”)."},"ipa":["/tˤann/","/tˤunn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27138","headword_ar":"طَنَّ","root":"Tn","body":[{"kind":"text","text":", (MA, Msb, K, TA,) aor."},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"TaniynN","text_ar":"طَنِينٌ"},{"kind":"text","text":"[q. v. infrà], (MA, Msb,)"},{"kind":"italic_en","text":"It made a sound"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a continued"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reiterated kind, and"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharp"},{"kind":"text","text":"]; (MA, Msb, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Tn~n","text_ar":"طنّن","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"TanoTana","text_ar":"طَنْطَنَ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Tan~a Al*~ubaAbu","text_ar":"طَنَّ الذُّبَابُ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"TanoTana","text_ar":"طَنْطَنَ","orth_type":"arrow"},{"kind":"text","text":", as also"},{"kind":"arabic","text_bw":"dan~a","text_ar":"دَنَّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"danodana","text_ar":"دَنْدَنَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"The flies made a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"humming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buzzing,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound."},{"kind":"text","text":"(MA, Msb.) And in like manner"},{"kind":"arabic","text_bw":"Tan~a","text_ar":"طَنَّ"},{"kind":"text","text":"is said of other things than flies. (Msb.) [Thus,]"},{"kind":"arabic","text_bw":"Tan~a AlT~asotu","text_ar":"طَنَّ الطَّسْتُ"},{"kind":"text","text":", (MA,) or"},{"kind":"arabic","text_bw":"Tan~ati AlT~asotu","text_ar":"طَنَّتِ الطَّسْتُ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"The basin of brass"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other metal made a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ringing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tinkling,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound."},{"kind":"text","text":"(S, MA.) And"},{"kind":"arabic","text_bw":"AlbaT~apu taTin~u","text_ar":"البَطَّةُ تَطِنُّ"},{"kind":"italic_en","text":"The duck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goose, utters a sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sounds"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"quacks"},{"kind":"text","text":"]. (S.) ―         -b2-  [Hence,] one says also,"},{"kind":"arabic","text_bw":"Tan~a *ikoruhu fiY AlbilaAdi","text_ar":"طَنَّ ذِكْرُهُ فِى البِلَادِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His fame resounded through the countries"},{"kind":"text","text":"]. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Tan~at","text_ar":"طَنَّت"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The camels thirsted"},{"kind":"text","text":"[app. because thirst is often attended with a ringing, or tingling, in the ears]. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Tan~ato saAquhu","text_ar":"طَنَّتْ سَاقُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His shank was quickly cut off:"},{"kind":"text","text":"the verb being imitative of the sound of the shank in its falling. (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Tan~a","text_ar":"طَنَّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S, K:) so in the “ Musannaf ” [of Aboo-'Amr Esh-Sheybánee]. (S.) ―         -b6-  And (assumed tropical:)"},{"kind":"italic_en","text":"He licked his finger."},{"kind":"text","text":"(TA.)"}],"source_refs":["MA","Msb","K","TA","S"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D9%86/","headword_ar":"طن","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=10780#534ad7","body_html":"طن<br>عن الانجليزية القديمة إحدى صيغ الاسم طاني بمعنى عامل جلود ودباغ. يستخدم للذكور."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10780#90cdf0","body_html":"<span class=\"title1\">طن</span><br><span>الطَنُ: ضَرْب من التمْرِ. والطنُ: حُزْمَة من قَصَبٍ. والشَّخْصُ. والجِسْمُ. والعِلاوَةُ التي تُوْضَعُ بَيْنَ الجُوَالِقَيْنِ.</span><br><span>وهويَقُومُ بطُن نَفْسِه: أي بكِفَايَتِها. وطَن الرجُلُ: إذا ماتَ. وطَنَتْ يَدُه: أي طَرتْ. وأطَنها اللهُ. والطَّنِيْنُ: صَوْتُ الأذُنِ والطسْتِ ونَحْوِه. وطَن الذُّبَابُ: صاح. والطنْطَنَةُ: كَثْرَةُ الصَّوْتِ والكَلامِ. والإطْنَانُ: سُرْعَةُ القَطْعِ، ضَرَبْتُه فَاطْنَنْتُ ذِرَاعَه. والوطن: أمُّ رَأسِ بَعِيرٍ أو قِطْعَةُ لَحْمٍ تُعَلقُ لصَيْدِ النمِرِ. وطَنتْ من العُوْدِ طِنة: أي شَطْبَةٌ.</span>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10780#ac442e","body_html":"<span class=\"title1\">باب الطاء والنون ط ن مستعمل فقط</span><br><br><span>طن: الطُّنُّ: ضربٌ من التَّمْر. والطُّنُّ: الحُزْمةُ من القَصَب والحطب.</span><span> </span><a></a><span>والطَّنينُ: صَوْتُ الأُذُن والطَّسْت، ونحوه. وطَنَّ الذُّباب، إذا طار فَسَمِعْتَ لِطَيَرانِهِ صوتاً، قال :</span><br><br><span>كذُبابٍ طار في الجَوِّ فَطَنّ</span><br><br><span>والطَّنْطَنةُ في الصّوت: الكلام الكثير. والإطنانُ: سُرْعة القطع، [يُقال] : ضربتُهُ بالسّيفِ فأَطْنَنْت ذراعَهُ، وقد طنت ذراعُه يحكي بذلك صوتَها حين قُطِعَتْ.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10780#769530","body_html":"<h3>طن</h3><span class=\"sense\">1</span> طَنَّ, (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> طَنِينٌ [<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr> infrà], (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) It made a sound [of a continued or a reiterated kind, and either low or sharp]; (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) as also ↓ طنّن, and ↓ طَنْطَنَ. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) Yousay, طَنَّ الذُّبَابُ [and ↓ طَنْطَنَ, as also دَنَّ and دَنْدَنَ,] The flies made a [humming, or buzzing,] sound. (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) And in like manner طَنَّ is said of other things than flies. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) [Thus,] طَنَّ الطَّسْتُ, (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>,) or طَنَّتِ الطَّسْتُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) The basin of brass or other metal made a [ringing, or tinkling,] sound. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>.) And البَطَّةُ تَطِنُّ The duck, or goose, utters a sound or sounds [i. e. quacks]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b2:</span> [Hence,] one says also, طَنَّ ذِكْرُهُ فِى البِلَادِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [His fame resounded through the countries]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> And طَنَّت الإِبِلُ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The camels thirsted [<abbr title=\"apparently\">app.</abbr> because thirst is often attended with a ringing, or tingling, in the ears]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b4:</span> And طَنَّتْ سَاقُهُ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) His shank was quickly cut off: the verb being imitative of the sound of the shank in its falling. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b5:</span> And طَنَّ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He (a man, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) died: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) so in the “ Musannaf ” [of Aboo-'Amr Esh-Sheybánee]. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b6:</span> And (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He licked his finger. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 2 طَنَّّ see the foregoing paragraph, first sentence.<span class=\"sense\">4</span> اطنّ الطَّسْتَ He caused the basin of brass or other metal to make a [ringing, or tinkling,] sound. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> And اطنّ سَاقَهُ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He cut off his shank (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) quickly; (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) or اطنّ يَدَهُ he made his arm, or hand, to fall off; (so in a copy of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>;) by a stroke [of a sword or the like]; the verb being meant to imitate the sound of the cutting, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or the sound of the limb in its falling; and in like manner one says أَتَنَّهَا [and أَطَرَّهَا] and أَتَرَّهَا, meaning the same. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 8 هُوَ يُطَّنُّ بِكَذَا, meaning He is suspected of such a thing, is originally يُظْتَنُّ; as also يُظَّنُّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <abbr title=\"al-Rawḍ al-Unuf of al-Suhaylī\">R</abbr>. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1 طَنْطَنَ: see 1, first and second sentences.<br><br>طَنٌّ [<abbr title=\"according\">accord.</abbr> to the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr> طِنٌّ, being there said to be with kesr, but not so in other copies of the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, nor in the <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,] Fresh, ripe, red dates, very sweet, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and having much flowing juice; as also ↓ طُنٌّ, with damm. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">A2:</span> Also, [if not a mistranscription for طُنٌّ,] A half-load, such as is borne on one side of a beast, of cotton that has been separated, or loosened, and cleared of its seeds: from El-Hejeree. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) طُنٌّ A bundle of reeds or canes, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or (so <abbr title=\"according\">accord.</abbr> to the <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, but in the <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> “ and ”) of firewood: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) thought by <abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr> to be not genuine Arabic: and pronounced by the vulgar طِنّ, with kesr: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"noun of unity, وَاحِدَةٌ or وَاحِدٌ\">n. un.</abbr> with ة; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) [i. e.] ↓ طُنَّةٌ signifies a single reed or cane [or piece of firewood] of a bundle: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) and the <abbr title=\"plural, جَمْعٌ\">pl.</abbr> is أَطْنَانٌ: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) [or,] <abbr title=\"according\">accord.</abbr> to <abbr title=\"Abū Ḥanīfah al-Dīnawarī, author of the Book of Plants\">AHn</abbr>, a طُنّ of reeds or canes, and of fresh branches, is a وريقة [<abbr title=\"apparently\">app.</abbr> meaning a leafy bundle] put together and bound round, and having flowers, or blossoms, and plucked fruits put in the interior thereof. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> And A thing that is put between the two half-loads that are upon the sides of a beast. (<abbr title=\"Abū l-Haytham\">AHeyth</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b3:</span> And The stature [of a man]: or, <abbr title=\"according\">accord.</abbr> to <abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) the body of a man and of any animal: <abbr title=\"plural, جَمْعٌ\">pl.</abbr> أَطْنَانٌ and طِنَانٌ: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) whence, he says, the saying, فُلَانٌ لَا يَقُومُ بِطُنِّ نَفْسِهِ فَكَيْفَ بَغَيْرِهِ [Such a one will not rise with his own body: how then with another?]: but <abbr title=\"according\">accord.</abbr> to <abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, this is a saying of the vulgar; and he does not think it to be genuine Arabic. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">A2:</span> See also طَنٌّ.<br><br>طُنَّةٌ: see the next preceding paragraph.<br><br>طِنَّةٌ: see ظِنَّةٌ.<br><br>طُنِّىٌّ A large-bodied man. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) طَنِينٌ an <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr>: (<abbr title=\"The Muqaddimat al-Adab of al-Zamakhsharī\">MA</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>: [see 1:]) [as a simple <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>,] The sound of flies [i. e. a humming, or buzzing]: and of a basin of brass or other metal [i. e. a ringing, or tinkling]: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) and of the ear [i. e. a ringing, or tingling]: and of a mountain: and of a hard thing [of any kind]: and ↓ طَنْطَنَةٌ has a similar meaning. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) قَصِيدَةٌ طَنَّانَةٌ [A sonorous ode.] (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) طَنْطَنَةٌ: see طَنِينٌ. It is an onomatopœia, meaning The sound of the [kind of mandoline called] طُنْبُور, and the like, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) such as the lute. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And Low, faint, or soft, speech. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And Loquacity, and a sounding utterance of speech. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) رَجُلٌ ذُو طَنْطَانٍ A clamorous man. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.)"}]}}