{"lemma":"رَحِيم","slug":"رَحِيم","root":"ر.ح.م","root_slug":"ر-ح-م","root_link":"/words/roots/ر-ح-م","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رَحِيم","root":"رحم","pos":"N","occurrence_count":116},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n15096"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AD%D9%90%D9%8A%D9%85"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"merciful","examples":[{"text":"اِعْلَمُوا أَنَّ اللَّهَ شَدِيدُ الْعِقَابِ وَأَنَّ اللَّهَ غَفُورٌ رَحِيمٌ","english":"Know that Allah is severe in punishment and that Allah is forgiving and merciful"}]},{"pos":"adj","gloss":"compassionate"},{"pos":"adj","gloss":"beneficent"},{"pos":"adj","gloss":"related by blood"},{"pos":"adj","gloss":"sincere in friendship"}]},"etymology":{"source":"wiktextract","text":"فَعِيل (faʕīl)-type stative-verb derived from the active participle from the verb رَحِمَ (raḥima, “to be merciful”)."},"ipa":["/ra.ħiːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15096","headword_ar":"رَحِيمُ","root":"rHm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Alr~aHom`nu","text_ar":"الرَّحْمٰنُ"},{"kind":"text","text":", in seven places. ―         -b2-  Sometimes it is"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maroHuwmN","text_ar":"مَرْحُومٌ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Treated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regarded, with mercy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion;"},{"kind":"text","text":"&c.: see 1, first sentence]: 'Amelles Ibn-'Akeel says, (using it in this sense, Ham p. 628,)"},{"kind":"quote","text":"faA^am~aA A_i*aA EaD~ato bika AlHarobu EaD~apF\n                      \n                     \n                        faA_in~aka maEoTuwfN Ealayoka raHiymu"},{"kind":"text","text":"(S, and Ham,) i. e. ["},{"kind":"italic_en","text":"But at all events,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when war becomes"},{"kind":"text","text":"["},{"kind":"italic_en","text":"once"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"severe to thee,"},{"kind":"text","text":"and thine enemy has almost overcome thee, ["},{"kind":"italic_en","text":"verily thou art regarded with favour,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"treated with mercy,"},{"kind":"text","text":"and defended, by us. (Ham.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%AD%D9%8A%D9%85/","headword_ar":"رحيما","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=111336#724db9","body_html":"رحيما<br>عن الآرامية بمعنى حبيب ودود."}]}}