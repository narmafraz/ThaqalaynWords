{"lemma":"جَهَدَ","slug":"جَهَدَ","root":"ج.ه.د","root_slug":"ج-ه-د","root_link":"/words/roots/ج-ه-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَهَدْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَهَدْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَهَدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَهَدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَهَدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَهَدَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَهَدَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَهَدا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَهَدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَهَدُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَهَدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْهَد","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْهَدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْهَدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْهَدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْهَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْهَد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْهَد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْهَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَهَدْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَهَدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْهَد","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْهَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":true,"lemma_key":"جَهَدَ","root":"جهد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n6512"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%87%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to strive, to struggle, to labour, to exert oneself, to take pains, to endeavor (especially in the sense of strenuously, to the utmost of one's ability, etc.)"},{"pos":"verb","gloss":"to overwork, to overtax, to fatigue, to exhaust","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of جَهَدَ (jahada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"labour, toil, exertion, effort"},{"pos":"noun","gloss":"strain, exertion, effort"},{"pos":"noun","gloss":"power, ability"},{"pos":"noun","gloss":"to the limit of, as much as (جُهْدَ (juhda) used as preposition)","examples":[{"text":"هُوَ أَكَلَ جُهْدَ طَاقَتِهِ.","english":"He ate to the limit of his ability."}]}]},"etymology":null,"ipa":["/d͡ʒa.ha.da/","/d͡ʒahd/","/d͡ʒuhd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6512","headword_ar":"جَهَدَ","root":"jhd","body":[{"kind":"text","text":", (S, A, L, &c.,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jahodN","text_ar":"جَهْدٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He strove, laboured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toiled; exerted himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability; employed himself vigorously, strenuously, laboriously, diligently, studiously, sedulously, earnestly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with energy; was diligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"studious; took pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinary pains;"},{"kind":"text","text":"(S, A, L, K;)"},{"kind":"arabic","text_bw":"fiY ka*aA","text_ar":"فِى كَذَا"},{"kind":"italic_en","text":"in such a thing;"},{"kind":"text","text":"(S;) or"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"italic_en","text":"in the affair;"},{"kind":"text","text":"(A;) as also ↓"},{"kind":"arabic","text_bw":"Ajthd","text_ar":"اجتهد","orth_type":"arrow"},{"kind":"text","text":"; (A, K;) and so ↓"},{"kind":"arabic","text_bw":"jAhd","text_ar":"جاهد","orth_type":"arrow"},{"kind":"text","text":", with respect to speech and actions: (L:) or"},{"kind":"arabic","text_bw":"jahada fiY AlA^amori","text_ar":"جَهَدَ فِى الاَمْرِ"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"he did his utmost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"used his utmost power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, in prosecuting the affair:"},{"kind":"text","text":"(Msb:) and ↓"},{"kind":"arabic","text_bw":"Ajthd","text_ar":"اجتهد","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tjAhd","text_ar":"تجاهد","orth_type":"arrow"},{"kind":"italic_en","text":"he exerted unsparingly his power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajthd","text_ar":"اجتهد","orth_type":"arrow"},{"kind":"italic_en","text":"he exerted unsparingly his power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, in the prosecution of the affair, so as to effect his utmost."},{"kind":"text","text":"(Msb.) You say also,"},{"kind":"arabic","text_bw":"Aijohado jahadaka fiY h*aA AlA^amori","text_ar":"اِجْهَدْ جَهَدَكَ فِى هذَا الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Do thine utmost in this affair:"},{"kind":"text","text":"(Fr, S, K: *) but not"},{"kind":"arabic","text_bw":"juhodaka","text_ar":"جُهْدَكَ"},{"kind":"text","text":". (Fr, S.) And"},{"kind":"arabic","text_bw":"raA^oyahu","text_ar":"رَاْيَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajthd","text_ar":"اجتهد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He took pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put himself to trouble"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue, to form a right judgment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion."},{"kind":"text","text":"(MA.) And"},{"kind":"arabic","text_bw":"raA^oyiY wanafosiY Hat~aY","text_ar":"رَاْيِى وَنَفْسِى حَتَّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aijotahadotu","text_ar":"اِجْتَهَدْتُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"balagotu majohuwdiY","text_ar":"بَلَغْتُ مَجْهُودِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I exerted my judgment and my mind so that I attained the utmost of my power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability."},{"kind":"text","text":"(T, L.) ―         -b2-"},{"kind":"arabic","text_bw":"jahadabihi","text_ar":"جَهَدَبِهِ"},{"kind":"italic_en","text":"He tried, proved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined, him,"},{"kind":"text","text":"(L, K,)"},{"kind":"arabic","text_bw":"Eani Alxayori wa gayorihi","text_ar":"عَنِ الخَيْرِ وَ غَيْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"respecting good"},{"kind":"text","text":"qualities, &c.]. (L.)       -A2-"},{"kind":"arabic","text_bw":"jahadahu","text_ar":"جَهَدَهُ"},{"kind":"text","text":", (Mgh, L, Msb,) aor."},{"kind":"text","text":", (Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"jahodN","text_ar":"جَهْدٌ"},{"kind":"text","text":", (L, Msb,)"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"(an affair, and a disease,) and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a man,)"},{"kind":"italic_en","text":"affected him severely; harassed, embarrassed, distressed, afflicted, troubled, inconvenienced, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wearied, him:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(disease, L and K, and fatigue, and love, L)"},{"kind":"italic_en","text":"rendered him lean; emaciated him:"},{"kind":"text","text":"(L, K:)"},{"kind":"italic_en","text":"he burdened him beyond his power; imposed upon him that which was beyond his power;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ajhdhu","text_ar":"اجهدهُ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) and, [as also ↓"},{"kind":"arabic","text_bw":"Ajhdhu","text_ar":"اجهدهُ","orth_type":"arrow"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"he importuned him, harassed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plied him hard, in asking, begging,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petitioning."},{"kind":"text","text":"(A.) [Hence,]"},{"kind":"arabic","text_bw":"juhida","text_ar":"جُهِدَ"},{"kind":"text","text":", said of a man,"},{"kind":"italic_en","text":"He was severely affected, harassed, embarrassed, distressed, afflicted, troubled, inconvenienced, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wearied:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"was grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made sorry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unhappy."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"A^aSaAbahumo quHuwTN mina AlmaTari fajuhiduwA jahodFA $adiydFA","text_ar":"اَصَابَهُمْ قُحُوطٌ مِنَ المَطَرِ فَجُهِدُوا جَهْدًا شَدِيدًا"},{"kind":"italic_en","text":"Drought befell them, and they consequently became severely distressed."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"juhiduwA","text_ar":"جُهِدُوا"},{"kind":"italic_en","text":"They were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, afflicted with drought, barrenness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with drought, and dryness of the earth."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"rajulN yajohadu A^ano yaHomila silaAHahu","text_ar":"رَجُلٌ يَجْهَدُ اَنْ يَحْمِلَ سِلَاحَهُ"},{"kind":"arabic","text_bw":"mina AlD~aEofi","text_ar":"مِنَ الضَّعْفِ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"yajohadu nafosahu","text_ar":"يَجْهَدُ نَفْسَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"A man who imposes upon himself a difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a difficult"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severe task,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who strains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strains himself, in the carrying of his weapons,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arms, by reason of weakness."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"jahada daAb~atahu","text_ar":"جَهَدَ دَابَّتَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AjhdhA","text_ar":"اجهدها","orth_type":"arrow"},{"kind":"italic_en","text":"He jaded, harassed, distressed, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wearied, his beast; i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"balaga jahodahaA","text_ar":"بَلَغَ جَهْدَهَا","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"he tasked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plied, his beast beyond his power in journeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marching,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in respect of pace."},{"kind":"text","text":"(S, Msb.) And"},{"kind":"arabic","text_bw":"A^ajohadotuhu EalaY A^ano yafoEala","text_ar":"اَجْهَدْتُهُ عَلَى اَنْ يَفْعَلَ"},{"kind":"arabic","text_bw":"ka*aA wa ka*aA","text_ar":"كَذَا وَ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I importuned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"harassed him, to do such and such things"},{"kind":"text","text":"]. (L.) ―         -b2-  Also, (S, Msb,) aor. as above, (A,) and so the inf. n., (Msb,) (tropical:)"},{"kind":"italic_en","text":"He deprived it"},{"kind":"text","text":"(namely, milk,)"},{"kind":"italic_en","text":"of its butter,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"entirely:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"churned it so as to extract its butter and render it sweet and pleasant:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed it with water:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"diluted it so that it consisted for the most part of water:"},{"kind":"text","text":"and in like manner it  is used in relation to broth. (A.) ―         -b3-  Hence, (Msb,)"},{"kind":"arabic","text_bw":"jahadahaA","text_ar":"جَهَدَهَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He lay with her;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compressed her:"},{"kind":"text","text":"(L, Msb, from a trad.:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dafaEahaA","text_ar":"دَفَعَهَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HafazahaA","text_ar":"حَفَزَهَا"},{"kind":"text","text":"[which has a similar meaning]. (L.) ―         -b4-"},{"kind":"arabic","text_bw":"jahada AlT~aEaAmi","text_ar":"جَهَدَ الطَّعَامِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He desired the food eagerly; longed for it;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"Ajhdhu","text_ar":"اجهدهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"juhida AlT~aEaAmu","text_ar":"جُهِدَ الطَّعَامُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ujohida","text_ar":"اُجْهِدَ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The food was eagerly desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longed for."},{"kind":"text","text":"(S.) ―         -b5-  Also (tropical:)"},{"kind":"italic_en","text":"He ate much of the food:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"he left nothing of it."},{"kind":"text","text":"(A.) You say also,"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"arabic","text_bw":"kalaA^N yajohaduhu AlmaAlu","text_ar":"كَلَاٌ يَجْهَدُهُ المَالُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"This is herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasture, of which the cattle eat perseveringly."},{"kind":"text","text":"(AA, TA.)       -A3-"},{"kind":"arabic","text_bw":"jahida","text_ar":"جَهِدَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a state of life)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, difficult, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressful."},{"kind":"text","text":"(S, K.)"}],"source_refs":["K","TA","L","Msb","S","A","Mgh"]}]}}