{"lemma":"سِمَةٍ","slug":"سِمَةٍ","root":"#.س.م","root_slug":"_-س-م","root_link":"/words/roots/_-س-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n20590","n20596","n20597","n20598","n44577"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%90%D9%85%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of وَسَمَ (wasama, “to brand, describe”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"sign, mark"},{"pos":"noun","gloss":"stigma"},{"pos":"noun","gloss":"distinction"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20590","headword_ar":"سَمَّهُ","root":"sm","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He put poison into it;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"poisoned it; infected it with poison;"},{"kind":"text","text":"] namely, food. (S, Msb, K.) And"},{"kind":"italic_en","text":"He gave him to drink poison."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"sam~atohu AlhaAm~apu","text_ar":"سَمَّتْهُ الهَامَّةُ"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"hAm~p","text_ar":"هامّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"venomous reptile"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"smote him with its poison."},{"kind":"text","text":"(M.) ―         -b2-  [Hence, perhaps,"},{"kind":"italic_en","text":"He suggested it,"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"italic_en","text":"to him:"},{"kind":"text","text":"a signification mentioned by Freytag, but without any indication of the authority.] ―         -b3-  [And, app.,"},{"kind":"italic_en","text":"It perforated it; transpierced it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, through it:"},{"kind":"text","text":"for it is said that]"},{"kind":"arabic","text_bw":"masam~N","text_ar":"مَسَمٌّ"},{"kind":"text","text":"may be an inf. n. of the verb [signifying"},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":"], and may also signify a place of"},{"kind":"arabic","text_bw":"nufuw*","text_ar":"نُفُوذ"},{"kind":"text","text":". (Msb.) ―         -b4-  And, (K,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He probed it;"},{"kind":"text","text":"namely a case, or an affair;"},{"kind":"italic_en","text":"and examined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured to learn, its depth."},{"kind":"text","text":"(S, K, TA.) ―         -b5-  Also, inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$ad~ahu","text_ar":"شَدَّهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made it firm, fast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong;"},{"kind":"text","text":"&c.]: (M:) [or this may be a mistranscription for"},{"kind":"arabic","text_bw":"sad~ahu","text_ar":"سَدَّهُ"},{"kind":"text","text":"; for] you say,"},{"kind":"arabic","text_bw":"samamotu AlqaAruwrapawanaHowahaA","text_ar":"سَمَمْتُ القَارُورَةَوَنَحْوَهَا"},{"kind":"text","text":", (S, K, *) inf. n. as above, (TA,) meaning"},{"kind":"arabic","text_bw":"sadadotu","text_ar":"سَدَدْتُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I closed, stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped up, the flask,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bottle, and the like"},{"kind":"text","text":"]. (S, K. *) ―         -b6-  Also, (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aSolaHahu","text_ar":"اَصْلَحَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He rectified it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put it into a good, sound, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, state;"},{"kind":"text","text":"&c.]; namely, a thing. (M, K.) And"},{"kind":"arabic","text_bw":"sam~a bayona","text_ar":"سَمَّ بَيْنَ"},{"kind":"arabic","text_bw":"Alqawomi","text_ar":"القَوْمِ"},{"kind":"text","text":", (S, M,) or"},{"kind":"arabic","text_bw":"sam~a bayonahumaA","text_ar":"سَمَّ بَيْنَهُمَا"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", [for the verb is trans.,"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":"being understood, or"},{"kind":"arabic","text_bw":"bayona","text_ar":"بَيْنَ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"*aAta Albayoni","text_ar":"ذَاتَ البَيْنِ"},{"kind":"text","text":",] (M,) inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aSolaHa","text_ar":"اَصْلَحَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He rectified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reformed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amended, the circumstances subsisting between the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between them two;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he effected a rectification of affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an agreement, a harmony,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reconciliation, between the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between them two"},{"kind":"text","text":"]. (S. M, K.) ―         -b7-  And"},{"kind":"arabic","text_bw":"sam~N AlwadaEa","text_ar":"سَمٌّ الوَدَعَ"},{"kind":"italic_en","text":"He strung the"},{"kind":"arabic","text_bw":"wadaE","text_ar":"وَدَع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"cowries"},{"kind":"text","text":"]; which, when strung, are termed"},{"kind":"arabic","text_bw":"sum~apN","text_ar":"سُمَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sum~N","text_ar":"سُمٌّ"},{"kind":"text","text":"(M.) ―         -b8-"},{"kind":"arabic","text_bw":"sam~ahu","text_ar":"سَمَّهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", signifies also"},{"kind":"italic_en","text":"He appropriated it to a particular, peculiar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, object."},{"kind":"text","text":"(M.) You say,"},{"kind":"arabic","text_bw":"sam~a","text_ar":"سَمَّ"},{"kind":"arabic","text_bw":"Aln~iEomapa","text_ar":"النِّعْمَةَ"},{"kind":"italic_en","text":"He so appropriated the benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounty."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"sam~ati Aln~iEomapu","text_ar":"سَمَّتِ النِّعْمَةُ"},{"kind":"italic_en","text":"The benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounty, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, particular, peculiar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, as to its object:"},{"kind":"text","text":"(S, K:) the verb being intrans. as well as trans. (K.) El-'Ajjáj says,"},{"kind":"quote","text":"huwa Al~a*iY A^anoEama nuEomaY Eam~ato\n                      \n                     \n                        EalaY Al~a*iyna A^asolamuwA wasam~ato"},{"kind":"text","text":"(S,) or the latter hemistich is"},{"kind":"page_break","n":1419},{"kind":"quote","text":"EalaY AlbilaAdi rab~unaA wasam~ato"},{"kind":"text","text":"(M,) ["},{"kind":"italic_en","text":"He is the Being who has bestowed bounty that has been general and that has been particular upon those who have become Muslims,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the countries,"},{"kind":"text","text":"namely,"},{"kind":"italic_en","text":"our Lord"},{"kind":"text","text":"]: he means that it has reached all. (S.) ―         -b9-  [And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaSadahu","text_ar":"قَصَدَهُ"},{"kind":"text","text":":] you say,"},{"kind":"arabic","text_bw":"samamotu sam~aka","text_ar":"سَمَمْتُ سَمَّكَ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"qaSadotu qaSodaka","text_ar":"قَصَدْتُ قَصْدَكَ"},{"kind":"text","text":"[which means"},{"kind":"italic_en","text":"I tended, repaired, betook myself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"directed my course, towards thee;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I have tended,"},{"kind":"text","text":"&c.: and also"},{"kind":"italic_en","text":"I pursued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have pursued, thy way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course, doing like thee"},{"kind":"text","text":"]. (S.)       -A2-  ["},{"kind":"arabic","text_bw":"sum~a","text_ar":"سُمَّ"},{"kind":"italic_en","text":"It was smitten by the wind called"},{"kind":"arabic","text_bw":"sumuwm","text_ar":"سُمُوم"},{"kind":"text","text":"; applied to a plant; and in like manner to a man: see its part. n.,"},{"kind":"arabic","text_bw":"masomuwmN","text_ar":"مَسْمُومٌ"},{"kind":"text","text":". And]"},{"kind":"arabic","text_bw":"sum~a yawomunaA","text_ar":"سُمَّ يَوْمُنَا"},{"kind":"text","text":", with damm [to the"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"Our day was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, attended with the wind called"},{"kind":"arabic","text_bw":"samuwm","text_ar":"سَمُوم"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","Msb","K","TA","M"]},{"entry_id":"n20596","headword_ar":"سَمَّةٌ","root":"sm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"meatus of the vagina"},{"kind":"text","text":"of a woman; (As, TA;) as also ↓"},{"kind":"arabic","text_bw":"simaAmN","text_ar":"سِمَامٌ","orth_type":"arrow"},{"kind":"text","text":", [which is shown to be thus used as a sing., by a citation from a trad., though said to be] from"},{"kind":"arabic","text_bw":"simaAmN","text_ar":"سِمَامٌ"},{"kind":"text","text":"as signifying the “ eyes ” ("},{"kind":"arabic","text_bw":"vuqab","text_ar":"ثُقَب"},{"kind":"text","text":") of the needle [or of needles]: or the"},{"kind":"italic_en","text":"rima"},{"kind":"text","text":"of a woman,"},{"kind":"italic_en","text":"with the parts that are next to it of the haunch and of the borders of the vulva,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"of the labia majora."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"sim~apN","text_ar":"سِمَّةٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"arabic","text_bw":"Als~am~apu","text_ar":"السَّمَّةُ"},{"kind":"text","text":", (AA, TA,) or"},{"kind":"arabic","text_bw":"sam~apu","text_ar":"سَمَّةُ"},{"kind":"arabic","text_bw":"Alqalobi","text_ar":"القَلْبِ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cerebrum, of the palm-tree:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"smm","text_ar":"سمم"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"simamN","text_ar":"سِمَمٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"sumamN","text_ar":"سُمَمٌ"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["AA","TA"]},{"entry_id":"n20597","headword_ar":"سُمَّةٌ","root":"sm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sam~N","text_ar":"سَمٌّ"},{"kind":"text","text":", last sentence.       -A2-  Also"},{"kind":"italic_en","text":"A mat,"},{"kind":"text","text":"(AHn, M,) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"suforap","text_ar":"سُفْرَة"},{"kind":"text","text":"[q. v.], (K,) or"},{"kind":"italic_en","text":"a thing like a wide"},{"kind":"arabic","text_bw":"suforap","text_ar":"سُفْرَة"},{"kind":"text","text":", (T, TA,)"},{"kind":"italic_en","text":"made,"},{"kind":"text","text":"(AHn, M,) [i. e.]"},{"kind":"italic_en","text":"woven,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"xuwS","text_ar":"خُوص"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leaves"},{"kind":"text","text":"] (AHn, T, M, K)"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"gaDaf","text_ar":"غَضَف"},{"kind":"text","text":"[a tree resembling a dwarfpalm-tree]: (AHn, M:)"},{"kind":"italic_en","text":"it is spread beneath the palm-tree"},{"kind":"text","text":"(T, K, TA)"},{"kind":"italic_en","text":"when the dates are cut off,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"and upon it fall what become scattered"},{"kind":"text","text":"(T, K, TA)"},{"kind":"italic_en","text":"of the dates:"},{"kind":"text","text":"(T, TA:) pl."},{"kind":"arabic","text_bw":"simaAmN","text_ar":"سِمَامٌ"},{"kind":"text","text":", (AHn, M, TA,) or"},{"kind":"arabic","text_bw":"sumamN","text_ar":"سُمَمٌ"},{"kind":"text","text":", (K,) or, as in the T,"},{"kind":"arabic","text_bw":"sumuwmN","text_ar":"سُمُومٌ"},{"kind":"text","text":". (TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"saAm~N","text_ar":"سَامٌّ"},{"kind":"text","text":", latter part, in two places."}],"source_refs":["AHn","M","K","T","TA"]},{"entry_id":"n20598","headword_ar":"سِمَّةٌ","root":"sm","body":[{"kind":"text","text":"The"},{"kind":"arabic","text_bw":"Aisot","text_ar":"اِسْت"},{"kind":"text","text":"[here app. meaning"},{"kind":"italic_en","text":"anus"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"sam~apN","text_ar":"سَمَّةٌ","orth_type":"arrow"},{"kind":"text","text":"[q. v.]. (K.)"}],"source_refs":[]},{"entry_id":"n44577","headword_ar":"سِمَةٌ","root":"wsm","body":[{"kind":"italic_en","text":"A brand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mark"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figure made with a hot iron, upon an animal."},{"kind":"text","text":"(K.) And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EalaAmapN","text_ar":"عَلَامَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A mark, sign, badge, token, symptom,"},{"kind":"text","text":"&c.]. (Msb.) And The"},{"kind":"arabic","text_bw":"EulowaAn","text_ar":"عُلْوَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"title"},{"kind":"text","text":"] of a book or writing. (TA in art."},{"kind":"arabic","text_bw":"Elw","text_ar":"علو"},{"kind":"text","text":".) See also"},{"kind":"arabic","text_bw":"siymapN","text_ar":"سِيمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"siymaY","text_ar":"سِيمَى"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"swm","text_ar":"سوم"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}