{"lemma":"عَهِدَ","slug":"عَهِدَ","root":"ع.ه.د","root_slug":"ع-ه-د","root_link":"/words/roots/ع-ه-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَهِدْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَهِدْتِ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَهِدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَهِدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَهِدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَهِدَ","in_corpus":true,"count":19,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَهِدَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَهِدا","in_corpus":true,"count":21,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَهِدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَهِدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَهِدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْهَد","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْهَدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْهَدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْهَدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْهَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْهَد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْهَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْهَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْهَد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْهَد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَهِدْنا","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَهِدْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":true,"lemma_key":"عَهِدَ","root":"عهد","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":13},"lanes":{"found":true,"entry_ids":["n30861","n30862"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%87%D9%90%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to further"},{"pos":"verb","gloss":"to care, to be cognizant of, to know"},{"pos":"noun","gloss":"verbal noun of عَهِدَ (ʕahida) (form I)","tags":["form-of","noun-from-verb"],"examples":[{"text":"الْعَهْد الْقَدِيم (al-ʕahd al-qadīm, “the Old Testament”)"}]},{"pos":"noun","gloss":"covenant","tags":["Judaism"],"examples":[{"text":"تَابُوت الْعَهْد (tābūt al-ʕahd, “the Ark of the Covenant”)"}]},{"pos":"noun","gloss":"knowledge, acquaintance, contact"},{"pos":"noun","gloss":"close observance, strict adherence, keeping, fulfillment"},{"pos":"noun","gloss":"delegation, assignment, committing, commissioning, entrusting"},{"pos":"noun","gloss":"commission"},{"pos":"noun","gloss":"commitment, obligation, liability, responsibility"},{"pos":"noun","gloss":"agreement, covenant, treaty, pact, compact, pledge"},{"pos":"noun","gloss":"promise, vow, oath"},{"pos":"noun","gloss":"time, epoch, era"},{"pos":"noun","gloss":"testament","examples":[{"text":"الْعَهْد الْجَدِيد (al-ʕahd al-jadīd, “the New Testament”)"}]}]},"etymology":null,"ipa":["/ʕa.hi.da/","/ʕahd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30861","headword_ar":"عَهْدٌ","root":"Ehd","body":[{"kind":"text","text":"[an inf. n. of 1, q. v.: used as a simple subst.,]"},{"kind":"italic_en","text":"An injunction, a charge, a bidding, an order,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a command."},{"kind":"text","text":"(S, A, Mgh, O, Msb, K, TA.) [Pl. in this and other senses"},{"kind":"arabic","text_bw":"EuhuwdN","text_ar":"عُهُودٌ"},{"kind":"text","text":".]"},{"kind":"arabic","text_bw":"EahodiY","text_ar":"عَهْدِى"},{"kind":"arabic","text_bw":"A^ano laA A=xu*a mino raADiEK $ayoy^FA","text_ar":"اَنْ لَا ا=خُذَ مِنْ رَاضِعٍ شَيْيًا"},{"kind":"text","text":", occurring in a trad., is a phrase tropically abridged, meaning (tropical:)"},{"kind":"italic_en","text":"It is in the injunction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charge, prescribed as obligatory on me"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that I should not take anything from a suckling"},{"kind":"text","text":"]. (Mgh.) ―         -b2-"},{"kind":"italic_en","text":"A compact, a contract, a covenant, an agreement, a confederacy, a league, a treaty, an engagement, a bond, an obligation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a promise:"},{"kind":"text","text":"(S, A, Mgh, O, L, Msb, K, TA:) pl."},{"kind":"arabic","text_bw":"EuhuwdN","text_ar":"عُهُودٌ"},{"kind":"text","text":": or, accord. to AHeyth, ↓"},{"kind":"arabic","text_bw":"EahodapN","text_ar":"عَهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"has this this meaning, and"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ"},{"kind":"text","text":"is its pl. [or rather a coll. gen. n.]. (TA.) Hence"},{"kind":"arabic","text_bw":"waliY~u EahodK","text_ar":"وَلِىُّ عَهْدٍ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"suc-"},{"kind":"page_break","n":2183},{"kind":"italic_en","text":"cessor by virtue of a covenant"},{"kind":"text","text":"of a Khaleefeh [or King]. (TA.) [And"},{"kind":"arabic","text_bw":"wilaAyapu EahodK","text_ar":"وِلَايَةُ عَهْدٍ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"succession by virtue of a covenant."},{"kind":"text","text":"] ―         -b3-"},{"kind":"italic_en","text":"Protection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safeguard; a promise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an assurance, of security"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety; responsibility,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suretiship;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^amaAnN","text_ar":"اَمَانٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"*im~apN","text_ar":"ذِمَّةٌ"},{"kind":"text","text":"; (Sh, S, A, O, Msb, K;) and"},{"kind":"arabic","text_bw":"DamaAnN","text_ar":"ضَمَانٌ"},{"kind":"text","text":"; (O, K;) as also ↓"},{"kind":"arabic","text_bw":"Euh~ayodaY","text_ar":"عُهَّيْدَى","orth_type":"arrow"},{"kind":"text","text":"[in the O ↓"},{"kind":"arabic","text_bw":"EuhayodaY","text_ar":"عُهَيْدَى","orth_type":"arrow"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"EihodaAnN","text_ar":"عِهْدَانٌ","orth_type":"arrow"},{"kind":"text","text":"[which last is said in the S and O to be syn. with"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ"},{"kind":"text","text":", but in what sense is not there specified]. (K.) Hence,"},{"kind":"arabic","text_bw":"*uw EahodK","text_ar":"ذُو عَهْدٍ"},{"kind":"text","text":", an appel-lation given to a Christian, and a Jew, [and a Sabian, who is a subject of a Muslim government,] meaning"},{"kind":"italic_en","text":"One between whom and the Muslims a compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covenant, subsists, whereby the latter are responsible for his security"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and freedom and toleration"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"as long as he acts agreeably to the compact"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by living peaceably with them and paying a poll-tax"},{"kind":"text","text":"]; (Mgh, * Msb, * TA;) [i. e."},{"kind":"italic_en","text":"a free non-Muslim subject of a Muslim government;"},{"kind":"text","text":"] as also ↓"},{"kind":"arabic","text_bw":"muEaAhidN","text_ar":"مُعَاهِدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEaAhadN","text_ar":"مُعَاهَدٌ","orth_type":"arrow"},{"kind":"text","text":", the act. and pass. forms being both applied to such a person because the compact is mutual; (Msb;) both syn. with"},{"kind":"arabic","text_bw":"*im~iY~N","text_ar":"ذِمِّىٌّ"},{"kind":"text","text":": (S:) persons of this description are called collectively"},{"kind":"arabic","text_bw":"A^aholu AlEahodi","text_ar":"اَهْلُ العَهْدِ"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"italic_en","text":"An oath:"},{"kind":"text","text":"(S, A, O, K:) pl."},{"kind":"arabic","text_bw":"EuhuwdN","text_ar":"عُهُودٌ"},{"kind":"text","text":": or, accord. to AHeyth, ↓"},{"kind":"arabic","text_bw":"EahodapN","text_ar":"عَهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"an oath whereby one secures himself against him with whom he makes a compact, contract, covenant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ"},{"kind":"text","text":"is its pl. [or rather a coll. gen. n.]. (TA.) [But it is generally used as a sing.: hence,] one says,"},{"kind":"arabic","text_bw":"EalaY~a Eahodu A@ll~`hi laA^afoEalan~a ka*aA","text_ar":"عَلَىَّ عَهْدُ ا@للّٰهِ لَاَفْعَلَنَّ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The oath by attestation of God is binding on me that I will assuredly do such a thing"},{"kind":"text","text":"]. (S, O.) ―         -b5-"},{"kind":"italic_en","text":"A writ,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diploma, of appointment to the office of a prefect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"governor"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(S, O, K:) pl."},{"kind":"arabic","text_bw":"EuhuwdN","text_ar":"عُهُودٌ"},{"kind":"text","text":". (TA.) ―         -b6-"},{"kind":"italic_en","text":"Defence of those persons,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"things, that should be sacred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inviolable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that are entitled to reverence, respect, honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defence;"},{"kind":"text","text":"(S, A, O, K;) and"},{"kind":"italic_en","text":"mindfulness, regard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observance,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"of such things,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"of love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection;"},{"kind":"text","text":"occurring in this sense in a trad., in which it is said that generosity therein is a point of religion. (S.) ―         -b7-"},{"kind":"italic_en","text":"Fulfilment of a promise"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(O, K.) So in the Kur vii. 100. (O.) ―         -b8-  The"},{"kind":"italic_en","text":"assertion of the unity of God:"},{"kind":"text","text":"whence,"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"arabic","text_bw":"mani A@t~axa*a Einoda A@lr~aHom`ni EahodFA","text_ar":"مَنِ ا@تَّخَذَ عِنْدَ ا@لرَّحْمٰنِ عَهْدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Except such as hath made a covenant with the Compassionate to assert his unity"},{"kind":"text","text":"], (O, K,) in the Kur [xix. 90]: (O:) and the words of a trad. relating to prayer,"},{"kind":"arabic","text_bw":"A^anaA","text_ar":"اَنَا"},{"kind":"arabic","text_bw":"EalaY Eahodika wawaEodika maA A@sotaTaEotu","text_ar":"عَلَى عَهْدِكَ وَوَعْدِكَ مَا ا@سْتَطَعْتُ"},{"kind":"italic_en","text":"I am persevering in the observance of my covenant and promise to Thee to believe in Thee and to assert thy unity incessantly"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as far as I am able"},{"kind":"text","text":"]. (TA.)       -A2-  Also"},{"kind":"italic_en","text":"A time;"},{"kind":"text","text":"(S, * A, K;) and so ↓"},{"kind":"arabic","text_bw":"EihodaAnN","text_ar":"عِهْدَانٌ","orth_type":"arrow"},{"kind":"text","text":". (A, TA.) One says,"},{"kind":"arabic","text_bw":"kaAna EalaY Eahodi fulaAnK","text_ar":"كَانَ عَلَى عَهْدِ فُلَانٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EihodaAnihi","text_ar":"عِهْدَانِهِ","orth_type":"arrow"},{"kind":"italic_en","text":"It was in the time of such a one."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"arabic","text_bw":"*`lika fiY Eahodi $abaAbiY","text_ar":"ذٰلِكَ فِى عَهْدِ شَبَابِى"},{"kind":"italic_en","text":"That was in the time of my youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young manhood."},{"kind":"text","text":"(TK.) And"},{"kind":"arabic","text_bw":"A^ataY EalayohaA","text_ar":"اَتَى عَلَيْهَا"},{"kind":"arabic","text_bw":"EahodN TawiylN","text_ar":"عَهْدٌ طَوِيلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Over which a long time has passed"},{"kind":"text","text":"]. (S, in explanation of"},{"kind":"arabic","text_bw":"qaroyapN EahiydapN","text_ar":"قَرْيَةٌ عَهِيدَةٌ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"qadiymapN","text_ar":"قَدِيمَةٌ"},{"kind":"text","text":".) ―         -b2-  One says also,"},{"kind":"arabic","text_bw":"EahodiY bihi qariybN","text_ar":"عَهْدِى بِهِ قَرِيبٌ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"My meeting"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was a short time ago"},{"kind":"text","text":"]. (S, * Msb.) And"},{"kind":"arabic","text_bw":"huwa qariybu AlEahodi baka*aA","text_ar":"هُوَ قَرِيبُ العَهْدِ بَكَذَا"},{"kind":"italic_en","text":"He knew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was acquainted with, such a thing,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"was in such a state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, recently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short time ago."},{"kind":"text","text":"(Msb. [And in like manner one says"},{"kind":"arabic","text_bw":"Hadiyvu AlEahodi","text_ar":"حَدِيثُ العَهْدِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hadiyvu EahodK","text_ar":"حَدِيثُ عَهْدٍ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"EahodiY bihi","text_ar":"عَهْدِى بِهِ"},{"kind":"arabic","text_bw":"bimawoDiEi ka*aA","text_ar":"بِمَوْضِعِ كَذَا"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"fiY HaAli ka*aA","text_ar":"فِى حَالِ كَذَا"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"I met,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"met with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I knew,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"I saw,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in such a place,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"in such a state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA liY EahodN bihi","text_ar":"مَا لِى عَهْدٌ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have not any knowledge of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquaintance with, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"mataY Eahoduka bifulaAnK","text_ar":"مَتَى عَهْدُكَ بِفُلَانٍ"},{"kind":"italic_en","text":"When didst thou meet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meet with, such a one?"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"see such a one?"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"mataY Eahoduka biAlxuf~i","text_ar":"مَتَى عَهْدُكَ بِالخُفِّ"},{"kind":"italic_en","text":"When didst thou wear the boots?"},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"mataY Eahoduka biA^asofali fiyka","text_ar":"مَتَى عَهْدُكَ بِاَسْفَلِ فِيكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When didst thou see the lower part of thy mouth?"},{"kind":"text","text":"]: a prov.; said in asking a person respecting an old affair of which he has no knowledge. (L.) The saying of the poet, (Aboo-Khirásh El-Hudhalee, TA, and so in a copy of the S,)"},{"kind":"quote","text":"falayosa kaEahodi Ald~aAri yaA A^um~a maAlikK\n                      \n                     \n                        wal`kino A^aHaATato biAlr~iqaAbi Als~alaAsilu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And it is not like the formerly-known state of the abode, O Umm-Málik; but chains have surrounded the necks;"},{"kind":"text","text":"] is expl. as meaning, the case is not as thou knewest it; but El-Islám has come, and has subverted that case. (S, TA.) [Hence,"},{"kind":"arabic","text_bw":"liloEahodi","text_ar":"لِلْعَهْدِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"lilomaEohuwdi","text_ar":"لِلْمَعْهُودِ","orth_type":"arrow"},{"kind":"text","text":", said of the article"},{"kind":"arabic","text_bw":"Aalo","text_ar":"اَلْ"},{"kind":"text","text":"; meaning"},{"kind":"italic_en","text":"Used to distinguish a noun as known to the hearer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reader, in a particular sense."},{"kind":"text","text":"]       -A3-  Also"},{"kind":"italic_en","text":"A first rain;"},{"kind":"text","text":"the rain immediately following which is called"},{"kind":"arabic","text_bw":"waloYN","text_ar":"وَلْىٌ"},{"kind":"text","text":": (TA:) or the"},{"kind":"italic_en","text":"first of the rain called"},{"kind":"arabic","text_bw":"AlwasomiY~u","text_ar":"الوَسْمِىُّ"},{"kind":"text","text":"; (IAar, M, K;) and so ↓"},{"kind":"arabic","text_bw":"EahodapN","text_ar":"عَهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EihodapN","text_ar":"عِهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EihaAdapN","text_ar":"عِهَادَةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K, TA,) or, as in some copies of the K [and in the CK], ↓"},{"kind":"arabic","text_bw":"EihaAdN","text_ar":"عِهَادٌ","orth_type":"arrow"},{"kind":"text","text":", which is pl. of"},{"kind":"arabic","text_bw":"EahodN","text_ar":"عَهْدٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Rain that falls after other rain,"},{"kind":"text","text":"(AHn, S, K,)"},{"kind":"italic_en","text":"while the moisture of the former yet remains;"},{"kind":"text","text":"(AHn, K;) as also ↓"},{"kind":"arabic","text_bw":"EahodapN","text_ar":"عَهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EihodapN","text_ar":"عِهْدَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl."},{"kind":"arabic","text_bw":"EihaAdN","text_ar":"عِهَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuhuwdN","text_ar":"عُهُودٌ"},{"kind":"text","text":": (S:) or"},{"kind":"arabic","text_bw":"EihaAdN","text_ar":"عِهَادٌ"},{"kind":"text","text":", accord. to some, signifies"},{"kind":"italic_en","text":"recent rains;"},{"kind":"text","text":"app. from the saying,"},{"kind":"arabic","text_bw":"A^aSaAbatonaA diymapN biEoda diymapK EalaY EihaAdK","text_ar":"اَصَابَتْنَا دِيمَةٌ بِعْدَ دِيمَةٍ عَلَى عِهَادٍ"},{"kind":"arabic","text_bw":"gayori qadiymapK","text_ar":"غَيْرِ قَدِيمَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A continuous and still rain fell upon us after a continuous and still rain following upon"},{"kind":"arabic","text_bw":"EhAd","text_ar":"عهاد"},{"kind":"italic_en","text":"not long anterior"},{"kind":"text","text":"]: (AHn, TA:) or"},{"kind":"arabic","text_bw":"EihaAdN","text_ar":"عِهَادٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"rains of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"autumn,"},{"kind":"text","text":"as is shown voce"},{"kind":"arabic","text_bw":"nawo'N","text_ar":"نَوْءٌ"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"after the rain called"},{"kind":"arabic","text_bw":"AlwasomiY~","text_ar":"الوَسْمِىّ"},{"kind":"text","text":": (A:) or"},{"kind":"italic_en","text":"weak, fine rain, of that which is called"},{"kind":"arabic","text_bw":"wasomiY~","text_ar":"وَسْمِىّ"},{"kind":"text","text":". (IAar, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EaAmu","text_ar":"عَامُ"},{"kind":"arabic","text_bw":"AlEuhuwdi","text_ar":"العُهُودِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The year of few rains."},{"kind":"text","text":"(TA.)       -A4-  See also"},{"kind":"arabic","text_bw":"EuhodapN","text_ar":"عُهْدَةٌ"},{"kind":"text","text":", near the middle, in two places:       -A5-  and see"},{"kind":"arabic","text_bw":"maEohadN","text_ar":"مَعْهَدٌ"},{"kind":"text","text":", in three places."}],"source_refs":["S","A","Mgh","O","L","Msb","K","TA","M","AHn"]},{"entry_id":"n30862","headword_ar":"عَهِدٌ","root":"Ehd","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who applies himself repeatedly to affairs,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to prefectures"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"governments"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who applies himself repeatedly thereto, and to the reforming thereof;"},{"kind":"text","text":"expl. by the words"},{"kind":"arabic","text_bw":"yataEaAhadu AlA^umuwra waAlwilaAyaAti","text_ar":"يَتَعَاهَدُ الاُمُورَ وَالوِلَايَاتِ"},{"kind":"text","text":": (S, K:) or one"},{"kind":"italic_en","text":"who loves prefectures"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and writs of appointment thereto;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"muHib~N lilowilaAyaAti waAlEuhuwdi","text_ar":"مُحِبٌّ لِلْوِلَايَاتِ وَالعُهُودِ"},{"kind":"text","text":". (A.)"}],"source_refs":["S","K"]}]}}