8%B1%D9%8E%D9%88%D9%8E%D9%91%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to circulate, to sling, to propagate, to pitch, to promote"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16969","headword_ar":"روّج","root":"rwj","body":[{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tarowiyjN","text_ar":"تَرْوِيجٌ"},{"kind":"text","text":", (A, Msb, K,)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a commodity"},{"kind":"italic_en","text":"to have an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a ready, sale; to be saleable; easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready, of sale;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand."},{"kind":"text","text":"(S, A, K. *) ―         -b2-"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"money"},{"kind":"italic_en","text":"to pass,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be current."},{"kind":"text","text":"(S, * A, * Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"rw~j Al$~aYo'a","text_ar":"روّج الشَّىْءَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rw~j bihi","text_ar":"روّج بِهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made the thing to be quick, speedy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expeditious;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick with it."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"raw~ajotu","text_ar":"رَوَّجْتُ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"A^ar~ajotu","text_ar":"اَرَّجْتُ"},{"kind":"text","text":": so in the saying, ↓"},{"kind":"arabic","text_bw":"raw~ajotu AlA^amora faraAja","text_ar":"رَوَّجْتُ الاَمْرَ فَرَاجَ","orth_type":"arrow"},{"kind":"text","text":", aor. of the latter"},{"kind":"arabic","text_bw":"yaruwju","text_ar":"يَرُوجُ"},{"kind":"text","text":", and inf. n."},{"kind":"arabic","text_bw":"rawojN","text_ar":"رَوْجٌ"},{"kind":"text","text":", [app. meaning"},{"kind":"italic_en","text":"I excited the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, and it became excited."},{"kind":"text","text":"] (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"rw~j kalaAmahu","text_ar":"روّج كَلَامَهُ"},{"kind":"italic_en","text":"He embellished his speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, and made it vague, so that one knew not its true meaning:"},{"kind":"text","text":"(Msb, TA:) from"},{"kind":"arabic","text_bw":"raAjati Alr~iyHu","text_ar":"رَاجَتِ الرِّيحُ"},{"kind":"text","text":", (TA,) or from"},{"kind":"arabic","text_bw":"rw~jt Alr~iyHu","text_ar":"روّجت الرِّيحُ"},{"kind":"text","text":". (Msb.) ―         -b6-  For"},{"kind":"arabic","text_bw":"rw~jt AlryH","text_ar":"روّجت الريح"},{"kind":"text","text":"see 1, last sentence. ―         -b7-"},{"kind":"arabic","text_bw":"rw~j AlgubaAru EalaY raA^osi AlbaEiyri","text_ar":"روّج الغُبَارُ عَلَى رَاْسِ البَعِيرِ"},{"kind":"text","text":"[perhaps"},{"kind":"arabic","text_bw":"ruw~ija","text_ar":"رُوِّجَ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"The dust continued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went round, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over, the head of the camel;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_definitions":null}