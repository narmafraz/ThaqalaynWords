:"s"},{"role":"present_1mp","form":"نُنار","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُنار","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40722"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to light, to illuminate"},{"pos":"verb","gloss":"to elucidate, to clarify"},{"pos":"verb","gloss":"to come to light, to appear, to show, to be uncovered, to be disclosed, to be revealed"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40722","headword_ar":"انار","root":"nwr","body":[{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"A_inaArapN","text_ar":"اـِنَارَةٌ"},{"kind":"text","text":", Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing) (S, Msb)"},{"kind":"italic_en","text":"gave light;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly;"},{"kind":"text","text":"(S, A, * Msb, K; *) as also ↓"},{"kind":"arabic","text_bw":"nw~r","text_ar":"نوّر","orth_type":"arrow"},{"kind":"text","text":", (Lh, S, * A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tanowiyrN","text_ar":"تَنْوِيرٌ"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"AstnAr","text_ar":"استنار","orth_type":"arrow"},{"kind":"text","text":"; (S, A, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"naAra","text_ar":"نَارَ","orth_type":"arrow"},{"kind":"text","text":", (A, Msb, K,) aor."},{"kind":"arabic","text_bw":"yanuwru","text_ar":"يَنُورُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"naworN","text_ar":"نَوْرٌ"},{"kind":"text","text":", (K, TA,) or"},{"kind":"arabic","text_bw":"nuwrN","text_ar":"نُورٌ"},{"kind":"text","text":", (as in a copy of the A,) or"},{"kind":"arabic","text_bw":"niyaArN","text_ar":"نِيَارٌ"},{"kind":"text","text":": (Msb;) and ↓"},{"kind":"arabic","text_bw":"tnw~r","text_ar":"تنوّر","orth_type":"arrow"},{"kind":"text","text":": (K:)"},{"kind":"arabic","text_bw":"nw~r","text_ar":"نوّر"},{"kind":"text","text":"(S, * Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"AnAr","text_ar":"انار"},{"kind":"text","text":"(Mgh, Msb) and"},{"kind":"arabic","text_bw":"AstnAr","text_ar":"استنار"},{"kind":"text","text":", (Msb,) said of the dawn, signify as above; (Mgh, Msb;) or"},{"kind":"italic_en","text":"its light appeared."},{"kind":"text","text":"(S, * K) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Alfitonapu","text_ar":"الفِتْنَةُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"naArati","text_ar":"نَارَتِ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tanuwru","text_ar":"تَنُورُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Sedition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, happened and spread."},{"kind":"text","text":"(Msb.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"AnAr","text_ar":"انار"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^anowara","text_ar":"اَنْوَرَ"},{"kind":"text","text":", (K.) the latter being the original form;"},{"kind":"page_break","n":2865},{"kind":"text","text":"said of a plant; (TA;)"},{"kind":"italic_en","text":"It became beautiful:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it became apparent."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"A^anowarati","text_ar":"اَنْوَرَتِ"},{"kind":"arabic","text_bw":"Al$~ajarapu","text_ar":"الشَّجَرَةُ"},{"kind":"italic_en","text":"The tree became beautiful in its verdure:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"put forth its blossoms"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowers."},{"kind":"text","text":"(TA.) See also 2.       -A2-"},{"kind":"arabic","text_bw":"AnAr","text_ar":"انار"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nw~r","text_ar":"نوّر","orth_type":"arrow"},{"kind":"italic_en","text":"He made to give light; to shine;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to shine brightly."},{"kind":"text","text":"(Msb.) ↓"},{"kind":"arabic","text_bw":"Alt~anowiyru","text_ar":"التَّنْوِيرُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA_inaArapu","text_ar":"الاـِنَارَةُ"},{"kind":"text","text":"signify the same. (S.) You say,"},{"kind":"arabic","text_bw":"AnAr Als~iraAja","text_ar":"انار السِّرَاجَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"nw~rhu","text_ar":"نوّرهُ","orth_type":"arrow"},{"kind":"text","text":", (A,) and"},{"kind":"arabic","text_bw":"AlmiSobaAHa","text_ar":"المِصْبَاحَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nw~r","text_ar":"نوّر","orth_type":"arrow"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He made the lamp to give light;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to become bright."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"AnAr AlmakaAna","text_ar":"انار المَكَانَ"},{"kind":"italic_en","text":"He illumined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lighted, the place;"},{"kind":"text","text":"(K;) i. e.,"},{"kind":"italic_en","text":"put light"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a light"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in it."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"AnArhu","text_ar":"انارهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He elucidated it; rendered it apparent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly apparent, conspicuous, manifest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"nwr~hu","text_ar":"نورّهُ","orth_type":"arrow"},{"kind":"text","text":". (A, TA. *) ―         -b4-  And hence,"},{"kind":"arabic","text_bw":"AnAr A@ll~`hu burohaAnahu","text_ar":"انار ا@للّٰهُ بُرْهَانَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"God taught him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dictated to him, his proof."},{"kind":"text","text":"(TA.) 7:17 AM 30/01/035: see 4, first signification.       -A3-"},{"kind":"arabic","text_bw":"tnwr~wA Aln~aAra mino","text_ar":"تنورّوا النَّارَ مِنْ"},{"kind":"arabic","text_bw":"biEiydK","text_ar":"بِعِيدٍ"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"naAruwhaA","text_ar":"نَارُوهَا","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"They looked at the fire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured to see it"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tabaS~aruwhaA","text_ar":"تَبَصَّرُوهَا"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"from afar:"},{"kind":"text","text":"(S, K:) or"},{"kind":"arabic","text_bw":"tnw~r Aln~aAra","text_ar":"تنوّر النَّارَ"},{"kind":"italic_en","text":"he looked at the fire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured to see it,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tabaS~arahaA","text_ar":"تَبَصَّرَهَا"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and repaired towards it:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"he came to the fire:"},{"kind":"text","text":"it has this signification as well as the first. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"tnw~r Alr~ajula","text_ar":"تنوّر الرَّجُلَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlmaroA^apa","text_ar":"المَرْاَةَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He looked at the man,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the woman, at"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by a fire, from a place where the latter did not see him; he stood in the dark to see the man,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the woman, by the light of the latter's fire, without the latter's seeing him;"},{"kind":"arabic","text_bw":"tanaw~urN","text_ar":"تَنَوُّرٌ"},{"kind":"text","text":"being like"},{"kind":"arabic","text_bw":"taDaw~uw^N","text_ar":"تَضَوُّوٌ"},{"kind":"text","text":". (TA.)       -A4-  See also 8."}],"source_refs":["S","Msb","A","K","TA","Mgh"]}]},"classical_definitions":null}