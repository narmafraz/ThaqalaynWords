yfN","text_ar":"طَرِيفٌ"},{"kind":"text","text":": (Mgh, Msb:) or"},{"kind":"italic_en","text":"born at the owner's abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"house;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that brings forth there;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"taAlidN","text_ar":"تَالِدٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"talodN","text_ar":"تَلْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tulodN","text_ar":"تُلْدٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"taladN","text_ar":"تَلَدٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"tilydN","text_ar":"تِليدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_itolaAdN","text_ar":"اـِتْلَادٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) like"},{"kind":"arabic","text_bw":"A_isonaAmN","text_ar":"اـِسْنَامٌ"},{"kind":"text","text":", (M, [in the CK written"},{"kind":"arabic","text_bw":"AatolA^ad","text_ar":"اَتْلاَد"},{"kind":"text","text":", and so accord. to the MS,]) and ↓"},{"kind":"arabic","text_bw":"mutoladN","text_ar":"مُتْلَدٌ","orth_type":"arrow"},{"kind":"text","text":";]) (M, K; [written in a copy of the M"},{"kind":"arabic","text_bw":"mutal~d","text_ar":"مُتَلّد"},{"kind":"text","text":";]) wherefore, [i. e. because of the meaning,] Yaakoob judges that the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"is a substitute for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"; [as is said to be the case in the S;] but this is not a valid decision; for, were it so, the word in some of its variations would be reduced to its original: (M:) or any"},{"kind":"italic_en","text":"old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long-possessed,"},{"kind":"text","text":"property, (T, M, L,) consisting of animals &c., (M, L,)"},{"kind":"italic_en","text":"inherited from parents;"},{"kind":"text","text":"(T, M, L;) as also ↓"},{"kind":"arabic","text_bw":"taAlidN","text_ar":"تَالِدٌ","orth_type":"arrow"},{"kind":"text","text":"(T, L) and ↓"},{"kind":"arabic","text_bw":"taliydN","text_ar":"تَلِيدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mutoladN","text_ar":"مُتْلَدٌ","orth_type":"arrow"},{"kind":"text","text":"(T, M, L [the last written in a copy of the T"},{"kind":"arabic","text_bw":"mNtolidN","text_ar":"مٌتْلِدٌ"},{"kind":"text","text":", and in a copy of the M"},{"kind":"arabic","text_bw":"mutal~d","text_ar":"مُتَلّد"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"talodN","text_ar":"تَلْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tulodN","text_ar":"تُلْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_itolaAdN","text_ar":"اـِتْلَادٌ","orth_type":"arrow"},{"kind":"text","text":", as above: (M:) or slaves, or pasturing beasts,"},{"kind":"italic_en","text":"that breed at one's own abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"home, and become old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long possessed:"},{"kind":"text","text":"(ISh, as related by Sh:) or that"},{"kind":"italic_en","text":"which you yourself breed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rear."},{"kind":"text","text":"(As, T.) [See also"},{"kind":"arabic","text_bw":"taliydN","text_ar":"تَلِيدٌ"},{"kind":"text","text":", below. ―         -b2-  Hence,]"},{"kind":"arabic","text_bw":"hun~a mino tilaAdiY","text_ar":"هُنَّ مِنْ تِلَادِى"},{"kind":"text","text":", said by a man, (namely, Ibn-Mes'ood, M,) in reference to certain chapters ("},{"kind":"arabic","text_bw":"suwar","text_ar":"سُوَر"},{"kind":"text","text":") of the Kur-án, meaning (tropical:)"},{"kind":"italic_en","text":"They are of those which I acquired"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"learned,"},{"kind":"text","text":"L)"},{"kind":"italic_en","text":"long ago"},{"kind":"text","text":"from the Kur-án: (S, M, L:) thus saying, he likened them to the property, or camels &c., called"},{"kind":"arabic","text_bw":"tilaAdN","text_ar":"تِلَادٌ"},{"kind":"text","text":". (M, L.) ―         -b3-  [Az says,] I heard a man of Mekkeh say,"},{"kind":"arabic","text_bw":"tilaAdiYbimak~apa","text_ar":"تِلَادِىبِمَكَّةَ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"miylaAdiY","text_ar":"مِيلَادِى"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"My birth was in Mekkeh"},{"kind":"text","text":"]. (T.)"}],"source_refs":["Mgh","Msb","A","L","S","K","M","T"]}]},"classical_definitions":null}