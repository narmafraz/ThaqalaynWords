"m","num":"p"},{"role":"present_2mp","form":"تَسْدَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْدَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْدَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْدَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْدَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْدَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْدَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْدَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْدَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْدَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْدَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْدَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْدَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَدِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَدِرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"سَدِرَ","root":"سدر","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n19306"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%AF%D9%90%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be dazzled, to be blinded, to have vision blocked","examples":[{"text":"يصولُ بمَجْرٍ لَيْسَ يُحْصى عديدُه\nويَسْدَرُ مِنْهُ، ساجِياً، كلُّ ناظِرِ","english":"He encroaches numerously in a number that cannot be counted\nAnd every beholder is silent and dazzled by him."}]},{"pos":"verb","gloss":"to be careless, to be regardless, to be reckless"},{"pos":"verb","gloss":"to let go, to exert"},{"pos":"verb","gloss":"to hung down, to descend"},{"pos":"noun","gloss":"verbal noun of سَدِرَ (sadira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"buckthorn, trees of the genus Ziziphus","tags":["collective"],"examples":[{"text":"فِي سِدْرٍ مَّخْضُودٍ وَطَلْحٍ مَّنْضُودٍ","english":"[They will be] among buckthorn trees with thorns removed and vachellia trees layered [with fruit]"}]}]},"etymology":{"source":"wiktextract","text":"Sense of letting go cognate with Hebrew שִׁדֵּר (shidér, “to send, to dispatch, to broadcast”) via Jewish Babylonian Aramaic root ש־ד־ר (“to send”)\n\nFrom the root س د ر (s d r) meaning “to obscure or block vision”, “to make an area inaccessible or blocked”; originally applied variously to lofty trees associated with shade."},"ipa":["/sa.di.ra/","/sidr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19306","headword_ar":"سَدِرَ","root":"sdr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sadarN","text_ar":"سَدَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sadaArapN","text_ar":"سَدَارَةٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He became dazzled by a thing at which he looked, so that he turned away his face from it:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taHay~ara","text_ar":"تَحَيَّرَ"},{"kind":"text","text":": (K:) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"became dazzled by a thing at which he looked, so that he turned away his face from it, by reason of intense heat:"},{"kind":"text","text":"(S, * K:) also, (TA,) or"},{"kind":"arabic","text_bw":"sadira baSaruhu","text_ar":"سَدِرَ بَصَرُهُ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"[app. a man or any animal]"},{"kind":"italic_en","text":"was hardly able to see:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"arabic","text_bw":"sadira baSaruhu","text_ar":"سَدِرَ بَصَرُهُ"},{"kind":"italic_en","text":"he was dazzled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confounded"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and did not see well;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Aisomadar~a","text_ar":"اِسْمَدَرَّ","orth_type":"arrow"},{"kind":"text","text":". (A, TA.) [See also"},{"kind":"arabic","text_bw":"sadarN","text_ar":"سَدَرٌ"},{"kind":"text","text":", below.]       -A2-"},{"kind":"arabic","text_bw":"sadara","text_ar":"سَدَرَ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"sadarato","text_ar":"سَدَرَتْ"},{"kind":"text","text":", (S,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sadorN","text_ar":"سَدْرٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she, let down, let fall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to hang down,"},{"kind":"text","text":"his, or her, hair; (S, M, K;) and in like manner, a curtain, or veil, (M,) and a garment; (Lh;) a dial. var. of"},{"kind":"arabic","text_bw":"sadala","text_ar":"سَدَلَ"},{"kind":"text","text":". (S, K. *) ―         -b2-  Also"},{"kind":"arabic","text_bw":"sadara","text_ar":"سَدَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sadorN","text_ar":"سَدْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suduwrN","text_ar":"سُدُورٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He rent"},{"kind":"text","text":"his garment. (Yaa- koob, M.)"}],"source_refs":["S","K","TA","M"]}]}}