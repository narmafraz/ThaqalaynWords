thee, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with respect to, this affair, lowness,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"any defect,"},{"kind":"text","text":"&c.; (S, TA;) or"},{"kind":"italic_en","text":"languor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want of power."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"maA A^aradotu bid`lika gaDiyDapa","text_ar":"مَا اَرَدْتُ بِدٰلِكَ غَضِيضَةَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"magaD~atahu","text_ar":"مَغَضَّتَهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"I desired not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meant not, thereby, to attribute any defect, imperfection, fault, vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, to such a one."},{"kind":"text","text":"(IAar.)"}],"source_refs":["S","A","K","IAar","Mgh"]}]},"classical_definitions":null}