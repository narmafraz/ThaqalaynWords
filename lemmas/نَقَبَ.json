{"lemma":"نَقَبَ","slug":"نَقَبَ","root":"ن.ق.ب","root_slug":"ن-ق-ب","root_link":"/words/roots/ن-ق-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"نَقَبْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"نَقَبْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"نَقَبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"نَقَبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"نَقَبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"نَقَبَ","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"نَقَبَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"نَقَبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"نَقَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"نَقَبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"نَقَبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَنْقُب","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَنْقُبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَنْقُبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَنْقُبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْقُبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَنْقُبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْقُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْقُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْقُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْقُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْقُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْقُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْقُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْقُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْقُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْقُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْقُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَنْقُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْقُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"نَقَبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَقَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":true,"lemma_key":"نَقَبَ","root":"نقب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":12,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n40324"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%82%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dig, to grave, to bore into (literally, or as to find, or to rummage a territory, etc.)"},{"pos":"verb","gloss":"to teem in holes, to be gappy"},{"pos":"verb","gloss":"to pierce, to lacerate (the skin)","tags":["transitive"]},{"pos":"verb","gloss":"to perforate, to drill a hole into (e.g. a wall)","tags":["transitive"]},{"pos":"verb","gloss":"to drill"},{"pos":"verb","gloss":"to dig","tags":["transitive"]},{"pos":"verb","gloss":"to dig into, to investigate thoroughly","tags":["figuratively"]},{"pos":"noun","gloss":"verbal noun of نَقَبَ (naqaba) (form I)","tags":["form-of","noun-from-verb"],"examples":[{"text":"آتُونِي زُبَرَ الْحَدِيدِ حَتَّىٰ إِذَا سَاوَىٰ بَيْنَ الصَّدَفَيْنِ قَالَ ٱنْفُخُوا حَتَّىٰ إِذَا جَعَلَهُ نَارًا قَالَ آتُونِي أُفْرِغْ عَلَيْهِ قِطْرًا ۝ فَمَا ٱسْطَاعُوا أَن يَظْهَرُوهُ وَمَا ٱسْتَطَاعُوا لَهُ نَقْبًا","english":"“Give me bits of iron.” Until he dumped equally high between the two mountain cuttings. He said: “Blow.” Till he made fire. He said: “Bring me molten copper I pour upon it.“ ۝ And they could neither scale nor penetrate it."}]},{"pos":"noun","gloss":"passage, breach, tunnel","examples":[{"text":"لَيْسَ مِنْ بَلَدٍ إِلَّا سَيَطَؤُهُ الدَّجَّالُ إِلَّا مَكَّةَ وَالْمَدِينَةَ وَلَيْسَ نَقْبٌ مِنْ أَنْقَابِهَا إِلَّا عَلَيْهِ الْمَلَائِكَةُ صَافِّينَ تَحْرُسُهَا","english":"There is no land that the False Messiah will not walk on, save for Mecca and Medina. There is no pathway among its pathways that does not have angels in array who watch over it."}]},{"pos":"noun","gloss":"verbal noun of نَقِبَ (naqiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to become a leader"},{"pos":"noun","gloss":"plural of نِقَاب (niqāb, “veil”)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40324","headword_ar":"نَقَبَ","root":"nqb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He perforated, pierced, bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a hole through,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into,"},{"kind":"text","text":"anything: like"},{"kind":"arabic","text_bw":"vaqaba","text_ar":"ثَقَبَ"},{"kind":"text","text":". (TA.)"},{"kind":"italic_en","text":"He made a hole through"},{"kind":"text","text":"a wall. (S.) ―         -b2-"},{"kind":"arabic","text_bw":"naqaba sur~apa Ald~aAb~api","text_ar":"نَقَبَ سُرَّةَ الدَّابَّةِ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a farrier)"},{"kind":"italic_en","text":"perforated the navel of the beast in order that a yellow fluid might issue forth."},{"kind":"text","text":"(S.) See"},{"kind":"arabic","text_bw":"manoqabN","text_ar":"مَنْقَبٌ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"naqaba AlEayona","text_ar":"نَقَبَ العَيْنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He performed, upon the eye, what is called"},{"kind":"arabic","text_bw":"AlqadoHu","text_ar":"القَدْحُ"},{"kind":"text","text":"in the language of the physicians; i. e.,"},{"kind":"italic_en","text":"a remedial operation for the black fluid that arises in the eye:"},{"kind":"text","text":"from the phrase next following: (IAth:) [but this is not a good explanation: the meaning is"},{"kind":"italic_en","text":"he performed upon the eye the operation of couching, for the cataract:"},{"kind":"text","text":"so in many Arabic works, ancient and modern: (IbrD:) the couching-needle is called"},{"kind":"arabic","text_bw":"miqodaHN","text_ar":"مِقْدَحٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A_iborapu AlqadoHi","text_ar":"اـِبْرَةُ القَدْحِ"},{"kind":"text","text":", in the present day]. ―         -b4-"},{"kind":"arabic","text_bw":"naqaba","text_ar":"نَقَبَ"},{"kind":"arabic","text_bw":"HaAfira Ald~aAb~api","text_ar":"حَافِرَ الدَّابَّةِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a farrier)"},{"kind":"italic_en","text":"pierced a hole in the hoof of the beast,"},{"kind":"text","text":"in order to extract what had entered into it. (IAth.) ―         -b5-"},{"kind":"arabic","text_bw":"naqabatohu nakobapN","text_ar":"نَقَبَتْهُ نَكْبَةٌ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"A misfortune, an evil accident,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a calamity befell him,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and overcame him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afflicted him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"nakabatohu","text_ar":"نَكَبَتْهُ"},{"kind":"text","text":". (TA.) [In the CK, for"},{"kind":"arabic","text_bw":"A^aSaAbatohu","text_ar":"اَصَابَتْهُ"},{"kind":"text","text":", is put"},{"kind":"arabic","text_bw":"AvAbth","text_ar":"اثابته"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"naqaba fiY AlA^aroDi","text_ar":"نَقَبَ فِى الاَرْضِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Anqb","text_ar":"انقب","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"naq~b","text_ar":"نَقّب","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, through the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country:"},{"kind":"text","text":"(K:) [in the CK and some MS. copies of the K, we afterwards find"},{"kind":"arabic","text_bw":"naqiba fiY AlbilaAdi","text_ar":"نَقِبَ فِى البِلَادِ"},{"kind":"text","text":"with kesr to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", explained as signifying"},{"kind":"italic_en","text":"he proceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, through the lands:"},{"kind":"text","text":"] ↓"},{"kind":"arabic","text_bw":"Anqb","text_ar":"انقب","orth_type":"arrow"},{"kind":"italic_en","text":"he proceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed,"},{"kind":"text","text":"through the country: (IAar:)"},{"kind":"arabic","text_bw":"nq~bwA fiY AlbilaAdi","text_ar":"نقّبوا فِى البِلَادِ"},{"kind":"text","text":"[Kur, l. 35,]"},{"kind":"italic_en","text":"they proceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, through the lands,"},{"kind":"text","text":"seeking for a place of refuge: (S:) or"},{"kind":"italic_en","text":"they traversed the lands, and journeyed through them, much,"},{"kind":"text","text":"&c.: (Fr.:) or"},{"kind":"italic_en","text":"they went about and about, and searched, &c."},{"kind":"text","text":"(Zj.)"},{"kind":"arabic","text_bw":"fiY AlA=faAqi","text_ar":"فِى الا=فَاقِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"naq~abotu","text_ar":"نَقَّبْتُ","orth_type":"arrow"},{"kind":"text","text":", in a verse of Imra-el-Keys,"},{"kind":"italic_en","text":"I journeyed through the tracts of the earth, and came and went."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"naqiba AlbaEiyru","text_ar":"نَقِبَ البَعِيرُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"naqiba Huf~u AlbEyri","text_ar":"نَقِبَ حُفُّ البعيرِ"},{"kind":"text","text":", (L, TA,) and ↓"},{"kind":"arabic","text_bw":"Anqb","text_ar":"انقب","orth_type":"arrow"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"The camel walked barefooted,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HafiYa","text_ar":"حَفِىَ"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"until his feet became worn in holes:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"naqiba AlbEyr","text_ar":"نَقِبَ البعير"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"Anqb","text_ar":"انقب","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"the camel's feet became thin,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"were worn thin;"},{"kind":"text","text":"which is also a signification of"},{"kind":"arabic","text_bw":"HafiYa","text_ar":"حَفِىَ"},{"kind":"text","text":"]. (S, K.) ―         -b8-"},{"kind":"arabic","text_bw":"naqibato A^aqodaAmunaA","text_ar":"نَقِبَتْ اَقْدَامُنَا"},{"kind":"italic_en","text":"Our feet became thin in the skin, and blistered, by reason of walking."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"naqaba Alxuf~a","text_ar":"نَقَبَ الخُفَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He patched the boot; repaired it by patching."},{"kind":"text","text":"(K.) Also,"},{"kind":"italic_en","text":"He made the boot thin: he made"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wore"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"holes in it."},{"kind":"text","text":"(Msb.) ―         -b10-"},{"kind":"arabic","text_bw":"naqiba Alxuf~u","text_ar":"نَقِبَ الخُفُّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"naqabN","text_ar":"نَقَبٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"The boot became lacerated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worn through, in holes."},{"kind":"text","text":"(S, K, TA.) [And in like manner"},{"kind":"italic_en","text":"The sole of the foot"},{"kind":"text","text":"of a camel or of a man: see below: and see an ex. voce"},{"kind":"arabic","text_bw":"A^aZal~u","text_ar":"اَظَلُّ"},{"kind":"text","text":".] ―         -b11-"},{"kind":"arabic","text_bw":"naqaba","text_ar":"نَقَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"put his feet together in his running"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"fiY HuDorihi","text_ar":"فِى حُضْرِهِ"},{"kind":"text","text":", [for which Golius and Freytag appear to have read"},{"kind":"arabic","text_bw":"fY xaSorihi","text_ar":"فى خَصْرِهِ"},{"kind":"text","text":",] K,)"},{"kind":"italic_en","text":"not spreading his fore feet, his running being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a kind of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"leaping."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"naqaba Eani AlA^axoboAri","text_ar":"نَقَبَ عَنِ الاَخْبْارِ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He scrutinized, investigated, searched into, examined into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquired into, the news;"},{"kind":"text","text":"(K;) and, in like manner, anything else: (MF:) [as also ↓"},{"kind":"arabic","text_bw":"nq~b","text_ar":"نقّب","orth_type":"arrow"},{"kind":"text","text":": see the phrase"},{"kind":"arabic","text_bw":"nq~bwA fY AlblAd","text_ar":"نقّبوا فى البلاد"},{"kind":"text","text":", explained above:] or"},{"kind":"italic_en","text":"he told, announced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"related, the news."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"A_in~iY lamo A^uw^omaro A^ano A^anoquba Eano quluwbi Aln~aAsi","text_ar":"اـِنِّى لَمْ اُوْمَرْ اَنْ اَنْقُبَ عَنْ قُلُوبِ النَّاسِ"},{"kind":"italic_en","text":"Verily I have not been commanded to scrutinize and reveal what is in the hearts of men."},{"kind":"text","text":"(TA, from a trad.) ―         -b3-"},{"kind":"arabic","text_bw":"naqaba EalaY qawomihi","text_ar":"نَقَبَ عَلَى قَوْمِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"niqaAbapN","text_ar":"نِقَابَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He acted as the"},{"kind":"arabic","text_bw":"naqiyb","text_ar":"نَقِيب"},{"kind":"italic_en","text":"over his people; was their"},{"kind":"arabic","text_bw":"nqyb","text_ar":"نقيب"},{"kind":"text","text":": (S, K:) but of a man who was not"},{"kind":"arabic","text_bw":"nqyb","text_ar":"نقيب"},{"kind":"text","text":", and has become so, you say"},{"kind":"arabic","text_bw":"naquba","text_ar":"نَقُبَ"},{"kind":"text","text":", with damm, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqaAbapN","text_ar":"نَقَابَةٌ"},{"kind":"text","text":", with fet-h,"},{"kind":"italic_en","text":"He became"},{"kind":"arabic","text_bw":"nqyb","text_ar":"نقيب"},{"kind":"text","text":"; (Fr., S, K;) as also"},{"kind":"arabic","text_bw":"naqiba","text_ar":"نَقِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":": (IKtt, K:) or"},{"kind":"arabic","text_bw":"nqAbp","text_ar":"نقابة"},{"kind":"text","text":"with kesr is a subst.; and with fet-h, an inf. n.; (S, K;) like"},{"kind":"arabic","text_bw":"wilaAyapN","text_ar":"وِلَايَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"walaAyapN","text_ar":"وَلَايَةٌ"},{"kind":"text","text":": so says Sb. (S.)       -A3-"},{"kind":"arabic","text_bw":"naqaba Alv~awoba","text_ar":"نَقَبَ الثَّوْبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made the piece of cloth into a"},{"kind":"arabic","text_bw":"nuqobap","text_ar":"نُقْبَة"},{"kind":"text","text":". (S.)"}],"source_refs":["IAth","IbrD","K","IAar","S","L","TA","MF","IKtt"]}]},"classical_definitions":null}