n":"m","num":"p"},{"role":"present_2mp","form":"تَبْلُجُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْلُجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْلُج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْلُج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْلُجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْلُجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْلُجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْلُجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْلُجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْلُجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْلُجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"بَلَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَلَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَبْلُج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبْلُج","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n3143","n3146","n3147","n3148","n3149"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%84%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3143","headword_ar":"بَلِجَ","root":"blj","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (ISh, TA,) inf. n."},{"kind":"arabic","text_bw":"balajN","text_ar":"بَلَجٌ"},{"kind":"text","text":", (S, K, TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had a clear, a conspicuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a white, space between the eyes, not having the eyebrows joined;"},{"kind":"text","text":"(ISh, TA;)"},{"kind":"italic_en","text":"he had a clear space between the eyebrows;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"he had a wide space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a space clear of hair, between the eyebrows."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bright"},{"kind":"text","text":"in countenance: or"},{"kind":"italic_en","text":"fair, beautiful, and wide in countenance:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"open and pleasant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful, in countenance:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"liberal with acts of beneficence:"},{"kind":"text","text":"or (tropical:)"},{"kind":"italic_en","text":"generous, beneficent, and open and pleasant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful, in countenance:"},{"kind":"text","text":"see the part. n."},{"kind":"arabic","text_bw":"A^abolaju","text_ar":"اَبْلَجُ"},{"kind":"text","text":", below.] ―         -b3-  And [hence,] aor. as above, (K,) and so the inf. n., (TA,) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"balija","text_ar":"بَلِجَ"},{"kind":"arabic","text_bw":"biAl$~ayo'i","text_ar":"بِالشَّيْءِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He rejoiced at the thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was rejoiced by it;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"valija","text_ar":"ثَلِجَ"},{"kind":"text","text":". (As, TA.) And"},{"kind":"arabic","text_bw":"balija bihi","text_ar":"بَلِجَ بِهِ"},{"kind":"arabic","text_bw":"AlS~adoru faraHFA","text_ar":"الصَّدْرُ فَرَحًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The bosom became dilated with joy thereat."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"balija baEoda maA Harija","text_ar":"بَلِجَ بَعْدَ مَا حَرِجَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the bosom)"},{"kind":"italic_en","text":"became dilated"},{"kind":"text","text":"with joy"},{"kind":"italic_en","text":"after it had been contracted"},{"kind":"text","text":"with grief]. (TA.) ―         -b4-  [And hence,] aor. and inf. n. as above; (Msb;) and"},{"kind":"arabic","text_bw":"balaja","text_ar":"بَلَجَ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buluwjN","text_ar":"بُلُوجٌ"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"Anblj","text_ar":"انبلج","orth_type":"arrow"},{"kind":"text","text":", (S, K,) or ↓"},{"kind":"arabic","text_bw":"Abtlj","text_ar":"ابتلج","orth_type":"arrow"},{"kind":"text","text":"; (so in copies of the A and Msb;) and ↓"},{"kind":"arabic","text_bw":"tbl~j","text_ar":"تبلّج","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K;) and ↓"},{"kind":"arabic","text_bw":"Ablj","text_ar":"ابلج","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the dawn, or daybreak,)"},{"kind":"italic_en","text":"shone, was bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly."},{"kind":"text","text":"(S, A, Msb, K.) And"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^abolajati","text_ar":"اَبْلَجَتِ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sun shone, was bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AblAj~","text_ar":"ابلاجّ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The thing shone, was bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly."},{"kind":"text","text":"(TA.) ―         -b5-  And hence, (Msb,)"},{"kind":"arabic","text_bw":"balaja AlHaq~u","text_ar":"بَلَجَ الحَقُّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"balija","text_ar":"بَلِجَ"},{"kind":"text","text":"; (Msb;) or ↓"},{"kind":"arabic","text_bw":"Ablj","text_ar":"ابلج","orth_type":"arrow"},{"kind":"text","text":"; (A, TA;) (tropical:)"},{"kind":"italic_en","text":"The truth became apparent,"},{"kind":"text","text":"(A, Msb, TA,)"},{"kind":"italic_en","text":"manifest, evident,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear."},{"kind":"text","text":"(A, Msb.) And ↓"},{"kind":"arabic","text_bw":"AblAj~","text_ar":"ابلاجّ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AiboliyjaAjN","text_ar":"اِبْلِيجَاجٌ"},{"kind":"text","text":", (S, and so the inf. n. is written in a copy of the K: in another copy of the K it is written"},{"kind":"arabic","text_bw":"AibolijaAjN","text_ar":"اِبْلِجَاجٌ"},{"kind":"text","text":"[inf. n. of ↓"},{"kind":"arabic","text_bw":"Ablj~","text_ar":"ابلجّ","orth_type":"arrow"},{"kind":"text","text":"], and the verb is written"},{"kind":"arabic","text_bw":"Ablj~","text_ar":"ابلجّ"},{"kind":"text","text":"in a copy of the S: accord. to the CK, the inf. n. is"},{"kind":"arabic","text_bw":"AiboliylaAjN","text_ar":"اِبْلِيلَاجٌ"},{"kind":"text","text":"[of which the verb is ↓"},{"kind":"arabic","text_bw":"Ablwlj","text_ar":"ابلولج","orth_type":"arrow"},{"kind":"text","text":"]:) said of anything, (S, TA,) signifies (tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apparent, manifest, evident,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear."},{"kind":"text","text":"(S, K,"},{"kind":"page_break","n":246},{"kind":"text","text":"TA.)       -A2-"},{"kind":"arabic","text_bw":"balaja","text_ar":"بَلَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"balojN","text_ar":"بَلْجٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He opened;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"fataHa","text_ar":"فَتَحَ"},{"kind":"text","text":". (K.)"}],"source_refs":["ISh","TA","S","K","A","Msb"]},{"entry_id":"n3146","headword_ar":"بَلْجُ","root":"blj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^abolajN","text_ar":"اَبْلَجٌ"},{"kind":"text","text":", in four places."}],"source_refs":[]},{"entry_id":"n3147","headword_ar":"بَلَجٌ","root":"blj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bulojapN","text_ar":"بُلْجَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n3148","headword_ar":"بَلِجٌ","root":"blj","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Joyful, glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"A^abolajN","text_ar":"اَبْلَجٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n3149","headword_ar":"بُلُجٌ","root":"blj","body":[{"kind":"text","text":", with two dammehs, Men"},{"kind":"italic_en","text":"clear of hair in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"parts of the face called the"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qasamaAt","text_ar":"قَسَمَات"},{"kind":"text","text":". (IAar, K.)"}],"source_refs":[]}]},"classical_definitions":null}