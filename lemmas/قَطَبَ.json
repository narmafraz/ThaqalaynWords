num":"p"},{"role":"present_2mp","form":"تَقْطِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَقْطِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَقْطِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَقْطِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقْطِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقْطِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقْطِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقْطِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقْطِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقْطِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقْطِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَقْطِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَقْطِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"قَطَبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"قَطَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":12},"lanes":{"found":true,"entry_ids":["n35871"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B7%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gather, to collect, to bind together, to contract, to concentrate at one point"},{"pos":"verb","gloss":"to mix the wine, to fill it into its vessels in a blended state","tags":["obsolete"],"examples":[{"text":"وَكَأسٍ كَعَينِ الديكِ باكَرتُ حَدَّها\nبِفِتيانِ صِدقٍ وَالنَواقيسُ تُضرَبُ\nسُلافٍ كَأَنَّ الزَعفَرانَ وَعَندَما\nيُصَفَّقُ في ناجودِها ثُمَّ تُقطَبُ\nwa-kaʾsin ka-ʿayni ad-dīki bākartu ḥadda-hā\nbi-fityāni ṣidqin wa-n-nawāqīsu tuḍrabu\nsulāfin ka-ʾanna az-zaʿfarāna wa-ʿindamā","english":"There are stoops splendid like cock’s eyen, and I betook myself early to cross the border [into the land of the Christians]\nwith friendly lads, where the bells are hit,\nwhere there is fore-must wine like saffron,\nand one clinks the beakers and then mixes the wine."}]},{"pos":"verb","gloss":"to knit the eyebrows, to scowl, frown"},{"pos":"verb","gloss":"to scowl, to glower; to knit the brow, to frown"},{"pos":"verb","gloss":"to mix the wine, to fill it into its vessels in a blended state","tags":["obsolete"]},{"pos":"verb","gloss":"to bind or sew together"},{"pos":"noun","gloss":"axis, axle"},{"pos":"noun","gloss":"pivot, hub"},{"pos":"noun","gloss":"pole"},{"pos":"noun","gloss":"leader, authority, leading personality, celebrity","tags":["plural-normally"]},{"pos":"noun","gloss":"verbal noun of قَطَبَ (qaṭaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"puncture-vine (Tribulus spp.)"}]},"etymology":{"source":"wiktextract","text":"From the root ق ط ب (q ṭ b). The plant-name is suspect of an old Aramaic loan, preceding dissimilated Classical Syriac ܩܘܽܪܛܒܳܐ (qurṭəḇā) and ܛܘܽܪܒܳܐ (ṭurṭəḇā) (and ܩܘܽܛܒܳܐ (quṭəḇā), ܩܘܽܛܒܬܳܐ (quṭəḇtā, “puncture-vine”), possibly Arabisms), however already with the meaning specification, but agreeing with Biblical Hebrew קֹטֶב (qōṭəḇ), קֶטֶב (qeṭeḇ, “thorn”). Compare رَتَم (ratam) for a similar constellation."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35871","headword_ar":"قَطَبَ","root":"qTb","body":[{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"brought"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"gathered"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"drew"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"together:"},{"kind":"text","text":"(K, TA:) this is the primary signification. (O.) ―         -b2-  [Hence] one says,"},{"kind":"arabic","text_bw":"qaTaba","text_ar":"قَطَبَ"},{"kind":"arabic","text_bw":"AlHimaAru EaAnatahu","text_ar":"الحِمَارُ عَانَتَهُ"},{"kind":"text","text":"i. e. (tropical:)  ["},{"kind":"italic_en","text":"The"},{"kind":"text","text":"wild"},{"kind":"italic_en","text":"ass"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"collected"},{"kind":"text","text":"["},{"kind":"italic_en","text":"his herd of wild she-asses"},{"kind":"text","text":"]. (A: there distinguished as tropical.) ―         -b3-  And"},{"kind":"arabic","text_bw":"qaTaba Alqawomu","text_ar":"قَطَبَ القَوْمُ"},{"kind":"text","text":", ["},{"kind":"arabic","text_bw":"A^anofusahumo","text_ar":"اَنْفُسَهُمْ"},{"kind":"text","text":"being app. understood,] and ↓"},{"kind":"arabic","text_bw":"AqTb","text_ar":"اقطب","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, assembled themselves together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"congregated,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"and were guests, and mixed together."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"qaTaba","text_ar":"قَطَبَ"},{"kind":"text","text":", (A, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quTuwbN","text_ar":"قُطُوبٌ"},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"qT~b","text_ar":"قطّب","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taqoTiybN","text_ar":"تَقْطِيبٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He contracted the part between his eyes;"},{"kind":"text","text":"(A, K;) and"},{"kind":"italic_en","text":"grinned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"displayed his teeth, frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracting his face, and looking sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely;"},{"kind":"text","text":"(K, TA;) by reason of drink, &c.: (TA:) or"},{"kind":"arabic","text_bw":"qaTaba bayona Eayonayohi","text_ar":"قَطَبَ بَيْنَ عَيْنَيْهِ"},{"kind":"text","text":", (S, O, Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"he contracted the part between his eyes:"},{"kind":"text","text":"(S, O, Msb:) and"},{"kind":"arabic","text_bw":"wajohahu","text_ar":"وَجْهَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qT~b","text_ar":"قطّب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taqoTiybN","text_ar":"تَقْطِيبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he contracted his face;"},{"kind":"text","text":"(S, O;) or did so"},{"kind":"italic_en","text":"much."},{"kind":"text","text":"(So accord. to a copy of the S.) ―         -b5-  And"},{"kind":"arabic","text_bw":"qaTaba","text_ar":"قَطَبَ"},{"kind":"arabic","text_bw":"Al$~araAba","text_ar":"الشَّرَابَ"},{"kind":"text","text":", (S, A, O, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He mixed the wine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beverage;"},{"kind":"text","text":"(S, A, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AqTbhu","text_ar":"اقطبهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, O, K;) and ↓"},{"kind":"arabic","text_bw":"qT~bhu","text_ar":"قطّبهُ","orth_type":"arrow"},{"kind":"text","text":", (O, K, TA,) inf. n."},{"kind":"arabic","text_bw":"taqoTiybN","text_ar":"تَقْطِيبٌ"},{"kind":"text","text":". (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"qaTaba AlA_inaA='a","text_ar":"قَطَبَ الاـِنَا=ءَ"},{"kind":"italic_en","text":"He filled the vessel."},{"kind":"text","text":"(K.) ―         -b7-"},{"kind":"arabic","text_bw":"qaTaba AljuwaAliqa","text_ar":"قَطَبَ الجُوَالِقَ"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"He inserted one of the two loops of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sack called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jwAlq","text_ar":"جوالق"},{"kind":"italic_en","text":"into the other,"},{"kind":"text","text":"(S, O, K, TA,) on the occasion of making up a load, (TA,)"},{"kind":"italic_en","text":"then bent it"},{"kind":"text","text":"(S, O, K *)"},{"kind":"italic_en","text":"again,"},{"kind":"text","text":"(S, O,) ["},{"kind":"italic_en","text":"this time,"},{"kind":"text","text":"app.,"},{"kind":"italic_en","text":"back and down,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and put them together"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in order,"},{"kind":"text","text":"it seems,"},{"kind":"italic_en","text":"to insert a stick, so that the middle of one loop should be above the stick and the middle of the other should be beneath it"},{"kind":"text","text":"]: (K, TA:) when he does not bend the loop, [app. meaning through the other and then a second time as described above,] the action is termed"},{"kind":"arabic","text_bw":"saloqN","text_ar":"سَلْقٌ"},{"kind":"text","text":". (S, O, [See"},{"kind":"arabic","text_bw":"salaqa AljuwaAliqa","text_ar":"سَلَقَ الجُوَالِقَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"slq","text_ar":"سلق"},{"kind":"text","text":".])       -A2-"},{"kind":"arabic","text_bw":"qaTabahu","text_ar":"قَطَبَهُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He angered him;"},{"kind":"text","text":"(O, K;) aor. as above [and so, app., the inf. n.]. (O.)       -A3-  And also, (K, TA,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"qaTobN","text_ar":"قَطْبٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"He cut it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut it off:"},{"kind":"text","text":"(S, O, K:) but in this instance the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"is substituted for"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":". (O.)"}],"source_refs":["K","TA","O","A","S","Msb"]}]},"classical_definitions":null}