{"lemma":"حِنْوُ","slug":"حِنْوُ","root":"ح.ن.#","root_slug":"ح-ن-_","root_link":"/words/roots/ح-ن-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n9365","n9366"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%90%D9%86%D9%92%D9%88%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of حَنَا (ḥanā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of حَنَا (ḥanā) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9365","headword_ar":"حَنْوٌ","root":"Hnw and HnY","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n9366","headword_ar":"حِنْوٌ","root":"Hnw and HnY","body":[{"kind":"text","text":"(S, Mgh, K) and ↓"},{"kind":"arabic","text_bw":"HanowN","text_ar":"حَنْوٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Anything in which is a bending, curving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crookedness,"},{"kind":"text","text":"(K,) and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(TA;) of the body, (K,) such as the"},{"kind":"italic_en","text":"bone beneath the eyebrow,"},{"kind":"text","text":"(K, * TA,) and the"},{"kind":"italic_en","text":"jaw-bone,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a rib;"},{"kind":"text","text":"and of other things, such as the ["},{"kind":"italic_en","text":"high ground termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"quf~","text_ar":"قُفّ"},{"kind":"text","text":", and the ["},{"kind":"italic_en","text":"tract of sand termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hiqof","text_ar":"حِقْف"},{"kind":"text","text":", (K,) and the"},{"kind":"italic_en","text":"bend of a valley"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"maHoniyapN","text_ar":"مَحْنِيَةٌ"},{"kind":"text","text":"&c.]: (TA:) see"},{"kind":"arabic","text_bw":"maHoniyapN","text_ar":"مَحْنِيَةٌ"},{"kind":"text","text":": and"},{"kind":"italic_en","text":"any curved piece of wood,"},{"kind":"text","text":"(K,) such as"},{"kind":"italic_en","text":"any of the curved pieces of wood of the horse's saddle,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"camel's saddle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qatab","text_ar":"قَتَب"},{"kind":"text","text":", (S, * CK, TA,) and"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"camel's saddle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":": (CK, TA:)"},{"kind":"italic_en","text":"each of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the curved pieces of wood called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"qarobuwsaAni","text_ar":"قَرْبُوسَانِ"},{"kind":"text","text":", the"},{"kind":"italic_en","text":"anterior"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"posterior, of the horse's saddle:"},{"kind":"text","text":"(Mgh:) and"},{"kind":"italic_en","text":"a bending, curving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crookedness,"},{"kind":"text","text":"of anything: whence,"},{"kind":"arabic","text_bw":"HinowN","text_ar":"حِنْوٌ"},{"kind":"arabic","text_bw":"Aljabali","text_ar":"الجَبَلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the bend of the mountain"},{"kind":"text","text":"]: (S:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aHonaA='N","text_ar":"اَحْنَا=ءٌ"},{"kind":"text","text":"(S, Mgh, K) and [of mult.]"},{"kind":"arabic","text_bw":"HiniY~N","text_ar":"حِنِىٌّ"},{"kind":"text","text":", [in the CK, erroneously,"},{"kind":"arabic","text_bw":"HaniY~N","text_ar":"حَنِىٌّ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"HuniY~N","text_ar":"حُنِىٌّ"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"Hunuw~N","text_ar":"حُنُوٌّ"},{"kind":"text","text":", first altered to"},{"kind":"arabic","text_bw":"HuniY~N","text_ar":"حُنِىٌّ"},{"kind":"text","text":", and then, because of the kesreh, to"},{"kind":"arabic","text_bw":"HiniY~N","text_ar":"حِنِىٌّ"},{"kind":"text","text":"]. (K, TA.) ―         -b2-  [The dual]"},{"kind":"arabic","text_bw":"HinowaAni","text_ar":"حِنْوَانِ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"two curved pieces of wood, with a net upon them, by means of which wheat is conveyed to the heap that is collected together in the place where it is trodden out."},{"kind":"text","text":"(K.) ―         -b3-  And the pl."},{"kind":"arabic","text_bw":"A^aHonaA='N","text_ar":"اَحْنَا=ءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jawaAnibu","text_ar":"جَوَانِبُ"},{"kind":"text","text":"[as meaning (assumed tropical:)"},{"kind":"italic_en","text":"Sides, regions, quarters,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"limits, bounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boundaries"},{"kind":"text","text":"]; like"},{"kind":"arabic","text_bw":"A^aEonaA='N","text_ar":"اَعْنَا=ءٌ"},{"kind":"text","text":". (S.) The saying,"},{"kind":"arabic","text_bw":"A^uzojuro A^aHonaA='a Tayorika","text_ar":"اُزْجُرْ اَحْنَا=ءَ طَيْرِكَ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"nawaAHiyahu","text_ar":"نَوَاحِيَهُ"},{"kind":"text","text":", [i. e. (assumed tropical:)"},{"kind":"italic_en","text":"Straiten thou the limits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounds, of thy levity,"},{"kind":"text","text":"(alluding to the restraining of birds from flight,)]"},{"kind":"italic_en","text":"on the right and left, and before and behind;"},{"kind":"text","text":"by"},{"kind":"arabic","text_bw":"Tyrk","text_ar":"طيرك"},{"kind":"text","text":"being meant"},{"kind":"arabic","text_bw":"xif~atika","text_ar":"خِفَّتِكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tayo$ika","text_ar":"طَيْشِكَ"},{"kind":"text","text":". (S, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"A^aHonaA='u AlA^umuwri","text_ar":"اَحْنَا=ءُ الاُمُورِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Dubious affairs:"},{"kind":"text","text":"(K, * TA:) or, as some say, it means"},{"kind":"arabic","text_bw":"A^aToraAfuhaA wanawaAHiyhaA","text_ar":"اَطْرَافُهَا وَنَوَاحِيهَا"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"the ends, and limits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounds, of affairs"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Mgh","K","TA","CK"]}]}}