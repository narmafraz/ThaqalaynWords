_2mp","form":"تَفْعَلُوا","in_corpus":true,"count":10,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْعَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْعَل","in_corpus":true,"count":103,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْعَل","in_corpus":true,"count":55,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْعَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْعَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْعَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْعَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْعَلُونَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْعَلُوا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْعَلْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَفْعَل","in_corpus":true,"count":43,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْعَل","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"فَعَلْنا","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَعَلْتُ","in_corpus":true,"count":20,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":771,"cross_references":{"qac":{"found":true,"lemma_key":"فَعَلَ","root":"فعل","pos":"V","occurrence_count":88},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n34198","n34199"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B9%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to do"},{"pos":"verb","gloss":"to fulfill"},{"pos":"verb","gloss":"to act, to perform an activity without help"},{"pos":"verb","gloss":"to affect, to have an effect on"},{"pos":"verb","gloss":"to activate"},{"pos":"noun","gloss":"verbal noun of فَعَلَ (faʕala) (form I)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"activity, action, work"},{"pos":"noun","gloss":"performance, acting"},{"pos":"noun","gloss":"vocation, employment"},{"pos":"noun","gloss":"function"},{"pos":"noun","gloss":"deed, act, action"},{"pos":"noun","gloss":"effect, impact, influence"},{"pos":"noun","gloss":"verb","examples":[{"text":"Ibn Malik\nكَلَامُنَا لَفْظٌ مُفِيدٌ كَٱسْتَقِمْ / وَٱسْمٌ وَفِعْلٌ ثُمَّ حَرْفٌ ٱلْكَلِم\nkalāmunā lafẓun mufīdun kastaqim / wasmun wafiʕlun ṯumma ḥarfun l-kalim","english":"(please add an English translation of this quotation)"}]},{"pos":"noun","gloss":"exploit, great deed, feat"},{"pos":"noun","gloss":"verbal noun of فَعَلَ (faʕala) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew פָּעַל (pa'ál, “to do”)."},"ipa":["/fa.ʕa.la/","/faʕ.ʕa.la/","/fiʕl/","/faʕl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34198","headword_ar":"فَعْلٌ","root":"fEl","body":[{"kind":"text","text":"an inf. n. of 1. (S, O, Msb, K.)       -A2-  And The"},{"kind":"italic_en","text":"vulva of the she-camel,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of any female."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n34199","headword_ar":"فِعْلٌ","root":"fEl","body":[{"kind":"text","text":": see 1, in two places: [as a subst. from"},{"kind":"arabic","text_bw":"faEalahu","text_ar":"فَعَلَهُ"},{"kind":"text","text":"] it signifies ["},{"kind":"italic_en","text":"A deed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an action:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a motion"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"HarakapN","text_ar":"حَرَكَةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of a human being:"},{"kind":"text","text":"(K:) or, as Sgh says, the"},{"kind":"italic_en","text":"origination of anything, whether it be what is termed"},{"kind":"arabic","text_bw":"EamalN","text_ar":"عَمَلٌ"},{"kind":"text","text":"[which means"},{"kind":"italic_en","text":"work"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"labour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"service"},{"kind":"text","text":"as well as"},{"kind":"italic_en","text":"a deed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an action"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"other than it;"},{"kind":"text","text":"so that it is more general in application than"},{"kind":"arabic","text_bw":"EamialN","text_ar":"عَمَِلٌ"},{"kind":"text","text":": (TA:) or it is a metonymical term for"},{"kind":"italic_en","text":"any"},{"kind":"arabic","text_bw":"Eamal","text_ar":"عَمَل"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"deed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is transitive"},{"kind":"text","text":"(M, K, TA) or"},{"kind":"italic_en","text":"intransitive"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"a mode that is accidental to the producer of an effect upon another"},{"kind":"text","text":"["},{"kind":"italic_en","text":"person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by reason of the producing of the effect at the first; as the mode that ensues to the cutter by reason of his being cutting:"},{"kind":"text","text":"or, as Er-Rághib says, the"},{"kind":"italic_en","text":"production of an effect considered with reference to an agent thereof;"},{"kind":"text","text":"and it is"},{"kind":"italic_en","text":"common to that which is by his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, origination or otherwise, and to that which is with knowledge or otherwise, and to that which is by intention or otherwise, and to what proceeds from the human being or the animal"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of any kind"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"or the inanimate thing;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EamalN","text_ar":"عَمَلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SunoEN","text_ar":"صُنْعٌ"},{"kind":"text","text":"are more particular in application: El-Harállee says that the"},{"kind":"arabic","text_bw":"fiEol","text_ar":"فِعْل"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"what has become apparent in consequence of a motive of the efficient, whether from knowledge or otherwise, by reason of premeditation"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"litaday~un","text_ar":"لِتَدَيُّن"},{"kind":"text","text":"(an obvious mistranscription in my original) I read"},{"kind":"arabic","text_bw":"litadab~urK","text_ar":"لِتَدَبُّرٍ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"or otherwise:"},{"kind":"text","text":"and El-Juweynee says that it is"},{"kind":"italic_en","text":"what is within the limits of a small space of time, without repetition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reiteration,"},{"kind":"text","text":"whereas the"},{"kind":"arabic","text_bw":"Eamal","text_ar":"عَمَل"},{"kind":"text","text":"is what has been repeated, or reiterated, and whereof the time has been long; but this is repugned by the trad. [in which occurs the saying],"},{"kind":"arabic","text_bw":"maA faEala Aln~uigayor","text_ar":"مَا فَعَلَ النُِّغَيْر"},{"kind":"text","text":"[expl. in art."},{"kind":"arabic","text_bw":"ngr","text_ar":"نغر"},{"kind":"text","text":"]; (TA:) the pl. is"},{"kind":"arabic","text_bw":"fiEaAlN","text_ar":"فِعَالٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"A^afoEaAlN","text_ar":"اَفْعَالٌ"},{"kind":"text","text":"[a pl. of pauc.], (O, TA,) [and"},{"kind":"arabic","text_bw":"A^afaAEiylu","text_ar":"اَفَاعِيلُ"},{"kind":"text","text":"is app. a pl. pl., i. e. pl. of"},{"kind":"arabic","text_bw":"A^afoEaAlN","text_ar":"اَفْعَالٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A^qaAwiylu","text_ar":"اقَاوِيلُ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"A^aqowaAlN","text_ar":"اَقْوَالٌ"},{"kind":"text","text":"which is pl. of"},{"kind":"arabic","text_bw":"qawolN","text_ar":"قَوْلٌ"},{"kind":"text","text":", and many other instances]: you say,"},{"kind":"arabic","text_bw":"A_in~a Alr~i$aA tafotalu AlA^afaAEiyla","text_ar":"اـِنَّ الرِّشَا تَفْتَلُ الاَفَاعِيلَ"},{"kind":"arabic","text_bw":"watunosiY A_iboraAhiyma waA_isomaAEiyla","text_ar":"وَتُنْسِى اـِبْرَاهِيمَ وَاـِسْمَاعِيلَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily bribes do"},{"kind":"text","text":"great"},{"kind":"italic_en","text":"deeds, and cause"},{"kind":"text","text":"the receivers"},{"kind":"italic_en","text":"to forget"},{"kind":"text","text":"the principles of"},{"kind":"italic_en","text":"Ibráheem and Ismá'eel,"},{"kind":"text","text":"who are esteemed models of true religion]. (TA. [This saying is written in my original without any vowel-signs, perhaps because well known: and it is there added that"},{"kind":"arabic","text_bw":"AlAfAEyl","text_ar":"الافاعيل"},{"kind":"text","text":"may be pl. of"},{"kind":"arabic","text_bw":"AfEwl","text_ar":"افعول"},{"kind":"text","text":"(which has been altered by the copyist and is probably a mistranscription for"},{"kind":"arabic","text_bw":"A^afoEuwlapN","text_ar":"اَفْعُولَةٌ"},{"kind":"text","text":") or of"},{"kind":"arabic","text_bw":"AfEAl","text_ar":"افعال"},{"kind":"text","text":"; with other remarks equally doubtful and unimportant.]) [Hence,"},{"kind":"arabic","text_bw":"biAlfiEoli","text_ar":"بِالفِعْلِ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"Actually;"},{"kind":"text","text":"as opposed to"},{"kind":"arabic","text_bw":"biAlquw~api","text_ar":"بِالقُوَّةِ"},{"kind":"text","text":"i. e. potentially, or virtually.] ―         -b2-  As used by the grammarians, it means ["},{"kind":"italic_en","text":"A verb;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"what denotes a meaning in itself together with any one of the three times"},{"kind":"text","text":"["},{"kind":"italic_en","text":"past and present and future:"},{"kind":"text","text":"but it should be observed that it includes the"},{"kind":"arabic","text_bw":"maSodar","text_ar":"مَصْدَر"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"infinitive noun;"},{"kind":"text","text":"and also that there is what is termed"},{"kind":"arabic","text_bw":"fiEolN nAqiSN","text_ar":"فِعْلٌ ناقِصٌ"},{"kind":"italic_en","text":"an incomplete,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"non-attributive, verb"},{"kind":"text","text":"(as"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":"coordinate to"},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":", &c.); as well as what is termed"},{"kind":"arabic","text_bw":"fiEolN taAm~N","text_ar":"فِعْلٌ تَامٌّ"},{"kind":"italic_en","text":"a complete,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"attributive, verb"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K","TA","M","S","O","Msb"]}]}}