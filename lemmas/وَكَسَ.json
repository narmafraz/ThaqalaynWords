ry_id":"n42318","headword_ar":"وَكَسَ","root":"wks","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakisu","text_ar":"يَكِسُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wakosN","text_ar":"وَكْسٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, defective,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient; it fell short; it diminished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decreased."},{"kind":"text","text":"(S, A, Msb, K.) It is said in a trad., (S, Msb,) of Ibn-Mes'ood, (TA,)"},{"kind":"arabic","text_bw":"lahaA mahoru mivolihaA laA wakos","text_ar":"لَهَا مَهْرُ مِثْلِهَا لَا وَكْس"},{"kind":"arabic","text_bw":"walaA $aTaTa","text_ar":"وَلَا شَطَطَ"},{"kind":"italic_en","text":"She shall have the dowry of her like: there shall be no falling short nor exceeding:"},{"kind":"text","text":"(S, A, * Msb, * TA:) or"},{"kind":"italic_en","text":"there shall be no diminishing nor exceeding of the limit."},{"kind":"text","text":"(Mgh.) [For]"},{"kind":"arabic","text_bw":"wakasahu","text_ar":"وَكَسَهُ"},{"kind":"text","text":", aor. and inf. n. as above, signifies"},{"kind":"italic_en","text":"He rendered it defective,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient; diminished it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decreased it;"},{"kind":"text","text":"(A, Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"wk~shu","text_ar":"وكّسهُ","orth_type":"arrow"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"tawokiysN","text_ar":"تَوْكِيسٌ"},{"kind":"text","text":". (K, TK.) ―         -b2-"},{"kind":"italic_en","text":"He made him"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"to suffer loss;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"naqaSahu","text_ar":"نَقَصَهُ"},{"kind":"text","text":"; (S, TA; as also ↓"},{"kind":"arabic","text_bw":"wk~shu","text_ar":"وكّسهُ","orth_type":"arrow"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"tawokiysN","text_ar":"تَوْكِيسٌ"},{"kind":"text","text":": (K, * TA:) or"},{"kind":"italic_en","text":"he cheated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defrauded him."},{"kind":"text","text":"(IKtt, TA.) You say,"},{"kind":"arabic","text_bw":"wukisa fiY tijaAratihi","text_ar":"وُكِسَ فِى تِجَارَتِهِ"},{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"wakosN","text_ar":"وَكْسٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He suffered loss,"},{"kind":"text","text":"(S, A, Msb, TA,) or"},{"kind":"italic_en","text":"diminution of the price,"},{"kind":"text","text":"(TA,) ["},{"kind":"italic_en","text":"in his traffic,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"merchandise;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^uwkisa","text_ar":"اُوكِسَ","orth_type":"arrow"},{"kind":"text","text":", (S, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iykaAsN","text_ar":"اـِيكَاسٌ"},{"kind":"text","text":"; (TA;) and so"},{"kind":"arabic","text_bw":"wakasa","text_ar":"وَكَسَ"},{"kind":"text","text":", aor. (K) and inf. n. (TA) as above. (K, TA.)"}],"source_refs":["S","Msb","TA","TK","A","K"]}]},"classical_definitions":null}