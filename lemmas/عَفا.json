ْفُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْفُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْفُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْفُوْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْف","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَفَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَفَوْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْفُو","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْفُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعْفَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْفَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":144,"cross_references":{"qac":{"found":true,"lemma_key":"عَفا","root":"عفو","pos":"V","occurrence_count":27},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n29771","n29777","n29778"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%81%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to obliterate, to eliminate the past mistakes"},{"pos":"verb","gloss":"to be obliterated, to be cleared, to be amnestied"},{"pos":"verb","gloss":"to pardon (عَن (ʕan))"},{"pos":"verb","gloss":"to excuse"},{"pos":"verb","gloss":"to desist"}]},"etymology":null,"ipa":["/ʕa.faː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29771","headword_ar":"عَفَا","root":"Efw","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEofuw","text_ar":"يَعْفُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"EafaA='N","text_ar":"عَفَا=ءٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"Eufuw~N","text_ar":"عُفُوٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":", (Msb, K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, effaced, erased, rased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obliterated;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tEf~Y","text_ar":"تعفّى","orth_type":"arrow"},{"kind":"text","text":": (K:) and"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, perished, came to nought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to an end,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"died."},{"kind":"text","text":"(S, TA.) One says,"},{"kind":"arabic","text_bw":"EafaA AlA^avaru","text_ar":"عَفَا الاَثَرُ"},{"kind":"italic_en","text":"The trace, vestige,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, effaced,"},{"kind":"text","text":"&c. (TA.) And [hence,]"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"arabic","text_bw":"A^avaruhu","text_ar":"اَثَرُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EafaA='N","text_ar":"عَفَا=ءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"died."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"arabic","text_bw":"Almanozilu","text_ar":"المَنْزِلُ"},{"kind":"text","text":", aor. as above. (S, Msb,) and so the inf. ns. as in the first sentence, (Msb,)"},{"kind":"italic_en","text":"the place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became effaced,"},{"kind":"text","text":"&c., (S, Msb:) and"},{"kind":"arabic","text_bw":"Eafat Ald~aAru","text_ar":"عَفَت الدَّارُ"},{"kind":"text","text":". aor."},{"kind":"arabic","text_bw":"tEofuw","text_ar":"تعْفُو"},{"kind":"text","text":", inf. a"},{"kind":"arabic","text_bw":"EafaA='N","text_ar":"عَفَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eufuw~N","text_ar":"عُفُوٌّ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":"]: (TA;) and ↓"},{"kind":"arabic","text_bw":"taEaf~at","text_ar":"تَعَفَّت","orth_type":"arrow"},{"kind":"text","text":", (S, TA.) and ↓"},{"kind":"arabic","text_bw":"Eaf~at","text_ar":"عَفَّت","orth_type":"arrow"},{"kind":"text","text":"also; (TA;)"},{"kind":"italic_en","text":"The house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, effaced,"},{"kind":"text","text":"&c. (S, TA) A'Obeyd cites, as an ex. of"},{"kind":"arabic","text_bw":"AlEafaA='u","text_ar":"العَفَا=ءُ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"the being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, effaced,"},{"kind":"text","text":"&c., and"},{"kind":"italic_en","text":"the perishing,"},{"kind":"text","text":"&c., the saying of Zuheyr, (S, TA.) mentioning a dwelling, or an abode, (TA.)"},{"kind":"quote","text":"taHam~alu A^ahulahaA EanohaA fabaAnuwA\n                      \n                     \n                        EalaY A=vaAri maA *ahaba AlEafaA='u"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Its occupants departed from it, and separated themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed far away; may the state of that which is effaced,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"be"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rest, upon the traces of what has gone away;"},{"kind":"text","text":"or the meaning may be,"},{"kind":"italic_en","text":"dust is upon the traces"},{"kind":"text","text":"&c., (see"},{"kind":"arabic","text_bw":"EafaA='N","text_ar":"عَفَا=ءٌ"},{"kind":"text","text":"as a subst., below;) but it is not thus accord to A 'Obeyd; for] he says, This is like their saying"},{"kind":"arabic","text_bw":"Ealayohi Ald~abaAru","text_ar":"عَلَيْهِ الدَّبَارُ"},{"kind":"text","text":"as an imprecation against one expressing a prayer that he may go away and"},{"kind":"italic_en","text":"not return."},{"kind":"text","text":"(S, TA.) MF says that"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"text","text":"is one of those verbs that have contr. significations, for at signifies"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unapparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperceptible"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perceptible:"},{"kind":"text","text":"and it has two other contr. significations, which will be mentioned in what follows (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":"signifies also The act of"},{"kind":"italic_en","text":"effacing, erasing, rasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obliterating."},{"kind":"text","text":"(K, TA.) One says,"},{"kind":"arabic","text_bw":"Eafati Alr~iyHu AlA^avara","text_ar":"عَفَتِ الرِّيحُ الاَثَرَ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"Almanozila","text_ar":"المَنْزِلَ"},{"kind":"text","text":", (S, Msb,) and"},{"kind":"arabic","text_bw":"Ald~aAra","text_ar":"الدَّارَ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"the wind effaced,"},{"kind":"text","text":"&c, (S, Msb, TA,)"},{"kind":"italic_en","text":"the trace, vestige,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"the place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"(S, Msb,) and"},{"kind":"italic_en","text":"the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling,"},{"kind":"text","text":"or"},{"kind":"page_break","n":2093},{"kind":"italic_en","text":"abode:"},{"kind":"text","text":"(TA:) and in like manner,"},{"kind":"arabic","text_bw":"Alr~iyHu","text_ar":"الرِّيحُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Eaf~ati","text_ar":"عَفَّتِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ald~aAra","text_ar":"الدَّارَ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"taEofiyapN","text_ar":"تَعْفِيَةٌ"},{"kind":"text","text":", (TA,) in which the verb is with teshdeed to denote intensiveness [of the signification, i. e."},{"kind":"italic_en","text":"the wind effaced,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"mightily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utterly, the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode"},{"kind":"text","text":"]: (S, TA:) and"},{"kind":"arabic","text_bw":"EalaY A^avarihi","text_ar":"عَلَى اَثَرِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Eaf~aY","text_ar":"عَفَّى","orth_type":"arrow"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, effaced its,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his, trace, vestige,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint."},{"kind":"text","text":"(MA.) ―         -b3-  Hence, as some say,"},{"kind":"arabic","text_bw":"EafaA A@ll~`hu Eanoka","text_ar":"عَفَا ا@للّٰهُ عَنْكَ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"May God efface"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from thee"},{"kind":"text","text":"thy sin, &c.; meaning"},{"kind":"italic_en","text":"may God absolve thee"},{"kind":"text","text":"]; (TA;) or"},{"kind":"italic_en","text":"may God efface thy sins:"},{"kind":"text","text":"(Msb:) [and"},{"kind":"arabic","text_bw":"EufiYa Eanohu","text_ar":"عُفِىَ عَنْهُ"},{"kind":"italic_en","text":"May he be absolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forgiven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pardoned:"},{"kind":"text","text":"] and hence the saying in a trad.,"},{"kind":"arabic","text_bw":"saluwA A@ll~`ha AlEafowa","text_ar":"سَلُوا ا@للّٰهَ العَفْوَ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"Ask ye of God"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the effacement of sin;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ask ye of God absolution,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forgiveness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pardon;"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"AlmuEaAfaApa","text_ar":"المُعَافَاةَ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlEaAfiyapa","text_ar":"العَافِيَةَ","orth_type":"arrow"},{"kind":"text","text":"[which have a similar meaning: see 3]: (TA:) and one says,"},{"kind":"arabic","text_bw":"Eafawotu Eano *anobihi","text_ar":"عَفَوْتُ عَنْ ذَنْبِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I left him, and did not punish him:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"Eafawotu Eanohu","text_ar":"عَفَوْتُ عَنْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eafawotu Eano *anobihi","text_ar":"عَفَوْتُ عَنْ ذَنْبِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eafawotu","text_ar":"عَفَوْتُ"},{"kind":"arabic","text_bw":"lahu Eano *anobihi","text_ar":"لَهُ عَنْ ذَنْبِهِ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"I turned away from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from his crime, sin, fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SafaHotu Eanohu","text_ar":"صَفَحْتُ عَنْهُ"},{"kind":"text","text":"; and"},{"kind":"italic_en","text":"I turned away"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aEoraDotu","text_ar":"اَعْرَضْتُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from punishing him:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the turning away"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlS~afoHu","text_ar":"الصَّفْحُ"},{"kind":"text","text":", K, TA) from the committer of a crime or the like; (TA;) and"},{"kind":"italic_en","text":"the relinquishing the punishment of the deserving"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]: and one says,"},{"kind":"arabic","text_bw":"EafaA Eanohu","text_ar":"عَفَا عَنْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EafaA lahu *anobahu","text_ar":"عَفَا لَهُ ذَنْبَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eano *anobihi","text_ar":"عَنْ ذَنْبِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he turned away from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from his crime,"},{"kind":"text","text":"&c; and"},{"kind":"italic_en","text":"relinquished the infliction of his merited punishment,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"forgave him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pardoned him"},{"kind":"text","text":"]: (K, TA:) or"},{"kind":"arabic","text_bw":"EafaA Eanohu *anobahu","text_ar":"عَفَا عَنْهُ ذَنْبَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EafaA lahu *anobahu","text_ar":"عَفَا لَهُ ذَنْبَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eano *anobihi","text_ar":"عَنْ ذَنْبِهِ"},{"kind":"text","text":": (so accord. to the CK:) accord. to MF, the primary signification of"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Alt~aroku","text_ar":"التَّرْكُ"},{"kind":"text","text":": but this is not the case: and"},{"kind":"arabic","text_bw":"AlS~afoHu","text_ar":"الصَّفْحُ"},{"kind":"text","text":"[by which it is expl. in the K] is [or rather implies] the relinquishing of blame, or reproof, or of severe, or angry, blame or reproof; and this is more than [is signified by]"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":", for the latter is sometimes without the former: the primary signification of"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":"[when trans.] is [said to be]"},{"kind":"italic_en","text":"the purposing to take a"},{"kind":"text","text":"thing; and Er-Rághib says that"},{"kind":"arabic","text_bw":"Eafawotu Eanoka","text_ar":"عَفَوْتُ عَنْكَ"},{"kind":"text","text":"is as though it meant"},{"kind":"italic_en","text":"I have purposed to remove"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"to take away"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thy crime"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(TA:) [but I think that the primary signification of"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":"when its object is a crime or the like is that of"},{"kind":"italic_en","text":"effacement:"},{"kind":"text","text":"and hence likewise what next follows:] ―         -b4-"},{"kind":"arabic","text_bw":"AlEafowu","text_ar":"العَفْوُ"},{"kind":"text","text":"is also metaphorically used as meaning (tropical:)"},{"kind":"italic_en","text":"The withdrawing"},{"kind":"text","text":"from a right, or due, and from seeking, or demanding, it: and thus the verb is used in the Kur ii. 238 [q. v.]: and in the saying of the Prophet,"},{"kind":"arabic","text_bw":"EafawonaA lakumo Eano Sadaqapi Alxayoli waAlr~aqiyqi","text_ar":"عَفَوْنَا لَكُمْ عَنْ صَدَقَةِ الخَيْلِ وَالرَّقِيقِ"},{"kind":"text","text":"[i. e. (tropical:)"},{"kind":"italic_en","text":"We have remitted to you the poor-rate of horses and of the slave"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slaves"},{"kind":"text","text":"]: (Mgh:) [and hence]"},{"kind":"arabic","text_bw":"Eafawotu Eani AlHaq~i","text_ar":"عَفَوْتُ عَنِ الحَقِّ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"I have annulled"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"remitted"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due;"},{"kind":"text","text":"as though I erased it from [the account of] him who owed it: (Msb:) and"},{"kind":"arabic","text_bw":"Eafawotu lahu Eano maA liY Ealayohi","text_ar":"عَفَوْتُ لَهُ عَنْ مَا لِى عَلَيْهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I have relinquished"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"remitted"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to him what was due to me on his part."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, much in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many in number:"},{"kind":"text","text":"(Msb, MF, TA:) and also the contr., i. e."},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, little in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"few in number."},{"kind":"text","text":"(MF, TA.) It is said in the former sense of hair, and of herbage, &c.: (S:) or, said of hair,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long, and much in quantity;"},{"kind":"text","text":"(TA;) and said of the hair of a camel, (K,) or of the hair of a camel's back, (TA,)"},{"kind":"italic_en","text":"it became abundant and long, and covered his rump;"},{"kind":"text","text":"(K, TA;) and said of herbage,"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, much in quantity, and tall."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"EafawoA","text_ar":"عَفَوْا"},{"kind":"text","text":"in the Kur vii. 93 means"},{"kind":"italic_en","text":"They became many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"numerous."},{"kind":"text","text":"(S, Msb.) And"},{"kind":"arabic","text_bw":"Eafati AlA^aroDu","text_ar":"عَفَتِ الاَرْضُ"},{"kind":"italic_en","text":"The land became covered with herbage."},{"kind":"text","text":"(K and TK. [In the CK,"},{"kind":"arabic","text_bw":"wAlArDa","text_ar":"والارضَ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"waAlA^aroDu","text_ar":"وَالاَرْضُ"},{"kind":"text","text":".]) ―         -b2-  And"},{"kind":"arabic","text_bw":"Eafawotuhu","text_ar":"عَفَوْتُهُ"},{"kind":"italic_en","text":"I made it to become much in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many in number;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^aEofayotuhu","text_ar":"اَعْفَيْتُهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, * Msb, TA; *) and so ↓"},{"kind":"arabic","text_bw":"Eaf~ayotuhu","text_ar":"عَفَّيْتُهُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) Accord. to Es-Sarakustee, one says,"},{"kind":"arabic","text_bw":"Eafawotu Al$~aEara","text_ar":"عَفَوْتُ الشَّعَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^aEofuwhu","text_ar":"اَعْفُوهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Eafayotuhu","text_ar":"عَفَيْتُهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^aEofiyhi","text_ar":"اَعْفِيهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EafaYN","text_ar":"عَفَىٌ"},{"kind":"text","text":"; meaning"},{"kind":"italic_en","text":"I left the hair to become abundant and long."},{"kind":"text","text":"(Msb.) And one says,"},{"kind":"arabic","text_bw":"All~iHoyapa","text_ar":"اللِّحْيَةَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AEfY","text_ar":"اعفى","orth_type":"arrow"},{"kind":"italic_en","text":"He left the beard to become abundant and long,"},{"kind":"text","text":"(Mgh, K, TA,)"},{"kind":"italic_en","text":"having ceased from cutting it:"},{"kind":"text","text":"(Mgh:) whence, (TA,) it is said in a trad.,"},{"kind":"arabic","text_bw":"A^amara A^ano tuHofaY","text_ar":"اَمَرَ اَنْ تُحْفَى"},{"kind":"arabic","text_bw":"Al$~awaAribu watuEofaY All~uHaY","text_ar":"الشَّوَارِبُ وَتُعْفَى اللُّحَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He commanded that the mustaches should be clipped closely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much, and that the beards should be left to become abundant and long"},{"kind":"text","text":"]: (S, TA:) or"},{"kind":"arabic","text_bw":"A^aHofuwA Al$~awaAriba waA^aEofuwA","text_ar":"اَحْفُوا الشَّوَارِبَ وَاَعْفُوا"},{"kind":"arabic","text_bw":"All~iHaY","text_ar":"اللِّحَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Clip ye"},{"kind":"text","text":"&c.], and one may also use the unaugmented verb [saying"},{"kind":"arabic","text_bw":"waA@EofuwA","text_ar":"وَا@عْفُوا"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"text","text":"]. (Msb, TA.) And"},{"kind":"arabic","text_bw":"$aEara AlbaEiyri","text_ar":"شَعَرَ البَعِيرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEofayotu","text_ar":"اَعْفَيْتُ","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"$aEara Zahori AlbaEiyri","text_ar":"شَعَرَ ظَهْرِ البَعِيرِ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"I left the hair of the camel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the hair of the back of the camel, to become abundant and long;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Eaf~ayotuhu","text_ar":"عَفَّيْتُهُ","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;) this latter with teshdeed. (TA. [In the CK,"},{"kind":"arabic","text_bw":"Eafayotuhu","text_ar":"عَفَيْتُهُ"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"EafaA AlS~uwfa","text_ar":"عَفَا الصُّوفَ"},{"kind":"text","text":", expl. in the K as signifying"},{"kind":"italic_en","text":"He shore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheared, the wool,"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he left the wool to become abundant and long, then shore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheared, it."},{"kind":"text","text":"(TA.)       -A3-  Also, inf. n."},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"faDala","text_ar":"فَضَلَ"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superfluous;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it remained over and above"},{"kind":"text","text":"]. (Msb.) You say,"},{"kind":"arabic","text_bw":"xu*o maA SafaA waEafaA","text_ar":"خُذْ مَا صَفَا وَعَفَا"},{"kind":"text","text":", [correctly,"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"arabic","text_bw":"EafaA waSafaA","text_ar":"عَفَا وَصَفَا"},{"kind":"text","text":",] meaning"},{"kind":"arabic","text_bw":"faDala watasah~ala","text_ar":"فَضَلَ وَتَسَهَّلَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Take thou what has exceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become redundant, and has become facilitated"},{"kind":"text","text":"]. (Mgh.) ―         -b2-  [And"},{"kind":"italic_en","text":"He exceeded."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"EafaA Ealayohi fiY AlEilomi","text_ar":"عَفَا عَلَيْهِ فِى العِلْمِ"},{"kind":"italic_en","text":"He exceeded him in knowledge;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"huwa yaEofuw","text_ar":"هُوَ يَعْفُو"},{"kind":"arabic","text_bw":"EalaY munoyapi Almutaman~iY wasuw^aAli Als~aAy^ili","text_ar":"عَلَى مُنْيَةِ المُتَمَنِّى وَسُوَالِ السَّايِلِ"},{"kind":"italic_en","text":"He exceeds, in giving, the wish of the wisher and the petition of the petitioner."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eafawotu lahu bimaAliY","text_ar":"عَفَوْتُ لَهُ بِمَالِى"},{"kind":"italic_en","text":"I exceeded to him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what was incumbent on me"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with my property, and gave him."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EafaA","text_ar":"عَفَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEofuw","text_ar":"يَعْفُو"},{"kind":"text","text":", signifies also [simply]"},{"kind":"italic_en","text":"He gave."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"AEfAhu","text_ar":"اعفاهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He gave to him,"},{"kind":"text","text":"namely, one seeking, or demanding, his beneficence. (Ham pp. 377 and 723.) And"},{"kind":"arabic","text_bw":"biHaq~ihi","text_ar":"بِحَقِّهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AEfAhu","text_ar":"اعفاهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He gave to him fully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wholly, his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due."},{"kind":"text","text":"(Har p. 117.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Eafawotu lahu mina Almaraqi","text_ar":"عَفَوْتُ لَهُ مِنَ المَرَقِ"},{"kind":"italic_en","text":"I laded out for him first, and gave to him in preference, some of the broth."},{"kind":"text","text":"(S. [See"},{"kind":"arabic","text_bw":"EifaAwapN","text_ar":"عِفَاوَةٌ"},{"kind":"text","text":".]) ―         -b5-  And"},{"kind":"arabic","text_bw":"Eafawotu Alqidora","text_ar":"عَفَوْتُ القِدْرَ"},{"kind":"italic_en","text":"I left in the bottom of the cooking-pot"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as a gratuity for the lender thereof"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the last of the broth, which is termed the"},{"kind":"arabic","text_bw":"EufaAwap","text_ar":"عُفَاوَة"},{"kind":"text","text":". (S.)       -A4-  And"},{"kind":"arabic","text_bw":"Eafawotu Alr~ajula","text_ar":"عَفَوْتُ الرَّجُلَ"},{"kind":"italic_en","text":"I asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petitioned, the man."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Eafawotuhu","text_ar":"عَفَوْتُهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AiEotafayotuhu","text_ar":"اِعْتَفَيْتُهُ","orth_type":"arrow"},{"kind":"italic_en","text":"I came to him seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding, his beneficence:"},{"kind":"text","text":"you say,"},{"kind":"arabic","text_bw":"fulaAnN taEofuwhu AlA^aDoyaAfu","text_ar":"فُلَانٌ تَعْفُوهُ الاَضْيَافُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taEotafiyhi","text_ar":"تَعْتَفِيهِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one, guests come to him seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding, his hospitality"},{"kind":"text","text":"]. (S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Eafati AlA_ibilu AlmaroEaY","text_ar":"عَفَتِ الاـِبِلُ المَرْعَى"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"taEofuwhu","text_ar":"تَعْفُوهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The camels took"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"cropped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the pasture near by."},{"kind":"text","text":"(K, TA.)       -A5-"},{"kind":"arabic","text_bw":"EafaA AlmaA='u","text_ar":"عَفَا المَا=ءُ"},{"kind":"italic_en","text":"The water was untrodden by what would render it turbid."},{"kind":"text","text":"(S, K.)"}],"source_refs":["S","Msb","K","TA","Mgh","MF"]},{"entry_id":"n29777","headword_ar":"عَفًا","root":"Efw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EafowN","text_ar":"عَفْوٌ"},{"kind":"text","text":", second and last sentences."}],"source_refs":[]},{"entry_id":"n29778","headword_ar":"عِفًا","root":"Efw","body":[{"kind":"text","text":": see the next paragraph, last sentence."}],"source_refs":[]}]}}