و","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغْدُو","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adv","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n31532"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%AF%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adv","gloss":"tomorrow"},{"pos":"verb","gloss":"go away, leave, come, do something, or exist early in the morning"},{"pos":"verb","gloss":"to become, to turn into, to come to be","tags":["copulative"]}]},"etymology":{"source":"wiktextract","text":"Adverbial accusative of غَد (ḡad, “morrow; tomorrow”, noun)."},"ipa":["/ɣa.dan/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31532","headword_ar":"غَدَا","root":"gdw","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"arabic","text_bw":"yagoduw","text_ar":"يَغْدُو"},{"kind":"text","text":", (S, M, Msb,) inf. n."},{"kind":"arabic","text_bw":"Euduw~N","text_ar":"عُدُوٌّ"},{"kind":"text","text":"(S, M, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"gadowN","text_ar":"غَدْوٌ"},{"kind":"text","text":"(M, TA, and so accord. to the CK instead of"},{"kind":"arabic","text_bw":"guduw~N","text_ar":"غُدُوٌّ"},{"kind":"text","text":"[which is the only inf. n. commonly known]) and"},{"kind":"arabic","text_bw":"gudowapN","text_ar":"غُدْوَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, in the time called"},{"kind":"arabic","text_bw":"gudowap","text_ar":"غُدْوَة"},{"kind":"text","text":", (Mgh, Msb,) i. e. ["},{"kind":"italic_en","text":"the early part of the morning,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the period between the prayer of daybreak and sunrise:"},{"kind":"text","text":"this is the primary signification: (Msb:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"bak~ara","text_ar":"بَكَّرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he went forth early in the morning; in the first part of the day;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between the time of the prayer of daybreak and sunrise"},{"kind":"text","text":"]; so in the phrase"},{"kind":"arabic","text_bw":"gadaA Ealayohi","text_ar":"غَدَا عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he went forth early in the morning,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; (K;) as also ↓"},{"kind":"arabic","text_bw":"AgtdY","text_ar":"اغتدى","orth_type":"arrow"},{"kind":"text","text":": (S, * K:) and ↓"},{"kind":"arabic","text_bw":"gAdAhu","text_ar":"غاداهُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"gadaA Ealayohi","text_ar":"غَدَا عَلَيْهِ"},{"kind":"text","text":"; (S;) or the same as"},{"kind":"arabic","text_bw":"baAkarahu","text_ar":"بَاكَرَهُ"},{"kind":"text","text":"[which is syn. with"},{"kind":"arabic","text_bw":"bak~ara Ealayohi","text_ar":"بَكَّرَ عَلَيْهِ"},{"kind":"text","text":"as expl. above; and signifies also, like"},{"kind":"arabic","text_bw":"bak~ara Ealayohi","text_ar":"بَكَّرَ عَلَيْهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he hastened to it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do it,"},{"kind":"text","text":"at any time, morning or evening]: (ISd, K, TA:)"},{"kind":"arabic","text_bw":"Alguduw~u","text_ar":"الغُدُوُّ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the contr of"},{"kind":"arabic","text_bw":"Alr~awaAHu","text_ar":"الرَّوَاحُ"},{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"raAHa","text_ar":"رَاحَ"},{"kind":"text","text":"]. (S.) Hence, in the Kur [lxviii. 22],"},{"kind":"arabic","text_bw":"A^ani A@goduwA EalaY Harovikumo","text_ar":"اَنِ ا@غْدُوا عَلَى حَرْثِكُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Saying, Go ye forth early,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to your land's produce"},{"kind":"text","text":"]: and the saying of a poet,"},{"kind":"quote","text":"waAlT~ayoru fiY wukunaAtihaA ↓ \n      waqado A^agotadiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And sometimes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, I go forth early,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"while the birds are in their nests"},{"kind":"text","text":"]. (TA.) ―         -b2-  Afterwards, by reason of frequency of use, it became employed as meaning"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed,"},{"kind":"text","text":"at any time. (Mgh, * Msb, TA.) Hence the saying, (Mgh, Msb,) of the Prophet, (Msb,) in a trad., (Mgh,)"},{"kind":"arabic","text_bw":"Augodu yaA A^unayosu","text_ar":"اُغْدُ يَا اُنَيْسُ"},{"kind":"text","text":", (Mgh, Msb,) meaning"},{"kind":"italic_en","text":"Depart then, O Uneys"},{"kind":"text","text":"(Msb.) ―         -b3-  [Freytag bas erroneously assigned to it another meaning, i. e. “ Nutrivit ” misled by his finding"},{"kind":"arabic","text_bw":"tagoduwo","text_ar":"تَغْدُوْ"},{"kind":"text","text":"put for"},{"kind":"arabic","text_bw":"tago*uw","text_ar":"تَغْذُو"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"TlY","text_ar":"طلى"},{"kind":"text","text":"in the CK.] ―         -b4-"},{"kind":"arabic","text_bw":"gadiYa","text_ar":"غَدِىَ"},{"kind":"text","text":": see 5."}],"source_refs":["S","M","Msb","K","Mgh","ISd","TA"]}]}}