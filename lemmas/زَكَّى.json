:[{"pos":"verb","gloss":"to give alms or charity","examples":[{"text":"قَدْ أَفْلَحَ مَنْ زَكَّىٰهَا / وَقَدْ خَابَ مَن دَسَّىٰهَا","english":"He has succeeded who shares his boons, / And he has failed who hoards it"}]},{"pos":"verb","gloss":"to purify, to cleanse by having performed a ritual","examples":[{"text":"خُذْ مِنْ أَمْوَالِهِمْ صَدَقَةً تُطَهِّرُهُمْ وَتُزَكِّيهِم بِهَا وَصَلِّ عَلَيْهِمْ إِنَّ صَلَوَاتَكَ سَكَنٌ لَّهُمْ وَٱللَّهُ سَمِيعٌ عَلِيمٌ","english":"Take charity from their wealth, wherewith thou mayst cleanse and purify them, and pray for them. Lo! thy prayer is an assuagement for them. God listens and notes."}]},{"pos":"verb","gloss":"to declare purified or commendable","examples":[{"text":"فَلَا تُزَكُّوٱ أَنْفُسَكُمْ هُوَ أَعْلَمُ بِمَنِ ٱتَّقَى","english":"Therefor ascribe not purity unto yourselves. He is Best Aware of him who wardeth off (evil)."}]}]},"etymology":{"source":"wiktextract","text":"Borrowed from Aramaic זַּכֵּי (zakkē). In effect, the same as a denominal verb from زَكَاة (zakāh)."},"ipa":["/zak.kaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17938","headword_ar":"زَكِىٌّ","root":"zkw","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"zaAkK","text_ar":"زَاكٍ","orth_type":"arrow"},{"kind":"text","text":", (Akh, S,) which signifies"},{"kind":"italic_en","text":"Increasing"},{"kind":"text","text":"[&c., as act part. n. of"},{"kind":"arabic","text_bw":"zakaA","text_ar":"زَكَا"},{"kind":"text","text":", q. v.]: (Ham p. 722:) [and"},{"kind":"italic_en","text":"growing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thriving"},{"kind":"text","text":"]: applied in this sense to a boy. (Akh, S.) ―         -b2-"},{"kind":"arabic","text_bw":"gulaAmFA zakiy~FA","text_ar":"غُلَامًا زَكِيًّا"},{"kind":"text","text":"in the Kur xix. 19 means ["},{"kind":"italic_en","text":"A boy"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"pure from sins:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"growing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"increasing, in goodness and righteousness:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"purified by nature:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as shall in the future become purified."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"nafosFA zakiy~apF","text_ar":"نَفْسًا زَكِيَّةً"},{"kind":"text","text":"in the Kur xviii. 73 means ["},{"kind":"italic_en","text":"A soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"person,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"pure from sins:"},{"kind":"text","text":"some read ↓"},{"kind":"arabic","text_bw":"zaAkiyapF","text_ar":"زَاكِيَةً","orth_type":"arrow"},{"kind":"text","text":"; but the former is more forcible: [or,] accord. to AA, ↓ the latter means"},{"kind":"italic_en","text":"that has never sinned:"},{"kind":"text","text":"and the former,"},{"kind":"italic_en","text":"that has sinned and then been forgiven."},{"kind":"text","text":"(Bd.) [Or]"},{"kind":"arabic","text_bw":"rajulN zakiY~N","text_ar":"رَجُلٌ زَكِىٌّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"righteous, man:"},{"kind":"text","text":"and the pl. is"},{"kind":"arabic","text_bw":"A^azokiyaA='u","text_ar":"اَزْكِيَا=ءُ"},{"kind":"text","text":". (Msb, K, * TA.) And also"},{"kind":"italic_en","text":"A man enjoying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leading, a plentiful, and a pleasant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an easy, and a soft"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate, life:"},{"kind":"text","text":"pl. as above. (K, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A^aroDN zakiy~apN","text_ar":"اَرْضٌ زَكِيَّةٌ"},{"kind":"italic_en","text":"Good, fat land."},{"kind":"text","text":"(TA in art"},{"kind":"arabic","text_bw":"zkY","text_ar":"زكى"},{"kind":"text","text":".)"}],"source_refs":["Akh","S","Bd"]},{"entry_id":"n17943","headword_ar":"زَكِىٌّ","root":"zkY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"zkw","text_ar":"زكو"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n17942","headword_ar":"زَكِىَ","root":"zkY","body":[{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yazokaY","text_ar":"يَزْكَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zakaApN","text_ar":"زَكَاةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"zakaA","text_ar":"زَكَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazokuw","text_ar":"يَزْكُو"},{"kind":"text","text":", as meaning"},{"kind":"italic_en","text":"It increased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"augmented;"},{"kind":"text","text":"(Lh, ISd, K, * TA;) and"},{"kind":"italic_en","text":"produced fruit:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"tzk~Y","text_ar":"تزكّى","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (K.)       -A2-  Also"},{"kind":"italic_en","text":"He thirsted."},{"kind":"text","text":"(Th, K.)"}],"source_refs":["K","TA"]}]}}