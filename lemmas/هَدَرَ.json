:null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَهْدِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْدِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْدُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْدُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهْدِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْدِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَهْدُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَهْدِر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْدِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"هَدَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَدَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَهْدُر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْدُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n41027"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to rumble, to roar, to shout, to rut, to bubble, to growl, to bray, to swirl, to come off noisily (human, beast, sea, cannon, whatever)","tags":["ambitransitive"]},{"pos":"verb","gloss":"to seethe, to boil, to simmer, to scald","tags":["ambitransitive"],"examples":[{"text":"إِذَا هَدَرَ الْعَصِيرَ رَأَيْتَهُمْ حُمْرًا عُيُونُهُمُ مِنَ الْمُسْطَارِ","english":"When they seethe the juice you see them red in the eyes from the defrutum."}]},{"pos":"verb","gloss":"to be spilled, to run off, to go amiss, to vanish to no avail, to go for nothing","tags":["intransitive"],"examples":[{"text":"الْحَنَفِيَّةُ فِي الْمَطْبَخِ تَقْطُرُ، مِمَّا يَهْدِرُ الْمَاءُ كُلَّ يَوْمٍ.","english":"The faucet in the kitchen drips, wasting water every day."}]},{"pos":"verb","gloss":"to rumble, to roar, to shout, to rut, to growl","tags":["intransitive"]},{"pos":"noun","gloss":"verbal noun of هَدَر (hadar) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"fall, downfall, tumble"},{"pos":"adj","gloss":"indolent, tardy, clumsy, hulking"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41027","headword_ar":"هَدَرَ","root":"hdr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"hadorN","text_ar":"هَدْرٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"hadarN","text_ar":"هَدَرٌ"},{"kind":"text","text":", (K,) or the latter is a simple subst., (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a man's blood, S, A, Msb, K, or another thing, K)"},{"kind":"italic_en","text":"went for nothing;"},{"kind":"text","text":"[meaning, in the case of blood,"},{"kind":"italic_en","text":"unretaliated, and uncompensated by a mulet;"},{"kind":"text","text":"as shown below, voce"},{"kind":"arabic","text_bw":"hadarN","text_ar":"هَدَرٌ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, of no account, null,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"void;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Ahdr","text_ar":"اهدر","orth_type":"arrow"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"hadarahu","text_ar":"هَدَرَهُ"},{"kind":"text","text":", (A, Msb, K,) aor."},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Msb, K, or the Sultán, S, A,)"},{"kind":"italic_en","text":"made it"},{"kind":"text","text":"(a man's blood)"},{"kind":"italic_en","text":"to go for nothing;"},{"kind":"text","text":"[meaning,"},{"kind":"italic_en","text":"unretaliated, and uncompensated by a mulct;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he made it to be of no account;"},{"kind":"text","text":"(A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Ahdrhu","text_ar":"اهدرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, Msb, K;) which means"},{"kind":"italic_en","text":"he made it"},{"kind":"text","text":"(a man's blood)"},{"kind":"italic_en","text":"allowable to be taken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shed."},{"kind":"text","text":"(S, TA.) Thus these two verbs are trans. as well as intrans. (Msb.) It is said in a trad,"},{"kind":"arabic","text_bw":"mani A@T~alaEa fiY daArK bigayori A_i*onK faqado","text_ar":"مَنِ ا@طَّلَعَ فِى دَارٍ بِغَيْرِ اـِذْنٍ فَقَدْ"},{"kind":"arabic","text_bw":"hudirato Eayonuhu","text_ar":"هُدِرَتْ عَيْنُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whoso looketh into a house without permission, his eye shall be allowed to be put out;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the putting out of his eye shall go for nothing, unretaliated, and uncompensated by a mulct."},{"kind":"text","text":"(TA.) One says also,"},{"kind":"arabic","text_bw":"hadarotaniY biA_isoqaATi AlHad~i Ean~iY","text_ar":"هَدَرْتَنِى بِاـِسْقَاطِ الحَدِّ عَنِّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou hast made me"},{"kind":"text","text":"(meaning my offence)"},{"kind":"italic_en","text":"to pass unnoticed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"host taken no account of"},{"kind":"page_break","n":2886},{"kind":"italic_en","text":"me, by annulling in respect of me the prescribed castigation"},{"kind":"text","text":"]. (K, art."},{"kind":"arabic","text_bw":"bhrj","text_ar":"بهرج"},{"kind":"text","text":".) And El-'Ajjáj says,"},{"kind":"quote","text":"wahadara Aljad~a mina Aln~aAsi Alha*aro"},{"kind":"text","text":"which El-Báhilee explains as meaning,"},{"kind":"italic_en","text":"And the worthless people have made good fortune to become of no account."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"ha*ara","text_ar":"هَذَرَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"(K) [and app."},{"kind":"text","text":"also], inf. n."},{"kind":"arabic","text_bw":"hadiyrN","text_ar":"هَدِيرٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"hadorN","text_ar":"هَدْرٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"huduwrN","text_ar":"هُدُورٌ"},{"kind":"text","text":", (TA,) said of a camel, (S, K,) that is advanced in age, (S, in art."},{"kind":"arabic","text_bw":"nqD","text_ar":"نقض"},{"kind":"text","text":",) ["},{"kind":"italic_en","text":"He brayed;"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"he reiterated his voice in his"},{"kind":"arabic","text_bw":"Hanojarap","text_ar":"حَنْجَرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"windpipe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the head of his windpipe"},{"kind":"text","text":"]: (S:) or"},{"kind":"italic_en","text":"he uttered his voice, not in a"},{"kind":"arabic","text_bw":"$iqo$iqap","text_ar":"شِقْشِقَة"},{"kind":"text","text":"[q. v.]: (K:) and ↓"},{"kind":"arabic","text_bw":"hd~r","text_ar":"هدّر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"tahodiyrN","text_ar":"تَهْدِيرٌ"},{"kind":"text","text":", (S,) signifies the same: (S, K:) Z mentions also"},{"kind":"arabic","text_bw":"tahodaArN","text_ar":"تَهْدَارٌ"},{"kind":"text","text":"as an inf. n. of"},{"kind":"arabic","text_bw":"hadara","text_ar":"هَدَرَ"},{"kind":"text","text":"said of a stallion, [meaning a stallioncamel.] (TA.) ―         -b2-  Hence the saying, (TA,)"},{"kind":"arabic","text_bw":"huwa yahodiru fiY manoTiqihi","text_ar":"هُوَ يَهْدِرُ فِى مَنْطِقِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY xuTobatihi","text_ar":"فِى خُطْبَتِهِ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"He is sonorous and fluent in his speech,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in his oration:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"hadarato $iqo$iqatuhu","text_ar":"هَدَرَتْ شِقْشِقَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His utterance was sonorous and fluent."},{"kind":"text","text":"] (A, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"hadara","text_ar":"هَدَرَ"},{"kind":"text","text":"is also said of a calf, [signifying, (assumed tropical:)"},{"kind":"italic_en","text":"He lowed"},{"kind":"text","text":"] (TA, art."},{"kind":"arabic","text_bw":"kt","text_ar":"كت"},{"kind":"text","text":", from the Nh.) ―         -b4-  Also, of a lion, [signifying, (assumed tropical:)"},{"kind":"italic_en","text":"He roared."},{"kind":"text","text":"] (S, TA, voce"},{"kind":"arabic","text_bw":"qaboqaba","text_ar":"قَبْقَبَ"},{"kind":"text","text":".) ―         -b5-  Also"},{"kind":"arabic","text_bw":"hadara","text_ar":"هَدَرَ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":"(Msb, K) and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"hadiyrN","text_ar":"هَدِيرٌ"},{"kind":"text","text":"(S, IKtt, Msb, TA) and"},{"kind":"arabic","text_bw":"hadorN","text_ar":"هَدْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tahodaArN","text_ar":"تَهْدَارٌ"},{"kind":"text","text":", (K,) said of a pigeon (tropical:)"},{"kind":"italic_en","text":"It uttered a cry:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"cooed,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaroqara","text_ar":"قَرْقَرَ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"sajaEa","text_ar":"سَجَعَ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"and reiterated its voice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry, in its"},{"kind":"arabic","text_bw":"Hanojarap","text_ar":"حَنْجَرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"windpipe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the head of its windpipe"},{"kind":"text","text":"]: (A:) its cry being apparently likened to the"},{"kind":"arabic","text_bw":"hadiyr","text_ar":"هَدِير"},{"kind":"text","text":"of the camel: and"},{"kind":"arabic","text_bw":"hadala","text_ar":"هَدَلَ"},{"kind":"text","text":"signifies the same. (TA.) ―         -b6-  Also"},{"kind":"arabic","text_bw":"hadara","text_ar":"هَدَرَ"},{"kind":"text","text":"said of a boy, (As.) when he desires to speak, being young, or little, (Abu-s-Semeyda',) (assumed tropical:)"},{"kind":"italic_en","text":"He uttered a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"hadala","text_ar":"هَدَلَ"},{"kind":"text","text":". (As, TA.) ―         -b7-  It is also said of thunder; inf. n."},{"kind":"arabic","text_bw":"hadiyrN","text_ar":"هَدِيرٌ"},{"kind":"text","text":"; signifying (tropical:)"},{"kind":"italic_en","text":"It made a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"loud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rumbling,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noise,"},{"kind":"text","text":"(A.) ―         -b8-  You say also, of"},{"kind":"arabic","text_bw":"$araAb","text_ar":"شَرَاب"},{"kind":"text","text":"[or wine],"},{"kind":"arabic","text_bw":"ha*ara","text_ar":"هَذَرَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hadorN","text_ar":"هَدْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tahodaArN","text_ar":"تَهْدَارٌ"},{"kind":"text","text":", (S, TA,) meaning, (assumed tropical:)"},{"kind":"italic_en","text":"It fermented;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"galaY","text_ar":"غَلَى"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"hadarato","text_ar":"هَدَرَتْ"},{"kind":"arabic","text_bw":"jar~apN Aln~abiy*i","text_ar":"جَرَّةٌ النَّبِيذِ"},{"kind":"text","text":", (TA,) aor."},{"kind":"text","text":", (A, TA,) inf. n."},{"kind":"arabic","text_bw":"hadiyrN","text_ar":"هَدِيرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tahodaArN","text_ar":"تَهْدَارٌ"},{"kind":"text","text":", (TA,) (tropical:)  ["},{"kind":"italic_en","text":"The jar of"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"italic_en","text":"fermented."},{"kind":"text","text":"] El-Akhtal says, describing wine,"},{"kind":"quote","text":"kum~ato valaAvapa A^aHowaAlK biTiynatihaA\n                      \n                     \n                        Hat~aY A_i*aA Sar~aHato mino biEodi tahodaAri"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was stopped three years with its lump of clay, until, when it became free from froth, after fermenting"},{"kind":"text","text":"]. (S, TA.)"}],"source_refs":["S","A","Msb","K","TA","IKtt"]}]}}