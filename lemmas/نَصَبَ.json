:"wiktextract","senses":[{"pos":"verb","gloss":"to set up, to lay, to erect, to raise, to build","tags":["transitive"],"examples":[{"text":"نَصَبَ نَفْسَهُ لِشَيْءٍ","english":"to dedicate oneself to something"}]},{"pos":"verb","gloss":"to raise the vowel to /a/; to put into the accusative case","tags":["transitive"]},{"pos":"verb","gloss":"to raise the vowel to /a/; to put into the subjunctive mood","tags":["transitive"]},{"pos":"verb","gloss":"to proclaim, to declare, to arrogate to oneself (king, war, sovereignty …)","tags":["ditransitive"]},{"pos":"verb","gloss":"to concern, to be directed at, to focus on, to concentrate on","tags":["formal","transitive"]},{"pos":"verb","gloss":"to swindle, to scam, to ambush","tags":["informal","transitive"]},{"pos":"verb","gloss":"to appoint, to assign","examples":[{"text":"نَصَبَ نَفْسَهُ مَلِكًا","english":"he proclaimed himself king"}]},{"pos":"verb","gloss":"to strive, to labor, to toil","examples":[{"text":"فَإِذَا فَرَغْتَ فَٱنْصَبْ\n وَإِلَىٰ رَبِّكَ فَٱرْغَب","english":"So when thou art free [from thy tasks], then strive [in worship]. And toward thy Lord and Master turn [thy] attention."}]},{"pos":"verb","gloss":"to install, to establish","tags":["transitive"],"examples":[{"text":"عِنْدَمَا نَصَّبْتَ اَلْبَرْنَامَجَ، هَلْ أَنْشَأْتَ لَهُ كَلِمَةِ سِرّ؟","english":"When you installed the program did you set up a password?"}]},{"pos":"verb","gloss":"to appoint, to assign"},{"pos":"noun","gloss":"verbal noun of نَصَبَ (naṣaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"accusative case","tags":["accusative"]},{"pos":"noun","gloss":"subjunctive mood"},{"pos":"noun","gloss":"swindle, trickery, deception, fraud","tags":["colloquial"]},{"pos":"noun","gloss":"an array of stones or a structure set up as a sign or mark to show the way (especially in the desert)"},{"pos":"noun","gloss":"something erected, sculpture, statue, monument","examples":[{"text":"[…]إِنَّمَا الْخَمْرُ وَٱلْمَيْسِرُ وَٱلْأَنْصَابُ وَٱلْأَزْلَامُ رِجْسٌ مِنْ عَمَلِ الشَّيْطَانِ فَٱجْتَنِبُوهُ[…]","english":"[…] Wine/liquor and games of chance/gambling and [sacrificing upon or offering unto] stone altars/statues and [drawing or casting] divination arrows are surely an abomination, of Satan's handiwork, so shun it […]"}]},{"pos":"noun","gloss":"something erected, sculpture, statue, monument","examples":[{"text":"حُرِّمَتْ عَلَيْكُمُ الْمَيْتَةُ وَالدَّمُ[…]وَمَا ذُبِحَ عَلَى النُّصُب[…]","english":"And prohibited unto you are carrion/dead meat and blood […] and what was slain upon the stone altars/statues […]"}]},{"pos":"prep","gloss":"in front of"}]},"etymology":null,"ipa":null}