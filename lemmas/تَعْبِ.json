{"lemma":"تَعْبِ","slug":"تَعْبِ","root":"ت.ع.ب","root_slug":"ت-ع-ب","root_link":"/words/roots/ت-ع-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n3949","n3951"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%92%D8%A8%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to get tired, to wear oneself out"},{"pos":"verb","gloss":"to work hard, to toil, to slave"},{"pos":"noun","gloss":"verbal noun of تَعِبَ (taʕiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"fatigue, weariness"},{"pos":"noun","gloss":"trouble, exertion, labor, toil, drudgery"},{"pos":"noun","gloss":"burden, nuisance, inconvenience, difficulty, hardship"},{"pos":"noun","gloss":"discomfort"},{"pos":"adj","gloss":"tired, weary, exhausted"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3949","headword_ar":"تَعِبَ","root":"tEb","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"taEabN","text_ar":"تَعَبٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"[a man and a beast]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fatigued, tired, wearied"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by labour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeying"},{"kind":"text","text":"&c.], or"},{"kind":"italic_en","text":"jaded;"},{"kind":"text","text":"(S, A, Msb;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"AisotaraAHa","text_ar":"اِسْتَرَاحَ"},{"kind":"text","text":". (K.) ["},{"kind":"arabic","text_bw":"taEabN","text_ar":"تَعَبٌ"},{"kind":"text","text":", which, used as a simple subst., may be rendered"},{"kind":"italic_en","text":"Fatigue, tiredness, weariness,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"state of being jaded,"},{"kind":"text","text":"is here said in the TA to be"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"raAHapN","text_ar":"رَاحَةٌ"},{"kind":"text","text":"; and to signify"},{"kind":"arabic","text_bw":"$id~apu","text_ar":"شِدَّةُ"},{"kind":"arabic","text_bw":"AlEanaA='i","text_ar":"العَنَا=ءِ"},{"kind":"text","text":", which may be rendered"},{"kind":"italic_en","text":"much fatigue"},{"kind":"text","text":"&c.; but accord. to an explanation of the verb of"},{"kind":"arabic","text_bw":"EanaA='N","text_ar":"عَنَا=ءٌ"},{"kind":"text","text":"in the S and TA in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":", this word and"},{"kind":"arabic","text_bw":"taEabN","text_ar":"تَعَبٌ"},{"kind":"text","text":"signify the same. See also"},{"kind":"arabic","text_bw":"matoEabN","text_ar":"مَتْعَبٌ"},{"kind":"text","text":".]"}],"source_refs":["S","A","Msb","K"]},{"entry_id":"n3951","headword_ar":"تَعِبٌ","root":"tEb","body":[{"kind":"italic_en","text":"Fatigued, tired, wearied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mutoEabN","text_ar":"مُتْعَبٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;) but not"},{"kind":"arabic","text_bw":"matoEuwbN","text_ar":"مَتْعُوبٌ"},{"kind":"text","text":". (S, K.) [↓"},{"kind":"arabic","text_bw":"taEobaAn","text_ar":"تَعْبَان","orth_type":"arrow"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"taEobaAnN","text_ar":"تَعْبَانٌ"},{"kind":"text","text":", fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", is used in this sense in the present day.]"}],"source_refs":[]}]},"classical_definitions":null}