xt_ar":"منْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from him"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"AstqY","text_ar":"استقى","orth_type":"arrow"},{"kind":"text","text":". (K, TA. [In the CK is immediately added after this explanation,"},{"kind":"arabic","text_bw":"wsaqiy~FA","text_ar":"وسَقِيًّا"},{"kind":"text","text":": but this is a mistranscription for"},{"kind":"arabic","text_bw":"wataqay~aA^a","text_ar":"وَتَقَيَّاَ"},{"kind":"text","text":"; expressing another signification of these two verbs, which will be expl. below.]) And"},{"kind":"italic_en","text":"He asked, begged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prayed, for rain;"},{"kind":"text","text":"(Msb, * TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AisotamoTara","text_ar":"اِسْتَمْطَرَ"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"mTr","text_ar":"مطر"},{"kind":"text","text":", and Msb. *) [Hence,"},{"kind":"arabic","text_bw":"SalaApu AlAisotisoqaA='i","text_ar":"صَلَاةُ الاِسْتِسْقَا=ءِ"},{"kind":"italic_en","text":"The prayer of the petitioning for rain."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"AstsqY lahaA","text_ar":"استسقى لَهَا"},{"kind":"italic_en","text":"He said"},{"kind":"arabic","text_bw":"saqaAhaAA@ll~`hu","text_ar":"سَقَاهَاا@للّٰهُ"},{"kind":"italic_en","text":"May God send down rain upon it,"},{"kind":"text","text":"namely, a land: see Har p. 300.] ―         -b2-  And"},{"kind":"italic_en","text":"He constrained himself to vomit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vomited intentionally;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taqay~aA^a","text_ar":"تَقَيَّاَ"},{"kind":"text","text":"; [see a statement above, in this paragraph, respecting a mistranscription in the CK;] as also ↓"},{"kind":"arabic","text_bw":"AstqY","text_ar":"استقى","orth_type":"arrow"},{"kind":"text","text":"; (K, TA;) mentioned by ISd. (TA.) ―         -b3-  See also 1, in the last quarter of the paragraph."}],"source_refs":[]}]},"classical_definitions":null}