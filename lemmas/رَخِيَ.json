t","text":"↓"},{"kind":"arabic","text_bw":"raAxiY","text_ar":"رَاخِى","orth_type":"arrow"},{"kind":"text","text":"(JK) (assumed tropical:)"},{"kind":"italic_en","text":"He is in an ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unstraitened,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pleasant,"},{"kind":"italic_en","text":"and a plentiful, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(JK, S, * Msb, TA. * [See also other explanations in art."},{"kind":"arabic","text_bw":"bwl","text_ar":"بول"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"A_in~a *`lika AlA^amoru laya*ohabu min~iY fiY baAlK","text_ar":"اـِنَّ ذٰلِكَ الاَمْرُ لَيَذْهَبُ مِنِّى فِى بَالٍ"},{"kind":"arabic","text_bw":"raxiYK","text_ar":"رَخِىٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily that affair passes away from me, I being in an easy state of mind,"},{"kind":"text","text":"] is said when you are not disquieted, rendered anxious, or grieved, by the affair. (TA.)"}],"source_refs":["Msb","K","JK","S","TA"]}]}}