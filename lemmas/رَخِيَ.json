,"num":"s"},{"role":"past_1mp","form":"رَخِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَخِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n15173"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AE%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15173","headword_ar":"رَخِىٌّ","root":"rxw","body":[{"kind":"text","text":"(Msb, K) and ↓"},{"kind":"arabic","text_bw":"raAxK","text_ar":"رَاخٍ","orth_type":"arrow"},{"kind":"text","text":", (K,) applied to life ("},{"kind":"arabic","text_bw":"Eayo$","text_ar":"عَيْش"},{"kind":"text","text":", Msb, K), (assumed tropical:)"},{"kind":"italic_en","text":"Ample, unstraitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plentiful, in its means,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances:"},{"kind":"text","text":"(Msb, K:) or both applied to a man, (assumed tropical:)"},{"kind":"italic_en","text":"in an ample, an unstraitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plentiful, state of life."},{"kind":"text","text":"(TK.) You say,"},{"kind":"arabic","text_bw":"A_in~ahu lafiY Eayo$K raxiY~K","text_ar":"اـِنَّهُ لَفِى عَيْشٍ رَخِىٍّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Verily he is in an ample, an unstraitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plentiful, state of life"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"huwa raxiY~u AlbaAli","text_ar":"هُوَ رَخِىُّ البَالِ"},{"kind":"text","text":"(JK, S, Msb, TA) and"},{"kind":"arabic","text_bw":"AlbaAli","text_ar":"البَالِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raAxiY","text_ar":"رَاخِى","orth_type":"arrow"},{"kind":"text","text":"(JK) (assumed tropical:)"},{"kind":"italic_en","text":"He is in an ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unstraitened,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pleasant,"},{"kind":"italic_en","text":"and a plentiful, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(JK, S, * Msb, TA. * [See also other explanations in art."},{"kind":"arabic","text_bw":"bwl","text_ar":"بول"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"A_in~a *`lika AlA^amoru laya*ohabu min~iY fiY baAlK","text_ar":"اـِنَّ ذٰلِكَ الاَمْرُ لَيَذْهَبُ مِنِّى فِى بَالٍ"},{"kind":"arabic","text_bw":"raxiYK","text_ar":"رَخِىٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily that affair passes away from me, I being in an easy state of mind,"},{"kind":"text","text":"] is said when you are not disquieted, rendered anxious, or grieved, by the affair. (TA.)"}],"source_refs":["Msb","K","JK","S","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%AE%D9%8A/","headword_ar":"رخي","entries":[{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=71439#6f7687","body_html":"رخي<br> رَخِيَ(n. ac. رَخًا [] )<br>رَخُوَ(n. ac. رِخْوَة [] ) <br>رَخَاوَة [] ) <br>a. Was soft, yielding, flabby, flaccid, enervated.<br> b. see supra.<br> <br> رَخَّيَa. Mixed.<br> <br> رَاْخَيَa. see IV (a)b. Removed to a distance.<br> <br> أَرْخَيَa. Softened; relaxed; unstrung; loosened; made slack;<br> lengthened out, let down. <br>b. Let go, loosened his hold of.<br> c. [acc.<br> or <br> La], Gave the rein to (horse).<br> <br> تَرَاْخَيَa. Was, became lazy; was cowardly; was remiss, dilatory;<br> flagged.<br> b. ['An], Gave up, desisted from; drew back from.<br> c. Rained gently.<br> <br> إِرْتَخَيَa. Was, became soft, yielding &amp;c.; hung down <br> loosely.<br> b. Yielded, gave way; gave up, abandoned; let go.<br> <br> إِسْتَرْخَيَa. see VIII <br> رَِخُو [رَخْي]<br>a. Soft, yielding; pliant, flexible.<br> b. Loose, slack, unstrung, relaxed.<br> c. Easy, comfortable.<br> <br> رِخْوَة []<br>a. Softness.<br> b. Looseness, slackness.<br> <br> رَخَآء []<br>a. Flabbiness; languidness, languor.<br> b. Ease, comfort, affluence.<br> <br> رَخَاوَة []<br>a. see 2t <br> رُخَآء []<br>a. Gentle wind, breeze, zephyr.<br> <br> رَخِيّa. Plentiful; ample.<br> b. see 1 <br> إِرْتِخَآء [ N.<br> Ac.<br> a. VIII], Relaxation."}]}}