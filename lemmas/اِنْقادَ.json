unt":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n36371"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D9%82%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36371","headword_ar":"انقاد","root":"qwd","body":[{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"AinoqiyaAdN","text_ar":"اِنْقِيَادٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a beast)"},{"kind":"italic_en","text":"suffered himself to be led;"},{"kind":"text","text":"(Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AqtAd","text_ar":"اقتاد","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"AstqAd","text_ar":"استقاد","orth_type":"arrow"},{"kind":"text","text":". (A, TA.) You say"},{"kind":"arabic","text_bw":"AnqAd liY","text_ar":"انقاد لِى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AstqAd lY","text_ar":"استقاد لى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tractable to me; gave me the means of leading him."},{"kind":"text","text":"(S, L.) ―         -b2-"},{"kind":"arabic","text_bw":"AnqAd","text_ar":"انقاد"},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"A_inqiyaAdN","text_ar":"اـِنقِيَادٌ"},{"kind":"text","text":", (S, L,) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, submissive, resigned, manageable, easy, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowly;"},{"kind":"text","text":"(S, L, A, K;) as also ↓"},{"kind":"arabic","text_bw":"AstqAd","text_ar":"استقاد","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AnqAd Als~aHaAbu","text_ar":"انقاد السَّحَابُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lil~iryHi","text_ar":"لِلِّريحِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstqAd","text_ar":"استقاد","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The cloud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clouds, became led on by the wind."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"AnqAd","text_ar":"انقاد"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a road)"},{"kind":"italic_en","text":"was easy and direct."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"AnqAd liYa AlT~ariyqu A_ilayohi","text_ar":"انقاد لِىَ الطَّرِيقُ اـِلَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The road to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obvious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifest, to me."},{"kind":"text","text":"(L, K.) ―         -b6-"},{"kind":"arabic","text_bw":"AnqAdt A_ilayohi AlmawaAridu","text_ar":"انقادت اـِلَيْهِ المَوَارِدُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The roads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ways, continued uninterruptedly to it."},{"kind":"text","text":"(As, AM; from a verse of Dhu-r-Rummeh.) See also 1."}],"source_refs":["K","A","S","L"]}]}}