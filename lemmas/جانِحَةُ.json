{"lemma":"جانِحَةُ","slug":"جانِحَةُ","root":"ج.ن.ح","root_slug":"ج-ن-ح","root_link":"/words/roots/ج-ن-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n6454"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D8%A7%D9%86%D9%90%D8%AD%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6454","headword_ar":"جَانِحَةٌ","root":"jnH","body":[{"kind":"text","text":"sing. of"},{"kind":"arabic","text_bw":"jawaAniHu","text_ar":"جَوَانِحُ"},{"kind":"text","text":"; (S, K;) which latter signifies The"},{"kind":"italic_en","text":"ribs of the breast:"},{"kind":"text","text":"(A:) or the"},{"kind":"italic_en","text":"ribs that are beneath"},{"kind":"text","text":"["},{"kind":"italic_en","text":"those called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"taraAy^ib","text_ar":"تَرَايِب"},{"kind":"text","text":","},{"kind":"italic_en","text":"of the part next the breast;"},{"kind":"text","text":"(S, K;) like the"},{"kind":"arabic","text_bw":"DuluwE","text_ar":"ضُلُوع"},{"kind":"text","text":"of the part next the back: (S:) or the"},{"kind":"italic_en","text":"anterior parts of those ribs;"},{"kind":"text","text":"so called because they incline over the heart: or the"},{"kind":"italic_en","text":"short ribs that are in the anterior part of the breast:"},{"kind":"text","text":"or, of a camel and a horse and the like, the"},{"kind":"italic_en","text":"ribs against which lies the shoulder-blade:"},{"kind":"text","text":"and of a man, the"},{"kind":"italic_en","text":"ribs of the back which are called"},{"kind":"arabic","text_bw":"daA^oY","text_ar":"دَاْى"},{"kind":"text","text":","},{"kind":"italic_en","text":"six in number, three on the right and three on the left."},{"kind":"text","text":"(L.)"}],"source_refs":["A","S"]}