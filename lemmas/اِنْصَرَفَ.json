":{"found":true,"entry_ids":["n24220"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%B5%D9%8E%D8%B1%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24220","headword_ar":"انصرف","root":"Srf","body":[{"kind":"text","text":", (S, M, O, K,) inf. n."},{"kind":"arabic","text_bw":"AinoSiraAfN","text_ar":"اِنْصِرَافٌ"},{"kind":"text","text":", (O,) and"},{"kind":"arabic","text_bw":"munoSarafN","text_ar":"مُنْصَرَفٌ"},{"kind":"text","text":"is also sometimes an inf. n. thereof as well as a n. of place, (S,) quasi-pass. of"},{"kind":"arabic","text_bw":"Sarafahu","text_ar":"صَرَفَهُ"},{"kind":"text","text":", (S, M,) said of a thing, (M,) or of a man; (S;) as such signifying"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, from its"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"his"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, therefrom;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"averted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repelled, therefrom:"},{"kind":"text","text":"(M:) [or"},{"kind":"italic_en","text":"shifted from one state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, to another:"},{"kind":"text","text":"(see 1, first sentence:)] or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ainokaf~a","text_ar":"اِنْكَفَّ"},{"kind":"text","text":"; so in the copies of the K; but [this is an inadequate explanation;] the right [or better] explanation is"},{"kind":"arabic","text_bw":"AnokafaA^a","text_ar":"انْكَفَاَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, reverted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returned;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, turned away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back"},{"kind":"text","text":"]; agreeably with what is said in the O. (TA.)"},{"kind":"arabic","text_bw":"vum~a A@noSarafuwA","text_ar":"ثُمَّ ا@نْصَرَفُوا"},{"kind":"text","text":"in the Kur [ix. 128] means"},{"kind":"italic_en","text":"Then they return,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"go back,"},{"kind":"text","text":"from the place in which they have listened: or"},{"kind":"italic_en","text":"then they turn away"},{"kind":"text","text":"from doing aught of that which they have heard. (M.) ―         -b2-  [Accord. to Golius, it signifies also"},{"kind":"italic_en","text":"It ran in a small stream;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"for he explains it as meaning “ manavit: ” but for this he names no authority. ―         -b3-  Said of a noun, it means"},{"kind":"italic_en","text":"It was inflected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declined, with tenween."},{"kind":"text","text":"]"}],"source_refs":["S","M","O","K"]}]},"classical_definitions":null}