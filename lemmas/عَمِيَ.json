le":"past_1mp","form":"عَمِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَمِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1079,"cross_references":{"qac":{"found":true,"lemma_key":"عَمِيَ","root":"عمي","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n30465","n30609","n30618"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%85%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become blind"},{"pos":"verb","gloss":"to not find the right way"},{"pos":"verb","gloss":"to be stupid"},{"pos":"verb","gloss":"to be dark"},{"pos":"verb","gloss":"to be obscure, to be hidden, to be unapparent"},{"pos":"adj","gloss":"common plural of أَعْمَى (ʔaʕmā)","tags":["common","form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30465","headword_ar":"عُمِّىٌّ","root":"Em","body":[{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qum~iY~N","text_ar":"قُمِّىٌّ"},{"kind":"text","text":", (K, TA,) with damm, but in the M"},{"kind":"arabic","text_bw":"Em","text_ar":"عم"},{"kind":"text","text":", (TA, [in which this word is thus doubtfully written, and has been altered, perhaps from"},{"kind":"arabic","text_bw":"Eam~iY~N","text_ar":"عَمِّىٌّ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"qum~iY~N","text_ar":"قُمِّىٌّ"},{"kind":"text","text":"is a word which I do not find in any case other than this, and if any word of the measure"},{"kind":"arabic","text_bw":"fuEoliY~N","text_ar":"فُعْلِىٌّ"},{"kind":"text","text":"were meant,"},{"kind":"arabic","text_bw":"A^um~iY~N","text_ar":"اُمِّىٌّ"},{"kind":"text","text":"would be a much better instance of similarity of form,]) an epithet applied to a man,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EaAm~N","text_ar":"عَامٌّ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"Of the common sort;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EaAm~iY~N","text_ar":"عَامِّىٌّ"},{"kind":"text","text":"]: (K, TA:) and"},{"kind":"arabic","text_bw":"quSoriY~N","text_ar":"قُصْرِىٌّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"qaSoriY~N","text_ar":"قَصْرِىٌّ"},{"kind":"text","text":", (accord. to different copies of the K,) in the M"},{"kind":"arabic","text_bw":"qaSorY","text_ar":"قَصْرى"},{"kind":"text","text":", (TA, [there thus written, only with a fet-hah to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":"and the sign of quiescence to the"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":",]) signifies [the contr., i. e.]"},{"kind":"arabic","text_bw":"xaAS~N","text_ar":"خَاصٌّ"},{"kind":"text","text":". (K, TA.)"},{"kind":"page_break","n":2150}],"source_refs":["K","TA"]},{"entry_id":"n30609","headword_ar":"عَمِىَ","root":"EmY","body":[{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yaEomaY","text_ar":"يَعْمَى"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"EamFY","text_ar":"عَمًى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blind,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"of both eyes;"},{"kind":"text","text":"(Msb, K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"AiEomaAYa","text_ar":"اِعْمَاىَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEomaAyu","text_ar":"يَعْمَايُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AiEomiyaA='N","text_ar":"اِعْمِيَا=ءٌ"},{"kind":"text","text":"; (K;) [said by SM to be like"},{"kind":"arabic","text_bw":"AiroEawaY","text_ar":"اِرْعَوَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaroEawiY","text_ar":"يَرْعَوِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AiroEiwaA='N","text_ar":"اِرْعِوَا=ءٌ"},{"kind":"text","text":"; as though"},{"kind":"arabic","text_bw":"AiEomaAYa","text_ar":"اِعْمَاىَ"},{"kind":"text","text":"were originally"},{"kind":"arabic","text_bw":"AiEomaY~a","text_ar":"اِعْمَىَّ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"AiroEawaY","text_ar":"اِرْعَوَى"},{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"AiroEaw~a","text_ar":"اِرْعَوَّ"},{"kind":"text","text":", both being of the measure"},{"kind":"arabic","text_bw":"AifoEl~a","text_ar":"اِفْعلَّ"},{"kind":"text","text":"; but he adds, correctly, that,] accord. to Sgh,"},{"kind":"arabic","text_bw":"AiEomaAYa","text_ar":"اِعْمَاىَ"},{"kind":"text","text":"is originally like"},{"kind":"arabic","text_bw":"AidohaAmama","text_ar":"اِدْهَامَمَ"},{"kind":"text","text":", which becomes"},{"kind":"arabic","text_bw":"AidohaAm~a","text_ar":"اِدْهَامَّ"},{"kind":"text","text":", [i. e. it is originally"},{"kind":"arabic","text_bw":"AiEomaAyaYa","text_ar":"اِعْمَايَىَ"},{"kind":"text","text":",] but the latter"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"because of the fet-hah of the former, so that it becomes"},{"kind":"arabic","text_bw":"AiEomaAyaA","text_ar":"اِعْمَايَا"},{"kind":"text","text":", and the two, thus differing, do not easily admit of idghám (TA;) and sometimes the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"AiEomaAYa","text_ar":"اِعْمَاىَ"},{"kind":"text","text":"is musheddedeh, (Sgh, K, TA,) so that it becomes [↓"},{"kind":"arabic","text_bw":"AiEomaAY~a","text_ar":"اِعْمَاىَّ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEomaAY~u","text_ar":"يَعْمَاىُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AiEmiy~aA='N","text_ar":"اِعمِيَّا=ءٌ"},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"AidohaAm~a","text_ar":"اِدْهَامَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yadohaAm~u","text_ar":"يَدْهَامُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AidohiymaAmN","text_ar":"اِدْهِيمَامٌ"},{"kind":"text","text":"; but this is by a straining of a point, and not in use: (Sgh, TA:) and ↓"},{"kind":"arabic","text_bw":"tEm~Y","text_ar":"تعمّى","orth_type":"arrow"},{"kind":"text","text":", likewise, signifies the same, (K, TA,) i. e., the same as"},{"kind":"arabic","text_bw":"EamiYa","text_ar":"عَمِىَ"},{"kind":"text","text":". (TA.) And you say also,"},{"kind":"arabic","text_bw":"Eamiyato EayonaAhu","text_ar":"عَمِيَتْ عَيْنَاهُ"},{"kind":"italic_en","text":"His two eyes were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blind."},{"kind":"text","text":"(TA.) ―         -b2-  Hence"},{"kind":"arabic","text_bw":"EamFY","text_ar":"عَمًى"},{"kind":"text","text":"is metaphorically used in relation to the mind, as meaning (tropical:)"},{"kind":"italic_en","text":"An erring;"},{"kind":"text","text":"the connection between the two meanings being the"},{"kind":"italic_en","text":"not finding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not taking, the right way:"},{"kind":"text","text":"(Msb:) or the"},{"kind":"italic_en","text":"being blind in respect of the mind:"},{"kind":"text","text":"and in this sense, the verb is as above, with the exception of the measure"},{"kind":"arabic","text_bw":"AifEaAl~a","text_ar":"اِفعَالَّ"},{"kind":"text","text":"[and the abbreviated form of this]. (K, * TA. ["},{"kind":"arabic","text_bw":"AafoEaAlK","text_ar":"اَفْعَالٍ"},{"kind":"text","text":"in the CK in this passage is a mistranscription, for"},{"kind":"arabic","text_bw":"A@foEaAl~a","text_ar":"ا@فْعَالَّ"},{"kind":"text","text":".]) You say,"},{"kind":"arabic","text_bw":"EamiYa Eano","text_ar":"عَمِىَ عَنْ"},{"kind":"arabic","text_bw":"ru$odihi","text_ar":"رُشْدِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Huj~atihi","text_ar":"حُجَّتِهِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"lamo yahotadi","text_ar":"لَمْ يَهْتَدِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He did not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"could not, become guided to his right course,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his plea"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blind thereto"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"EamiYa Eano Haq~ihi","text_ar":"عَمِىَ عَنْ حَقِّهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blind to his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due"},{"kind":"text","text":"], like"},{"kind":"arabic","text_bw":"Ea$iYa","text_ar":"عَشِىَ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"E$w","text_ar":"عشو"},{"kind":"text","text":".) ―         -b3-  One says also"},{"kind":"arabic","text_bw":"EamiYa","text_ar":"عَمِىَ"},{"kind":"arabic","text_bw":"Ealayohi Alxabaru","text_ar":"عَلَيْهِ الخَبَرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The information was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unapparent, obscure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covert, to him."},{"kind":"text","text":"(Mgh, Msb. *) And"},{"kind":"arabic","text_bw":"EamiYa Ealayohi Tariyquhu","text_ar":"عَمِىَ عَلَيْهِ طَرِيقُهُ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"Al$~iEoru","text_ar":"الشِّعْرُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlkalaAmu","text_ar":"الكَلَامُ"},{"kind":"text","text":", (Har p. 190,) i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"His way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"road,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the poetry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verse,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saying,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, obscure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dubious, to him;"},{"kind":"text","text":"(S, TA, and Har ubi suprá) and so ↓"},{"kind":"arabic","text_bw":"Eum~iYa","text_ar":"عُمِّىَ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"tEm~Y","text_ar":"تعمّى","orth_type":"arrow"},{"kind":"text","text":". (Har ubi suprá.) Hence, accord. to different readings, in the Kur [xxviii. 66],"},{"kind":"arabic","text_bw":"faEamiyato","text_ar":"فَعَمِيَتْ"},{"kind":"arabic","text_bw":"Ealayohimu A@loA^anobaA='u","text_ar":"عَلَيْهِمُ ا@لْاَنْبَا=ءُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"faEum~iyato","text_ar":"فَعُمِّيَتْ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"And the pleas shall"},{"kind":"page_break","n":2161},{"kind":"italic_en","text":"be obscure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dubious, to them"},{"kind":"text","text":"]. (S, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Eamiytu A_ilaY ka*aA","text_ar":"عَمِيتُ اـِلَى كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I betook myself to such a thing, not desiring any other;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"EaTi$otu","text_ar":"عَطِشْتُ"},{"kind":"text","text":". (TA. [Accord. to the TA, the inf. ns. of these two verbs, thus used, are"},{"kind":"arabic","text_bw":"EmyAn","text_ar":"عميان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ET$An","text_ar":"عطشان"},{"kind":"text","text":": but they are correctly"},{"kind":"arabic","text_bw":"EamFY","text_ar":"عَمًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaTa$N","text_ar":"عَطَشٌ"},{"kind":"text","text":".])       -A2-"},{"kind":"arabic","text_bw":"EamaY","text_ar":"عَمَى"},{"kind":"arabic","text_bw":"Almawoju","text_ar":"المَوْجُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEomiY","text_ar":"يَعْمِى"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"EamoYN","text_ar":"عَمْىٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"The waves cast the particles of rubbish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"driving them to their upper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uppermost, parts,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and the foam."},{"kind":"text","text":"(S, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EamaY bilugaAmihi","text_ar":"عَمَى بِلُغَامِهِ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"yaEomiY","text_ar":"يَعْمِى"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"brayed, and cast the foam of his mouth upon his head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the upper part of his head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anywhere:"},{"kind":"text","text":"(K, TA:) mentioned by ISd. (TA.) ―         -b3-  And [hence]"},{"kind":"arabic","text_bw":"EamaAniY bika*aA","text_ar":"عَمَانِى بِكَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He cast upon me a suspicion of such a thing."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"EamaY","text_ar":"عَمَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEomiY","text_ar":"يَعْمِى"},{"kind":"text","text":", said of water, (K, TA,) and of other things, (TA,) also signifies"},{"kind":"italic_en","text":"It flowed;"},{"kind":"text","text":"(K, TA;) and so"},{"kind":"arabic","text_bw":"hamaY","text_ar":"هَمَى"},{"kind":"text","text":". (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"EmY Aln~abotu","text_ar":"عمى النَّبْتُ"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"EamaY","text_ar":"عَمَى"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"AEtmY","text_ar":"اعتمى","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AiEotam~a","text_ar":"اِعْتَمَّ"},{"kind":"text","text":"are three syn. dial. vars., (TA in this art.,) meaning (assumed tropical:)"},{"kind":"italic_en","text":"The plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, became of its full height, and blossomed;"},{"kind":"text","text":"(S, K, TA, in explanation of the last, in art."},{"kind":"arabic","text_bw":"Em","text_ar":"عم"},{"kind":"text","text":";) and"},{"kind":"italic_en","text":"became luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant and dense."},{"kind":"text","text":"(TA in that art.)"}],"source_refs":["S","Msb","K","Sgh","TA"]},{"entry_id":"n30618","headword_ar":"عَمًى","root":"EmY","body":[{"kind":"text","text":"[sometimes written"},{"kind":"arabic","text_bw":"EamFA","text_ar":"عَمًا"},{"kind":"text","text":"] inf. n. of"},{"kind":"arabic","text_bw":"EamiYa","text_ar":"عَمِىَ"},{"kind":"text","text":"[q. v.]. (S, * Msb, K.) [Hence the saying,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"$alalFA walaA EamFY","text_ar":"شَلَلًا وَلَا عَمًى"},{"kind":"text","text":": see 1 in art."},{"kind":"arabic","text_bw":"$l","text_ar":"شل"},{"kind":"text","text":". Hence also one says,"},{"kind":"arabic","text_bw":"rakiba A^amorFA EalaY AlEamaY","text_ar":"رَكِبَ اَمْرًا عَلَى العَمَى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He ventured upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embarked in, an affair blindly;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"arabic","text_bw":"gayori baSiyrapi","text_ar":"غَيْرِ بَصِيرَةِ"},{"kind":"text","text":".]       -A2-  See also"},{"kind":"arabic","text_bw":"A^aEomaA='N","text_ar":"اَعْمَا=ءٌ"},{"kind":"text","text":".       -A3-  And see"},{"kind":"arabic","text_bw":"EamaA='N","text_ar":"عَمَا=ءٌ"},{"kind":"text","text":", in two places.       -A4-  Also"},{"kind":"italic_en","text":"Stature:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"height."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"maA A^aHosana EamaY h`*aA Alr~ajuli","text_ar":"مَا اَحْسَنَ عَمَى هٰذَا الرَّجُلِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"How goodly is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the height,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the stature, of this man!"},{"kind":"text","text":"(TA.)       -A5-  And"},{"kind":"italic_en","text":"Dust;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gubaArN","text_ar":"غُبَارٌ"},{"kind":"text","text":". (K.)       -A6-  In the saying of a rájiz, describing a skin of milk, because of its whiteness,"},{"kind":"quote","text":"yaHosabuhu AljaAhilu maA kaAna EamaA\n                      \n                     \n                        $ayoxFA EalaY kurosiy~ipi muEam~amaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The ignorant would think it, while there was remoteness, to be an old man upon his chair, turbaned,"},{"kind":"text","text":"] the meaning is"},{"kind":"italic_en","text":"looking at it from afar;"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AlEamaA","text_ar":"العَمَا"},{"kind":"text","text":"in this case signifies"},{"kind":"italic_en","text":"remoteness."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]}}