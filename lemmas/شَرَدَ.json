num":"p"},{"role":"present_2mp","form":"تَشْرُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْرُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْرُد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْرُد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْرُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْرُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْرُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْرُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْرُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْرُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْرُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَرَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَرَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْرُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْرُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":true,"lemma_key":"شَرَدَ","root":"شرد","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n22088"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to change direction, to take a turn (عَن (ʕan))"},{"pos":"verb","gloss":"to change direction, to take a turn (عَن (ʕan)); to be extraneous to, have nothing to do with"},{"pos":"verb","gloss":"to make change direction","tags":["transitive"]}]},"etymology":null,"ipa":["/ʃa.ra.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22088","headword_ar":"شَرَدَ","root":"$rd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$uruwdN","text_ar":"شُرُودٌ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"$iraAdN","text_ar":"شِرَادٌ"},{"kind":"text","text":", (S, L, K,) or the latter is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"$uraAdN","text_ar":"شُرَادٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"$arodN","text_ar":"شَرْدٌ"},{"kind":"text","text":", (L,) said of a camel, (S, A, L, Msb,) and of a horse or the like, (L,)"},{"kind":"italic_en","text":"He took fright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shied, and fled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ran away at random;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became refractory, and went away at random,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ran away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke loose, and went hither and thither by reason of his sprightliness;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafara","text_ar":"نَفَرَ"},{"kind":"text","text":", (S, L, Msb, K,) and"},{"kind":"arabic","text_bw":"nad~a","text_ar":"نَدَّ"},{"kind":"text","text":": (Msb:) and [simply]"},{"kind":"italic_en","text":"he fled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ran away;"},{"kind":"text","text":"said of a camel &c. (Aboo-Bekr, TA.) The saying of the Prophet,"},{"kind":"arabic","text_bw":"A^amaA ya$orudu bika baEiyruka","text_ar":"اَمَا يَشْرُدُ بِكَ بَعِيرُكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Does not thy camel take fright and run away with thee?"},{"kind":"text","text":"], addressed by him to Khowwát, who answered,"},{"kind":"arabic","text_bw":"A^amaA muno*u qay~adahu AlA_isolaAmu falaA","text_ar":"اَمَا مُنْذُ قَيَّدَهُ الاـِسْلَامُ فَلَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"As to the period since El-Islám shackled him, no"},{"kind":"text","text":"], mentioned in the A, points to a story related of Khowwát Ibn-Jubeyr, (TA,) that, being found by the Prophet sitting by some strange women, he endeavoured to excuse himself by saying that he had a camel which took fright and ran away, and he was seeking for something wherewith to shackle him: the Prophet used afterwards to taunt him by inquiring of him respecting the running-away of his camel: what Kr says, and J in the S [in art."},{"kind":"arabic","text_bw":"nHY","text_ar":"نحى"},{"kind":"text","text":"], is incorrect. (IAth, L.) You say also,"},{"kind":"arabic","text_bw":"$arada Ean~iY fulaAnN","text_ar":"شَرَدَ عَنِّى فُلَانٌ"},{"kind":"italic_en","text":"Such a one fled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apart"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a distance, from me;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafara","text_ar":"نَفَرَ"},{"kind":"text","text":". (A.) [Or]"},{"kind":"arabic","text_bw":"$arada","text_ar":"شَرَدَ"},{"kind":"text","text":"said of a man, inf. n."},{"kind":"arabic","text_bw":"$uruwdN","text_ar":"شُرُودٌ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"He departed, driven away."},{"kind":"text","text":"(L.) And you say,"},{"kind":"arabic","text_bw":"$arada EalaY A@ll~`hi","text_ar":"شَرَدَ عَلَى ا@للّٰهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He departed from obedience to God, and seceded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated himself from the community"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the faithful"},{"kind":"text","text":"]. (L.)"}],"source_refs":["S","L","Msb","K","A","TA"]}]},"classical_definitions":null}