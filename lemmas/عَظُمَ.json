":"present_2mp","form":"تَعْظُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْظُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْظُم","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْظُم","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْظُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْظُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْظُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْظُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْظُمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْظُمُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْظُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْظُم","in_corpus":true,"count":111,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْظُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَظُمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَظُمْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":154,"cross_references":{"qac":{"found":true,"lemma_key":"عَظُمَ","root":"عظم","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n29667"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B8%D9%8F%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"bone","examples":[{"text":"أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَع عِظَامَهُۥ.","english":"Thinketh man that We shall not assemble his bones?"},{"text":"رَأَيْتُكَ تُوسِعُ ٱلشُّعَرَاءَ نَيْلًا / حَدِيثَهُمُ ٱلْمُوَلَّدَ وَٱلْقَدِيمَا\nفَتُعْطِي مَنْ بَقَى مَالًا جَسِيمًا / وَتُعْطِي مَنْ مَضَى شَرَفًا عَظِيمَا\nسَمِعْتُكَ مُنْشِدًا بَيْتَيْ زِيَادٍ / نَشِيدًا مِثْلَ مُنْشِدِهِ كَرِيمَا\nفَمَا أَنْكَرْتُ مَوْضِعَهُ وَلَٰكِنْ / غَبَطْتُ بِذَاكَ أَعْظُمَهُ ٱلرَّمِيمَا"}]},{"pos":"verb","gloss":"to be great","tags":["intransitive"],"examples":[{"text":"إِلٰهِي إِنْ عَظُمَ الذَّنْبُ مِنْ عَبْدِكَ فَلْيَحْسُنِ العَفْوُ مِنْ عِنْدِكَ.","english":"My God if the wrongdoing of your worshipper has gotten great then let your forgiveness be splendid."}]},{"pos":"noun","gloss":"verbal noun of عَظُمَ (ʕaẓuma) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"greatness, magnitude, power"},{"pos":"noun","gloss":"pomp"},{"pos":"noun","gloss":"bulk, extent, thickness"},{"pos":"noun","gloss":"importance"},{"pos":"noun","gloss":"pride"},{"pos":"noun","gloss":"crowd, multitude"},{"pos":"noun","gloss":"enlargement of an organ (in nomenclature of conditions)","tags":["historical"],"examples":[{"text":"عِظَم الكَبِد","english":"hepatomegaly (enlargement of the liver)"}]},{"pos":"verb","gloss":"to make great","tags":["causative","transitive"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ʕaṯ̣m-.\n\nCompare عَظِيم (ʕaẓīm, “great, powerful, important”).\n\nForm-II causative of عَظُمَ (ʕaẓuma)."},"ipa":["/ʕaðˤm/","/ʕa.ðˤu.ma/","/ʕi.ðˤam/","/ʕuðˤm/","/ʕaðˤ.ðˤa.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29667","headword_ar":"عَظُمَ","root":"EZm","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"EiZamN","text_ar":"عِظَمٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"EaZaAmapN","text_ar":"عَظَامَةٌ"},{"kind":"text","text":", (Msb, K,) accord. to El-Isbahánee, primarily signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great in his bone:"},{"kind":"text","text":"then metaphorically said of anything"},{"kind":"arabic","text_bw":"kabiyr","text_ar":"كَبِير"},{"kind":"text","text":"[or great], whether an object of sense or of intel-lect, a substance or an accident: (TA:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"kabura","text_ar":"كَبُرَ"},{"kind":"text","text":", (S, TA,) said of a thing [as meaning"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large"},{"kind":"text","text":"], (S, Msb, TA,)"},{"kind":"italic_en","text":"in length"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"breadth"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"thickness:"},{"kind":"text","text":"(TA:) [and in like manner, metaphorically, said of an object of intellect; meaning"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great in estimation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity;"},{"kind":"text","text":"and thus also said of a man: or it imports more than"},{"kind":"arabic","text_bw":"kabura","text_ar":"كَبُرَ"},{"kind":"text","text":"; signifying"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great in comparison with other things of its kind; huge, enormous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vast;"},{"kind":"text","text":"and in a similar sense it is said of a man; and in an incomparably higher sense, of God: (see"},{"kind":"arabic","text_bw":"EaZiymN","text_ar":"عَظِيمٌ"},{"kind":"text","text":", below:)] and ↓"},{"kind":"arabic","text_bw":"AEZm","text_ar":"اعظم","orth_type":"arrow"},{"kind":"text","text":"said of an affair, or event, signifies [like"},{"kind":"arabic","text_bw":"EaZuma","text_ar":"عَظُمَ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it became"},{"kind":"arabic","text_bw":"EaZiym","text_ar":"عَظِيم"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"EiZamN","text_ar":"عِظَمٌ"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"contr."},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"SigarN","text_ar":"صِغَرٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"EaZuma Einodahu","text_ar":"عَظُمَ عِنْدَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EaZuma Ealayohi","text_ar":"عَظُمَ عَلَيْهِ"},{"kind":"text","text":": see 6, in three places: and see also 4. And"},{"kind":"arabic","text_bw":"maA yaEoZumuniY","text_ar":"مَا يَعْظُمُنِى"},{"kind":"text","text":"[which is similar in meaning to"},{"kind":"arabic","text_bw":"mA yaEoZumu EalaY~a","text_ar":"ما يَعْظُمُ عَلَىَّ"},{"kind":"text","text":"if not a mistranscription for"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"arabic","text_bw":"yuEoZimuniY","text_ar":"يُعْظِمُنِى"},{"kind":"text","text":"]: see 4. ―         -b3-  In the case of expressing wonder, one says,"},{"kind":"arabic","text_bw":"EuZoma AlbaTonu baTonuka","text_ar":"عُظْمَ البَطْنُ بَطْنُكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How great is the belly, thy belly !"},{"kind":"text","text":"], contracting"},{"kind":"arabic","text_bw":"EaZuma","text_ar":"عَظُمَ"},{"kind":"text","text":", and transferring the vowel of its middle letter to [the place of] its first; and thus one does in the case of that which denotes praise or blame, and of whatever [verb] may be well used in the manner"},{"kind":"page_break","n":2087},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"niEoma","text_ar":"نِعْمَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biy^osa","text_ar":"بِيْسَ"},{"kind":"text","text":": but what may not be thus used does not admit of the transferring, though it may be contracted; so that you may say,"},{"kind":"arabic","text_bw":"Hasuna Alwajohu","text_ar":"حَسُنَ الوَجْهُ"},{"kind":"arabic","text_bw":"wajohuka","text_ar":"وَجْهُكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hasona Alwajohu wajohuka","text_ar":"حَسْنَ الوَجْهُ وَجْهُكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Husona Alwajohu","text_ar":"حُسْنَ الوَجْهُ"},{"kind":"arabic","text_bw":"wajohuka","text_ar":"وَجْهُكَ"},{"kind":"text","text":", but not"},{"kind":"arabic","text_bw":"qado Husona Alwajohu wajohuka","text_ar":"قَدْ حُسْنَ الوَجْهُ وَجْهُكَ"},{"kind":"text","text":". (S.)       -A2-"},{"kind":"arabic","text_bw":"EaZama Alkaloba","text_ar":"عَظَمَ الكَلْبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaZomN","text_ar":"عَظْمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He gave the dog a bone to eat;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AEZmhu","text_ar":"اعظمهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EaZama fulaAnFA","text_ar":"عَظَمَ فُلَانًا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaZamapN","text_ar":"عَظَمَةٌ"},{"kind":"text","text":"(K, TA) and"},{"kind":"arabic","text_bw":"EaZamN","text_ar":"عَظَمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He struck such a one upon his bones."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","Msb","K","TA"]}]}}