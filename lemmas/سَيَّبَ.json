,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُسَيِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُسَيِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُسَيِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُسَيِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُسَيِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُسَيِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسَيِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَيِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسَيِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسَيِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسَيِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُسَيِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَيِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَيَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَيَّبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n21379","n21381","n21382"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%8A%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to set free, to liberate, to release (e.g., from prison)"},{"pos":"verb","gloss":"to abandon, to leave, to forsake"},{"pos":"verb","gloss":"to relinquish, to renounce"},{"pos":"noun","gloss":"verbal noun of سَابَ (sāba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21379","headword_ar":"سيّب","root":"syb","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He left, left alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglected,"},{"kind":"text","text":"a thing. (M.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He left"},{"kind":"text","text":"a beast, (S, A,) or a she-camel, (Mgh,)"},{"kind":"italic_en","text":"alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by itself, to pasture where it would, without a pastor."},{"kind":"text","text":"(S, A, Mgh.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"He emancipated"},{"kind":"text","text":"a slave"},{"kind":"italic_en","text":"so that he"},{"kind":"text","text":"(the emancipator)"},{"kind":"italic_en","text":"had no claim to inherit from him, and no control over his property; he made"},{"kind":"text","text":"him"},{"kind":"italic_en","text":"to be such as is termed"},{"kind":"arabic","text_bw":"saAy^ibap","text_ar":"سَايِبَة"},{"kind":"text","text":". (Msb.) ―         -b4-  See also what next follows."}],"source_refs":["S","A","Mgh"]},{"entry_id":"n21381","headword_ar":"سَيْبٌ","root":"syb","body":[{"kind":"text","text":"[is an inf. n. of 1, used in the sense of"},{"kind":"arabic","text_bw":"saAy^ibN","text_ar":"سَايِبٌ"},{"kind":"text","text":"(q. v.), as will be shown in what follows in this paragraph. ―         -b2-  And hence,] (tropical:)"},{"kind":"italic_en","text":"A gift:"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K:) and"},{"kind":"italic_en","text":"a voluntary gift, by way of alms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as a good work:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"a benefaction, an act of beneficence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kindness, a favour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a benefit:"},{"kind":"text","text":"(M, K:) pl."},{"kind":"arabic","text_bw":"suyuwbN","text_ar":"سُيُوبٌ"},{"kind":"text","text":". (L, TA.) It is said in a trad. respecting a prayer for rain,"},{"kind":"arabic","text_bw":"waA@joEalohu sayobFA naAfiEFA","text_ar":"وَا@جْعَلْهُ سَيْبًا نَافِعًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"And make Thou it to be a beneficial gift:"},{"kind":"text","text":"or the meaning in this instance may be,"},{"kind":"italic_en","text":"a flowing rain."},{"kind":"text","text":"(TA.) And one says,"},{"kind":"arabic","text_bw":"faADa sayobuhu EalaY Aln~aAsi","text_ar":"فَاضَ سَيْبُهُ عَلَى النَّاسِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His gifts flowed abundantly upon the people."},{"kind":"text","text":"(A, TA.) [See also an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"jub~aA^N","text_ar":"جُبَّاٌ"},{"kind":"text","text":".] ―         -b3-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"rikaAzN","text_ar":"رِكَازٌ"},{"kind":"text","text":"(tropical:)  [i. e."},{"kind":"italic_en","text":"Metal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mineral;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieces of gold"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"silver, that are extracted from the earth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any metals"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other minerals;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buried treasure of the people of the Time of Ignorance"},{"kind":"text","text":"]: (A, Msb:) or so"},{"kind":"arabic","text_bw":"suyuwbN","text_ar":"سُيُوبٌ"},{"kind":"text","text":"; (A 'Obeyd, S, M, Mgh, K;) which is the pl.: (A, Msb:) the latter signifies, accord. to Th,"},{"kind":"italic_en","text":"metals,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"minerals:"},{"kind":"text","text":"(M, TA:) accord. to Aboo-Sa'eed,"},{"kind":"italic_en","text":"veins of gold"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of silver, that come into existence, and appear, in the mines:"},{"kind":"text","text":"so called because of their running ("},{"kind":"arabic","text_bw":"liA@nosiyaAbihaA","text_ar":"لِا@نْسِيَابِهَا"},{"kind":"text","text":") in the earth: accord to Z,"},{"kind":"italic_en","text":"treasure buried in the Time of Ignorance:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"metal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mineral:"},{"kind":"text","text":"(TA:) because of the gift of God, (M, Z, Mgh, TA,) to him who finds it. (Z, TA.) The Prophet said, (Mgh, TA,)"},{"kind":"arabic","text_bw":"fiY Als~uyuwbi Alxumosu","text_ar":"فِى السُّيُوبِ الخُمْسُ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"In the case of"},{"kind":"arabic","text_bw":"rikaAz","text_ar":"رِكَاز"},{"kind":"text","text":","},{"kind":"italic_en","text":"the fifth part"},{"kind":"text","text":"[is for the government-treasury]. (A, Mgh, TA.)       -A2-  Also The"},{"kind":"italic_en","text":"hair of the tail"},{"kind":"text","text":"of a horse. (M, K.)       -A3-  And"},{"kind":"italic_en","text":"A pole with which a ship or boat is propelled."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","M","A","Mgh","Msb","K","TA","Z"]},{"entry_id":"n21382","headword_ar":"سِيبٌ","root":"syb","body":[{"kind":"italic_en","text":"A place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel, in which water runs:"},{"kind":"text","text":"(S, M, K:) or so"},{"kind":"arabic","text_bw":"siybu maA='K","text_ar":"سِيبُ مَا=ءٍ"},{"kind":"text","text":": (A:) pl."},{"kind":"arabic","text_bw":"suyuwbN","text_ar":"سُيُوبٌ"},{"kind":"text","text":". (M.)       -A2-  And The"},{"kind":"italic_en","text":"apple:"},{"kind":"text","text":"in this sense a Pers. word [arabicized]: and hence the name of [the celebrated grammarian]"},{"kind":"arabic","text_bw":"siybawayohi","text_ar":"سِيبَوَيْهِ"},{"kind":"text","text":"; as though meaning “ the scent of apples; ” (M, K, * TA;) accord. to Abu-l-'Alà, (M, TA,) and Seer: (TA:) by some, [app. such as mispronounce it,] this name is said to be from the Pers."},{"kind":"arabic","text_bw":"siYo","text_ar":"سِىْ"},{"kind":"text","text":"signifying “ thirty ” and"},{"kind":"arabic","text_bw":"buwyaho","text_ar":"بُويَهْ"},{"kind":"text","text":"signifying “ odour; ” as though meaning “ thirty odours: ” (MF, TA:) and some say that"},{"kind":"arabic","text_bw":"wayohi","text_ar":"وَيْهِ"},{"kind":"text","text":"is an ejaculation; and that the relaters of traditions dislike pronouncing this name therewith, as also other similar names, and therefore say"},{"kind":"arabic","text_bw":"siybuwyaho","text_ar":"سِيبُويَهْ"},{"kind":"text","text":", changing the"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", but pausing upon it [so as to pronounce it"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","M","K","A","TA","MF"]}]}}