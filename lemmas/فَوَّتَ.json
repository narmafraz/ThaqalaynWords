":"https://lanelexicon.com/?s=%D9%81%D9%8E%D9%88%D9%8E%D9%91%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lose, to miss","examples":[{"text":"فَوَّتَ ٱلْفُرْصَةَ","english":"miss the opportunity"}]}]},"etymology":null,"ipa":["/faw.wa.ta/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34761","headword_ar":"فَوْتٌ","root":"fwt","body":[{"kind":"text","text":"an inf. n. of 1. (S, * M, &c.) ―         -b2-"},{"kind":"arabic","text_bw":"fawota famihi","text_ar":"فَوْتَ فَمِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fawota rumoHihi","text_ar":"فَوْتَ رُمْحِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fawota yadihi","text_ar":"فَوْتَ يَدِهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Beyond the reach of his mouth"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of his spear"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of his hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm"},{"kind":"text","text":"(in several copies of the K erroneously written"},{"kind":"arabic","text_bw":"fawotu","text_ar":"فَوْتُ"},{"kind":"text","text":")] mean"},{"kind":"italic_en","text":"where he sees it but will not"},{"kind":"text","text":"["},{"kind":"italic_en","text":"be able to"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"reach it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attain it."},{"kind":"text","text":"(K, TA.) A man said to another, reviling him, [or rather said of him,]"},{"kind":"arabic","text_bw":"jaEala A@ll~`hu rizoqahu fawota famihi","text_ar":"جَعَلَ ا@للّٰهُ رِزْقَهُ فَوْتَ فَمِهِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"May God make his sustenance to be beyond the reach of his mouth,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"where he shall see it and shall not attain it."},{"kind":"text","text":"(S, O. [And the like is said in the M and A.]) And one says,"},{"kind":"arabic","text_bw":"huwa min~iY fawota Alr~umoHi","text_ar":"هُوَ مِنِّى فَوْتَ الرُّمْحِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"where my spear will not reach him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, A, O.) And"},{"kind":"arabic","text_bw":"huwa min~iY fawota Alyadi","text_ar":"هُوَ مِنِّى فَوْتَ اليَدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"beyond the reach of my hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm:"},{"kind":"text","text":"mentioned by Sb among what are peculiarly adverbial expressions. (M.) And"},{"kind":"arabic","text_bw":"A^afolatanaA fulaAnN fawota Alyadi","text_ar":"اَفْلَتَنَا فُلَانٌ فَوْتَ اليَدِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fawota AlZ~ufori","text_ar":"فَوْتَ الظُّفْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one escaped from us beyond the reach of a hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an arm,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"beyond the reach of a finger-nail"},{"kind":"text","text":"]. (A. [Golius, as on the authority of the A, has"},{"kind":"arabic","text_bw":"ZuforK","text_ar":"ظُفْرٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fuwayota","text_ar":"فُوَيْتَ","orth_type":"arrow"},{"kind":"text","text":", which he explains as syn. with"},{"kind":"arabic","text_bw":"fawota yadK","text_ar":"فَوْتَ يَدٍ"},{"kind":"text","text":"; but it signifies"},{"kind":"italic_en","text":"A little beyond the reach of a finger-nail."},{"kind":"text","text":"]) ―         -b3-"},{"kind":"arabic","text_bw":"A^asomaEu","text_ar":"اَسْمَعُ"},{"kind":"arabic","text_bw":"SawotFA waA^araY fawotFA","text_ar":"صَوْتًا وَاَرَى فَوْتًا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I hear a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voice, but I see not a deed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no deed."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Swt","text_ar":"صوت"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"fawotN","text_ar":"فَوْتٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"space between two fingers"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when they are extended apart"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"buSomN","text_ar":"بُصْمٌ"},{"kind":"text","text":")]: (S, M, O, K:) pl."},{"kind":"arabic","text_bw":"A^afowaAtN","text_ar":"اَفْوَاتٌ"},{"kind":"text","text":". (S, M, O.) ―         -b5-  And you say, ↓"},{"kind":"arabic","text_bw":"bayonahumaA fawotN faAy^itN","text_ar":"بَيْنَهُمَا فَوْتٌ فَايِتٌ","orth_type":"arrow"},{"kind":"text","text":"like as you say"},{"kind":"arabic","text_bw":"bawonN baAy^inN","text_ar":"بَوْنٌ بَايِنٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Between them two"},{"kind":"text","text":"(meaning two men)"},{"kind":"italic_en","text":"is a wide distance;"},{"kind":"text","text":"app. in respect of rank or estimation: the last word being in this case a corroborative, like the latter word in"},{"kind":"arabic","text_bw":"mawotN maAy^itN","text_ar":"مَوْتٌ مَايِتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"liyolN laAy^ilN","text_ar":"لِيْلٌ لَايِلٌ"},{"kind":"text","text":"]. (M.)"}],"source_refs":["S","M","O","K"]}]}}