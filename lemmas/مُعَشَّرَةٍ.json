{"lemma":"مُعَشَّرَةٍ","slug":"مُعَشَّرَةٍ","root":"ع.ش.ر","root_slug":"ع-ش-ر","root_link":"/words/roots/ع-ش-ر","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُعَشَّر","root":"عشر","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29213","n29214","n29215","n29216"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%8E%D8%B4%D9%8E%D9%91%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a company or collective body of people","tags":["Classical"]},{"pos":"noun","gloss":"a metal bowl, tray, or circular pedestal","tags":["Yemen"]}]},"etymology":null,"ipa":["/maʕ.ʃa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29213","headword_ar":"مَعْشَرٌ","root":"E$r","body":[{"kind":"italic_en","text":"A company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collective body,"},{"kind":"text","text":"(Az, S, O, Msb, K,)"},{"kind":"italic_en","text":"of people,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"consisting of men, exclusive of women;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"nafarN","text_ar":"نَفَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qawomN","text_ar":"قَوْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rahoTN","text_ar":"رَهْطٌ"},{"kind":"text","text":"; (Az, Msb;) having no proper sing.: (Az:) or"},{"kind":"italic_en","text":"any company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collective body, whose state of circumstances is one; a community;"},{"kind":"text","text":"as the"},{"kind":"arabic","text_bw":"mE$r","text_ar":"معشر"},{"kind":"text","text":"of the Muslims and that of the Polytheists: (Lth:) or"},{"kind":"italic_en","text":"a great company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collective body;"},{"kind":"text","text":"so called [from"},{"kind":"arabic","text_bw":"Ea$arapN","text_ar":"عَشَرَةٌ"},{"kind":"text","text":",] because they are many; for"},{"kind":"arabic","text_bw":"E$rp","text_ar":"عشرة"},{"kind":"text","text":"is that large and perfect number after which there is no number but what is composed of the units comprised in it: (MF:) or the"},{"kind":"italic_en","text":"family"},{"kind":"text","text":"of a man: or"},{"kind":"italic_en","text":"jinn"},{"kind":"text","text":"(i. e."},{"kind":"italic_en","text":"genii"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and mankind:"},{"kind":"text","text":"(K: [or the author of the K may mean, or"},{"kind":"italic_en","text":"jinn:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"mankind:"},{"kind":"text","text":"]) in the Kur [vi. 130, and lv. 33], we find the expression"},{"kind":"arabic","text_bw":"yaA maEo$ara A@lojin~i waA@loA_inosi","text_ar":"يَا مَعْشَرَ ا@لْجِنِّ وَا@لْاـِنْسِ"},{"kind":"text","text":"; but this means"},{"kind":"italic_en","text":"O"},{"kind":"arabic","text_bw":"mE$r","text_ar":"معشر"},{"kind":"italic_en","text":"consisting of the jinn and of mankind:"},{"kind":"text","text":"and [vi. 128],"},{"kind":"arabic","text_bw":"yaA maEo$ara Aljin~i","text_ar":"يَا مَعْشَرَ الجِنِّ"},{"kind":"text","text":", without the mention of"},{"kind":"arabic","text_bw":"AlAns","text_ar":"الانس"},{"kind":"text","text":": (MF:) pl."},{"kind":"arabic","text_bw":"maEaA$iru","text_ar":"مَعَاشِرُ"},{"kind":"text","text":". (S, Msb.) [See also"},{"kind":"arabic","text_bw":"Ea$iyrapN","text_ar":"عَشِيرَةٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"maEo$ara","text_ar":"مَعْشَرَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Eu$aAra","text_ar":"عُشَارَ"},{"kind":"text","text":", in four places."}],"source_refs":["Az","S","O","Msb","K","Lth","MF"]},{"entry_id":"n29214","headword_ar":"مُعْشِرٌ","root":"E$r","body":[{"kind":"text","text":"(tropical:)  A woman"},{"kind":"italic_en","text":"who has completed her full time of pregnancy."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n29215","headword_ar":"مُعَشَّرٌ","root":"E$r","body":[{"kind":"text","text":"["},{"kind":"text","text":"pass. part. n. of 2, q. v. See also"},{"kind":"arabic","text_bw":"muval~avN","text_ar":"مُثَلَّثٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n29216","headword_ar":"مُعَشِّرٌ","root":"E$r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Ea$~aArN","text_ar":"عَشَّارٌ"},{"kind":"text","text":".       -A2-  Also One"},{"kind":"italic_en","text":"whose camels have brought forth:"},{"kind":"text","text":"and one"},{"kind":"italic_en","text":"whose camels have become"},{"kind":"arabic","text_bw":"Ei$aAr","text_ar":"عِشَار"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"Eu$araA='","text_ar":"عُشَرَا=ء"},{"kind":"text","text":"]. (O, K.)"}],"source_refs":[]}]},"classical_definitions":null}