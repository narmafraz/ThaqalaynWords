d":"arabic","text_bw":"wayoquwrN","text_ar":"وَيْقُورٌ"},{"kind":"text","text":", (S,) the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":": (S, K:) [see 1:] or, accord. to some, it is syn. with"},{"kind":"arabic","text_bw":"tawoqiyrN","text_ar":"تَوْقِيرٌ"},{"kind":"text","text":". (TA.) El-'Ajjáj says,"},{"kind":"quote","text":"faA_ino yakuno A^amosaY AlbilaY tayoquwriY"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"AmsY waqaAriY","text_ar":"امسى وَقَارِى"},{"kind":"text","text":". ["},{"kind":"italic_en","text":"And if wear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waste, hath become"},{"kind":"text","text":"the cause of"},{"kind":"italic_en","text":"my gravity,"},{"kind":"text","text":"&c.: or, if it be syn. with"},{"kind":"arabic","text_bw":"tawoqiyriY","text_ar":"تَوْقِيرِى"},{"kind":"text","text":", the cause of"},{"kind":"italic_en","text":"making me still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quiet"},{"kind":"text","text":"]. (S, TA.) Some make it to be of the measure"},{"kind":"arabic","text_bw":"tafoEuwlN","text_ar":"تَفْعُولٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"ta*onowbN","text_ar":"تَذْنْوبٌ"},{"kind":"text","text":", &c. (TA.) ―         -b2-  Also, The"},{"kind":"italic_en","text":"greatness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"majesty,"},{"kind":"text","text":"of God: as in the Kur. lxxi. 12. (S. [See 1, in art."},{"kind":"arabic","text_bw":"rjw","text_ar":"رجو"},{"kind":"text","text":".]) ―         -b3-  See also"},{"kind":"arabic","text_bw":"waquwrN","text_ar":"وَقُورٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K"]}]}}