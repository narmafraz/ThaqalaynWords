{"lemma":"خَزَى","slug":"خَزَى","root":"خ.ز.#","root_slug":"خ-ز-_","root_link":"/words/roots/خ-ز-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَزَى","root":"خزي","pos":"N","occurrence_count":11},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n10560"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B2%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be vile, ashamed of"},{"pos":"noun","gloss":"verbal noun of خَزِيَ (ḵaziya) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"shame, shamefulness, disgrace"}]},"etymology":null,"ipa":["/xa.zi.ja/","/xizj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10560","headword_ar":"خَزِىَ","root":"xzY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxozaY","text_ar":"يَخْزَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xizoYN","text_ar":"خِزْىٌ"},{"kind":"text","text":"(S, Mgh, * Msb, K, &c.) and"},{"kind":"arabic","text_bw":"xazFY","text_ar":"خَزًى"},{"kind":"text","text":"(Sb, K) and"},{"kind":"arabic","text_bw":"xizoyapN","text_ar":"خِزْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maxozaApN","text_ar":"مَخْزَاةٌ"},{"kind":"text","text":", (MA, [or these two are simple substs.,])"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, base, abased, abject, vile, despicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominious:"},{"kind":"text","text":"(S, Mgh, Msb:) or, accord. to ISk,"},{"kind":"italic_en","text":"he fell into trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he fell into trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and evil,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and a thing that exposed him to disgrace, and thereby became base, abased, abject, vile, despicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominious;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AixozawaY","text_ar":"اِخْزَوَى","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) like"},{"kind":"arabic","text_bw":"AiroEawaY","text_ar":"اِرْعَوَى"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"xizoYN","text_ar":"خِزْىٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"disgrace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy:"},{"kind":"text","text":"so in the Kur v. 37 [&c.]: (Sh, TA:) or its primary signification is"},{"kind":"italic_en","text":"a state of abasement, vileness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy, of which one is ashamed:"},{"kind":"text","text":"so accord. to Er-Rághib and Bd and the Ksh: (MF, TA:) or the"},{"kind":"italic_en","text":"manifesting foul actions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"qualities, for the manifesting of which one deserves punishment:"},{"kind":"text","text":"(El- Harállee, TA:) or"},{"kind":"arabic","text_bw":"xaziYa","text_ar":"خَزِىَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he became disgraced, and was confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, by reason of disgrace."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xaziYa","text_ar":"خَزِىَ"},{"kind":"text","text":", (S, Msb, K,) aor. as above, (S, Mgh,) inf. n."},{"kind":"arabic","text_bw":"xazaAyapN","text_ar":"خَزَايَةٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"xazFY","text_ar":"خَزًى"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected, with shame;"},{"kind":"text","text":"(S, Mgh, Msb, K;) [as also ↓"},{"kind":"arabic","text_bw":"AstxzY","text_ar":"استخزى","orth_type":"arrow"},{"kind":"text","text":": see the part. n. of this latter below:] or"},{"kind":"arabic","text_bw":"xazaAyapN","text_ar":"خَزَايَةٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"being moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected, with much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intense, shame."},{"kind":"text","text":"(JK.)       -A2-"},{"kind":"arabic","text_bw":"xaAzaAniY faxazayotuhu","text_ar":"خَازَانِى فَخَزَيْتُهُ"},{"kind":"text","text":": see the next paragraph.       -A3-"},{"kind":"arabic","text_bw":"xizaAyapN","text_ar":"خِزَايَةٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"xzw","text_ar":"خزو"},{"kind":"text","text":"."}],"source_refs":["Sb","K","S","Mgh","Msb","TA","Sh","MF"]}]},"classical_definitions":null}