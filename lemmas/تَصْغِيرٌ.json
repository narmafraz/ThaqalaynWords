{"lemma":"تَصْغِيرٌ","slug":"تَصْغِيرٌ","root":"ص.غ.ر","root_slug":"ص-غ-ر","root_link":"/words/roots/ص-غ-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"diminishment, reduction"},{"pos":"noun","gloss":"diminutive","tags":["diminutive"]}]},"etymology":{"source":"wiktextract","text":"Verbal noun of صَغَّرَ (ṣaḡḡara, “to diminish, to make small”), from the root ص غ ر (ṣ ḡ r)."},"ipa":["/tasˤ.ɣiːr/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%B5%D8%BA%D9%8A%D8%B1/","headword_ar":"تصغير","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23096#daf59c","body_html":"<span>التصغير: تغيير صيغة الاسم لأجل تغيير المعنى، تحقيرًا، أو تقليلًا، أو تقريبًا، أو تكريمًا، أو تلطيفا، كرجيل، ودريهمات، وقبيل، وفويق، وأخي، ويبنى عليه ما في قوله صلى الله عليه وسلم في حق عائشة رضي الله عنها: \"خذوا نصف دينكم عن هذه الحميراء\".</span>"}]}}