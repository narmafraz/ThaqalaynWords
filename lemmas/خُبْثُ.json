{"lemma":"خُبْثُ","slug":"خُبْثُ","root":"خ.ب.ث","root_slug":"خ-ب-ث","root_link":"/words/roots/خ-ب-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خُبْثُ","root":"خبث","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n9864","n9869","n9870"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D8%A8%D9%92%D8%AB%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become bad or evil, to commit evil act"}]},"etymology":null,"ipa":["/xa.bu.θa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9864","headword_ar":"خَبُثَ","root":"xbv","body":[{"kind":"text","text":", (S, Mgh, Msb, K, &c.,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xabaAvapN","text_ar":"خَبَاثَةٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", the former being a simple subst., (Msb,) or both, (Mgh, K, [the latter word erroneously written in the CK"},{"kind":"arabic","text_bw":"xabov","text_ar":"خَبْث"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"xabaAviyapN","text_ar":"خَبَاثِيَةٌ"},{"kind":"text","text":", (K,) said of a thing, (S, Mgh, Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xabiyv","text_ar":"خَبِيث"},{"kind":"text","text":"[q. v., meaning"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"&c.];"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"TaAba","text_ar":"طَابَ"},{"kind":"text","text":". (S, Mgh, Msb, K.) [Hence,]"},{"kind":"arabic","text_bw":"xabuvato raAy^iHatuhu","text_ar":"خَبُثَتْ رَايِحَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Its,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his, odour was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"xabuva TaEomuhu","text_ar":"خَبُثَ طَعْمُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Its taste was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, foul, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nauseous"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"xabuvato nafosuhu","text_ar":"خَبُثَتْ نَفْسُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His soul"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stomach"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became heavy;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"it heaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became agitated by a tendency to vomit;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gavato","text_ar":"غَثَتْ"},{"kind":"text","text":": (A and TA in the present art., and S and K in art."},{"kind":"arabic","text_bw":"gvY","text_ar":"غثى"},{"kind":"text","text":": [see also"},{"kind":"arabic","text_bw":"ma*irato nafosuhu","text_ar":"مَذِرَتْ نَفْسُهُ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"m*r","text_ar":"مذر"},{"kind":"text","text":":]) a phrase forbidden by Mohammad to be used; as though he disliked the word"},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":". (TA.) One says of certain food,"},{"kind":"arabic","text_bw":"taxobuvu Eanohu Aln~afosu","text_ar":"تَخْبُثُ عَنْهُ النَّفْسُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stomach, becomes heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heaves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becomes agitated by a tendency to vomit, in consequence of it"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":", (S, A, K,) inf. n."},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", (S, K,) said of a man, signifies [in like manner]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xabiyv","text_ar":"خَبِيث"},{"kind":"text","text":", (S, A, K,) meaning"},{"kind":"italic_en","text":"bad, corrupt, base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable; wicked, deceitful, guileful, artful, crafty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning."},{"kind":"text","text":"(S, K, TA. [See also 4.]) [Hence,]"},{"kind":"arabic","text_bw":"xabuva bihaA","text_ar":"خَبُثَ بِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He committed adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication, with her."},{"kind":"text","text":"(A, Mgh, Msb, K.) ―         -b3-  [It is also said of a venomous reptile and the like, meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, malignant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noxious; impure, unclean, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"]"}],"source_refs":["Msb","K","S","Mgh","A"]},{"entry_id":"n9869","headword_ar":"خُبْثٌ","root":"xbv","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":": (S, Mgh, Msb, K:) [used as a simple subst., it means"},{"kind":"italic_en","text":"Any of the qualities denoted by the epithet"},{"kind":"arabic","text_bw":"xabiyvN","text_ar":"خَبِيثٌ"},{"kind":"text","text":", q. v., i. e."},{"kind":"italic_en","text":"badness,"},{"kind":"text","text":"&c.:] and ↓"},{"kind":"arabic","text_bw":"xib~iyvaY","text_ar":"خِبِّيثَى","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) or this is a subst. from"},{"kind":"arabic","text_bw":"A^axobva","text_ar":"اَخْبثَ"},{"kind":"text","text":"meaning “ he had a bad, wicked, or deceitful, family; ” (TA;) and signifies the"},{"kind":"italic_en","text":"state of having bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful, companions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friends"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"connexions:"},{"kind":"text","text":"(L:) ↓"},{"kind":"arabic","text_bw":"xaAbivapN","text_ar":"خَابِثَةٌ","orth_type":"arrow"},{"kind":"text","text":", also, is"},{"kind":"italic_en","text":"syn. with"},{"kind":"page_break","n":694},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", and so is] ↓"},{"kind":"arabic","text_bw":"xabaAvapN","text_ar":"خَبَاثَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [for] this last is another inf. n. of"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"xubovN","text_ar":"خُبْثٌ"},{"kind":"text","text":", (S, Mgh, K,) or it is a simple subst. (Msb.) [Hence,] the first particularly signifies (tropical:)"},{"kind":"italic_en","text":"Adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication."},{"kind":"text","text":"(K, TA.) See also"},{"kind":"arabic","text_bw":"xabiyvN","text_ar":"خَبِيثٌ"},{"kind":"text","text":", in three places."}],"source_refs":["S","Mgh","Msb","K","L"]},{"entry_id":"n9870","headword_ar":"خَبَثٌ","root":"xbv","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"dross"},{"kind":"text","text":"of iron, (S, TA,) and of silver, when they are molten. (TA.) [Hence the saying,]"},{"kind":"arabic","text_bw":"layosa AlA_iboriyzu kaAlxabavi","text_ar":"لَيْسَ الاـِبْرِيزُ كَالخَبَثِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Pure gold is not like dross"},{"kind":"text","text":"]; meaning (tropical:)"},{"kind":"italic_en","text":"the good is not like the bad."},{"kind":"text","text":"(A, TA.) ―         -b2-"},{"kind":"italic_en","text":"Adulterating alloy in gold and iron &c."},{"kind":"text","text":"(Har p. 135.) ―         -b3-"},{"kind":"italic_en","text":"A thing wherein is no good."},{"kind":"text","text":"(TA.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"Excrement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordure: impurity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth."},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"ql","text_ar":"قل"},{"kind":"text","text":", and TA.) Hence the saying in a trad.,"},{"kind":"arabic","text_bw":"A_i*aA balaga AlmaA='u qul~atayoni","text_ar":"اـِذَا بَلَغَ المَا=ءُ قُلَّتَيْنِ"},{"kind":"arabic","text_bw":"lamo yaHomilo xabavFA","text_ar":"لَمْ يَحْمِلْ خَبَثًا"},{"kind":"text","text":"[explained in art."},{"kind":"arabic","text_bw":"AHl","text_ar":"احل"},{"kind":"text","text":"]. (Mgh ubi suprà, and TA.)"}],"source_refs":["S","TA"]}]}}