ic","text_bw":"HuruwmN","text_ar":"حُرُومٌ"},{"kind":"text","text":"; (Az, TA;) and"},{"kind":"arabic","text_bw":"Harimat","text_ar":"حَرِمَت"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaramN","text_ar":"حَرَمٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Harom","text_ar":"حَرْم"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"HaraAmN","text_ar":"حَرَامٌ"},{"kind":"text","text":"; (Msb, K, TA;)"},{"kind":"italic_en","text":"Prayer was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, forbidden, prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlawful,"},{"kind":"text","text":"(Msb,)"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"italic_en","text":"to her;"},{"kind":"text","text":"(T, S, K;) namely, a woman (T, S, K) menstruating. (S.) And"},{"kind":"arabic","text_bw":"Haruma Als~aHuwru EalaY AlS~aAy^imi","text_ar":"حَرُمَ السَّحُورُ عَلَى الصَّايِمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The meal before daybreak was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, forbidden to the faster"},{"kind":"text","text":"]. (K.) And"},{"kind":"arabic","text_bw":"Harumati AlmaroA^apu EalaY zawojihaA","text_ar":"حَرُمَتِ المَرْاَةُ عَلَى زَوْجِهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HuromN","text_ar":"حُرْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaraAmN","text_ar":"حَرَامٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The woman was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, forbidden to her husband."},{"kind":"text","text":"] (Az, TA.) ―         -b2-  [Also"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a place, a possession, a right, an office or a function, a quality, a command or an ordinance, &c.,) and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a person,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sacred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inviolable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entitled to reverence, respect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honour;"},{"kind":"text","text":"whence several applications of its part. n."},{"kind":"arabic","text_bw":"HariymN","text_ar":"حَرِيمٌ"},{"kind":"text","text":", q. v.]       -A2-"},{"kind":"arabic","text_bw":"Haramahu Al$~aYo'a","text_ar":"حَرَمَهُ الشَّىْءَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"Harimahu Al$y^","text_ar":"حَرِمَهُ الشي"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n."},{"kind":"arabic","text_bw":"HarimN","text_ar":"حَرِمٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"HiromN","text_ar":"حِرْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HarimapN","text_ar":"حَرِمَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"HiromapN","text_ar":"حِرْمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HiromaAnN","text_ar":"حِرْمَانٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"HariymapN","text_ar":"حَرِيمَةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"HariymN","text_ar":"حَرِيمٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"maHoramapN","text_ar":"مَحْرَمَةٌ"},{"kind":"text","text":"; (Har p. 69;) and ↓"},{"kind":"arabic","text_bw":"AHrmhu","text_ar":"احرمهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al$y^","text_ar":"الشي"},{"kind":"text","text":", (S, Msb, K,) but this last is of weak authority; (K;)"},{"kind":"italic_en","text":"He denied him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused him, the thing;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he refused to give him the"},{"kind":"page_break","n":554},{"kind":"italic_en","text":"thing:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he rendered him hopeless of the thing:"},{"kind":"text","text":"(PS:) accord. to the T,"},{"kind":"arabic","text_bw":"HiromN","text_ar":"حِرْمٌ"},{"kind":"text","text":"signifies the act of"},{"kind":"italic_en","text":"denying"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refusing"},{"kind":"text","text":"[a thing]; and"},{"kind":"arabic","text_bw":"HiromapN","text_ar":"حِرْمَةٌ"},{"kind":"text","text":"is the same as"},{"kind":"arabic","text_bw":"HiromaAnN","text_ar":"حِرْمَانٌ"},{"kind":"text","text":"; (TA;) which signifies [also the"},{"kind":"italic_en","text":"denying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refusing,"},{"kind":"text","text":"a thing; or] the"},{"kind":"italic_en","text":"rendering unprosperous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfortunate;"},{"kind":"text","text":"(KL;) [and frequently, as inf. n. of the pass. v."},{"kind":"arabic","text_bw":"Hurima","text_ar":"حُرِمَ"},{"kind":"text","text":", the"},{"kind":"italic_en","text":"being denied prosperity; privation of prosperity; ill-fatedness:"},{"kind":"text","text":"see its syn."},{"kind":"arabic","text_bw":"HurofN","text_ar":"حُرْفٌ"},{"kind":"text","text":".]       -A3-"},{"kind":"arabic","text_bw":"Harimato","text_ar":"حَرِمَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HiraAmN","text_ar":"حِرَامٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AstHrmt","text_ar":"استحرمت","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) said of a female cloven-hoofed animal,"},{"kind":"italic_en","text":"She desired the male:"},{"kind":"text","text":"(S, K:) accord. to El-Umawee, (S,) likewise said of a she-wolf and of a bitch: (S, K:) and sometimes also said of a she-camel: but mostly of a ewe or she-goat. (TA.)       -A4-"},{"kind":"arabic","text_bw":"Harima","text_ar":"حَرِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"HaramN","text_ar":"حَرَمٌ"},{"kind":"text","text":", (S,) accord. to AZ and Ks, (S,)"},{"kind":"italic_en","text":"He was overcome in contending for stakes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wagers, in a game of hazard,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"not having himself overcome therein."},{"kind":"text","text":"(K.)       -A5-  Also"},{"kind":"arabic","text_bw":"Harima","text_ar":"حَرِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HaramN","text_ar":"حَرَمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He persisted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persisted obstinately;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persisted in contention, litigation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrangling;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he contended, litigated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrangled."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","K","IKoot","T","TA","PS"]}]}}