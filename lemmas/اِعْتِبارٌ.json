{"lemma":"اِعْتِبارٌ","slug":"اِعْتِبارٌ","root":"ع.ب.ر","root_slug":"ع-ب-ر","root_link":"/words/roots/ع-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of اِعْتَبَرَ (iʕtabara) (form VIII)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"regard, respect","examples":[{"text":"اِعْتِبَارًا لِ/بِ...","english":"with respect to..."},{"text":"بِ/عَلَى ٱعْتِبَارِ أَنْ...","english":"considering that..."}]}]},"etymology":{"source":"wiktextract","text":"Verbal noun of اِعْتَبَرَ (iʕtabara)."},"ipa":["/iʕ.ti.baːr/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D8%B9%D8%AA%D8%A8%D8%A7%D8%B1/","headword_ar":"اعتبار","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22912#b1fe62","body_html":"<span>الاعتبار: هو النظر في الحكم الثابت أنه لأي معنى ثبت، وإلحاق نظيره به وهذا عين القياس.</span>"},{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22912#fe9d99","body_html":"<span>الاعتبار: أن يرى الدنيا للفناء، والعاملين فيها للموت، وعمرانها للخراب، وقيل: الاعتبار اسم المعتبرة، وهي رؤية فناء الدنيا كلها باستعمال النظر في فناء جزئها، وقيل: الاعتبار من العبر، وهو شق النهر والبحر يعني يرى المعتبر نفسه على حرف من مقامات الدنيا.</span>"}]}}