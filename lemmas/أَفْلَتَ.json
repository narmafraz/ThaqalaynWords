t":1},"lanes":{"found":true,"entry_ids":["n34437"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D9%84%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to escape, to get or be set free","examples":[{"text":"أَفْلَتَ مِنْ عِقَابٍ","english":"get away with"},{"text":"أَفْلَتَ مِنْ ذَاكِرَتِهِ","english":"slip one's mind"}]}]},"etymology":null,"ipa":["/ʔaf.la.ta/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34437","headword_ar":"افلت","root":"flt","body":[{"kind":"text","text":", (T, S, O, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"A_ifolaAtN","text_ar":"اـِفْلَاتٌ"},{"kind":"text","text":"; (T, Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"Anflt","text_ar":"انفلت","orth_type":"arrow"},{"kind":"text","text":"; (T, S, O, TA;) and ↓"},{"kind":"arabic","text_bw":"tfl~t","text_ar":"تفلّت","orth_type":"arrow"},{"kind":"text","text":"; (S, O, TA;) and ↓"},{"kind":"arabic","text_bw":"falata","text_ar":"فَلَتَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"falotN","text_ar":"فَلْتٌ"},{"kind":"text","text":"; (Msb;) signify the same; (T, S, O, Msb, TA;) i. e."},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a bird, &c., Msb, or a thing, S, O,)"},{"kind":"italic_en","text":"escaped; got away;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, loose, clear, quit, free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at liberty;"},{"kind":"text","text":"(O, Msb, TA;) [or"},{"kind":"italic_en","text":"did so"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"suddenly:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"A_ifolaAtN","text_ar":"اـِفْلَاتٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AinofilaAtN","text_ar":"اِنْفِلَاتٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tafal~utN","text_ar":"تَفَلُّتٌ","orth_type":"arrow"},{"kind":"text","text":"signify a thing's"},{"kind":"italic_en","text":"going forth suddenly:"},{"kind":"text","text":"(Mgh:) or ↓"},{"kind":"arabic","text_bw":"Anflt","text_ar":"انفلت","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went forth quickly:"},{"kind":"text","text":"(Msb:) and one says"},{"kind":"arabic","text_bw":"A^afolataniY","text_ar":"اَفْلَتَنِى"},{"kind":"text","text":", (M, K,) for"},{"kind":"arabic","text_bw":"Aflt min~iY","text_ar":"افلت مِنِّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he escaped,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from me"},{"kind":"text","text":"]; (Sgh, TA in art."},{"kind":"arabic","text_bw":"jrE","text_ar":"جرع"},{"kind":"text","text":";) and"},{"kind":"arabic","text_bw":"mn~Y","text_ar":"منّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tfl~t","text_ar":"تفلّت","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Anflt","text_ar":"انفلت","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) all signifying the same. (TA.) [See exs. voce"},{"kind":"arabic","text_bw":"juroEapN","text_ar":"جُرْعَةٌ"},{"kind":"text","text":"; and another ex. in art."},{"kind":"arabic","text_bw":"HS","text_ar":"حص"},{"kind":"text","text":", conj. 7.] ―         -b2-  See also 5.       -A2-"},{"kind":"arabic","text_bw":"Aflthu","text_ar":"افلتهُ"},{"kind":"text","text":"; (T, S, M, O, Msb, K;) and ↓ 2, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"falotN","text_ar":"فَلْتٌ"},{"kind":"text","text":"; both verbs being trans. as well as intrans.; (Msb;)"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"he suffered him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"] (namely, a man, M, or a bird, &c., Msb,)"},{"kind":"italic_en","text":"to escape,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"get away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to become,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"get, loose, clear, quit, free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at liberty; he set him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, loose, free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at liberty;"},{"kind":"text","text":"(T, M, O, Msb, TA;)"},{"kind":"italic_en","text":"he saved him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freed him,"},{"kind":"text","text":"from destruction. (T, TA.) [See, again,"},{"kind":"arabic","text_bw":"HuroEapN","text_ar":"حُرْعَةٌ"},{"kind":"text","text":".]"}],"source_refs":["T","S","O","Msb","TA","Mgh","M","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%81%D9%84%D8%AA/","headword_ar":"أفلت","entries":[{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=81284#ea3f62","body_html":"<span class=\"title1\">اف ل [أفلت]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: فَلَمَّا أَفَلَتْ .</span><br><span>قال: فلما زالت الشمس عن كبد السماء.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت كعب بن مالك الأنصاري وهو يرثيه عليه السلام:</span><br><span>فتغيّر القمر المنير لفقده </span><span class=\"red\">...</span><span> والشّمس كسفت وكادت تأفل </span>"}]}}