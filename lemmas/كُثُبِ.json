{"lemma":"كُثُبِ","slug":"كُثُبِ","root":"ك.ث.ب","root_slug":"ك-ث-ب","root_link":"/words/roots/ك-ث-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"كَثِيب","root":"كثب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n36666","n36669"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8F%D8%AB%D9%8F%D8%A8%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dune"}]},"etymology":{"source":"wiktextract","text":"From كَثَبَ (kaṯaba, “to collect, congregate”)."},"ipa":["/ka.θiːb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36666","headword_ar":"كثّب","root":"kvb","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takoviybN","text_ar":"تَكْثِيبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[a number of things, or a quantity,]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"little."},{"kind":"text","text":"The inf. n. is explained in the K by the word"},{"kind":"arabic","text_bw":"qil~ap","text_ar":"قِلَّة"},{"kind":"text","text":"; but this, says SM, I do not find in the [other] lexicons. (TA.)"}],"source_refs":[]},{"entry_id":"n36669","headword_ar":"كَثَبٌ","root":"kvb","body":[{"kind":"italic_en","text":"Nearness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with respect to place"},{"kind":"text","text":"]. (S, K.) The"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"in this word is sometimes changed into"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"huwa ka$abaka","text_ar":"هُوَ كَشَبَكَ"},{"kind":"italic_en","text":"He is near thee."},{"kind":"text","text":"Sb says that it is not used otherwise than as an adverbial noun of place. But you say,"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"yaromiY mino kavabK","text_ar":"يَرْمِى مِنْ كَثَبٍ"},{"kind":"italic_en","text":"He shoots,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"throws, from a near spot, and from a distance from which he can reach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hit."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":null}