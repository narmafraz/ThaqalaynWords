B6%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to remain, to be left over","tags":["intransitive"]},{"pos":"verb","gloss":"to exceed or outdo (especially in virtue, merit, or worth); to outworth","tags":["transitive"]},{"pos":"verb","gloss":"to become meritorious; to become illustrious"},{"pos":"verb","gloss":"to deem more favorable, to prefer, to favor","tags":["transitive"]},{"pos":"verb","gloss":"to make dominant, to privilege","tags":["transitive"]},{"pos":"verb","gloss":"to make dominant, to privilege; to make distinct or prominent, to distinguish, to honor, to grace","tags":["transitive"]},{"pos":"noun","gloss":"grace, favor (especially when seen as unmerited or unconditional); courtesy","tags":["uncountable"]},{"pos":"noun","gloss":"grace, favor (especially when seen as unmerited or unconditional); courtesy; a blessing, an honor, a generous gift, a bestowment","tags":["countable"]},{"pos":"noun","gloss":"distinction","tags":["uncountable"]},{"pos":"noun","gloss":"distinction; merit","tags":["uncountable"]},{"pos":"noun","gloss":"leftovers, remnants","tags":["uncountable"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34074","headword_ar":"فَضَلَ","root":"fDl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; three syn. dial. vars.; (S, O, Msb, K;) the second mentioned by ISk; and the third [said to be] anomalous and unparalleled; (S, O;) [but] it is a compound of two thereof, (S, O, Msb, K,) accord. to the companions of Sb, (S, O,) i. e. a compound of the second and the third, (K,) like"},{"kind":"arabic","text_bw":"naEima","text_ar":"نَعِمَ"},{"kind":"text","text":"having for its aor."},{"kind":"arabic","text_bw":"yanoEumu","text_ar":"يَنْعُمُ"},{"kind":"text","text":", (Sb, S, O, Msb,) and"},{"kind":"arabic","text_bw":"nakila","text_ar":"نَكِلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yanokulu","text_ar":"يَنْكُلُ"},{"kind":"text","text":", [but this I do not find in its proper art.,] and"},{"kind":"arabic","text_bw":"HaDira","text_ar":"حَضِرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHoDuru","text_ar":"يَحْضُرُ"},{"kind":"text","text":", [but this is disallowed by some,] and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaforugu","text_ar":"يَفْرُغُ"},{"kind":"text","text":", among perfect verbs, (Msb,) and"},{"kind":"arabic","text_bw":"mit~a","text_ar":"مِتَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tamuwtu","text_ar":"تَمُوتُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"dimota","text_ar":"دِمْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taduwmu","text_ar":"تَدُومُ"},{"kind":"text","text":", (Sb, S, O, Msb,) and"},{"kind":"arabic","text_bw":"kidota","text_ar":"كِدْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"takuwdu","text_ar":"تَكُودُ"},{"kind":"text","text":"; (Sb, S;) inf. n."},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":": (S, * O, * Msb, K: *) all signify"},{"kind":"italic_en","text":"It exceeded;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, redundant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superfluous;"},{"kind":"text","text":"[syn."},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":";] being used in relation to"},{"kind":"arabic","text_bw":"AlfaDolu","text_ar":"الفَضْلُ"},{"kind":"text","text":"(K, MF, TA) meaning"},{"kind":"arabic","text_bw":"Alz~iyaAdapu","text_ar":"الزِّيَادَةُ"},{"kind":"text","text":", as Ibn-Es-Seed says, (MF, TA,) [i. e.] as meaning the contr. of"},{"kind":"arabic","text_bw":"Aln~aqoSu","text_ar":"النَّقْصُ"},{"kind":"text","text":": (K, TA:) or the first of the three, i. e."},{"kind":"arabic","text_bw":"fDala","text_ar":"فضَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":", signifies thus,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"fuDolN","text_ar":"فُضْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuDulN","text_ar":"فُضُلٌ"},{"kind":"text","text":"are also inf. ns. [of the same, i. e.] signifying"},{"kind":"arabic","text_bw":"ziyaAdapN","text_ar":"زِيَادَةٌ"},{"kind":"text","text":", as in the saying, in a trad., accord. to different relaters,"},{"kind":"arabic","text_bw":"A_in~a lil~`hi malaAy^ikapF say~aArapF fuDolFA EalaY AlmalaAy^ikapi","text_ar":"اـِنَّ لِلّٰهِ مَلَايِكَةً سَيَّارَةً فُضْلًا عَلَى المَلَايِكَةِ"},{"kind":"arabic","text_bw":"Almurat~abiyna maEa AlxalaAy^iqi","text_ar":"المُرَتَّبِينَ مَعَ الخَلَايِقِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuDulFA","text_ar":"فُضُلًا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Verily to God belong angels who occupy themselves in ranging about, in addition to the angels who are stationed among the created,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"human and other, beings"},{"kind":"text","text":"]: (TA:) and all the three dial. vars. mentioned above signify"},{"kind":"italic_en","text":"it remained"},{"kind":"text","text":"[of a greater quantity or number]; syn."},{"kind":"arabic","text_bw":"baqiYa","text_ar":"بَقِىَ"},{"kind":"text","text":"; (S, * O, * Msb;) you say,"},{"kind":"arabic","text_bw":"faDala minohu $aYo'N","text_ar":"فَضَلَ مِنْهُ شَىْءٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":";"},{"kind":"italic_en","text":"somewhat remained thereof:"},{"kind":"text","text":"(S, O:) or from"},{"kind":"arabic","text_bw":"AlfaDolu","text_ar":"الفَضْلُ"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"Albaqiy~apu","text_ar":"البَقِيَّةُ"},{"kind":"text","text":", you say"},{"kind":"arabic","text_bw":"faDala","text_ar":"فَضَلَ"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"naSara","text_ar":"نَصَرَ"},{"kind":"text","text":", [i. e. aor."},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"Hasiba","text_ar":"حَسِبَ"},{"kind":"text","text":", [implying that the aor. is"},{"kind":"text","text":"and"},{"kind":"text","text":",] (K,) [accord. to the TK meaning"},{"kind":"italic_en","text":"it had somewhat remaining,"},{"kind":"text","text":"but accord. to SM,] using these verbs [which are said by him to be like"},{"kind":"arabic","text_bw":"naSara","text_ar":"نَصَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samiEa","text_ar":"سَمِعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hasiba","text_ar":"حَسِبَ"},{"kind":"text","text":", the last as mentioned by Lh,] in the phrase"},{"kind":"arabic","text_bw":"faDala minohu","text_ar":"فَضَلَ مِنْهُ"},{"kind":"arabic","text_bw":"$aYo'N","text_ar":"شَىْءٌ"},{"kind":"text","text":"[expl. above]. (TA.) ―         -b2-  ["},{"kind":"arabic","text_bw":"faDala","text_ar":"فَضَلَ"},{"kind":"text","text":"is trans. as well as intrans.] One says,"},{"kind":"arabic","text_bw":"faDalahu","text_ar":"فَضَلَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faDala Ealayohi","text_ar":"فَضَلَ عَلَيْهِ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. ns."},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuDuwlN","text_ar":"فُضُولٌ"},{"kind":"text","text":", [but see a distinction made between these two words voce"},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":", below,] meaning"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, exceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excelled, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(MA.) See also 4. [And see"},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":"below, last signification.]"},{"kind":"arabic","text_bw":"AlfaDolu","text_ar":"الفَضْلُ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"The overcoming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpassing, in highness, elevation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eminence, of rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation,"},{"kind":"text","text":"has but one form of verb,"},{"kind":"arabic","text_bw":"faDala","text_ar":"فَضَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqoEudu","text_ar":"يَقْعُدُ"},{"kind":"text","text":": he who relates the saying of the poet,"},{"kind":"quote","text":"wajadonaA naho$alFA faDalato fuqayomaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We found,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have found, that Nahshal"},{"kind":"text","text":"(the tribe so called)"},{"kind":"italic_en","text":"overcame"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"have overcome"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"Fukeym"},{"kind":"text","text":"(another tribe)], pronouncing the"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":"[in"},{"kind":"arabic","text_bw":"fDlt","text_ar":"فضلت"},{"kind":"text","text":"] with kesr, errs; not distinguishing between the two meanings: so says Ibn-Es-Seed, in the book entitled “ Kitáb el-Fark: ” and Es- Seymuree says, in his book entitled “ Kitáb etTebsireh, ”"},{"kind":"arabic","text_bw":"faDala","text_ar":"فَضَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"naSara","text_ar":"نَصَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yanoSuru","text_ar":"يَنْصُرُ"},{"kind":"text","text":", is from"},{"kind":"arabic","text_bw":"AlfaDolu","text_ar":"الفَضْلُ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"the ruling"},{"kind":"text","text":"[others]"},{"kind":"italic_en","text":"as a chief, lord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"master."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"faDalahu","text_ar":"فَضَلَهُ"},{"kind":"text","text":"signifies also [simply]"},{"kind":"italic_en","text":"He overcame him; surpassed him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained ascendency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the mastery, over him."},{"kind":"text","text":"(TA.) See also 3."}],"source_refs":["S","O","Msb","K","Sb","MF","TA"]}]}}