{"lemma":"قاعِدٌ","slug":"قاعِدٌ","root":"ق.ع.د","root_slug":"ق-ع-د","root_link":"/words/roots/ق-ع-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"قاعِد","root":"قعد","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n35966"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D8%B9%D9%90%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sit with"},{"pos":"adj","gloss":"active participle of قَعَدَ (qaʕada)","tags":["active","form-of","participle"],"examples":[{"text":"النَّارِ ذَاتِ الْوَقُودِ ۝ إِذْ هُمْ عَلَيْهَا قُعُودٌ ۝"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35966","headword_ar":"قَاعِدٌ","root":"qEd","body":[{"kind":"text","text":"[act. part. n. of"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Sitting; sitting down;"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"quEuwdN","text_ar":"قُعُودٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"quE~aAdN","text_ar":"قُعَّادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaAEiduwna","text_ar":"قَاعِدُونَ"},{"kind":"text","text":": (TA:) fem."},{"kind":"arabic","text_bw":"qaAEidapN","text_ar":"قَاعِدَةٌ"},{"kind":"text","text":"; pl."},{"kind":"arabic","text_bw":"qawaAEidu","text_ar":"قَوَاعِدُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaAEidaAtN","text_ar":"قَاعِدَاتٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  (assumed tropical:)  A sack"},{"kind":"italic_en","text":"full of grain;"},{"kind":"text","text":"(IAar, K;) as though by reason of its fulness it were sitting. (IAar.) ―         -b3-  [And from"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"text","text":"in the third meaning,]"},{"kind":"arabic","text_bw":"qaAEidN Eani Algazowi","text_ar":"قَاعِدٌ عَنِ الغَزْوِ"},{"kind":"text","text":"(tropical:)  A man"},{"kind":"italic_en","text":"holding back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstaining, from warring and plundering:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"quE~aAdN","text_ar":"قُعَّادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaAEiduwna","text_ar":"قَاعِدُونَ"},{"kind":"text","text":"; and quasi-pl. n."},{"kind":"arabic","text_bw":"qaEadN","text_ar":"قَعَدٌ"},{"kind":"text","text":": (L:) which last is also explained as signifying those"},{"kind":"italic_en","text":"who have"},{"kind":"text","text":"no"},{"kind":"arabic","text_bw":"diywaAn","text_ar":"دِيوَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"register in which they are enrolled as soldiers and stipendiaries"},{"kind":"text","text":"], (S, A, L, K,) and (as some say, L)"},{"kind":"italic_en","text":"who do not go forth to fight."},{"kind":"text","text":"(L, K.) ―         -b4-  [And hence, the pl.]"},{"kind":"arabic","text_bw":"qaEadN","text_ar":"قَعَدٌ"},{"kind":"text","text":", [which is, properly speaking, a quasi-pl. n.,] like"},{"kind":"arabic","text_bw":"HaArisN","text_ar":"حَارِسٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HarasN","text_ar":"حَرَسٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"xaAdimN","text_ar":"خَادِمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xadamN","text_ar":"خَدَمٌ"},{"kind":"text","text":": (TA:) ["},{"kind":"italic_en","text":"The Abstainers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Separatists:"},{"kind":"text","text":"] the"},{"kind":"arabic","text_bw":"qaEad","text_ar":"قَعَد"},{"kind":"text","text":"(so in the S, L, K: in the A, and some copies of the K, ↓"},{"kind":"arabic","text_bw":"qaEadap","text_ar":"قَعَدَة","orth_type":"arrow"},{"kind":"text","text":":) are (tropical:)  The ["},{"kind":"italic_en","text":"schismatics called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xawaArij","text_ar":"خَوَارِج"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"certain of the"},{"kind":"arabic","text_bw":"xwArj","text_ar":"خوارج"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"a people of the"},{"kind":"arabic","text_bw":"xwArj","text_ar":"خوارج"},{"kind":"italic_en","text":"who held back"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qaEaduwA","text_ar":"قَعَدُوا"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from aiding 'Alee, and from fighting against him;"},{"kind":"text","text":"(A;) certain of the"},{"kind":"arabic","text_bw":"Haruwriy~ap","text_ar":"حَرُورِيَّة"},{"kind":"text","text":"; (L;) the ["},{"kind":"italic_en","text":"schismatics called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"$uraAp","text_ar":"شُرَاة"},{"kind":"text","text":","},{"kind":"italic_en","text":"who hold the doctrine that government belongs only to God, but do not war;"},{"kind":"text","text":"(IAar, L;)"},{"kind":"italic_en","text":"who hold the doctrine that government belongs only to God, but do not go forth to war against a people."},{"kind":"text","text":"(L.) ―         -b5-  [And the sing.,]"},{"kind":"arabic","text_bw":"qaAEidN","text_ar":"قَاعِدٌ"},{"kind":"text","text":"(tropical:)  A woman"},{"kind":"italic_en","text":"who has ceased to bear children,"},{"kind":"text","text":"(S, K,) and"},{"kind":"italic_en","text":"to have the menstrual discharge,"},{"kind":"text","text":"(ISk, S, K,) and"},{"kind":"italic_en","text":"to have a husband:"},{"kind":"text","text":"(Zj, K:) or an"},{"kind":"italic_en","text":"old"},{"kind":"text","text":"woman,"},{"kind":"italic_en","text":"advanced in years:"},{"kind":"text","text":"(IAth:) pl."},{"kind":"arabic","text_bw":"qawaAEidu","text_ar":"قَوَاعِدُ"},{"kind":"text","text":": (ISk, S:) when you mean “ sitting, ” you say"},{"kind":"arabic","text_bw":"qaAEidapN","text_ar":"قَاعِدَةٌ"},{"kind":"text","text":". (ISk, IAth.) ―         -b6-"},{"kind":"arabic","text_bw":"naxolapN qaAEidapN","text_ar":"نَخْلَةٌ قَاعِدَةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A palm-tree bearing fruit one year and not another:"},{"kind":"text","text":"(A, TA:) or,"},{"kind":"italic_en","text":"that has not borne fruit in its year."},{"kind":"text","text":"(IKtt.) ―         -b7-  Also,"},{"kind":"arabic","text_bw":"qaAEidN","text_ar":"قَاعِدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"A palm-tree:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a young palm-tree:"},{"kind":"text","text":"pl. [or rather quasi-pl. n.]"},{"kind":"arabic","text_bw":"qaEadN","text_ar":"قَعَدٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"xadamN","text_ar":"خَدَمٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"xaAdimN","text_ar":"خَادِمٌ"},{"kind":"text","text":". (L.) ―         -b8-"},{"kind":"arabic","text_bw":"qaAEidN","text_ar":"قَاعِدٌ"},{"kind":"text","text":"(tropical:)  A young palm-tree"},{"kind":"italic_en","text":"having a trunk:"},{"kind":"text","text":"(A, K:) or, ["},{"kind":"italic_en","text":"of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the branches"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"may be reached by the hand."},{"kind":"text","text":"(S, K.) Ex."},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"arabic","text_bw":"A^aroDihimo ka*aA mina AlqaAEidi","text_ar":"اَرْضِهِمْ كَذَا مِنَ القَاعِدِ"},{"kind":"italic_en","text":"In their land are so many young palm-trees having trunks."},{"kind":"text","text":"(A.) Thus it is used us a gen. n. (TA.)       -A2-"},{"kind":"arabic","text_bw":"raHFY qaAEidapN","text_ar":"رَحًى قَاعِدَةٌ"},{"kind":"italic_en","text":"A mill which one turns by the handle with the hand."},{"kind":"text","text":"(L.)       -A3-"},{"kind":"arabic","text_bw":"Halabota qaAEidFA","text_ar":"حَلَبْتَ قَاعِدًا"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Hlb","text_ar":"حلب"},{"kind":"text","text":"."}],"source_refs":["Msb","TA","L","S","A","K","ISk","Zj","IAth"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%82%D8%A7%D8%B9%D8%AF/","headword_ar":"قاعدة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23482#d890b9","body_html":"<span>القاعدة: هي قضية كلية منطبقة على جميع جزئياتها.</span>"}]}}