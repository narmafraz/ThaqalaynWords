:"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"A beast,"},{"kind":"text","text":"(As, T, S,) or"},{"kind":"italic_en","text":"a camel,"},{"kind":"text","text":"(ISk, T,) or"},{"kind":"italic_en","text":"a she-camel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a cow,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"by means of which one conceals himself from the objects of the chase,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wild animals,"},{"kind":"text","text":"(As, ISk, T, S, M,)"},{"kind":"italic_en","text":"so deceiving them,"},{"kind":"text","text":"(ISk, T, M,)"},{"kind":"italic_en","text":"shooting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"casting, when he is able to do so:"},{"kind":"text","text":"(As, ISk, T, S:) or, accord. to AZ, it is with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", ["},{"kind":"arabic","text_bw":"dariyoy^apN","text_ar":"دَرِيْيَةٌ"},{"kind":"text","text":",] because the"},{"kind":"arabic","text_bw":"dryy^p","text_ar":"دريية"},{"kind":"text","text":"is driven ("},{"kind":"arabic","text_bw":"tudoraA^u","text_ar":"تُدْرَاُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"tudofaEu","text_ar":"تُدْفَعُ"},{"kind":"text","text":",) towards the objects of the chase. (S, M.) ―         -b2-  Also"},{"kind":"italic_en","text":"A wild animal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wild animals,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"waHo$","text_ar":"وَحْش"},{"kind":"text","text":",) specially"},{"kind":"italic_en","text":"of such as are objects of the chase."},{"kind":"text","text":"(M, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A thing,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"ring,"},{"kind":"text","text":"(Ham p. 75,)"},{"kind":"italic_en","text":"by aiming at which one learns to pierce"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thrust"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with the spear"},{"kind":"text","text":"]. (Ham, K.) So in a verse cited voce"},{"kind":"arabic","text_bw":"dariyoy^apN","text_ar":"دَرِيْيَةٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"drA^","text_ar":"درا"},{"kind":"text","text":". (Ham ubi suprà.)"}],"source_refs":["As","T","S","ISk","M","K"]}]},"classical_definitions":null}