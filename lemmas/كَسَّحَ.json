xicon.com/?s=%D9%83%D9%8E%D8%B3%D9%8E%D9%91%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sweep, to whoosh"},{"pos":"verb","gloss":"to be lame, to limp, to labour from infirmity of the limbs"},{"pos":"verb","gloss":"to make lame, to cripple"},{"pos":"noun","gloss":"verbal noun of كَسَحَ (kasaḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of كَسِحَ (kasiḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to prune, to clip"},{"pos":"noun","gloss":"verbal noun of كَسَحَ (kasaḥa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Borrowed from Classical Syriac ܟܣܰܚ (ksaḥ)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36947","headword_ar":"كَسَحَ","root":"ksH","body":[{"kind":"text","text":", (aor."},{"kind":"text","text":", K, inf. n."},{"kind":"arabic","text_bw":"kasoHN","text_ar":"كَسْحٌ"},{"kind":"text","text":", Msb,)"},{"kind":"italic_en","text":"He swept"},{"kind":"text","text":"a house, or"},{"kind":"italic_en","text":"chamber."},{"kind":"text","text":"(S, Msb, K,) [You say]"},{"kind":"arabic","text_bw":"kasaHati Alr~iyHu AlA^aroDa","text_ar":"كَسَحَتِ الرِّيحُ الاَرْضَ"},{"kind":"italic_en","text":"The wind swept off the dust from the surface of the ground."},{"kind":"text","text":"(S, K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"kasaHa","text_ar":"كَسَحَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He cleaned out"},{"kind":"text","text":"a well, and a canal or channel of running water, &c. (Msb.) ―         -b3-  [And hence also,] (tropical:)"},{"kind":"italic_en","text":"He cut"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"off; destroyed"},{"kind":"text","text":"it;"},{"kind":"italic_en","text":"did away with"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"carried"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"off:"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"he swept it away."},{"kind":"text","text":"] ―         -b4-"},{"kind":"arabic","text_bw":"kasaHonaA baniY fulaAnK","text_ar":"كَسَحْنَا بَنِى فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We extirpated the sons of such a one."},{"kind":"text","text":"(A.) ―         -b5-"},{"kind":"arabic","text_bw":"kasiHa","text_ar":"كَسِحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kasaHN","text_ar":"كَسَحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He had a heaviness in one of his legs, and dragged it when he walked:"},{"kind":"text","text":"(T:)"},{"kind":"italic_en","text":"he was crippled in the legs,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the arms:"},{"kind":"text","text":"(L, K:) mostly used in relation to the legs. (L.) [See also"},{"kind":"arabic","text_bw":"kusaAHN","text_ar":"كُسَاحٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Msb","K","T","L"]},{"entry_id":"n36949","headword_ar":"كَسْحٌ","root":"ksH","body":[{"kind":"italic_en","text":"Impotence,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"arising from a disease which attacks the hips, and weakens the leg."},{"kind":"text","text":"(TA.)"}],"source_refs":["K"]}]},"classical_definitions":null}