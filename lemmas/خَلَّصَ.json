n11265","n11272","n11273"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D9%8E%D9%91%D8%B5%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be pure, to be unadulterated (e.g. of water or wine)"},{"pos":"verb","gloss":"to be clear (of a goal, an idea, etc.)","tags":["figuratively"]},{"pos":"verb","gloss":"to belong"},{"pos":"verb","gloss":"to reach"},{"pos":"verb","gloss":"to come to, to arrive at"},{"pos":"verb","gloss":"to be or become free"},{"pos":"verb","gloss":"to be freed, to be liberated"},{"pos":"verb","gloss":"to get rid"},{"pos":"verb","gloss":"to be rescued, to be saved, to escape"},{"pos":"verb","gloss":"to attain salvation"},{"pos":"verb","gloss":"to be finished, to be done, to be concluded","tags":["colloquial"]},{"pos":"verb","gloss":"to be all gone, to be out","tags":["colloquial"]},{"pos":"verb","gloss":"to purify"},{"pos":"verb","gloss":"to rectify"},{"pos":"verb","gloss":"to clarify (a situation, etc.)"},{"pos":"verb","gloss":"to liberate, to rescue","examples":[{"text":"فَخَرَجَ إِيلَاذُ مِنْ عِنْدِ الْـمَلِكِ وَقَالَ: لَا أَقْتُلُهَا حَتَّى يَسْكُنَ عَنْهُ الْغَضَبُ، فَٱلْـمَرْأَةُ عَاقِلَةٌ سَدِيدَةُ الرَّأْيِ، مِنَ الْـمَلِكَاتِ الَّتِي لَيْسَ لَهَا عَدِيلٌ فِي النِّسَاءِ، وَلَيْسَ الْـمَلِكُ بِصَابِرٍ عَنْهَا وَقَدْ خَلَّصَتْهُ مِنَ الْـمَوْتِ، وَعَمِلَتْ أَعْمَالًا صَالِحَةً. وَرَجَاؤُنَا فِيهَا عَظِيمٌ."}]},{"pos":"verb","gloss":"to rid"},{"pos":"verb","gloss":"to settle, to pay for (a bill)"},{"pos":"verb","gloss":"to pay duty"},{"pos":"verb","gloss":"to redeem, to deliver"},{"pos":"verb","gloss":"to finish, to conclude","tags":["colloquial","transitive"]},{"pos":"verb","gloss":"to clear [with عَلَى (ʕalā) ‘goods’] (to take the necessary measures for goods getting through the airport, train station, or post)"},{"pos":"verb","gloss":"to check in"},{"pos":"noun","gloss":"plural of خَالِص (ḵāliṣ)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of خَالِص (ḵāliṣ)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11265","headword_ar":"خَلَصَ","root":"xlS","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"xuluwSN","text_ar":"خُلُوصٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"xalaASN","text_ar":"خَلَاصٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"xaAliSapN","text_ar":"خَالِصَةٌ"},{"kind":"text","text":", (K,) or the second and third of these are simple substs. [used as inf. ns., i. e., quasi-inf. ns.]; (TA;) and"},{"kind":"arabic","text_bw":"xaluSa","text_ar":"خَلُصَ"},{"kind":"text","text":"also; (Et-Towsheeh, TA;) but the former is that which is commonly known; (TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xaAliS","text_ar":"خَالِص"},{"kind":"text","text":", (S, A, K,) which signifies [here]"},{"kind":"italic_en","text":"clear, pure, sheer, free from admixture, unmingled, unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genuine;"},{"kind":"text","text":"(B, TA;) and"},{"kind":"italic_en","text":"white."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"xalaSa AnmaA='u mina Alkadari","text_ar":"خَلَصَ انمَا=ءُ مِنَ الكَدَرِ"},{"kind":"italic_en","text":"The water became clear from turbidness."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xalaSa Alz~ubodu","text_ar":"خَلَصَ الزُّبْدُ"},{"kind":"arabic","text_bw":"mina Alv~ufoli","text_ar":"مِنَ الثُّفْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The butter became clear from the dregs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sediment,"},{"kind":"text","text":"] in being cooked. (S.) ―         -b2-"},{"kind":"arabic","text_bw":"xalaSa mina","text_ar":"خَلَصَ مِنَ"},{"kind":"arabic","text_bw":"AlwaroTapi","text_ar":"الوَرْطَةِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"Alt~alafi","text_ar":"التَّلَفِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xalaASN","text_ar":"خَلَاصٌ"},{"kind":"text","text":"(A, Msb) and"},{"kind":"arabic","text_bw":"xuluwSN","text_ar":"خُلُوصٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maxolaSN","text_ar":"مَخْلَصٌ"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"He became safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, from embarrassment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from destruction,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"like as a thing becomes clear from its turbidness."},{"kind":"text","text":"(A.) [See also 5.] ―         -b3-"},{"kind":"arabic","text_bw":"xalaSa mina Alqawomi","text_ar":"خَلَصَ مِنَ القَوْمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He withdrew, retired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apart, from the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men."},{"kind":"text","text":"(A, TA.) It is said in the Kur [xii. 80],"},{"kind":"arabic","text_bw":"xalaSuwA najiy~FA","text_ar":"خَلَصُوا نَجِيًّا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They retired, conferring privately together."},{"kind":"text","text":"(Bd, Jel, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"xalaSa A_ilayohi","text_ar":"خَلَصَ اـِلَيْهِ"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"(TA,) inf. n."},{"kind":"arabic","text_bw":"xuluwSN","text_ar":"خُلُوصٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, S, and grief, and happiness, A, TA,)"},{"kind":"italic_en","text":"came to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reached, him:"},{"kind":"text","text":"(S, A, K, TA:)"},{"kind":"italic_en","text":"he came to, reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrived at, it;"},{"kind":"text","text":"namely, a place. (TA.) ―         -b5-  Also"},{"kind":"arabic","text_bw":"xalaSuwA A_ilayohi","text_ar":"خَلَصُوا اـِلَيْهِ"},{"kind":"italic_en","text":"They came to him"},{"kind":"text","text":"(namely a judge or governor)"},{"kind":"italic_en","text":"and referred to him their cause,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suit, for judgment."},{"kind":"text","text":"(T and L in art."},{"kind":"arabic","text_bw":"nf*","text_ar":"نفذ"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"xalaSa","text_ar":"خَلَصَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xalaASN","text_ar":"خَلَاصٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuluwSN","text_ar":"خُلُوصٌ"},{"kind":"text","text":"; (TA;) or ↓"},{"kind":"arabic","text_bw":"xl~S","text_ar":"خلّص","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taxoliySN","text_ar":"تَخْلِيصٌ"},{"kind":"text","text":"; (TA;) but the former is that which is found in the correct lexicons; (TA;)"},{"kind":"italic_en","text":"He took the"},{"kind":"arabic","text_bw":"xulaASap","text_ar":"خُلَاصَة"},{"kind":"text","text":"[q. v.] (K, TA) of, or from, clarified butter; (TA;) and ↓"},{"kind":"arabic","text_bw":"AxlS","text_ar":"اخلص","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ixolaASN","text_ar":"اـِخْلَاصٌ"},{"kind":"text","text":", signifies the same. (TA.) [See also this last below.]"}],"source_refs":["S","TA","A","K","Msb"]},{"entry_id":"n11272","headword_ar":"خِلْصٌ","root":"xlS","body":[{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"xuloSaAnN","text_ar":"خُلْصَانٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, TA) and ↓"},{"kind":"arabic","text_bw":"xaAliSapN","text_ar":"خَالِصَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, TA) (tropical:)"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"man's"},{"kind":"italic_en","text":"friend;"},{"kind":"text","text":"[or his"},{"kind":"italic_en","text":"sincere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"true,"},{"kind":"text","text":"] or his"},{"kind":"italic_en","text":"secret,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"private, friend;"},{"kind":"text","text":"or his"},{"kind":"italic_en","text":"companion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associate, who converses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talks,"},{"kind":"text","text":"with him; syn."},{"kind":"arabic","text_bw":"xidonN","text_ar":"خِدْنٌ"},{"kind":"text","text":"; (S, K, TA;) his"},{"kind":"italic_en","text":"particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, friend:"},{"kind":"text","text":"(TA:) ↓ the second is also used in a pl. sense: (S, TA:) pl. of the first,"},{"kind":"arabic","text_bw":"xulaSaA='u","text_ar":"خُلَصَا=ءُ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","A","K","TA"]},{"entry_id":"n11273","headword_ar":"خَلَصٌ","root":"xlS","body":[{"kind":"italic_en","text":"A kind of tree like the grape-vine"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"in its manner of growth,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"that clings to other trees, and rises high;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"having leaves of a dust-colour, thin, round, and wide; and a blossom like that of the"},{"kind":"arabic","text_bw":"mr","text_ar":"مر"},{"kind":"text","text":"[?];"},{"kind":"italic_en","text":"and tinged in the lower parts of its stems;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"sweet in odour; and having berries"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"like those of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the plant called"},{"kind":"arabic","text_bw":"EinabN Alv~aEolabi","text_ar":"عِنَبٌ الثَّعْلَبِ"},{"kind":"text","text":", [see art."},{"kind":"arabic","text_bw":"vElb","text_ar":"ثعلب"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"three and four together, red,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"like the beads of"},{"kind":"arabic","text_bw":"Eaqiyq","text_ar":"عَقِيق"},{"kind":"text","text":"[q. v.]; (K;)"},{"kind":"italic_en","text":"not eaten"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by men"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"but depastured:"},{"kind":"text","text":"(TA:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (K:) thus described by [AHn] Ed-Deenawaree, on the authority of an Arab of the desert. (TA.) See the end of the next paragraph."}],"source_refs":["K","TA"]}]}}