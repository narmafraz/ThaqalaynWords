,{"kind":"arabic","text_bw":"AlS~alaApa","text_ar":"الصَّلَاةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They used to assemble, and endeavour to ascertain the time of prayer:"},{"kind":"text","text":"but the common reading is"},{"kind":"arabic","text_bw":"yataHay~anuwna","text_ar":"يَتَحَيَّنُونَ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"He reclined upon a pillow."},{"kind":"text","text":"(K.)"}],"source_refs":["TA"]}]},"classical_definitions":null}