{"role":"present_1mp","form":"نُبِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبِيح","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3508"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to allow, to legitimise, to legalise, to authorize"},{"pos":"verb","gloss":"to reveal, to disclose"}]},"etymology":null,"ipa":["/ʔa.baː.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3508","headword_ar":"اباح","root":"bwH","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ibaAHapN","text_ar":"اـِبَاحَةٌ"},{"kind":"text","text":": see 1, in three places. ―         -b2-"},{"kind":"arabic","text_bw":"A_ibaAHapN","text_ar":"اـِبَاحَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AisotibaAHapN","text_ar":"اِسْتِبَاحَةٌ","orth_type":"arrow"},{"kind":"text","text":"are used as syn.: but it is said that the former signifies The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"allowable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free,"},{"kind":"text","text":"to him who desires it, or seeks it: and the latter, the"},{"kind":"italic_en","text":"taking"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as allowed, allowable, free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lawful."},{"kind":"text","text":"(MF.) You say,"},{"kind":"arabic","text_bw":"AbAH","text_ar":"اباح"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"italic_en","text":"He made the thing allowable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"AbAH maAlahu","text_ar":"اباح مَالَهُ"},{"kind":"italic_en","text":"He gave permission either to take or let alone his property; made it allowable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, either way one might choose to take."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^abaHotuka Al$~aYo'a","text_ar":"اَبَحْتُكَ الشَّىْءَ"},{"kind":"italic_en","text":"I made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have made, the thing allowable, free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lawful, to thee,"},{"kind":"text","text":"(S, L, K, TA,)"},{"kind":"italic_en","text":"to take it,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or let it alone,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"or do it,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or make use of it,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"or possess it;"},{"kind":"text","text":"but not by the law of the religion, for to do this belongs to God and his apostle; except in the language of this law. (MF, TA.) [Hence it is said that]"},{"kind":"arabic","text_bw":"A_ibaAHapN","text_ar":"اـِبَاحَةٌ"},{"kind":"text","text":"bears a signification similar to that of"},{"kind":"arabic","text_bw":"nuhobaY","text_ar":"نُهْبَى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Spoliation; a taking of spoil;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"taking"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as spoil;"},{"kind":"text","text":"a signification more properly belonging to the inf. n. of 10, q. v.]. (L.)"}],"source_refs":["S","L","K","TA"]}]}}