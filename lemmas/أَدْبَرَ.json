{"lemma":"أَدْبَرَ","slug":"أَدْبَرَ","root":"د.ب.ر","root_slug":"د-ب-ر","root_link":"/words/roots/د-ب-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَدْبَرْتَ","in_corpus":true,"count":14,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَدْبَرْتِ","in_corpus":true,"count":14,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَدْبَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَدْبَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَدْبَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَدْبَرَ","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَدْبَرَت","in_corpus":true,"count":14,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَدْبَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَدْبَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَدْبَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَدْبَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُدْبِر","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُدْبِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُدْبِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُدْبِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُدْبِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُدْبِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدْبِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدْبِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدْبِر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدْبِر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدْبِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدْبِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدْبِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدْبِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدْبِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدْبِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدْبِرْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُدْبِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدْبِر","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَدْبَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَدْبَرْتُ","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":88,"cross_references":{"qac":{"found":true,"lemma_key":"أَدْبَرَ","root":"دبر","pos":"V","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11992","n12017"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%92%D8%A8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"alternative form of تَدَبَّرَ (tadabbara)","tags":["alt-of","alternative"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11992","headword_ar":"ادبر","root":"dbx","body":[{"kind":"text","text":", (M, K, and Bd in ix. 25,) inf. n."},{"kind":"arabic","text_bw":"A_idobaArN","text_ar":"اـِدْبَارٌ"},{"kind":"text","text":"(S, M) and ↓"},{"kind":"arabic","text_bw":"duborN","text_ar":"دُبْرٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to Kr, but correctly the latter is a simple subst. [or quasi-inf. n.]; (M;) and ↓"},{"kind":"arabic","text_bw":"dabara","text_ar":"دَبَرَ","orth_type":"arrow"},{"kind":"text","text":", (IAar, S, K,) inf. n."},{"kind":"arabic","text_bw":"daborN","text_ar":"دَبْرٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"dubuwrN","text_ar":"دُبُورٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"He went, turning his back; turned back; went back; took a backward course; retreated; retired; retrograded; declined;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"wal~aYi","text_ar":"وَلَّىِ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"taA^ax~ara","text_ar":"تَاَخَّرَ"},{"kind":"text","text":"(IAar) and"},{"kind":"arabic","text_bw":"*ahaba A_ilaY xalofK","text_ar":"ذَهَبَ اـِلَى خَلْفٍ"},{"kind":"text","text":"; (Bd ubi suprà, and S and K in art."},{"kind":"arabic","text_bw":"qbl","text_ar":"قبل"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^aqobala","text_ar":"اَقْبَلَ"},{"kind":"text","text":". (S, Bd.) And"},{"kind":"arabic","text_bw":"Adbr bihi","text_ar":"ادبر بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"backward, with it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him; removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, backward"},{"kind":"text","text":"]. (S, K.) You say,"},{"kind":"arabic","text_bw":"yudobiru","text_ar":"يُدْبِرُ"},{"kind":"arabic","text_bw":"biAld~alowi A_ilaY AlHawoDi","text_ar":"بِالدَّلْوِ اـِلَى الحَوْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He goes back with the bucket to the watering-trough"},{"kind":"text","text":"]: opposed to the phrase"},{"kind":"arabic","text_bw":"yuqobilu bihaA A_ilaY biy^ori","text_ar":"يُقْبِلُ بِهَا اـِلَى بِيْرِ"},{"kind":"text","text":". (A.) See also"},{"kind":"arabic","text_bw":"dabiyrN","text_ar":"دَبِيرٌ"},{"kind":"text","text":", first sentence. And"},{"kind":"arabic","text_bw":"Adbr Eanohu","text_ar":"ادبر عَنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went back,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him"},{"kind":"text","text":"]. (Msb.) ―         -b2-  [Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"He feigned himself negligent of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inattentive to, the want of his friend;"},{"kind":"text","text":"(K;) as though he turned back from him. (TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"Adbr","text_ar":"ادبر"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"It went backward, to a bad state;"},{"kind":"text","text":"said of the affair, or case, of a people. (M, TA.) You say also,"},{"kind":"arabic","text_bw":"A^amorN fulaAnK A_ilaY A_iqobaAlK","text_ar":"اَمْرٌ فُلَانٍ اـِلَى اـِقْبَالٍ"},{"kind":"text","text":"and [in the contr. sense]"},{"kind":"arabic","text_bw":"AlY","text_ar":"الى"},{"kind":"arabic","text_bw":"A_idobaArN","text_ar":"اـِدْبَارٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, of such a one is inclining to advance,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to go backward, to a bad state"},{"kind":"text","text":"]. (A.) ["},{"kind":"arabic","text_bw":"A_idobaArN","text_ar":"اـِدْبَارٌ"},{"kind":"text","text":"often signifies The"},{"kind":"italic_en","text":"retiring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declining, of good fortune;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"A_iqobaAlN","text_ar":"اـِقْبَالٌ"},{"kind":"text","text":": see also 1, in the latter part of the paragraph.] And"},{"kind":"arabic","text_bw":"Adbr Alqawomu","text_ar":"ادبر القَوْمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The case of the people took a backward course, and there remained none of them."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Adbr Aln~ahaAri","text_ar":"ادبر النَّهَارِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"dabara","text_ar":"دَبَرَ","orth_type":"arrow"},{"kind":"text","text":"(inf. n. of the latter"},{"kind":"arabic","text_bw":"dubuwrN","text_ar":"دُبُورٌ"},{"kind":"text","text":", A) signify the same; (Fr, T, S, M;) i. e."},{"kind":"italic_en","text":"The day went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed;"},{"kind":"text","text":"(M, A;) and so"},{"kind":"arabic","text_bw":"AlS~ayofu","text_ar":"الصَّيْفُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the summer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the spring"},{"kind":"text","text":"]: and in like manner one says [in the contr. sense]"},{"kind":"arabic","text_bw":"A^aqobala","text_ar":"اَقْبَلَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qabala","text_ar":"قَبَلَ"},{"kind":"text","text":": so says Fr, and he adds, but you say of a man,"},{"kind":"arabic","text_bw":"Aqbl Alr~aAkibu","text_ar":"اقبل الرَّاكِبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Adbr","text_ar":"ادبر"},{"kind":"text","text":"only, with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", though [Az says] it seems to me that the two forms are applicable in the same manner to men as they are to times. (T.) Some read, in the Kur [lxxiv. 36], ↓"},{"kind":"arabic","text_bw":"waA@ll~ayoli A_i*aA dabara","text_ar":"وَا@للَّيْلِ اـِذَا دَبَرَ","orth_type":"arrow"},{"kind":"text","text":", (T, S,) which, accord. to some, means"},{"kind":"italic_en","text":"And the night when it cometh after the day;"},{"kind":"text","text":"(T;) or"},{"kind":"italic_en","text":"when it followeth the day:"},{"kind":"text","text":"(S: [for another rendering, see 1:]) others, (T, S,) the greater number, (T,) read"},{"kind":"arabic","text_bw":"A*A A^adobara","text_ar":"اذا اَدْبَرَ"},{"kind":"text","text":", (T, S,) meaning"},{"kind":"italic_en","text":"when it retreateth to depart."},{"kind":"text","text":"(T.) [Hence,]"},{"kind":"arabic","text_bw":"Adbrt AlS~alaApu","text_ar":"ادبرت الصَّلَاةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The prayer ended."},{"kind":"text","text":"(Bd in l. 39.) And"},{"kind":"arabic","text_bw":"waA_idobaAra Als~ujuwdi","text_ar":"وَاـِدْبَارَ السُّجُودِ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"waA_idobaAra Aln~ujuwmi","text_ar":"وَاـِدْبَارَ النُّجُومِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"duburN","text_ar":"دُبُرٌ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"Adbr","text_ar":"ادبر"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He died;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"dAbr","text_ar":"دابر","orth_type":"arrow"},{"kind":"text","text":"."},{"kind":"page_break","n":845},{"kind":"text","text":"(Lh, M, K. [See also"},{"kind":"arabic","text_bw":"dabara Alqawomu","text_ar":"دَبَرَ القَوْمُ"},{"kind":"text","text":", in the first paragraph.]) ―         -b4-"},{"kind":"arabic","text_bw":"maA A^aqobala mina Aljabali wamaA A^adobara","text_ar":"مَا اَقْبَلَ مِنَ الجَبَلِ وَمَا اَدْبَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA qabala","text_ar":"مَا قَبَلَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"minohu wamaA dabara","text_ar":"مِنْهُ وَمَا دَبَرَ","orth_type":"arrow"},{"kind":"text","text":"signify the same [i. e."},{"kind":"italic_en","text":"What is in front, of the mountain; and what is behind"},{"kind":"text","text":"]. (JK.)       -A2-"},{"kind":"arabic","text_bw":"Adbr","text_ar":"ادبر"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"to be behind him."},{"kind":"text","text":"(M.)       -A3-  And"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"(the saddle, S, K, or a burden, M, TA,) and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a man, S, Mgh,)"},{"kind":"italic_en","text":"caused"},{"kind":"text","text":"a camel, (S, M, Mgh,) or a horse or the like, (K,)"},{"kind":"italic_en","text":"to have galls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sores, on the back; galled the back."},{"kind":"text","text":"(M, Mgh, K. *) ―         -b2-  And"},{"kind":"italic_en","text":"His camel became galled in the back."},{"kind":"text","text":"(S, K.) ―         -b3-  See also 1, last signification.       -A4-  It is also said [app., of a man, as meaning"},{"kind":"italic_en","text":"He slit the ear of a she-camel in a particular manner,"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"when"},{"kind":"text","text":"(T)"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"fatolap","text_ar":"فَتْلَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"twisted slip formed by slitting"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"A_idobaArapN","text_ar":"اـِدْبَارَةٌ"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"of the ear of a she-camel,"},{"kind":"text","text":"(T, K,)"},{"kind":"italic_en","text":"it being slit,"},{"kind":"text","text":"(T, [but for"},{"kind":"arabic","text_bw":"A*A nHrt","text_ar":"اذا نحرت"},{"kind":"text","text":"in the TT and TA, from which this is taken, I read"},{"kind":"arabic","text_bw":"A_i*aA buHirato","text_ar":"اـِذَا بُحِرَتْ"},{"kind":"text","text":", an emendation evidently required,])"},{"kind":"italic_en","text":"turns towards the back of the neck:"},{"kind":"text","text":"(IAar, T, TT, K, * TA:) and"},{"kind":"arabic","text_bw":"A^aqobala","text_ar":"اَقْبَلَ"},{"kind":"text","text":"is said in like manner when this"},{"kind":"arabic","text_bw":"ftlp","text_ar":"فتلة"},{"kind":"text","text":"is turned towards the face. (IAar, T, TT, TA. [See also 3.])       -A5-  It signifies also"},{"kind":"arabic","text_bw":"Earafa dabiyrahu mino qabiylihi","text_ar":"عَرَفَ دَبِيرَهُ مِنْ قَبِيلِهِ"},{"kind":"text","text":", (IAar,) or"},{"kind":"arabic","text_bw":"Earafa","text_ar":"عَرَفَ"},{"kind":"arabic","text_bw":"qabiylahu mino dabiyrihi","text_ar":"قَبِيلَهُ مِنْ دَبِيرِهِ"},{"kind":"text","text":"; (K;) said of a man. (IAar. [See"},{"kind":"arabic","text_bw":"dabiyrN","text_ar":"دَبِيرٌ"},{"kind":"text","text":".])       -A6-  Also"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(K,) a man, (TA,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"a company of men, (S, M,)"},{"kind":"italic_en","text":"entered upon"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a time in which blew"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the wind called"},{"kind":"arabic","text_bw":"Ald~abuwr","text_ar":"الدَّبُور"},{"kind":"text","text":". (S, M, K.)       -A7-  And"},{"kind":"italic_en","text":"He journeyed on the day called"},{"kind":"arabic","text_bw":"dubaAr","text_ar":"دُبَار"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Wednesday."},{"kind":"text","text":"(K, TA.)       -A8-  And"},{"kind":"italic_en","text":"He became possessed of much property"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of many camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(Msb, * K.)"}],"source_refs":["S","M","IAar","K","TA","T","Mgh"]},{"entry_id":"n12017","headword_ar":"اَدْبَرُ","root":"dbx","body":[{"kind":"text","text":"; and its fem."},{"kind":"arabic","text_bw":"daboraA=hu","text_ar":"دَبْرَا=هُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dabirN","text_ar":"دَبِرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}