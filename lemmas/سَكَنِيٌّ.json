{"lemma":"سَكَنِيٌّ","slug":"سَكَنِيٌّ","root":"س.ك.ن","root_slug":"س-ك-ن","root_link":"/words/roots/س-ك-ن","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n20263"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%83%D9%8E%D9%86%D9%90%D9%8A%D9%8C%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20263","headword_ar":"سُكْنَى","root":"skn","body":[{"kind":"text","text":"is an inf. n. of"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"arabic","text_bw":"Ald~aAra","text_ar":"الدَّارَ"},{"kind":"text","text":": (MA, Mgh, L, JM:) or a simple subst. therefrom: (Msb:) or a subst. in the sense of"},{"kind":"arabic","text_bw":"A_isokaAnN","text_ar":"اـِسْكَانٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"ruqobaY","text_ar":"رُقْبَى"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"A_iroqaAbN","text_ar":"اـِرْقَابٌ"},{"kind":"text","text":": (Mgh:) see 1, in three places: or it is a subst. (S, L, K) also (L) from"},{"kind":"arabic","text_bw":"A^asokanahu Ald~aAra","text_ar":"اَسْكَنَهُ الدَّارَ"},{"kind":"text","text":", (S, L, K,) like as"},{"kind":"arabic","text_bw":"EutobaY","text_ar":"عُتْبَى"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"A_iEotaAbN","text_ar":"اـِعْتَابٌ"},{"kind":"text","text":", (S, L,) and so is ↓"},{"kind":"arabic","text_bw":"sakanN","text_ar":"سَكَنٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, L, K,) [which is app. mentioned in the Msb as an inf. n. of the former verb,] signifying, as also ↓"},{"kind":"arabic","text_bw":"sukonN","text_ar":"سُكْنٌ","orth_type":"arrow"},{"kind":"text","text":", [so in one place, as on the authority of Lth, in the L, and said in the MA to be, like"},{"kind":"arabic","text_bw":"sukonaY","text_ar":"سُكْنَى"},{"kind":"text","text":", an inf. n. of the verb first mentioned above,] The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"giving"},{"kind":"text","text":"] a man"},{"kind":"italic_en","text":"a place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abode, to inhabit, without rent;"},{"kind":"text","text":"(L, and Ham p. 400 in explanation of the first of these words;) the term"},{"kind":"arabic","text_bw":"sukonaY","text_ar":"سُكْنَى"},{"kind":"text","text":"being similar to"},{"kind":"arabic","text_bw":"EumoraY","text_ar":"عُمْرَى"},{"kind":"text","text":". (L.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"masokanN","text_ar":"مَسْكَنٌ"},{"kind":"text","text":", in five places."}],"source_refs":["MA","Mgh","L","JM","Msb","S","K","Lh"]}]},"classical_definitions":null}