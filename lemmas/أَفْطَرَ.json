3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفْطَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْطَرا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْطِرا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْطِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفْطَرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْطَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْطِرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْطِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفْطَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُفْطِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُفْطَر","in_corpus":true,"count":59,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفْطَر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْطِر","in_corpus":true,"count":59,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفْطِر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَفْطَرْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَفْطَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":367,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n34129"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%B7%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34129","headword_ar":"افطر","root":"fTr","body":[{"kind":"italic_en","text":"He broke his fast;"},{"kind":"text","text":"(S, * Mgh; *)"},{"kind":"italic_en","text":"he breakfasted; he ate and drank after fasting;"},{"kind":"text","text":"(Msb, * K;) as also ↓"},{"kind":"arabic","text_bw":"faTara","text_ar":"فَطَرَ","orth_type":"arrow"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"fuTuwrN","text_ar":"فُطُورٌ"},{"kind":"text","text":": (Msb, TA:)"},{"kind":"italic_en","text":"his fast became vitiated."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"AfTr","text_ar":"افطر"},{"kind":"text","text":"as quasi-pass. of"},{"kind":"arabic","text_bw":"faT~arotuhu","text_ar":"فَطَّرْتُهُ"},{"kind":"text","text":"is extr., (Sb,) like"},{"kind":"arabic","text_bw":"A^abo$ara","text_ar":"اَبْشَرَ"},{"kind":"text","text":"as quasi-pass. of"},{"kind":"arabic","text_bw":"ba$~arotuhu","text_ar":"بَشَّرْتُهُ"},{"kind":"text","text":". (Sb, Mgh.) You say"},{"kind":"arabic","text_bw":"AfTr EalaY tamorK","text_ar":"افطر عَلَى تَمْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He breakfasted upon dates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried dates;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he made dates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried dates, his breakfast, after sunset"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in Ramadán"},{"kind":"text","text":"]. (Msb.) In the saying"},{"kind":"arabic","text_bw":"SuwmuwA liruw^oyatihi waA^afoTiruwA liruwoyatihi","text_ar":"صُومُوا لِرُوْيَتِهِ وَاَفْطِرُوا لِرُوْيَتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Fast ye after the sight of it,"},{"kind":"text","text":"namely, the new moon commencing Ramadán,"},{"kind":"italic_en","text":"and break ye your fast after the sight of it,"},{"kind":"text","text":"namely, the new moon commencing Showwál], the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is in the sense of"},{"kind":"arabic","text_bw":"baEod","text_ar":"بَعْد"},{"kind":"text","text":", i. e.,"},{"kind":"arabic","text_bw":"baEoda ruw^oyatihi","text_ar":"بَعْدَ رُوْيَتِهِ"},{"kind":"text","text":". (Msb.) ―         -b2-"},{"kind":"italic_en","text":"It was time for him to break his fast:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"he entered upon the time of breaking his fast;"},{"kind":"text","text":"(Mgh, Msb, K;) like"},{"kind":"arabic","text_bw":"A^aSobaHa","text_ar":"اَصْبَحَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amosaY","text_ar":"اَمْسَى"},{"kind":"text","text":"as meaning “ he entered upon the time of morning ” and “ upon the time of evening: ” (Mgh, * Msb:) or"},{"kind":"italic_en","text":"he became in the predicament of those who break their fast, and so though he neither ate nor drank:"},{"kind":"text","text":"whence the trad.,"},{"kind":"arabic","text_bw":"A^afoTara","text_ar":"اَفْطَرَ"},{"kind":"arabic","text_bw":"AlHaAjimu waA@lomaHojuwmu","text_ar":"الحَاجِمُ وَا@لْمَحْجُومُ"},{"kind":"italic_en","text":"The cupper and the cupped place themselves in the predicament of those who break their fast:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it is time for the cupper and the cupped to break their fast:"},{"kind":"text","text":"or it is used after the manner of a harsh expression, and an imprecation against them. (IAth.)       -A2-"},{"kind":"arabic","text_bw":"AfTrhu","text_ar":"افطرهُ"},{"kind":"text","text":": see 2.       -A3-"},{"kind":"arabic","text_bw":"AfTr Aljiloda","text_ar":"افطر الجِلْدَ"},{"kind":"text","text":": see 1."}],"source_refs":["K","TA","Msb","Sb"]}]},"classical_definitions":null}