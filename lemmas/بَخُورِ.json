:"italic_en","text":"originally called"},{"kind":"arabic","text_bw":"EaroTaniyvaA","text_ar":"عَرْطَنِيثَا"},{"kind":"text","text":";"},{"kind":"italic_en","text":"hot; dry;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"having the property of clearing the complexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skin; aperient; diuretic;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"laxative;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"and very useful:"},{"kind":"text","text":"(K:) it is a laxative when used in the form of a suppository, or applied as a liniment below the navel. (TA.)"}],"source_refs":["S","A","Msb","K"]}]},"classical_definitions":null}