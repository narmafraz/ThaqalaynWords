"text_ar":"حُكْمٌ مُطْلَقٌ"},{"kind":"text","text":"means (assumed tropical:) ["},{"kind":"italic_en","text":"A judicial decision,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ordinance or the like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a rule, that is unrestricted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"absolute,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"in which is no exception."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"muTolaqu","text_ar":"مُطْلَقُ"},{"kind":"arabic","text_bw":"Alyadi AlyumonaY","text_ar":"اليَدِ اليُمْنَى"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"muTolaqa Alyadayoni","text_ar":"مُطْلَقَ اليَدَيْنِ"},{"kind":"text","text":": each applied to a horse: see"},{"kind":"arabic","text_bw":"TuluqN","text_ar":"طُلُقٌ"},{"kind":"text","text":".       -A2-  [Golius, as on the authority of Meyd, explains it as signifying also"},{"kind":"italic_en","text":"A place where horses meet to be sent forth to run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"race:"},{"kind":"text","text":"but what here next follows inclines me to think that it may be correctly"},{"kind":"arabic","text_bw":"muTal~aqN","text_ar":"مُطَلَّقٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n26991","headword_ar":"مُطَلِّقٌ","root":"Tlq","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"desiring to outstrip with his horse in a race."},{"kind":"text","text":"(K.)"}],"source_refs":[]}]},"classical_definitions":null}