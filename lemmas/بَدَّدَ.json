IAar","T","M","K"]},{"entry_id":"n1934","headword_ar":"بَدَدَ","root":"bd","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"badadFA","text_ar":"بَدَدًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"badaAdi","text_ar":"بَدَادِ"},{"kind":"text","text":", in three places:       -A2-  and see also 3.       -A3-"},{"kind":"arabic","text_bw":"maA laka bihi badadN","text_ar":"مَا لَكَ بِهِ بَدَدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bad~apN","text_ar":"بَدَّةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bid~apN","text_ar":"بِدَّةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Thou hast not power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, to do it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to bear it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to cope with him."},{"kind":"text","text":"(S, M, K.)"}],"source_refs":[]}]}}