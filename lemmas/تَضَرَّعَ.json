search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B6%D9%8E%D8%B1%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25787","headword_ar":"تضرّع","root":"DrE","body":[{"kind":"italic_en","text":"He lowered, humbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abased, himself:"},{"kind":"text","text":"(O, K, TA:) or"},{"kind":"italic_en","text":"he addressed himself with earnest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"energetic, supplication:"},{"kind":"text","text":"(TA:) syn."},{"kind":"arabic","text_bw":"Aibotahala","text_ar":"اِبْتَهَلَ"},{"kind":"text","text":", to God ("},{"kind":"arabic","text_bw":"A_ilaY A@ll~`hi","text_ar":"اـِلَى ا@للّٰهِ"},{"kind":"text","text":"): (S, O, K:) or"},{"kind":"italic_en","text":"he manifested"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"DaraAEap","text_ar":"ضَرَاعَة","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"severe poverty,"},{"kind":"text","text":"(O, TA:)"},{"kind":"italic_en","text":"and want,"},{"kind":"text","text":"(TA,) to God: (O, TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"taEar~aDa biTalabi AlHaAjapi","text_ar":"تَعَرَّضَ بِطَلَبِ الحَاجَةِ"},{"kind":"text","text":", (K, TA,) or"},{"kind":"arabic","text_bw":"yaTolubu AlHaAjapa","text_ar":"يَطْلُبُ الحَاجَةَ"},{"kind":"text","text":"; (CK;) you say,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN yataDar~aEu","text_ar":"جَا=ءَ فُلَانٌ يَتَضَرَّعُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yataEar~aDu","text_ar":"يَتَعَرَّضُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Such a one came asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petitioning, to another for a thing that he wanted."},{"kind":"text","text":"(Fr, S, O.) [See also"},{"kind":"arabic","text_bw":"taSar~aEa","text_ar":"تَصَرَّعَ"},{"kind":"text","text":".] ―         -b2-  Also"},{"kind":"italic_en","text":"He writhed; and asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"called, for aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour."},{"kind":"text","text":"(TA.) ―         -b3-  And, said of the shade, (tropical:)"},{"kind":"italic_en","text":"It contracted, shrank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decreased;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it went away;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qalaSa","text_ar":"قَلَصَ"},{"kind":"text","text":": (Ibn-'Abbád, O, K, TA:) and"},{"kind":"arabic","text_bw":"taSar~aEa","text_ar":"تَصَرَّعَ"},{"kind":"text","text":"is a dial. var. thereof. ―         -b4-  See also 2."}],"source_refs":["O","K","TA","S"]}]},"classical_definitions":null}