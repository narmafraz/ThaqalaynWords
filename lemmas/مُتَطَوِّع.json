{"lemma":"مُتَطَوِّع","slug":"مُتَطَوِّع","root":"ط.#.ع","root_slug":"ط-_-ع","root_link":"/words/roots/ط-_-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n27309"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AA%D9%8E%D8%B7%D9%8E%D9%88%D9%90%D9%91%D8%B9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of تَطَوَّعَ (taṭawwaʕa)","tags":["active","form-of","participle"],"examples":[{"text":"الَّذِينَ يَلْمِزُونَ ٱلْمُطَّوِّعِينَ مِنَ ٱلْمُؤْمِنِينَ فِي ٱلصَّدَقَاتِ[…]"}]},{"pos":"adj","gloss":"volunteer"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27309","headword_ar":"مُتَطَوِّعٌ","root":"TwE","body":[{"kind":"italic_en","text":"A supererogator in any good act."},{"kind":"text","text":"(O, K.) One says,"},{"kind":"arabic","text_bw":"faEalahu mutaTaw~iEFA","text_ar":"فَعَلَهُ مُتَطَوِّعًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He did it without its being incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on him; supererogatorily:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gratuitously, unasked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unbidden:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disinterestedly; not seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring, a compensation:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"mutabar~iEFA","text_ar":"مُتَبَرِّعًا"},{"kind":"text","text":"]. (S and K in art."},{"kind":"arabic","text_bw":"brE","text_ar":"برع"},{"kind":"text","text":".) And ↓"},{"kind":"arabic","text_bw":"AlmuT~aw~iEapu","text_ar":"المُطَّوِّعَةُ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Those who exceed what is obligatory on them in fighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warring, against unbelievers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(S, O, Msb;) originally"},{"kind":"arabic","text_bw":"AlmutaTaw~iEapu","text_ar":"المُتَطَوِّعَةُ"},{"kind":"text","text":": (Msb:) hence ↓"},{"kind":"arabic","text_bw":"AlmuT~aw~iEiyna","text_ar":"المُطَّوِّعِينَ","orth_type":"arrow"},{"kind":"text","text":"in the Kur ix. 80; originally"},{"kind":"arabic","text_bw":"AlmutaTaw~iEiyna","text_ar":"المُتَطَوِّعِينَ"},{"kind":"text","text":". (S, O.)"}],"source_refs":["Msb"]}]}}