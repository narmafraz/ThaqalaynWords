{"lemma":"صَرَعَ","slug":"صَرَعَ","root":"ص.ر.ع","root_slug":"ص-ر-ع","root_link":"/words/roots/ص-ر-ع","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"صَرَعْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"صَرَعْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"صَرَعْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"صَرَعْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"صَرَعْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"صَرَعَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"صَرَعَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"صَرَعا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"صَرَعَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"صَرَعُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"صَرَعْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَصْرَع","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَصْرَعِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَصْرَعِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَصْرَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَصْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَصْرَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصْرَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْرَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْرَع","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْرَع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْرَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْرَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْرَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْرَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْرَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صَرَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَرَعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْرَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْرَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n24197","n24198"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%B1%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to throw down to the ground"},{"pos":"verb","gloss":"to knock down"},{"pos":"verb","gloss":"to have an epileptic fit, to have a violent headache"},{"pos":"verb","gloss":"to be thrown down to the ground"},{"pos":"noun","gloss":"verbal noun of صُرِعَ (ṣuriʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of صَرَعَ (ṣaraʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"epilepsy"},{"pos":"noun","gloss":"resin"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24197","headword_ar":"صَرْعٌ","root":"SrE","body":[{"kind":"text","text":"an inf. n. of 1. (S, Msb, K.) ―         -b2-  Also, [as a subst.,"},{"kind":"italic_en","text":"Epilepsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falling sickness:"},{"kind":"text","text":"and sometimes, app.,"},{"kind":"italic_en","text":"ecstatic catalepsy; a sort of trance into which a person falls:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain disease,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"well known,"},{"kind":"text","text":"(S, O,)"},{"kind":"italic_en","text":"resembling madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diabolical possession,"},{"kind":"text","text":"(Msb,) accord."},{"kind":"page_break","n":1679},{"kind":"text","text":"to the Ra-ees [Ibn-Seenà, whom we call “ Avicenna ”], (TA,)"},{"kind":"italic_en","text":"preventing, but not completely, the vital organs from performing their actions"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"functions"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"the cause of which is an obstruction that occurs in one or more of the venters"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"buTuwn","text_ar":"بُطُون"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the brain and in the ducts of the"},{"kind":"arabic","text_bw":"A^aEoSaAb","text_ar":"اَعْصَاب"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"nerves"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by which the members are moved,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"arising"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from an abundant thick or viscous"},{"kind":"arabic","text_bw":"xiloT","text_ar":"خِلْط"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"humour"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"whereby the"},{"kind":"arabic","text_bw":"ruwH","text_ar":"رُوح"},{"kind":"text","text":"[by which is here meant, as in many other instances, the"},{"kind":"italic_en","text":"vital spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nervous fluid,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is prevented from pervading them in the natural manner, and consequently the members become"},{"kind":"text","text":"["},{"kind":"italic_en","text":"spasmodically"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"contracted."},{"kind":"text","text":"(K, TA.)       -A2-  Also"},{"kind":"italic_en","text":"A sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a state, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner of being:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"DarobN","text_ar":"ضَرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fan~N","text_ar":"فَنٌّ"},{"kind":"text","text":": (S, K:) of a thing: (K:) and so ↓"},{"kind":"arabic","text_bw":"SiroEN","text_ar":"صِرْعٌ","orth_type":"arrow"},{"kind":"text","text":": and likewise"},{"kind":"arabic","text_bw":"DaroEN","text_ar":"ضَرْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DiroEN","text_ar":"ضِرْعٌ"},{"kind":"text","text":": (TA:) [See also"},{"kind":"arabic","text_bw":"SaroEapN","text_ar":"صَرْعَةٌ"},{"kind":"text","text":":] pl. [of mult.]"},{"kind":"arabic","text_bw":"SuruwEN","text_ar":"صُرُوعٌ"},{"kind":"text","text":"(S, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^aSoruEN","text_ar":"اَصْرُعٌ"},{"kind":"text","text":". (K.) One says,"},{"kind":"arabic","text_bw":"huwa *uw","text_ar":"هُوَ ذُو"},{"kind":"arabic","text_bw":"SaroEayoni","text_ar":"صَرْعَيْنِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"*uw lawonayoni","text_ar":"ذُو لَوْنَيْنِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, has two sorts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two distinctive qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"properties"},{"kind":"text","text":"]. (Ibn-'Abbád, Z, O, K.) And"},{"kind":"arabic","text_bw":"tarakotuhumo SaroEayoni","text_ar":"تَرَكْتُهُمْ صَرْعَيْنِ"},{"kind":"italic_en","text":"I left them changing from state to state."},{"kind":"text","text":"(Ibn-'Abbád, O, K.) And"},{"kind":"arabic","text_bw":"liloA^amori SaroEaAni","text_ar":"لِلْاَمْرِ صَرْعَانِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"TarafaAni","text_ar":"طَرَفَانِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"There are two ways of performing the affair, either of which may be chosen"},{"kind":"text","text":"]. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"SiroEN","text_ar":"صِرْعٌ"},{"kind":"text","text":", in three places. ―         -b3-"},{"kind":"arabic","text_bw":"SaroEaAni","text_ar":"صَرْعَانِ"},{"kind":"italic_en","text":"Two camels of which one comes to the water when the other returns from it,"},{"kind":"text","text":"by reason of their [the camels'] multitude. (S, O, K.) ―         -b4-  And [hence, perhaps,]"},{"kind":"arabic","text_bw":"AlS~aroEaAni","text_ar":"الصَّرْعَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The night and the day;"},{"kind":"text","text":"(K;) [and] so ↓"},{"kind":"arabic","text_bw":"AlS~iroEaAni","text_ar":"الصِّرْعَانِ","orth_type":"arrow"},{"kind":"text","text":", with kesr, like"},{"kind":"arabic","text_bw":"AlS~irofaAni","text_ar":"الصِّرْفَانِ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"Srf","text_ar":"صرف"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"the forenoon and the afternoon; from the first part of day to midday and from midday to sunset;"},{"kind":"text","text":"each of these being termed"},{"kind":"arabic","text_bw":"SaroEN","text_ar":"صَرْعٌ"},{"kind":"text","text":": (S, O, K:) or"},{"kind":"italic_en","text":"the morning, between daybreak and sunrise, and the evening, between sunset and nightfall;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"AlEaSoraAni","text_ar":"العَصْرَانِ"},{"kind":"text","text":"; (S and K in explanation of"},{"kind":"arabic","text_bw":"AlA^aboradaAni","text_ar":"الاَبْرَدَانِ"},{"kind":"text","text":";) and some assert that it is formed by transposition from"},{"kind":"arabic","text_bw":"AlEaSoraAni","text_ar":"العَصْرَانِ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"the two extremities of the day."},{"kind":"text","text":"(A, TA.) And one says,"},{"kind":"arabic","text_bw":"A^atayotuhu SaroEaYi","text_ar":"اَتَيْتُهُ صَرْعَىِ"},{"kind":"arabic","text_bw":"Aln~ahaAri","text_ar":"النَّهَارِ"},{"kind":"italic_en","text":"I came to him in the morning and evening;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between daybreak and sunrise and between sunset and nightfall."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"laqiytuhu SaroEaYi","text_ar":"لَقِيتُهُ صَرْعَىِ"},{"kind":"arabic","text_bw":"Aln~ahaAri","text_ar":"النَّهَارِ"},{"kind":"italic_en","text":"I met him at the two extremities of the day."},{"kind":"text","text":"(A, TA.) Dhu-r-Rummeh says,"},{"kind":"quote","text":"kaA^an~aniY naAziEN yavoniyhi Eano waTanK\n                      \n                     \n                        SaroEaAni raAy^iHapF EaqolN wataqoyiydu"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"As though I were one,"},{"kind":"text","text":"i. e. a camel,"},{"kind":"italic_en","text":"yearning towards his place of abode, which an evening and a morning, in evening a binding of the fore shank to the arm and"},{"kind":"text","text":"in the morning"},{"kind":"italic_en","text":"a shackling of the legs, turn"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"keep"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"away from a settled abiding-place:"},{"kind":"text","text":"or, as Aboo-'Alee relates it,"},{"kind":"arabic","text_bw":"raAy^iHapN","text_ar":"رَايِحَةٌ"},{"kind":"text","text":", [as a partial substitute for"},{"kind":"arabic","text_bw":"SaroEaAni","text_ar":"صَرْعَانِ"},{"kind":"text","text":",] meaning,"},{"kind":"italic_en","text":"an evening,"},{"kind":"text","text":"when there is"},{"kind":"italic_en","text":"a binding of the fore shank to the arm, and a"},{"kind":"text","text":"morning, when there is"},{"kind":"italic_en","text":"a shackling of the legs;"},{"kind":"text","text":"for they bind the camel's fore shank to his arm in the evening when he is lying down, and they shackle his legs in the morning so that he may pasture [but not stray]: another reading is"},{"kind":"arabic","text_bw":"SaroEaAhu","text_ar":"صَرْعَاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"his morning and evening"},{"kind":"text","text":"]. (TA.) ―         -b5-  One says also,"},{"kind":"arabic","text_bw":"huwa SaroEu ka*aA","text_ar":"هُوَ صَرْعُ كَذَا"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"Hi*aA='ahu","text_ar":"حِذَا=ءَهُ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"It is over against,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corresponding to, such a thing"},{"kind":"text","text":"]. (O, K.)"}],"source_refs":["S","O","Msb","K","TA"]},{"entry_id":"n24198","headword_ar":"صِرْعٌ","root":"SrE","body":[{"kind":"text","text":"an inf. n. of 1. (S, K.)       -A2-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"muSaAriEN","text_ar":"مُصَارِعٌ"},{"kind":"text","text":". (K.) See the latter in two places.       -A3-  See also"},{"kind":"arabic","text_bw":"SaroEN","text_ar":"صَرْعٌ"},{"kind":"text","text":", former half. ―         -b2-  [Also"},{"kind":"italic_en","text":"Either of two opposite conditions"},{"kind":"text","text":"in which one is or stands &c. in respect of an affair or case.] One says,"},{"kind":"arabic","text_bw":"Talabotu mino fulaAnK HaAjapF faA@noSarafotu wamaA A^adoriY EalaY","text_ar":"طَلَبْتُ مِنْ فُلَانٍ حَاجَةً فَا@نْصَرَفْتُ وَمَا اَدْرِى عَلَى"},{"kind":"arabic","text_bw":"A^aY~i SiroEaYo A^amorihi huwa","text_ar":"اَىِّ صِرْعَىْ اَمْرِهِ هُوَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, of such a one, an object of want, and then turned away, and I know not in which of the two opposite conditions he was in respect of his affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case"},{"kind":"text","text":"]; i. e., his affair, or case, did not become apparent, or clear, or known, to me. (S, O, K. *) And a poet says,"},{"kind":"quote","text":"faruHotu wamaA wad~aEotu layolaY wamaA darato\n                      \n                     \n                        EalaY A^aY~i SiroEaYo A^amorihaA A^ataraw~aHu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I went, and bade not farewell to Leylà, and she knew not in which of the two opposite conditions in respect of her affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, I was going"},{"kind":"text","text":"]; i. e., whether I went from her presence retaining attachment, or forsaking; (S, TA;) or, as Z says, in a condition of success or of disappointment. (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"SaroEN","text_ar":"صَرْعٌ"},{"kind":"text","text":", in the middle of the paragraph. ―         -b4-  Also"},{"kind":"italic_en","text":"A like; a similar person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"SaroEN","text_ar":"صَرْعٌ","orth_type":"arrow"},{"kind":"text","text":". (O, K.) One says,"},{"kind":"arabic","text_bw":"humaA SiroEaAni","text_ar":"هُمَا صِرْعَانِ"},{"kind":"text","text":"(S, O) and ↓"},{"kind":"arabic","text_bw":"SaroEaAni","text_ar":"صَرْعَانِ","orth_type":"arrow"},{"kind":"text","text":"(O)"},{"kind":"italic_en","text":"They two are likes:"},{"kind":"text","text":"(S, O:) and so"},{"kind":"arabic","text_bw":"$iroEaAni","text_ar":"شِرْعَانِ"},{"kind":"text","text":", &c. (S.) And"},{"kind":"arabic","text_bw":"h`*aA SiroEuhu","text_ar":"هٰذَا صِرْعُهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SaroEuhu","text_ar":"صَرْعُهُ","orth_type":"arrow"},{"kind":"italic_en","text":"This is the like of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"DiroEuhu","text_ar":"ضِرْعُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DaroEuhu","text_ar":"ضَرْعُهُ"},{"kind":"text","text":", &c. (IAar, TA.) ―         -b5-  And"},{"kind":"italic_en","text":"A strand of a rope:"},{"kind":"text","text":"(O, K:) and so"},{"kind":"arabic","text_bw":"DiroEN","text_ar":"ضِرْعٌ"},{"kind":"text","text":": (O:) pl."},{"kind":"arabic","text_bw":"SuruwEN","text_ar":"صُرُوعٌ"},{"kind":"text","text":"(O, K) and"},{"kind":"arabic","text_bw":"DuruwEN","text_ar":"ضُرُوعٌ"},{"kind":"text","text":". (O.)"}],"source_refs":["S","O","K"]}]},"classical_definitions":null}