ole":"present_2mp","form":"تَجِلُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجِلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْلِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجِلّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْلِل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجِلّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْلِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجِلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجِلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجِلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجِلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجِلُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجِلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْلِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجِلّ","in_corpus":true,"count":101,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجِلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَلَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":867,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n6011","n6018","n6019","n6020"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"great"},{"pos":"adj","gloss":"bulky"},{"pos":"adj","gloss":"outstanding"},{"pos":"noun","gloss":"the bulk (of), the majority (of); the lion's share","tags":["construct"],"examples":[{"text":"مَا لَا يُدْرَكُ كُلُّهُ، لَا يُتْرَكُ جُلُّهُ.","english":"What is not wholly achieved is not to be largely abandoned."},{"text":"جل الناسِ أعداءُ على السرَّاءِ والضَّرَّا\nفلا يغرُرْكَ مبتسمٌ وإن أبدى لكَ البشرا\nففي الصدر حزازاتٌ تكادُ تمزقُ الصدرا\nولو كادوا النجومَ هوتْ من الخضراءِ للغبرا\nوما الدنيا إذا فكر تَ غير جهنمَ الصُّغرى\nألستَ ترى بها أمماً وكلٌّ تلعنُ الأخرى\nلقد جرَّبْتُ جُلَّهُمُ فلمْ أر فيهمُ خيرا","english":"Most men are rabid foes, / Be they in joy or woe!\nDo not be fooled by smiles, / Even if seeming kind:\nIn their breasts is hateful fury, / almost tearing their hearts apart!\nIf men could plot against the stars, / The stars would fall into the mire.\nLife, if you reflect, / Is but a \"lesser Hell\":\nDo you not see in it many nations? / And each of them execrates the other!\nI have appraised most sorts and kinds, / And in all, I saw no goodness!"}]},{"pos":"verb","gloss":"to be illustrious"},{"pos":"verb","gloss":"to be beyond or above"},{"pos":"verb","gloss":"to be exalted or dignified"},{"pos":"verb","gloss":"to grow old"},{"pos":"noun","gloss":"jasmine, rose","tags":["uncommon"]},{"pos":"noun","gloss":"horse-covering, saddlecloth","tags":["regional","uncommon"],"examples":[{"text":"ومن السوس: الأُتْرُجُّ ودُهن البنفسج والشاه سبرم والجِلال والبراذع.","english":"From Sūs one gets citrons, violet-oil, basil, and horse-covers and pack-saddles."},{"text":"وقد لبسوا التلاليس وجِلال الدوابّ وجعلوا فوق رءوسهم التراب والتبن.","english":"They were clothed in sacks and pelts of domestic beasts and had their heads covered with earth and straw."}]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew גַּל (gall).\n\nBorrowed from Classical Persian گُل (gul). Doublet of وَرْد (ward).\n\nBorrowed from Iranian. Compare Central Kurdish جِل (cil, “beggar’s clothes”), Classical Persian جُلّ (jull, “horse-covering, saddle-cloth”), Balti [script needed] (jol, “horse cover”), Yaghnobi [script needed] (jul, “horse-cloth”), Gurani [script needed] (jal, jul, “cover, cloth”). Doublet of شَلَّاق (šallāq), جُوَالَق (juwālaq), and جُوَال (juwāl)."},"ipa":["/d͡ʒall/","/d͡ʒull/","/d͡ʒal.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6011","headword_ar":"جَلَّّ","root":"jl","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajil~u","text_ar":"يَجِلُّ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jalaAlapN","text_ar":"جَلَالَةٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"jalaAlN","text_ar":"جَلَالٌ"},{"kind":"text","text":", (K, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"julAlFA","text_ar":"جُلالًا"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"jalaAlFA","text_ar":"جَلَالًا"},{"kind":"text","text":",]) or both, (TA, [but see what follows,]) and"},{"kind":"arabic","text_bw":"jul~aY","text_ar":"جُلَّى"},{"kind":"text","text":", (Ham p. 218, see this word below, under"},{"kind":"arabic","text_bw":"jalalN","text_ar":"جَلَلٌ"},{"kind":"text","text":",) [in its primary sense,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thick, gross, coarse, rough, rugged, rude, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulky:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"jaliylN","text_ar":"جَلِيلٌ"},{"kind":"text","text":":) and then,]"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, Msb,) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great;"},{"kind":"text","text":"(S, Msb, K, TA;) [said of a thing, meaning"},{"kind":"italic_en","text":"in size;"},{"kind":"text","text":"and] said of a man, meaning"},{"kind":"italic_en","text":"in estimation, rank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"arabic","text_bw":"jalaAlapN","text_ar":"جَلَالَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"greatness of estimation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity:"},{"kind":"text","text":"but"},{"kind":"arabic","text_bw":"jalaAlN","text_ar":"جَلَالٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"supreme greatness thereof:"},{"kind":"text","text":"(Er-Rághib, TA:) the latter is an attribute of God only; (As in Ham p. 607, Er-Rághib, TA;) except in few instances: (As ubi suprà:) or it means the"},{"kind":"italic_en","text":"greatness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"majesty,"},{"kind":"text","text":"of God: (S, Msb:) or his"},{"kind":"italic_en","text":"absolute independence."},{"kind":"text","text":"(Bd in lv. 27.) ["},{"kind":"arabic","text_bw":"Eaz~a wa jal~a","text_ar":"عَزَّ وَ جَلَّ"},{"kind":"text","text":", referring to the name of God expressed or understood, is a phrase of frequent occurrence, meaning,"},{"kind":"italic_en","text":"To Him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to Whom, belong might and majesty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glory and greatness"},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"yajilPu Eani AlA_iHaATapi bihi","text_ar":"يَجِلپُ عَنِ الاـِحَاطَةِ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is too great to be comprehended within limits"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"yajil~u A^ano yudoraka biAlHawaAs~i","text_ar":"يَجِلُّ اَنْ يُدْرَكَ بِالحَوَاسِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is too great to be perceived by the senses"},{"kind":"text","text":"] are phrases used in speaking of God. (Er-Rághib, TA.) ―         -b3-  The saying of El-Ahmar,"},{"kind":"quote","text":"yaA jal~a maA baEudato Ealayoka bilaAdunaA\n                      \n                     \n                        faA@boruqo biA^aroDika maA badaA laka waA@roEudi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O, how greatly distant to thee is our country! therefore threaten in thy land as long as it seems fit to thee, and menace"},{"kind":"text","text":"], means"},{"kind":"arabic","text_bw":"mA bEdt","text_ar":"ما بعدت"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^ajal~a","text_ar":"مَا اَجَلَّ","orth_type":"arrow"},{"kind":"text","text":"[&c.]. (S.) ―         -b4-  Also"},{"kind":"arabic","text_bw":"jal~a","text_ar":"جَلَّ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalaAlapN","text_ar":"جَلَالَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jalaAlN","text_ar":"جَلَالٌ"},{"kind":"text","text":", (K,) said of a man, (S,)"},{"kind":"italic_en","text":"He became old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced in age,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, in judgment."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jal~ato","text_ar":"جَلَّتْ"},{"kind":"text","text":"said of a she-camel,"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced in age:"},{"kind":"text","text":"(Abu-n-Nasr, S:) and so ↓"},{"kind":"arabic","text_bw":"tjAl~t","text_ar":"تجالّت","orth_type":"arrow"},{"kind":"text","text":"said of a woman. (TA.)       -A2-"},{"kind":"arabic","text_bw":"jal~ati AlhaAjinu Eani Alawladi","text_ar":"جَلَّتِ الهَاجِنُ عَنِ الَولَدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The girl married before she had arrived at puberty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the beast covered before she was of fit age,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was too young"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to bear offspring"},{"kind":"text","text":"]: (S:) a prov. (TA.) [Thus the verb bears two contr. significations. See also"},{"kind":"arabic","text_bw":"haAjinN","text_ar":"هَاجِنٌ"},{"kind":"text","text":".]       -A3-"},{"kind":"arabic","text_bw":"jal~a Alqawomu","text_ar":"جَلَّ القَوْمُ"},{"kind":"text","text":", (S, Msb, * K, *)"},{"kind":"arabic","text_bw":"Eani Albaladi","text_ar":"عَنِ البَلَدِ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Eano manaAzilihimo","text_ar":"عَنْ مَنَازِلِهِمْ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (Msb, K,) or"},{"kind":"text","text":"[contr. to rule], (S, Sgh,) or both, accord. to Ibn-Málik and others, (TA,) inf. n."},{"kind":"arabic","text_bw":"juluwlN","text_ar":"جُلُولٌ"},{"kind":"text","text":", (S, K,) [and"},{"kind":"arabic","text_bw":"jalaA='N","text_ar":"جَلَا=ءٌ"},{"kind":"text","text":"accord. to the K, but this is an inf. n. of"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, went forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrated,"},{"kind":"text","text":"(S, Msb, K,) like"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"from a country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town,"},{"kind":"text","text":"(Msb,) [or"},{"kind":"italic_en","text":"from their places of abode,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to another country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town."},{"kind":"text","text":"(S, Msb.)       -A4-"},{"kind":"arabic","text_bw":"jal~uwA AlA^aqiTa","text_ar":"جَلُّوا الاَقِطَ"},{"kind":"text","text":", (K,) [aor., accord. to rule,"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"jal~N","text_ar":"جَلٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"They took the main part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"preparation of milk termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AqT","text_ar":"اقط"},{"kind":"text","text":". (K.) [See also 5.] ―         -b2-"},{"kind":"arabic","text_bw":"jalalota h`*aA EalaY nafosika","text_ar":"جَلَلْتَ هٰذَا عَلَى نَفْسِكَ"},{"kind":"italic_en","text":"Thou hast brought this as an injury"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"janayotahu","text_ar":"جَنَيْتَهُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"upon thyself."},{"kind":"text","text":"(K.)       -A5-"},{"kind":"arabic","text_bw":"jal~a AlbaEara","text_ar":"جَلَّ البَعَرَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"jal~N","text_ar":"جَلٌّ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"jal~apN","text_ar":"جَلَّةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He picked up,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"collected with his hand,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"the camels',"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar, dung;"},{"kind":"text","text":"(S, K;) and ↓"},{"kind":"arabic","text_bw":"Ajtl~pu","text_ar":"اجتلّةُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, (S,) or"},{"kind":"italic_en","text":"he picked it up for fuel."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"jal~apN","text_ar":"جَلَّةٌ"},{"kind":"text","text":".]       -A6-  See also 2."}],"source_refs":["S","Msb","K","TA","Sgh"]},{"entry_id":"n6018","headword_ar":"جَلٌّ","root":"jl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"sail of a ship:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"juluwl~N","text_ar":"جُلُولٌّ"},{"kind":"text","text":". (S, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"jul~N","text_ar":"جُلٌّ"},{"kind":"text","text":", in two places:       -A3-  and"},{"kind":"arabic","text_bw":"jil~N","text_ar":"جِلٌّ"},{"kind":"text","text":":      -A4-  and"},{"kind":"arabic","text_bw":"jaliylN","text_ar":"جَلِيلٌ"},{"kind":"text","text":". ―         -b2-  Also"},{"kind":"italic_en","text":"Contemptible, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paltry:"},{"kind":"text","text":"thus bearing two contr. significations. (K.)"}],"source_refs":[]},{"entry_id":"n6019","headword_ar":"جُلٌّ","root":"jl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"greater, main, principal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, part"},{"kind":"text","text":"of a thing; the"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"thereof; the"},{"kind":"italic_en","text":"main, gross, mass,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulk,"},{"kind":"text","text":"of it; (S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"julaAlN","text_ar":"جُلَالٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"A^axa*a jul~ahu","text_ar":"اَخَذَ جُلَّهُ"},{"kind":"text","text":"(K, TA) and ↓"},{"kind":"arabic","text_bw":"julaAlahu","text_ar":"جُلَالَهُ","orth_type":"arrow"},{"kind":"text","text":"(S, Sgh, K) ["},{"kind":"italic_en","text":"He took the greater part of it"},{"kind":"text","text":"].       -A2-"},{"kind":"italic_en","text":"A horse-cloth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covering"},{"kind":"text","text":"(Msb, K,) of a horse or similar beast, (S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"for protection"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"from the cold;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"jal~N","text_ar":"جَلٌّ","orth_type":"arrow"},{"kind":"text","text":": (K:) [in Persian"},{"kind":"arabic","text_bw":"jalo","text_ar":"جَلْ"},{"kind":"text","text":":] pl. [of mult.]"},{"kind":"arabic","text_bw":"jilaAlN","text_ar":"جِلَالٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^ajolaAlN","text_ar":"اَجْلَالٌ"},{"kind":"text","text":", (Msb, K,) and"},{"kind":"arabic","text_bw":"A^ajil~apN","text_ar":"اَجِلَّةٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"jilaAlN","text_ar":"جِلَالٌ"},{"kind":"text","text":". (S, TA.) ―         -b2-  The"},{"kind":"italic_en","text":"cover of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thing with which one covers, a book,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"volume;"},{"kind":"text","text":"which latter is hence called ↓"},{"kind":"arabic","text_bw":"majal~apN","text_ar":"مَجَلَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (Er-Rághib in TA; but, in this sense, written without any vowel-sign.)       -A3-  The"},{"kind":"italic_en","text":"place of the pitching and constructing"},{"kind":"text","text":"of a tent or house. (K.)       -A4-  Also, (S, K,) and ↓"},{"kind":"arabic","text_bw":"jal~N","text_ar":"جَلٌّ","orth_type":"arrow"},{"kind":"text","text":", (K,) The"},{"kind":"italic_en","text":"rose,"},{"kind":"text","text":"(AHn, S, K,) the"},{"kind":"italic_en","text":"white"},{"kind":"text",