rm":"نَطْوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"طَوَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَوَيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُطْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَطْو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":true,"lemma_key":"طَوَى","root":"طوي","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27383","n27384","n27385","n27387"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D9%88%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be folded, to be rolled up"},{"pos":"verb","gloss":"to be hungry, to starve"},{"pos":"verb","gloss":"to be closed"},{"pos":"adj","gloss":"foldable, pliable, flexible, supple, bendable"},{"pos":"adj","gloss":"lank, slender, small in the belly"},{"pos":"noun","gloss":"bundle of garments, cloths together"},{"pos":"noun","gloss":"well cased in the inner with bricks"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27383","headword_ar":"طَوًى","root":"TwY","body":[{"kind":"italic_en","text":"A skin for water"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"milk;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"siqaA='N","text_ar":"سِقَا=ءٌ"},{"kind":"text","text":"; (K;) as also ↓"},{"kind":"arabic","text_bw":"TaY~N","text_ar":"طَىٌّ","orth_type":"arrow"},{"kind":"text","text":": or the former signifies"},{"kind":"italic_en","text":"a skin"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sqA='","text_ar":"سقا=ء"},{"kind":"text","text":")"},{"kind":"italic_en","text":"that has been folded having in it its moisture, and has consequently become dissundered;"},{"kind":"text","text":"app. an inf. n. [of"},{"kind":"arabic","text_bw":"TawiYa","text_ar":"طَوِىَ"},{"kind":"text","text":"] used as a subst. [properly so called]: and ↓"},{"kind":"arabic","text_bw":"siqaA='N TawK","text_ar":"سِقَا=ءٌ طَوٍ","orth_type":"arrow"},{"kind":"text","text":"signifies [the same, or]"},{"kind":"italic_en","text":"a skin that has been folded having in it moisture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"some remains of milk, in consequence of which it has become altered, and stinking, and dissundered by putrefaction."},{"kind":"text","text":"(TA.)       -A2-  Also"},{"kind":"italic_en","text":"Hunger;"},{"kind":"text","text":"(S;) [and] so ↓"},{"kind":"arabic","text_bw":"Taw~N","text_ar":"طَوٌّ","orth_type":"arrow"},{"kind":"text","text":"[if not a mistranscription]. (TA. [See"},{"kind":"arabic","text_bw":"TawiYa","text_ar":"طَوِىَ"},{"kind":"text","text":", of which the former is an inf. n., as also"},{"kind":"arabic","text_bw":"TiwFY","text_ar":"طِوًى"},{"kind":"text","text":".])"}],"source_refs":[]},{"entry_id":"n27384","headword_ar":"طُوًى","root":"TwY","body":[{"kind":"text","text":"is said by some to be like ↓"},{"kind":"arabic","text_bw":"TiwFY","text_ar":"طِوًى","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A thing twice done"},{"kind":"text","text":"[as though folded]; and to be thus in the Kur [xx. 12 and lxxix. 16]; meaning"},{"kind":"italic_en","text":"twice"},{"kind":"text","text":"sanctified [referring to the valley there mentioned]; (S, TA; [and thus expl., and said to be like"},{"kind":"arabic","text_bw":"vinFY","text_ar":"ثِنًى"},{"kind":"text","text":", in the Ksh and by Bd;]) or, as El-Hasan says,"},{"kind":"italic_en","text":"twice"},{"kind":"text","text":"blest and sanctified: (S, TA:) or meaning"},{"kind":"italic_en","text":"twice"},{"kind":"text","text":"called [referring to the calling of Moses mentioned in the context]. (Ksh and Bd in xx. 12, and in like manner says Er-Rághib.) [But"},{"kind":"arabic","text_bw":"TuwaY","text_ar":"طُوَى"},{"kind":"text","text":"(as most pronounce it) or"},{"kind":"arabic","text_bw":"TuwFY","text_ar":"طُوًى"},{"kind":"text","text":", in the Kur, is generally held to be the name of a certain valley. Golius explains"},{"kind":"arabic","text_bw":"TuwFY","text_ar":"طُوًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TiwFY","text_ar":"طِوًى"},{"kind":"text","text":"as meaning “ Plicata, plicabilis, res; ” which is a mistake: and he adds, “ Ambulatio, incessus reciprocatus, ultro citroque in se rediens: ” for the latter of these explanations, both of which he gives as on the authority of J and the K, I am quite unable to account.]"}],"source_refs":["S","TA"]},{"entry_id":"n27385","headword_ar":"طِوًى","root":"TwY","body":[{"kind":"text","text":": see the next preceding paragraph: ―         -b2-  and see also"},{"kind":"arabic","text_bw":"TaY~N","text_ar":"طَىٌّ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n27387","headword_ar":"طَوِىٌّ","root":"TwY","body":[{"kind":"italic_en","text":"A bundle of"},{"kind":"arabic","text_bw":"baz~","text_ar":"بَزّ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"cloths"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stuffs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"garments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a kind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kinds, thereof:"},{"kind":"text","text":"so called as being folded together]: thus in the Tekmileh [and in copies of the K]: in [some of] the copies of the K,"},{"kind":"arabic","text_bw":"mina Alburodi","text_ar":"مِنَ البُرْدِ"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"mn","text_ar":"من"},{"kind":"arabic","text_bw":"Albaz~i","text_ar":"البَزِّ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"A well that is cased"},{"kind":"text","text":"(S, M, Msb, * TA)"},{"kind":"italic_en","text":"with stones,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with baked bricks;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"TaY~N","text_ar":"طَىٌّ","orth_type":"arrow"},{"kind":"text","text":": (TA:) of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":": (Msb:) it is masc., but may be made fem. to accord. with the meaning [i. e."},{"kind":"arabic","text_bw":"biy^orN","text_ar":"بِيْرٌ"},{"kind":"text","text":"]: (M, TA:) pl."},{"kind":"arabic","text_bw":"A^aTowaA='N","text_ar":"اَطْوَا=ءٌ"},{"kind":"text","text":": accord. to the K, ↓"},{"kind":"arabic","text_bw":"Tawiy~apN","text_ar":"طَوِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a well;"},{"kind":"text","text":"but [SM says] I have not seen that any one has mentioned this. (TA.)       -A2-  And"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"saAEap","text_ar":"سَاعَة"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"short portion"},{"kind":"text","text":"] of the night: (K:) one says,"},{"kind":"arabic","text_bw":"A^atayotuhu baEoda TawiY~K mina All~ayoli","text_ar":"اَتَيْتُهُ بَعْدَ طَوِىٍّ مِنَ اللَّيْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came to him after a short portion of the night"},{"kind":"text","text":"]: mentioned by ISd. (TA.)"}],"source_refs":["TA","Msb","M","K"]}]}}