وا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعِيلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَعُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عُلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عُلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عِلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عِلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعُول","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعُول","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعِيل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعِيل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":59,"cross_references":{"qac":{"found":true,"lemma_key":"عال","root":"علو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":13},"lanes":{"found":true,"entry_ids":["n30431","n31063","n31256"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to provide for, to sustain"},{"pos":"verb","gloss":"to impoverish, to pauperize"},{"pos":"verb","gloss":"to be poor or needy"},{"pos":"verb","gloss":"to burden, to vex; to be burdensome"},{"pos":"verb","gloss":"to burden, to vex; to be bothersome, to be troublesome"},{"pos":"verb","gloss":"to greaten; to be dominant","tags":["intransitive"]},{"pos":"verb","gloss":"to greaten; to be intense or severe","tags":["intransitive"]},{"pos":"verb","gloss":"to be poor","examples":[{"text":"أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ\nوَوَجَدَكَ ضَالًّا فَهَدَى\nوَوَجَدَكَ عَائِلًا فَأَغْنَىٰ"}]},{"pos":"verb","gloss":"to engage in milking constantly, to milk morning, noon, and night, to milk before an udder is at full capacity or has had time to recover","tags":["Classical"]},{"pos":"adj","gloss":"active participle of عَلَا (ʕalā) or active participle of عَلِيَ (ʕaliya).","tags":["Classical","active","form-of","participle"]},{"pos":"adj","gloss":"high","tags":["Classical"]},{"pos":"adj","gloss":"exalted, lofty, excellent","tags":["Classical"]},{"pos":"noun","gloss":"The upper part of something","tags":["Classical"],"examples":[{"text":"فَلَمَّا جَاءَ أَمْرُنَا جَعَلْنَا عَالِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهَا حِجَارَةً مِّنْ سِجِّيلٍ مَّنْضُودٍ","english":"So when Our command came, We made the highest part its lowest and rained upon them stones of layered hard clay."}]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb form I from the root ع ل ي (ʕ l y)."},"ipa":["/ʕaː.lin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30431","headword_ar":"عَالٍ","root":"Elw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaliY~N","text_ar":"عَلِىٌّ"},{"kind":"text","text":". ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"rajulN EaAliY AlkaEobi","text_ar":"رَجُلٌ عَالِى الكَعْبِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A man who is elevated, exalted, eminent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noble."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"kaEobN","text_ar":"كَعْبٌ"},{"kind":"text","text":".]) It is said in a trad. respecting Keyleh,"},{"kind":"arabic","text_bw":"laA yazaAlu kaEobuki EaAlayFA","text_ar":"لَا يَزَالُ كَعْبُكِ عَالَيًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"May thou not cease to be elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noble; exalted above such as treats,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regards, thee with enmity."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"mino EaAlK","text_ar":"مِنْ عَالٍ"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"mino Eali","text_ar":"مِنْ عَلِ"},{"kind":"text","text":", q. v. (S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"EaAliyapu Ald~ami","text_ar":"عَالِيَةُ الدَّمِ"},{"kind":"text","text":", said of the"},{"kind":"arabic","text_bw":"HaAy^iD","text_ar":"حَايِض"},{"kind":"text","text":", means One"},{"kind":"italic_en","text":"whose blood rises above the water."},{"kind":"text","text":"(TA.) ―         -b5-  ["},{"kind":"arabic","text_bw":"EaAlK","text_ar":"عَالٍ"},{"kind":"text","text":"applied to a word, or form of word, signifies (assumed tropical:)"},{"kind":"italic_en","text":"Of high authority, approved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chaste:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"usual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"common:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^aEolaY","text_ar":"اَعْلَى"},{"kind":"text","text":".]       -A2-  See also"},{"kind":"arabic","text_bw":"EaAy^ilN","text_ar":"عَايِلٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n31063","headword_ar":"عَالٌ","root":"Ewl","body":[{"kind":"text","text":"a word occurring in the saying"},{"kind":"arabic","text_bw":"maA lahu EaAlN","text_ar":"مَا لَهُ عَالٌ"},{"kind":"arabic","text_bw":"walaA maAlN","text_ar":"وَلَا مَالٌ"},{"kind":"text","text":", which means"},{"kind":"italic_en","text":"He has not anything belonging to him."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n31256","headword_ar":"عَالَ","root":"Eyl","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEiylu","text_ar":"يَعِيلُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EayolapN","text_ar":"عَيْلَةٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) [afterwards said in the K to be the subst. from this verb] and"},{"kind":"arabic","text_bw":"EuyuwlN","text_ar":"عُيُولٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"EiyuwlN","text_ar":"عِيُولٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEiylN","text_ar":"مَعِيلٌ"},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"EAl","text_ar":"عال"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEuwlu","text_ar":"يَعُولُ"},{"kind":"text","text":"; (Ks, TA in art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":";) and ↓"},{"kind":"arabic","text_bw":"AEAl","text_ar":"اعال","orth_type":"arrow"},{"kind":"text","text":"; (K in that art.;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, poor,"},{"kind":"text","text":"(S, Mgh, O, Msb, K,) and"},{"kind":"italic_en","text":"in want."},{"kind":"text","text":"(S, O.) So in the saying"},{"kind":"arabic","text_bw":"maA lahu maAla waEaAla","text_ar":"مَا لَهُ مَالَ وَعَالَ"},{"kind":"text","text":", [of which see another explanation in art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":",] a form of imprecation. (TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"maA EaAla muqotaSidN walaA yaEiylu","text_ar":"مَا عَالَ مُقْتَصِدٌ وَلَا يَعِيلُ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"One following the right course"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"has not become poor"},{"kind":"text","text":"["},{"kind":"italic_en","text":"nor will he become poor"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"laA yaEiylu A^aHadN EalaY AlqaSodi","text_ar":"لَا يَعِيلُ اَحَدٌ عَلَى القَصْدِ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"yaquwlu","text_ar":"يَقُولُ"},{"kind":"text","text":", expl. in art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":"], (Yoo, TA.) ―         -b2-  See also 4.       -A2-"},{"kind":"arabic","text_bw":"EaAlaniY","text_ar":"عَالَنِى"},{"kind":"text","text":", (S, O, K,) aor. as above, (S, O,) inf. n."},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEiylN","text_ar":"مَعِيلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, wanted by me, and unattainable to me:"},{"kind":"text","text":"(S, O, K:) mentioned by El-Ahmar. (S, O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EAl AlD~aAl~apa","text_ar":"عال الضَّالَّةَ"},{"kind":"text","text":", (S, O, K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EayalaAnN","text_ar":"عَيَلَانٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"He knew not where to seek the stray beast."},{"kind":"text","text":"(S, O, K.)       -A3-"},{"kind":"arabic","text_bw":"EAl","text_ar":"عال"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"EAl fiY ma$oyihi","text_ar":"عال فِى مَشْيِهِ"},{"kind":"text","text":", (K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":", (S, O,) said of a horse, (S, O, TA,) and of a man, (S, TA,)"},{"kind":"italic_en","text":"He inclined from side to side in his gait,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"(when said of a man, S)"},{"kind":"italic_en","text":"was proud, haughty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self-conceited, therein:"},{"kind":"text","text":"(S, K:) the doing so in a horse is commended, as indicative of his generousness: (TA:) and ↓"},{"kind":"arabic","text_bw":"tEy~l","text_ar":"تعيّل","orth_type":"arrow"},{"kind":"text","text":"signifies the same, (O, K,) said of a man. (O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EAl fiY AlA^aroDi","text_ar":"عال فِى الاَرْضِ"},{"kind":"text","text":", (O, K,) aor. as above, (O,) inf. n."},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Euyuwl","text_ar":"عُيُول"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuyuwlN","text_ar":"عُيُولٌ"},{"kind":"text","text":", thus in the K, i. e. with damm and fet-h, but in the M ["},{"kind":"arabic","text_bw":"EuyuwlN","text_ar":"عُيُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiyuwlN","text_ar":"عِيُولٌ"},{"kind":"text","text":", i. e.] with damm and kesr, [of the like whereof there are many instances, one of them in the first sentence above,] (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, O)"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"and round about,"},{"kind":"text","text":"(K, TA, but not in the CK)"},{"kind":"italic_en","text":"in the land;"},{"kind":"text","text":"(O, K;) or"},{"kind":"italic_en","text":"journeyed therein seeking sustenance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for the purpose of traffic;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Daraba fiyhaA","text_ar":"ضَرَبَ فِيهَا"},{"kind":"text","text":": so says IAmb. (O.) ―         -b3-"},{"kind":"arabic","text_bw":"EAl AlmiyzaAnu","text_ar":"عال المِيزَانُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEiylu","text_ar":"يَعِيلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaEuwlu","text_ar":"يَعُولُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EayolN","text_ar":"عَيْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EawolN","text_ar":"عَوْلٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":"."}],"source_refs":["S","Mgh","O","Msb","K","TA"]}]},"classical_definitions":null}