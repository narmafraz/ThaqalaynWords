en":"m","num":"p"},{"role":"present_2mp","form":"تَمْعَطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَمْعَطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَمْعَط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَمْعَط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَمْعَطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمْعَطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَمْعَطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمْعَطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَمْعَطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمْعَطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَمْعَطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَمْعَط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَمْعَط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"مَعَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مَعَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n29512","n29648","n38750","n38754"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B9%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29512","headword_ar":"مَعَطٌّ","root":"ET","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A place of slitting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rending"},{"kind":"text","text":"&c.]. One says"},{"kind":"arabic","text_bw":"fatoqN waAsiEu AlmaEaT~i","text_ar":"فَتْقٌ وَاسِعُ المَعَطِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A rent of which the place of slitting is wide"},{"kind":"text","text":"]. (TA.)"}],"source_refs":[]},{"entry_id":"n29648","headword_ar":"مُعْطٍ","root":"ETw","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Giving,"},{"kind":"text","text":"&c.]. When thou desirest Zeyd [i. e. any person] to give thee a thing, thou sayest,"},{"kind":"arabic","text_bw":"halo A^anota muEoTiy~ahu","text_ar":"هَلْ اَنْتَ مُعْطِيَّهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Art thou my giver of it?"},{"kind":"text","text":"], with fet-h and teshdeed to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":": and in like manner thou sayest to a pl. number,"},{"kind":"arabic","text_bw":"halo A^anotumo","text_ar":"هَلْ اَنْتُمْ"},{"kind":"arabic","text_bw":"muEoTiy~ahu","text_ar":"مُعْطِيَّهُ"},{"kind":"text","text":", because the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"[of the word"},{"kind":"arabic","text_bw":"muEoTuwna","text_ar":"مُعْطُونَ"},{"kind":"text","text":"] falls out by reason of the word's becoming a prefixed noun, and the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and incorporated [into the pronominal"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"], and the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"is pronounced with fet-h because [originally] preceded by a quiescent letter [i. e. the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"which is changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"]: and to two persons thou sayest,"},{"kind":"arabic","text_bw":"halo","text_ar":"هَلْ"},{"kind":"arabic","text_bw":"A^anotumaA muEoTiyaAyahu","text_ar":"اَنْتُمَا مُعْطِيَايَهُ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":": and thus you do in similar cases. (S, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"qawosN","text_ar":"قَوْسٌ"},{"kind":"arabic","text_bw":"muEoTiyapN","text_ar":"مُعْطِيَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A pliable bow, not rigid nor resisting to him who pulls the string:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"that has been bent and not been broken."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"EaTowaY","text_ar":"عَطْوَى"},{"kind":"text","text":".]"},{"kind":"page_break","n":2086}],"source_refs":[]},{"entry_id":"n38750","headword_ar":"مَعِطَ","root":"mET","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"maEaTN","text_ar":"مَعَطٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, without hair upon his body:"},{"kind":"text","text":"(S:) and in like manner you say of a man's skin: (TA:) and of a wolf, meaning"},{"kind":"italic_en","text":"his hair fell off by degrees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part after part:"},{"kind":"text","text":"but you should not say"},{"kind":"arabic","text_bw":"maEiTa $aEaruhu","text_ar":"مَعِطَ شَعَرُهُ"},{"kind":"text","text":": (S:) [but see 5:] or, said of a wolf, it signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, mischievous, malignant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"his hair became scanty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"little,"},{"kind":"text","text":"(K,) and ↓"},{"kind":"arabic","text_bw":"tmE~T","text_ar":"تمعّط","orth_type":"arrow"},{"kind":"text","text":"said of a wolf,"},{"kind":"italic_en","text":"his hair fell off:"},{"kind":"text","text":"(Mgh, Msb:) and ↓"},{"kind":"arabic","text_bw":"A_im~aEaTa","text_ar":"اـِمَّعَطَ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) of the measure"},{"kind":"arabic","text_bw":"A_ifotaEala","text_ar":"اـِفْتَعَلَ"},{"kind":"text","text":", or"},{"kind":"page_break","n":2725},{"kind":"text","text":"[rather]"},{"kind":"arabic","text_bw":"A_inofaEala","text_ar":"اـِنْفَعَلَ"},{"kind":"text","text":", (accord. to different copies of the K,) said of a rope, (S, K,) &c., (S,)"},{"kind":"italic_en","text":"it became worn smooth."},{"kind":"text","text":"(S, K.) ―         -b2-  See also 5.       -A2-"},{"kind":"arabic","text_bw":"maEaTa","text_ar":"مَعَطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"maEoTN","text_ar":"مَعْطٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He plucked out"},{"kind":"text","text":"hair [or wool] (K, TA,) from the head of a sheep or goat. (TA.)"}],"source_refs":["S","K","TA","Mgh","Msb"]},{"entry_id":"n38754","headword_ar":"مَعِطٌ","root":"mET","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^amoEaTu","text_ar":"اَمْعَطُ"},{"kind":"text","text":"."}],"source_refs":[]}]}}