{"lemma":"سَرَّ","slug":"سَرَّ","root":"س.ر.ر","root_slug":"س-ر-ر","root_link":"/words/roots/س-ر-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَرَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَرَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَرَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَرَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَرَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَرَّ","in_corpus":true,"count":26,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَرَّت","in_corpus":true,"count":8,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَرّا","in_corpus":true,"count":34,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَرَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَرُّوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَرَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسُرّ","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْرُر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسُرِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسُرِّي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسُرّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسُرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسُرُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْرُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسُرّ","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْرُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسُرّ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْرُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسُرّا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسُرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسُرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسُرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْرُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسُرّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسُرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":110,"cross_references":{"qac":{"found":true,"lemma_key":"سَرَّ","root":"سرر","pos":"N","occurrence_count":11},"wiktextract":{"found":true,"entry_count":10,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":17},"lanes":{"found":true,"entry_ids":["","n19417","n19418","n19419"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gladden, to make happy, to delight, to cheer, to rejoice"},{"pos":"verb","gloss":"to satisfy"},{"pos":"verb","gloss":"to pass"},{"pos":"verb","gloss":"to be glad, to be happy, to be delighted, to take pleasure in"},{"pos":"noun","gloss":"verbal noun of سَرَّ (sarra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of سَرَّ (sarra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"umbilical cord, navel string"},{"pos":"verb","gloss":"to cut off the navel string of (someone)"},{"pos":"verb","gloss":"to hurt the navel of (someone)"},{"pos":"verb","gloss":"to complain of pain in the navel"},{"pos":"noun","gloss":"secret, secret thought","tags":["countable","uncountable"]},{"pos":"noun","gloss":"heart, inmost","tags":["countable","uncountable"]},{"pos":"noun","gloss":"secrecy, mystery","tags":["countable","uncountable"]},{"pos":"noun","gloss":"sacrament (Christianity)","tags":["countable","uncountable"]},{"pos":"noun","gloss":"underlying reason","tags":["countable","uncountable"]},{"pos":"noun","gloss":"line in the palm","tags":["countable","uncountable"]},{"pos":"noun","gloss":"head, chief","tags":["countable","in-compounds","uncountable"],"examples":[{"text":"سِرْدَار (sirdār)","english":"supreme commander; commanding general"},{"text":"سَرْعَسْكَر (sarʕaskar)","english":"Ottoman general"}]}]},"etymology":{"source":"wiktextract","text":"Compare Ugaritic 𐎌𐎗 (šr).\n\nDenominal verb from سُرّ (surr, “umbilical cord”) and سُرَّة (surra, “navel”).\n\nDenominal verb from سُرَّة (surra, “navel”).\n\nFor the fourth sense, compare Classical Syriac ܐ݇ܪܵܙܵܐ (rāzā, “sacrament”, literally “secret”).\n\nFrom Ottoman Turkish سر (ser), from Persian سر (sar)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19417","headword_ar":"سَرٌّ","root":"sr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who rejoices,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gladdens, another;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"makes him happy;"},{"kind":"text","text":"(S, K;) [and so ↓"},{"kind":"arabic","text_bw":"saAr~N","text_ar":"سَارٌّ","orth_type":"arrow"},{"kind":"text","text":":] fem."},{"kind":"arabic","text_bw":"sar~apN","text_ar":"سَرَّةٌ"},{"kind":"text","text":"; with which ↓"},{"kind":"arabic","text_bw":"saAr~apN","text_ar":"سَارَّةٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. (Lh, M, K.) You say"},{"kind":"arabic","text_bw":"rajulN bar~N sar~N","text_ar":"رَجُلٌ بَرٌّ سَرٌّ"},{"kind":"italic_en","text":"A man who treats with goodness and affection and gentleness, and rejoices"},{"kind":"text","text":"&c., (S, K, TA,)"},{"kind":"italic_en","text":"his brethren:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"bar~uwna","text_ar":"بَرُّونَ"},{"kind":"arabic","text_bw":"sar~uwna","text_ar":"سَرُّونَ"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n19418","headword_ar":"سُرٌّ","root":"sr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"suruwrN","text_ar":"سُرُورٌ"},{"kind":"text","text":":       -A2-  and"},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":", last sentence but one.       -A3-  It is also a contraction of"},{"kind":"arabic","text_bw":"sururN","text_ar":"سُرُرٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"sariyrN","text_ar":"سَرِيرٌ"},{"kind":"text","text":". (Sb, M.)       -A4-  Also, and ↓"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"sararN","text_ar":"سَرَرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K, in the CK"},{"kind":"arabic","text_bw":"surar","text_ar":"سُرَر"},{"kind":"text","text":",) The"},{"kind":"italic_en","text":"navel-string"},{"kind":"text","text":"of a child; i. e. the"},{"kind":"italic_en","text":"thing that the midwife cuts off from the navel"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sur~ap","text_ar":"سُرَّة"},{"kind":"text","text":") of a child; (S, K;) the"},{"kind":"italic_en","text":"thing that hangs from the navel"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sur~ap","text_ar":"سُرَّة"},{"kind":"text","text":") of a newborn child,"},{"kind":"italic_en","text":"and that is cut off:"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"part that is cut off thereof, and that goes away:"},{"kind":"text","text":"(M:) pl. (of"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ"},{"kind":"text","text":", S, [or of"},{"kind":"arabic","text_bw":"sur~N","text_ar":"سُرٌّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"sararN","text_ar":"سَرَرٌ"},{"kind":"text","text":",])"},{"kind":"arabic","text_bw":"A^asir~apN","text_ar":"اَسِرَّةٌ"},{"kind":"text","text":", (Yaakoob, S, M, K,) which is extr. (M.) One says,"},{"kind":"arabic","text_bw":"Earafotu *`lika qabola A^ano yuqoTaEa sur~uka","text_ar":"عَرَفْتُ ذٰلِكَ قَبْلَ اَنْ يُقْطَعَ سُرُّكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I knew that before thy navel-string was cut"},{"kind":"text","text":"]: one should not say"},{"kind":"arabic","text_bw":"sur~atuka","text_ar":"سُرَّتُكَ"},{"kind":"text","text":"; for the"},{"kind":"arabic","text_bw":"sur~ap","text_ar":"سُرَّة"},{"kind":"text","text":"is not cut. (S.) And"},{"kind":"arabic","text_bw":"waAHidi","text_ar":"وَاحِدِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waladato valaAvapF fiY sararK","text_ar":"وَلَدَتْ ثَلَاثَةً فِى سَرَرٍ","orth_type":"arrow"},{"kind":"italic_en","text":"She brought forth three"},{"kind":"text","text":"[boys]"},{"kind":"italic_en","text":"consecutively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one at the heels of another."},{"kind":"text","text":"(M.) [See also"},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":", last sentence.]"}],"source_refs":["S","M","K"]},{"entry_id":"n19419","headword_ar":"سِرٌّ","root":"sr","body":[{"kind":"italic_en","text":"A secret; a thing that is concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suppressed,"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K,)"},{"kind":"italic_en","text":"in the mind;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"sariyrapN","text_ar":"سَرِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, M, A, K:) or the former has the above-mentioned signification, and the latter signifies"},{"kind":"italic_en","text":"a secret action, whether good or evil:"},{"kind":"text","text":"(Lth:) [and the former, also,"},{"kind":"italic_en","text":"a mystery:"},{"kind":"text","text":"] pl. of the former,"},{"kind":"arabic","text_bw":"A^asoraArN","text_ar":"اَسْرَارٌ"},{"kind":"text","text":"; (S, M, A, Mgh, Msb, K;) and of the latter,"},{"kind":"arabic","text_bw":"saraAy^iru","text_ar":"سَرَايِرُ"},{"kind":"text","text":". (S, A, K.) It is said in a prov.,"},{"kind":"arabic","text_bw":"maA yawomu Haliymapa bisir~K","text_ar":"مَا يَوْمُ حَلِيمَةَ بِسِرٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The day of Haleemeh is not a secret"},{"kind":"text","text":"]: applied to anything commonly known: alluding to Haleemeh the daughter of El-Hárith the son of Aboo-Shemir El-Ghassánee; for, when her father sent an army to El-Mundhir the son of Má-es-Semà, she took forth for the soldiers some perfume in a vessel ("},{"kind":"arabic","text_bw":"mirokan","text_ar":"مِرْكَن"},{"kind":"text","text":"), and perfumed them with it. (S.) [You say also,"},{"kind":"arabic","text_bw":"huwa mawoDiEu sir~iY","text_ar":"هُوَ مَوْضِعُ سِرِّى"},{"kind":"italic_en","text":"He is the depositary of my secret, or secrets."},{"kind":"text","text":"] The words of the Kur [lxxxvi. 9] ↓"},{"kind":"arabic","text_bw":"yawoma tubolaY Als~araAy^iru","text_ar":"يَوْمَ تُبْلَى السَّرَايِرُ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"In the day wherein the secret tenets and intentions shall be tried and revealed:"},{"kind":"text","text":"(Jel:) or by"},{"kind":"arabic","text_bw":"AlsrAy^r","text_ar":"السراير"},{"kind":"text","text":"is here meant"},{"kind":"italic_en","text":"fasting, and prayer, and alms-giving, and ablution on account of the pollution termed"},{"kind":"arabic","text_bw":"janaAbap","text_ar":"جَنَابَة"},{"kind":"text","text":". (TA.) [See also a verse cited in the third paragraph of art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"A thing that is revealed, appears,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is made manifest:"},{"kind":"text","text":"thus it has two contrary significations. (MF.) ―         -b3-"},{"kind":"arabic","text_bw":"Als~ir~u","text_ar":"السِّرُّ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"maHal~u","text_ar":"مَحَلُّ"},{"kind":"arabic","text_bw":"Als~ir~i","text_ar":"السِّرِّ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The heart; the mind; the recesses of the mind; the secret thoughts; the soul;"},{"kind":"text","text":"] is a syn. of"},{"kind":"arabic","text_bw":"AlD~amiyru","text_ar":"الضَّمِيرُ"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"Dmr","text_ar":"ضمر"},{"kind":"text","text":". [See also"},{"kind":"arabic","text_bw":"sariyrapN","text_ar":"سَرِيرَةٌ"},{"kind":"text","text":".]) ["},{"kind":"arabic","text_bw":"laA tutoEibo sir~aka","text_ar":"لَا تُتْعِبْ سِرَّكَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Weary not thy heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind,"},{"kind":"text","text":"is a common modern phrase. And one says, of a deceased holy man,"},{"kind":"arabic","text_bw":"qad~asa A@ll~`hu sir~ahu","text_ar":"قَدَّسَ ا@للّٰهُ سِرَّهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"May God sanctify his soul."},{"kind":"text","text":"] ―         -b4-"},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Secrecy; privacy; contr. of"},{"kind":"arabic","text_bw":"EalaAniyapN","text_ar":"عَلَانِيَةٌ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"Eln","text_ar":"علن"},{"kind":"text","text":".) You say"},{"kind":"arabic","text_bw":"sir~FA waEalaAniyapF","text_ar":"سِرًّا وَعَلَانِيَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Secretly and openly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"privately and publickly"},{"kind":"text","text":"]. (Kur ii. 275, &c.) ―         -b5-"},{"kind":"italic_en","text":"Concealment."},{"kind":"text","text":"(S.) ―         -b6-"},{"kind":"italic_en","text":"Suppression; contr. of"},{"kind":"arabic","text_bw":"A_iEolaAnN","text_ar":"اـِعْلَانٌ"},{"kind":"text","text":". (Msb.) [So in the phrase"},{"kind":"arabic","text_bw":"takal~ama sir~FA","text_ar":"تَكَلَّمَ سِرًّا"},{"kind":"italic_en","text":"He spoke with a suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low, voice; softly."},{"kind":"text","text":"] ―         -b7-  ["},{"kind":"italic_en","text":"One having private knowledge"},{"kind":"text","text":"of a thing. You say,]"},{"kind":"arabic","text_bw":"fulaAnN sir~u h`*aA AlA^amori","text_ar":"فُلَانٌ سِرُّ هٰذَا الاَمْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one has"},{"kind":"text","text":"["},{"kind":"italic_en","text":"private"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"knowledge of this thing."},{"kind":"text","text":"(TA.) ―         -b8-  (tropical:)  The"},{"kind":"italic_en","text":"penis"},{"kind":"text","text":"(T, S, M, K) of a man: (T:) and (tropical:)  the"},{"kind":"italic_en","text":"vulva,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"external portion of the organs of generation,"},{"kind":"text","text":"of a woman. (K.) One says,"},{"kind":"arabic","text_bw":"AilotaqaY Als~ir~aAni","text_ar":"اِلْتَقَى السِّرَّانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The two pudenda met."},{"kind":"text","text":"(A.) ―         -b9-  (tropical:)"},{"kind":"italic_en","text":"Concubitus."},{"kind":"text","text":"(AHeyth, S, Mgh, K.) ―         -b10-  (tropical:)"},{"kind":"italic_en","text":"Marriage:"},{"kind":"text","text":"(M, A, Msb, K:) pl."},{"kind":"arabic","text_bw":"A^asoraArN","text_ar":"اَسْرَارٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"waAEadahaA sir~FA","text_ar":"وَاعَدَهَا سِرًّا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He promised her marriage, she promising him the same."},{"kind":"text","text":"(A.) So, accord. to some, in the Kur ii. 235. (TA.) ―         -b11-  (tropical:)"},{"kind":"italic_en","text":"Plain declaration of marriage:"},{"kind":"text","text":"(K:) i. e.,"},{"kind":"italic_en","text":"a man's offering himself in marriage to a woman during her"},{"kind":"arabic","text_bw":"Eid~ap","text_ar":"عِدَّة"},{"kind":"text","text":": so expl. as occurring in the Kur ubi suprà: (TA:) or"},{"kind":"italic_en","text":"a man's demanding a woman in marriage during her"},{"kind":"arabic","text_bw":"Eid~ap","text_ar":"عِدَّة"},{"kind":"text","text":". (Mujáhid.) ―         -b12-  (tropical:)"},{"kind":"italic_en","text":"Adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication:"},{"kind":"text","text":"(AHeyth, (K:) so, accord. to Aboo-Mijlez and El-Hasan, in the Kur ubi suprà. (TA.) Hence the saying,"},{"kind":"arabic","text_bw":"laA yurojaY mino waladi Als~ir~i bir~N","text_ar":"لَا يُرْجَى مِنْ وَلَدِ السِّرِّ بِرٌّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"One does not hope for filial piety from the offspring of adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication."},{"kind":"text","text":"(TK.) ―         -b13-  (assumed tropical:)"},{"kind":"italic_en","text":"Origin;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aSolN","text_ar":"اَصْلٌ"},{"kind":"text","text":"; (M, K;) as in the phrase"},{"kind":"arabic","text_bw":"huwa kariymu Als~ir~i kaviyru Albir~i","text_ar":"هُوَ كَرِيمُ السِّرِّ كَثِيرُ البِرِّ"},{"kind":"italic_en","text":"He is of generous origin, of much filial piety."},{"kind":"text","text":"(TK.) ―         -b14-  (assumed tropical:)  The"},{"kind":"italic_en","text":"commencement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first night,"},{"kind":"text","text":"of a lunar month: (K, TA:) or its"},{"kind":"italic_en","text":"middle;"},{"kind":"text","text":"(K;) app. meaning"},{"kind":"italic_en","text":"what are called"},{"kind":"arabic","text_bw":"AlA^ay~aAmu AlbiyDu","text_ar":"الاَيَّامُ البِيضُ"},{"kind":"text","text":": (TA:) but Az says, I know it not in this sense. (IAth.) ―         -b15-  (assumed tropical:)  The"},{"kind":"italic_en","text":"interior"},{"kind":"text","text":"of anything; its"},{"kind":"italic_en","text":"heart."},{"kind":"text","text":"(K.) Whence"},{"kind":"arabic","text_bw":"sir~u Al$~ahori","text_ar":"سِرُّ الشَّهْرِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"All~ayoli","text_ar":"اللَّيْلِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The middle of the lunar month and of the night"},{"kind":"text","text":"]. (TA.) ―         -b16-  The"},{"kind":"italic_en","text":"marrow"},{"kind":"text","text":"of anything. (TA.) ―         -b17-  (tropical:)  The"},{"kind":"italic_en","text":"pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"best, part"},{"kind":"text","text":"of anything. (Fr, M, K.) You say,"},{"kind":"arabic","text_bw":"A^aEoTayotuka sir~ahu","text_ar":"اَعْطَيْتُكَ سِرَّهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I gave thee the pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"best, part of it."},{"kind":"text","text":"(A.) ―         -b18-  (tropical:)  The"},{"kind":"italic_en","text":"pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genuine, quality"},{"kind":"text","text":"of race, or lineage: (S, A, K:) its"},{"kind":"italic_en","text":"best quality:"},{"kind":"text","text":"(S, K:) and the"},{"kind":"italic_en","text":"middle sort"},{"kind":"text","text":"thereof; (S;) and of rank, or quality, or the like: (M:) as also ↓"},{"kind":"arabic","text_bw":"saraArN","text_ar":"سَرَارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saraArapN","text_ar":"سَرَارَةٌ","orth_type":"arrow"},{"kind":"text","text":". (M, K.) One says,"},{"kind":"arabic","text_bw":"huwa fiY sir~i qawomihi","text_ar":"هُوَ فِى سِرِّ قَوْمِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is of the best"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in race"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"family"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his people:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"of the middle sort of them."},{"kind":"text","text":"(S.) ―         -b19-  (tropical:)  The"},{"kind":"italic_en","text":"low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, part"},{"kind":"text","text":"of a valley: (K:) the"},{"kind":"italic_en","text":"best,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"most fruitful,"},{"kind":"text","text":"(As, M, TA,)"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"thereof: (As, S, M, K:) as also ↓"},{"kind":"arabic","text_bw":"saraArN","text_ar":"سَرَارٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"saraArapN","text_ar":"سَرَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"(As, S, M, K) and ↓"},{"kind":"arabic","text_bw":"sur~apN","text_ar":"سُرَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) or the last signifies the"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"of a valley: (S:) the pl. of"},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suruwrN","text_ar":"سُرُورٌ"},{"kind":"text","text":"(M) and"},{"kind":"arabic","text_bw":"A^asir~apN","text_ar":"اَسِرَّةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"A^aqin~apN","text_ar":"اَقِنَّةٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"qin~N","text_ar":"قِنٌّ"},{"kind":"text","text":", (S,) or the last is pl. of ↓"},{"kind":"arabic","text_bw":"saraArN","text_ar":"سَرَارٌ","orth_type":"arrow"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"A^aqo*ilapN","text_ar":"اَقْذِلَةٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"qa*aAlN","text_ar":"قَذَالٌ"},{"kind":"text","text":"; (M;) and that of ↓"},{"kind":"arabic","text_bw":"saraArapN","text_ar":"سَرَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"saraArN","text_ar":"سَرَارٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) or [this is a coll. gen. n., and the pl. is]"},{"kind":"arabic","text_bw":"saraAy^iru","text_ar":"سَرَايِرُ"},{"kind":"text","text":": (M:) also ↓"},{"kind":"arabic","text_bw":"sur~apN","text_ar":"سُرَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  the"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"of a city: and"},{"kind":"arabic","text_bw":"A^asir~apN","text_ar":"اَسِرَّةٌ"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"middles"},{"kind":"text","text":"of meadows. (TA.) And"},{"kind":"arabic","text_bw":"A^aroDN sir~N","text_ar":"اَرْضٌ سِرٌّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Fruitful, good, land;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"sar~aA='u","text_ar":"سَرَّا=ءُ","orth_type":"arrow"},{"kind":"text","text":". (K, * TA.) ―         -b20-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Goodness; excellence."},{"kind":"text","text":"(Msb.) ―         -b21-  Also, and ↓"},{"kind":"arabic","text_bw":"sur~N","text_ar":"سُرٌّ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"sururN","text_ar":"سُرُرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"siraArN","text_ar":"سِرَارٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,)"},{"kind":"italic_en","text":"A line"},{"kind":"text","text":"of the palm of the hand, (M, K, *) and of the face, (M,) and of the forehead: (S, M, Mgh:) pl. (of"},{"kind":"arabic","text_bw":"sir~N","text_ar":"سِرٌّ"},{"kind":"text","text":", TA, or of ↓"},{"kind":"arabic","text_bw":"siraArN","text_ar":"سِرَارٌ","orth_type":"arrow"},{"kind":"text","text":", S)"},{"kind":"arabic","text_bw":"A^asir~apN","text_ar":"اَسِرَّةٌ"},{"kind":"text","text":", (M, TA,) and (of the same, K, or of ↓"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ","orth_type":"arrow"},{"kind":"text","text":", S, Mgh)"},{"kind":"arabic","text_bw":"A^asoraArN","text_ar":"اَسْرَارٌ"},{"kind":"text","text":"; (S, M, Mgh, K;) and pl. pl., [i. e. pl. of"},{"kind":"arabic","text_bw":"A^asoraArN","text_ar":"اَسْرَارٌ"},{"kind":"text","text":",]"},{"kind":"arabic","text_bw":"A^asaAriyru","text_ar":"اَسَارِيرُ"},{"kind":"text","text":": (S, M, (Mgh, K:) this last, accord. to AA, signifies the"},{"kind":"italic_en","text":"lines in the forehead, from the shrivelling of the skin;"},{"kind":"text","text":"and its sing. is ↓"},{"kind":"arabic","text_bw":"sararN","text_ar":"سَرَرٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) some also apply the pl."},{"kind":"arabic","text_bw":"A^asir~apN","text_ar":"اَسِرَّةٌ"},{"kind":"text","text":"to (tropical:)"},{"kind":"italic_en","text":"lines,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streaks, of herbage;"},{"kind":"text","text":"as being likened to the lines of the hand and of the face, but this is not of valid authority: (M:) and"},{"kind":"arabic","text_bw":"A^asaAriyru","text_ar":"اَسَارِيرُ"},{"kind":"text","text":"(as pl. of"},{"kind":"arabic","text_bw":"A^asoraArN","text_ar":"اَسْرَارٌ"},{"kind":"text","text":", which is pl. of"},{"kind":"arabic","text_bw":"sirarN","text_ar":"سِرَرٌ"},{"kind":"text","text":", TA) also signifies the"},{"kind":"italic_en","text":"beauties"},{"kind":"text","text":"of the face, and of the cheeks, and of the elevated parts of the cheeks. (K, TA.) ―         -b22-"},{"kind":"arabic","text_bw":"wulida lahu valaAvapN EalaY sir~K","text_ar":"وُلِدَ لَهُ ثَلَاثَةٌ عَلَى سِرٍّ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"arabic","text_bw":"waAHidK","text_ar":"وَاحِدٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sirarK","text_ar":"سِرَرٍ","orth_type":"arrow"},{"kind":"text","text":", (K, * TA,) means"},{"kind":"italic_en","text":"Three children were born to him, whose navel-strings were cut in a similar manner, without any female among them."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"sur~N","text_ar":"سُرٌّ"},{"kind":"text","text":".])"}],"source_refs":["S","M","A","Mgh","Msb","K","Lth","Jel","T","TA","As"]}]}}