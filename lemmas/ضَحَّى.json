per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُضَحِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُضَحَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُضَحَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُضَحُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُضَحُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُضَحِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُضَحَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُضَحّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُضَحَّى","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُضَحَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُضَحِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُضَحِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ضَحَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَحَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":38,"cross_references":{"qac":{"found":true,"lemma_key":"ضَحَّى","root":"ضحو","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n25621","n25626"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%AD%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"alternative form of ضُحًا (ḍuḥan)","tags":["alt-of","alternative"],"examples":[{"text":"وَٱلضُّحَى وَٱللَّيْلِ إِذَا سَجَى مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى","english":"By the forenoon, and the night when it is the stillest, thy Lord hath not forsaken thee nor doth He hate thee."}]},{"pos":"noun","gloss":"alternative form of ضُحًا (ḍuḥan); ellipsis of صَلَاة الضُّحَى (ṣalā(t) aḍ-ḍuḥā, “morning or forenoon prayer”)","tags":["abbreviation","alt-of","ellipsis"]},{"pos":"verb","gloss":"to sacrifice"},{"pos":"verb","gloss":"to slaughter, to butcher"}]},"etymology":null,"ipa":["/dˤu.ħan/","/dˤaħ.ħaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25621","headword_ar":"ضُحًى","root":"DHw and DHY","body":[{"kind":"text","text":", also written"},{"kind":"arabic","text_bw":"DuHFA","text_ar":"ضُحًا"},{"kind":"text","text":", held by some to be of the measure"},{"kind":"arabic","text_bw":"fuEalN","text_ar":"فُعَلٌ"},{"kind":"text","text":", and by others to be [originally"},{"kind":"arabic","text_bw":"DuHowFY","text_ar":"ضُحْوًى"},{"kind":"text","text":"i. e.] of the measure"},{"kind":"arabic","text_bw":"fuEolFY","text_ar":"فُعْلًى"},{"kind":"text","text":", of the former measure accord. to Mbr, and of the latter accord. to Th, (MF, TA,) [The"},{"kind":"italic_en","text":"early part of the forenoon, after sunrise:"},{"kind":"text","text":"accord. to some,"},{"kind":"italic_en","text":"when the sun is yet low:"},{"kind":"text","text":"accord. to others,"},{"kind":"italic_en","text":"when the sun is somewhat high:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to most authorities: (MF, TA, and so in one place in the K:) or this latter signifies the"},{"kind":"italic_en","text":"period"},{"kind":"text","text":"of the day"},{"kind":"italic_en","text":"after sunrise:"},{"kind":"text","text":"(S:) or this signifies the"},{"kind":"italic_en","text":"advanced state of the day"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AirotifaAEu Aln~ahaAri","text_ar":"اِرْتِفَاعُ النَّهَارِ"},{"kind":"text","text":"[which is said by the doctors of the law in the present day to mean"},{"kind":"italic_en","text":"when the sun has risen the measure of a"},{"kind":"arabic","text_bw":"rumoH","text_ar":"رُمْح"},{"kind":"text","text":", q. v., or"},{"kind":"italic_en","text":"more"},{"kind":"text","text":"]); as also ↓"},{"kind":"arabic","text_bw":"DaHowN","text_ar":"ضَحْوٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"DaHiy~apN","text_ar":"ضَحِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) and the"},{"kind":"arabic","text_bw":"DuHaY","text_ar":"ضُحَى"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"after the"},{"kind":"arabic","text_bw":"DaHowap","text_ar":"ضَحْوَة"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"a little,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"when the sun shines brightly:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"from sunrise to the time when the day is advanced and very white:"},{"kind":"text","text":"thus in the M: (TA:) or it is the"},{"kind":"italic_en","text":"spreading of the sun"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon the earth"},{"kind":"text","text":"], and the"},{"kind":"italic_en","text":"extending of the day:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"] is thus named: (Er-Rághib, TA:) or"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"is pl. of ↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"qurFY","text_ar":"قُرًى"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":"; and its sing. is like ↓"},{"kind":"arabic","text_bw":"DaHaA='N","text_ar":"ضَحَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", which means the"},{"kind":"italic_en","text":"extending of the day,"},{"kind":"text","text":"and is of the masc. gender, as though a name of the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]: then"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"became used as a sing., and the"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"was thus called: (Msb:) it is fem. and masc.: (S, K: *) he who makes it fem. holds it to be pl. of ↓"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and he who makes it masc. holds it to be [a sing.] noun of the measure"},{"kind":"arabic","text_bw":"fuEalN","text_ar":"فُعَلٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"SuradN","text_ar":"صُرَدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nugarN","text_ar":"نُغَرٌ"},{"kind":"text","text":": (S:) its dim. is ↓"},{"kind":"arabic","text_bw":"DuHaY~N","text_ar":"ضُحَىٌّ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (Fr, Msb, K;) for they disapproved the affixing the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"lest it should be confounded with the dim. of"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ"},{"kind":"text","text":". (Fr, Msb.) Using it as an adv. noun, you say,"},{"kind":"arabic","text_bw":"laqiytuhu DuHaY","text_ar":"لَقِيتُهُ ضُحَى"},{"kind":"text","text":", when you mean ["},{"kind":"italic_en","text":"I met him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"DHY","text_ar":"ضحى"},{"kind":"italic_en","text":"of this day;"},{"kind":"text","text":"without tenween. (S, TA.) See also"},{"kind":"arabic","text_bw":"DaHowapN","text_ar":"ضَحْوَةٌ"},{"kind":"text","text":". [See also De Sacy's Chrest. Ar., sec. ed., i. 162-167, respecting the prayer that is performed in the time thus called,"},{"kind":"page_break","n":1774},{"kind":"text","text":"i. e. the prayer termed"},{"kind":"arabic","text_bw":"SalaApu AlD~uHaY","text_ar":"صَلَاةُ الضُّحَى"},{"kind":"text","text":", mentioned above, voce"},{"kind":"arabic","text_bw":"A^aDoHaY","text_ar":"اَضْحَى"},{"kind":"text","text":".] ―         -b2-  Also The"},{"kind":"italic_en","text":"sun:"},{"kind":"text","text":"(M, Msb, K:) because of its appearing in the time thus called. (M, TA.) One says,"},{"kind":"arabic","text_bw":"AirotafaEati AlD~aHaY","text_ar":"اِرْتَفَعَتِ الضَّحَى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The sun became high."},{"kind":"text","text":"(Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"DuHaY Al$~amosi","text_ar":"ضُحَى الشَّمْسِ"},{"kind":"italic_en","text":"The light of the sun:"},{"kind":"text","text":"thus is expl. xci. 1. of the Kur. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"maA likalaAmihi","text_ar":"مَا لِكَلَامِهِ"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"His speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, has no perspicuity:"},{"kind":"text","text":"thus in the M and K: but in the A, ↓"},{"kind":"arabic","text_bw":"A^ano$adaniY $aEorFA layosa fiyhi HalaAwapN walaA DaHaA='N","text_ar":"اَنْشَدَنِى شَعْرًا لَيْسَ فِيهِ حَلَاوَةٌ وَلَا ضَحَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"He recited to me poetry"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in which was no"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sweetness nor"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"plainness of meaning."},{"kind":"text","text":"(TA.)"}],"source_refs":["MF","TA","S","K","Msb","M"]},{"entry_id":"n25626","headword_ar":"ضُحَىٌّ","root":"DHw and DHY","body":[{"kind":"text","text":"dim. of"},{"kind":"arabic","text_bw":"DuHFY","text_ar":"ضُحًى"},{"kind":"text","text":", q. v. (Fr, Msb, K.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D8%AD%D9%89/","headword_ar":"ضحى","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=10171#9cd60e","body_html":"<span class=\"title1\">ضحى</span><br><span>الضُّحَى: انبساطُ الشمس وامتداد النهار، وسمّي الوقت به. قال الله عزّ وجل: وَالشَّمْسِ وَضُحاها</span><br><span>[الشمس/ 1] ، إِلَّا عَشِيَّةً أَوْ ضُحاها [النازعات/ 46] ، وَالضُّحى وَاللَّيْلِ [الضحى/ 1- 2] ، وَأَخْرَجَ ضُحاها [النازعات/ 29] ، وَأَنْ يُحْشَرَ النَّاسُ ضُحًى</span><br><span>[طه/ 59] ، وضَحَى يَضْحَى: تَعَرَّضَ للشمس.</span><br><span>قال: وَأَنَّكَ لا تَظْمَؤُا فِيها وَلا تَضْحى</span><br><span>[طه/ 119] ، أي: لك أن تتصوّن من حرّ الشمس، وتَضَحَّى: أَكَلَ ضُحًى، كقولك: تغدّى، والضَّحَاءُ والغداءُ لطعامهما، وضَاحِيَةُ كلِّ شيءٍ:</span><br><span>ناحيتُهُ البارزةُ، وقيل للسماء: الضَّوَاحِي وليلة إِضْحِيَانَةٌ، وضَحْيَاءُ: مُضيئةٌ إضاءةَ الضُّحَى.</span><br><span>والأُضْحِيَّةُ جمعُها أَضَاحِي وقيل: ضَحِيَّةٌ وضَحَايَا، وأَضْحَاةٌ وأَضْحًى، وتسميتها بذلك في الشّرع لقوله عليه السلام: «من ذبح قبل صلاتنا هذه فليُعِدْ» .</span>"},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10171#ef4007","body_html":"<span class=\"title1\">ضحى</span><span> وَقَالَ [أَبُو عبيد -] : فِي حَدِيث عَبْد اللَّه [بْن عُمَر] أَنه رأى رجلا مُحرما قد استظل فَقَالَ: اضح لمن أَحرمت لَهُ. قَوْله: أضح المحدثون يَقُولُونَهُ بِفَتْح الْألف وَكسر الْحَاء من أضحيت وَقَالَ الْأَصْمَعِي: وَإِنَّمَا هُوَ: إضْحَ لمن أَحرمت لَهُ بِكَسْر الْألف وَفتح الْحَاء من ضَحِيتُ فَأَنا أضحى [قَالَ أَبُو عبيد -] وَهُوَ عِنْدِي على مَا قَالَ الْأَصْمَعِي لِأَنَّهُ إِنَّمَا أمره بالبروز للشمس وَكره لَهُ الظلال [وَمن هَذَا قَول الله تبَارك وَتَعَالَى {وإنَّكَ لَا تَظْمَأُ فِيْهَا وَلاَ تضحى} . وَأما أضْحِ مِنْ أضْحِيْت فَإِنَّمَا يكون هَذَا من الضحاء يُقَال: أقمتُ بِالْمَكَانِ حَتَّى أضْحَيتُ وَمن هَذَا قَول عمر رَحمَه الله - قَالَ: حَدَّثَنِيهِ عبد الرَّحْمَن عَن سُفْيَان عَن سماك بن حَرْب عَن عمّه مسلمة قَالَ: سَمِعت عمر يَقُول: يَا عباد الله أضْحوا بِصَلَاة الضُّحَى يَعْنِي: لَا تصلوها إِلَى ارْتِفَاع الضُّحَى وَحَدِيث ابْن عمر من غير هَذَا] . </span><span>وَقَالَ [أَبُو عبيد -] : فِي حَدِيث عبد الله [بن عمر -] أَنه كَانَ لَا يصلّي فِي مَسجد فِيهِ قذاف.</span>"}]}}