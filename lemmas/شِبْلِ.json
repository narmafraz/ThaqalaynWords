ext":"became a youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man, among the sons of such a one:"},{"kind":"text","text":"(S, TA:) and"},{"kind":"arabic","text_bw":"qado $abala AlgulaAmu A^aHosana $ubuwlK","text_ar":"قَدْ شَبَلَ الغُلَامُ اَحْسَنَ شُبُولٍ"},{"kind":"italic_en","text":"The boy has grown up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become a youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man, in the best manner:"},{"kind":"text","text":"(S:) but accord. to others,"},{"kind":"page_break","n":1499},{"kind":"text","text":"it is not said except in the case of being in a state of ease and plenty. (TA.)"}],"source_refs":["K","TK","TA","S"]},{"entry_id":"n21623","headword_ar":"شِبْلٌ","root":"$bl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"whelp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young one, of the lion:"},{"kind":"text","text":"(S, Mgh, O, Msb:) or the"},{"kind":"italic_en","text":"young one of the lion when it has attained to the seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"taking, of prey:"},{"kind":"text","text":"(K, TA:) [and Freytag says, on the authority of Meyd,"},{"kind":"italic_en","text":"of any wild beast:"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"A^a$obaAlN","text_ar":"اَشْبَالٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"A^a$obulN","text_ar":"اَشْبُلٌ"},{"kind":"text","text":"(S, O, K) [both properly pls. of pauc.] and [pl. of mult.]"},{"kind":"arabic","text_bw":"$ubuwlN","text_ar":"شُبُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ibaAlN","text_ar":"شِبَالٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","Mgh","O","Msb","K","TA"]}]},"classical_definitions":null}