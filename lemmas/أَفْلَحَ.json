er":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفْلِحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفْلِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفْلِح","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفْلِح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفْلِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفْلِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفْلِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْلِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفْلِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْلِحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفْلِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفْلِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْلِح","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَفْلَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَفْلَحْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":26,"cross_references":{"qac":{"found":true,"lemma_key":"أَفْلَحَ","root":"فلح","pos":"V","occurrence_count":27},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n34479","n34489"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D9%84%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to succeed","examples":[{"text":"قَدْ أَفْلَحَ مَن زَكَّاهَا / وَقَدْ خَابَ مَن دَسَّاهَا"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34479","headword_ar":"افلح","root":"flH","body":[{"kind":"italic_en","text":"He prospered; was successful; attained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired, that which he desired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought,"},{"kind":"text","text":"(MA, L, Msb,) or"},{"kind":"italic_en","text":"what was good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"felicity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that whereby he became in a happy and good state:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fortunate, happy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a happy and good state."},{"kind":"text","text":"(MA.) It is commonly known as an intrans. verb; but Talhah Ibn-Musarrif and 'Amr Ibn-'Obeyd, read"},{"kind":"arabic","text_bw":"qado","text_ar":"قَدْ"},{"kind":"arabic","text_bw":"A^ufoliHa A@lomuw^ominuwna","text_ar":"اُفْلِحَ ا@لْمُوْمِنُونَ"},{"kind":"text","text":", [the first verse of ch. xxiii. of the Kur-án,] with the verb in the pass. form. (MF.) [See also 10.] ―         -b2-"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of safety."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"italic_en","text":"He continued in a good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperous, state,"},{"kind":"text","text":"(MA, L,) and"},{"kind":"italic_en","text":"in the enjoyment of ease, comfort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the blessings of life."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"AflH biAl$~aYo'i","text_ar":"افلح بِالشَّىْءِ"},{"kind":"italic_en","text":"He lived"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"continued in life"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by means of the thing."},{"kind":"text","text":"(K.) The saying of 'Abeed,"},{"kind":"quote","text":"A^afoliHo bimaA $iy^ota faqado yubolagu biA@\n                      \n                     \n                        waqado yuxad~aEu AlA^ariybu"},{"kind":"text","text":"The Perseus transcribers were unclear about the last character of line one and the first character of line two."},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Live thou by what thou wilt:"},{"kind":"text","text":"whether by stupidity or by intelligence;"},{"kind":"italic_en","text":"for"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one's object is sometimes attained by stupidity, and the intelligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sagacious, is sometimes deluded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much deluded;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the stupid is sometimes supplied with the means of subsistence, and the intelligent is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sometimes"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"denied:"},{"kind":"text","text":"(T, L:) or the meaning is"},{"kind":"italic_en","text":"prosper thou,"},{"kind":"text","text":"&c. (L.)"}],"source_refs":["MA","L","Msb","T"]},{"entry_id":"n34489","headword_ar":"اَفْلَحُ","root":"flH","body":[{"kind":"italic_en","text":"Having a fissure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crack, in the under lip:"},{"kind":"text","text":"(S, Mgh:) or a man"},{"kind":"italic_en","text":"having what is termed"},{"kind":"arabic","text_bw":"falaHN","text_ar":"فَلَحٌ"},{"kind":"italic_en","text":"in his lip:"},{"kind":"text","text":"fem."},{"kind":"arabic","text_bw":"faloHaA='u","text_ar":"فَلْحَا=ءُ"},{"kind":"text","text":". (L.) 'Antarah El- 'Absee was surnamed"},{"kind":"arabic","text_bw":"AlfaloHaA='u","text_ar":"الفَلْحَا=ءُ"},{"kind":"text","text":"because of a fissure in his under lip; the fem. form of the epithet being used because"},{"kind":"arabic","text_bw":"Al$~afapu","text_ar":"الشَّفَةُ"},{"kind":"text","text":"(the lip) is fem.; (S, L;) or because his name is fem. (L.) [See also"},{"kind":"arabic","text_bw":"A^aEolamu","text_ar":"اَعْلَمُ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh"]}]}}