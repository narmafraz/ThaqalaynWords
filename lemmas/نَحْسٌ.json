{"lemma":"نَحْسٌ","slug":"نَحْسٌ","root":"ن.ح.س","root_slug":"ن-ح-س","root_link":"/words/roots/ن-ح-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"نَحْس","root":"نحس","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n39503"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AD%D9%92%D8%B3%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bring bad luck, to jinx, to hex"},{"pos":"noun","gloss":"verbal noun of نَحَسَ (naḥasa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"bad luck, misfortune"}]},"etymology":{"source":"wiktextract","text":"Cognate with Classical Syriac ܢܚܫܐ and Hebrew נחש."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39503","headword_ar":"نَحْسٌ","root":"nHs","body":[{"kind":"italic_en","text":"Unprosperousness, unfortunateness, inauspiciousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unluckiness; contr. of"},{"kind":"arabic","text_bw":"saEodN","text_ar":"سَعْدٌ"},{"kind":"text","text":"; (S, A, K;) of stars, and of other things: pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^anoHusN","text_ar":"اَنْحُسٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"nuHuwsN","text_ar":"نُحُوسٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"manaAHisu","text_ar":"مَنَاحِسُ"},{"kind":"text","text":"is an irreg. pl. of the same, (TA,) syn. with"},{"kind":"arabic","text_bw":"ma$aAy^imu","text_ar":"مَشَايِمُ"},{"kind":"text","text":", (IDrd, K, TA,) which is in like manner an irreg. pl. of"},{"kind":"arabic","text_bw":"$uw^omN","text_ar":"شُوْمٌ"},{"kind":"text","text":". (TA.) [In Har, p."},{"kind":"text","text":"375"},{"kind":"text","text":", a doubt is expressed respecting"},{"kind":"arabic","text_bw":"manaAHisu","text_ar":"مَنَاحِسُ"},{"kind":"text","text":", as to its being a pl. of"},{"kind":"arabic","text_bw":"naHosN","text_ar":"نَحْسٌ"},{"kind":"text","text":"; but only from ignorance of their being any authority for its being so: it may, however, be pl. of"},{"kind":"arabic","text_bw":"manoHasapN","text_ar":"مَنْحَسَةٌ"},{"kind":"text","text":", and not of"},{"kind":"arabic","text_bw":"naHosN","text_ar":"نَحْسٌ"},{"kind":"text","text":".] In the Kur, [liv. 19,] some read,"},{"kind":"arabic","text_bw":"fY yawomi naHosK","text_ar":"فى يَوْمِ نَحْسٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In a day of unprosperousness"},{"kind":"text","text":"]: others read"},{"kind":"arabic","text_bw":"nHs","text_ar":"نحس"},{"kind":"text","text":"as an epithet. (S.) See"},{"kind":"arabic","text_bw":"naHisN","text_ar":"نَحِسٌ"},{"kind":"text","text":". ―         -b2-  Also,"},{"kind":"italic_en","text":"Difficulty, distress, trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue; harm, injury,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jahodN","text_ar":"جَهْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Dur~N","text_ar":"ضُرٌّ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"A^anoHusN","text_ar":"اَنْحُسٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["TA","IDrd","K"]}]},"classical_definitions":null}