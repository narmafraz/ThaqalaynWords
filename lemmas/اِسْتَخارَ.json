r":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْتَخِير","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":11,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11809"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%AE%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to seek what's best, ask for best, to ask for guidance, to choose what's best"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11809","headword_ar":"استخار","root":"xyr","body":[{"kind":"italic_en","text":"He sought, desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asked for,"},{"kind":"arabic","text_bw":"xiyrap","text_ar":"خِيرَة"},{"kind":"text","text":"(S, Msb, K) or"},{"kind":"arabic","text_bw":"xiyarap","text_ar":"خِيَرَة"},{"kind":"text","text":"(as in some copies of the K) [i. e."},{"kind":"italic_en","text":"the blessing, prospering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour, of God;"},{"kind":"text","text":"&c.]. [And it is trans.; for] one says,"},{"kind":"arabic","text_bw":"Aisotaxiri A@ll~`ha yaxiro laka","text_ar":"اِسْتَخِرِ ا@للّٰهَ يَخِرْ لَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Desire thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ask thou for, the blessing, prospering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour, of God;"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"He will bless, prosper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour, thee;"},{"kind":"text","text":"&c.]. (S.) And"},{"kind":"arabic","text_bw":"Aisotaxarotu A@ll~`ha fiyhi faxaAra liY","text_ar":"اِسْتَخَرْتُ ا@للّٰهَ فِيهِ فَخَارَ لِى"},{"kind":"italic_en","text":"I desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asked, of God, the better of the two things,"},{"kind":"text","text":"[or rather"},{"kind":"italic_en","text":"the better in it,"},{"kind":"text","text":"meaning a case, or an affair,]"},{"kind":"italic_en","text":"and He chose it for me."},{"kind":"text","text":"(A.) ―         -b2-  See also 8."}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}