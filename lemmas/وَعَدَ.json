ِ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوعَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوعَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعِدُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوعَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوعَدُونَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُوعَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعِد","in_corpus":true,"count":34,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُوعَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوعَد","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"وَعَدْنا","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَعَدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":208,"cross_references":{"qac":{"found":true,"lemma_key":"وَعَدَ","root":"وعد","pos":"V","occurrence_count":70},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n42110"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%B9%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to promise (construed doubly transitive or someone بِ (bi) something)","tags":["ditransitive"],"examples":[{"text":"هَلْ تَعِدُنِي بِذٰلِكَ؟","english":"Will you promise me (are you promising me) this?"},{"text":"بِطَرِيقَة أُخْرَى، أَعِدِ الكَرَّة، حَاوِلْ مَرَّة أُخْرَى","english":"In other words, try again"}]},{"pos":"verb","gloss":"to threaten with","tags":["ditransitive"],"examples":[{"text":"هٰذِهِ جَهَنَّمُ ٱلَّتِي كُنْتُمْ تُوعَدُونَ","english":"This is the Hell with which you were threatened"}]},{"pos":"noun","gloss":"verbal noun of وَعَدَ (waʕada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"promise"},{"pos":"noun","gloss":"threat, menace"},{"pos":"noun","gloss":"anything promised or threatened"}]},"etymology":null,"ipa":["/wa.ʕa.da/","/waʕd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42110","headword_ar":"وَعَدَ","root":"wEd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEidu","text_ar":"يَعِدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"waEodN","text_ar":"وَعْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EidapN","text_ar":"عِدَةٌ"},{"kind":"text","text":", (S, L, Msb, K,) [in which the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is a substitute for the elided"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":",] or the latter is a quasi-inf. n., (L,) and"},{"kind":"arabic","text_bw":"mawoEidN","text_ar":"مَوْعِدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mawoEidapN","text_ar":"مَوْعِدَةٌ"},{"kind":"text","text":", (L, Msb, K,) or the last is a quasi-inf. n., (L,) and"},{"kind":"arabic","text_bw":"mawoEuwdN","text_ar":"مَوْعُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mawoEuwdapN","text_ar":"مَوْعُودَةٌ"},{"kind":"text","text":", (L, K,) the last two being instances of inf. ns. of the measures"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mafoEwulapN","text_ar":"مَفْعوُلَةٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He promised."},{"kind":"text","text":"(TA.) It is trans. immediately, and by means of the prep."},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"; (L, Msb, K;) but some say that the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"is redundant in this case; and most of the lexicologists disallow it with this form of the verb, allowing it only with"},{"kind":"arabic","text_bw":"A^awoEada","text_ar":"اَوْعَدَ"},{"kind":"text","text":". (TA.) It is also used with reference to good and evil: (S, L, Msb, K:) you say"},{"kind":"arabic","text_bw":"waEadahu xayorFA","text_ar":"وَعَدَهُ خَيْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He promised him good"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"waEadahu $ar~FA","text_ar":"وَعَدَهُ شَرًّا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He threatened him with evil"},{"kind":"text","text":"]: (Fr, Fs, S, L, Msb, K, &c.:) and, [accord. to some,]"},{"kind":"arabic","text_bw":"wEdh bixayorK","text_ar":"وعده بِخَيْرٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bi$ar~","text_ar":"بِشَرّ"},{"kind":"text","text":". (IKoot, Msb.) When neither good nor evil is mentioned, if you mean the former, you say"},{"kind":"arabic","text_bw":"waEada","text_ar":"وَعَدَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He promised good"},{"kind":"text","text":"]: and if you mean the latter, ↓"},{"kind":"arabic","text_bw":"A^awoEada","text_ar":"اَوْعَدَ","orth_type":"arrow"},{"kind":"text","text":", (Fr, T, S, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iyEaAdN","text_ar":"اـِيعَادٌ"},{"kind":"text","text":", with which"},{"kind":"arabic","text_bw":"waEiydN","text_ar":"وَعِيدٌ"},{"kind":"text","text":"is syn., (S, L, Msb, K,) being one irregular inf. n., [or quasiinf. n.,] (Msb,) ["},{"kind":"italic_en","text":"He threatened,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"threatened with, evil"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"A^awoEadahu","text_ar":"اَوْعَدَهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He threatened him, menaced him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"threatened him with evil"},{"kind":"text","text":"]; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"twE~dhu","text_ar":"توعّدهُ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb,) inf. n."},{"kind":"arabic","text_bw":"tawaE~udN","text_ar":"تَوَعُّدٌ"},{"kind":"text","text":"; (S, L, K;) and ↓"},{"kind":"arabic","text_bw":"At~Edhu","text_ar":"اتّعدهُ","orth_type":"arrow"},{"kind":"text","text":". (L.) You also say"},{"kind":"arabic","text_bw":"xayorFA","text_ar":"خَيْرًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AwEd","text_ar":"اوعد","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He promised good"},{"kind":"text","text":"]; (IAar, T, ISd, Msb, K;) but this is extr.: (L:) and"},{"kind":"arabic","text_bw":"bi$ar~K","text_ar":"بِشَرٍّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AwEd","text_ar":"اوعد","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He threatened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"threatened with, evil"},{"kind":"text","text":"]: (S, L, Msb, K:) when"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"is introduced after this form of the verb, it relates only to evil: (Fs, Msb:) but you also say"},{"kind":"arabic","text_bw":"$ar~FA","text_ar":"شَرًّا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AwEdh","text_ar":"اوعده","orth_type":"arrow"},{"kind":"text","text":". (Msb.) ―         -b2-  Failure of performance, with respect to a promise, the Arabs regard as a lie; but with regard to a threat, as generosity. A poet says,"},{"kind":"quote","text":"waA_in~iY waA_ino A^awoEadotuhu A^awo waEadotuhu\n                      \n                     \n                        lamuxolifu A_iyEaAdiY wamunojizu mawoEidiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And verily I, if I threaten him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"promise him, fail to perform my threat, but fulfil my promise"},{"kind":"text","text":"]. (Msb.) Nay, they do not apply the term"},{"kind":"arabic","text_bw":"xulofN","text_ar":"خُلْفٌ"},{"kind":"text","text":"to the failure of performing a threat. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"yawomunaA yaEidu barodFA","text_ar":"يَوْمُنَا يَعِدُ بَرْدًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Our day promises cold."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"waEadati AlA^arD","text_ar":"وَعَدَتِ الاَرض"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The land promised good produce."},{"kind":"text","text":"(A.) ―         -b5-"},{"kind":"arabic","text_bw":"waAEadahu fawaEadahu","text_ar":"وَاعَدَهُ فَوَعَدَهُ"},{"kind":"text","text":": see 3."}],"source_refs":["S","L","Msb","K","Fr","T","Fs"]}]}}