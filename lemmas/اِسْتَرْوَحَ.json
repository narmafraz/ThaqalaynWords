16983"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%B1%D9%92%D9%88%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16983","headword_ar":"اِسْتَرْوَحَ","root":"rwH","body":[{"kind":"text","text":", said of a branch, (Msb, TA,)"},{"kind":"italic_en","text":"It became shaken by the wind:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"it inclined from side to side."},{"kind":"text","text":"(Msb.) ―         -b2-  See also 1, near the beginning of the paragraph; and see"},{"kind":"arabic","text_bw":"AisotarowaHotu","text_ar":"اِسْتَرْوَحْتُ"},{"kind":"arabic","text_bw":"A_ilaY Hadiyvihi","text_ar":"اـِلَى حَدِيثِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AstrAH AlY Hdyvh","text_ar":"استراح الى حديثه"},{"kind":"text","text":", in the former part of the same paragraph. ―         -b3-  Also, (K,) and"},{"kind":"arabic","text_bw":"AstrAH","text_ar":"استراح"},{"kind":"text","text":", (S, A, Msb, K,) [which latter is the more common in this sense,] and ↓"},{"kind":"arabic","text_bw":"ArtAH","text_ar":"ارتاح","orth_type":"arrow"},{"kind":"text","text":", (TA,) and sometimes ↓"},{"kind":"arabic","text_bw":"ArAH","text_ar":"اراح","orth_type":"arrow"},{"kind":"text","text":", q. v., (Msb,) [and ↓"},{"kind":"arabic","text_bw":"trw~H","text_ar":"تروّح","orth_type":"arrow"},{"kind":"text","text":", as quasi-pass. of"},{"kind":"arabic","text_bw":"raw~aHa Eanohu","text_ar":"رَوَّحَ عَنْهُ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":",] said of a hired man, (Msb,) [and of any man,]"},{"kind":"italic_en","text":"He found,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experienced, rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, at rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at ease; rested;"},{"kind":"text","text":"] (S, * A, * Msb, * K;)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"], (A,) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by means of it"},{"kind":"text","text":"]; (Msb;) from"},{"kind":"arabic","text_bw":"Alr~aAHapu","text_ar":"الرَّاحَةُ"},{"kind":"text","text":"; (S;) quasi-pass. of"},{"kind":"arabic","text_bw":"A^araHotuhu","text_ar":"اَرَحْتُهُ"},{"kind":"text","text":","},{"kind":"page_break","n":1180},{"kind":"text","text":"(A, Msb,) and of"},{"kind":"arabic","text_bw":"A^araAHahu A@ll~`hu","text_ar":"اَرَاحَهُ ا@للّٰهُ"},{"kind":"text","text":". (S.) ―         -b4-"},{"kind":"arabic","text_bw":"AstrwH A_ilayohi","text_ar":"استروح اـِلَيْهِ"},{"kind":"text","text":"(accord. to the S and K, but in other lexicons"},{"kind":"arabic","text_bw":"AstrAH","text_ar":"استراح"},{"kind":"text","text":", TA)"},{"kind":"italic_en","text":"He trusted to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relied upon, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, and became quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy, in mind."},{"kind":"text","text":"(S, K, TA.) ―         -b5-  See also 1, in the last quarter of the paragraph, in seven places.       -A2-"},{"kind":"arabic","text_bw":"AstrwH AlmaTaru Al$~ajara","text_ar":"استروح المَطَرُ الشَّجَرَ"},{"kind":"italic_en","text":"The rain revived the trees."},{"kind":"text","text":"(L.)"}],"source_refs":["Msb","TA","K","S","A"]}]},"classical_definitions":null}