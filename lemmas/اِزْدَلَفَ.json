,"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B2%D9%92%D8%AF%D9%8E%D9%84%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to flatter"},{"pos":"verb","gloss":"to advance, approach, be near one another"}]},"etymology":null,"ipa":["/iz.da.la.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18008","headword_ar":"اِزْدَلَفَ","root":"zlf","body":[{"kind":"text","text":", (Mgh, Msb,) originally"},{"kind":"arabic","text_bw":"Aizotalafa","text_ar":"اِزْتَلَفَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"AizodalafuwA","text_ar":"اِزْدَلَفُوا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tzl~fwA","text_ar":"تزلّفوا","orth_type":"arrow"},{"kind":"text","text":", (S, O, L, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they, approached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near:"},{"kind":"text","text":"(Mgh, O, L, Msb, TA: in the K,"},{"kind":"arabic","text_bw":"tafar~aquwA","text_ar":"تَفَرَّقُوا"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"taqar~abuwA","text_ar":"تَقَرَّبُوا"},{"kind":"text","text":": TA:) or (O, accord. to the K “ and ”)"},{"kind":"italic_en","text":"advanced;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"before:"},{"kind":"text","text":"(S, O, K:)"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"], (Mgh, K,) and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"[which means the same, as after"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":"&c.]: (TA, and Har p. 452:) [and ↓"},{"kind":"arabic","text_bw":"zalafa","text_ar":"زَلَفَ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zalafuwA","text_ar":"زَلَفُوا"},{"kind":"text","text":", inf. n. app."},{"kind":"arabic","text_bw":"zalofN","text_ar":"زَلْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zalafN","text_ar":"زَلَفٌ"},{"kind":"text","text":", signify the same: for] you say also,"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"zalafa","text_ar":"زَلَفَ","orth_type":"arrow"},{"kind":"italic_en","text":"He drew near to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"zalafonaA","text_ar":"زَلَفْنَا","orth_type":"arrow"},{"kind":"italic_en","text":"We advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forward, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"zalofN","text_ar":"زَلْفٌ"},{"kind":"text","text":"signifies the act of"},{"kind":"italic_en","text":"advancing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going forward,"},{"kind":"text","text":"(A'Obeyd, S, TA,) from place to place; as also"},{"kind":"arabic","text_bw":"zalafN","text_ar":"زَلَفٌ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"Azdlf Als~ahomu A_ilaY","text_ar":"ازدلف السَّهْمُ اـِلَى"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"italic_en","text":"The arrow approached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near, to such a thing."},{"kind":"text","text":"(Msb.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"faA_i*aA zaAlati Al$~amosu faA@ozodalifo A_ilaY A@ll~`hi fiyhi birakoEatayoni","text_ar":"فَاـِذَا زَالَتِ الشَّمْسُ فَا@ْزْدَلِفْ اـِلَى ا@للّٰهِ فِيهِ بِرَكْعَتَيْنِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"taqar~abo","text_ar":"تَقَرَّبْ"},{"kind":"text","text":"[i. e.,"},{"kind":"italic_en","text":"When the sun declines from the meridian, then seek thou to draw near unto God therein by means of"},{"kind":"text","text":"the prayers of"},{"kind":"italic_en","text":"two rek'ahs"},{"kind":"text","text":"]. (TA.)       -A2-  See also 4, in two places."}],"source_refs":["Mgh","Msb","S","O","L","K","TA"]}]},"classical_definitions":null}