{"lemma":"أَخْبَثانِ","slug":"أَخْبَثانِ","root":"خ.ب.ث","root_slug":"خ-ب-ث","root_link":"/words/roots/خ-ب-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n9866","n9881"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%92%D8%A8%D9%8E%D8%AB%D8%A7%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to act malignantly, deceitfully, infamously or to teach or induce to act so or deprave"},{"pos":"adj","gloss":"elative degree of خَبِيث (ḵabīṯ)"},{"pos":"adj","gloss":"elative degree of خَبِيث (ḵabīṯ):; more/most malignant, wicked, deceitful, depraved"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9866","headword_ar":"اخبث","root":"xbv","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, characterized by"},{"kind":"arabic","text_bw":"xubov","text_ar":"خُبْث"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"$ar~","text_ar":"شَرّ"},{"kind":"text","text":"(Msb) [meaning"},{"kind":"italic_en","text":"badness, wickedness, deceit,"},{"kind":"text","text":"&c.: see also"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":"]. ―         -b2-"},{"kind":"italic_en","text":"He had bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful, companions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friends,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful, family:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"his companions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friends, became bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful:"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"fls","text_ar":"فلس"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"he took to himself bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful, companions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friends"},{"kind":"text","text":"(S, L, K) or"},{"kind":"italic_en","text":"connexions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assistants."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Axbvhu","text_ar":"اخبثهُ"},{"kind":"italic_en","text":"He taught him to be bad, wicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"rendered him bad, corrupt, vitious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depraved."},{"kind":"text","text":"(S.) ―         -b2-  See also 2."}],"source_refs":["Msb","TA","L","S","K"]},{"entry_id":"n9881","headword_ar":"اَخْبَثُ","root":"xbv","body":[{"kind":"text","text":"[compar. and superl. of"},{"kind":"arabic","text_bw":"xabiyvN","text_ar":"خَبِيثٌ"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"A^axaAbivu","text_ar":"اَخَابِثُ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"humo A^axaAbivu Aln~aAsi","text_ar":"هُمْ اَخَابِثُ النَّاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They are the worst,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the most wicked"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deceitful, of men"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"huwa mina AlA^axaAbivi","text_ar":"هُوَ مِنَ الاَخَابِثِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is of the worst,"},{"kind":"text","text":"&c., of men]. (A, TA.) And"},{"kind":"arabic","text_bw":"hiYa","text_ar":"هِىَ"},{"kind":"page_break","n":695},{"kind":"arabic","text_bw":"A^axobavu Al~ugatayoni","text_ar":"اَخْبَثُ الُّغَتَيْنِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It is the worse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more corrupt,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in respect of authority,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the two words,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dialectic variants."},{"kind":"text","text":"(A, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AlA^axobavaAni","text_ar":"الاَخْبَثَانِ"},{"kind":"italic_en","text":"Urine and dung"},{"kind":"text","text":"(S, A, Msb, K)"},{"kind":"italic_en","text":"of a human being:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"vomit and human ordure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thin human ordure:"},{"kind":"text","text":"(Fr, TA:) or"},{"kind":"italic_en","text":"fetor of the mouth, and sleeplessness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sleeplessness, and disquietude of mind by reason of grief."},{"kind":"text","text":"(K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA yuSal~iY Alr~ajulu wuhuwa yudaAfiEu AlA^axobavayoni","text_ar":"لَا يُصَلِّى الرَّجُلُ وُهُوَ يُدَافِعُ الاَخْبَثَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The man shall not pray while he is striving to suppress the urine and ordure"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","A","Msb","K","Fr","TA"]}]},"classical_definitions":null}