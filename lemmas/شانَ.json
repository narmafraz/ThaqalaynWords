َشِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشِينا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشِينانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشِنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِينُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِينُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَشِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شِنّا","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شِنْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشِين","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِين","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":29,"cross_references":{"qac":{"found":true,"lemma_key":"شانَ","root":"شأن","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n21510"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D8%A7%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"Old Hijazi form of شَأْن (šaʔn)"}]},"etymology":null,"ipa":["/ʃaːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21510","headword_ar":"شَاْنٌ","root":"$A^n","body":[{"kind":"italic_en","text":"A thing, an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a business;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^amorN","text_ar":"اَمْرٌ"},{"kind":"text","text":"; (S, L, K;) and"},{"kind":"arabic","text_bw":"xaTobN","text_ar":"خَطْبٌ"},{"kind":"text","text":"[in the same sense, or in that next following]: (L, K:)"},{"kind":"italic_en","text":"a great thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"(Har p. 274:)"},{"kind":"italic_en","text":"state, condition, case, quality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner of being;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAlN","text_ar":"حَالٌ"},{"kind":"text","text":": (S, L:) [also"},{"kind":"italic_en","text":"property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nature:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"importance"},{"kind":"text","text":"attaching to a person or thing:] pl."},{"kind":"arabic","text_bw":"$uw^uwnN","text_ar":"شُوُونٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$iy^aAnN","text_ar":"شِيَانٌ"},{"kind":"text","text":", (L, K,) the latter mentioned by IJ on the authority of AAF, and"},{"kind":"arabic","text_bw":"$uwnN","text_ar":"شُونٌ"},{"kind":"text","text":"occurs in poetry for the former of these, or as another pl. originally"},{"kind":"arabic","text_bw":"$uw^onN","text_ar":"شُوْنٌ"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"fuEolN","text_ar":"فُعْلٌ"},{"kind":"text","text":". (L.) It is said in the Kur [lv. 29],"},{"kind":"arabic","text_bw":"kul~a yam K huwa fiY $aA^onK","text_ar":"كُلَّ يَم ٍ هُوَ فِى شَاْنٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Every day He is"},{"kind":"text","text":"employing Himself"},{"kind":"italic_en","text":"in an affair"},{"kind":"text","text":"of some kind]: expl. as meaning that, of his business ("},{"kind":"arabic","text_bw":"mino $aA^onihi","text_ar":"مِنْ شَاْنِهِ"},{"kind":"text","text":"[which may also be rendered “ of his property ”]) it is to render mighty one who is brought low, and to bring low one who is mighty, and to enrich one who is poor, and to impoverish one who is rich; and no affair occupies him so as to divert him from an affair ("},{"kind":"arabic","text_bw":"laA ya$oEaluhu $aA^onN Eano $aA^onK","text_ar":"لَا يَشْعَلُهُ شَاْنٌ عَنْ شَاْنٍ"},{"kind":"text","text":"). (L.) [And one says,"},{"kind":"arabic","text_bw":"maA $aA^onuka","text_ar":"مَا شَاْنُكَ"},{"kind":"italic_en","text":"What is thy affair?"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is thy case?"},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"$aA^onaka","text_ar":"شَاْنَكَ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"Ai$oA^ano $aA^onaka","text_ar":"اِشْاَنْ شَاْنَكَ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Pursue thy way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy affair;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"do what thou dost well;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keep to thy affair:"},{"kind":"text","text":"or the like: and to this is often added,"},{"kind":"arabic","text_bw":"wamaA turiydu","text_ar":"وَمَا تُرِيدُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"and what thou wilt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wishest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirest."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"mino $aA^onihi A^ano","text_ar":"مِنْ شَاْنِهِ اَنْ"},{"kind":"arabic","text_bw":"yafoEala ka*aA","text_ar":"يَفْعَلَ كَذَا"},{"kind":"italic_en","text":"It is of his business,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nature, to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that he should do, such a thing."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"rajulN saholu Al$~aA^oni","text_ar":"رَجُلٌ سَهْلُ الشَّاْنِ"},{"kind":"text","text":"(a phrase occurring in the S and K in art."},{"kind":"arabic","text_bw":"h$","text_ar":"هش"},{"kind":"text","text":")"},{"kind":"italic_en","text":"A man of easy nature."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"lahu $aA^onN","text_ar":"لَهُ شَاْنٌ"},{"kind":"text","text":", sometimes meaning"},{"kind":"italic_en","text":"There is for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he has, a great thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair"},{"kind":"text","text":"to perform or transact: but more commonly,"},{"kind":"italic_en","text":"great importance attaches to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to it:"},{"kind":"text","text":"see 1, last sentence. And a grandee, or a prince, is said to be"},{"kind":"arabic","text_bw":"EaZiymu Al$~aA^oni","text_ar":"عَظِيمُ الشَّاْنِ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Of great importance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity."},{"kind":"text","text":"]       -A2-  Also ["},{"kind":"italic_en","text":"A suture of the skull;"},{"kind":"text","text":"i. e.] the"},{"kind":"italic_en","text":"place of junction of the"},{"kind":"arabic","text_bw":"qabaAy^il","text_ar":"قَبَايِل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"principal bones,"},{"kind":"text","text":"namely, the"},{"kind":"italic_en","text":"frontal, occipital,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"two parietal, bones,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the head:"},{"kind":"text","text":"(K:) sing. of"},{"kind":"arabic","text_bw":"$uw^uwnN","text_ar":"شُوُونٌ"},{"kind":"text","text":", (Mgh,) which signifies the"},{"kind":"italic_en","text":"places of junction,"},{"kind":"text","text":"(As, S, Mgh, L,) and"},{"kind":"italic_en","text":"of meeting,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"qabaAy^il","text_ar":"قَبَايِل"},{"kind":"text","text":"(As, S, Mgh, L)"},{"kind":"italic_en","text":"of the head;"},{"kind":"text","text":"(S, L;)"},{"kind":"italic_en","text":"between every two of which"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"italic_en","text":"is a"},{"kind":"arabic","text_bw":"$aA^on","text_ar":"شَاْن"},{"kind":"text","text":": (As, L:) [it is fancifully said that] from them come the tears: (As, S, L:) the pl. is also expl. as meaning the"},{"kind":"arabic","text_bw":"salaAsil","text_ar":"سَلَاسِل"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"sutures"},{"kind":"text","text":"as being likened to the"},{"kind":"arabic","text_bw":"slAsl","text_ar":"سلاسل"},{"kind":"text","text":"(or lines) of writing]"},{"kind":"italic_en","text":"that unite the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":": by Lth, as the"},{"kind":"arabic","text_bw":"namaAnim","text_ar":"نَمَانِم"},{"kind":"text","text":"[likewise meaning"},{"kind":"italic_en","text":"sutures resembling lines of writing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the skull; between the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":": by AHát, as the"},{"kind":"arabic","text_bw":"$uEab","text_ar":"شُعَب"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"serrated edges"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that unite the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"italic_en","text":"of the head."},{"kind":"text","text":"(L.) ―         -b2-  And The"},{"kind":"italic_en","text":"channel by which the tears flow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"run, to the eye:"},{"kind":"text","text":"pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^a$ow^unN","text_ar":"اَشْوُنٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"$uw^uwnN","text_ar":"شُوُونٌ"},{"kind":"text","text":": (L, K:) [perhaps thus called because supposed to come from the sutures of the skull: but they may have been supposed to come thence because tears are called"},{"kind":"arabic","text_bw":"maA='u Al$~uw^uwni","text_ar":"مَا=ءُ الشُّوُونِ"},{"kind":"text","text":"(as in a verse cited voce"},{"kind":"arabic","text_bw":"rasama","text_ar":"رَسَمَ"},{"kind":"text","text":"); for this phrase may have been misunderstood as signifying “ the water of the sutures of the skull, ” whereas it seems to be properly rendered “ the water of the channels of the tears: ”] it is said that the"},{"kind":"arabic","text_bw":"$uw^uwn","text_ar":"شُوُون"},{"kind":"text","text":"connect the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":"of the head [expl. above] to the eye: Lth says that they are the"},{"kind":"italic_en","text":"ducts"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Euruwq","text_ar":"عُرُوق"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the tears from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the interior of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the head to the eye:"},{"kind":"text","text":"and Th, that they are"},{"kind":"italic_en","text":"certain ducts"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Erwq","text_ar":"عروق"},{"kind":"text","text":")"},{"kind":"italic_en","text":"above the"},{"kind":"arabic","text_bw":"qbAy^l","text_ar":"قبايل"},{"kind":"text","text":","},{"kind":"italic_en","text":"which become strong by degrees as the man advances in age:"},{"kind":"text","text":"(L: [but it seems that Th has confounded explanations of"},{"kind":"arabic","text_bw":"$w^wn","text_ar":"شوون"},{"kind":"text","text":"in two different senses:]) accord. to ISk, (S,) or AA and others, (L,) the"},{"kind":"arabic","text_bw":"$aA^onaAni","text_ar":"شَاْنَانِ"},{"kind":"text","text":"are"},{"kind":"italic_en","text":"two ducts"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EiroqaAni","text_ar":"عِرْقَانِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"descending from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the upper part of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the head to the eyebrows and then to the eyes."},{"kind":"text","text":"(S, L.) ―         -b3-  [The pl."},{"kind":"arabic","text_bw":"$uw^uwnN","text_ar":"شُوُونٌ"},{"kind":"text","text":"is also expl. as though meaning"},{"kind":"italic_en","text":"Tears"},{"kind":"text","text":"themselves, in a phrase mentioned voce"},{"kind":"arabic","text_bw":"*ay^irN","text_ar":"ذَيِرٌ"},{"kind":"text","text":"(q. v.), on the authority of the K.] ―         -b4-  And"},{"kind":"arabic","text_bw":"$uw^uwnN Alxamori","text_ar":"شُوُونٌ الخَمْرِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The effluvia of wine that creep"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maA dab~a mina Alxamori","text_ar":"مَا دَبَّ مِنَ الخَمْرِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the veins of the body."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"$aA^onN","text_ar":"شَاْنٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A vein of earth in a mountain,"},{"kind":"text","text":"(L, K,) i. e."},{"kind":"italic_en","text":"a cleft therein,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"in which palm-trees are"},{"kind":"page_break","n":1492},{"kind":"italic_en","text":"planted;"},{"kind":"text","text":"(L, K;) or"},{"kind":"italic_en","text":"in which trees of the kind called"},{"kind":"arabic","text_bw":"naboE","text_ar":"نَبْع"},{"kind":"italic_en","text":"grow;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that produces plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"(L:) pl."},{"kind":"arabic","text_bw":"$uw^uwnN","text_ar":"شُوُونٌ"},{"kind":"text","text":": (L, K:) which is said by ISd to mean"},{"kind":"italic_en","text":"lines,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streaks, in a mountain:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"cracks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clefts:"},{"kind":"text","text":"and to these cracks, or clefts, the poet Keys Ibn-Kuráa likens [imaginary] clefts in the liver, occasioned by love. (L.)"}],"source_refs":["L","K","S","Mgh","As"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B4%D8%A7%D9%86/","headword_ar":"شان","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=124221#bd903a","body_html":"شان<br>عن الأيرلندية للإسم جون المأخوذ عن العبرية بمعنى الله رحيم. يستخدم للذكور."}]}}