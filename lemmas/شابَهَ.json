m","num":"p"},{"role":"present_2mp","form":"تُشابِهُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشابِهْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشابِه","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشابِه","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشابِها","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشابِهانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشابِها","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشابِهانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشابِهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشابِهُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشابِهْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شابَهْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شابَهْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشابِه","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشابِه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["","n23256"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D8%A7%D8%A8%D9%8E%D9%87%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to resemble"}]},"etymology":null,"ipa":["/ʃaː.ba.ha/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23256","headword_ar":"شَابَهُ","root":"$wb","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$uwbuhu","text_ar":"يَشُوبُهُ"},{"kind":"text","text":", (S, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"$awobN","text_ar":"شَوْبٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"$iyaAbN","text_ar":"شِيَابٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He mixed it;"},{"kind":"text","text":"(S, A, Msb, K;) such as milk with water; (Msb;) or honey with water. (A.) [And"},{"kind":"italic_en","text":"It mingled with it:"},{"kind":"text","text":"for] one says also,"},{"kind":"arabic","text_bw":"kaA^an~a riyqatahaA xamorN ya$uwbuhaA","text_ar":"كَاَنَّ رِيقَتَهَا خَمْرٌ يَشُوبُهَا"},{"kind":"arabic","text_bw":"EasalN","text_ar":"عَسَلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"As though her saliva were wine with which honey mingled"},{"kind":"text","text":"]. (A.) ―         -b2-  [It is sometimes used in a good sense, but more frequently in a bad sense; and often means"},{"kind":"italic_en","text":"He adulterated, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sophisticated, it."},{"kind":"text","text":"] It is said in a trad.,"},{"kind":"arabic","text_bw":"ya$ohadu","text_ar":"يَشْهَدُ"},{"kind":"arabic","text_bw":"bayoEakumu AlHalifu waAll~agowu fa$uwbuwhu biAlS~adaqapi","text_ar":"بَيْعَكُمُ الحَلِفُ وَاللَّغْوُ فَشُوبُوهُ بِالصَّدَقَةِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Swearing, and unprofitable speech, attend your selling; therefore mix ye it with alms"},{"kind":"text","text":"]. (TA.) And it is said in a prov.,"},{"kind":"arabic","text_bw":"huwa ya$uwbu wayaruwbu","text_ar":"هُوَ يَشُوبُ وَيَرُوبُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He mixes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"makes a confusion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorder, in speech"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in actions:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"he says right one time and wrong another time:"},{"kind":"text","text":"(As, TA:) or"},{"kind":"italic_en","text":"he defends without energy:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he is sometimes incited to motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action, and defends himself, but without energy, and sometimes he is motionless, and does not become excited to motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action;"},{"kind":"text","text":"and it is not from [the words"},{"kind":"arabic","text_bw":"$awobN","text_ar":"شَوْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rawobN","text_ar":"رَوْبٌ"},{"kind":"text","text":"applied to] milk: so says Aboo-Sa'eed [i. e. As]: and he says also that"},{"kind":"arabic","text_bw":"$aAba Eanohu waraAba","text_ar":"شَابَ عَنْهُ وَرَابَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he defended him at one time, and was sluggish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indolent, at another time:"},{"kind":"text","text":"and that"},{"kind":"arabic","text_bw":"Enh","text_ar":"عنه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$w~b","text_ar":"شوّب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ta$owiybN","text_ar":"تَشْوِيبٌ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"he defended him without energy:"},{"kind":"text","text":"and thus this latter is expl. in the K, as is likewise"},{"kind":"arabic","text_bw":"$Ab Enh","text_ar":"شاب عنه"},{"kind":"text","text":": also that the Arabs say,"},{"kind":"arabic","text_bw":"laqiytu fulaAnFA Alyawoma ya$uwbu Eano A^aSoHaAbihi","text_ar":"لَقِيتُ فُلَانًا اليَوْمَ يَشُوبُ عَنْ اَصْحَابِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I found such a one to-day defending his companions in some measure."},{"kind":"text","text":"(TA.) [See also art."},{"kind":"arabic","text_bw":"rwb","text_ar":"روب"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"$Ab","text_ar":"شاب"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He acted treacherously, perfidiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfaithfully:"},{"kind":"text","text":"(Fr, TA:)"},{"kind":"italic_en","text":"he lied: he deceived in selling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buying:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he acted dishonestly, insincerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with dissimulation."},{"kind":"text","text":"(IAar, TA.) ―         -b4-  [See also Har p. 448; where it is implied that it signifies also"},{"kind":"italic_en","text":"He spoke truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was veracious."},{"kind":"text","text":"]"}],"source_refs":["S","A","Msb","K","TA","As","Fr"]}]},"classical_definitions":null}