{"lemma":"مُسْرِفٌ","slug":"مُسْرِفٌ","root":"س.ر.ف","root_slug":"س-ر-ف","root_link":"/words/roots/س-ر-ف","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُسْرِف","root":"سرف","pos":"N","occurrence_count":15},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n19611"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B3%D9%92%D8%B1%D9%90%D9%81%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of أَسْرَفَ (ʔasrafa)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"being excessive"},{"pos":"adj","gloss":"prodigal, extravagant, spendthrift, wasteful (profuse in expenditure)","examples":[{"text":"وَكُلُوا۟ وَٱشْرَبُوا۟ وَلَا تُسْرِفُوٓا۟ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْمُسْرِفِينَ","english":"Eat and drink, but do not waste. Surely the Lord does not like the wasteful."}]},{"pos":"adj","gloss":"excessive in committing sins","examples":[{"text":"إِنَّ ٱللَّهَ لَا يَهْدِى مَنْ هُوَ مُسْرِفٌۭ كَذَّابٌۭ","english":"Surely Allah does not guide whoever is a transgressor, a total liar."}]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of أَسْرَفَ (ʔasrafa, “to be excessive”)."},"ipa":["/mus.rif/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19611","headword_ar":"مُسْرِفٌ","root":"srf","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Exceeding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transgressing, the just,"},{"kind":"text","text":"or"},{"kind":"page_break","n":1352},{"kind":"italic_en","text":"right, bound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"measure; acting extravagantly,"},{"kind":"text","text":"&c.: see its verb (4)]. ―         -b2-  See also"},{"kind":"arabic","text_bw":"sarifN","text_ar":"سَرِفٌ"},{"kind":"text","text":". ―         -b3-  [Also]"},{"kind":"italic_en","text":"Denying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledging, the favours,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the unity, and the prophets and law, of God; a disbeliever, an unbeliever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an infidel:"},{"kind":"text","text":"it is said to be used in this sense in the Kur xl. 36. (TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%B3%D8%B1%D9%81/","headword_ar":"مسرف","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23644#475502","body_html":"<span>المسرف: من ينفق المال الكثير في الغرض الخسيس.</span>"}]}}