anelexicon.com/?s=%D9%83%D9%8E%D8%B1%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to oppress, to distress"},{"pos":"verb","gloss":"to grieve, to worry, to trouble"},{"pos":"verb","gloss":"to ache, to anguish, to agonize, to cause pain to"},{"pos":"verb","gloss":"to overburden, to overload (a work animal)"},{"pos":"verb","gloss":"to almost do something (with following non-past or with أَن (ʔan) + subjunctive)","examples":[{"text":"كَرَبَ ٱلْحَالُ يَنْصَلِحُ.","english":"The situation starts to improve."}]},{"pos":"noun","gloss":"verbal noun of كَرَبَ (karaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"worry, sorrow, care, grief, apprehension, concern, anxiety, fear, heartache, agony, affliction, anguish, blues, dejection, gloom, pang, distress, trouble, gloominess, pain, torment, torture, glumness, a lump in the throat, low spirits, grimness"},{"pos":"noun","gloss":"grief, anxiety"},{"pos":"noun","gloss":"near"},{"pos":"noun","gloss":"a large number of lashes"},{"pos":"noun","gloss":"plural of كُرْبَة (kurba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36811","headword_ar":"كَرَبَ","root":"krb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kuruwbN","text_ar":"كُرُوبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near; drew near; approached."},{"kind":"text","text":"(S, K.) [Compare"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":".] ―         -b2-  [You say]"},{"kind":"arabic","text_bw":"karaba A^ano yakuwna","text_ar":"كَرَبَ اَنْ يَكُونَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"karaba yakuwnu","text_ar":"كَرَبَ يَكُونُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nigh, to being"},{"kind":"text","text":"―         -b3- . (TA.) This is one of the verbs to which one does not give as its enunciative the act. part. n. of the verb which is its proper enunciative: [so that] you do not say,"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"arabic","text_bw":"kaAy^inFA","text_ar":"كَايِنًا"},{"kind":"text","text":": [in which"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":"implies the pron."},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"text","text":", which is called its noun; and"},{"kind":"arabic","text_bw":"kAy^nA","text_ar":"كاينا"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"yakuwnu","text_ar":"يَكُونُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^ano yakuwna","text_ar":"اَنْ يَكُونَ"},{"kind":"text","text":", its proper enunciative]. (Sb.)"},{"kind":"arabic","text_bw":"karaba A^ano yafoEala ka*aA","text_ar":"كَرَبَ اَنْ يَفْعَلَ كَذَا"},{"kind":"italic_en","text":"He was near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nigh, to doing so; he well nigh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"almost, did so."},{"kind":"text","text":"(S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"karabati Al$~amosu","text_ar":"كَرَبَتِ الشَّمْسُ"},{"kind":"italic_en","text":"The sun was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near to setting."},{"kind":"text","text":"(S, K.) ―         -b5-"},{"kind":"arabic","text_bw":"krbt AljaAriyapu An tudorika","text_ar":"كربت الجَارِيَةُ ان تُدْرِكَ"},{"kind":"italic_en","text":"The girl was near to coming of age."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"karabato HayaApu Aln~aAri","text_ar":"كَرَبَتْ حَيَاةُ النَّارِ"},{"kind":"italic_en","text":"The fire was near to becoming extinguished."},{"kind":"text","text":"(S, K.)       -A2-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"italic_en","text":"He bound near together"},{"kind":"text","text":"the two pasterns of an ass or of a camel"},{"kind":"italic_en","text":"with a rope"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with shackles."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"karaba Alqayoda","text_ar":"كَرَبَ القَيْدَ"},{"kind":"italic_en","text":"He straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made narrow, the shackle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shackles,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"upon the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"animal"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"shackled."},{"kind":"text","text":"(S, K.) 'Abd-Allah Ibn- 'Anameh Ed-Dabbee says,"},{"kind":"quote","text":"A^azojuro HimaAraka laA yarotaEo birawoDatinaA\n                      \n                     \n                        A_i*FA yurad~a waqayodu AlEayori makoruwbu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Check thine ass: let him not pasture at large in our meadow: in that case he will be sent back with the ass's shackles straitened"},{"kind":"text","text":"]: (S:) meaning Do not venture to revile us; for we are able to shackle this ass, and to prevent his acting as he pleaseth. (L.) See Ham, p. 290. ―         -b3-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He loaded"},{"kind":"text","text":"a she-camel. (S, K.)       -A3-"},{"kind":"arabic","text_bw":"karabahu","text_ar":"كَرَبَهُ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"karobN","text_ar":"كَرْبٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(sorrow, grief, &c., S, K, or an affair, Msb, TA)"},{"kind":"italic_en","text":"afflicted, distressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oppressed, him,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"so that it filled his heart with rage."},{"kind":"text","text":"(Msb.) See also 8.       -A4-"},{"kind":"arabic","text_bw":"karaba Ald~alowa","text_ar":"كَرَبَ الدَّلْوَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"karobN","text_ar":"كَرْبٌ"},{"kind":"text","text":", TA,) and ↓"},{"kind":"arabic","text_bw":"kr~bhA","text_ar":"كرّبها","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AkrbhA","text_ar":"اكربها","orth_type":"arrow"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He put"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attached, a"},{"kind":"arabic","text_bw":"karab","text_ar":"كَرَب"},{"kind":"italic_en","text":"to the bucket."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"kariba","text_ar":"كَرِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"The rope called"},{"kind":"arabic","text_bw":"karab","text_ar":"كَرَب"},{"kind":"italic_en","text":"of his bucket broke."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"kr~b","text_ar":"كرّب","orth_type":"arrow"},{"kind":"text","text":"; explained by the words"},{"kind":"arabic","text_bw":"TaqoTaqa Alkariyba lixa$abapi Alxab~aAzi","text_ar":"طَقْطَقَ الكَرِيبَ لِخَشَبَةِ الخَبَّازِ"},{"kind":"text","text":"[app. meaning,"},{"kind":"italic_en","text":"He caused the"},{"kind":"arabic","text_bw":"kryb","text_ar":"كريب"},{"kind":"text","text":"(a baker's wooden implement)"},{"kind":"italic_en","text":"to make a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reiterated sound, such as is termed"},{"kind":"arabic","text_bw":"TaqoTaqap","text_ar":"طَقْطَقَة"},{"kind":"text","text":"]. (K.)       -A5-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":"; (accord. to the K;) or ↓"},{"kind":"arabic","text_bw":"kr~b","text_ar":"كرّب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takoriybN","text_ar":"تَكْرِيبٌ"},{"kind":"text","text":"; (accord. to IM;)"},{"kind":"italic_en","text":"He sowed land such as is called"},{"kind":"arabic","text_bw":"kariybN","text_ar":"كَرِيبٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"karaba AlA^aroDa","text_ar":"كَرَبَ الاَرْضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"karobN","text_ar":"كَرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kiraAbN","text_ar":"كِرَابٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He turned over the ground for sowing,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"for cultivating."},{"kind":"text","text":"(S, Msb.)       -A6-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He took the"},{"kind":"arabic","text_bw":"karab","text_ar":"كَرَب"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"lower parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ends, of the branches"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from the palm-trees."},{"kind":"text","text":"(IAar, K.)"},{"kind":"italic_en","text":"He lopped a palmtree."},{"kind":"text","text":"(Msb.)       -A7-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"kr~b","text_ar":"كرّب","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He ate the dates called"},{"kind":"arabic","text_bw":"kuraAbap","text_ar":"كُرَابَة"},{"kind":"text","text":". (K.)       -A8-"},{"kind":"arabic","text_bw":"karaba","text_ar":"كَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"karobN","text_ar":"كَرْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He twisted"},{"kind":"text","text":"[a rope &c.] ("},{"kind":"arabic","text_bw":"qutala","text_ar":"قُتَلَ"},{"kind":"text","text":": accord. to some copies of the K) or"},{"kind":"italic_en","text":"he slew"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qatala","text_ar":"قَتَلَ"},{"kind":"text","text":": accord to other copies of the same)."}],"source_refs":["S","K","TA","Msb"]}]}}