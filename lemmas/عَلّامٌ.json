ext","text":"and ↓"},{"kind":"arabic","text_bw":"Eul~aAmN","text_ar":"عُلَّامٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) both mentioned by ISd, the latter [which is less used] from Lh, (TA,) and ↓"},{"kind":"arabic","text_bw":"Eal~aAmapN","text_ar":"عَلَّامَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"tiEolimapN","text_ar":"تِعْلِمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tiEolaAmapN","text_ar":"تِعْلَامَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Very knowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scientific"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"learned:"},{"kind":"text","text":"(S, K:) the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"in ↓"},{"kind":"arabic","text_bw":"Eal~aAmapN","text_ar":"عَلَّامَةٌ","orth_type":"arrow"},{"kind":"text","text":"is added to denote intensiveness; (S;) or [rather] to denote that the person to whom it is applied has attained the utmost degree of the quality signified thereby; [so that it means"},{"kind":"italic_en","text":"knowing"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"in the utmost degree;"},{"kind":"text","text":"or it may be rendered"},{"kind":"italic_en","text":"very very,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"singularly, knowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scientific"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"learned;"},{"kind":"text","text":"] and this epithet is applied also to a woman: (IJ, TA:) [↓"},{"kind":"arabic","text_bw":"tiEolaAmapN","text_ar":"تِعْلَامَةٌ","orth_type":"arrow"},{"kind":"text","text":", likewise, is doubly intensive; and so, app., is ↓"},{"kind":"arabic","text_bw":"tiEolimapN","text_ar":"تِعْلِمَةٌ","orth_type":"arrow"},{"kind":"text","text":":] the pl. of"},{"kind":"arabic","text_bw":"Eal~aAmN","text_ar":"عَلَّامٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Eal~aAmuwna","text_ar":"عَلَّامُونَ"},{"kind":"text","text":"; and that of ↓"},{"kind":"arabic","text_bw":"Eul~aAmN","text_ar":"عُلَّامٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Eul~aAmuwna","text_ar":"عُلَّامُونَ"},{"kind":"text","text":". (TA.) See also, for the first,"},{"kind":"arabic","text_bw":"EaliymN","text_ar":"عَلِيمٌ"},{"kind":"text","text":". ―         -b2-  Also the same epithets, (K,) or"},{"kind":"arabic","text_bw":"Eal~aAmN","text_ar":"عَلَّامٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eal~aAmapN","text_ar":"عَلَّامَةٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nas~aAbapN","text_ar":"نَسَّابَةٌ"},{"kind":"text","text":"; (K, TA;) [or rather"},{"kind":"arabic","text_bw":"Eal~aAmN","text_ar":"عَلَّامٌ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"nas~aAbN","text_ar":"نَسَّابٌ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"very skilful in genealogies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a great genealogist;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eal~aAmapN","text_ar":"عَلَّامَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"nas~aAbapN","text_ar":"نَسَّابَةٌ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"possessing the utmost knowledge in genealogies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a most skilful genealogist;"},{"kind":"text","text":"] from"},{"kind":"arabic","text_bw":"AlEilomu","text_ar":"العِلْمُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["K","TA","S","IJ"]},{"entry_id":"n30361","headword_ar":"عُلَّامٌ","root":"Elm","body":[{"kind":"text","text":": see the next preceding paragraph, in two places. ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"EulaAmN","text_ar":"عُلَامٌ","orth_type":"arrow"},{"kind":"text","text":", The"},{"kind":"arabic","text_bw":"Saqor","text_ar":"صَقْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hawk"},{"kind":"text","text":"]; (K;) the latter on the authority of IAar: (TA:) and [particularly] the"},{"kind":"arabic","text_bw":"baA$aq","text_ar":"بَاشَق"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"musket,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sparrow-hawk"},{"kind":"text","text":"]; (K;) as some say: (TA:) or so the former word, (T, * S, TA,) or the latter word accord. to Kr and IB. (TA.) ―         -b3-  And the former word, The ["},{"kind":"italic_en","text":"plant called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hin~aA='","text_ar":"حِنَّا=ء"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Lawsonia inermis"},{"kind":"text","text":"]: (IAar, S, K, TA:) thus correctly, but mentioned by Kr as without tesh-deed. (TA.) ―         -b4-  And the same, i. e. with tesh-deed, The"},{"kind":"italic_en","text":"kernel of the stone of the"},{"kind":"arabic","text_bw":"nabiq","text_ar":"نَبِق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fruit,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"drupe, of the lote-tree called"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["TA","IAar","S","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D9%84%D8%A7%D9%85/","headword_ar":"عَلَّام","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=105215#88dae5","body_html":"عَلَّام<br>من (ع ل م) جمع عَلامة.<br>عَلَّام<br>من (ع ل م) كثير العلم والمعرفة والنسابة."}]}}