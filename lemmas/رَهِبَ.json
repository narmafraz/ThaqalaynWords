","text":"["},{"kind":"italic_en","text":"In my heart is fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cautious fear, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (A.) ―         -b2-  And"},{"kind":"arabic","text_bw":"rahibahu","text_ar":"رَهِبَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rahobapN","text_ar":"رَهْبَةٌ"},{"kind":"text","text":"(JK, Mgh) and"},{"kind":"arabic","text_bw":"ruhobapN","text_ar":"رُهْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruhobN","text_ar":"رُهْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rahabN","text_ar":"رَهَبٌ"},{"kind":"text","text":"; (JK;) [and app."},{"kind":"arabic","text_bw":"rahiba minohu","text_ar":"رَهِبَ مِنْهُ"},{"kind":"text","text":", as seems to be indicated above;]"},{"kind":"italic_en","text":"He feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(JK, Mgh;) [or"},{"kind":"italic_en","text":"feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with caution;"},{"kind":"text","text":"] namely, a thing. (JK.)       -A2-  See also the next paragraph, in two places."}],"source_refs":["S","K","Msb","A","JK","Mgh"]}]},"classical_definitions":null}