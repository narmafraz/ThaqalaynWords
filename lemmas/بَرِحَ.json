{"lemma":"بَرِحَ","slug":"بَرِحَ","root":"ب.ر.ح","root_slug":"ب-ر-ح","root_link":"/words/roots/ب-ر-ح","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَرِحْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَرِحْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَرِحْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَرِحْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَرِحْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَرِحَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَرِحَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَرِحا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَرِحَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَرِحُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَرِحْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْرَح","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْرَحِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْرَحِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْرَحا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْرَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْرَحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْرَح","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْرَح","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْرَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْرَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَرِحْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَرِحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْرَح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْرَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n2192"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B1%D9%90%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to leave, to depart","examples":[{"text":"بَرِحَ ٱلْمَكَانَ / بَرِحَ مِنَ ٱلْمَكَانِ","english":"He left that place."}]},{"pos":"verb","gloss":"to still do","tags":["copulative"],"examples":[{"text":"مَا بَرِحَ ٱلطَّالِبُ مُتَفَوِّقًا فِي دِرَاسَتِهِ","english":"The student is still excellent in his study."}]},{"pos":"noun","gloss":"verbal noun of بَرِحَ (bariḥa)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to harass, to exhaust, to torment"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew ברח (baráħ, “escape”)."},"ipa":["/ba.ri.ħa/","/ba.raħ/","/bar.ra.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2192","headword_ar":"بَرِحَ","root":"brH","body":[{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"zaAla","text_ar":"زَالَ"},{"kind":"text","text":"[in two senses; i. e. as an attributive verb, and also as a non-attributive verb; as will be shown by what follows]. (S, A, Mgh.) [Using it as an attributive verb,] you say,"},{"kind":"arabic","text_bw":"laA A^aboraHu Hat~aY taqoDiYa HaAjatiY","text_ar":"لَا اَبْرَحُ حَتَّى تَقْضِىَ حَاجَتِى"},{"kind":"italic_en","text":"I will not go away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdraw,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"laA A^azuwlN","text_ar":"لَا اَزُولٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"laA A^atanaH~aYi","text_ar":"لَا اَتَنَحَّىِ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"until thou accomplish my want:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"bariHa AlmakaAnu","text_ar":"بَرِحَ المَكَانُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baraAHN","text_ar":"بَرَاحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed, from the place;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zaAla minohu","text_ar":"زَالَ مِنْهُ"},{"kind":"text","text":": and to be distinguished from the phrase in the Kur [xviii. 59, similar as to words,] mentioned below. (Mgh.) You say,"},{"kind":"arabic","text_bw":"bariHa makaAnahu","text_ar":"بَرِحَ مَكَانَهُ"},{"kind":"text","text":", (S, A, L, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"baraAHN","text_ar":"بَرَاحٌ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"buruwHN","text_ar":"بُرُوحٌ"},{"kind":"text","text":"(L, TA, and Ham p. 250) and"},{"kind":"arabic","text_bw":"baraHN","text_ar":"بَرَحٌ"},{"kind":"text","text":", (L,) or"},{"kind":"arabic","text_bw":"baroHN","text_ar":"بَرْحٌ"},{"kind":"text","text":", (as in a copy of the TA,)"},{"kind":"italic_en","text":"He went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed, from his place;"},{"kind":"text","text":"(S, L, K, and Ham ubi suprà;) and"},{"kind":"italic_en","text":"he became in the"},{"kind":"arabic","text_bw":"baraAH","text_ar":"بَرَاح"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wide, uncultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninhabited, tract"},{"kind":"text","text":"]. (S, L, K.) And"},{"kind":"arabic","text_bw":"maA bariHa makaAnahu","text_ar":"مَا بَرِحَ مَكَانَهُ"},{"kind":"italic_en","text":"He did not quit his place."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"bariHa","text_ar":"بَرِحَ"},{"kind":"text","text":"[alone], aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baraAHN","text_ar":"بَرَاحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"zaAla","text_ar":"زَالَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"from its place;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"tbr~H","text_ar":"تبرّح","orth_type":"arrow"},{"kind":"text","text":". (L.) In the phrase"},{"kind":"arabic","text_bw":"laA baraAHa","text_ar":"لَا بَرَاحَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall be, no quitting of place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departing"},{"kind":"text","text":"], the noun is in the accus. case, as in"},{"kind":"arabic","text_bw":"laA rayoba","text_ar":"لَا رَيْبَ"},{"kind":"text","text":": but it is allowable to put it in the nom. case, so that"},{"kind":"arabic","text_bw":"lA","text_ar":"لا"},{"kind":"text","text":"is used in the manner of"},{"kind":"arabic","text_bw":"layosa","text_ar":"لَيْسَ"},{"kind":"text","text":"; (S, K;) as in the following saying of Saad Ibn-Málik, [in the TA, in one place, Ibn-Náshib,] in a poem of which the rhyme is with refa, (S, IAth,) alluding to El-Hárith Ibn-'Abbád, who had withdrawn himself from the war of Teghlib and Bekr the sons of Wáïl: (IAth, TA:)"},{"kind":"quote","text":"faA^anaA A@bonu qayosK laA baraAHu \n                        mano far~aEano niyraAnihaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whoso fleeth from its fires,"},{"kind":"text","text":"(i. e."},{"kind":"arabic","text_bw":"niyraAni AlHarobi","text_ar":"نِيرَانِ الحَرْبِ"},{"kind":"italic_en","text":"the fires of the war,"},{"kind":"text","text":") let him do so:"},{"kind":"italic_en","text":"but"},{"kind":"text","text":"as for me,"},{"kind":"italic_en","text":"I am the son of Keys:"},{"kind":"text","text":"to me"},{"kind":"italic_en","text":"there is not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall not be, any quitting of place"},{"kind":"text","text":"]. (S, IAth. [See also Ham p. 250, where, for"},{"kind":"arabic","text_bw":"man far~a","text_ar":"مَن فَرَّ"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"mano Sad~a","text_ar":"مَنْ صَدَّ"},{"kind":"italic_en","text":"whoso turneth away."},{"kind":"text","text":"]) [Hence,]"},{"kind":"arabic","text_bw":"bariHati","text_ar":"بَرِحَتِ"},{"kind":"arabic","text_bw":"Alr~iyHu biAlt~uraAbi","text_ar":"الرِّيحُ بِالتُّرَابِ"},{"kind":"italic_en","text":"The wind carried up, raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swept up and scattered,"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"went away with,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the dust."},{"kind":"text","text":"(Msb.) [Hence also, accord. to some,]"},{"kind":"arabic","text_bw":"bariHa AlxafaA='u","text_ar":"بَرِحَ الخَفَا=ءُ"},{"kind":"text","text":", (T, S, K, &c.,) and"},{"kind":"arabic","text_bw":"baraHa","text_ar":"بَرَحَ"},{"kind":"text","text":", (Ibn-ElLihyánee, Z, and TA, [thus written in a copy of the A,]) (tropical:)"},{"kind":"italic_en","text":"The state of concealment departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased:"},{"kind":"text","text":"or (tropical:)"},{"kind":"italic_en","text":"what was in a state of concealment became apparent;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"baraAHN","text_ar":"بَرَاحٌ"},{"kind":"text","text":"meaning “what is open and apparent” of land: or (tropical:)"},{"kind":"italic_en","text":"what I was concealing became apparent:"},{"kind":"text","text":"(T, TA:) or (tropical:)"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became manifest,"},{"kind":"text","text":"(S, A, K,) and"},{"kind":"italic_en","text":"its concealment ceased,"},{"kind":"text","text":"(A,) [or]"},{"kind":"italic_en","text":"as though the secret departed, and ceased:"},{"kind":"text","text":"(S:) or, as some say, (assumed tropical:)"},{"kind":"italic_en","text":"the secret became apparent:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"xfY","text_ar":"خفى"},{"kind":"text","text":":) or, lit.,"},{"kind":"italic_en","text":"the low ground became high and apparent;"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"what was concealed became revealed:"},{"kind":"text","text":"(Har pp. 133—4:) the first who said it was Shikk the Diviner. (IDrd, TA.) ―         -b2-  [Using it as a non-attributive verb,] you say,"},{"kind":"arabic","text_bw":"laA A^aboraHu","text_ar":"لَا اَبْرَحُ"},{"kind":"arabic","text_bw":"A^afoEalu *`lika","text_ar":"اَفْعَلُ ذٰلِكَ"},{"kind":"italic_en","text":"I will not cease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I will continue,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"laA A^azaAlu","text_ar":"لَا اَزَالُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"to do that:"},{"kind":"text","text":"(S, A: *) and"},{"kind":"arabic","text_bw":"maA bariHa yafoEalu","text_ar":"مَا بَرِحَ يَفْعَلُ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he ceased not to do thus;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he persevered in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept to, doing thus:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"maA bariHa","text_ar":"مَا بَرِحَ"},{"kind":"arabic","text_bw":"zayodN qaAy^imFA","text_ar":"زَيْدٌ قَايِمًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Zeyd ceased not to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, standing"},{"kind":"text","text":"]: in this case, the verb is of the category of"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":"; (Mgh;) relates to time; and requires a predicate: and its inf. n. is"},{"kind":"arabic","text_bw":"baraAHN","text_ar":"بَرَاحٌ"},{"kind":"text","text":". (Ham p. 250.) Hence the saying in the Kur [xviii. 59],"},{"kind":"arabic","text_bw":"laA A^aboraAHu Hat~aY A^aboluga majomaEa AlbaHorayoni","text_ar":"لَا اَبْرَاحُ حَتَّى اَبْلُغَ مَجْمَعَ البَحْرَيْنِ"},{"kind":"text","text":", but the predicate is suppressed: it may be"},{"kind":"arabic","text_bw":"maA naHonu","text_ar":"مَا نَحْنُ"},{"kind":"arabic","text_bw":"fiyhi ka*`lika","text_ar":"فِيهِ كَذٰلِكَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I will not cease in that wherein we are thus engaged until I reach the place of meeting of the two seas"},{"kind":"text","text":"]: (Mgh:) or it means"},{"kind":"arabic","text_bw":"laA A^azaAlu","text_ar":"لَا اَزَالُ"},{"kind":"arabic","text_bw":"A^asiyru","text_ar":"اَسِيرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will not cease journeying"},{"kind":"text","text":"]: (Bd, Jel:) or"},{"kind":"arabic","text_bw":"lA AbrH","text_ar":"لا ابرح"},{"kind":"text","text":"here may mean"},{"kind":"italic_en","text":"I will not depart"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"laA A^azuwlu","text_ar":"لَا اَزُولُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from that upon which I am intent,"},{"kind":"text","text":"namely journeying and seeking; and"},{"kind":"italic_en","text":"I will not relinquish it;"},{"kind":"text","text":"so that it does not require the predicate. (Bd. [He gives a third explanation, paraphrastic and strained, which I omit.])       -A2-"},{"kind":"arabic","text_bw":"baraHa","text_ar":"بَرَحَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (L, TA, [but it is implied in the K that it is"},{"kind":"text","text":", which is contr. to rule,]) inf. n."},{"kind":"arabic","text_bw":"buruwHN","text_ar":"بُرُوحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a gazelle, S, K, and a bird, and any wild animal, that is hunted or shot, TA)"},{"kind":"italic_en","text":"turned its left side towards the spectator, passing by"},{"kind":"text","text":"(S, K *)"},{"kind":"italic_en","text":"from the direction of his right hand towards that of his left hand:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"passed by from the direction of the spectator's left hand towards that of his right hand:"},{"kind":"text","text":"(Aboo-'Amr Esh-Sheybánee, IF, L, Msb, in art."},{"kind":"arabic","text_bw":"snH","text_ar":"سنح"},{"kind":"text","text":":) [the former appears to be accord. to the usage of the Hijázees; and the latter, accord. to that of the Nejdees, in general: see"},{"kind":"arabic","text_bw":"baAriHN","text_ar":"بَارِحٌ"},{"kind":"text","text":":] contr. of"},{"kind":"arabic","text_bw":"sanaHa","text_ar":"سَنَحَ"},{"kind":"text","text":". (S.)       -A3-"},{"kind":"arabic","text_bw":"baraHa","text_ar":"بَرَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [contr. to rule,] (K,) inf. n."},{"kind":"arabic","text_bw":"baroHN","text_ar":"بَرْحٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was angry."},{"kind":"text","text":"(K.) When a man has been angry with his companion, one says,"},{"kind":"arabic","text_bw":"maA A^a$ad~a","text_ar":"مَا اَشَدَّ"},{"kind":"arabic","text_bw":"maA baraHa Ealayohi","text_ar":"مَا بَرَحَ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How violently angry was he with him!"},{"kind":"text","text":"]. (L.)"}],"source_refs":["S","A","L","K","IAth","TA","T","Msb","Mgh","Bd","Jel"]}]}}