%D9%8E%D8%A8%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"proof"},{"pos":"noun","gloss":"list, index"},{"pos":"verb","gloss":"to be firm, fixed, stable","tags":["intransitive"]},{"pos":"verb","gloss":"to withstand","tags":["intransitive"]},{"pos":"verb","gloss":"to make firm, fixed, stable","tags":["intransitive"],"examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا إِنْ تَنْصُرُوا اللَّهَََ يَنْصُرْكُمْ وَيُثَبِّتْ أَقْدَامَكُمْ","english":"O you who have believed, if you support Allah, He will support you and plant firmly your feet."}]},{"pos":"verb","gloss":"to confine, to restrict","tags":["intransitive"]},{"pos":"verb","gloss":"to make or keep (something) constant in motion","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4299","headword_ar":"ثَبَتَ","root":"vbt","body":[{"kind":"text","text":", (S, M, A, &c.,) aor."},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"vubuwtN","text_ar":"ثُبُوتٌ"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"vabaAtN","text_ar":"ثَبَاتٌ"},{"kind":"text","text":", (S, M, Mgh, K,) or this latter is a simple subst., (Msb,) [unexplained in the S and M and A and K, as being well known,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Msb)"},{"kind":"italic_en","text":"continued, subsisted, lasted, endured, remained, remained fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary, stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rested; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, permanent, constant, firm, steady, steadfast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established: it obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":": (Mgh, Msb:) and"},{"kind":"arabic","text_bw":"Aisotaqar~a","text_ar":"اِسْتَقَرَّ"},{"kind":"text","text":": (Msb:) ["},{"kind":"italic_en","text":"it stood, as a fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth; it stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held, good; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, a fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an established, fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, sound, valid, substantial, real, sure, certain, true, right, correct, just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"vabata biAlmakaAni","text_ar":"ثَبَتَ بِالمَكَانِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuburtN","text_ar":"ثُبُرتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He continued, remained, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place."},{"kind":"text","text":"(T.) ―         -b3-"},{"kind":"arabic","text_bw":"vabata AljaraAdu","text_ar":"ثَبَتَ الجَرَادُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"v~bt","text_ar":"ثّبت","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Avbt","text_ar":"اثبت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The locusts stuck their tails into the ground to lay their eggs."},{"kind":"text","text":"(T.) ―         -b4-"},{"kind":"arabic","text_bw":"vabat~u EalaY AlA^amori","text_ar":"ثَبَتُّ عَلَى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I kept constantly, firmly, steadily, steadfastly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixedly, to the affair"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"zmE","text_ar":"زمع"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"vabata liboduka","text_ar":"ثَبَتَ لِبْدُكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"May thy case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, be permanent."},{"kind":"text","text":"(A, TA.) ―         -b6-  ["},{"kind":"arabic","text_bw":"vabata Einodahu ka*aA","text_ar":"ثَبَتَ عِنْدَهُ كَذَا"},{"kind":"italic_en","text":"Such a thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, a settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an established, fact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth, with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in his opinion; it became established, substantiated, made good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, in his opinion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"vabata Ealayohi","text_ar":"ثَبَتَ عَلَيْهِ"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, established against him."},{"kind":"text","text":"Hence,"},{"kind":"arabic","text_bw":"vabata lahu Ealayohi ka*aA","text_ar":"ثَبَتَ لَهُ عَلَيْهِ كَذَا"},{"kind":"italic_en","text":"Such a thing became established,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, as due to him from him:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". And hence,]"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, necessitated, necessary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requisite:"},{"kind":"text","text":"so that"},{"kind":"arabic","text_bw":"vabata Ealayohi","text_ar":"ثَبَتَ عَلَيْهِ"},{"kind":"text","text":"means also"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent, on him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it rested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lay, on him; as a debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a duty:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a sentence &c.)"},{"kind":"italic_en","text":"became necessitated to take effect upon him:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vabata lahu","text_ar":"ثَبَتَ لَهُ"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, due to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"owing to him"},{"kind":"text","text":"]. (Telweeh, TA in art."},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب"},{"kind":"text","text":".) ―         -b7-  ["},{"kind":"arabic","text_bw":"vabata lahu","text_ar":"ثَبَتَ لَهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It belonged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appertained, as an attribute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a quality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a property, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it; it was affirmable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"predicable, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"vabuta","text_ar":"ثَبُتَ"},{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"vabaAtapN","text_ar":"ثَبَاتَةٌ"},{"kind":"text","text":"(M, A, K) and"},{"kind":"arabic","text_bw":"vubuwtapN","text_ar":"ثُبُوتَةٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm in intellect, understanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, in fight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"intelligent, and possessing self-restraint:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seldom erring"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making a mistake"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committing a 