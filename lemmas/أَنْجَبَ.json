ull,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُنْجَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُنْجَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُنْجِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُنْجِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُنْجَبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُنْجَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُنْجِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُنْجِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُنْجَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُنْجِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَنْجَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَنْجَبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُنْجَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُنْجَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُنْجِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُنْجِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n39344"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%92%D8%AC%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to beget a noble (نَجِيب (najīb)) person (female or male)","tags":["obsolete"]},{"pos":"verb","gloss":"to beget, to sire, to bear (female or male)","tags":["broadly"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39344","headword_ar":"انجب","root":"njb","body":[{"kind":"italic_en","text":"He begot a generous, noble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liberal, child; such as is termed"},{"kind":"arabic","text_bw":"najiybN","text_ar":"نَجِيبٌ"},{"kind":"text","text":". (S.) [This verb, being coupled in the K with"},{"kind":"arabic","text_bw":"najuba","text_ar":"نَجُبَ"},{"kind":"text","text":", might be imagined syn. therewith; but this, accord. to the TA, is not the case.] El-Aashà says,"},{"kind":"quote","text":"A^anojaba A^azomaAna waAlidaAhu bihi\n                      \n                     \n                        A_i*o najalaAhu faniEoma maA najalaA"},{"kind":"text","text":"(S)"},{"kind":"italic_en","text":"He begot a generous son in the times when his parents"},{"kind":"text","text":"("},{"kind":"italic_en","text":"rejoiced"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in him, when they produced him; and excellent was that which they produced."},{"kind":"text","text":"Accord. to one reading, the second word is"},{"kind":"arabic","text_bw":"A^ay~aAma","text_ar":"اَيَّامَ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A^ay~aAmu waAlidayohi","text_ar":"اَيَّامُ وَالِدَيْهِ"},{"kind":"text","text":"is also read in place of"},{"kind":"arabic","text_bw":"AzmAn wAldAh","text_ar":"ازمان والداه"},{"kind":"text","text":"; in which case,"},{"kind":"arabic","text_bw":"Ay~aAm","text_ar":"ايَّام"},{"kind":"text","text":"is fig. the agent of"},{"kind":"arabic","text_bw":"Anjb","text_ar":"انجب"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Anjbt","text_ar":"انجبت"},{"kind":"text","text":"is said of a woman, in the same sense. (TA.) See also"},{"kind":"arabic","text_bw":"Anxb","text_ar":"انخب"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"Anjb","text_ar":"انجب"},{"kind":"text","text":"[as also"},{"kind":"arabic","text_bw":"Anxb","text_ar":"انخب"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He begot a cowardly child:"},{"kind":"text","text":"(from"},{"kind":"arabic","text_bw":"najabN","text_ar":"نَجَبٌ"},{"kind":"text","text":", the “ bark ” of a tree: TA:) thus the verb bears two contr. significations: (K:) or the two significations are not necessarily contr.; for a courageous man may be not generous, or liberal; and a generous, or liberal, man may be not courageous. (MF.)"}],"source_refs":["S","K"]}]}}