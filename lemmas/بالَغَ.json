},{"role":"present_2mp","form":"تُبالِغُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُبالِغْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُبالِغ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُبالِغ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُبالِغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُبالِغانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبالِغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبالِغانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبالِغُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبالِغُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبالِغْنَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُبالِغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبالِغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"بالَغْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بالَغْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":true,"lemma_key":"بالَغَ","root":"بلغ","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n3224","n3242"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D8%A7%D9%84%D9%8E%D8%BA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to exaggerate"},{"pos":"verb","gloss":"to overdo"},{"pos":"verb","gloss":"to do one’s utmost"},{"pos":"verb","gloss":"to intensify"},{"pos":"verb","gloss":"active participle of بَلَغَ (balaḡa)","tags":["active","form-of","form-vi","participle"],"examples":[{"text":"إِنَّ اللَّهَ بَالِغُ أَمْرِهِ"}]},{"pos":"adj","gloss":"extensive, far-reaching"},{"pos":"adj","gloss":"considerable, profound, serious"},{"pos":"adj","gloss":"intense, high, extreme, strong"},{"pos":"adj","gloss":"violent, vehement"},{"pos":"noun","gloss":"one who has reached puberty; pubescent, mature, of age, in one’s majority, adult"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb بَلَغَ (balaḡa, “to reach, to arrive, to come to, to amount to”)."},"ipa":["/baː.la.ɣa/","/baː.liɣ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3224","headword_ar":"بالغ","root":"blg","body":[{"kind":"text","text":", (S, Msb, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"mubaAlagapN","text_ar":"مُبَالَغَةٌ"},{"kind":"text","text":"(JK, K, &c.) and"},{"kind":"arabic","text_bw":"bilaAgN","text_ar":"بِلَاغٌ"},{"kind":"text","text":", (K.)"},{"kind":"italic_en","text":"He exceeded the usual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordinary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, bounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree,"},{"kind":"text","text":"in a thing;"},{"kind":"italic_en","text":"acted egregiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"immoderately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extravagantly,"},{"kind":"text","text":"therein: (KL:)"},{"kind":"italic_en","text":"he strove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laboured; exerted himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability; employed himself vigorously, strenuously, laboriously, sedulously, earnestly, with energy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effectiveness; took pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinary pains:"},{"kind":"text","text":"(K, TA:)"},{"kind":"italic_en","text":"he did not fall short of doing what was requisite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he ought; did not flag,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was not remiss:"},{"kind":"text","text":"(S, K, TA:)"},{"kind":"italic_en","text":"he exerted unsparingly his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effort"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the utmost thereof:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"he accomplished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, the utmost of his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effort"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavour; he did his utmost:"},{"kind":"text","text":"(JK:)"},{"kind":"arabic","text_bw":"fiY A^amorK","text_ar":"فِى اَمْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an affair"},{"kind":"text","text":"]: (S, K, TA:) or"},{"kind":"arabic","text_bw":"fiY ka*aA","text_ar":"فِى كَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"in the pursuit of such a thing."},{"kind":"text","text":"(Msb.) ["},{"kind":"arabic","text_bw":"bAlg fiY ka*aA","text_ar":"بالغ فِى كَذَا"},{"kind":"text","text":"may be rendered as above, or"},{"kind":"italic_en","text":"He did such a thing much, exceedingly, egregiously, extraordinarily, immoderately, extravagantly, excessively, vehemently, energetically, superlatively, excellently, consummately, thoroughly."},{"kind":"text","text":"Hence"},{"kind":"arabic","text_bw":"mubaAlagapN","text_ar":"مُبَالَغَةٌ"},{"kind":"text","text":"in explanations of words; meaning"},{"kind":"italic_en","text":"Intensiveness; muchness; extraordinariness; excessiveness; vehemence; energy; emphasis; hyperbole;"},{"kind":"text","text":"&c.; and sometimes,"},{"kind":"italic_en","text":"frequentative signification."},{"kind":"text","text":"Thus,"},{"kind":"arabic","text_bw":"A_isomu mubaAlagapK","text_ar":"اـِسْمُ مُبَالَغَةٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A noun of intensiveness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an intensive epithet:"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"$akuwrN","text_ar":"شَكُورٌ"},{"kind":"text","text":"“ very thankful, ” or “ very grateful; ” and"},{"kind":"arabic","text_bw":"Ham~aAdN","text_ar":"حَمَّادٌ"},{"kind":"text","text":"“ a great praiser, ” or “ a frequent praiser. ”]"}],"source_refs":["KL","K","TA","S","Msb","JK"]},{"entry_id":"n3242","headword_ar":"بَالِغٌ","root":"blg","body":[{"kind":"italic_en","text":"Reaching, attaining, arriving at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coming to,"},{"kind":"text","text":"a place [or time, or an affair or a state or an event that is meditated or intended or determined or appointed;"},{"kind":"italic_en","text":"reaching,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to the utmost point"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree:"},{"kind":"text","text":"and sometimes,"},{"kind":"italic_en","text":"being at the point of reaching"},{"kind":"text","text":"&c.: see 1, first sentence]. (TA.) You say also, ↓"},{"kind":"arabic","text_bw":"jayo$N balogN","text_ar":"جَيْشٌ بَلْغٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"baAligN","text_ar":"بَالِغٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An army reaching,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arriving at, its appointed place"},{"kind":"text","text":"]. (K, TA.) And ↓"},{"kind":"arabic","text_bw":"A^amoru A@ll~`hi balogN","text_ar":"اَمْرُ ا@للّٰهِ بَلْغٌ","orth_type":"arrow"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"baAligN","text_ar":"بَالِغٌ"},{"kind":"text","text":", (S, K,) meaning ["},{"kind":"italic_en","text":"The decree of God"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"reacheth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attaineth, its intended object:"},{"kind":"text","text":"(K:) from the saying in the Kur [lxv. 3],"},{"kind":"arabic","text_bw":"A_in~a A@ll~`ha baAligN A^amorahu","text_ar":"اـِنَّ ا@للّٰهَ بَالِغٌ اَمْرَهُ"},{"kind":"text","text":"(S)"},{"kind":"italic_en","text":"Verily God attaineth his purpose."},{"kind":"text","text":"(Bd, Jel.) And"},{"kind":"arabic","text_bw":"baAligN fiY AlHumoqi","text_ar":"بَالِغٌ فِى الحُمْقِ"},{"kind":"italic_en","text":"Reaching the utmost point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree, in stupidity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolishness."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"lazimahu *`lika baAligFA maA balaga","text_ar":"لَزِمَهُ ذٰلِكَ بَالِغًا مَا بَلَغَ"},{"kind":"text","text":": see 1: and see the sentence there next following it. (Msb.)"},{"kind":"arabic","text_bw":"A^ayomaAnN baAligapN","text_ar":"اَيْمَانٌ بَالِغَةٌ"},{"kind":"text","text":", in the Kur lxviii. 39, means"},{"kind":"italic_en","text":"Firm covenants:"},{"kind":"text","text":"(Jel:) or"},{"kind":"italic_en","text":"covenants confirmed by oaths in the utmost degree:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"rendered obligatory for ever; sworn to, that they shall be constantly observed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that have reached their utmost point:"},{"kind":"text","text":"(Th, TA:) or"},{"kind":"arabic","text_bw":"yamiynN baAligapN","text_ar":"يَمِينٌ بَالِغَةٌ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"an oath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a covenant,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"confirmed."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"Attaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having attained, to puberty, virility, ripeness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"maturity;"},{"kind":"text","text":"applied to a boy: (T, IKoot, IKtt, Msb:) and in like manner, without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", applied to a girl; (T, IAmb, Msb, K;) thus applied, with the mention of the noun qualified by it, by Esh-Sháfi'ee (T, Msb) and other chaste persons, of the Arabs; (T, TA;) or"},{"kind":"arabic","text_bw":"baAligapN","text_ar":"بَالِغَةٌ"},{"kind":"text","text":"; (IKoot, Msb;) or the latter is also thus applied, with the mention of the noun which it qualifies, (T, Msb, K,) not being wrong because it is the original form; (T, TA;) and seems to be necessarily used when the noun which it qualifies is not mentioned, to prevent ambiguity. (Msb.) ―         -b3-"},{"kind":"italic_en","text":"A good, a goodly,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"excellent,"},{"kind":"text","text":"thing. (S, K.)"}],"source_refs":["S","K","Jel","Bd","Th","TA","T","IKoot","IKtt","Msb"]}]},"classical_definitions":null}