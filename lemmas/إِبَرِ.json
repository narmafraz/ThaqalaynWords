{"lemma":"إِبَرِ","slug":"إِبَرِ","root":"#.ب.ر","root_slug":"_-ب-ر","root_link":"/words/roots/_-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["","n2160"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D8%A8%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"needle (all senses)"}]},"etymology":null,"ipa":["/ʔib.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2160","headword_ar":"اَبَرٌّ","root":"br","body":[{"kind":"text","text":"[accord. to analogy signifies"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, pious"},{"kind":"text","text":"&c.: see"},{"kind":"arabic","text_bw":"bar~N","text_ar":"بَرٌّ"},{"kind":"text","text":". But the only meaning that I find assigned to it in any of the lexicons is that here following.       -A2- ]"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, distant in the desert,"},{"kind":"text","text":"(T, K,)"},{"kind":"italic_en","text":"as to habitation."},{"kind":"text","text":"(T.) So in the saying,"},{"kind":"arabic","text_bw":"A^afoSaHu AlEarabi A^abar~uhumo","text_ar":"اَفْصَحُ العَرَبِ اَبَرُّهُمْ"},{"kind":"italic_en","text":"The most chaste in speech of the Arabs are the most distant of them in the desert, as to habitation."},{"kind":"text","text":"(T, K. * [In the latter, instead of"},{"kind":"arabic","text_bw":"AfSH","text_ar":"افصح"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"A^aSolaHu","text_ar":"اَصْلَحُ"},{"kind":"text","text":".])"}],"source_refs":["T","K"]}]},"classical_definitions":null}