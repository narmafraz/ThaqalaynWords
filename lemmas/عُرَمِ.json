ugnant;"},{"kind":"text","text":"(S, Msb, K; *) and"},{"kind":"italic_en","text":"sharp:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong:"},{"kind":"text","text":"(K:) said of a boy, or child: (S:) or of a man: and, said of a boy, or child, (or so [particularly]"},{"kind":"arabic","text_bw":"Earuma","text_ar":"عَرُمَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaraAmapN","text_ar":"عَرَامَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuraAmN","text_ar":"عُرَامٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"he behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^a$ira","text_ar":"اَشِرَ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"mariHa","text_ar":"مَرِحَ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"baTira","text_ar":"بَطِرَ"},{"kind":"text","text":"; [all of which signify the same;] or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wicked;"},{"kind":"arabic","text_bw":"EalayonaA","text_ar":"عَلَيْنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to us"},{"kind":"text","text":"]. (K, TA.) And accord. to IAar,"},{"kind":"arabic","text_bw":"Earama","text_ar":"عَرَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, ignorant;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Earuma","text_ar":"عَرُمَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Earima","text_ar":"عَرِمَ"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"EaraAmN","text_ar":"عَرَامٌ"},{"kind":"text","text":", below.] ―         -b2-"},{"kind":"arabic","text_bw":"Earima","text_ar":"عَرِمَ"},{"kind":"text","text":"said of a bone, [app. when burnt,] aor."},{"kind":"text","text":", (K, TA,)"},{"kind":"page_break","n":2025},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"EaramN","text_ar":"عَرَمٌ"},{"kind":"text","text":", accord. to the copies of the K"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"fatara","text_ar":"فَتَرَ"},{"kind":"text","text":", but correctly"},{"kind":"arabic","text_bw":"fatara","text_ar":"فَتَرَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"It exhaled its scent, smell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"odour"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Earama fulaAnFA","text_ar":"عَرَمَ فُلَانًا"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"EaraAmapN","text_ar":"عَرَامَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He treated such a one with illnature, and exceeding perverseness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crossness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repugnance."},{"kind":"text","text":"(K, * TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Earama AlEaZoma","text_ar":"عَرَمَ العَظْمَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaromN","text_ar":"عَرْمٌ"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"tEr~mhu","text_ar":"تعرّمهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) are like"},{"kind":"arabic","text_bw":"Earaqahu","text_ar":"عَرَقَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tEr~qhu","text_ar":"تعرّقهُ"},{"kind":"text","text":"; (S;) [i. e.] both signify"},{"kind":"italic_en","text":"He stripped off the flesh from the bone"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with his fore teeth, eating it"},{"kind":"text","text":"]. (K.) ―         -b3-  And in like manner, (S,)"},{"kind":"arabic","text_bw":"Earamati AlA_ibilu Al$~ajara","text_ar":"عَرَمَتِ الاـِبِلُ الشَّجَرَ"},{"kind":"italic_en","text":"The camels"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cropped the trees;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"obtained"},{"kind":"text","text":"["},{"kind":"italic_en","text":"pasture"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the trees."},{"kind":"text","text":"(S, K.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Earama A^um~ahu","text_ar":"عَرَمَ اُمَّهُ"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"EaromN","text_ar":"عَرْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child)"},{"kind":"italic_en","text":"sucked the breast of his mother;"},{"kind":"text","text":"(K, TA;) and so"},{"kind":"arabic","text_bw":"vadoYa A^um~ihi","text_ar":"ثَدْىَ اُمِّهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AEtrm","text_ar":"اعترم","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n28836","headword_ar":"عَرْمٌ","root":"Erm","body":[{"kind":"italic_en","text":"Grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"dripping that exudes from flesh-meat and from fat."},{"kind":"text","text":"(K.) And The"},{"kind":"italic_en","text":"remains of the cooking-pot:"},{"kind":"text","text":"(K, TA:) or the"},{"kind":"italic_en","text":"dirt of the cooking-pot;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EuraAmN","text_ar":"عُرَامٌ","orth_type":"arrow"},{"kind":"text","text":", (TA.)"}],"source_refs":["K","TA"]},{"entry_id":"n28837","headword_ar":"عَرَمٌ","root":"Erm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"in anything,"},{"kind":"italic_en","text":"of being of two colours:"},{"kind":"text","text":"a leopard has this quality: (Th, TA:) or, as also ↓"},{"kind":"arabic","text_bw":"EuromapN","text_ar":"عُرْمَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"blackness mixed with whiteness,"},{"kind":"text","text":"in anything: or the"},{"kind":"italic_en","text":"quality of being speckled with blackness and whiteness, without largeness of every speckle:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a whiteness in the lip of the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat:"},{"kind":"text","text":"(K:) or thus the latter word: (S, TA:) and likewise the"},{"kind":"italic_en","text":"quality of being speckled with black, in the ear thereof."},{"kind":"text","text":"(TA.) Also (i. e."},{"kind":"arabic","text_bw":"EaramN","text_ar":"عَرَمٌ"},{"kind":"text","text":") The"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"in a collection of small cattle,"},{"kind":"italic_en","text":"of consisting of sheep and goats."},{"kind":"text","text":"(S.)       -A2-  See also"},{"kind":"arabic","text_bw":"EaramapN","text_ar":"عَرَمَةٌ"},{"kind":"text","text":"."}],"source_refs":["Th","TA","K","S"]},{"entry_id":"n28838","headword_ar":"عَرِمٌ","root":"Erm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaArimN","text_ar":"عَارِمٌ"},{"kind":"text","text":", in two places.       -A2-  Also"},{"kind":"italic_en","text":"A dam;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"musan~aApN","text_ar":"مُسَنَّاةٌ"},{"kind":"text","text":": (S, TA:) [or rather"},{"kind":"italic_en","text":"dams,"},{"kind":"text","text":"agreeably with what here follows:] a pl. [or coll. gen. n.] (K) having no sing. [or n. un.]: (S, K:) or its sing. [or n. un.] is ↓"},{"kind":"arabic","text_bw":"EarimapN","text_ar":"عَرِمَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) which signifies, (Kr, K, TA,) as also ↓"},{"kind":"arabic","text_bw":"EaramapN","text_ar":"عَرَمَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Kr, TA,)"},{"kind":"italic_en","text":"a dam"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"musan~aApN","text_ar":"مُسَنَّاةٌ"},{"kind":"text","text":", Kr, or"},{"kind":"arabic","text_bw":"sad~N","text_ar":"سَدٌّ"},{"kind":"text","text":", K)"},{"kind":"italic_en","text":"that is raised across a valley,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"torrent-bed:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"EarimN","text_ar":"عَرِمٌ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"dams such as are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^aHobaAs","text_ar":"اَحْبَاس"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"HibosN","text_ar":"حِبْسٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"constructed in valleys,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"torrent-beds,"},{"kind":"text","text":"(AHn, K, TA,)"},{"kind":"italic_en","text":"in the middle parts of these:"},{"kind":"text","text":"(AHn, TA:) in each of which senses it is said to be used in the Kur xxxiv. 15: (TA:) or it there signifies"},{"kind":"italic_en","text":"a torrent of which the rush is not to be withstood:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"a violent rain,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"that is not to be endured:"},{"kind":"text","text":"thus, accord. to some, in the Kur: (TA:) and the"},{"kind":"italic_en","text":"male of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"species of rat called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jura*","text_ar":"جُرَذ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"which is the"},{"kind":"arabic","text_bw":"xulod","text_ar":"خُلْد"},{"kind":"text","text":", so, Az says, is there meant accord. to some: (TA:) and, (K, TA,) as some say, in that instance, (TA,) it is the name of"},{"kind":"italic_en","text":"a certain valley"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in ElYemen:"},{"kind":"text","text":"so says (TA.)"}],"source_refs":["S","TA","K","Msb","Kr","AHn"]}]},"classical_definitions":null}