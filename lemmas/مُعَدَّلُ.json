{"lemma":"مُعَدَّلُ","slug":"مُعَدَّلُ","root":"ع.د.ل","root_slug":"ع-د-ل","root_link":"/words/roots/ع-د-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n28334","n28336"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%8E%D8%AF%D9%8E%D9%91%D9%84%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"average"},{"pos":"noun","gloss":"rate"},{"pos":"noun","gloss":"average"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of عَدَّلَ (ʕaddala, “to balance”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28334","headword_ar":"مَعْدِلٌ","root":"Edl","body":[{"kind":"italic_en","text":"A place of turning away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"maEoduwlN","text_ar":"مَعْدُولٌ","orth_type":"arrow"},{"kind":"text","text":": so in the saying,"},{"kind":"arabic","text_bw":"maA lahu maEodilN","text_ar":"مَا لَهُ مَعْدِلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEoduwlN","text_ar":"مَعْدُولٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is for him no place of turning away"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back"},{"kind":"text","text":"]: (K:) pl."},{"kind":"arabic","text_bw":"maEaAdilu","text_ar":"مَعَادِلُ"},{"kind":"text","text":": Aboo-Khirásh says,"},{"kind":"quote","text":"taDiyqu EalaY~a AlA^aroDu *aAtu AlmaEaAdili"},{"kind":"text","text":"meaning ["},{"kind":"italic_en","text":"The earth having those ways in which one may turn in various directions becomes strait to me;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"having such amplitude that by reason thereof one may turn in it to the right and left."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"A way, course, mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of acting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conduct"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"thus in the saying"},{"kind":"arabic","text_bw":"A^axa*a fiY maEodili AlHaq~i","text_ar":"اَخَذَ فِى مَعْدِلِ الحَقِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took to the right way of acting"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"maEodili AlbaATili","text_ar":"مَعْدِلِ البَاطِلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrong, way of acting"},{"kind":"text","text":"]: and in like manner one says,"},{"kind":"arabic","text_bw":"AunoZuruwA A_ilaY suwo'i maEaAdilihi","text_ar":"اُنْظُرُوا اـِلَى سُوْءِ مَعَادِلِهِ"},{"kind":"italic_en","text":"Look ye at his evil ways of acting:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"huwa sadiydu AlmaEaAdili","text_ar":"هُوَ سَدِيدُ المَعَادِلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is one who takes a right direction in respect of the ways of acting"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K"]},{"entry_id":"n28336","headword_ar":"مُعَدَّلٌ","root":"Edl","body":[{"kind":"text","text":"Anything"},{"kind":"italic_en","text":"straightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made even:"},{"kind":"text","text":"(S, O, K:) [&c.: see its verb.] ―         -b2-"},{"kind":"arabic","text_bw":"Alkur~u AlmuEad~alu","text_ar":"الكُرُّ المُعَدَّلُ"},{"kind":"text","text":"see in art."},{"kind":"arabic","text_bw":"kr","text_ar":"كر"},{"kind":"text","text":"."}],"source_refs":["S","O","K"]}]},"classical_definitions":null}