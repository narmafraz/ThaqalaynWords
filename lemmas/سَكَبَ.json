ions":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pour, to spill","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of سَكَبَ (sakaba).","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"spilling, pouring, pouring out","tags":["uncountable"]}]},"etymology":{"source":"wiktextract","text":"Verbal noun of سَكَبَ (sakaba)."},"ipa":["/sa.ka.ba/","/sakb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20176","headword_ar":"سَكَبَ","root":"skb","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (A, TA,) inf. n."},{"kind":"arabic","text_bw":"sukuwbN","text_ar":"سُكُوبٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"sakobN","text_ar":"سَكْبٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"tasokaAbN","text_ar":"تَسْكَابٌ"},{"kind":"text","text":", (S, [this last assigned in the K to the trans. verb,]) said of water, (S, A, Msb, K,) and a flow of tears ("},{"kind":"arabic","text_bw":"damoE","text_ar":"دَمْع"},{"kind":"text","text":"), (A, TA,) and the like, (TA,)"},{"kind":"italic_en","text":"It poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Anskb","text_ar":"انسكب","orth_type":"arrow"},{"kind":"text","text":". (S, K.)       -A2-  And"},{"kind":"arabic","text_bw":"sakabahu","text_ar":"سَكَبَهُ"},{"kind":"text","text":", (S, A, Mgh, Msb, K,) aor. as above, (A, TA,) inf. n."},{"kind":"arabic","text_bw":"sakobN","text_ar":"سَكْبٌ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"tasokaAbN","text_ar":"تَسْكَابٌ"},{"kind":"text","text":", (K, [the latter assigned in the S to the intrans. verb,])"},{"kind":"italic_en","text":"He poured it out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"namely, water, (S, A, Mgh, Msb, K,) and a flow of tears, (A, TA,) and the like; (TA;) as also ↓"},{"kind":"arabic","text_bw":"Askbhu","text_ar":"اسكبهُ","orth_type":"arrow"},{"kind":"text","text":". (A.) The people of El-Medeeneh say,"},{"kind":"arabic","text_bw":"Ausokubo EalaY","text_ar":"اُسْكُبْ عَلَى"},{"kind":"arabic","text_bw":"yad aY~a","text_ar":"يَد َىَّ"},{"kind":"italic_en","text":"Pour thou out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, upon my hands."},{"kind":"text","text":"(A.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"haAhunaA tusokabu AlEabaraAtu","text_ar":"هَاهُنَا تُسْكَبُ العَبَرَاتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Here tears are to be poured forth"},{"kind":"text","text":"], meaning this is the place in which one should weep, seeking forgiveness. (Mgh.)"}],"source_refs":["S","A","Msb","K","TA","Mgh"]}]}}