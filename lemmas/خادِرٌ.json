{"lemma":"خادِرٌ","slug":"خادِرٌ","root":"خ.د.ر","root_slug":"خ-د-ر","root_link":"/words/roots/خ-د-ر","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n10104"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%AF%D9%90%D8%B1%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10104","headword_ar":"خَادِرٌ","root":"xdr","body":[{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"muxodirN","text_ar":"مُخْدِرٌ","orth_type":"arrow"},{"kind":"text","text":"(A, TA) [originally"},{"kind":"italic_en","text":"Keeping behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"within, the"},{"kind":"arabic","text_bw":"xidor","text_ar":"خِدْر"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"curtain."},{"kind":"text","text":"―         -b2-  And hence,] (tropical:)  A lion"},{"kind":"italic_en","text":"keeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding, in his lurking-place:"},{"kind":"text","text":"(A, * K, * TA:) or"},{"kind":"italic_en","text":"entering into it."},{"kind":"text","text":"(S, TA.) And the former, and ↓"},{"kind":"arabic","text_bw":"xaduwrN","text_ar":"خَدُورٌ","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)  A gazelle"},{"kind":"italic_en","text":"remaining behind the herd; not going with it:"},{"kind":"text","text":"and (assumed tropical:)  a beast"},{"kind":"italic_en","text":"that remains behind; not overtaking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coming up with, the others:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xaduwrN","text_ar":"خَدُورٌ","orth_type":"arrow"},{"kind":"text","text":"likewise signifies (assumed tropical:)  a camel"},{"kind":"italic_en","text":"that is in the rear of the other camels; that remains behind them, and when it sees them go on, goes on with them."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xaAdirN","text_ar":"خَادِرٌ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"Languid, and lazy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slothful."},{"kind":"text","text":"(S.) ―         -b2-  And (tropical:)  A gazelle"},{"kind":"italic_en","text":"having feeble bones."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","A","K","TA"]}]},"classical_definitions":null}