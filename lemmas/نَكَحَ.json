","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْكُحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْكُحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْكَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْكَحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْكِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْكِحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْكُحْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْكَحْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْكِحْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْكُح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْكُح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْكَح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْكَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْكِح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْكِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَكَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَكَحْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":186,"cross_references":{"qac":{"found":true,"lemma_key":"نَكَحَ","root":"نكح","pos":"V","occurrence_count":14},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3482","n40484"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%83%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to marry","examples":[{"text":"فَإِن طَلَّقَهَا فَلَا تَحِلُّ لَهُ مِن بَعْدُ حَتَّى تَنْكِحَ زَوْجًا غَيْرَهُ ۗ فَإِن طَلَّقَهَا فَلَا جُنَاحَ عَلَيْهِمَا أَن يَتَرَاجَعَا إِن ظَنَّا أَن يُقِيمَا حُدُودَ ٱللَّهِ ۗ وَتِلْكَ حُدُودُ ٱللَّهِ يُبَيِّنُهَا لِقَوْمٍ يَعْلَمُونَ","english":"And if he has divorced her, then she is not lawful to him afterward until she marries a husband other than him. And if the latter husband divorces her, there is no blame upon the woman and her former husband for returning to each other if they think that they can keep the limits of God. These are the limits of God, which He makes clear to a people who know."}]},{"pos":"verb","gloss":"to have sex with","tags":["vulgar"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3482","headword_ar":"نَكَحَ","root":"bwA^","body":[{"kind":"text","text":": (M, K:) and also"},{"kind":"arabic","text_bw":"taz~awaja","text_ar":"تَزَّوَجَ"},{"kind":"text","text":". (TA. [There mentioned as a distinct signification.]) The verb is trans. in these two senses. (TK.)       -A2-"},{"kind":"arabic","text_bw":"bw~A^ AlrumoHa","text_ar":"بوّا الرُمْحَ"},{"kind":"arabic","text_bw":"naHowahu","text_ar":"نَحْوَهُ"},{"kind":"italic_en","text":"He directed the spear towards him;"},{"kind":"text","text":"(T, S;) and (T)"},{"kind":"italic_en","text":"confronted him with it;"},{"kind":"text","text":"(T, M, K;) and"},{"kind":"italic_en","text":"prepared it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it ready"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to thrust it towards him"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["M","K","T"]},{"entry_id":"n40484","headword_ar":"نَكَحَ","root":"nkH","body":[{"kind":"text","text":", (S, K, &c.,) aor."},{"kind":"text","text":", (Msb, K,) and"},{"kind":"text","text":", (K,) the latter agreeable with analogy, but by some rejected, and the former contr. to analogy, but more common, and the form used"},{"kind":"page_break","n":2848},{"kind":"text","text":"in the Kur, (TA,) the only instance of an aor. of this form from a verb having"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":"for its last radical letter, except"},{"kind":"arabic","text_bw":"ynTH","text_ar":"ينطح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ymnH","text_ar":"يمنح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ynDH","text_ar":"ينضح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ynbH","text_ar":"ينبح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yrjH","text_ar":"يرجح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yA^nH","text_ar":"يانح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yA^zH","text_ar":"يازح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ymlH","text_ar":"يملح"},{"kind":"text","text":", (ISd,) [and"},{"kind":"arabic","text_bw":"yDH","text_ar":"يضح"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"nikaAHN","text_ar":"نِكَاحٌ"},{"kind":"text","text":"(S, K, &c.) and"},{"kind":"arabic","text_bw":"nakoHN","text_ar":"نَكْحٌ"},{"kind":"text","text":"; (ISd, K;)"},{"kind":"italic_en","text":"Inivit"},{"kind":"text","text":"feminam: and (sometimes, S)"},{"kind":"italic_en","text":"he married, took in marriage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted a marriage with,"},{"kind":"text","text":"a woman: as also ↓"},{"kind":"arabic","text_bw":"AstnkH","text_ar":"استنكح","orth_type":"arrow"},{"kind":"text","text":"(S, K, &c.) [and ↓"},{"kind":"arabic","text_bw":"nAkH","text_ar":"ناكح","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"munaAkaHapN","text_ar":"مُنَاكَحَةٌ"},{"kind":"text","text":":] used only with reference to a man: (ISd:) but Th uses it with reference to flies: (TA:) J says, that it is sometimes used in the latter sense; but accord. to the Msb it is more commonly so used; (MF;) and it is used only in this sense in the Kur: (TA:) IF and others say, that it signifies coitus; and coitus without marriage; and marriage without coitus: (Msb:) [but] in the Time of Ignorance, when a man demanded a woman in marriage he said,"},{"kind":"arabic","text_bw":"AinokiHiyniY","text_ar":"اِنْكِحِينِى"},{"kind":"text","text":"; and when he desired fornication, he said,"},{"kind":"arabic","text_bw":"saAfiHiyniY","text_ar":"سَافِحِينِى"},{"kind":"text","text":". (TA, in art"},{"kind":"arabic","text_bw":"sfH","text_ar":"سفح"},{"kind":"text","text":".) It is disputed whether it be proper or tropical in these two senses; or proper in one, and tropical in one: (MF:) it is said to be from"},{"kind":"arabic","text_bw":"nakaHahu Ald~awaY","text_ar":"نَكَحَهُ الدَّوَى"},{"kind":"text","text":", or from"},{"kind":"arabic","text_bw":"tanaAkaHati AlA^a$ojaAru","text_ar":"تَنَاكَحَتِ الاَشْجَارُ"},{"kind":"text","text":", or from"},{"kind":"arabic","text_bw":"nakaHa AlmaTaru","text_ar":"نَكَحَ المَطَرُ"},{"kind":"arabic","text_bw":"AlA^aroDa","text_ar":"الاَرْضَ"},{"kind":"text","text":"; and if so, it is tropical in both the above senses; and the opinion that it is so is confirmed by this, that the signification of marriage is not understood unless by a word or phrase in connexion with it, as when you say"},{"kind":"arabic","text_bw":"nakaHa fiY baniY","text_ar":"نَكَحَ فِى بَنِى"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he took a wife from among the sons of such a one"},{"kind":"text","text":"]; nor is that of coitus unless by the same means, as when you say"},{"kind":"arabic","text_bw":"nakaHa zawojatahu","text_ar":"نَكَحَ زَوْجَتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"inivit conjugem suam"},{"kind":"text","text":"]; and this is one of the signs of a tropical expression. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"nakaHato","text_ar":"نَكَحَتْ"},{"kind":"italic_en","text":"She married,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took a husband."},{"kind":"text","text":"(S, K.) ―         -b3-"},{"kind":"arabic","text_bw":"nakaHa","text_ar":"نَكَحَ"},{"kind":"arabic","text_bw":"AlmaTaru AlA^aroDa","text_ar":"المَطَرُ الاَرْضَ"},{"kind":"italic_en","text":"The rain became commingled with the soil:"},{"kind":"text","text":"(Msb:) or,"},{"kind":"italic_en","text":"rested upon the ground so as to soak it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A_iEotamada EalayohaA","text_ar":"اـِعْتَمَدَ عَلَيْهَا"},{"kind":"text","text":": (K:) as also ↓"},{"kind":"arabic","text_bw":"naAkahaA","text_ar":"نَاكَهَا","orth_type":"arrow"},{"kind":"text","text":". (L.) ―         -b4-"},{"kind":"arabic","text_bw":"nakaHahu Ald~awaY","text_ar":"نَكَحَهُ الدَّوَى"},{"kind":"italic_en","text":"The disease infected him"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xaAmarhu","text_ar":"خَامَرهُ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and overcame him."},{"kind":"text","text":"(Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"nakaHa","text_ar":"نَكَحَ"},{"kind":"arabic","text_bw":"Aln~uEaAsu Eayonahu","text_ar":"النُّعَاسُ عَيْنَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Drowsiness overcame his eye;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"naAkahaA","text_ar":"نَاكَهَا"},{"kind":"text","text":": and in like manner ↓"},{"kind":"arabic","text_bw":"AstnkH","text_ar":"استنكح","orth_type":"arrow"},{"kind":"arabic","text_bw":"Aln~awomu Eayonahu","text_ar":"النَّوْمُ عَيْنَهُ"},{"kind":"italic_en","text":"sleep overcame his eye."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","K","TA","ISd","MF"]}]}}