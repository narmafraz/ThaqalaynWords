ee.)"}], "source_refs": ["S", "K", "TA", "Msb"]}, {"entry_id": "n6033", "headword_ar": "جُلَّلٌ", "root": "jl", "body": [{"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "jaliylN", "text_ar": "جَلِيلٌ"}], "source_refs": []}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}