":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْخُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْخُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْخَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْخَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْخُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْخُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْخَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْخَبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْخُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَشْخَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَخَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَخَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْخُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْخُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشْخَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْخَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n21872"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AE%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21872","headword_ar":"شَخَبَ","root":"$xb","body":[{"kind":"text","text":", (Mgh, TA,) aor."},{"kind":"text","text":"[and"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"$axobN","text_ar":"شَخْبٌ"},{"kind":"text","text":", said of milk, (Mgh,) and of anything,"},{"kind":"italic_en","text":"It flowed."},{"kind":"text","text":"(Mgh, TA.) And"},{"kind":"arabic","text_bw":"$axabotuhu","text_ar":"شَخَبْتُهُ"},{"kind":"italic_en","text":"I made it to flow."},{"kind":"text","text":"(Mgh.) You say,"},{"kind":"arabic","text_bw":"$axaba All~abanu","text_ar":"شَخَبَ اللَّبَنُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, O, CK,) inf. n."},{"kind":"arabic","text_bw":"$axobN","text_ar":"شَخْبٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"The milk flowed in an extended stream from the udder when milked;"},{"kind":"text","text":"(S, O, CK;) and (assumed tropical:)  in like manner one says of blood: (O:) or"},{"kind":"arabic","text_bw":"$axaba All~abana","text_ar":"شَخَبَ اللَّبَنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":","},{"kind":"italic_en","text":"he made the milk to flow in a continuous stream from the udder"},{"kind":"text","text":"(K accord. to the TA [and accord. to the context in the K, in which it is immediately added"},{"kind":"arabic","text_bw":"faA@no$axaba","text_ar":"فَا@نْشَخَبَ"},{"kind":"text","text":", showing that ↓"},{"kind":"arabic","text_bw":"An$xb","text_ar":"انشخب","orth_type":"arrow"},{"kind":"text","text":"has the former of these two significations as quasi-pass. of"},{"kind":"arabic","text_bw":"$axaba","text_ar":"شَخَبَ"},{"kind":"text","text":", and the like is said in the A,])"},{"kind":"italic_en","text":"between the vessel and the teat."},{"kind":"text","text":"(TA.) Hence, i. e. from"},{"kind":"arabic","text_bw":"$axaba All~abanu","text_ar":"شَخَبَ اللَّبَنُ"},{"kind":"text","text":", the saying of ElKumeyt,"},{"kind":"quote","text":"wawaHowaHa fiY HiDoni AlfataApi DajiyEuhaA\n                      \n                     \n                        walamo yaku fiY Aln~ukodi AlmaqaAliyti ma$oxabu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And he who lay upon his side with her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"her bedfellow, breathed audibly, by reason of the cold, in the bosom of the young woman, and there was not, among the she-camels that had no young ones living, and that should therefore abound with milk, because not suckling, any flowing of milk in a continuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an extended, stream,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place, thereof,"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"ma$oxabN","text_ar":"مَشْخَبٌ"},{"kind":"text","text":"may be, agreeably with a general rule, an inf. n. or a n. of time or of place]. (S.) And some expl."},{"kind":"arabic","text_bw":"$axobN","text_ar":"شَخْبٌ"},{"kind":"text","text":"as signifying The"},{"kind":"italic_en","text":"sounding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, of milk when it is being drawn from the udder."},{"kind":"text","text":"(TA.) One says also,"},{"kind":"arabic","text_bw":"$axabato A^awodaAju Alqatiyli damFA","text_ar":"شَخَبَتْ اَوْدَاجُ القَتِيلِ دَمًا"},{"kind":"text","text":"i. e. (tropical:)  ["},{"kind":"italic_en","text":"The external jugular veins of the slain person"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"streamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed with blood:"},{"kind":"text","text":"(Msb, TA: * [and the like is said in the Mgh:]) and"},{"kind":"arabic","text_bw":"$axabotuhu A^anaA","text_ar":"شَخَبْتُهُ اَنَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I made it to stream,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flow"},{"kind":"text","text":"]: the verb being intrans. and trans. (Msb.) And"},{"kind":"arabic","text_bw":"huwa ya$oxubu damFA","text_ar":"هُوَ يَشْخُبُ دَمًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, flows"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"streams"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with blood;"},{"kind":"text","text":"the last word being in the accus. case as a specificative: and"},{"kind":"italic_en","text":"be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, pours forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"makes to flow"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stream"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"blood;"},{"kind":"text","text":"the last word, when this is the meaning, being in the accus. case as an objective complement: but the former is that which is commonly known. (Mgh.) And"},{"kind":"arabic","text_bw":"$axabato yadaAhu Hat~aY maAta","text_ar":"شَخَبَتْ يَدَاهُ حَتَّى مَاتَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His hands flowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamed, with blood, until he died:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"poured forth blood,"},{"kind":"text","text":"&c.]: said, in a trad., of one whose knuckles, or finger-joints, were cut. (TA.) ↓"},{"kind":"arabic","text_bw":"An$xb","text_ar":"انشخب","orth_type":"arrow"},{"kind":"text","text":", also, is said of blood [as meaning (assumed tropical:)"},{"kind":"italic_en","text":"It flowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamed"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"damFA","text_ar":"دَمًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"An$xb","text_ar":"انشخب","orth_type":"arrow"},{"kind":"text","text":", said of a vein, means (assumed tropical:)"},{"kind":"italic_en","text":"It flowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamed, with blood."},{"kind":"text","text":"(S, K, TA.) And it is said in a trad. respecting the"},{"kind":"arabic","text_bw":"HawoD","text_ar":"حَوْض"},{"kind":"text","text":"[or pool (of the Apostle)],"},{"kind":"arabic","text_bw":"ya$oxuabu fiyhi miyzaAbaAni mina Aljan~api","text_ar":"يَشْخَُبُ فِيهِ مِيزَابَانِ مِنَ الجَنَّةِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Two spouts will pour forth into it from Paradise"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"$axabotu All~iqaAHa","text_ar":"شَخَبْتُ اللِّقَاحَ"},{"kind":"italic_en","text":"I milked the milch camels."},{"kind":"text","text":"(A, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"mar~a ya$oxabu fiY","text_ar":"مَرَّ يَشْخَبُ فِى"},{"kind":"arabic","text_bw":"AlA^aroDi","text_ar":"الاَرْضِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed by,"},{"kind":"text","text":"(O,) or"},{"kind":"italic_en","text":"ran,"},{"kind":"text","text":"(El-Fáïk, TA,)"},{"kind":"italic_en","text":"swiftly"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the ground"},{"kind":"text","text":"]. (El-Fáïk, O, TA.)"}],"source_refs":["Mgh","TA","S","O","CK"]}]}}