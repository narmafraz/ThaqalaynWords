{"lemma":"حُزْمَة","slug":"حُزْمَة","root":"ح.ز.م","root_slug":"ح-ز-م","root_link":"/words/roots/ح-ز-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n7871","n7878","n7879","n7881"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D8%B2%D9%92%D9%85%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"bundle"},{"pos":"noun","gloss":"armful"},{"pos":"noun","gloss":"package, packet, parcel, bale"},{"pos":"noun","gloss":"sheaf"},{"pos":"noun","gloss":"wisp"}]},"etymology":{"source":"wiktextract","text":"Compare حَزَمَ (ḥazama, “to tie up, to bundle”)."},"ipa":["/ħuz.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7871","headword_ar":"حَزَمَهُ","root":"Hzm","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HazomN","text_ar":"حَزْمٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He bound it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tied it;"},{"kind":"text","text":"(S, K;) namely, a thing: (S:) or"},{"kind":"italic_en","text":"he made it a"},{"kind":"arabic","text_bw":"Huzomap","text_ar":"حُزْمَة"},{"kind":"text","text":"[q. v.]. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"Hazama Ald~aAb~apa","text_ar":"حَزَمَ الدَّابَّةَ"},{"kind":"text","text":"(S, Msb) or"},{"kind":"arabic","text_bw":"Alfarasa","text_ar":"الفَرَسَ"},{"kind":"text","text":", (K,) aor. as above, (Msb,) and so the inf. n., (Mgh, Msb,)"},{"kind":"italic_en","text":"He bound the beast"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"horse"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"HizaAm","text_ar":"حِزَام"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"girth"},{"kind":"text","text":"]; (T, * S, * Mgh, * Msb;) and"},{"kind":"italic_en","text":"with a rope;"},{"kind":"text","text":"(T, TA;) or"},{"kind":"italic_en","text":"he bound the"},{"kind":"arabic","text_bw":"HizaAm","text_ar":"حِزَام"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"beast"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"horse."},{"kind":"text","text":"(K.) ―         -b3-  [And hence,]"},{"kind":"arabic","text_bw":"Hazama","text_ar":"حَزَمَ"},{"kind":"arabic","text_bw":"raA^oyahu","text_ar":"رَاْيَهُ"},{"kind":"text","text":", [aor. and] inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He made his judgment, opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsel, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound."},{"kind":"text","text":"(Msb.) It is said in a prov.,"},{"kind":"arabic","text_bw":"qado A^aHozimu lawo A^aEozimu","text_ar":"قَدْ اَحْزِمُ لَوْ اَعْزِمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Certainly I make firm"},{"kind":"text","text":"my determination"},{"kind":"italic_en","text":"if I determine"},{"kind":"text","text":"upon doing a thing]; meaning I know"},{"kind":"arabic","text_bw":"AlHazom","text_ar":"الحَزْم"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"prudence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discretion,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"precaution"},{"kind":"text","text":"], though I do not practise it. (IB, TA. [See also Freytag's Arab. Prov. ii. 262.])       -A2-  [Hence, also,]"},{"kind":"arabic","text_bw":"Hazuma","text_ar":"حَزُمَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HazaAmapN","text_ar":"حَزَامَةٌ"},{"kind":"text","text":"(S, K *) and"},{"kind":"arabic","text_bw":"HuzuwmapN","text_ar":"حُزُومَةٌ"},{"kind":"text","text":", (K, * TK,) but this latter is not of established authority, (TA,) and"},{"kind":"arabic","text_bw":"HazomN","text_ar":"حَزْمٌ"},{"kind":"text","text":", (CK, * TK, [or this is probably a simple subst. in relation to"},{"kind":"arabic","text_bw":"Hazuma","text_ar":"حَزُمَ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"He possessed the quality of"},{"kind":"arabic","text_bw":"Hazom","text_ar":"حَزْم"},{"kind":"text","text":"[explained below, as meaning"},{"kind":"italic_en","text":"prudence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discretion,"},{"kind":"text","text":"&c.]. (S, K.)       -A3-"},{"kind":"arabic","text_bw":"Hazima","text_ar":"حَزِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HazamN","text_ar":"حَزَمٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, choked,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"he had what resembled a choking,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"in his chest."},{"kind":"text","text":"(S, K.)"}],"source_refs":["S","Msb","K","Mgh","TA"]},{"entry_id":"n7878","headword_ar":"حَزْمَةٌ","root":"Hzm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HazomN","text_ar":"حَزْمٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7879","headword_ar":"حُزْمَةٌ","root":"Hzm","body":[{"kind":"italic_en","text":"A bundle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is bound round,"},{"kind":"text","text":"(K, TA,) of firewood &c.: (S:) pl."},{"kind":"arabic","text_bw":"HuzamN","text_ar":"حُزَمٌ"},{"kind":"text","text":". (Msb, TA.)"}],"source_refs":["K","TA","S"]},{"entry_id":"n7881","headword_ar":"حُزُمَّةٌ","root":"Hzm","body":[{"kind":"italic_en","text":"Short;"},{"kind":"text","text":"(K;) applied to a man. (TA.)"}],"source_refs":[]}]}}