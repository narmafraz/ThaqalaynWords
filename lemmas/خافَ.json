{"lemma":"خافَ","slug":"خافَ","root":"خ.#.ف","root_slug":"خ-_-ف","root_link":"/words/roots/خ-_-ف","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خِفْتَ","in_corpus":true,"count":16,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خِفْتِ","in_corpus":true,"count":33,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خِفْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خِفْتُم","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خِفْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خافَ","in_corpus":true,"count":54,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خافَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خافا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خافَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خافُوا","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خِفْنَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخَف","in_corpus":true,"count":14,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَخاف","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخافِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخافِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخافا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخافانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخافُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخافُونَ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخَفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخَف","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخاف","in_corpus":true,"count":66,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخَف","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخاف","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخافا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخافانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخافا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخافانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخافُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخافُونَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخَفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خِفْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خِفْتُ","in_corpus":true,"count":12,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخاف","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخاف","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":265,"cross_references":{"qac":{"found":true,"lemma_key":"خافَ","root":"خوف","pos":"V","occurrence_count":83},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n11152","n11710","n11714"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fear, to be afraid of","examples":[{"text":"قُلْتُ : إِنِّي أَخَافُ أَنْ يَكُونَ اِنْصِرَافًا لَيْسَ بَعْدَهُ عَوْد","english":"I said, \"I am afraid that it'll be a departure [that] there is no, after it, a return\"."}]},{"pos":"verb","gloss":"to feel free or be scared for"}]},"etymology":null,"ipa":["/xaː.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11152","headword_ar":"خَافٍ","root":"xfY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xafiY~N","text_ar":"خَفِىٌّ"},{"kind":"text","text":": ―         -b2-  and see also"},{"kind":"arabic","text_bw":"xafFA","text_ar":"خَفًا"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"AlxaAfiY","text_ar":"الخَافِى"},{"kind":"italic_en","text":"The jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii;"},{"kind":"text","text":"(As, Lh, JK, S, K;) because they conceal themselves from the eyes [of men]; (TA;) as also ↓"},{"kind":"arabic","text_bw":"AlxaAfiyaA='u","text_ar":"الخَافِيَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"(JK, K) and ↓"},{"kind":"arabic","text_bw":"AxaAfiyapu","text_ar":"اخَافِيَةُ","orth_type":"arrow"},{"kind":"text","text":": (K:) or this last signifies"},{"kind":"italic_en","text":"what conceals itself in the body, of the jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii:"},{"kind":"text","text":"(Ibn-Menádhir, S:) the pl. (of the first, Lh, JK, [and of the second and third also accord. to analogy,]) is"},{"kind":"arabic","text_bw":"xawaAfK","text_ar":"خَوَافٍ"},{"kind":"text","text":"; (Lh, JK, K;) [and of the first,"},{"kind":"arabic","text_bw":"xaAfuwna","text_ar":"خَافُونَ"},{"kind":"text","text":"also, like"},{"kind":"arabic","text_bw":"qaADuwna","text_ar":"قَاضُونَ"},{"kind":"text","text":"; for] the bare piece of ground amid herbage is said, in a trad., to be"},{"kind":"arabic","text_bw":"muSal~aY","text_ar":"مُصَلَّى"},{"kind":"arabic","text_bw":"AlxaAfiyna","text_ar":"الخَافِينَ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"The praying-place"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii."},{"kind":"text","text":"(TA.) The first ("},{"kind":"arabic","text_bw":"AlxaAfiY","text_ar":"الخَافِى"},{"kind":"text","text":") also signifies"},{"kind":"italic_en","text":"Mankind;"},{"kind":"text","text":"thus bearing two contr. [or rather opposite] meanings. (TA.) And one says,"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^adoriY A^aY~u xaAfiyapa","text_ar":"مَا اَدْرِى اَىُّ خَافِيَةَ","orth_type":"arrow"},{"kind":"text","text":", (K and TA voce"},{"kind":"arabic","text_bw":"xaAlifap","text_ar":"خَالِفَة"},{"kind":"text","text":", q. v.,) or ↓"},{"kind":"arabic","text_bw":"xaAfiyapK","text_ar":"خَافِيَةٍ","orth_type":"arrow"},{"kind":"text","text":", (CK ibid.,)"},{"kind":"italic_en","text":"I know not what one of mankind he is."},{"kind":"text","text":"(K ibid.) ―         -b4-"},{"kind":"arabic","text_bw":"A^aroDN xaAfiyapN","text_ar":"اَرْضٌ خَافِيَةٌ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"A^aroDu xaAfiyapK","text_ar":"اَرْضُ خَافِيَةٍ","orth_type":"arrow"},{"kind":"text","text":", the latter word in the former case being an epithet, fem. of"},{"kind":"arabic","text_bw":"xaAfK","text_ar":"خَافٍ"},{"kind":"text","text":", and in the latter case a subst., or an epithet in which the quality of a subst is predominant,]"},{"kind":"italic_en","text":"A land in which are jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii."},{"kind":"text","text":"(K.) ―         -b5-"},{"kind":"arabic","text_bw":"xaAfiY AlguraAbi","text_ar":"خَافِى الغُرَابِ"},{"kind":"text","text":": see the last sentence but one in the next paragraph."}],"source_refs":["JK","K"]},{"entry_id":"n11710","headword_ar":"خَافَ","root":"xwf","body":[{"kind":"text","text":", (S, Msb, K, &c.,) originally"},{"kind":"arabic","text_bw":"xawifa","text_ar":"خَوِفَ"},{"kind":"text","text":", (Lth, L, &c.,) first pers."},{"kind":"arabic","text_bw":"xifotu","text_ar":"خِفْتُ"},{"kind":"text","text":", (TA,) aor."},{"kind":"arabic","text_bw":"yaxaAfu","text_ar":"يَخَافُ"},{"kind":"text","text":", (S, K, &c.,) originally"},{"kind":"arabic","text_bw":"yaxowafu","text_ar":"يَخْوَفُ"},{"kind":"text","text":", (L,) imperative"},{"kind":"arabic","text_bw":"xafo","text_ar":"خَفْ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"xawofN","text_ar":"خَوْفٌ"},{"kind":"text","text":"(S, Msb, K, &c.) and ↓"},{"kind":"arabic","text_bw":"xiyfN","text_ar":"خِيفٌ","orth_type":"arrow"},{"kind":"text","text":", [originally"},{"kind":"arabic","text_bw":"xiwofN","text_ar":"خِوْفٌ"},{"kind":"text","text":",] (Lh, TA,) erroneously written in the K with fet-h [to the"},{"kind":"arabic","text_bw":"x","text_ar":"خ"},{"kind":"text","text":"], but some say that this is a simple subst., not an inf. n., (TA,) and ↓"},{"kind":"arabic","text_bw":"xiyfapN","text_ar":"خِيفَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, S, Msb, K, &c.,) originally"},{"kind":"arabic","text_bw":"xiwofapN","text_ar":"خِوْفَةٌ"},{"kind":"text","text":", (K,) but some say that this also is a simple subst., not an inf. n., (TA,) and [therefore] its pl. is"},{"kind":"arabic","text_bw":"xiyfN","text_ar":"خِيفٌ"},{"kind":"text","text":", (Lh, JK, S, and so in the CK,) in [some of] the copies of the K erroneously written"},{"kind":"arabic","text_bw":"xiyafN","text_ar":"خِيَفٌ"},{"kind":"text","text":", (TA,) or this [as well as the next preceding] may be an inf. n., for some few inf. ns. have pls., (ISd, TA,) and"},{"kind":"arabic","text_bw":"maxaAfapN","text_ar":"مَخَافَةٌ"},{"kind":"text","text":", (S, Msb, K, &c.,) originally"},{"kind":"arabic","text_bw":"maxowafapN","text_ar":"مَخْوَفَةٌ"},{"kind":"text","text":", for which last, the first of these inf. ns. is used by a poet, and therefore made fem., (TA,)"},{"kind":"italic_en","text":"He feared; he was afraid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frightened"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"faziEa","text_ar":"فَزِعَ"},{"kind":"text","text":". (K.) It is also trans.: (Msb:) you say,"},{"kind":"arabic","text_bw":"xaAfahu","text_ar":"خَافَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"txw~fhu","text_ar":"تخوّفهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was afraid of, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; (Msb, TA;) both signifying the same: (TA:) [and so"},{"kind":"arabic","text_bw":"xaAfa minohu","text_ar":"خَافَ مِنْهُ"},{"kind":"text","text":"; or this may mean"},{"kind":"italic_en","text":"he feared what might happen to him from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Ealayohi $ayoy^FA","text_ar":"عَلَيْهِ شَيْيًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"txw~f","text_ar":"تخوّف","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"xaAfahu","text_ar":"خَافَهُ"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"xaAfa Ealayohi","text_ar":"خَافَ عَلَيْهِ"},{"kind":"arabic","text_bw":"$ayoy^FA","text_ar":"شَيْيًا"},{"kind":"italic_en","text":"He feared for him a thing"},{"kind":"text","text":"]: (S, K:) and"},{"kind":"arabic","text_bw":"xaAafahu EalaY maAlihi","text_ar":"خَاَفَهُ عَلَى مَالِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"txw~fhu","text_ar":"تخوّفهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, for his property"},{"kind":"text","text":"]. (Mgh.) ―         -b2-  [Hence,] it is also used in the sense of"},{"kind":"arabic","text_bw":"Zan~a","text_ar":"ظَنَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He thought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opined"},{"kind":"text","text":"]: and in this case, the Arabs sometimes use it in the same manner as a verb signifying an oath, and give it the same kind of complement; as in an ex. cited voce"},{"kind":"arabic","text_bw":"darida","text_ar":"دَرِدَ"},{"kind":"text","text":"[q. v.]. (S in art."},{"kind":"arabic","text_bw":"drd","text_ar":"درد"},{"kind":"text","text":".) And"},{"kind":"italic_en","text":"He knew."},{"kind":"text","text":"(Lh, Kr, K.) Hence,"},{"kind":"arabic","text_bw":"waA_ini A@moraA^apN","text_ar":"وَاـِنِ ا@مْرَاَةٌ"},{"kind":"arabic","text_bw":"xaAfato mino baEolihaA nu$uwzFA","text_ar":"خَافَتْ مِنْ بَعْلِهَا نُشُوزًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And if a woman know"},{"kind":"text","text":"that there is,"},{"kind":"italic_en","text":"on the part of her husband, injurious treatment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unkindness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estrangement"},{"kind":"text","text":"], (K,) in the Kur [iv. 127]. (TA.) And hence also,"},{"kind":"arabic","text_bw":"famano xaAfa mino muwSK janafFA","text_ar":"فَمَنْ خَافَ مِنْ مُوصٍ جَنَفًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And he who knoweth"},{"kind":"text","text":"that there is,"},{"kind":"italic_en","text":"on the part of the testator, an inclining to a wrong course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a declining from the right course,"},{"kind":"text","text":"&c.], (K,) in the Kur [ii. 178]; thus explained by Lh. (TA.)       -A2-"},{"kind":"arabic","text_bw":"xaAfahu","text_ar":"خَافَهُ"},{"kind":"text","text":", (S,) first pers."},{"kind":"arabic","text_bw":"xufotuhu","text_ar":"خُفْتُهُ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yaxuwfuhu","text_ar":"يَخُوفُهُ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He exceeded him in fear."},{"kind":"text","text":"(S, K. *) You say,"},{"kind":"arabic","text_bw":"faxaAfahu","text_ar":"فَخَافَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAwafahu","text_ar":"خَاوَفَهُ","orth_type":"arrow"},{"kind":"text","text":", (S,) inf. n. of the former"},{"kind":"arabic","text_bw":"muxaAwafahu","text_ar":"مُخَاوَفَهُ"},{"kind":"text","text":", (TA,) i. e. ["},{"kind":"italic_en","text":"He vied with him to see which of them would exceed the other in fear, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he exceeded him in fear."},{"kind":"text","text":"(S.)"}],"source_refs":["TA","L","S","Lh","K","ISd","Msb"]},{"entry_id":"n11714","headword_ar":"خَافٌ","root":"xwf","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"very fearful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"timorous;"},{"kind":"text","text":"(S, K;) [and so, in the present day, ↓"},{"kind":"arabic","text_bw":"xaw~aAfN","text_ar":"خَوَّافٌ","orth_type":"arrow"},{"kind":"text","text":"; the former originally] of the measure"},{"kind":"arabic","text_bw":"faEilN","text_ar":"فَعِلٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"fariqN","text_ar":"فَرِقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faziEN","text_ar":"فَزِعٌ"},{"kind":"text","text":"; and similar to"},{"kind":"arabic","text_bw":"SaAtN","text_ar":"صَاتٌ"},{"kind":"text","text":", meaning a man “ having a strong, or loud, voice: ” (S:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAy^ifN","text_ar":"خَايِفٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) accord. to Kh, it may be [originally"},{"kind":"arabic","text_bw":"xaAwifN","text_ar":"خَاوِفٌ"},{"kind":"text","text":",] of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":", having the medial radical rejected; or ["},{"kind":"arabic","text_bw":"xawofN","text_ar":"خَوْفٌ"},{"kind":"text","text":",] of the measure"},{"kind":"arabic","text_bw":"faEolN","text_ar":"فَعْلٌ"},{"kind":"text","text":"; and in either case, the dim. is [↓"},{"kind":"arabic","text_bw":"xuwayofN","text_ar":"خُوَيْفٌ","orth_type":"arrow"},{"kind":"text","text":",] with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":": so says Sb. (TA.)"}],"source_refs":["S","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D9%81/","headword_ar":"خافَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=30189#cdb7be","body_html":"<span>خافَ يَخافُ خَوْفاً وخَيْفاً ومَخافةً وخِيفةً، بالكسر، وأصْلُها خِوْفَةٌ، وجَمْعُها خِيَفٌ: فَزِعَ، وهم خُوَّفٌ وخِيَّفٌ، كسُكَّرٍ وقِنَّبٍ، وخَوْفٌ، أو هذه: اسمٌ للجَمْعِ.</span><br><span>والخَوْفُ أيضاً: القَتْلُ، قيل: ومنه: {ولَنَبْلُوَنَّكُمْ بشيءٍ من الخَوْفِ} ،</span><br><span>وـ: القِتالُ،</span><br><span>ومنه: {فإذا جاءَ الخَوْفُ} وـ: العِلْمُ،</span><br><span>ومنه: {وإن امرأةٌ خافَتْ من بَعْلِها نُشُوزاً أو إِعْراضاً} و {فَمَن خافَ من مُوصٍ جَنَفاً} ، وأديمٌ أحمرُ يُقَدُّ أمْثالَ السُّيورِ، لغةٌ في الحَوْفِ بالمهملةِ.</span><br><span>ورجلٌ خافٌ: شديدُ الخَوْفِ.</span><br><span>والخافةُ: جُبَّةٌ من أدَمٍ يَلْبَسُها العَسَّالُ، أو خَريطةٌ يُشْتارُ فيها العَسَلُ، أو سُفْرَةٌ كالخَريطَةِ مُصَعَّدَةٌ، قد رُفِعَ رأسُها للعَسَلِ.</span><br><span>وخُفْتُه، كقُلْتُه: غَلَبْتُهُ بالخَوْفِ.</span><br><span>وطريقٌ مَخُوفٌ: يُخافُ فيه،</span><br><span>ووَجَعٌ مُخِيفٌ، لأنَّ الطريقَ لا تُخيفُ، وإنما يُخيفُ قاطِعُها.</span><br><span>والمُخيفُ: الأسَدُ.</span><br><span>وحائطٌ مُخيفٌ: إذا خِفْتَ أنْ يَقَعَ عليك.</span><br><span>وخَوَّفَه: أخافَهُ، أو صَيَّرَهُ بِحالٍ يَخَافُهُ الناسُ.</span><br><span>وتَخَوَّفَ عليه شَيْئاً: خافَهُ،</span><br><span>وـ الشيءَ: تَنَقَّصَهُ، ومنه: {أو يَأخُذَهُمْ على تَخَوُّفٍ} .</span><br><span>وخَوَافٌ، كسَحابٍ: ناحِيَةٌ بِنَيْسابورَ.</span><br><span>وسَمِعَ خَوافَهُم: ضَجَّتَهُم.</span>"}]}}