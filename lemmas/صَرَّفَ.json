{"lemma":"صَرَّفَ","slug":"صَرَّفَ","root":"ص.ر.ف","root_slug":"ص-ر-ف","root_link":"/words/roots/ص-ر-ف","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"صَرَّفْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"صَرَّفْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"صَرَّفْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"صَرَّفْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"صَرَّفْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"صَرَّفَ","in_corpus":true,"count":16,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"صَرَّفَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"صَرَّفا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"صَرَّفَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"صَرَّفُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"صَرَّفْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُصَرِّف","in_corpus":true,"count":5,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُصَرِّفِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُصَرِّفِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُصَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُصَرِّفا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُصَرِّفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُصَرِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُصَرِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُصَرِّف","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُصَرِّف","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُصَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُصَرِّفا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُصَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُصَرِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُصَرِّفُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُصَرِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصَرِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُصَرِّف","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصَرِّف","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَرَّفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَرَّفْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":62,"cross_references":{"qac":{"found":true,"lemma_key":"صَرَّفَ","root":"صرف","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":19},"lanes":{"found":true,"entry_ids":["n24223","n24224"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%B1%D9%8E%D9%91%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to turn"},{"pos":"verb","gloss":"to divert, to turn away, to avert"},{"pos":"verb","gloss":"to dismiss, to send away"},{"pos":"verb","gloss":"to inflect (a noun) with tanween"},{"pos":"verb","gloss":"to change (money)"},{"pos":"verb","gloss":"to spend (money, time)"},{"pos":"verb","gloss":"to embellish (a speech)"},{"pos":"verb","gloss":"to deliver, distribute"},{"pos":"verb","gloss":"to explain","examples":[{"text":"اُنْظُرْ كَيْفَ نُصَرِّفُ الْآيَاتِ لَعَلَّهُمْ يَفْقَهُونَ"}]},{"pos":"verb","gloss":"to inflect"},{"pos":"verb","gloss":"to conduct, to do","examples":[{"text":"وسنستمر في تصريف الاعمال بشكل عادي.","english":"We will continue to conduct business as normal."}]},{"pos":"verb","gloss":"to drink (wine) unmixed"},{"pos":"verb","gloss":"to creak, to grate"},{"pos":"noun","gloss":"verbal noun of صَرَفَ (ṣarafa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"diverting, averting, turning away"},{"pos":"noun","gloss":"expenditure, expense"},{"pos":"noun","gloss":"delivery, distribution"},{"pos":"noun","gloss":"morphology, the breaking down and manipulating of roots","examples":[{"text":"الصَّرفُ، ويُقال له التصريف، وهو لغة: التغيير، ومن تصريف الرياح، أي: تغييرها^([١]). واصطلاحاً بالمعنى العَمَليّ: تحويل الأصل الواحد إلى أمثلة مختلفة، لمعان مقصودة، لا تحصل إلّا بها، كاسمي الفاعل والمفعول، واسم التفضيل، والتثنية والجمع، إلى غير ذلك^([٢]). وبالمعنى العِلْميّ^([٣]): علم بأصول يُعْرف بها أحوالُ أبنية الكلمة، التي ليست بإعراب ولا بناء^((١)).","english":"Introduction"}]},{"pos":"noun","gloss":"inflection of nouns with tanwīn","tags":["form-of"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24223","headword_ar":"صَرْفٌ","root":"Srf","body":[{"kind":"text","text":"[as an inf. n.: see 1]. ―         -b2-  Used as a subst., The"},{"kind":"italic_en","text":"evil accidents, mishaps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calamities,"},{"kind":"text","text":"of time, or fortune; [thus expl. as having a pl. signification;]"},{"kind":"arabic","text_bw":"Sarofu Ald~ahori","text_ar":"صَرْفُ الدَّهْرِ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"HadavaAnuhu","text_ar":"حَدَثَانُهُ"},{"kind":"text","text":", (S, M, O, K,) and"},{"kind":"arabic","text_bw":"nawaAy^ibuhu","text_ar":"نَوَايِبُهُ"},{"kind":"text","text":", (S, O, K,) or"},{"kind":"arabic","text_bw":"HawaAdivuhu","text_ar":"حَوَادِثُهُ"},{"kind":"text","text":"; (Msb;) because it [i. e. time, or fortune,] turns things from their way, or course: (M:) [but it seems to be more properly rendered the"},{"kind":"italic_en","text":"shifting"},{"kind":"text","text":"of fortune, or its"},{"kind":"italic_en","text":"shifting about;"},{"kind":"text","text":"and to be an inf. n. sometimes used as a simple subst., and therefore having a pl., for] its pl. is"},{"kind":"arabic","text_bw":"SuruwfN","text_ar":"صُرُوفٌ"},{"kind":"text","text":". (M, Msb.) In the phrase"},{"kind":"arabic","text_bw":"qado $aHaTato Sarofu nawaAhaA","text_ar":"قَدْ شَحَطَتْ صَرْفُ نَوَاهَا"},{"kind":"text","text":", in a verse of Sakhr-el-Ghei, [ISd says,] he has made it fem. because of its dependance upon"},{"kind":"arabic","text_bw":"Aln~awaY","text_ar":"النَّوَى"},{"kind":"text","text":"[which is fem.; as though the meaning were"},{"kind":"italic_en","text":"The afflictions that are the consequence of the course taken by her in her journey have exceeded the bounds of moderation"},{"kind":"text","text":"]: (M:) [or it is here made fem. because having the signification of a broken pl., which is fem.:] or the meaning is,"},{"kind":"arabic","text_bw":"qado baEudato","text_ar":"قَدْ بَعُدَتْ"},{"kind":"arabic","text_bw":"taSar~ufu wajohihaA Al~a*iY A^axa*ato fiyhi","text_ar":"تَصَرُّفُ وَجْهِهَا الَّذِى اَخَذَتْ فِيهِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the shiftingabout of her course that she has taken has become far-extending;"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"text","text":"being thus used as an inf. n.; for the Arabs sometimes make the inf. n. fem., saying"},{"kind":"arabic","text_bw":"A^awojaEatoniY Darobuka","text_ar":"اَوْجَعَتْنِى ضَرْبُكَ"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"A^awojaEaniY","text_ar":"اَوْجَعَنِى"},{"kind":"arabic","text_bw":"Darobuka","text_ar":"ضَرْبُكَ"},{"kind":"text","text":"; (see EM p. 157;) and this I think the most preferable explanation]. (Skr in his Expos. of the Poems of the Hudhalees, p. 14 of the vol. edited by Kosegarten.) ―         -b3-  Also"},{"kind":"italic_en","text":"Repentance."},{"kind":"text","text":"(S, M, O, Msb, K.) [See a phrase below, in which this and other meanings are assigned to it.] ―         -b4-  And (tropical:)"},{"kind":"italic_en","text":"Art, artifice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning."},{"kind":"text","text":"(Yoo, S, M, O, K, TA.) Hence, in the Kur [xxv. 20],"},{"kind":"arabic","text_bw":"famaA=","text_ar":"فَمَا="},{"kind":"arabic","text_bw":"yasotaTiyEuwna SarofFA walaA naSorFA","text_ar":"يَسْتَطِيعُونَ صَرْفًا وَلَا نَصْرًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"And they are not able to put in practice art"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"artifice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning, nor aid"},{"kind":"text","text":"]: (S, TA:) or this means"},{"kind":"italic_en","text":"and they are not able to avert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repel,"},{"kind":"text","text":"from themselves punishment, (O, K, TA,)"},{"kind":"italic_en","text":"nor to aid"},{"kind":"text","text":"themselves. (O, TA.) ―         -b5-  And"},{"kind":"italic_en","text":"Excellence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superiority,"},{"kind":"text","text":"of a dirhem, (S, M, Mgh, O, Msb, K,) and of a deenár, (M,) over another, (S, M, &c.,)"},{"kind":"italic_en","text":"in goodness,"},{"kind":"text","text":"(S, Mgh, Msb,) or"},{"kind":"italic_en","text":"in value;"},{"kind":"text","text":"(M, Mgh, O, K;) as in the saying,"},{"kind":"arabic","text_bw":"bayona Ald~irohamayoni SarofN","text_ar":"بَيْنَ الدِّرْهَمَيْنِ صَرْفٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Between the two dirhems is a difference of excellence"},{"kind":"text","text":"], because of the [superior] goodness of the silver of one of them: (S:) and in like manner, of speech; (O, K;) as in the saying"},{"kind":"arabic","text_bw":"fulaAnN laA yaEorifu Sarofa AlkalaAmi","text_ar":"فُلَانٌ لَا يَعْرِفُ صَرْفَ الكَلَامِ"},{"kind":"italic_en","text":"Such a one knows not the excellence of speech"},{"kind":"text","text":"over other speech: (O:) and [in like manner] one says,"},{"kind":"arabic","text_bw":"lih`*aA EalaY h`*aA SarofN","text_ar":"لِهٰذَا عَلَى هٰذَا صَرْفٌ"},{"kind":"italic_en","text":"There is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pertains, to this, an excess,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"an excellence, over this;"},{"kind":"text","text":"for when one is judged to excel, it, or he, is turned aside from its, or his, likes, or fellows. (O, K. *) ―         -b6-  And The"},{"kind":"italic_en","text":"night;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"day:"},{"kind":"text","text":"(K:) [because of their interchanging:]"},{"kind":"arabic","text_bw":"AlS~arofaAni","text_ar":"الصَّرْفَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the night and the day;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"AlS~irofaAni","text_ar":"الصِّرْفَانِ","orth_type":"arrow"},{"kind":"text","text":"; (K;) the latter accord. to Ibn-'Abbád; (O;) like"},{"kind":"arabic","text_bw":"AlS~iroEaAni","text_ar":"الصِّرْعَانِ"},{"kind":"text","text":", with kesr also [as well as with fet-h]. (TA.) ―         -b7-  In the saying (S, M, O, Msb) of the Arabs, (M,) or of the Prophet, (O, Msb,) in a certain trad., (K,)"},{"kind":"arabic","text_bw":"laA yuqobalu minohu SarofN walaA EadolN","text_ar":"لَا يُقْبَلُ مِنْهُ صَرْفٌ وَلَا عَدْلٌ"},{"kind":"page_break","n":1682},{"kind":"text","text":"["},{"kind":"italic_en","text":"Neither"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"italic_en","text":"nor"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"italic_en","text":"shall be accepted from him"},{"kind":"text","text":"], (S, M, * O, Msb, *) by"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"text","text":"is meant"},{"kind":"italic_en","text":"repentance;"},{"kind":"text","text":"(S, M, O, Msb, K;) and by"},{"kind":"arabic","text_bw":"Eadol","text_ar":"عَدْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"ransom:"},{"kind":"text","text":"(M, Msb, K:) or by the former,"},{"kind":"italic_en","text":"art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"artifice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning;"},{"kind":"text","text":"(Yoo, S, M, O, K;) and by the latter,"},{"kind":"italic_en","text":"ransom:"},{"kind":"text","text":"(M:) or by the former,"},{"kind":"italic_en","text":"acquisition of gain;"},{"kind":"text","text":"and by the latter,"},{"kind":"italic_en","text":"ransom:"},{"kind":"text","text":"(K:) or by the former,"},{"kind":"italic_en","text":"a supererogatory act;"},{"kind":"text","text":"(A'Obeyd, M, O, K;) and by the latter,"},{"kind":"italic_en","text":"an obligatory act:"},{"kind":"text","text":"(A'Obeyd, M, K:) or vice versâ: (K:) or by the former,"},{"kind":"italic_en","text":"weight;"},{"kind":"text","text":"and by the latter,"},{"kind":"italic_en","text":"measure:"},{"kind":"text","text":"(M, O, K:) or by the former,"},{"kind":"italic_en","text":"deviation;"},{"kind":"text","text":"and by the latter,"},{"kind":"italic_en","text":"a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"direct, course:"},{"kind":"text","text":"(IAar, M:) or by the former,"},{"kind":"arabic","text_bw":"maA yutaSar~afu fiyhi","text_ar":"مَا يُتَصَرَّفُ فِيهِ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"an evasive artifice"},{"kind":"text","text":"]; and by the latter,"},{"kind":"italic_en","text":"a like:"},{"kind":"text","text":"(Th, M:) or by the former,"},{"kind":"italic_en","text":"value,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"price;"},{"kind":"text","text":"and by the latter,"},{"kind":"italic_en","text":"a like;"},{"kind":"text","text":"the saying originally relating to the bloodwit ("},{"kind":"arabic","text_bw":"Ald~iyap","text_ar":"الدِّيَة"},{"kind":"text","text":"): one says,"},{"kind":"arabic","text_bw":"lamo yaqobaluwA minohumo SarofFA walaA EadolFA","text_ar":"لَمْ يَقْبَلُوا مِنْهُمْ صَرْفًا وَلَا عَدْلًا"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"They did not accept from them a bloodwit, nor did they slay one man for him, of their people, who had been slain;"},{"kind":"text","text":"but they required from them more than that; for the Arabs used [often] to slay two men, and three, for one man; when they slew a man for a man, that was"},{"kind":"arabic","text_bw":"AlEadol","text_ar":"العَدْل"},{"kind":"text","text":"with them; and when they took a bloodwit, having turned from the blood to another thing, that was"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"text","text":", i. e. the value, or price, was"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"text","text":": then the saying was applied in relation to anything, so as to be proverbially used in the case of him who was to render more than was incumbent on him: it has also been said that by"},{"kind":"arabic","text_bw":"Sarof","text_ar":"صَرْف"},{"kind":"text","text":"is meant [in the saying cited above]"},{"kind":"italic_en","text":"something additional,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in excess;"},{"kind":"text","text":"but this is nought. (M.)"}],"source_refs":["S","M","O","K","TA","Mgh","Msb","IAar","Th"]},{"entry_id":"n24224","headword_ar":"صِرْفٌ","root":"Srf","body":[{"kind":"text","text":": see its dual in the next preceding paragraph, near the middle.       -A2-  Also"},{"kind":"italic_en","text":"Pure, unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from admixture;"},{"kind":"text","text":"(S, M, Mgh, O, Msb, K;) applied to wine, (S, M, O, Msb, K,) or beverage, as meaning"},{"kind":"italic_en","text":"unmixed,"},{"kind":"text","text":"(S, M, O, Msb,) and so ↓"},{"kind":"arabic","text_bw":"maSoruwfN","text_ar":"مَصْرُوفٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K,) and to other things, (K,) to blood, and to phlegm, (TA,) and to anything (M, Msb) as meaning"},{"kind":"italic_en","text":"free from turbid foulnesses:"},{"kind":"text","text":"(Mgh, * Msb:) and ↓"},{"kind":"arabic","text_bw":"SariyfN","text_ar":"صَرِيفٌ","orth_type":"arrow"},{"kind":"text","text":"likewise signifies anything"},{"kind":"italic_en","text":"having in it no admixture."},{"kind":"text","text":"(TA.)       -A3-  And"},{"kind":"italic_en","text":"A certain dye,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"a red dye,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"with which the thongs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straps, of sandals are dyed,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"with which the hide is dyed:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a certain red thing with which the hide is tanned"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yudobagu","text_ar":"يُدْبَغُ"},{"kind":"text","text":"[perhaps a mistranscription for"},{"kind":"arabic","text_bw":"yuSobagu","text_ar":"يُصْبَغُ"},{"kind":"text","text":"]). (So in a copy of the M.)"}],"source_refs":["S","M","O","Msb","K","TA"]}]}}