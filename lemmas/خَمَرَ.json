{"lemma":"خَمَرَ","slug":"خَمَرَ","root":"خ.م.ر","root_slug":"خ-م-ر","root_link":"/words/roots/خ-م-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَمَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَمَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَمَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَمَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَمَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَمَرَ","in_corpus":true,"count":38,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَمَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَمَرا","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَمَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَمَرُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَمَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْمُر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْمُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْمُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْمُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْمُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْمُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْمُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْمُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْمُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْمُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْمُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْمُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْمُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْمُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْمُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْمُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْمُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْمُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْمُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَمَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَمَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":51,"cross_references":{"qac":{"found":true,"lemma_key":"خَمَرَ","root":"خمر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n11469"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%85%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cover, to hide, to conceal; to veil, to screen, to shroud","tags":["transitive"]},{"pos":"verb","gloss":"to brew, to ferment, to leaven, to cause to rise chemically"},{"pos":"verb","gloss":"to give or serve wine to","tags":["transitive"]},{"pos":"verb","gloss":"to cover, to hide, to conceal; to enveil, to enshroud"},{"pos":"verb","gloss":"to ferment, to leaven, to cause to rise chemically"},{"pos":"noun","gloss":"verbal noun of خَمَرَ (ḵamara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wine"},{"pos":"noun","gloss":"an intoxicating drink, an alcoholic beverage; liquor, spirits","tags":["broadly"]},{"pos":"noun","gloss":"plural of خِمَار (ḵimār)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11469","headword_ar":"خَمَرَ","root":"xmr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"page_break","n":808},{"kind":"italic_en","text":"veiled, covered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed,"},{"kind":"text","text":"a thing; (K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxomiyrN","text_ar":"تَخْمِيرٌ"},{"kind":"text","text":", (Mgh, Msb,) which also signifies"},{"kind":"italic_en","text":"he covered over"},{"kind":"text","text":"a thing; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"A_ixomaArN","text_ar":"اـِخْمَارٌ"},{"kind":"text","text":". (K.) [Hence,]"},{"kind":"arabic","text_bw":"xamarahaA","text_ar":"خَمَرَهَا"},{"kind":"text","text":"[and app. ↓"},{"kind":"arabic","text_bw":"xm~rhA","text_ar":"خمّرها","orth_type":"arrow"},{"kind":"text","text":"also, for the quasi-pass. is"},{"kind":"arabic","text_bw":"txm~rt","text_ar":"تخمّرت"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"Axtmrt","text_ar":"اختمرت"},{"kind":"text","text":","},{"kind":"italic_en","text":"He veiled her with a muffler;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put on her a"},{"kind":"arabic","text_bw":"ximaAr","text_ar":"خِمَار"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"A_inaA='ahu","text_ar":"اـِنَا=ءَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"wajohahu","text_ar":"وَجْهَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He covered over his vessel,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his face."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"bayotahu","text_ar":"بَيْتَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xm~r","text_ar":"خمّر","orth_type":"arrow"},{"kind":"italic_en","text":"He concealed his house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chamber,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent,"},{"kind":"text","text":"[meaning its interior,]"},{"kind":"italic_en","text":"and ordered it aright."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"AlA^aroDu Ean~iY","text_ar":"الاَرْضُ عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axomaratohu","text_ar":"اَخْمَرَتْهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"min~iY","text_ar":"مِنِّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, concealed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, from me."},{"kind":"text","text":"(K.) And ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He concealed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceived it, in him mind."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"fulaAnN EalaY~a Zin~apF","text_ar":"فُلَانٌ عَلَىَّ ظِنَّةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceived, in his mind a suspicion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an evil opinion, of me."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"xamara $ahaAdatahu","text_ar":"خَمَرَ شَهَادَتَهُ"},{"kind":"text","text":", (S, Msb,) and ↓"},{"kind":"arabic","text_bw":"xm~rhA","text_ar":"خمّرها","orth_type":"arrow"},{"kind":"text","text":", (A, Mgh,) and ↓"},{"kind":"arabic","text_bw":"AxmrhA","text_ar":"اخمرها","orth_type":"arrow"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He concealed his testimony."},{"kind":"text","text":"(S, A, Mgh, Msb, TA.) And"},{"kind":"arabic","text_bw":"Alxamoru taxomuru AlEaqola","text_ar":"الخَمْرُ تَخْمُرُ العَقْلَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Wine veils"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"obscures"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the intellect;"},{"kind":"text","text":"(K;) and so ↓"},{"kind":"arabic","text_bw":"tuxaAmiruhu","text_ar":"تُخَامِرُهُ","orth_type":"arrow"},{"kind":"text","text":", lit."},{"kind":"italic_en","text":"covers it:"},{"kind":"text","text":"(Msb:) or the latter signifies (assumed tropical:)"},{"kind":"italic_en","text":"Infects it;"},{"kind":"text","text":"[as though acting like leaven; and if so, from"},{"kind":"arabic","text_bw":"xamara AlEajiyna","text_ar":"خَمَرَ العَجِينَ"},{"kind":"text","text":", which see in what follows; nearly the same as “ intoxicates, ” which properly signifies “ empoisons, ” or “ infects with poison; ”] syn."},{"kind":"arabic","text_bw":"tuxaAliTuhu","text_ar":"تُخَالِطُهُ"},{"kind":"text","text":". (S, * K. [See"},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"xamira","text_ar":"خَمِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xamarN","text_ar":"خَمَرٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He became concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hidden;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid, himself;"},{"kind":"text","text":"(S, K;)"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"italic_en","text":"from me;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"xAmr","text_ar":"خامر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"muxaAmarapN","text_ar":"مُخَامَرَةٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axmr","text_ar":"اخمر","orth_type":"arrow"},{"kind":"text","text":": (K:) or this last signifies"},{"kind":"italic_en","text":"he concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid, himself in a"},{"kind":"arabic","text_bw":"xamar","text_ar":"خَمَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"covert of trees"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"xamira Ean~iY Alxabaru","text_ar":"خَمِرَ عَنِّى الخَبَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The news,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"story, became concealed from me."},{"kind":"text","text":"(S.) And one says to the hyena,"},{"kind":"arabic","text_bw":"A^um~a EaAmirK","text_ar":"اُمَّ عَامِرٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAmiriY","text_ar":"خَامِرِى","orth_type":"arrow"},{"kind":"italic_en","text":"Hide thyself, O Umm-'Ámir:"},{"kind":"text","text":"(S, K:) which is a prov.: (TA:) and is said to be also a phrase used as a surname of the hyena, in the manner of"},{"kind":"arabic","text_bw":"taA^ab~aTa $ar~FA","text_ar":"تَاَبَّطَ شَرًّا"},{"kind":"text","text":". (Ham p. 242.) And"},{"kind":"arabic","text_bw":"HaDaAjiro A^ataAki maA tuHaA*iro","text_ar":"حَضَاجِرْ اَتَاكِ مَا تُحَاذِرْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAmiriY","text_ar":"خَامِرِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Hide thyself, O hyena: what thou fearest has come to thee"},{"kind":"text","text":"]: thus we have found it: (K:) and this is the reading commonly obtaining accord. to the authors on proverbs: (TA:) but it should properly be"},{"kind":"arabic","text_bw":"xaAmirN","text_ar":"خَامِرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"A^ataAka","text_ar":"اَتَاكَ"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"tuHaA*iryna","text_ar":"تُحَاذِرينَ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"xamarN","text_ar":"خَمَرٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"becoming changed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altered, from a former state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"xamira Al$~aYo'u","text_ar":"خَمِرَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing became changed,"},{"kind":"text","text":"&c. (TK.)       -A3-"},{"kind":"arabic","text_bw":"xamara AlEajiyna","text_ar":"خَمَرَ العَجِينَ"},{"kind":"text","text":", (Ks, S, A, Msb, K,) aor."},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (S, Msb, K,) ["},{"kind":"italic_en","text":"He leavened the dough;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"text","text":", (Ks, A,) or"},{"kind":"arabic","text_bw":"xamiyr","text_ar":"خَمِير"},{"kind":"text","text":", (S, A, Msb,)"},{"kind":"italic_en","text":"into the dough;"},{"kind":"text","text":"(Ks, S, A, Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"xm~rhu","text_ar":"خمّرهُ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"he left the dough until it became good"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mature"},{"kind":"text","text":"]; (K;) and in like manner, accord. to the K,"},{"kind":"arabic","text_bw":"AlT~iyna","text_ar":"الطِّينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the clay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mud"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faTara","text_ar":"فَطَرَ"},{"kind":"text","text":"]: or, as in other lexicons,"},{"kind":"arabic","text_bw":"AlT~iyba","text_ar":"الطِّيبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the perfume"},{"kind":"text","text":"]; (TA;) and the like; as also ↓"},{"kind":"arabic","text_bw":"xm~rhu","text_ar":"خمّرهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxomiyrN","text_ar":"تَخْمِيرٌ"},{"kind":"text","text":", in relation to any of these things; and ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"in relation to the first [and probably to the others also]: (K:) and"},{"kind":"arabic","text_bw":"xamara Aln~abiy*a","text_ar":"خَمَرَ النَّبِيذَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he fermented the beverage called"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"he put"},{"kind":"arabic","text_bw":"xumorap","text_ar":"خُمْرَة"},{"kind":"italic_en","text":"into the"},{"kind":"arabic","text_bw":"nby*","text_ar":"نبيذ"},{"kind":"text","text":". (A.) [Mtr says, in the Mgh,"},{"kind":"arabic","text_bw":"AlEaSiyra","text_ar":"العَصِيرَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xam~ara","text_ar":"خَمَّرَ","orth_type":"arrow"},{"kind":"text","text":"I have not found, nor ↓"},{"kind":"arabic","text_bw":"txm~r","text_ar":"تخمّر","orth_type":"arrow"},{"kind":"text","text":"as its quasi-pass.] ―         -b2-"},{"kind":"arabic","text_bw":"xamarahu","text_ar":"خَمَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axmrhu","text_ar":"اخمرهُ","orth_type":"arrow"},{"kind":"text","text":"; (Mgh;)"},{"kind":"italic_en","text":"He gave him"},{"kind":"text","text":"(namely, a man, and a beast, such as a horse and the like, TA)"},{"kind":"italic_en","text":"wine"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xamor","text_ar":"خَمْر"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to drink."},{"kind":"text","text":"(K, * Mgh, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xumira","text_ar":"خُمِرَ"},{"kind":"text","text":", (Mgh, TA,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He suffered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was affected with,"},{"kind":"arabic","text_bw":"xumaAr","text_ar":"خُمَار"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the remains of intoxication"},{"kind":"text","text":"]. (Mgh, TA.) [See also 5.]       -A4-"},{"kind":"arabic","text_bw":"xamarahu","text_ar":"خَمَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (AA, S,) inf. n."},{"kind":"arabic","text_bw":"xamorN","text_ar":"خَمْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was ashamed for himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was bashful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy, with respect to him; was abashed at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy of him."},{"kind":"text","text":"(AA, S, K. *)"}],"source_refs":["TA","K","Mgh","Msb","S","A","Ks","AA"]}]}}