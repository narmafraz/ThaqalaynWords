nt_3mp","form":"يَبُوؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبُوؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبُؤْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بُؤْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بُؤْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبُوء","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبُوء","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":true,"lemma_key":"باءَ","root":"بوأ","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to return, to come back"},{"pos":"verb","gloss":"to bring back"},{"pos":"noun","gloss":"ba’, name of the second letter of the Arabic alphabet (ب (b))."}]},"etymology":{"source":"wiktextract","text":"Related to Hebrew בָּא (bá, “to come”), Phoenician 𐤁𐤀 (bʾ), Ge'ez ቦአ (boʾä, “to enter”)."},"ipa":["/baː.ʔa/","/baːʔ/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D8%A7%D8%A1/","headword_ar":"باء","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61737#ec4219","body_html":"<span class=\"title1\">باء</span><br><span>أصل البَوَاء: مساواة الأجزاء في المكان، خلاف النّبو الذي هو منافاة الأجزاء. يقال:</span><br><span>مكان بَوَاء: إذا لم يكن نابيا بنازله، وبَوَّأْتُ له مكانا: سوّيته فَتَبَوَّأَ، وبَاءَ فلان بدم فلان يَبُوءُ به أي: ساواه، قال تعالى: وَأَوْحَيْنا إِلى مُوسى وَأَخِيهِ أَنْ تَبَوَّءا لِقَوْمِكُما بِمِصْرَ بُيُوتاً [يونس/ 87] ، وَلَقَدْ بَوَّأْنا بَنِي إِسْرائِيلَ مُبَوَّأَ صِدْقٍ</span><br><span>[يونس/ 93] ، تُبَوِّئُ الْمُؤْمِنِينَ مَقاعِدَ لِلْقِتالِ [آل عمران/ 121] ، يَتَبَوَّأُ مِنْها حَيْثُ يَشاءُ [يوسف/ 56] ، وروي أنه: (كان عليه السلام يتبوّأ لبوله كما يتبوّأ لمنزله) وبَوَّأْتُ الرمح: هيأت له مكانا، ثم قصدت الطعن به، وقال عليه السلام: «من كذب عليّ متعمّدا فليتبوأ مقعده من النّار» ، وقال الراعي في صفة إبل:</span><br><span>لها أمرها حتى إذا ما تبوّأت بأخفافها مأوى تبوّأ مضجعا</span><br><span>أي: يتركها الراعي حتى إذا وجدت مكانا موافقا للرعي طلب الراعي لنفسه متبوّأ لمضجعه. ويقال: تَبَوَّأَ فلان كناية عن التزوّج، كما يعبّر عنه بالبناء فيقال: بنى بأهله. ويستعمل البَوَاء في مراعاة التكافؤ في المصاهرة والقصاص، فيقال: فلان بواء لفلان إذا ساواه، وقوله عزّ وجلّ: باءَ بِغَضَبٍ مِنَ اللَّهِ</span><br><span>[الأنفال/ 16] ، أي: حلّ مبّوأ ومعه غضب الله، أي: عقوبته، وقوله: بِغَضَبٍ في موضع حال، كخرج بسيفه، أي: رجع، لا مفعول نحو: مرّ بزيد. واستعمال (باء) تنبيها على أنّ مكانه الموافق يلزمه فيه غضب الله، فكيف غيره من الأمكنة؟ وذلك على حدّ ما ذكر في قوله:</span><br><span>فَبَشِّرْهُمْ بِعَذابٍ أَلِيمٍ [آل عمران/ 21] ، وقوله: إِنِّي أُرِيدُ أَنْ تَبُوءَ بِإِثْمِي وَإِثْمِكَ [المائدة/ 29] أي: تقيم بهذه الحالة. قال:</span><br><span>أنكرت باطلها وبؤت بحقّها</span><br><span>وقول من قال: أقررت بحقها فليس تفسيره بحسب مقتضى اللفظ . والبَاءَة كناية عن الجماع. وحكي عن خلف الأحمر أنه قال في قولهم: حيّاك الله وبيّاك:</span><br><span>إنّ أصله: بوّأك منزلا، فغيّر لازدواج الكلمة، كما غيّر جمع الغداة في قولهم: آتيه الغدايا والعشايا .</span>"}]}}