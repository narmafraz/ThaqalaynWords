e": "past_1mp", "form": "قُمْنا", "in_corpus": true, "count": 2, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "قُمْتُ", "in_corpus": true, "count": 14, "asp": "p", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1ms", "form": "أَقُوم", "in_corpus": true, "count": 17, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَقُوم", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 533, "cross_references": {"qac": {"found": true, "lemma_key": "قامَ", "root": "قوم", "pos": "V", "occurrence_count": 33}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": true, "sense_count": 4}, "lanes": {"found": true, "entry_ids": ["n42885"], "search_url": "https://lanelexicon.com/?s=%D9%82%D8%A7%D9%85%D9%8E"}}, "translations": {"en": "to stand up", "fa": "ایستادن", "ur": "کھڑا ہونا", "tr": "ayaklanmak", "id": "berdiri", "bn": "দাঁড়ানো", "es": "ponerse de pie", "fr": "se lever", "de": "aufstehen", "ru": "вставать", "zh": "站立"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to stand up (to rise from lying or sitting position); to get up"}, {"pos": "verb", "gloss": "to do, to undertake, to take upon oneself (بِ (bi))", "examples": [{"text": "أَتَقُومُ بِتَمَارِينِ الرِّيَاضَةِ؟", "english": "Do you do (sport) exercises?"}]}, {"pos": "verb", "gloss": "to engage in (constructed with بِ (bi))", "examples": [{"text": "فَهُمْ عَبَدُوا الْأَصْنَامَ وَقامُوا بِمُمَارَسَاتٍ مُنْحَطَّةٍ أُخْرَى.", "english": "They worshiped idols and engaged in other degenerated practices."}]}, {"pos": "verb", "gloss": "to rise from the dead", "examples": [{"text": "يَوْمَ يَقُومُ النَّاسُ لِرَبِّ الْعَالَمِينَ", "english": "On the day people will rise up to the Lord of the worlds"}]}]}, "etymology": {"source": "wiktextract", "text": "From the root ق و م (q w m). Compare Hebrew קָם (kam), Ge'ez ቆመ (ḳomä), Classical Syriac ܩܳܡ, Ugaritic 𐎖𐎎 (qm)."}, "ipa": ["/qaː.ma/", "/qoːm/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n42885", "headword_ar": "قَامَ", "root": "qwm", "body": [{"kind": "italic_en", "text": "He stood still"}, {"kind": "text", "text": "(Ksh and Bd in ii. 19)"}, {"kind": "italic_en", "text": "in his place."}, {"kind": "text", "text": "(Ksh.) ―         -b2-"}, {"kind": "arabic", "text_bw": "qaAmati Ald~aAb~apu", "text_ar": "قَامَتِ الدَّابَّةُ"}, {"kind": "italic_en", "text": "The beast stopped"}, {"kind": "text", "text": "(S, K, TA)"}, {"kind": "italic_en", "text": "from journeying,"}, {"kind": "text", "text": "(TA,)"}, {"kind": "italic_en", "text": "from fatigue,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "being jaded;"}, {"kind": "text", "text": "(S, TA;)"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "AnqTEt", "text_ar": "انقطعت"}, {"kind": "text", "text": ". (A.) And"}, {"kind": "arabic", "text_bw": "qaAmato Ealayohi Ald~aAb~apu", "text_ar": "قَامَتْ عَلَيْهِ الدَّابَّةُ"}, {"kind": "italic_en", "text": "His beast, being jaded, stopped with him, and moved not from its place."}, {"kind": "text", "text": "(Mgh.) ―         -b3-"}, {"kind": "arabic", "text_bw": "qaAma", "text_ar": "قَامَ"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, stood up,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "erect;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "AinotaSaba", "text_ar": "اِنْتَصَبَ"}, {"kind": "text", "text": ". (K.) And hence,"}, {"kind": "italic_en", "text": "He rose,"}, {"kind": "text", "text": "i. e. from sitting or reclining. ―         -b4-"}, {"kind": "arabic", "text_bw": "qaAma biAll~ayoli", "text_ar": "قَامَ بِاللَّيْلِ"}, {"kind": "italic_en", "text": "He rose in the night"}, {"kind": "text", "text": "to pray. ―         -b5-"}, {"kind": "arabic", "text_bw": "qaAma", "text_ar": "قَامَ"}, {"kind": "arabic", "text_bw": "ramaDaAna", "text_ar": "رَمَضَانَ"}, {"kind": "italic_en", "text": "He passed the nights of Ramadán in prayer:"}, {"kind": "text", "text": "(El-'Alkarnee in a marginal note in a copy of the Jámi' es-Sagheer, voce"}, {"kind": "arabic", "text_bw": "mano", "text_ar": "مَنْ"}, {"kind": "text", "text": ":) or"}, {"kind": "italic_en", "text": "he performed the prayers"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "of Ramadán"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "called"}, {"kind": "arabic", "text_bw": "Alt~araAwiyH", "text_ar": "التَّرَاوِيح"}, {"kind": "text", "text": ". (En-Nawawee, ibid.) ―         -b6-"}, {"kind": "arabic", "text_bw": "qaAmati AlS~alaApu", "text_ar": "قَامَتِ الصَّلَاةُ"}, {"kind": "italic_en", "text": "The people rose to prayer:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the time of their doing so came."}, {"kind": "text", "text": "(TA.) ―         -b7-"}, {"kind": "arabic", "text_bw": "qaAmati Als~aAEapu", "text_ar": "قَامَتِ السَّاعَةُ"}, {"kind": "italic_en", "text": "The resurrection,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the time thereof, came to pass."}, {"kind": "text", "text": "―         -b8-"}, {"kind": "arabic", "text_bw": "qaAmati Al$~amosu wakaAda AlZ~il~u yaEoqilu", "text_ar": "قَامَتِ الشَّمْسُ وَكَادَ الظِّلُّ يَعْقِلُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The sun became high, and the shade almost disappeared, at midday"}, {"kind": "text", "text": "]. (JK.) ―         -b9-"}, {"kind": "arabic", "text_bw": "qaAma Ealayohi", "text_ar": "قَامَ عَلَيْهِ"}, {"kind": "italic_en", "text": "He rose up against him:"}, {"kind": "text", "text": "see a verse cited voce"}, {"kind": "arabic", "text_bw": "HuwbN", "text_ar": "حُوبٌ"}, {"kind": "text", "text": ". ―         -b10-"}, {"kind": "arabic", "text_bw": "qaAma biAlA^amori", "text_ar": "قَامَ بِالاَمْرِ"}, {"kind": "italic_en", "text": "He undertook the affair; took,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "imposed, it upon himself;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "takaf~ala bihi", "text_ar": "تَكَفَّلَ بِهِ"}, {"kind": "text", "text": "; and the epithet is"}, {"kind": "arabic", "text_bw": "qaAy^imN", "text_ar": "قَايِمٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "qay~imN", "text_ar": "قَيِّمٌ"}, {"kind": "text", "text": ": (Ham, p. 5:) [and]"}, {"kind": "italic_en", "text": "he managed, conducted, ordered, regulated,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "superintended, the affair;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "saAsahu", "text_ar": "سَاسَهُ"}, {"kind": "text", "text": "; (TA in art."}, {"kind": "arabic", "text_bw": "sws", "text_ar": "سوس"}, {"kind": "text", "text": ";) and"}, {"kind": "arabic", "text_bw": "qAm Ealayohi", "text_ar": "قام عَلَيْهِ"}, {"kind": "text", "text": "has this latter signification; and"}, {"kind": "italic_en", "text": "he tended,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "took care of, it,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "him;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "saAsahu", "text_ar": "سَاسَهُ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "waliyahu", "text_ar": "وَلِيَهُ"}, {"kind": "text", "text": ": (Ham ubi supra:) [and] the former signifies"}, {"kind": "italic_en", "text": "he attended to the affair;"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "occupied himself with it"}, {"kind": "text", "text": "]; (this should be the first explanation;)"}, {"kind": "italic_en", "text": "was mindful of it; kept to it constantly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "steadily;"}, {"kind": "text", "text": "and is"}, {"kind": "italic_en", "text": "contr. of"}, {"kind": "arabic", "text_bw": "qaEada Eanohu", "text_ar": "قَعَدَ عَنْهُ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "taqaAEada", "text_ar": "تَقَاعَدَ"}, {"kind": "text", "text": ": (JM, q. v.:) [or,] as"}, {"kind": "italic_en", "text": "contr. of"}, {"kind": "arabic", "text_bw": "qEd", "text_ar": "قعد"}, {"kind": "arabic", "text_bw": "Enh", "text_ar": "عنه"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "tqAEd", "text_ar": "تقاعد"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "he acted vigorously in the affair;"}, {"kind": "text", "text": "as also ↓"}, {"kind": "arabic", "text_bw": "A^aqaAmahu", "text_ar": "اَقَامَهُ", "orth_type": "arrow"}, {"kind": "text", "text": "; syn."}, {"kind": "arabic", "text_bw": "jad~a fiyhi", "text_ar": "جَدَّ فِيهِ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "tajal~ada", "text_ar": "تَجَلَّدَ"}, {"kind": "text", "text": ". (Bd in ii. 2.) ―         -b11-  You say,"}, {"kind": "arabic", "text_bw": "qaAma bi$aA^onihi", "text_ar": "قَامَ بِشَاْنِهِ"}, {"kind": "italic_en", "text": "He undertook,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "superintended,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "managed, his affair,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "affairs."}, {"kind": "text", "text": "And you say,"}, {"kind": "arabic", "text_bw": "qaAma biAlyatiymi", "text_ar": "قَامَ بِاليَتِيمِ"}, {"kind": "text", "text": ", (Msb in art."}, {"kind": "arabic", "text_bw": "Ewl", "text_ar": "عول"}, {"kind": "text", "text": ",) and"}, {"kind": "arabic", "text_bw": "biAlS~abiY~i", "text_ar": "بِالصَّبِىِّ"}, {"kind": "text", "text": ", (Idem, art."}, {"kind": "arabic", "text_bw": "kfl", "text_ar": "كفل"}, {"kind": "text", "text": ",)"}, {"kind": "italic_en", "text": "He maintained the orphan,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "the child;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "EaAlahu", "text_ar": "عَالَهُ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "kafalahu", "text_ar": "كَفَلَهُ"}, {"kind": "text", "text": ": (Idem:) and"}, {"kind": "arabic", "text_bw": "qaAma AlmaroA^apa", "text_ar": "قَامَ المَرْاَةَ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "EalayohaA", "text_ar": "عَلَيْهَا"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He undertook the maintenance of the woman;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "he maintained her;"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "maAnahaA", "text_ar": "مَانَهَا"}, {"kind": "text", "text": "[i. e."}, {"kind": "arabic", "text_bw": "qaAma bikifaAyatihaA", "text_ar": "قَامَ بِكِفَايَتِهَا"}, {"kind": "text", "text": "(S and K in art."}, {"kind": "arabic", "text_bw": "mwn", "text_ar": "مون"}, {"kind": "text", "text": ")];)"}, {"kind": "italic_en", "text": "and undertook,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "managed, her affair,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "affairs."}, {"kind": "text", "text": "(K.) And"}, {"kind": "arabic", "text_bw": "Alr~ijaAlu yaquwmuwna EalaY Aln~isaA='i", "text_ar": "الرِّجَالُ يَقُومُونَ عَلَى النِّسَا=ءِ"}, {"kind": "italic_en", "text": "The men govern the women:"}, {"kind": "text", "text": "(Bd, iv. 38:) or"}, {"kind": "italic_en", "text": "are mindful of them, and act well to them,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "take care of them."}, {"kind": "text", "text": "(TA.) ―         -b12-"}, {"kind": "arabic", "text_bw": "qAma biEu*oriY", "text_ar": "قامَ بِعُذْرِى"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He undertook,"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "it served, to excuse me"}, {"kind": "text", "text": "]. (Msb and TA in art."}, {"kind": "arabic", "text_bw": "E*r", "text_ar": "عذر"}, {"kind": "text", "text": "; &c.) ―         -b13-"}, {"kind": "arabic", "text_bw": "qaAma bihi", "text_ar": "قَامَ بِهِ"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, was supported,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sustained, by it; subsisted by it:"}, {"kind": "text", "text": "see the explanation of"}, {"kind": "arabic", "text_bw": "qaiwaAmN", "text_ar": "قَِوَامٌ"}, {"kind": "text", "text": "in the Msb. ―         -b14-"}, {"kind": "arabic", "text_bw": "qaAma Ealayohi ka*aA", "text_ar": "قَامَ عَلَيْهِ كَذَا"}, {"kind": "italic_en", "text": "It cost him such a thing, such a sum,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "so much."}, {"kind": "text", "text": "―         -b15-"}, {"kind": "arabic", "text_bw": "qaAma", "text_ar": "قَامَ"}, {"kind": "text", "text": "often signifies"}, {"kind": "arabic", "text_bw": "vabata", "text_ar": "ثَبَتَ"}, {"kind": "text", "text": ": so in"}, {"kind": "arabic", "text_bw": "qaAma fiY nafosihi", "text_ar": "قَامَ فِى نَفْسِهِ"}, {"kind": "arabic", "text_bw": "A^an~ahu ka*aA", "text_ar": "اَنَّهُ كَذَا"}, {"kind": "italic_en", "text": "It was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, established in his mind that it was so."}, {"kind": "text", "text": "―         -b16-"}, {"kind": "arabic", "text_bw": "qaAma bihi qiyaAmFA taAm~FA", "text_ar": "قَامَ بِهِ قِيَامًا تَامًّا"}, {"kind": "italic_en", "text": "He managed it perfectly."}, {"kind": "text", "text": "―         -b17-"}, {"kind": "arabic", "text_bw": "qaAma yafoEalu ka*aA", "text_ar": "قَامَ يَفْعَلُ كَذَا"}, {"kind": "italic_en", "text": "He began to do such a thing; he betook himself to doing such a thing."}, {"kind": "text", "text": "(Zj, in TA, art."}, {"kind": "arabic", "text_bw": "qdm", "text_ar": "قدم"}, {"kind": "text", "text": ".) ―         -b18-"}, {"kind": "arabic", "text_bw": "qaAma AlmaA='u", "text_ar": "قَامَ المَا=ءُ"}, {"kind": "text", "text": "(assumed tropical:)"},