{"lemma":"زاهِدَةٍ","slug":"زاهِدَةٍ","root":"ز.ه.د","root_slug":"ز-ه-د","root_link":"/words/roots/ز-ه-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"زاهِد","root":"زهد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n18300"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D8%A7%D9%87%D9%90%D8%AF%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"ascetic"},{"pos":"noun","gloss":"A popular title bestowed on disciples of Mystic Sufi orders upon their initiation. After initiation the title took the place of the new Spiritual Masters’ given names. A famous bearer of the title Zahed was Sheikh Zahed Gilani of Lahijan in Gilan province of northern Iran."},{"pos":"adj","gloss":"abstemious, abstinent, self-denying"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of زَهِدَ (zahida, “to abstain, to renounce”)."},"ipa":["/zaː.hid/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18300","headword_ar":"زَاهِدٌ","root":"zhd","body":[{"kind":"text","text":"act. part. n. of"},{"kind":"arabic","text_bw":"zahida","text_ar":"زَهِدَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Abstaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstinent; relinquishing; forsaking; shunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoiding; not desiring"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirous:"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"abstaining from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retiring from, worldly pleasures; exercising himself in the service of God,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in acts of devotion; a devotee"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"zih~iydN","text_ar":"زِهِّيدٌ","orth_type":"arrow"},{"kind":"text","text":"has a similar, but intensive, meaning [i. e."},{"kind":"italic_en","text":"abstaining much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very abstinent;"},{"kind":"text","text":"&c.]: pl. of the former"},{"kind":"arabic","text_bw":"zuh~aAdN","text_ar":"زُهَّادٌ"},{"kind":"text","text":". (Msb, TA.) See also"},{"kind":"arabic","text_bw":"zahiydN","text_ar":"زَهِيدٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]}]},"classical_definitions":null}