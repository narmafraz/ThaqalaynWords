n":"m","num":"p"},{"role":"present_2mp","form":"تَجْنَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْنَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْنَح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْنَح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْنَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْنَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْنَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْنَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْنَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْنَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْنَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَنَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَنَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْنَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْنَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"جَنَحَ","root":"جنح","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n6444"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%86%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"darkness, gloom"},{"pos":"noun","gloss":"vicinity, neighbourhood, region"},{"pos":"noun","gloss":"shadow, shelter, protection"}]},"etymology":null,"ipa":["/d͡ʒunħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6444","headword_ar":"جَنَحَ","root":"jnH","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (S, Msb, K,) agreeably with analogy, of the dial. of Temeem, and the most chaste form, (TA,) and"},{"kind":"text","text":", (S, Msb, K,) of the dial. of Keys, (TA,) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined, leant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"propended,"},{"kind":"text","text":"(S, A, Mgh, L, K)"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"(L, Msb) and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"(L) ["},{"kind":"italic_en","text":"to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, it"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"AjtnH","text_ar":"اجتنح","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, K,) and ↓"},{"kind":"arabic","text_bw":"AjnH","text_ar":"اجنح","orth_type":"arrow"},{"kind":"text","text":". (K [but, by the omission of a"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"after it, this is made in some copies of the K to relate to what there follows it].) It is said in the Kur [viii. 63],"},{"kind":"arabic","text_bw":"waA_ino janaHuwA","text_ar":"وَاـِنْ جَنَحُوا"},{"kind":"arabic","text_bw":"lils~alomi faA@jonaHo lahaA","text_ar":"لِلسَّلْمِ فَا@جْنَحْ لَهَا"},{"kind":"text","text":"(Mgh, L)"},{"kind":"italic_en","text":"And if they incline to peace, incline thou to it:"},{"kind":"arabic","text_bw":"slm","text_ar":"سلم"},{"kind":"text","text":"being here made fem. because syn. with"},{"kind":"arabic","text_bw":"muSaAlaHap","text_ar":"مُصَالَحَة"},{"kind":"text","text":". (L.) You say,"},{"kind":"arabic","text_bw":"janaHuwA lils~alomi","text_ar":"جَنَحُوا لِلسَّلْمِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":". (A.) ―         -b2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leant, on one side;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"leant upon his bow:"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AjtnH","text_ar":"اجتنح","orth_type":"arrow"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjtnH","text_ar":"اجتنح","orth_type":"arrow"},{"kind":"italic_en","text":"he leant upon him."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"janaHato","text_ar":"جَنَحَتْ"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel lying on her breast)"},{"kind":"italic_en","text":"leant on one side."},{"kind":"text","text":"(AO, TA.) ―         -b3-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"set about a thing, to do it with his hands, his breast leaning over it."},{"kind":"text","text":"(T, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"janaHa EalaY mirofaqayohi","text_ar":"جَنَحَ عَلَى مِرْفَقَيْهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"janoHN","text_ar":"جَنْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"rested himself upon his elbows, having set them upon the ground or upon a cushion."},{"kind":"text","text":"(ISh, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"janaHa A_ilayohimo","text_ar":"جَنَحَ اـِلَيْهِمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lahumo","text_ar":"لَهُمْ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"["},{"kind":"italic_en","text":"inclined to them;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"followed them and submitted to them;"},{"kind":"text","text":"namely, a sect. (ISh, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"janaHati Al$~amosu liloguruwbi","text_ar":"جَنَحَتِ الشَّمْسُ لِلْغُرُوبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The sun inclined to setting"},{"kind":"text","text":"]. (A.) ―         -b7-"},{"kind":"arabic","text_bw":"janaHa","text_ar":"جَنَحَ"},{"kind":"text","text":", (A, L, Msb,) aor."},{"kind":"text","text":", (L, Msb,) inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":", (S, L, K,) said of the night, (S, A, L, Msb, K) and of the evening, (A,) and of the darkness, (L,)"},{"kind":"italic_en","text":"It inclined to going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to coming:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"it came on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached."},{"kind":"text","text":"(S, L, Msb, K.) ―         -b8-  Also, with the same aor. and inf. n., said of a bird,"},{"kind":"italic_en","text":"It contracted its wings to descend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alight, and approached like one falling, and repairing to a place of refuge."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"janaHato","text_ar":"جَنَحَتْ"},{"kind":"text","text":"said of camels,"},{"kind":"italic_en","text":"They lowered the fore part of the neck"},{"kind":"text","text":"[in running]: or"},{"kind":"italic_en","text":"they went quickly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swiftly."},{"kind":"text","text":"(TA.) ―         -b10-  And, inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":", said of a ship ("},{"kind":"arabic","text_bw":"safiynap","text_ar":"سَفِينَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"She came to shallow water, and stuck to the ground,"},{"kind":"text","text":"(A, L,)"},{"kind":"italic_en","text":"so as to cease from motion."},{"kind":"text","text":"(L.)       -A2-"},{"kind":"arabic","text_bw":"janaHa","text_ar":"جَنَحَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"gave with his"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"janaAH","text_ar":"جَنَاح"},{"kind":"text","text":", or]"},{"kind":"italic_en","text":"hand."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"janaHahu","text_ar":"جَنَحَهُ"},{"kind":"text","text":", (S, L,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"janoHN","text_ar":"جَنْحٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, its"},{"kind":"arabic","text_bw":"janaAH","text_ar":"جَنَاح"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wing"},{"kind":"text","text":"]; (S, L;) i. e., the"},{"kind":"arabic","text_bw":"jnAH","text_ar":"جناح"},{"kind":"text","text":"of the bird. (S.) And"},{"kind":"arabic","text_bw":"janaHa fulaAnFA","text_ar":"جَنَحَ فُلَانًا"},{"kind":"italic_en","text":"He hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, the arm"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"janaAH","text_ar":"جَنَاح"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of such a one."},{"kind":"text","text":"(K. [In some copies of the K, by the omission of a"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":", this signification is erroneously made to relate to"},{"kind":"arabic","text_bw":"AjnH","text_ar":"اجنح"},{"kind":"text","text":": so in the copies used by MF and SM, who state that the right verb is"},{"kind":"arabic","text_bw":"janaHa","text_ar":"جَنَحَ"},{"kind":"text","text":"])       -A4-"},{"kind":"arabic","text_bw":"juniHa","text_ar":"جُنِحَ"},{"kind":"text","text":", (S, K,) with damm, (S,) like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"junuwHN","text_ar":"جُنُوحٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had his"},{"kind":"arabic","text_bw":"jawaAniH","text_ar":"جَوَانِح"},{"kind":"text","text":"[the ribs so called]"},{"kind":"italic_en","text":"broken by reason of the heaviness of his load:"},{"kind":"text","text":"(S, K:) or"},{"kind":"page_break","n":469},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had the first of his ribs broken in the part next the breast."},{"kind":"text","text":"(TA.)       -A5-  ["},{"kind":"arabic","text_bw":"janaHa","text_ar":"جَنَحَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He regarded"},{"kind":"text","text":"an act"},{"kind":"italic_en","text":"as a crime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sin."},{"kind":"text","text":"Thus,]"},{"kind":"arabic","text_bw":"A_in~Y laA^ajonaHu A^ano A=kula minohu","text_ar":"اـِنّى لَاَجْنَحُ اَنْ ا=كُلَ مِنْهُ"},{"kind":"text","text":", in a trad. respecting the property of the orphan, means"},{"kind":"italic_en","text":"Verily I regard as a crime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sin,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"junaAH","text_ar":"جُنَاح"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"my eating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"devouring,"},{"kind":"text","text":"[aught]"},{"kind":"italic_en","text":"thereof."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA","Mgh","A","L"]}]},"classical_definitions":null}