{"lemma":"خَلاقٌ","slug":"خَلاقٌ","root":"خ.ل.ق","root_slug":"خ-ل-ق","root_link":"/words/roots/خ-ل-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَلاق","root":"خلق","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n11397","n11398","n11408"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D8%A7%D9%82%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"original, artistic, creative"},{"pos":"adj","gloss":"new, fertile, inventive"},{"pos":"noun","gloss":"maker"},{"pos":"noun","gloss":"inventor, author, originator, maker"},{"pos":"noun","gloss":"innovator, contriver, creator"},{"pos":"noun","gloss":"seminal, novel"},{"pos":"noun","gloss":"share (of positive qualities, religion)","examples":[{"text":"فَٱسْتَمْتَعُوا۟ بِخَلَـٰقِهِمْ فَٱسْتَمْتَعْتُم بِخَلَـٰقِكُمْ كَمَا ٱسْتَمْتَعَ ٱلَّذِينَ مِن قَبْلِكُم بِخَلَـٰقِهِمْ","english":"They enjoyed their share in this life. You have enjoyed your share, just as they did"}]}]},"etymology":{"source":"wiktextract","text":"Compare خَلَقَ (ḵalaqa, “to create”)."},"ipa":["/xal.laːq/","/xa.laːq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11397","headword_ar":"خَلَاقٌ","root":"xlq","body":[{"kind":"italic_en","text":"A share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion:"},{"kind":"text","text":"(JK, S, Msb:) and"},{"kind":"italic_en","text":"a good, just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"righteous, share"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"a full, a complete,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abundant, share"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion of good,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"of goodness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"righteousness:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"religion:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, thereof."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"laA xalaAqa lahu fiY AlA=xirapi","text_ar":"لَا خَلَاقَ لَهُ فِى الا=خِرَةِ"},{"kind":"italic_en","text":"There is no share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of good"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for him in the final state of existence."},{"kind":"text","text":"(S. [See the Kur iii. 71, &c.]) And"},{"kind":"arabic","text_bw":"laA xalaAqa lahu","text_ar":"لَا خَلَاقَ لَهُ"},{"kind":"italic_en","text":"He has no desire for good, nor righteousness in religion."},{"kind":"text","text":"(TA.)"}],"source_refs":["JK","S","Msb","K","TA"]},{"entry_id":"n11398","headword_ar":"خِلَاقٌ","root":"xlq","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n11408","headword_ar":"خَلَّاقٌ","root":"xlq","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D9%84%D8%A7%D9%82/","headword_ar":"خلاق","entries":[{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=94280#4dda1d","body_html":"<span class=\"title1\">خ ل ق [خلاق]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: ما لَهُ فِي الْآخِرَةِ مِنْ خَلاقٍ .</span><br><span>قال: ما له في الآخرة من نصيب.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت أمية بن أبي الصلت وهو يقول:</span><br><span>يدعون منها بقوم لا خلاق لهم </span><span class=\"red\">...</span><span> إلّا سرابيل من قطر وأغلال </span><br><span>وقال عدي بن زيد :</span><br><span>سوف يأتيك والسلام جميعا </span><span class=\"red\">...</span><span> لكلانا فما له من خلاق </span>"}]}}