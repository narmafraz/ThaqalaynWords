":[{"entry_id":"n1079","headword_ar":"اَلَقَ","root":"Alq","body":[{"kind":"text","text":", (JK, K, TA,) aor."},{"kind":"text","text":"; (K, TA;) or"},{"kind":"arabic","text_bw":"A^aliqa","text_ar":"اَلِقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (CK; [in which it would seem, from what follows in this paragraph and the next, that the pret. is wrong, but that the aor. is right;]) inf. n."},{"kind":"arabic","text_bw":"A^aloqN","text_ar":"اَلْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilaAqN","text_ar":"اـِلَاقٌ"},{"kind":"text","text":"; (JK, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(lightning)"},{"kind":"italic_en","text":"lied;"},{"kind":"text","text":"(AHeyth, K;) [i. e.]"},{"kind":"italic_en","text":"it was without rain."},{"kind":"text","text":"(JK.) ―         -b2-  See also 5. ―         -b3-  Also,"},{"kind":"arabic","text_bw":"A^alaqa","text_ar":"اَلَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^aloqN","text_ar":"اَلْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He lied; spoke falsely:"},{"kind":"text","text":"whence the reading of Aboo-Jaafar and Zeyd Ibn-Aslam, [in the Kur xxiv. 14,]"},{"kind":"arabic","text_bw":"A_i*o taA^olaquwnahu","text_ar":"اـِذْ تَاْلَقُونَهُ"},{"kind":"arabic","text_bw":"tA^l~q","text_ar":"تالّق"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When ye spoke it falsely with your tongues"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["JK","K","TA"]},{"entry_id":"n1081","headword_ar":"اـِلْقٌ","root":"Alq","body":[{"kind":"italic_en","text":"A he-wolf:"},{"kind":"text","text":"fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (IAar, S, K:) and the fem. is also applied to"},{"kind":"italic_en","text":"a she-ape"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"monkey;"},{"kind":"text","text":"the male of which is not called"},{"kind":"arabic","text_bw":"A_iloqN","text_ar":"اـِلْقٌ"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"qirodN","text_ar":"قِرْدٌ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"rub~aAHN","text_ar":"رُبَّاحٌ"},{"kind":"text","text":". (S.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"Evil in disposition,"},{"kind":"text","text":"applied to a man; and so with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"applied to a woman: and the latter,"},{"kind":"italic_en","text":"a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"demon of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"siEolaAp","text_ar":"سِعْلَاة"},{"kind":"text","text":"; because of its evil, or malignant, nature: (TA:) and a"},{"kind":"italic_en","text":"bold"},{"kind":"text","text":"woman; (Lth, K;) for the same reason. (TA.)"}],"source_refs":["IAar","S","K","TA"]},{"entry_id":"n1084","headword_ar":"اُلَّقٌ","root":"Alq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A_ilaAqN","text_ar":"اـِلَاقٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1085","headword_ar":"اـِلَّقٌ","root":"Alq","body":[{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A_im~aEN","text_ar":"اـِمَّعٌ"},{"kind":"text","text":", [in a copy of the JK incorrectly written"},{"kind":"arabic","text_bw":"A^aliqN","text_ar":"اَلِقٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"mutaA^al~iqN","text_ar":"مُتَاَلِّقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Shining, gleaming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistening"},{"kind":"text","text":"]; (S, K;) applied to lightning. (JK.) ―         -b2-  Also (assumed tropical:)  An"},{"kind":"italic_en","text":"inconstant"},{"kind":"text","text":"man; from"},{"kind":"arabic","text_bw":"Alt~aA^al~uqu","text_ar":"التَّاَلُّقُ"},{"kind":"text","text":"as relating to lightning. (JK: there, in this