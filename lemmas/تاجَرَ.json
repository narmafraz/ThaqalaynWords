num":"p"},{"role":"present_2mp","form":"تُتاجِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُتاجِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُتاجِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُتاجِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُتاجِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُتاجِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُتاجِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتاجِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُتاجِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُتاجِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُتاجِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُتاجِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُتاجِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تاجَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تاجَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":true,"lemma_key":"تاجَرَ","root":"أجر","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n3783"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D8%A7%D8%AC%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3783","headword_ar":"تَاجِرٌ","root":"tjr","body":[{"kind":"italic_en","text":"A merchant; one who practises traffic, merchandise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commerce; a trafficker; a trader,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tradesman; a dealer; one who sells and buys;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"one who sells and buys for gain:"},{"kind":"text","text":"(Ksh in ii. 15:) and"},{"kind":"italic_en","text":"a vintner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seller of wine,"},{"kind":"text","text":"(S, K,) was also called thus by the Arabs: (S:) accord. to IAth, this latter is said to be the primary signification: and hence the saying in a trad.,"},{"kind":"arabic","text_bw":"A_in~a","text_ar":"اـِنَّ"},{"kind":"arabic","text_bw":"Alt~aAjira faAjirN","text_ar":"التَّاجِرَ فَاجِرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily the vintner is a transgressor"},{"kind":"text","text":"]: (TA:) pl."},{"kind":"arabic","text_bw":"tuj~aArN","text_ar":"تُجَّارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tijaArN","text_ar":"تِجَارٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tajorN","text_ar":"تَجْرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) [or rather this last is a quasi-pl. n.,] like as"},{"kind":"arabic","text_bw":"SaHobN","text_ar":"صَحْبٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"SaAHibN","text_ar":"صَاحِبٌ"},{"kind":"text","text":", (S, Msb,) and"},{"kind":"arabic","text_bw":"tujurN","text_ar":"تُجُرٌ"},{"kind":"text","text":", (K,) or this may be a pl. of"},{"kind":"arabic","text_bw":"tijaArN","text_ar":"تِجَارٌ"},{"kind":"text","text":". (ISd, TA.) ↓"},{"kind":"arabic","text_bw":"Alt~ajiru","text_ar":"التَّجِرُ","orth_type":"arrow"},{"kind":"text","text":"."},{"kind":"page_break","n":298},{"kind":"text","text":"occurring in a verse of El-Akhtal, [for"},{"kind":"arabic","text_bw":"Alt~aAjiru","text_ar":"التَّاجِرُ"},{"kind":"text","text":",] is thought by ISd to be like"},{"kind":"arabic","text_bw":"TahirN","text_ar":"طَهِرٌ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"TaAhirN","text_ar":"طَاهِرٌ"},{"kind":"text","text":"]. (TA.) ―         -b2-  [Hence,] (tropical:)  A man"},{"kind":"italic_en","text":"skilful in an affair."},{"kind":"text","text":"(K, TA.) The Arabs say,"},{"kind":"arabic","text_bw":"A_in~ahu lataAjirN bi*`lika AlA^amori","text_ar":"اـِنَّهُ لَتَاجِرٌ بِذٰلِكَ الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Verily he is skilful in that affair."},{"kind":"text","text":"(IAar, TA.) ―         -b3-  And (tropical:)  A she-camel"},{"kind":"italic_en","text":"that is saleable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy of sale,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand, in traffic,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the market;"},{"kind":"text","text":"(A 'Obeyd, S, K;) as also"},{"kind":"arabic","text_bw":"taAjirapN","text_ar":"تَاجِرَةٌ"},{"kind":"text","text":": (K:) or the latter, a she-camel"},{"kind":"italic_en","text":"that is goodly, and saleable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"that is easy of sale when offered, by reason of her excellence:"},{"kind":"text","text":"(T:) or simply,"},{"kind":"italic_en","text":"that is easy of sale,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand:"},{"kind":"text","text":"(S:) as though, by reason of her beauty, or goodliness, and fatness, she sold herself: (Ksh in ii. 15:)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"kaAsidapN","text_ar":"كَاسِدَةٌ"},{"kind":"text","text":": (S, * TA:) the pl. of"},{"kind":"arabic","text_bw":"tAjrp","text_ar":"تاجرة"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"tawaAjiru","text_ar":"تَوَاجِرُ"},{"kind":"text","text":". (T, A.) You say also,"},{"kind":"arabic","text_bw":"Ealayoka","text_ar":"عَلَيْكَ"},{"kind":"arabic","text_bw":"biAls~ilaEi Alt~awaAjiri","text_ar":"بِالسِّلَعِ التَّوَاجِرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Keep thou to the commodities"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that are saleable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in much demand."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"huwa EalaY A^akorami taAjirapK","text_ar":"هُوَ عَلَى اَكْرَمِ تَاجِرَةٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He is upon a most noble horse."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","TA","Msb","A","T"]}]},"classical_definitions":null}