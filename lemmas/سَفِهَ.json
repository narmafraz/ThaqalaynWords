{"lemma":"سَفِهَ","slug":"سَفِهَ","root":"س.ف.ه","root_slug":"س-ف-ه","root_link":"/words/roots/س-ف-ه","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَفِهْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَفِهْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَفِهْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَفِهْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَفِهْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَفِهَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَفِهَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَفِها","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَفِهَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَفِهُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَفِهْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْفَه","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْفَهِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْفَهِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْفَها","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْفَهانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْفَهُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْفَهُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْفَهْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْفَه","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْفَه","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْفَها","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْفَهانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْفَها","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْفَهانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْفَهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْفَهُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْفَهْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"سَفِهْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَفِهْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَسْفَه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْفَه","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"سَفِهَ","root":"سفه","pos":"V","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n20025"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%81%D9%90%D9%87%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20025","headword_ar":"سَفِهَ","root":"sfh","body":[{"kind":"text","text":", (S, MA, Msb,) aor."},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"safuha","text_ar":"سَفُهَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":";] (S, Msb;) inf. n."},{"kind":"arabic","text_bw":"safahN","text_ar":"سَفَهٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safaAhapN","text_ar":"سَفَاهَةٌ"},{"kind":"text","text":"(S, MA, Msb, K *) and"},{"kind":"arabic","text_bw":"safaAhN","text_ar":"سَفَاهٌ"},{"kind":"text","text":", (S, MA, K, *) [all mentioned in the MA as of the former verb, and so in the TA when that verb is trans., but properly] the first is of the former verb, and the second is of the latter verb, (S, Msb,) and so is the third; (S;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"safiyh","text_ar":"سَفِيه"},{"kind":"text","text":"; (S, TA;) [i. e.]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unwise, witless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destitute of wisdom"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding,"},{"kind":"text","text":"or [rather]"},{"kind":"italic_en","text":"lightwitted."},{"kind":"text","text":"(MA.) ―         -b2-  The phrase"},{"kind":"arabic","text_bw":"safiha nafosapu","text_ar":"سَفِهَ نَفْسَةُ"},{"kind":"text","text":", [of which an instance occurs in the Kur ii. 124, and] to which"},{"kind":"arabic","text_bw":"gabina raA^oyahu","text_ar":"غَبِنَ رَاْيَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baTira Eayo$ahu","text_ar":"بَطِرَ عَيْشَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^alima baTonahu","text_ar":"اَلِمَ بَطْنَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wafiqa A^amorahu","text_ar":"وَفِقَ اَمْرَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ra$ida A^amorahu","text_ar":"رَشِدَ اَمْرَهُ"},{"kind":"text","text":"are similar, was originally"},{"kind":"arabic","text_bw":"safihato","text_ar":"سَفِهَتْ"},{"kind":"arabic","text_bw":"nafosu zayodK","text_ar":"نَفْسُ زَيْدٍ"},{"kind":"text","text":"[or rather"},{"kind":"arabic","text_bw":"safihato nafosuhu","text_ar":"سَفِهَتْ نَفْسُهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mind, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lightwitted,"},{"kind":"text","text":"&c.]; but when [the dependence of] the verb became transferred [from the"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"] to the man, what followed the verb was put in the accus. case by being its objective complement, for the phrase became identical in meaning with"},{"kind":"arabic","text_bw":"nafosahu","text_ar":"نَفْسَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"saf~aha","text_ar":"سَفَّهَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he made himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mind, lightwitted,"},{"kind":"text","text":"&c.]: so say the Basrees and Ks; and it is allowable with them to make this accus. to precede [the verb]; like as it is allowable to say,"},{"kind":"arabic","text_bw":"gulaAmahu Darab zayodN","text_ar":"غُلَامَهُ ضَرَب زَيْدٌ"},{"kind":"text","text":": (S, TA:) accord. to the K, the verb thus used has three forms; (TA;) you say"},{"kind":"arabic","text_bw":"safiha nafosahu","text_ar":"سَفِهَ نَفْسَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raA^oyahu","text_ar":"رَاْيَهُ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"Hilomahu","text_ar":"حِلْمَهُ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"safuha","text_ar":"سَفُهَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"safaha","text_ar":"سَفَهَ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Hamalahu EalaYAls~afahi","text_ar":"حَمَلَهُ عَلَىالسَّفَهِ"},{"kind":"text","text":"[which is virtually the same as"},{"kind":"arabic","text_bw":"saf~ahahu","text_ar":"سَفَّهَهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he made himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mind, lightwitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unwise,"},{"kind":"text","text":"&c., and in like manner"},{"kind":"italic_en","text":"his judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, and he made his gravity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, to become levity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastiness,"},{"kind":"text","text":"&c.]: or"},{"kind":"italic_en","text":"he attributed"},{"kind":"arabic","text_bw":"safah","text_ar":"سَفَه"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"lightwittedness,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mind,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to his judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"he destroyed it;"},{"kind":"text","text":"(K, TA;) agreeably with the meaning assigned to"},{"kind":"arabic","text_bw":"safiha nafosahu","text_ar":"سَفِهَ نَفْسَهُ"},{"kind":"text","text":"by AO: (TA:) or this means"},{"kind":"italic_en","text":"he held himself in mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light, estimation;"},{"kind":"text","text":"(MA, and Ksh and Bd in ii. 124;) and"},{"kind":"italic_en","text":"rendered himself low, base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contemptible:"},{"kind":"text","text":"(Bd ibid.:) but Lh says that"},{"kind":"arabic","text_bw":"safiha nafosahu","text_ar":"سَفِهَ نَفْسَهُ"},{"kind":"text","text":", with kesr [to the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"safahN","text_ar":"سَفَهٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safaAhapN","text_ar":"سَفَاهَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safaAhN","text_ar":"سَفَاهٌ"},{"kind":"text","text":", means"},{"kind":"arabic","text_bw":"Hamalahu EalaY","text_ar":"حَمَلَهُ عَلَى"},{"kind":"arabic","text_bw":"Als~afahi","text_ar":"السَّفَهِ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"HamalahaA","text_ar":"حَمَلَهَا"},{"kind":"text","text":"], and is the approved form, and that some say"},{"kind":"arabic","text_bw":"safuha","text_ar":"سَفُهَ"},{"kind":"text","text":", which is rare: and accord. to J and others, (TA,) when they say"},{"kind":"arabic","text_bw":"sfh nafosahu","text_ar":"سفه نَفْسَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"raA^oyahu","text_ar":"رَاْيَهُ"},{"kind":"text","text":", they do not say it otherwise than with kesr [to the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"], because"},{"kind":"arabic","text_bw":"faEula","text_ar":"فَعُلَ"},{"kind":"text","text":"is not trans.: (S, TA:) so that the three forms of the verb mentioned in the K require consideration: (TA:) accord. to Fr, when [the dependence of] the verb in the phrase"},{"kind":"arabic","text_bw":"safiha nafosahu","text_ar":"سَفِهَ نَفْسَهُ"},{"kind":"text","text":"became transferred from the"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"to the possessor thereof, what followed the verb became an explicative, to indicate that the"},{"kind":"arabic","text_bw":"safah","text_ar":"سَفَه"},{"kind":"text","text":"[or lightwittedness, &c.,] was therein; and by rule it should be"},{"kind":"arabic","text_bw":"safiha zayodN nafosFA","text_ar":"سَفِهَ زَيْدٌ نَفْسًا"},{"kind":"text","text":", for the explicative should not be otherwise than indeterminate; but it was left in its state of a prefixed noun, and put in the accus. case in the manner of an indeterminate noun as being likened thereto; [the meaning, therefore, accord. to him, is"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lightwitted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"as to his mind;"},{"kind":"text","text":"] it is not allowable, however, in his opinion, to make this accus. to precede [the verb], because the explicative may not precede; and similar to this is the phrase"},{"kind":"arabic","text_bw":"Diqotu bihi *aroEFA","text_ar":"ضِقْتُ بِهِ ذَرْعًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Tibotu bihi nafosFA","text_ar":"طِبْتُ بِهِ نَفْسًا"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"DaAqa *aroEiYbihi","text_ar":"ضَاقَ ذَرْعِىبِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TaAbato nafosiY bihi","text_ar":"طَابَتْ نَفْسِى بِهِ"},{"kind":"text","text":": (S, TA:) but this saying [of Fr] is disallowed by the grammarians; for they say that explicatives are indeterminate, and that determinate nouns may not be used as indeterminate: some of the grammarians say that"},{"kind":"arabic","text_bw":"A_il~aAmano safiha nafosahu","text_ar":"اـِلَّامَنْ سَفِهَ نَفْسَهُ"},{"kind":"text","text":"in the Kur [ii. 124] means"},{"kind":"arabic","text_bw":"Al~A mn safiha fiYnafosihi","text_ar":"الّا من سَفِهَ فِىنَفْسِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"but he who is lightwitted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his mind"},{"kind":"text","text":"], i. e., who becomes"},{"kind":"arabic","text_bw":"safiyh","text_ar":"سَفِيه"},{"kind":"text","text":"; [the prep.]"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":"being suppressed [and the noun therefore put in the accus. case agreeably with a general rule]: Zj holds that the approvable saying is, that it means"},{"kind":"arabic","text_bw":"A_il~aA mano jahila nafosahu","text_ar":"اـِلَّا مَنْ جَهِلَ نَفْسَهُ"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"but he who is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ignorant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"silly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"unreflecting in his mind:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"safiha raA^oyahu","text_ar":"سَفِهَ رَاْيَهُ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"jahilahu","text_ar":"جَهِلَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he was ignorant,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion"},{"kind":"text","text":"]; and"},{"kind":"italic_en","text":"his judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, was unsound, without rectitude:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safiha nafosahu","text_ar":"سَفِهَ نَفْسَهُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"he lost himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his own soul."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"safiha AlHaq~a","text_ar":"سَفِهَ الحَقَّ"},{"kind":"text","text":"is likewise expl. as meaning"},{"kind":"arabic","text_bw":"AlHaq~a","text_ar":"الحَقَّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"saf~aha","text_ar":"سَفَّهَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right, to be foolishness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]; and Yoo held the one to be a dial. var. of the other, and the measure of the former verb to denote intensiveness; and accord. to this explanation one may say,"},{"kind":"arabic","text_bw":"safihotu","text_ar":"سَفِهْتُ"},{"kind":"arabic","text_bw":"zayodFA","text_ar":"زَيْدًا"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"zayodFA","text_ar":"زَيْدًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"saf~ahotu","text_ar":"سَفَّهْتُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I pronounced Zeyd lightwitted,"},{"kind":"text","text":"&c.]: or the meaning is"},{"kind":"arabic","text_bw":"jahila AlHaq~a","text_ar":"جَهِلَ الحَقَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he ignored the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right"},{"kind":"text","text":"], and"},{"kind":"italic_en","text":"he did not see it to be the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he regarded the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right, as foolishness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignorance."},{"kind":"text","text":"(S and TA in art."},{"kind":"arabic","text_bw":"gmT","text_ar":"غمط"},{"kind":"text","text":".) See also 2. ―         -b3-"},{"kind":"arabic","text_bw":"safiha Ealayohi","text_ar":"سَفِهَ عَلَيْهِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"jahila","text_ar":"جَهِلَ"},{"kind":"text","text":"[i. e., when thus trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He feigned ignorance to him"},{"kind":"text","text":"]; as also"},{"kind":"arabic","text_bw":"safuha","text_ar":"سَفُهَ"},{"kind":"text","text":", (K, TA,) and ↓"},{"kind":"arabic","text_bw":"tsAfh","text_ar":"تسافه","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b4-  And"},{"kind":"arabic","text_bw":"safihotu naSiybiY","text_ar":"سَفِهْتُ نَصِيبِى"},{"kind":"text","text":"[and it is implied in the K that one says"},{"kind":"arabic","text_bw":"safahotu nSybY","text_ar":"سَفَهْتُ نصيبى"},{"kind":"text","text":"also, but only the former is authorized by the TA,]"},{"kind":"italic_en","text":"I forgot my share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion."},{"kind":"text","text":"(Th, K, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"safaha SaAHibahu","text_ar":"سَفَهَ صَاحِبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He overcame his companion in what is termed"},{"kind":"arabic","text_bw":"musaAfahap","text_ar":"مُسَافَهَة"},{"kind":"text","text":"[inf. n. of 3, q. v.]. (K.) You say, ↓"},{"kind":"arabic","text_bw":"saAfahahu","text_ar":"سَافَهَهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fasafahahu","text_ar":"فَسَفَهَهُ"},{"kind":"text","text":". (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"safihati AlT~aEonapu","text_ar":"سَفِهَتِ الطَّعْنَةُ"},{"kind":"text","text":", (JK, K, TA,) inf. n."},{"kind":"arabic","text_bw":"safahN","text_ar":"سَفَهٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The spear-wound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, emitted blood which came from it quickly"},{"kind":"text","text":"(JK, K, TA)"},{"kind":"italic_en","text":"and dried up"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"wajaf~a","text_ar":"وَجَفَّ"},{"kind":"text","text":"[in the TK"},{"kind":"arabic","text_bw":"wixf","text_ar":"وِخف"},{"kind":"text","text":"]): (K, TA:) so in the A. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"safiha Al$~araAba","text_ar":"سَفِهَ الشَّرَابَ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"safahN","text_ar":"سَفَهٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He drank much of the beverage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wine, without having his thirst satisfied thereby."},{"kind":"text","text":"(S, K, TA.) See also 3. And"},{"kind":"arabic","text_bw":"safiha AlmaA='a","text_ar":"سَفِهَ المَا=ءَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He drank the water immoderately."},{"kind":"text","text":"(TA.) ―         -b8-  And"},{"kind":"arabic","text_bw":"safihotu","text_ar":"سَفِهْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safahotu","text_ar":"سَفَهْتُ"},{"kind":"text","text":"signify"},{"kind":"arabic","text_bw":"$ugilotu","text_ar":"شُغِلْتُ"},{"kind":"text","text":", (so in the CK,) in [some of] the copies of the K"},{"kind":"arabic","text_bw":"$agalotu","text_ar":"شَغَلْتُ"},{"kind":"text","text":", but the right reading is"},{"kind":"arabic","text_bw":"$ugilotu","text_ar":"شُغِلْتُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I was occupied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"busied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diverted"},{"kind":"text","text":"from a thing]: or, accord. to the copies of the K,"},{"kind":"arabic","text_bw":"ta$ag~alotu","text_ar":"تَشَغَّلْتُ"},{"kind":"text","text":"; but correctly, or"},{"kind":"arabic","text_bw":"$agalotu","text_ar":"شَغَلْتُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I occupied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"busied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diverted"},{"kind":"text","text":"from a thing]. (TA.)"}],"source_refs":["S","MA","Msb","TA","K","JK"]}]},"classical_definitions":null}