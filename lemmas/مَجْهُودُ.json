{"lemma":"مَجْهُودُ","slug":"مَجْهُودُ","root":"ج.ه.د","root_slug":"ج-ه-د","root_link":"/words/roots/ج-ه-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n6524"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AC%D9%92%D9%87%D9%8F%D9%88%D8%AF%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"effort, exertion"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of جَهَدَ (jahada, “to struggle, labor, exert effort”)."},"ipa":["/mad͡ʒ.huːd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6524","headword_ar":"مَجْهُودٌ","root":"jhd","body":[{"kind":"italic_en","text":"Severely affected, harassed, embarrassed, distressed, afflicted, troubled, inconvenienced, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wearied:"},{"kind":"text","text":"(S, Mgh, L:)"},{"kind":"italic_en","text":"distressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afflicted, by disease"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty:"},{"kind":"text","text":"(JK:)"},{"kind":"italic_en","text":"afflicted with drought, barrenness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with drought, and dryness of the earth:"},{"kind":"text","text":"(L:) and"},{"kind":"italic_en","text":"angry."},{"kind":"text","text":"(JK.) ―         -b2-  A"},{"kind":"italic_en","text":"hard, difficult, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressful,"},{"kind":"text","text":"state of life. (TA.) ―         -b3-  (tropical:)  Milk"},{"kind":"italic_en","text":"deprived of its butter"},{"kind":"text","text":"(S, A)"},{"kind":"italic_en","text":"entirely:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"mixed with water:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"diluted so as to consist for the most part of water;"},{"kind":"text","text":"and in like manner, broth: (A:) or"},{"kind":"italic_en","text":"churned so that its butter is extracted and it is rendered sweet and pleasant:"},{"kind":"text","text":"and used as meaning"},{"kind":"italic_en","text":"eagerly desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longed for, and drunk without its occasioning disgust, by reason of its sweetness and pleasantness:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"eagerly desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longed for;"},{"kind":"text","text":"and so food in general: (JK, L:) or"},{"kind":"italic_en","text":"eagerly desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longed for, and drunk with perseverance, on account of its pleasantness and sweetness."},{"kind":"text","text":"(L.)       -A2-  See also"},{"kind":"arabic","text_bw":"jahodN","text_ar":"جَهْدٌ"},{"kind":"text","text":", in six places."}],"source_refs":["S","Mgh","L","JK","A","Msb"]}]},"classical_definitions":null}