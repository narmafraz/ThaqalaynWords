:"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدَرِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدَرِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدَرِّع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدَرِّع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدَرِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدَرِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدَرِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَرِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدَرِّعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَرِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدَرِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُدَرِّع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَرِّع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَرَّعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَرَّعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":43,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n12435","n12436","n12440","n12441"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%B1%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"protective coverings; protective war equipment, armor","tags":["uncountable"]},{"pos":"noun","gloss":"protective coverings; a body armor","tags":["countable"]},{"pos":"noun","gloss":"protective coverings; an armor plate held in hand, a shield","tags":["countable"]},{"pos":"noun","gloss":"protective coverings; something that resembles or is used like a shield (such as human shields)","tags":["countable"]},{"pos":"noun","gloss":"protective coverings; a protective shell or covering (as of a tortoise), armature","tags":["countable"]},{"pos":"noun","gloss":"a garment worn by women","tags":["broadly"]},{"pos":"verb","gloss":"to put armor on, to armor"}]},"etymology":{"source":"wiktextract","text":"From the root د ر ع (d r ʕ). Compare Ge'ez ድርዕ (dərʿ, “coat of mail, harness”), Tigre ደርዕ (därʿ), Tigrinya ድርዒ (dərʿi), Amharic ዲር (dir), ድር (dər), Soqotri daraḥ (“to put on (a garment)”). Nöldeke thinks that the Arabic is borrowed from Ge'ez."},"ipa":["/dirʕ/","/dar.ra.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12435","headword_ar":"دَرِعَ","root":"drE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"daraEN","text_ar":"دَرَعٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse, and a sheep or goat,)"},{"kind":"italic_en","text":"was black in the head, and white"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the other parts"},{"kind":"text","text":"]: or, as some say,"},{"kind":"italic_en","text":"was black in the head and neck."},{"kind":"text","text":"(Msb: [in my copy of which is an evident omission, which I have supplied: see"},{"kind":"arabic","text_bw":"A^adoraEu","text_ar":"اَدْرَعُ"},{"kind":"text","text":".]) [See also"},{"kind":"arabic","text_bw":"daraEN","text_ar":"دَرَعٌ"},{"kind":"text","text":", below.]"}],"source_refs":[]},{"entry_id":"n12436","headword_ar":"درّع","root":"drE","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tadoriyEN","text_ar":"تَدْرِيعٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He clad"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"with a"},{"kind":"arabic","text_bw":"diroE","text_ar":"دِرْع"},{"kind":"text","text":", (K,) i. e. a"},{"kind":"arabic","text_bw":"drE","text_ar":"درع"},{"kind":"italic_en","text":"of iron"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"coat of mail"},{"kind":"text","text":"]: (TA:) and a woman"},{"kind":"italic_en","text":"with a"},{"kind":"arabic","text_bw":"qamiyS","text_ar":"قَمِيص"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shift"},{"kind":"text","text":"]. (S, K.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n12440","headword_ar":"دِرْعٌ","root":"drE","body":[{"kind":"italic_en","text":"A coat of mail;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zarad~iyapN","text_ar":"زَرَدِّيَةٌ"},{"kind":"text","text":": (IAth, Msb, TA:) [or"},{"kind":"italic_en","text":"a coat of defence of any kind;"},{"kind":"text","text":"being a term applied in the S and K &c. to a"},{"kind":"arabic","text_bw":"yalabap","text_ar":"يَلَبَة"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a coat of defence of skins,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of camel's hide:"},{"kind":"text","text":"] and also,"},{"kind":"italic_en","text":"of plate-armour:"},{"kind":"text","text":"(AO, in his book on the"},{"kind":"arabic","text_bw":"diroE","text_ar":"دِرْع"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bayoDap","text_ar":"بَيْضَة"},{"kind":"text","text":", cited in the TA voce"},{"kind":"arabic","text_bw":"migofarN","text_ar":"مِغْفَرٌ"},{"kind":"text","text":":) [but the first is the most general, and proper, meaning:] as meaning a"},{"kind":"arabic","text_bw":"diroE","text_ar":"دِرْع"},{"kind":"text","text":"of iron, it is fem.; (S, Mgh, K *) or mostly so; (Msb;) but sometimes masc.: (K:) AO says that it is masc. and fem.; (S, TA;) and so Lh: (TA:) pl."},{"kind":"arabic","text_bw":"A^adoruEN","text_ar":"اَدْرُعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^adoraAEN","text_ar":"اَدْرَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"duruwEN","text_ar":"دُرُوعٌ"},{"kind":"text","text":"; (S, Msb, K;) the first and second, pls. of pauc.; the third, a pl. of mult. (S.) The dim. is ↓"},{"kind":"arabic","text_bw":"durayoEN","text_ar":"دُرَيْعٌ","orth_type":"arrow"},{"kind":"text","text":", which is anomalous, (S, Msb, K,) for by rule it should be with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (S;) or this may be [a regular form] of the dial. of those who make the word masc.; and some say ↓"},{"kind":"arabic","text_bw":"durayoEapN","text_ar":"دُرَيْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"."},{"kind":"page_break","n":872},{"kind":"text","text":"(Msb.) ―         -b2-  Also"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"woman's"},{"kind":"arabic","text_bw":"qamiyS","text_ar":"قَمِيص"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shift"},{"kind":"text","text":"]; (S, Msb, K;)"},{"kind":"italic_en","text":"a garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, in the middle of which a woman cuts an opening for the head to be put through, and to which she puts arms"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sleeves"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and the two openings of which"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at the two sides"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"she sews up:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"a"},{"kind":"text","text":"woman's"},{"kind":"italic_en","text":"garment which is worn above the"},{"kind":"arabic","text_bw":"qamiyS","text_ar":"قَمِيص"},{"kind":"text","text":": or, accord. to El-Hulwánee,"},{"kind":"italic_en","text":"one of which the opening for the head to pass through extends towards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to, the bosom;"},{"kind":"text","text":"whereas the"},{"kind":"arabic","text_bw":"qmyS","text_ar":"قميص"},{"kind":"text","text":"is one of which the slit is towards, or to, the shoulder-joint; but this [says Mtr] I find not in the lexicons: (Mgh:)"},{"kind":"italic_en","text":"a small garment which a young girl wears in her house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chamber,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent:"},{"kind":"text","text":"(TA:) as meaning a woman's"},{"kind":"arabic","text_bw":"diroE","text_ar":"دِرْع"},{"kind":"text","text":", it is masc., (Lh, S, Mgh, Msb, K,) only; (Lh;) or sometimes fem.: (TA:) pl."},{"kind":"arabic","text_bw":"A^adoraAEN","text_ar":"اَدْرَاعٌ"},{"kind":"text","text":". (S, K.) [See a verse cited voce"},{"kind":"arabic","text_bw":"mijowalN","text_ar":"مِجْوَلٌ"},{"kind":"text","text":".]"}],"source_refs":["IAth","Msb","TA","K","S","T","Mgh","Lh"]},{"entry_id":"n12441","headword_ar":"دَرَعٌ","root":"drE","body":[{"kind":"italic_en","text":"Whiteness in the breast of a sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat, and in its"},{"kind":"arabic","text_bw":"naHor","text_ar":"نَحْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"part where it is slaughtered,"},{"kind":"text","text":"but"},{"kind":"arabic","text_bw":"wanaHorihaA","text_ar":"وَنَحْرِهَا"},{"kind":"text","text":", in the K, is probably a mistranscription, for"},{"kind":"arabic","text_bw":"wanaHowihaA","text_ar":"وَنَحْوِهَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"and the like thereof,"},{"kind":"text","text":"i. e., of the sheep, or goat],"},{"kind":"italic_en","text":"and blackness in the thigh."},{"kind":"text","text":"(Lth, K.) [See also 1; and see"},{"kind":"arabic","text_bw":"duroEapN","text_ar":"دُرْعَةٌ"},{"kind":"text","text":".]"}],"source_refs":[]}]}}