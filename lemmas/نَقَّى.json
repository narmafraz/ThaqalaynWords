,"gen":"f","num":"d"},{"role":"present_3fd","form":"تُنَقَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُنَقِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُنَقِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُنَقُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُنَقُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُنَقَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُنَقِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُنَقّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُنَقَّى","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُنَقَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَقَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَقَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُنَقِّي","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُنَقِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n44124"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%82%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to purify, to cleanse, to clean, to refine"},{"pos":"verb","gloss":"to remove impurities"},{"pos":"verb","gloss":"to select, to choose"}]},"etymology":null,"ipa":["/naq.qaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44124","headword_ar":"نِقْىٌ","root":"nqY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"pith"},{"kind":"text","text":"of canes, or reeds: see"},{"kind":"arabic","text_bw":"*ihonN","text_ar":"ذِهْنٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"Somewhat of fat"},{"kind":"text","text":"in a camel. (TA in art."},{"kind":"arabic","text_bw":"TEm","text_ar":"طعم"},{"kind":"text","text":".) ―         -b3-  And"},{"kind":"italic_en","text":"Marrow; i. q."},{"kind":"arabic","text_bw":"mux~N","text_ar":"مُخٌّ"},{"kind":"text","text":". (TA voce"},{"kind":"arabic","text_bw":"SuhaArapN","text_ar":"صُهَارَةٌ"},{"kind":"text","text":".)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%86%D9%82%D9%89/","headword_ar":"نقى","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10086#356fb6","body_html":"<h3>نق</h3>ى<span class=\"sense\">2</span> نَقَّاهُ He cleansed it; cleared it; picked it; purified it; removing from it what was bad. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, &amp;c.) 10 اِسْتَنْقَى He took extraordinary pains, or the utmost pains, in cleansing his body. (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>.) You say also, اِسْتَنْقَى الذَّكَرَ مِنَ البَوْلِ (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, art. برأ,) [He took extraordinary pains in cleansing the ذَكَر from urine: or] he cleansed the ذكر entirely from urine; <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr> اِسْتَنْظَفَهُ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in that art.) <span class=\"sub-sense\">b2:</span> اِسْتِنْقَاءٌ: see <abbr title=\"under the heading\">voce</abbr> اِسْتَبْرَأَ.<br><br>نِقْىٌ The pith of canes, or reeds: see ذِهْنٌ. <span class=\"sub-sense\">b2:</span> Somewhat of fat in a camel. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in art. طعم.) <span class=\"sub-sense\">b3:</span> And Marrow; <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> مُخٌّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> <abbr title=\"under the heading\">voce</abbr> صُهَارَةٌ.) بَنَاتُ النَّقَى<br><br>, or النَّقَا, The حُلَكَة [or حُلْكَة]; to which the fingers (بَنَان) of virgins are likened: (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr> in art. بنى:) a certain small reptile, that dwells in sand, resembling a fish, smooth, and having a mixture of whiteness and redness; called also شَحْمَةُ النَّقَا. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See حُلَكَةٌ and شَحْمٌ. <span class=\"sub-sense\">b2:</span> نَقًا or نَقًى<br><br>An extended gibbous piece of sand. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) نُقَايَةٌ The extract, or refuse, of a thing: see عُصَارَةٌ.<br><br>مُنْقٍ<br><br>, said of a sheep, Becoming a little fat: see سَاحٌّ. <span class=\"sub-sense\">b2:</span> A sieve, <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr> غِرْبَالٌ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, art. دوس.) مُنَقِّيَةٌ A woman who trims the split palmstalks in mat-making: see شَطَبَ and شَاطِبَةٌ."},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10086#5a1ea2","body_html":"<span class=\"title1\">نقى</span><span> قبح قَمح بثث نقث أَبُو عبيد: وَلَا أَظن وَاحِدَة من هَاتين الْكَلِمَتَيْنِ من كَلَام الْعَرَب وَلَا أَدْرِي مَا هُوَ فَإِن كَانَ </span><span>كَمَا قيل فَإِنَّهَا أَرَادَت أَنهم أَصْحَاب زرع وَهَذَا أشبه بِكَلَام الْعَرَب إِن كَانَ مَحْفُوظًا. وَأما قَول الْمُحدثين: مُنِقّ فَلَا أَدْرِي مَا مَعْنَاهُ وَلَكِنِّي أَحْسبهُ: منَقّ فَإِن كَانَ هَذَا بِالْفَتْح فَإِنَّهَا أَرَادَتْهُ من تنقية الطَّعَام أَي دائس للطعام ومُنَقّ لَهُ. وَقَوْلها: عِنْده أَقُول فَلَا أقبّح واشرب فأتقمح تَقول: لَا يقبح عليّ قولي بل يقبل مني. وَأما التقمّح فِي الشَّرَاب فَإِنَّهُ مَأْخُوذ من النَّاقة المُقامح. قَالَ الْأَصْمَعِي: وَهِي الَّتِي ترد الْحَوْض فَلَا تشرب.</span>"}]}}