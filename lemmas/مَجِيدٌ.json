{"lemma":"مَجِيدٌ","slug":"مَجِيدٌ","root":"م.ج.د","root_slug":"م-ج-د","root_link":"/words/roots/م-ج-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَجِيد","root":"مجد","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n38229"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AC%D9%90%D9%8A%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"glorious, glorified"},{"pos":"adj","gloss":"famous, celebrated"},{"pos":"adj","gloss":"exalted","examples":[{"text":"الْمَجِيد","english":"the Exalted (God)"}]},{"pos":"adj","gloss":"praiseworthy, excellent, splendid"},{"pos":"adj","gloss":"noble"}]},"etymology":{"source":"wiktextract","text":"Compare مَجَدَ (majada, “to be glorious, to be exalted”) and مَجُدَ (majuda, “(same)”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38229","headword_ar":"مَجِيدٌ","root":"mjd","body":[{"kind":"text","text":"(from"},{"kind":"arabic","text_bw":"majuda","text_ar":"مَجُدَ"},{"kind":"text","text":", L) and ↓"},{"kind":"arabic","text_bw":"maAjidN","text_ar":"مَاجِدٌ","orth_type":"arrow"},{"kind":"text","text":"(from"},{"kind":"arabic","text_bw":"majada","text_ar":"مَجَدَ"},{"kind":"text","text":", L) A man (S)"},{"kind":"italic_en","text":"possessing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"characterized by,"},{"kind":"arabic","text_bw":"majod","text_ar":"مَجْد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"glory, honour, dignity, nobility, &c.; glorious, in a state of honour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity, noble, &c."},{"kind":"text","text":"]: (S, L, K:)"},{"kind":"italic_en","text":"glorious, in a state of honour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity, noble, abounding in good, and beneficent;"},{"kind":"text","text":"but the former has a more intensive sense: or the latter,"},{"kind":"italic_en","text":"characterized by gloriousness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobleness of actions:"},{"kind":"text","text":"(K:) or,"},{"kind":"italic_en","text":"by personal glory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility with goodness of actions;"},{"kind":"text","text":"and the former has a more intensive sense: or both,"},{"kind":"italic_en","text":"generous and munificent:"},{"kind":"text","text":"(L:) and the latter,"},{"kind":"italic_en","text":"good in disposition, and liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous:"},{"kind":"text","text":"(ISh, L, K:) pl., either of the former or of the latter,"},{"kind":"arabic","text_bw":"A^amojaAdN","text_ar":"اَمْجَادٌ"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"Almajiydu","text_ar":"المَجِيدُ"},{"kind":"text","text":"as an epithet of God signifies"},{"kind":"italic_en","text":"The Glorious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Great in dignity, who gives liberally,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bountifully:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the Bountiful and beneficent:"},{"kind":"text","text":"(L, TA:) and ↓"},{"kind":"arabic","text_bw":"AlmaAjidu","text_ar":"المَاجِدُ","orth_type":"arrow"},{"kind":"text","text":"is applied in the same manner: (L:) or the former,"},{"kind":"italic_en","text":"He who is glorified for his deeds."},{"kind":"text","text":"(T, L.) ―         -b3-"},{"kind":"arabic","text_bw":"majiydN","text_ar":"مَجِيدٌ"},{"kind":"text","text":"is also applied in the Kur as an epithet to the throne ("},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"text","text":") of God; and to the Kur-án; (L.) and signifies"},{"kind":"italic_en","text":"exalted; sublime;"},{"kind":"text","text":"(IAar. L, K;)"},{"kind":"italic_en","text":"noble;"},{"kind":"text","text":"(Zj, L, K;) when thus applied: (IAar, Zj, L, K:) but in ch. lxxxv., v. 15, for"},{"kind":"arabic","text_bw":"*uw AlEaro$i Almajiydi","text_ar":"ذُو العَرْشِ المَجِيدِ"},{"kind":"text","text":", some read"},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"arabic","text_bw":"AlEaro$i Almajiydu","text_ar":"العَرْشِ المَجِيدُ"},{"kind":"text","text":", making"},{"kind":"arabic","text_bw":"Almjyd","text_ar":"المجيد"},{"kind":"text","text":"an epithet of"},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"text","text":"; and in the same ch., v. 21, for"},{"kind":"arabic","text_bw":"huwa quraA=nN majiydN","text_ar":"هُوَ قُرَا=نٌ مَجِيدٌ"},{"kind":"text","text":", some read"},{"kind":"arabic","text_bw":"hw quroA=nN majiydK","text_ar":"هو قُرْا=نٌ مَجِيدٍ"},{"kind":"text","text":", making"},{"kind":"arabic","text_bw":"mjyd","text_ar":"مجيد"},{"kind":"text","text":"an epithet of God. (L.)"},{"kind":"arabic","text_bw":"Almajiydu","text_ar":"المَجِيدُ"},{"kind":"text","text":"alone also occurs in a trad. as meaning the Kur-án. (L.)"}],"source_refs":["S","L","K","ISh","TA","IAar","Zj"]}]},"classical_definitions":null}