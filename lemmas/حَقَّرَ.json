D9%8E%D9%82%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to disdain, to belittle, to despise, to look down","examples":[{"text":"لا تَحقِرَنَّ مِنَ المَعْرُوف شَيْئًا، وَلَو أنْ تَلقَى أخَاكَ بوجهٍ طليقٍ","english":"Do not belittle any good deed, even your meeting with your brother with a cheerful face"}]},{"pos":"verb","gloss":"to be vile, low, despicable"},{"pos":"verb","gloss":"to belittle, to depreciate, to undervalue","tags":["transitive"]},{"pos":"verb","gloss":"to humiliate","tags":["transitive"]}]},"etymology":null,"ipa":["/ħa.qa.ra/","/ħa.qu.ra/","/ħaq.qa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8612","headword_ar":"حَقُرَ","root":"Hqr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaqaArapN","text_ar":"حَقَارَةٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"HaqorN","text_ar":"حَقْرٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"Haqara","text_ar":"حَقَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaqorN","text_ar":"حَقْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Huqoriy~apN","text_ar":"حُقْرِيَّةٌ"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, contemptible, despicable, mean, paltry, abject, ignominious, base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile,"},{"kind":"text","text":"(S, A, Msb, K,) and"},{"kind":"italic_en","text":"held of no weight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worth."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Haqura","text_ar":"حَقُرَ"},{"kind":"arabic","text_bw":"fiY EayoniY","text_ar":"فِى عَيْنِى"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"Huqira","text_ar":"حُقِرَ"},{"kind":"text","text":", (so in a copy of the A,) and ↓"},{"kind":"arabic","text_bw":"tHAqr","text_ar":"تحاقر","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, contemptible, despicable, mean, paltry,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in my eye."},{"kind":"text","text":"(K, * TA.) And"},{"kind":"arabic","text_bw":"A_ilayohi nafosuhu","text_ar":"اـِلَيْهِ نَفْسُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taHaAqarato","text_ar":"تَحَاقَرَتْ","orth_type":"arrow"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his own self,"},{"kind":"text","text":")"},{"kind":"italic_en","text":"became contemptible,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his own estimation."},{"kind":"text","text":"(S, TA.) You say also,"},{"kind":"arabic","text_bw":"HaqorFA lahu waEaqorFA","text_ar":"حَقْرًا لَهُ وَعَقْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May he be contemptible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"despicable, and beget no children"},{"kind":"text","text":"]: (A, TA:) a form of imprecation. (TA.) And"},{"kind":"arabic","text_bw":"HaqorN naqorN","text_ar":"حَقْرٌ نَقْرٌ"},{"kind":"text","text":"[in which the latter word is an imitative sequent, or a corroborative: see"},{"kind":"arabic","text_bw":"HaqiyrN","text_ar":"حَقِيرٌ"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"Haqirota wanaqirota","text_ar":"حَقِرْتَ وَنَقِرْتَ"},{"kind":"italic_en","text":"Thou hast become very contemptible, despicable, mean, paltry,"},{"kind":"text","text":"&c.; syn."},{"kind":"arabic","text_bw":"Sirota HaqiyrFA naqiyrFA","text_ar":"صِرْتَ حَقِيرًا نَقِيرًا"},{"kind":"text","text":". (K.)       -A2-"},{"kind":"arabic","text_bw":"Haqarahu","text_ar":"حَقَرَهُ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HaqorN","text_ar":"حَقْرٌ"},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"Hq~rhu","text_ar":"حقّرهُ","orth_type":"arrow"},{"kind":"text","text":", (A,) inf. n."},{"kind":"arabic","text_bw":"taHoqiyrN","text_ar":"تَحْقِيرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AHtqrAhu","text_ar":"احتقراهُ","orth_type":"arrow"},{"kind":"text","text":", (S, A, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"AstHqrhu","text_ar":"استحقرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K;)"},{"kind":"italic_en","text":"He contemned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"despised, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it; held him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, to be contemptible, despicable, mean, paltry, abject, ignominious, base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile,"},{"kind":"text","text":"(S, A, Msb, K, TA,) and"},{"kind":"italic_en","text":"of no weight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worth."},{"kind":"text","text":"(Msb.) [Hence,]"},{"kind":"arabic","text_bw":"mano Huqira Hurima","text_ar":"مَنْ حُقِرَ حُرِمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who is contemned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"despised, is prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred,"},{"kind":"text","text":"from what is good]: a prov. (A.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n8614","headword_ar":"حَقْرٌ","root":"Hqr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaqaArapN","text_ar":"حَقَارَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}