مِنْ نُقَّادِهِ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"He is one of those who pick out the faults of poetry"},{"kind":"text","text":"]. (A.)"}],"source_refs":["Msb"]}]},"classical_definitions":null}