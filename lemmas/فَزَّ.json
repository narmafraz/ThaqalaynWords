ind":"text","text":"or"},{"kind":"italic_en","text":"eagerness."},{"kind":"text","text":"(O, K.)       -A3-"},{"kind":"arabic","text_bw":"faz~a fulaAnFA Eano mawoDiEihi","text_ar":"فَزَّ فُلَانًا عَنْ مَوْضِعِهِ"},{"kind":"text","text":", (A, O, * K,) inf. n."},{"kind":"arabic","text_bw":"faz~N","text_ar":"فَزٌّ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"He disturbed, removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, such a one from his place:"},{"kind":"text","text":"(A, O, * K:) or"},{"kind":"italic_en","text":"he frightened, and disturbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, such a one from his place, and made his courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to fly away:"},{"kind":"text","text":"(IDrd, TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"A^afaz~ahu","text_ar":"اَفَزَّهُ","orth_type":"arrow"},{"kind":"italic_en","text":"he frightened him;"},{"kind":"text","text":"(K;) or, as in some copies of the K,"},{"kind":"italic_en","text":"he disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted him;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"he frightened him, and disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled him, and made his courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to fly away."},{"kind":"text","text":"(S, O. *) [See also 10.]       -A4-"},{"kind":"arabic","text_bw":"faz~a","text_ar":"فَزَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faziyzN","text_ar":"فَزِيزٌ"},{"kind":"text","text":"(S, O, K, TA) and"},{"kind":"arabic","text_bw":"faz~N","text_ar":"فَزٌّ"},{"kind":"text","text":", (TA,) said of a wound,"},{"kind":"italic_en","text":"It became moist, and flowed,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"discharging its contents;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"faS~a","text_ar":"فَصَّ"},{"kind":"text","text":": and in like manner it is said of water [app. as meaning"},{"kind":"italic_en","text":"it oozed forth"},{"kind":"text","text":"]: (TA:) and of sweat, meaning"},{"kind":"italic_en","text":"It exuded;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"faS~a","text_ar":"فَصَّ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"fS","text_ar":"فص"},{"kind":"text","text":".)"}],"source_refs":["A","O","K","TA","IDrd","S"]}]}}