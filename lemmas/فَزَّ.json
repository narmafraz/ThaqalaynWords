{"lemma":"فَزَّ","slug":"فَزَّ","root":"ف.ز.ز","root_slug":"ف-ز-ز","root_link":"/words/roots/ف-ز-ز","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فَزَزْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فَزَزْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فَزَزْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فَزَزْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فَزَزْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فَزَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فَزَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فَزّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فَزَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فَزُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فَزَزْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفِزّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَفْزِز","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفِزِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفِزِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفِزّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفِزّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفِزُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفِزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْزِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفِزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَفْزِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفِزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَفْزِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفِزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفِزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفِزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفِزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفِزُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفِزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْزِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَفِزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفِزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَزَزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَزَزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n33778"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to jolt in fright"}]},"etymology":null,"ipa":["/faz.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33778","headword_ar":"فَزَّ","root":"fz","body":[{"kind":"text","text":", (A, O, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faz~N","text_ar":"فَزٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a gazelle)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afraid."},{"kind":"text","text":"(A, O, K.) ―         -b2-"},{"kind":"arabic","text_bw":"faz~a qalobuhu","text_ar":"فَزَّ قَلْبُهُ"},{"kind":"italic_en","text":"His heart heaved"},{"kind":"text","text":"by reason of fear. (O.) ―         -b3-"},{"kind":"arabic","text_bw":"faz~a Eanohu","text_ar":"فَزَّ عَنْهُ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, O)"},{"kind":"italic_en","text":"turned away from him."},{"kind":"text","text":"(A, O, K.) And"},{"kind":"italic_en","text":"He separated himself from him, and became alone."},{"kind":"text","text":"(A, O, K.)       -A2-"},{"kind":"arabic","text_bw":"faz~a","text_ar":"فَزَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fazaAzapN","text_ar":"فَزَازَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuzuwzapN","text_ar":"فُزُوزَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, O)"},{"kind":"italic_en","text":"became excited with ardour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerness."},{"kind":"text","text":"(O, K.)       -A3-"},{"kind":"arabic","text_bw":"faz~a fulaAnFA Eano mawoDiEihi","text_ar":"فَزَّ فُلَانًا عَنْ مَوْضِعِهِ"},{"kind":"text","text":", (A, O, * K,) inf. n."},{"kind":"arabic","text_bw":"faz~N","text_ar":"فَزٌّ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"He disturbed, removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, such a one from his place:"},{"kind":"text","text":"(A, O, * K:) or"},{"kind":"italic_en","text":"he frightened, and disturbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, such a one from his place, and made his courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to fly away:"},{"kind":"text","text":"(IDrd, TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"A^afaz~ahu","text_ar":"اَفَزَّهُ","orth_type":"arrow"},{"kind":"italic_en","text":"he frightened him;"},{"kind":"text","text":"(K;) or, as in some copies of the K,"},{"kind":"italic_en","text":"he disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted him;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"he frightened him, and disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled him, and made his courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to fly away."},{"kind":"text","text":"(S, O. *) [See also 10.]       -A4-"},{"kind":"arabic","text_bw":"faz~a","text_ar":"فَزَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faziyzN","text_ar":"فَزِيزٌ"},{"kind":"text","text":"(S, O, K, TA) and"},{"kind":"arabic","text_bw":"faz~N","text_ar":"فَزٌّ"},{"kind":"text","text":", (TA,) said of a wound,"},{"kind":"italic_en","text":"It became moist, and flowed,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"discharging its contents;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"faS~a","text_ar":"فَصَّ"},{"kind":"text","text":": and in like manner it is said of water [app. as meaning"},{"kind":"italic_en","text":"it oozed forth"},{"kind":"text","text":"]: (TA:) and of sweat, meaning"},{"kind":"italic_en","text":"It exuded;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"faS~a","text_ar":"فَصَّ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"fS","text_ar":"فص"},{"kind":"text","text":".)"}],"source_refs":["A","O","K","TA","IDrd","S"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%B2/","headword_ar":"فز","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=52524#e7c963","body_html":"فز: فزفلان: (وثب. محيط المحيط).<br>فز على فلان: هاجمه، انقض عليه. ففي النويري (مخطوطة رقم 2، ص161 و): قفز عليه باطني في زي حاج فقتله.<br>فز ل عجل، بادر إلى. (المقدمة 3: 363).<br>أفز: هاجم، هجم، انقض (هلو).<br>استفز: مرادف: استخف، يقال: استفز فلانا أي أثاره وأزعجه. ويقال: استفزته الخمرة، واستنفزه الفرح، واستفزه الخوف واستفزه الطمع، إلى غير ذلك. (معجم مسلم، عبد الواحد ص49، المقدمة 1: 229، المقري 3: 28).<br>جلد الفزاري: جلد الجاموس. (كاريت جغرافية ص96).<br>مستفزة: ملذة عابثة. ففي القلائد (ص248): ما علمت له صبوة: ولا حلت له إلى مستفزة حبوة."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=52524#602879","body_html":"<span class=\"title1\">فز</span><br><span>الفَزُ: وَلَدُ البَقَرَةِ، وجَمْعُه أفْزَازٌ. وفَزَ الظَبْيُ: أي فَزعَ. وأفَزَه: أي أفْزَعَه. والإِفْزَازُ: الذُّعْرُ. واسْتَفَزُّوه: أخْرَجُوه من دارِه. وفَز الجُرْحُ فَزِيْزاً: سالَ منه شَيْء. والافْتِزَازُ: أنْ يُقْتَطَعَ الشيْءُ فيُعْدَلَ عن عُظْمِ الشيْءِ الذي هو منه. وفَزَ عَنّي جانباً: أي عَدَلَ عَنّي وانْفَرَدَ، يَفِزُّ. وفَز قَلْبي من الخَوْفِ: شَخَصَ. ورَجُل فَز يَفِزُّ فَزَازَةً وفُزُوْزاً: وهو المُتَوَقِّدُ. وقد تَفزَزَ تَفَزُزاً: أي غَنَّى غِنَاءً.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=52524#80d302","body_html":"<h3>فز</h3><span class=\"sense\">1</span> فَزَّ, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَزٌّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) He (a gazelle) was, or became, frightened, or afraid. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> فَزَّ قَلْبُهُ His heart heaved by reason of fear. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>.) <span class=\"sub-sense\">b3:</span> فَزَّ عَنْهُ He (a man, O) turned away from him. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) And He separated himself from him, and became alone. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">A2:</span> فَزَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَزَازَةٌ and فُزُوزَةٌ, He (a man, O) became excited with ardour, or eagerness. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">A3:</span> فَزَّ فُلَانًا عَنْ مَوْضِعِهِ, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَزٌّ, (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) He disturbed, removed, or unsettled, such a one from his place: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or he frightened, and disturbed, or removed, or unsettled, such a one from his place, and made his courage (<abbr title=\"literally\">lit.</abbr> his heart) to fly away: (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) and [in like manner] ↓ أَفَزَّهُ he frightened him; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) or, as in some copies of the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, he disturbed or disquieted him; (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) or he frightened him, and disturbed or disquieted or unsettled him, and made his courage (<abbr title=\"literally\">lit.</abbr> his heart) to fly away. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, O. *) [See also 10.]<br><br><span class=\"sub-sense\">A4:</span> فَزَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَزِيزٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) and فَزٌّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) said of a wound, It became moist, and flowed, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) discharging its contents; and so فَصَّ: and in like manner it is said of water [<abbr title=\"apparently\">app.</abbr> as meaning it oozed forth]: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) and of sweat, meaning It exuded; and so فَصَّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in art. فص.) 2 فزّزهُ He (a man) rendered him powerful, or strong, and made him to overcome. (Ibn-'Abbád, O.) 4 أَفْزَ3َ see 1, latter half.<span class=\"sense\">8</span> افتزّ He (a man, O) overcame; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) or was, or became, powerful, or strong, and overcame: (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>:) and ابتزّ and ابتذّ signify the same: so in the Nawádir. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 10 استفزّهُ It (fear, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, O) excited him to lightness and unsteadiness; unsettled him. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) وَاسْتَفْزِزْ مَنِ اسْتَطَعتَ مِنْهُمْ بِصَوْتِكَ, in the <abbr title=\"The Quran\">Kur</abbr> [xvii. 66], is <abbr title=\"explained\">expl.</abbr> by <abbr title=\"al-Farrāʾ\">Fr</abbr> as meaning and excite thou to lightness and unsteadiness, or unsettle thou, when thou canst, with thy voice. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And in like manner, وَإِنْ كَادُوا لَيَسْتَفِزُّونَكَ مِنَ الأَرْضِ, in the same [xvii. 78], is <abbr title=\"explained\">expl.</abbr> by him (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) as meaning, And verily they were near to unsettling thee from the land: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) but some say the meaning is, they were near to frightening thee so as to excite thee to promptness of flight from the land. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And استفزّهُ عَنْ رَأْيِهِ He incited him, or excited him, to ignorance, foolishness, or wrong conduct, and levity, or unsteadiness, so as to make him swerve from his right sentiment, opinion, or judgment; like اِسْتَخَفَّهُ عن رأيه. (<abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr> in art. خف.) <span class=\"sub-sense\">b2:</span> He incited him, or excited him, to be promptly obedient and submissive to him and to that which he desired of him; like استخفّهُ. (<abbr title=\"The Kashshāf of al-Zamakhsharī\">Ksh</abbr> in xliii. 54.) <span class=\"sub-sense\">b3:</span> He expelled him (<abbr title=\"Tafsīr al-Jalālayn by al-Suyūṭī\">Jel</abbr> in xvii. 105, and <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) from the land, (<abbr title=\"Tafsīr al-Jalālayn by al-Suyūṭī\">Jel</abbr>,) or from his abode, and disturbed, or disquieted, or unsettled, him, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) so as to excite him to lightness and unsteadiness. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [See also 1, latter half.] <span class=\"sub-sense\">b4:</span> He, or it, deceived him, or beguiled him, so as to cast him into destruction. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b5:</span> He slew him: so the verb is <abbr title=\"explained\">expl.</abbr> by some in the <abbr title=\"The Quran\">Kur</abbr> xvii. 78, quoted above. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) فَزٌّ A light, or an active, man. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> And The offspring of the cow; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>;) [meaning,] of the wild cow: (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) because of its restlessness: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> أَفْزَازٌ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) فَزَّةٌ A leap with disquietude [or fright]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) قَعَدَ مُسْتَفَزًّا [so in a copy of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, but without the vowel-signs: in two other copies of the same, مُسْتَوْفِزًا, which belongs to art. وفز:] He sat in an uneasy posture. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b2:</span> فَرَسٌ مُسْتَفِزٌّ لِلْوَثْبِ وَالعَدْوِ [so in two copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, in art. طمر; in the <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, in that art., مُسْتَفِزُّ الوَثْبِ وَالعَدْوِ; probably a mistake for مُسْتَفَزّ; <abbr title=\"apparently\">app.</abbr> meaning, A horse in a state of excitement to leap and run.]"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=52524#b1ebc3","body_html":"<span class=\"title1\">فز</span><br><span>قال تعالى: وَاسْتَفْزِزْ مَنِ اسْتَطَعْتَ مِنْهُمْ بِصَوْتِكَ</span><br><span>[الإسراء/ 64] ، أي: أزعج، وقال تعالى: فَأَرادَ أَنْ يَسْتَفِزَّهُمْ مِنَ الْأَرْضِ</span><br><span>[الإسراء/ 103] ، أي: يزعجهم، وفَزَّنِي فلان، أي: أزعجني، والْفَزُّ: ولد البقرة، وسمّي بذلك لما تصوّر فيه من الخفّة، كما يسمّى عجلا لما تصوّر فيه من العجلة.</span>"}]}}