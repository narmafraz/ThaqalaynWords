","form":"تَقْضَض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَقْضُض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقَضّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقَضّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقُضّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقُضّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقَضّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقَضّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقُضّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقُضّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقَضُّوا","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقَضُّونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقُضُّونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقُضُّوا","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقْضَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَقْضُضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَقَضّ","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقَضّ","in_corpus":true,"count":19,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَقُضّ","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقُضّ","in_corpus":true,"count":19,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"قَضَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَضَضْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":239,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n35802","n35808"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B6%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35802","headword_ar":"قَٰضَّ","root":"qD","body":[{"kind":"text","text":", (S, M, A, &c.,) aor."},{"kind":"arabic","text_bw":"yaquD~u","text_ar":"يَقُضُّ"},{"kind":"text","text":", (S, M, Msb,) inf. n."},{"kind":"arabic","text_bw":"qaD~N","text_ar":"قَضٌّ"},{"kind":"text","text":", (M, Msb,)"},{"kind":"italic_en","text":"He bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforated,"},{"kind":"text","text":"a pearl, (S, M, A, K,) or a piece of wood. (Msb.)"},{"kind":"arabic","text_bw":"qaD~a dur~apF","text_ar":"قَضَّ دُرَّةً"},{"kind":"text","text":"is also used as signifying"},{"kind":"arabic","text_bw":"qaD~a EanohaA SadafahaA faA@sotaxorajahaA","text_ar":"قَضَّ عَنْهَا صَدَفَهَا فَا@سْتَخْرَجَهَا"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"He broke through the shell of the pearl so as to disclose it, and extracted it."},{"kind":"text","text":"] (TA.) ―         -b2-  Also, (M, A, K,) aor. and inf. n. as above, (M,)"},{"kind":"italic_en","text":"He broke"},{"kind":"text","text":"a thing: (M:) or"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"a stone"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"miqaD~","text_ar":"مِقَضّ"},{"kind":"text","text":", q. v.: (A:) or"},{"kind":"italic_en","text":"he broke, brayed, crushed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke in pieces by beating,"},{"kind":"text","text":"a thing; syn."},{"kind":"arabic","text_bw":"daq~","text_ar":"دَقّ"},{"kind":"text","text":"; (K;) as also ↓"},{"kind":"arabic","text_bw":"qaDoqaDa","text_ar":"قَضْقَضَ","orth_type":"arrow"},{"kind":"text","text":": (TA:) which latter also signifies"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"in pieces"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in any manner"},{"kind":"text","text":"]. (M, TA.) You say also,"},{"kind":"arabic","text_bw":"qaD~a AlHaAy^iTa","text_ar":"قَضَّ الحَايِطَ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"AljidaAra","text_ar":"الجِدَارَ"},{"kind":"text","text":", (TA,) meaning"},{"kind":"italic_en","text":"He threw down, pulled down, pulled to pieces, demolished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destroyed, with violence, the wall."},{"kind":"text","text":"(A, TA.) And ↓"},{"kind":"arabic","text_bw":"AlA^asadu yuqaDoqiDu","text_ar":"الاَسَدُ يُقَضْقِضُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fariysatahu","text_ar":"فَرِيسَتَهُ"},{"kind":"text","text":"(S, A)"},{"kind":"italic_en","text":"The lion breaks the limbs and bones of his prey."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"janobahu mino Sulobihi","text_ar":"جَنْبَهُ مِنْ صُلْبِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qaDoqaDotu","text_ar":"قَضْقَضْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I severed his side from his back-bone."},{"kind":"text","text":"(Sh.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"qaD~a Ealayohimu Alxayola","text_ar":"قَضَّ عَلَيْهِمُ الخَيْلَ"},{"kind":"text","text":", (S, M, A [in the first and last"},{"kind":"arabic","text_bw":"qaDaDonaA","text_ar":"قَضَضْنَا"},{"kind":"text","text":"]) aor. as above, (M, A,) and so the inf. n., (M,) (tropical:)"},{"kind":"italic_en","text":"He sent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent forth,"},{"kind":"text","text":"(M, TA,) or"},{"kind":"italic_en","text":"impelled,"},{"kind":"text","text":"(TA,) [or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"(see 7,)]"},{"kind":"italic_en","text":"the horses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"horsemen, against them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon them."},{"kind":"text","text":"(M, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"qaD~a Alwatida","text_ar":"قَضَّ الوَتِدَ"},{"kind":"text","text":", (JK, O, K,) aor. and inf. n. as above, (TA,)"},{"kind":"italic_en","text":"He pulled out"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qalaEa","text_ar":"قَلَعَ"},{"kind":"text","text":", in some copies of the K"},{"kind":"arabic","text_bw":"qaTaEa","text_ar":"قَطَعَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"the wooden pin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peg"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake."},{"kind":"text","text":"(JK, O, K, TA.)       -A2-"},{"kind":"arabic","text_bw":"qaD~a Als~awiyqa","text_ar":"قَضَّ السَّوِيقَ"},{"kind":"text","text":", (Zj, K,) aor. and inf. n. as above, (Zj,) (tropical:)"},{"kind":"italic_en","text":"He put into the"},{"kind":"arabic","text_bw":"swyq","text_ar":"سويق"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"meal of parched barley, or gruel made thereof,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"something dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard, such as sugar, or"},{"kind":"arabic","text_bw":"qanod","text_ar":"قَنْد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"sugar-candy"},{"kind":"text","text":"]; (Zj, K;) as also ↓"},{"kind":"arabic","text_bw":"A^aqaD~ahu","text_ar":"اَقَضَّهُ","orth_type":"arrow"},{"kind":"text","text":": (A, Sgh, K:) and ↓"},{"kind":"arabic","text_bw":"qaDoqaDa","text_ar":"قَضْقَضَ","orth_type":"arrow"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"he put much sugar into his"},{"kind":"arabic","text_bw":"swyq","text_ar":"سويق"},{"kind":"text","text":". (IAar.)       -A3-"},{"kind":"arabic","text_bw":"qaDiDotu AlT~aEaAma","text_ar":"قَضِضْتُ الطَّعَامَ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"qaDiDotu minohu","text_ar":"قَضِضْتُ مِنْهُ"},{"kind":"text","text":", (S, M, K,) [aor."},{"kind":"arabic","text_bw":"A^aqaD~u","text_ar":"اَقَضُّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"I found pebbles,"},{"kind":"text","text":"(S, M, K,) or"},{"kind":"italic_en","text":"dust,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"between my teeth in eating the food."},{"kind":"text","text":"(S, M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"qaD~ AlT~aEaAmu","text_ar":"قَضّ الطَّعَامُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqaD~u","text_ar":"يَقَضُّ"},{"kind":"text","text":", (S, A, K,) inf. n."},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":", (A, TA,)"},{"kind":"italic_en","text":"The food had in it pebbles,"},{"kind":"text","text":"(S, * A, * K, * TA,) or"},{"kind":"italic_en","text":"dust,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"which got between the teeth of the eater:"},{"kind":"text","text":"(S, * K, * TA:) from"},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":"[q. v.]: (S:) the verb is like"},{"kind":"arabic","text_bw":"Ealima","text_ar":"عَلِمَ"},{"kind":"text","text":", in this sense as well as in that next preceding; intrans. as well as trans.: (TA:) and ↓"},{"kind":"arabic","text_bw":"A^aqaD~a","text_ar":"اَقَضَّ","orth_type":"arrow"},{"kind":"text","text":"signifies [in like manner]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(food)"},{"kind":"italic_en","text":"had in it pebbles and dust."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qaD~a All~aHomu","text_ar":"قَضَّ اللَّحْمُ"},{"kind":"text","text":", (IAar, M,) second pers."},{"kind":"arabic","text_bw":"qaDiDota","text_ar":"قَضِضْتَ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yaqaD~u","text_ar":"يَقَضُّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"The flesh-meat had in it"},{"kind":"arabic","text_bw":"qaDaD","text_ar":"قَضَض"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"which got between the teeth of its eater, like small pebbles:"},{"kind":"text","text":"(IAar:) or"},{"kind":"italic_en","text":"fell upon pebbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust, which one consequently found in the eating of it."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"qaD~ati AlbaDoEapu biAlt~uraAbi","text_ar":"قَضَّتِ البَضْعَةُ بِالتُّرَابِ"},{"kind":"italic_en","text":"The piece of flesh-meat had some dust upon it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^aqaD~at","text_ar":"اَقَضَّت","orth_type":"arrow"},{"kind":"text","text":". (M, K.) An Arab of the desert, describing the effect of rains, said,"},{"kind":"arabic","text_bw":"lawo A^aloqayota baDoEapF maA qaD~ato","text_ar":"لَوْ اَلْقَيْتَ بَضْعَةً مَا قَضَّتْ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"If thou wert to throw down a piece of flesh-meat,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it would not become dusty;"},{"kind":"text","text":"meaning, by reason of the abundance of the herbage. (M.) You say also,"},{"kind":"arabic","text_bw":"qaD~a AlmakaAnu","text_ar":"قَضَّ المَكَانُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqaD~u","text_ar":"يَقَضُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The place had in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon it,"},{"kind":"arabic","text_bw":"qaDaD","text_ar":"قَضَض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"small pebbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"A^aqaD~a","text_ar":"اَقَضَّ","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) and ↓"},{"kind":"arabic","text_bw":"AstqD~","text_ar":"استقضّ","orth_type":"arrow"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"qaD~a AlfiraA$u","text_ar":"قَضَّ الفِرَاشُ"},{"kind":"text","text":", aor. and inf. n. as in the next preceding instance,"},{"kind":"italic_en","text":"The bed became overspread with dust."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"Ealayohi AlmaDojaEu","text_ar":"عَلَيْهِ المَضْجَعُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aqaD~a","text_ar":"اَقَضَّ","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K *)"},{"kind":"italic_en","text":"The bed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place where he lay upon his side, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rough to him, and dusty:"},{"kind":"text","text":"(S, K: *) or"},{"kind":"italic_en","text":"had"},{"kind":"arabic","text_bw":"qaDaD","text_ar":"قَضَض"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"small pebbles, upon it:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, uneasy to him;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"qaD~a Elyh","text_ar":"قَضَّ عليه"},{"kind":"text","text":": (M, TA:) or both signify"},{"kind":"italic_en","text":"he did not sleep:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his sleep was uneasy."},{"kind":"text","text":"(TA.) And [hence]"},{"kind":"arabic","text_bw":"Ealayohi Alham~u","text_ar":"عَلَيْهِ الهَمُّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aqaD~a","text_ar":"اَقَضَّ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety, disquieted him"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","M","Msb","A","K","TA","JK","O","Zj","Sgh","IAar"]},{"entry_id":"n35808","headword_ar":"قَضٌّ","root":"qD","body":[{"kind":"text","text":"A place"},{"kind":"italic_en","text":"in which are"},{"kind":"arabic","text_bw":"qaDaD","text_ar":"قَضَض"},{"kind":"text","text":", (M, K,) meaning"},{"kind":"italic_en","text":"small pebbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust;"},{"kind":"text","text":"(M;) as also ↓"},{"kind":"arabic","text_bw":"qaDiDN","text_ar":"قَضِضٌ","orth_type":"arrow"},{"kind":"text","text":". (M, K.) And"},{"kind":"arabic","text_bw":"A^aroDN qaD~apN","text_ar":"اَرْضٌ قَضَّةٌ"},{"kind":"text","text":", (M,) or ↓"},{"kind":"arabic","text_bw":"qaD~apN","text_ar":"قَضَّةٌ","orth_type":"arrow"},{"kind":"text","text":"[alone, as though a subst.], (K,) and ↓"},{"kind":"arabic","text_bw":"qiD~apN","text_ar":"قِضَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"Land in which are pebbles:"},{"kind":"text","text":"(S, M, K:) and"},{"kind":"italic_en","text":"land abounding with stones:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, land, the ground of which is sand, and by the side of which is plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard, and elevated land:"},{"kind":"text","text":"(Lth in explanation of the last of these words, and K:) pl. of the last,"},{"kind":"arabic","text_bw":"qiDaDN","text_ar":"قِضَضٌ"},{"kind":"text","text":". (Lth.) Also, Food"},{"kind":"italic_en","text":"in which are pebbles and dust:"},{"kind":"text","text":"(TA:) and flesh-meat"},{"kind":"italic_en","text":"that has fallen upon pebbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"upon stones,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pebbles,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"which one consequently finds in eating it:"},{"kind":"text","text":"(M, TA:) and anything"},{"kind":"italic_en","text":"having dust in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon it;"},{"kind":"text","text":"as food, or a garment, &c.: (M, TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"qaDiDN","text_ar":"قَضِضٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) or ↓"},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) but when applied to a place, the author of the K writes it"},{"kind":"arabic","text_bw":"qaDiDN","text_ar":"قَضِضٌ"},{"kind":"text","text":", (TA,) food"},{"kind":"italic_en","text":"containing pebbles,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"dust,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"getting between the teeth of the eater."},{"kind":"text","text":"(S, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"qaDaDN","text_ar":"قَضَضٌ"},{"kind":"text","text":", in two places."}],"source_refs":["M","K","S","TA"]}]}}