"role":"present_2mp","form":"تَرْقُدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْقُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْقُد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْقُد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْقُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْقُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْقُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْقُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْقُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْقُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْقُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرْقُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْقُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَقَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَقَدْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n16324"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%82%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sleep, to fall asleep","examples":[{"text":"وَتَحْسَبُهُمْ أَيْقَاظًا وَهُمْ رُقُودٌ […]","english":"And you think they are awake while they are sleeping"}]},{"pos":"verb","gloss":"to recline, to lie down, to repose"},{"pos":"verb","gloss":"to lie dormant"},{"pos":"verb","gloss":"to relax"},{"pos":"verb","gloss":"to put to sleep, to put to bed"},{"pos":"noun","gloss":"verbal noun of رَقَدَ (raqada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"sleep"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16324","headword_ar":"رَقَدَ","root":"rqd","body":[{"kind":"text","text":", (S, Msb,) aor."},{"kind":"text","text":", inf.n."},{"kind":"arabic","text_bw":"ruqaAdN","text_ar":"رُقَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruquwdN","text_ar":"رُقُودٌ"},{"kind":"text","text":"(JK, S, A, Msb, K) and"},{"kind":"arabic","text_bw":"raqodN","text_ar":"رَقْدٌ"},{"kind":"text","text":"(S, Msb, K) and perhaps also"},{"kind":"arabic","text_bw":"maroqadN","text_ar":"مَرْقَدٌ"},{"kind":"text","text":"[q. v.], (TA,)"},{"kind":"italic_en","text":"He slept,"},{"kind":"text","text":"(JK, S, A, Msb, K,) accord. to some, specially, (Msb, K,)"},{"kind":"italic_en","text":"by night;"},{"kind":"text","text":"(JK, Msb, K) but it correctly means,"},{"kind":"italic_en","text":"whether by night or by day;"},{"kind":"text","text":"as is shown by verse 17 of ch. xviii. of the Kur-án: (Msb:) the assertion that it means, specially, by night, is weak: (TA:) accord. to Lth,"},{"kind":"arabic","text_bw":"ruquwdN","text_ar":"رُقُودٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"by night;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruqaAdN","text_ar":"رُقَادٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"by day:"},{"kind":"text","text":"but the Arabs used both of these words as meaning the"},{"kind":"italic_en","text":"sleeping by night"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"by day."},{"kind":"text","text":"(T, TA.) You say,"},{"kind":"arabic","text_bw":"maAbiY ruquwdN","text_ar":"مَابِى رُقُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruqAdN","text_ar":"رُقادٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is not in me any sleep"},{"kind":"text","text":"]. (A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"raqada Eani AlA^amori","text_ar":"رَقَدَ عَنِ الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He abstained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back, from the affair."},{"kind":"text","text":"(Msb, TA.) And"},{"kind":"arabic","text_bw":"raqada Eano Dayofihi","text_ar":"رَقَدَ عَنْ ضَيْفِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He neglected his guest;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he did not pay attention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frequent attention, to his guest."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"raqada Alv~awobu","text_ar":"رَقَدَ الثَّوْبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"raqodN","text_ar":"رَقْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruqaAdN","text_ar":"رُقَادٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The garment became old and worn out, and no longer of use;"},{"kind":"text","text":"(A, * TA;) like"},{"kind":"arabic","text_bw":"naAma","text_ar":"نَامَ"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"raqadati Als~uwqu","text_ar":"رَقَدَتِ السُّوقُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The market became stagnant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull, with respect to traffic;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"naAmat","text_ar":"نَامَت"},{"kind":"text","text":". (Th, TA.) And"},{"kind":"arabic","text_bw":"raqada AlHar~u","text_ar":"رَقَدَ الحَرُّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The heat remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"subsided."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"rakada","text_ar":"رَكَدَ"},{"kind":"text","text":".])"}],"source_refs":["S","Msb","JK","A","K","TA"]}]}}