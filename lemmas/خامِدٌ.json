{"lemma":"خامِدٌ","slug":"خامِدٌ","root":"خ.م.د","root_slug":"خ-م-د","root_link":"/words/roots/خ-م-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خامِد","root":"خمد","pos":"N","occurrence_count":2},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n11467"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D9%85%D9%90%D8%AF%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11467","headword_ar":"خَامِدٌ","root":"xmd","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Silent; from whom no voice is heard:"},{"kind":"text","text":"and in like manner, ↓"},{"kind":"arabic","text_bw":"muxomidN","text_ar":"مُخْمِدٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless, and silent: still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless; having disposed and submitted himself to an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(L.)"},{"kind":"arabic","text_bw":"xaAmiduwna","text_ar":"خَامِدُونَ"},{"kind":"text","text":"in the Kur xxxvi. 28 means (assumed tropical:)"},{"kind":"italic_en","text":"Silent and dead"},{"kind":"text","text":": (Jel:) or"},{"kind":"italic_en","text":"silent; having died, and become like extinguished ashes."},{"kind":"text","text":"(Zj, Bd. *)"}],"source_refs":["Jel"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D9%85%D8%AF/","headword_ar":"خامدين","entries":[{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=94311#4029d9","body_html":"<span class=\"title1\">خ م د [خامدين]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: خامِدِينَ .</span><br><span>قال: أصبح قوم صالح في ديارهم ميتين.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت لبيد بن ربيعة وهو يقول:</span><br><span>خلّوا ثيابهم على عوارتهم </span><span class=\"red\">...</span><span> فهم بأفنية البيوت خمود </span>"}]}}