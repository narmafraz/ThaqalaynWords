h_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D9%81%D9%8E%D8%B1%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33432","headword_ar":"انفرد","root":"frd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"farada","text_ar":"فَرَدَ","orth_type":"arrow"},{"kind":"text","text":"signify the same: (S:) the latter, aor."},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"furuwdN","text_ar":"فُرُودٌ"},{"kind":"text","text":",] is expl. by Lth as signifying"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone, by himself, apart from others,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solitary:"},{"kind":"text","text":"(T, L:) and thus"},{"kind":"arabic","text_bw":"Anfrd binafosihi","text_ar":"انفرد بِنَفْسِهِ"},{"kind":"text","text":"signifies. (Msb.) And"},{"kind":"arabic","text_bw":"Anfrd Eanohu","text_ar":"انفرد عَنْهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separate, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, and alone."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Anfrd bifulAani","text_ar":"انفرد بِفُلاَنِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Astfrdhu","text_ar":"استفردهُ","orth_type":"arrow"},{"kind":"text","text":"are syn. [as meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone with such a one"},{"kind":"text","text":"]. (M, A, K.) And"},{"kind":"arabic","text_bw":"Anfrd","text_ar":"انفرد"},{"kind":"arabic","text_bw":"baAlA^amori","text_ar":"بَالاَمْرِ"},{"kind":"text","text":", (AZ, T, M, L, K,) and"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"biraA^oyihi","text_ar":"بِرَاْيِهِ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"farada","text_ar":"فَرَدَ","orth_type":"arrow"},{"kind":"text","text":", (AZ, T, M, L, K,) aor."},{"kind":"text","text":", (AZ, T, M, L,) inf. n."},{"kind":"arabic","text_bw":"furuwdN","text_ar":"فُرُودٌ"},{"kind":"text","text":"; (AZ, L;) and ↓"},{"kind":"arabic","text_bw":"farida","text_ar":"فَرِدَ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"faruda","text_ar":"فَرُدَ","orth_type":"arrow"},{"kind":"text","text":", (M, L, K,) mentioned by Lh; (M, L;) and ↓"},{"kind":"arabic","text_bw":"Afrd","text_ar":"افرد","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"tfr~d","text_ar":"تفرّد","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Astfrd","text_ar":"استفرد","orth_type":"arrow"},{"kind":"text","text":"; (S, M, L, K;) signify alike; (AZ, T, S, M, L, K;) i. e."},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone; independent of others; without any to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him; in the affair,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in such a thing,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in his opinion:"},{"kind":"text","text":"(the lexicons passim: [see"},{"kind":"arabic","text_bw":"Aisotabad~a","text_ar":"اِسْتَبَدَّ"},{"kind":"text","text":":]) and [in like manner]"},{"kind":"arabic","text_bw":"biAlmaAli","text_ar":"بِالمَالِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tfr~d","text_ar":"تفرّد","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he was without any to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him in the property"},{"kind":"text","text":"]. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"laA^uqaAtilan~ahumo Ht~aY tanofaridu saAlifatiY","text_ar":"لَاُقَاتِلَنَّهُمْ حتَّى تَنْفَرِدُ سَالِفَتِى"},{"kind":"text","text":", occurring in a trad., means (assumed tropical:)"},{"kind":"italic_en","text":"I will assuredly fight with them until I die;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"until the side of my neck shall become separate"},{"kind":"text","text":"from my body; because its separation can be only by death. (L.)"}],"source_refs":["S","T","L","AZ","M","K"]}]},"classical_definitions":null}