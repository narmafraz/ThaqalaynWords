role":"present_2mp","form":"تَلْيَسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَلْيَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَلْيَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَلْيَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَلْيَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَلْيَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَلْيَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَلْيَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَلْيَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْيَسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَلْيَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"لَيِسْتُ","in_corpus":true,"count":64,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"لَيِسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَلْيَس","in_corpus":true,"count":62,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَلْيَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1680,"cross_references":{"qac":{"found":true,"lemma_key":"لَيِسَ","root":"ليس","pos":"V","occurrence_count":89},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","conj","noun","particle","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n38170"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"not to be","tags":["copulative","defective"],"examples":[{"text":"قَالَ يَا قَوْمِ لَيْسَ بِي ضَلَالَةٌ وَلَٰكِنِّي رَسُولٌ مِن رَبِّ ٱلْعَالَمِينَ","english":"He said, “O my people, there is not error in me, but I am a messenger from the Lord of the worlds.”"}]},{"pos":"verb","gloss":"except","tags":["rare"],"examples":[{"text":"جَاءَ النَّاسُ لَيْسَ زُهَيْرًا","english":"People came, except for Zuhayr"}]},{"pos":"particle","gloss":"Used to negate verbs","examples":[{"text":"وَلَيْسَ يَصِحُّ فِي الْأَفْهَامِ شَيْءٌ\nإِذَا ٱحْتَاجَ النَّهَارُ إِلَى دَلِيلِ\nwa-laysa yaṣiḥḥu fī l-ʔafhāmi šayʔun","english":"(please add an English translation of this quotation)"}]},{"pos":"conj","gloss":"not (refers to a preceding context)","tags":["rare"],"examples":[{"text":"أَيْنَ الْمَفَرُّ وَالْإِلَهُ الطَّالِبُ\n وَالْأَشْرَمُ الْمَغْلُوبُ لَيْسَ ٱلْغَالِبُ"}]},{"pos":"verb","gloss":"to be valiant, to be brave, to be courageous"},{"pos":"noun","gloss":"verbal noun of لَيِسَ (layisa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"masculine plural of أَلْيَس (ʔalyas)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"Uncertain. Traditionally taken to be a contracted pronunciation of either a verb لَيِسَ (layisa), whose ultimate origin is in turn unknown or unexplored, or of لَا (lā, “not”) + an existential أَيْس (ʔays) that has a proposed etymology in Proto-Semitic *ys < *yt. This existential would be a native cognate to Hebrew יֵשׁ (yēš) and Akkadian 𒌇 (/⁠išu⁠/, “to have or own; to be”, also used copulatively), although Al-Jallad (2018) expresses doubt that it is anything more than a back-formation from the negative, in other words implying that لَا (lā, “not”) + *أَيْس (*ʔays, existential) is just a folk etymology for لَيْسَ (laysa) from which أَيْس (ʔays) was created artificially. Al-Jallad instead proceeds to identify a form of لَيْسَ (laysa) in a Safaitic inscription dated between the first century BC and the fourth century AD, whose form, he says, invalidates the possibility of an origin in a verb لَيِسَ (layisa); he thereby argues that لَيْسَ (laysa) may either be a loan from Neo-Assyrian 𒆷𒀸𒋗 (la-aš-šu /⁠laššu⁠/, “there is not”) or from Taymanitic 𐪁𐪚𐪏 (lys³ /⁠lāʾis, lāyis⁠/, “not existing or being”)."},"ipa":["/laj.sa/","/la.ji.sa/"]}