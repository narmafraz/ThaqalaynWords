{"lemma":"خَلَّى","slug":"خَلَّى","root":"خ.ل.#","root_slug":"خ-ل-_","root_link":"/words/roots/خ-ل-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَلَّيْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَلَّيْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَلَّيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَلَّيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَلَّيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَلَّى","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَلَّت","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَلَّيا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَلَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَلَّوْا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَلَّيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُخَلّ","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُخَلَّى","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُخَلِّي","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُخَلِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُخَلِّي","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُخَلَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُخَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُخَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُخَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُخَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُخَلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُخَلَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُخَلِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُخَلّ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُخَلَّى","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُخَلِّي","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُخَلّ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُخَلَّى","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُخَلِّي","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُخَلَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخَلَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخَلُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخَلَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُخَلِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخَلّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَلَّيْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَلَّيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُخَلَّى","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخَلَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَلِّي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخَلِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":107,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n11419"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"empty, free, void"},{"pos":"adj","gloss":"single, having no relationship"},{"pos":"adj","gloss":"carefree","examples":[{"text":"تَطَاوَلَ لَيْلُكَ بِٱلْأَثْمُدِ\n وَنَامَ ٱلْخَلِيُّ وَلَمْ تَرْقُدِ","english":"Long was your night at al-Athmud.\n The carefree one slept but you did not slumber."}]}]},"etymology":null,"ipa":["/xa.lijj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11419","headword_ar":"خَلَّى","root":"xlw","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He left"},{"kind":"text","text":"a place, &c.,"},{"kind":"italic_en","text":"empty, vacant, void, devoid, destitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied."},{"kind":"text","text":"] Hence,"},{"kind":"arabic","text_bw":"xl~Y makaAnahu","text_ar":"خلّى مَكَانَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left his place vacant;"},{"kind":"text","text":"] meaning (tropical:)"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(TA, and so in Ham p. 478:) a meaning assigned in the K to ↓"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا","orth_type":"arrow"},{"kind":"arabic","text_bw":"makaAnuhu","text_ar":"مَكَانُهُ"},{"kind":"text","text":", and by IAar to"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"alone, without tesh-deed; but when"},{"kind":"arabic","text_bw":"mkAnh","text_ar":"مكانه"},{"kind":"text","text":"is added, it is with teshdeed. (TA.) And (assumed tropical:)"},{"kind":"italic_en","text":"He went his way."},{"kind":"text","text":"(Ham p. 379.) And"},{"kind":"arabic","text_bw":"xl~Y sabiylahu","text_ar":"خلّى سَبِيلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left his way free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open, to him"},{"kind":"text","text":"]. (S, TA.) And"},{"kind":"arabic","text_bw":"xl~Y bayonahumaA","text_ar":"خلّى بَيْنَهُمَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left the way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"space, free between them two;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he left them two free, each to do to the other as he pleased"},{"kind":"text","text":"]. (TA.) [And"},{"kind":"arabic","text_bw":"xl~Y bayonahu wabayona ka*aA","text_ar":"خلّى بَيْنَهُ وَبَيْنَ كَذَا"},{"kind":"italic_en","text":"He left him free access to such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xl~Y bayonahu wa bayona nafosihi","text_ar":"خلّى بَيْنَهُ وَ بَيْنَ نَفْسِهِ"},{"kind":"italic_en","text":"He left him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, alone;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^ahomalahu","text_ar":"اَهْمَلَهُ"},{"kind":"text","text":". (S and O and K in art."},{"kind":"arabic","text_bw":"hml","text_ar":"همل"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"xl~Ahu wafulaAnFA","text_ar":"خلّاهُ وَفُلَانًا"},{"kind":"italic_en","text":"He left him to do as he pleased with such a one."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xl~Y AlA^amora","text_ar":"خلّى الاَمْرَ"},{"kind":"italic_en","text":"He left, left alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let alone, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"txl~Y","text_ar":"تخلّى","orth_type":"arrow"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"xAlAhu","text_ar":"خالاهُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"xilaA='N","text_ar":"خِلَا=ءٌ"},{"kind":"text","text":". (TA.) For"},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"leaving,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to be alone."},{"kind":"text","text":"(Har p. 123.) ["},{"kind":"arabic","text_bw":"xl~Ahu","text_ar":"خلّاهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xl~Y Eanohu","text_ar":"خلّى عَنْهُ"},{"kind":"text","text":"both signify"},{"kind":"italic_en","text":"He left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left alone, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"] It is said in a trad.,"},{"kind":"arabic","text_bw":"xl~Y Eanohumo","text_ar":"خلّى عَنْهُمْ"},{"kind":"arabic","text_bw":"A^arobaEiyna EaAmFA","text_ar":"اَرْبَعِينَ عَامًا"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"left them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left them alone, and turned from them, forty years."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"xl~Ahu lika*aA","text_ar":"خلّاهُ لِكَذَا"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left him, vacant, unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure, for such a thing."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":"also signifies The act of"},{"kind":"italic_en","text":"loosing; contr. of"},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":". (IAar, K in art."},{"kind":"arabic","text_bw":"AbD","text_ar":"ابض"},{"kind":"text","text":".) [Hence,]"},{"kind":"arabic","text_bw":"xl~Y Eani Al$~aYo'i","text_ar":"خلّى عَنِ الشَّىْءِ"},{"kind":"text","text":", (JK, S, * TA,) in the K ↓"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا","orth_type":"arrow"},{"kind":"text","text":", without teshdeed, but this requires consideration, (TA,)"},{"kind":"italic_en","text":"He dismissed, loosed, let loose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let go, the thing."},{"kind":"text","text":"(JK, K, TA.) ―         -b3-  [And hence"},{"kind":"arabic","text_bw":"xl~Ahu","text_ar":"خلّاهُ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"He left it, permitted it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allowed it:"},{"kind":"text","text":"see the pass. part. n., below.]       -A2-"},{"kind":"arabic","text_bw":"xul~iyato","text_ar":"خُلِّيَتْ"},{"kind":"text","text":", said of a she-camel such as is termed"},{"kind":"arabic","text_bw":"xaliy~ap","text_ar":"خَلِيَّة"},{"kind":"text","text":"; and hence, of a cooking-pot: see 1 in art."},{"kind":"arabic","text_bw":"xlY","text_ar":"خلى"},{"kind":"text","text":"."}],"source_refs":["K","TA","God"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D9%84%D9%89/","headword_ar":"خلى","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10110#caa8ca","body_html":"<h3>خل</h3>ى<span class=\"sense\">1</span> خَلَى, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـْ (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> خَلْىٌ; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and ↓ اختلى; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) He cut the herbage called خَلًى: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or he plucked it up. (<abbr title=\"El-Lihyanee (Abu al-Ḥasan al-Liḥyānī)\">Lh</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) Hence, in a <abbr title=\"tradition (hadith), حَدِيْثٌ\">trad.</abbr>, (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) respecting the declaration of the sacredness of Mekkeh, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) خَلَاهَا ↓ لَا يُخْتَلَى, (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) i. e. [Its fresh herbage] shall not be cut. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b2:</span> خَلَى الدَّابَّةَ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or المَاشِيَةَ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> as above; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) or الماشية ↓ اخلى, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> إِخْلَآءٌ; (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, as from the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) He cut the herbage called خَلًى (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) for the beast, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or for the cattle: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) and he fed the beast, or the cattle, with خَلًى. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> خَلَى الشَّعِيرَ He collected the barley in a مِخْلَاة. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b4:</span> خَلَى القِدْرِ, (<abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> as above, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He put firewood beneath the cooking-pot: or he put flesh-meat into the cooking-pot. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And القِدْرِ ↓ اخلى (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He kindled a fire for the cooking-pot with camels', or similar, dung; as though he put خَلًى to it. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) and ↓ أُخْلِيَتْ, said of a cooking-pot, (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) It had firewood put to it, like as a she-camel has خَلًى put to her, and kindled beneath it: or, as some relate a verse in which it occurs, ↓ خُلِّيَتْ, [belonging to art. خلو,] having a similar meaning, from this verb said of a she-camel such as is termed خَلِيَّة, meaning “ she had ” a young one “ put to her. ” (<abbr title=\"Sharḥ Dīwān al-Ḥamāsah by al-Tabrīzī\">Ham</abbr> p. 663.) <span class=\"sub-sense\">b5:</span> خَلَى الفَرَسَ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or خَلَاهُ اللِّجَامَ, (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He put the bit in the mouth of the horse, (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) like fresh خَلًى. (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>.) <span class=\"sub-sense\">b6:</span> And خَلَى اللِّجَامَ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) عَنِ الفَرَسِ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> and <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> as above, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He pulled out the bit [from the mouth of the horse]. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">A2:</span> See also 1, last sentence, in art. خلو.<span class=\"sense\">2</span> خَلَّىَ see خَلًى, below: <span class=\"sub-sense\">A2:</span> and see also 1.<span class=\"sense\">3</span> خَاْلَىَ mentioned in this art. in the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>: see art. خلو.<span class=\"sense\">4</span> إِخلى المَاشِيَةَ, (<abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> إِخْلَآءٌ, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) said of God, He made خَلًى to grow for the cattle. (<abbr title=\"El-Lihyanee (Abu al-Ḥasan al-Liḥyānī)\">Lh</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> See also 1, in three places.<br><br><span class=\"sub-sense\">A2:</span> اخلت الأَرْضُ The land became abundant in خَلًى. (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> [And hence,] اخلى (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He uttered words, or expressions, without any great meaning. (<abbr title=\"Sharḥ Dīwān al-Ḥamāsah by al-Tabrīzī\">Ham</abbr> p. 391.) 7 انخلى, said of خَلًى, It was cut. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) 8 إِخْتَلَىَ see 1, in two places. [Hence,] السَّيْفُ يَخْتَلِى<br><br>الأَيْدِى وَالأَرْجُلَ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The sword cuts off the arms and the legs. (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 12 اخلولى He constantly drank milk. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) خَلًى Fresh, green, or juicy, herbage: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Ibn Barrī (d. 1187 CE), author of Annotations on the Ṣiḥāḥ with al-Bustī\">IB</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) that which is dry is termed حَشِيش [but see this word]: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, from the <abbr title=\"The Kifāyat al-Mutaḥaffiẓ (of Ibn al-Ajdābī)\">Kf</abbr>:) or dry حَشِيش: (so in one place in the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>: [<abbr title=\"apparently\">app.</abbr> a mistake occasioned by an omission:]) or <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> رُطْبٌ, (<abbr title=\"Ibn Barrī (d. 1187 CE), author of Annotations on the Ṣiḥāḥ with al-Bustī\">IB</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) with damm, (<abbr title=\"Ibn Barrī (d. 1187 CE), author of Annotations on the Ṣiḥāḥ with al-Bustī\">IB</abbr>,) [i. e. fresh, or green, pasture; or such as consists of the herbs, or leguminous plants, of the رَبِيع; or of these and of trees or shrubs:] or herbage that is cut, of the herbs, or leguminous plants, of the ربيع: (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>:) or, <abbr title=\"according\">accord.</abbr> to [the Imám] Mohammad, anything that is eaten as pasture, not [growing] upon a stem: (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>:) or slender herbage as long as it remains fresh, green, or juicy: (<abbr title=\"Ibn al-Athīr al-Jazari\">IAth</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) it is also written ↓ خَلَآءٌ, with medd, like قَضَآءٌ: (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>:) <abbr title=\"noun of unity, وَاحِدَةٌ or وَاحِدٌ\">n. un.</abbr> خَلَاةٌ: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or this signifies any herb (بَقْلَة) that one pulls up: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> أَخْلَآءٌ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) a <abbr title=\"plural, جَمْعٌ\">pl.</abbr> sometimes used [<abbr title=\"apparently\">app.</abbr> as meaning sorts of خَلًى]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [Hence,] عَبْدٌ وَخَلًى فِى يَدَيْهِ [A slave with fresh herbage in his hands, or arms]; meaning, though a slave, yet rich, or possessing sufficiency: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) a <abbr title=\"proverb, مَثَلٌ\">prov.</abbr>, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>,) applied to the case of property possessed by him who does not deserve it: or, as some relate it, فى ↓ وَخُلِّىَ يديه [having fresh herbage put in his hands, or arms]: (<abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>:) but this latter reading is disallowed by Yaakoob: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) [see other readings, not belonging to this art., in Freytag's Arab. <abbr title=\"proverb, مَثَلٌ\">Prov.</abbr> ii. 75:] هٰذَا, or هُوَ, is understood before عَبْدٌ. (<abbr title=\"al-Maydānī's Proverbs\">Meyd</abbr>.) And مَا كُنْتُ خَلَاةً لِمَوْعِدَةٍ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) I was not a breaker of a promise. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) and [hence also, <abbr title=\"apparently\">app.</abbr>, if this be the right reading,] إِنَّهُ لَحُلْوُ الخَلَا [or rather الخَلَى]; or ↓ الخَلَآءِ: see خَلَآءٌ, in art. خلو.<br><br>خَلَآءٌ: see the next preceding paragraph, in two places.<br><br>خَالٍ and ↓ مُخْتَلٍ A cutter of خَلًى. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>. [The pls. خَالُونَ and مُخْتَلُونَ are mentioned in the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.]) مِخْلًى The thing [or instrument] with which خَلًى is cut. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) مِخْلَاةٌ A thing [or bag] into which خَلًى is put: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) [and hence a nose-bag for a horse or the like; so in the present day;] a small sack that is hung to the head of a horse [or the like], in which he eats barley [&amp;c.]: (<abbr title=\"Maqāmat al-Ḥarīrī, the Commentary on; 2nd edit, of Paris\">Har</abbr> p. 76:) so called because they used to cut [and put] خَلًى therein for their beasts: (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> مَخَالٍ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> مَخَالِى<br><br>القَتَبِ: see حِدْجٌ.<br><br>مُخْتَلٍ: see خَالٍ. <span class=\"sub-sense\">b2:</span> المُخْتَلِى (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The lion: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) because of his courage. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=10110#e53862","body_html":"خلى: مخْلَى: ذكرت في معجم فوك: مخلاة أي كيس، جوالق صغير.<br>مْخِلاَيَة: صيغة حديثة لمخلاة: مزود، مقنب، كيس وجوالق صغير يوضع فيه الشعير ويعلق برأس الدابة لتأكل منه (بوشر).<br>ومخلاية: كرز الراعي يضع فيه خبزه (بوشر)."},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10110#7a2e0c","body_html":"<span class=\"title1\">خلى</span><span> وَقَالَ [أَبُو عبيد] : فِي حَدِيثه عَلَيْهِ السَّلَام فِي خلايا النَّحْل: إِن فِيهَا الْعشْر. قَالَ: هِيَ الْمَوَاضِع الَّتِي تعتسل فِيهَا النَّحْل وَهُوَ مثل الراقود أَو نَحوه يعْمل لَهَا من طين واحدتها: خَلِيّة. وَحَدِيثه: مَا تعدّون فِيكُم الصرعة فالصرعة الَّذِي يصرع الرِّجَال. وَفِي حَدِيث آخر قَالَ: صَلَاة الْأَوَّابِينَ إِذا رَمِضَت الفِصال من الضُّحَى يَقُول: إِذا وجد الفصيل حرّ الشَّمْس على الرَّمضاء يَقُول: تِلْكَ السَّاعَة صَلَاة الضُّحَى.</span>"},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10110#3b6221","body_html":"<span class=\"title1\">خلى</span><span> وَقَالَ [أَبُو عبيد -] : فِي حَدِيث عمر [رَضِي الله عَنهُ -] أَنه رُفِع إِلَيْهِ رجل قَالَت لَهُ امْرَأَته: شَبِّهني فَقَالَ: كَأَنَّك ظَبْيَة كَأَنَّك حمامة فَقَالَت: لَا أرْضى حَتَّى تَقول: خَلِيّة طَالِق فَقَالَ ذَلِك فَقَالَ عمر: خُذ بِيَدِهَا فَهِيَ امْرَأَتك. قَوْله: خليّة طَالِق أَرَادَ النَّاقة تكون معقولة ثمَّ تُطلق من عقالها </span><span>وتخلى عَنْهَا فَهِيَ خليّة من العقال وَهِي طَالِق لِأَنَّهَا قد طُلِّقت مِنْهُ فَأَرَادَ الرجل ذَلِك فأسقط عمر عَنهُ الطَّلَاق لنيته. وَهَذَا أصل لكل من تكلم بِشَيْء يشبه لفظ الطَّلَاق وَالْعتاق وَهُوَ يَنْوِي غَيره أَن القَوْل فِيهِ قَوْله فِيمَا بَينه وَبَين الله [تبَارك وَتَعَالَى -] وَفِي الحكم على تَأْوِيل مَذْهَب عمر وَأما الَّذِي يَقُوله أَبُو حنيفَة وَأَصْحَابه فَغير هَذَا. قَالَ أَبُو عبيد: سَمِعت أَبَا يُوسُف يَقُول فِي أشباه لهَذَا الْكَلَام: إِذا كَانَ فِي غضب أَو جوابَ كَلَام لم أُدينه فِي الْقَضَاء وَحَكَاهُ عَن أبي حنيفَة وَقَول عمر أولى بالاتباع. </span>"},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10110#1e76a1","body_html":"خلى<br>خَلَّيْتُ عن الشَّيْءِ: أرْسَلْتَه. وتَبَرَّأْت منه. وخَلا فلانٌ: مضى. والقُرُونُ الخالِيَةُ: المَوَاضي. وفي المَثَل: \" عَبْدٌ وخُلِّيَ في يَدَيْه \" أي يَمْلِكُه مَنْ لا يَسْتَأْهِلُه. والخَلا: الحَشِيْش من بُقُول الرَّبيع تَخْتَلِيه، وبه سُمِّيَتِ المِخْلاةُ؛ لأنَّهم كانوا يَخْتَلُونَ لِدَوابِّهم فيها. وأخْلَت الأرْضُ: كَثُرَ خَلاها. والسَّيْفُ يَخْتَلي الأيديَ والأرْجُلَ: إذا أبانَها. رضي الله عنها يقولون: فلانٌ حُلْوُ الخَلا: أي حَسَنُ الكلام. وقالوا في قَوْلِ تَمِيْمً:<br>تَمَطَّيْتُ أخْلِيْهِ اللِّجَامَ<br>أي أُدْخِلُ اللِّجامَ في فيه، بمنزلة الخَلا الرَّطْب. والخَلِيُّ: الذي لا هَمَّ له، وَيْلٌ للشَّجِيِّ من الخَليِّ. والخَلِيُّ: مَوضِعُ العَسَل من الكوّارَة. والخَلاءُ: البَرَاز. والخَلِيَّةُ من النُّوق: التي خَلَّتْ عن وَلَدِها ورَئمَتْ وَلَدَ غيرها. وقيل: هي التي ليس مَعَهاوَلَدٌ. وناقَةٌ مِخْلاءُ: إذا خُلِّيَتْ عن وَلَدِها. وهي من السُّفُن: التي لا يُسَيِّرُها مَلاّحُها، تَسِيْرُ من ذات نفسِها، والجميع الخَلايا. والخِلاءُ في الإِبل: كالحِرَانِ في الدابَّة، خَلأََتِ الناقةُ تَخْلأُ خِلاءً.<br>وتقول: ما في الدار أحَدٌ خَلا زَيْداً، ويُجَرُّ أيضاً. وما أرَدْتُ مَسَاءَتَكَ خَلا أنّي وَعَظْتُك: في معنى إِلأَّ أنّي. ومَثَلٌ: \" افْعَلْ ذاكَ وخَلاكَ ذَمٌّ \" أي جاوَزَكَ وحَيّاك، من خَلافُوْهُ. والإِخْلاءُ: دُعَاءُ الكَلْب. ويُقال: لوكانَ في التِّخْلِىءُ ما نَفَعَه. والتِّخْلىءُ: الدُّنيا."}]}}