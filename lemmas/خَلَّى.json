le":"present_3fd","form":"تُخَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخَلُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخَلَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُخَلِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخَلّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَلَّيْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَلَّيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخَلَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَلَّى","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخَلِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَلِّي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":107,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n11419"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"empty, free, void"},{"pos":"adj","gloss":"single, having no relationship"},{"pos":"adj","gloss":"carefree","examples":[{"text":"تَطَاوَلَ لَيْلُكَ بِٱلْأَثْمُدِ\n وَنَامَ ٱلْخَلِيُّ وَلَمْ تَرْقُدِ","english":"Long was your night at al-Athmud.\n The carefree one slept but you did not slumber."}]}]},"etymology":null,"ipa":["/xa.lijj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11419","headword_ar":"خَلَّى","root":"xlw","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He left"},{"kind":"text","text":"a place, &c.,"},{"kind":"italic_en","text":"empty, vacant, void, devoid, destitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied."},{"kind":"text","text":"] Hence,"},{"kind":"arabic","text_bw":"xl~Y makaAnahu","text_ar":"خلّى مَكَانَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left his place vacant;"},{"kind":"text","text":"] meaning (tropical:)"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(TA, and so in Ham p. 478:) a meaning assigned in the K to ↓"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا","orth_type":"arrow"},{"kind":"arabic","text_bw":"makaAnuhu","text_ar":"مَكَانُهُ"},{"kind":"text","text":", and by IAar to"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"alone, without tesh-deed; but when"},{"kind":"arabic","text_bw":"mkAnh","text_ar":"مكانه"},{"kind":"text","text":"is added, it is with teshdeed. (TA.) And (assumed tropical:)"},{"kind":"italic_en","text":"He went his way."},{"kind":"text","text":"(Ham p. 379.) And"},{"kind":"arabic","text_bw":"xl~Y sabiylahu","text_ar":"خلّى سَبِيلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left his way free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open, to him"},{"kind":"text","text":"]. (S, TA.) And"},{"kind":"arabic","text_bw":"xl~Y bayonahumaA","text_ar":"خلّى بَيْنَهُمَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He left the way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"space, free between them two;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he left them two free, each to do to the other as he pleased"},{"kind":"text","text":"]. (TA.) [And"},{"kind":"arabic","text_bw":"xl~Y bayonahu wabayona ka*aA","text_ar":"خلّى بَيْنَهُ وَبَيْنَ كَذَا"},{"kind":"italic_en","text":"He left him free access to such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xl~Y bayonahu wa bayona nafosihi","text_ar":"خلّى بَيْنَهُ وَ بَيْنَ نَفْسِهِ"},{"kind":"italic_en","text":"He left him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, alone;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^ahomalahu","text_ar":"اَهْمَلَهُ"},{"kind":"text","text":". (S and O and K in art."},{"kind":"arabic","text_bw":"hml","text_ar":"همل"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"xl~Ahu wafulaAnFA","text_ar":"خلّاهُ وَفُلَانًا"},{"kind":"italic_en","text":"He left him to do as he pleased with such a one."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xl~Y AlA^amora","text_ar":"خلّى الاَمْرَ"},{"kind":"italic_en","text":"He left, left alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let alone, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"txl~Y","text_ar":"تخلّى","orth_type":"arrow"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"xAlAhu","text_ar":"خالاهُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"xilaA='N","text_ar":"خِلَا=ءٌ"},{"kind":"text","text":". (TA.) For"},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"leaving,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to be alone."},{"kind":"text","text":"(Har p. 123.) ["},{"kind":"arabic","text_bw":"xl~Ahu","text_ar":"خلّاهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xl~Y Eanohu","text_ar":"خلّى عَنْهُ"},{"kind":"text","text":"both signify"},{"kind":"italic_en","text":"He left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left alone, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"] It is said in a trad.,"},{"kind":"arabic","text_bw":"xl~Y Eanohumo","text_ar":"خلّى عَنْهُمْ"},{"kind":"arabic","text_bw":"A^arobaEiyna EaAmFA","text_ar":"اَرْبَعِينَ عَامًا"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"left them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left them alone, and turned from them, forty years."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"xl~Ahu lika*aA","text_ar":"خلّاهُ لِكَذَا"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left him, vacant, unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure, for such a thing."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"taxoliyapN","text_ar":"تَخْلِيَةٌ"},{"kind":"text","text":"also signifies The act of"},{"kind":"italic_en","text":"loosing; contr. of"},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":". (IAar, K in art."},{"kind":"arabic","text_bw":"AbD","text_ar":"ابض"},{"kind":"text","text":".) [Hence,]"},{"kind":"arabic","text_bw":"xl~Y Eani Al$~aYo'i","text_ar":"خلّى عَنِ الشَّىْءِ"},{"kind":"text","text":", (JK, S, * TA,) in the K ↓"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا","orth_type":"arrow"},{"kind":"text","text":", without teshdeed, but this requires consideration, (TA,)"},{"kind":"italic_en","text":"He dismissed, loosed, let loose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let go, the thing."},{"kind":"text","text":"(JK, K, TA.) ―         -b3-  [And hence"},{"kind":"arabic","text_bw":"xl~Ahu","text_ar":"خلّاهُ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"He left it, permitted it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allowed it:"},{"kind":"text","text":"see the pass. part. n., below.]       -A2-"},{"kind":"arabic","text_bw":"xul~iyato","text_ar":"خُلِّيَتْ"},{"kind":"text","text":", said of a she-camel such as is termed"},{"kind":"arabic","text_bw":"xaliy~ap","text_ar":"خَلِيَّة"},{"kind":"text","text":"; and hence, of a cooking-pot: see 1 in art."},{"kind":"arabic","text_bw":"xlY","text_ar":"خلى"},{"kind":"text","text":"."}],"source_refs":["K","TA","God"]}]}}