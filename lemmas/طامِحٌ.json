{"lemma":"طامِحٌ","slug":"طامِحٌ","root":"ط.م.ح","root_slug":"ط-م-ح","root_link":"/words/roots/ط-م-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n27077"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D9%85%D9%90%D8%AD%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27077","headword_ar":"طَامِحٌ","root":"TmH","body":[{"kind":"text","text":"[part. n. of 1: fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": pl. of the latter"},{"kind":"arabic","text_bw":"TawaAmiHu","text_ar":"طَوَامِحُ"},{"kind":"text","text":"]. You say"},{"kind":"arabic","text_bw":"nisaA='N TawaAmiHu A_ilaY Alr~ijaAli","text_ar":"نِسَا=ءٌ طَوَامِحُ اـِلَى الرِّجَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Women who raise their eyes towards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"look at, men"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"farasN TaAmiHu AlT~arofi","text_ar":"فَرَسٌ طَامِحُ الطَّرْفِ"},{"kind":"text","text":", (A, L,) and"},{"kind":"arabic","text_bw":"TaAmiHu AlbaSari","text_ar":"طَامِحُ البَصَرِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"TamuwHuhu","text_ar":"طَمُوحُهُ","orth_type":"arrow"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"A horse that raises,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevates, his eye."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"TaAmiHN","text_ar":"طَامِحٌ"},{"kind":"text","text":"[without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"] is also an epithet applied to a woman, from"},{"kind":"arabic","text_bw":"TamaHato","text_ar":"طَمَحَتْ"},{"kind":"text","text":"as syn. with, or similar to,"},{"kind":"arabic","text_bw":"jamaHato","text_ar":"جَمَحَتْ"},{"kind":"text","text":"; [i. e. an epithet meaning"},{"kind":"italic_en","text":"That goes forth from the place where she has been accustomed to pass the night, in anger, without the permission of her husband;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that goes forth from the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, of her husband, to her own family, not having been divorced by him;"},{"kind":"text","text":"] (S, K;)"},{"kind":"italic_en","text":"that raises her eyes towards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looks at, men"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taTomaHu","text_ar":"تَطْمَحُ"},{"kind":"arabic","text_bw":"A_ilaY Alr~ijaAli","text_ar":"اـِلَى الرِّجَالِ"},{"kind":"text","text":"): (S:) or"},{"kind":"italic_en","text":"that hates her husband, and looks towards other men:"},{"kind":"text","text":"(Aboo-'Amr EshSheybánee, T:) a woman"},{"kind":"italic_en","text":"disobedient to her husband, resisting him, hating him, and deserting him."},{"kind":"text","text":"(L.) ―         -b3-  Also A"},{"kind":"italic_en","text":"high, overlooking,"},{"kind":"text","text":"mountain. (Msb.) Anything"},{"kind":"italic_en","text":"high, lofty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevating itself."},{"kind":"text","text":"(S, K.) And (assumed tropical:)  Anyone"},{"kind":"italic_en","text":"lofty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevating himself, in excessive pride."},{"kind":"text","text":"(T, TA.) And one says"},{"kind":"arabic","text_bw":"qalobN TaAmiHN A_ilaY kul~i $aYo'","text_ar":"قَلْبٌ طَامِحٌ اـِلَى كُلِّ شَىْء"},{"kind":"text","text":"[app. meaning (assumed tropical:)"},{"kind":"italic_en","text":"A heart aspiring to everything"},{"kind":"text","text":"]. (Lth, O, K, TA, voce"},{"kind":"arabic","text_bw":"$aniqN","text_ar":"شَنِقٌ"},{"kind":"text","text":".)"}],"source_refs":["A","L","S"]}]},"classical_definitions":null}