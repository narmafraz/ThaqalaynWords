o the next paragraph, in three places."}],"source_refs":["Msb","M","K","TA","S"]},{"entry_id":"n14713","headword_ar":"رَتِلٌ","root":"rtl","body":[{"kind":"text","text":"(T, M, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"ratalN","text_ar":"رَتَلٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) [the latter an inf. n. used as an epithet,] applied to front teeth, ("},{"kind":"arabic","text_bw":"vagorN","text_ar":"ثَغْرٌ"},{"kind":"text","text":", T, S, M, Mgh, Msb, K,)"},{"kind":"italic_en","text":"Well set together:"},{"kind":"text","text":"(T, M:) or"},{"kind":"italic_en","text":"even in growth:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"separate, one from another;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having interstices between them, not overlapping one another:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"separate, one from another, and even in the manner of growth, and well set together;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"murat~alN","text_ar":"مُرَتَّلٌ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) or"},{"kind":"italic_en","text":"separate, one from another, well set together, very white, and very lustrous."},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"ratilN","text_ar":"رَتِلٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"ratilu AlA^asonaAni","text_ar":"رَتِلُ الاَسْنَانِ"},{"kind":"text","text":", (M,) [or"},{"kind":"arabic","text_bw":"Alv~agori","text_ar":"الثَّغْرِ"},{"kind":"text","text":",] A man"},{"kind":"italic_en","text":"having the teeth"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the front teeth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"separate, one from another,"},{"kind":"text","text":"(S, M,) &c. (M.) ―         -b3-  And ↓"},{"kind":"arabic","text_bw":"ratalN","text_ar":"رَتَلٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"ratilN","text_ar":"رَتِلٌ"},{"kind":"text","text":", (M, K,) applied to speech, or language, (S, M, K,)"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"murat~alN","text_ar":"مُرَتَّلٌ","orth_type":"arrow"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"uttered in a leisurely manner, and distinctly, without exceeding the proper bounds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limits:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"good,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"and uttered in a leisurely manner."},{"kind":"text","text":"(M.) ―         -b4-  And"},{"kind":"arabic","text_bw":"ratilN","text_ar":"رَتِلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"ratalN","text_ar":"رَتَلٌ","orth_type":"arrow"},{"kind":"text","text":", applied to anything,"},{"kind":"italic_en","text":"Good, sweet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasant."},{"kind":"text","text":"(M, K.) ―         -b5-  And the former, applied to water,"},{"kind":"italic_en","text":"Cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool."},{"kind":"text","text":"(Kr, M, K.)"}],"source_refs":["T","M","Mgh","Msb","K","S"]}]}}