{"lemma":"تُرْبَةٍ","slug":"تُرْبَةٍ","root":"ت.ر.ب","root_slug":"ت-ر-ب","root_link":"/words/roots/ت-ر-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n3831","n3832","n3833"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8F%D8%B1%D9%92%D8%A8%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dust; soil, ground"},{"pos":"noun","gloss":"burial ground, graveyard"},{"pos":"noun","gloss":"ellipsis of تُرْبَة حُسَيْنِيَّة (turba(t) ḥusayniyya, “turbah, a piece of soil used for praying”)","tags":["abbreviation","alt-of","ellipsis"]}]},"etymology":null,"ipa":["/tur.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3831","headword_ar":"تُرْبَةٌ","root":"trb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"turaAbN","text_ar":"تُرَابٌ"},{"kind":"text","text":", in seven places. ―         -b2-  Also A man's"},{"kind":"arabic","text_bw":"ramos","text_ar":"رَمْس"},{"kind":"text","text":"[i. e. his"},{"kind":"italic_en","text":"grave:"},{"kind":"text","text":"so in the present"},{"kind":"page_break","n":301},{"kind":"text","text":"day: pl."},{"kind":"arabic","text_bw":"turbN","text_ar":"تُربٌ"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust, thereof"},{"kind":"text","text":"]: (M:) or"},{"kind":"italic_en","text":"a cemetery, burial-place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of graves"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a grave:"},{"kind":"text","text":"[so, too, in the present day:] pl."},{"kind":"arabic","text_bw":"turabN","text_ar":"تُرَبٌ"},{"kind":"text","text":". (Msb.)"}],"source_refs":["M"]},{"entry_id":"n3832","headword_ar":"تَرَبَةٌ","root":"trb","body":[{"kind":"text","text":": see the word next following."}],"source_refs":[]},{"entry_id":"n3833","headword_ar":"تَرِبَةٌ","root":"trb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"end of a finger;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"joint in which is the nail;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^anomalapN","text_ar":"اَنْمَلَةٌ"},{"kind":"text","text":": (S, K:) pl."},{"kind":"arabic","text_bw":"taribaAtN","text_ar":"تَرِبَاتٌ"},{"kind":"text","text":". (S.)       -A2-  Also, (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"tarabapN","text_ar":"تَرَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tarobaA='u","text_ar":"تَرْبَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"A certain plant,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"growing in the plains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in soft land, having serrated leaves:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"a certain thorny tree, of which the fruit is like a suspended unripe date, growing in the plains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in soft land, and in rugged ground, and in Tihámeh:"},{"kind":"text","text":"accord. to AHn, the"},{"kind":"arabic","text_bw":"taribap","text_ar":"تَرِبَة"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a green herb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leguminous plant, that has a purging effect upon camels:"},{"kind":"text","text":"(M:) [accord. to Meyd, as stated by Golius,"},{"kind":"italic_en","text":"what is called in Persian"},{"kind":"arabic","text_bw":"xnfj","text_ar":"خنفج"},{"kind":"text","text":"; i. e. the plant"},{"kind":"italic_en","text":"thlaspi;"},{"kind":"text","text":"and to this it is applied in the present day.]"}],"source_refs":["S","K","M"]}]},"classical_definitions":null}