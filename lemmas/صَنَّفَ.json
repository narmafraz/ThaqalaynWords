,"gen":"m","num":"p"},{"role":"present_2mp","form":"تُصَنِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُصَنِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُصَنِّف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُصَنِّف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُصَنِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُصَنِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُصَنِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُصَنِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُصَنِّفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُصَنِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصَنِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صَنَّفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَنَّفْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصَنِّف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصَنِّف","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["name","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n25031","n25032","n25033"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%86%D9%8E%D9%91%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sort, classify, or categorize something"},{"pos":"verb","gloss":"to compile or compose"},{"pos":"noun","gloss":"kind, sort, specimen"},{"pos":"noun","gloss":"class, genus, species, category"},{"pos":"noun","gloss":"fringe, hem, border of a garment","tags":["Classical"]},{"pos":"name","gloss":"Champa (a historical region of Farther India)","tags":["Classical"]}]},"etymology":{"source":"wiktextract","text":"In the root ص ن ف (ṣ n f) one also finds صِنْفَة (ṣinfa, “border of a garment”), which fits Ge'ez ጽንፍ (ṣənf, “extremity, edge, border, fringe etc.”), suspiciously enough with alternative vocalization as in Arabic ጸንፍ (ṣänf). Due to the restricted semantic range and the varying vocalization one wonders about a borrowing from Aramaic. Christian Palestinian Aramaic has ܨܢܦܬܐ (“border, fringe (of a garment)”) and Jewish Palestinian Aramaic צנפה (ṣanpā, “border, fringe (of a garment)”) and צנף (“to wrap or gird oneself”), but Jewish Babylonian Aramaic סנפא, סינפא (sinpā, “side-room”) seems also similar, via the idea of an anyhow abstract pigeonhole or خَانَة (ḵāna) things are fitted into, not emphatic but no doubt related because in the same isolect there is the geminate verb סנפ (“to gird”), which is also found in Classical Syriac, while the Syriac base stem ܣܢܱܦ (snap̄) means “to introduce, to insert”; apparently a Western Aramaic—Eastern Aramaic anlaut variation. For the meaning development in to a “sort” also contrast نَمَط (namaṭ, “drugget, horse-rug; pattern, manner”). In modern Hebrew, סְנִיף (snif) is used as “branch, affiliate”.\nThe ultimate origin is suggested by the Dictionnaire du faisceau dialectal arabe andalou as ultimately Akkadian [script needed] (ṣiliptu, “diagonal”), related to Akkadian [script needed] (ṣalāpu, “to distort”), well also found in Jewish Babylonian Aramaic צלפ / Classical Syriac ܨܠܦ (ṣlap̄, “to split, to wound”), the geminate stem in Syriac and Jewish Literary Aramaic “to perforate” and “to wound”, the Syriac causative stem “to open up as to show”, with an unemphatic variant Jewish Babylonian Aramaic סלף (“to wound”), Jewish Literary Aramaic סלף (“to wound”).\n\nProbably borrowed from Middle Persian *čamp with Middle Persian č rendered as Arabic ṣ, as found in other borrowings from Persian: صَنْج (ṣanj), صَارُوج (ṣārūj), صَهْرِيج (ṣahrīj), الصِّين (aṣ-ṣīn)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25031","headword_ar":"صَنْفٌ","root":"Snf","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n25032","headword_ar":"صِنْفٌ","root":"Snf","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SanofN","text_ar":"صَنْفٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species,"},{"kind":"text","text":"(Lth, S, M, O, Msb, K,) of a thing, (M, TA,) or of things, (Lth, TA,) as, for instance, of householdgoods, or furniture and utensils: (TA:) [a term subordinate to"},{"kind":"arabic","text_bw":"jinosN","text_ar":"جِنْسٌ"},{"kind":"text","text":":] and"},{"kind":"italic_en","text":"a part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constituent,"},{"kind":"text","text":"of anything: (Lth, Msb, TA:) pl. (of the former, Msb)"},{"kind":"arabic","text_bw":"A^aSonaAfN","text_ar":"اَصْنَافٌ"},{"kind":"text","text":"and (of the latter, Msb)"},{"kind":"arabic","text_bw":"SunuwfN","text_ar":"صُنُوفٌ"},{"kind":"text","text":". (M, O, Msb, K.) ―         -b2-  Also the former,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SifapN","text_ar":"صِفَةٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"A quality, an attribute, a property;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a description,"},{"kind":"text","text":"as meaning the"},{"kind":"italic_en","text":"aggregate of the qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attributes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"properties,"},{"kind":"text","text":"of a thing, or the"},{"kind":"italic_en","text":"state, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case,"},{"kind":"text","text":"of a thing]. (M, K.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"SanifapN","text_ar":"صَنِفَةٌ"},{"kind":"text","text":"."}],"source_refs":["Lth","S","M","O","Msb","K","TA"]},{"entry_id":"n25033","headword_ar":"صَنِفٌ","root":"Snf","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]}]}}