,"gen":"m","num":"p"},{"role":"present_2mp","form":"تُسايِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُسايِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُسايِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُسايِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُسايِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُسايِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسايِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسايِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسايِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسايِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسايِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سايَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سايَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُسايِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسايِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n18574","n21423"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%8A%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to keep pace with"},{"pos":"verb","gloss":"to go along with (of the current)"}]},"etymology":null,"ipa":["/saː.ja.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18574","headword_ar":"سَايِرٌ","root":"sA^r","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remainder,"},{"kind":"text","text":"(T, and M in art."},{"kind":"arabic","text_bw":"syr","text_ar":"سير"},{"kind":"text","text":", and Msb and K,) of a thing, (Z, M, Msb,) whether little or much; (T, Msb;) and of men, or people: (Sgh; Msb:) not the"},{"kind":"italic_en","text":"whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all,"},{"kind":"text","text":"as many imagine it to mean, (Sgh, Msb, K,) though people use it in this latter sense, (IAth,) which Sgh asserts to be a vulgar error: (Msb:) it occurs repeatedly in trads., and always in the former sense: (IAth:) or it is sometimes used [in chaste Arabic] in the latter sense: (K:) and is correctly so used accord. to AAF and J and IJ and ElJawáleekee and IB, the last of whom confirms this signification by many examples and evident proofs: but whether, in this sense, it is derived from"},{"kind":"arabic","text_bw":"Als~ayor","text_ar":"السَّيْر"},{"kind":"text","text":", as AAF and J and others hold, or from"},{"kind":"arabic","text_bw":"suwrN","text_ar":"سُورٌ"},{"kind":"text","text":"the “ wall which surrounds a town or city, ” as others hold, is disputed: (TA:) and"},{"kind":"arabic","text_bw":"saAru Al$~aYo'i","text_ar":"سَارُ الشَّىْءِ"},{"kind":"text","text":"is a dial. var. of"},{"kind":"arabic","text_bw":"saAy^iruhu","text_ar":"سَايِرُهُ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"syr","text_ar":"سير"},{"kind":"text","text":".) ―         -b2-  An Arab of the desert became the guest of a party, and they ordered the female slave to perfume him; whereupon he said,"},{"kind":"arabic","text_bw":"baToniY EaT~iriY","text_ar":"بَطْنِى عَطِّرِى"},{"kind":"arabic","text_bw":"wasaAy^iriY *ariY","text_ar":"وَسَايِرِى ذَرِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My belly perfume thou, and the rest of me leave thou"},{"kind":"text","text":"]: (K:) but in other lexicons than the K, we find"},{"kind":"arabic","text_bw":"A^aEoTiriY","text_ar":"اَعْطِرِى"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"ETr","text_ar":"عطر"},{"kind":"text","text":".) This saying is a well-known prov. (TA.) [In the TA it is added that"},{"kind":"arabic","text_bw":"sAy^ry","text_ar":"سايري"},{"kind":"text","text":"here signifies"},{"kind":"italic_en","text":"the whole of me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all of me:"},{"kind":"text","text":"but this is an evident mistake.] You say this to a man who gives you what you do not want, and refuses you what you want. (Sgh, TA in art."},{"kind":"arabic","text_bw":"ETr","text_ar":"عطر"},{"kind":"text","text":".) ―         -b3-  It is related, also, that a hostile attack was made upon a people, and they cried out for aid to the sons of their uncle; but these held back from them until they had been made captives and taken away; then they came inquiring respecting them; and the person asked replied,"},{"kind":"arabic","text_bw":"A^asaAy^ira Alyawomi waqado zaAla AlZ~uhoru","text_ar":"اَسَايِرَ اليَوْمِ وَقَدْ زَالَ الظُّهْرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What, all the day, when the noon has passed?"},{"kind":"text","text":"] (K:) i. e., Dost thou covet what is remote, ("},{"kind":"arabic","text_bw":"maA baEuda","text_ar":"مَا بَعُدَ"},{"kind":"text","text":", (S, K, TA, in a copy of the S and in one of the K and in the CK"},{"kind":"arabic","text_bw":"maA baEodu","text_ar":"مَا بَعْدُ"},{"kind":"text","text":",) when [reason for] despair hath become manifest to thee: for when one wants the whole day, and the noon has passed, he must despair like as he despairs of accomplishing his want at sunset. (S in art."},{"kind":"arabic","text_bw":"syr","text_ar":"سير"},{"kind":"text","text":", and K.) This saying is a prov.; (S, A;) and is used with reference to a thing which one hopes to attain when its time has passed. (A.)"}],"source_refs":["Z","M","Msb","Sgh","K","IAth","TA"]},{"entry_id":"n21423","headword_ar":"سَايِرٌ","root":"syr","body":[{"kind":"text","text":"[part. n. of 1,"},{"kind":"italic_en","text":"Going,"},{"kind":"text","text":"&c. ―         -b2-  Hence,] (assumed tropical:)  A proverb [and a saying]"},{"kind":"italic_en","text":"current,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commonly known."},{"kind":"text","text":"(TA.)       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"saArN","text_ar":"سَارٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) both are syn., (K,) signifying The"},{"kind":"italic_en","text":"rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remainder,"},{"kind":"text","text":"of a thing: (M:) [and accord. to some,] the"},{"kind":"italic_en","text":"whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all,"},{"kind":"text","text":"of a thing or of people. (S, TA.) [See the former word in art."},{"kind":"arabic","text_bw":"sA^r","text_ar":"سار"},{"kind":"text","text":".]"}],"source_refs":["S","M","K"]}]},"classical_definitions":null}