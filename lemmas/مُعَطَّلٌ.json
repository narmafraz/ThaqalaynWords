{"lemma":"مُعَطَّلٌ","slug":"مُعَطَّلٌ","root":"ع.ط.ل","root_slug":"ع-ط-ل","root_link":"/words/roots/ع-ط-ل","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n29614"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%8E%D8%B7%D9%8E%D9%91%D9%84%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"out of order, broken (machine, etc.)"},{"pos":"adj","gloss":"unemployed, idle"},{"pos":"adj","gloss":"closed (store, office, etc.)"},{"pos":"adj","gloss":"stopped (engine)"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of عَطَّلَ (ʕaṭṭala, “to neglect, to leave idle, to damage”)."},"ipa":["/mu.ʕatˤ.tˤal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29614","headword_ar":"مُعَطَّلٌ","root":"ETl","body":[{"kind":"text","text":"[pass. part. n. of 2 (which see for some of its significations)] is applied to Anything"},{"kind":"italic_en","text":"left untended, unminded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglected;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muEoTalN","text_ar":"مُعْطَلٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) [Thus]"},{"kind":"arabic","text_bw":"muEaT~aluwna","text_ar":"مُعَطَّلُونَ"},{"kind":"text","text":"signifies People, or subjects,"},{"kind":"italic_en","text":"left without any one to govern them."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A_ibilN muEaT~alapN","text_ar":"اـِبِلٌ مُعَطَّلَةٌ"},{"kind":"italic_en","text":"Camels"},{"kind":"text","text":"["},{"kind":"italic_en","text":"left"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without a pastor."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"AlmuEaT~alu","text_ar":"المُعَطَّلُ"},{"kind":"italic_en","text":"What has no owner, of which no use is made, and from which no advantage is derived,"},{"kind":"text","text":"of land. (S, O, K.) And"},{"kind":"arabic","text_bw":"biy^orN","text_ar":"بِيْرٌ"},{"kind":"arabic","text_bw":"muEaT~alapN","text_ar":"مُعَطَّلَةٌ"},{"kind":"text","text":", (S, O, TA,) and ↓"},{"kind":"arabic","text_bw":"muEoTalapN","text_ar":"مُعْطَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"accord. to one reading [in the Kur xxii. 44], (O, TA,)"},{"kind":"italic_en","text":"A well from which water is not drawn, and of the water of which no use is made:"},{"kind":"text","text":"(TA:) or it is thus called because [it is"},{"kind":"italic_en","text":"one of which"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its owners have perished:"},{"kind":"text","text":"(S, O, TA:)"},{"kind":"italic_en","text":"neglected by reason of the death of its owners."},{"kind":"text","text":"(Jel.)"}],"source_refs":["S","O","TA"]}]},"classical_definitions":null}