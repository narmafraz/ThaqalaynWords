role":"present_2mp","form":"تَذْمَُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَذْمَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَذْمَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَذْمَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَذْمَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَذْمَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَذْمَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَذْمَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَذْمَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَذْمَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَذْمَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَذْمَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَذْمَُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَذْمَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَذْمَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَذْمَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ذَمِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ذَمِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَذْمَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَذْمَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":15,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n14029","n14061","n14064"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D9%85%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14029","headword_ar":"ذِمِّىٌّ","root":"*m","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"*im~apN","text_ar":"ذِمَّةٌ"},{"kind":"text","text":", in the former half of the paragraph."}],"source_refs":[]},{"entry_id":"n14061","headword_ar":"ذَمِىَ","root":"*mY","body":[{"kind":"text","text":", (M, K, and so in some copies of the S,) aor."},{"kind":"arabic","text_bw":"ya*omaY","text_ar":"يَذْمَى"},{"kind":"text","text":"; (K, and some copies of the S;) or"},{"kind":"arabic","text_bw":"*amaY","text_ar":"ذَمَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":"; (T, and so in some copies of the S;) or both; (Sgh, TA;) inf. n."},{"kind":"arabic","text_bw":"*amaA='N","text_ar":"ذَمَا=ءٌ"},{"kind":"text","text":"; (T, * S, M, * K, * TA;) said of a slaughtered animal, (S, TA,)"},{"kind":"italic_en","text":"It moved."},{"kind":"text","text":"(T, S, M, Sgh, K, TA.) And"},{"kind":"arabic","text_bw":"*amiYa","text_ar":"ذَمِىَ"},{"kind":"text","text":"; (M;) or"},{"kind":"arabic","text_bw":"*amaY","text_ar":"ذَمَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":"; (K;) inf. n. as above; (M, K; *)"},{"kind":"italic_en","text":"He retained remains of the soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vital principle:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had strength of heart"},{"kind":"text","text":"["},{"kind":"italic_en","text":"remaining:"},{"kind":"text","text":"app. said of one dying]. (M, K. [These meaning are there indicated, but not expressed.]) You say,"},{"kind":"arabic","text_bw":"mar~a ya*omiY","text_ar":"مَرَّ يَذْمِى"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"He passed by at his last gasp of breath."},{"kind":"text","text":"(Har p. 220.) And"},{"kind":"arabic","text_bw":"*amaY","text_ar":"ذَمَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*amoYN","text_ar":"ذَمْىٌ"},{"kind":"text","text":"[and app."},{"kind":"arabic","text_bw":"*amaA='N","text_ar":"ذَمَا=ءٌ"},{"kind":"text","text":"also, as seems to be indicated by what here follows, or perhaps the latter only],"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a sick person)"},{"kind":"italic_en","text":"was seized by the agony of death, and was long in suffering the disquietude thereof:"},{"kind":"text","text":"whence one says,"},{"kind":"arabic","text_bw":"maA A^aTowala *amaA='ahu","text_ar":"مَا اَطْوَلَ ذَمَا=ءَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How long is his suffering of the agong and disquietude of death!"},{"kind":"text","text":"]. (As, T.) [See"},{"kind":"arabic","text_bw":"*amA='N","text_ar":"ذَما=ءٌ"},{"kind":"text","text":"below.] You say also, of a man,"},{"kind":"arabic","text_bw":"*amiYa","text_ar":"ذَمِىَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*amaA='N","text_ar":"ذَمَا=ءٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He remained long sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diseased."},{"kind":"text","text":"(M.)       -A2-"},{"kind":"arabic","text_bw":"*amaY","text_ar":"ذَمَى"},{"kind":"text","text":", aor,"},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*amayaAnN","text_ar":"ذَمَيَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He hastened, made haste, sped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went quickly:"},{"kind":"text","text":"(Fr, T, S, M, K:) some also mention"},{"kind":"arabic","text_bw":"*amiYa","text_ar":"ذَمِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omaY","text_ar":"يَذْمَى"},{"kind":"text","text":", [in this sense, and thus I find in one copy of the S,] but [ISd says,] I am not sure of this. (M.)       -A3-"},{"kind":"arabic","text_bw":"*amiYa liY minohu $aYo'N","text_ar":"ذَمِىَ لِى مِنْهُ شَىْءٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Somewhat thereof was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prepared for me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feasible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"practicable, to me:"},{"kind":"text","text":"(M:) [and so, app.,"},{"kind":"arabic","text_bw":"*amaY lY","text_ar":"ذَمَى لى"},{"kind":"text","text":": for] one says,"},{"kind":"arabic","text_bw":"xu*~ mino","text_ar":"خُذّ مِنْ"},{"kind":"arabic","text_bw":"fulaAnK maA *amaY laka","text_ar":"فُلَانٍ مَا ذَمَى لَكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Take thou, from such a one, what has risen up for thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arisen for thee;"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"maAA@rotafaEa laka","text_ar":"مَاا@رْتَفَعَ لَكَ"},{"kind":"text","text":". (S.)       -A4-"},{"kind":"arabic","text_bw":"*amatoniY Alr~iyHu","text_ar":"ذَمَتْنِى الرِّيحُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The odour annoyed me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"molested me;"},{"kind":"text","text":"(S, M, K;) accord. to AHn: (M:) and"},{"kind":"italic_en","text":"took away my breath;"},{"kind":"text","text":"referring to a wind emitted from the anus; inf. n."},{"kind":"arabic","text_bw":"*amoYN","text_ar":"ذَمْىٌ"},{"kind":"text","text":": (M:) and"},{"kind":"italic_en","text":"killed me;"},{"kind":"text","text":"(T, M;) accord. to AZ; (T;) aor."},{"kind":"arabic","text_bw":"ta*omiY","text_ar":"تَذْمِى"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"*amoYN","text_ar":"ذَمْىٌ"},{"kind":"text","text":": (TA:) but Aboo-Málik disallows this, and says, you say,"},{"kind":"arabic","text_bw":"*amato fiY A^anofihi Alr~iyHu","text_ar":"ذَمَتْ فِى اَنْفِهِ الرِّيحُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The odour flew"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rose"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"into his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"nose and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"head:"},{"kind":"text","text":"and accord. to As, you say,"},{"kind":"arabic","text_bw":"*amaY AlHaba$iY~u fiY A^anofi Alr~ajuli biSunaAnihi","text_ar":"ذَمَى الحَبَشِىُّ فِى اَنْفِ الرَّجُلِ بِصُنَانِهِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*amoYN","text_ar":"ذَمْىٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The Abyssinian annoyed the man in his nose by the odour of his armpits."},{"kind":"text","text":"(T.) One says also,"},{"kind":"arabic","text_bw":"*amaY","text_ar":"ذَمَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya*omiY","text_ar":"يَذْمِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, emitted a displeasing odour."},{"kind":"text","text":"(M.)"}],"source_refs":["S","TA","Fr","T","M","K"]},{"entry_id":"n14064","headword_ar":"ذَمًى","root":"*mY","body":[{"kind":"italic_en","text":"A fetid odour:"},{"kind":"text","text":"(M:)"},{"kind":"italic_en","text":"an odour that is disliked, hated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hateful."},{"kind":"text","text":"(K.)"}],"source_refs":["M"]}]}}