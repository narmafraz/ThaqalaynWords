{"lemma":"لَغْطُ","slug":"لَغْطُ","root":"ل.غ.ط","root_slug":"ل-غ-ط","root_link":"/words/roots/ل-غ-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n37845","","n37846","n37847"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D8%BA%D9%92%D8%B7%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be noisy, to clamor, to din, to shout"},{"pos":"noun","gloss":"verbal noun of لَغَطَ (laḡaṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"heart murmur"}]},"etymology":null,"ipa":["/la.ɣa.tˤa/","/la.ɣatˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37845","headword_ar":"لَغَطَ","root":"lgT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"lagoTN","text_ar":"لَغْطٌ"},{"kind":"text","text":"(S, Msb, TA) and"},{"kind":"arabic","text_bw":"lagaTN","text_ar":"لَغَطٌ"},{"kind":"text","text":", (TA,) or the latter is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"ligaATN","text_ar":"لِغَاطٌ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"lg~T","text_ar":"لغّط","orth_type":"arrow"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AlgT","text_ar":"الغط","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"AilogaATN","text_ar":"اِلْغَاطٌ"},{"kind":"text","text":"; (S, Mgh;)"},{"kind":"italic_en","text":"He spoke clamorously, confusedly, and indistinctly:"},{"kind":"text","text":"(Msb:) or, said of a number of men, (S, Mgh, K,)"},{"kind":"italic_en","text":"they uttered a sound, noise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a clamour, confused noise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixture of voices"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"they uttered indistinct, and unintelligible sounds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries."},{"kind":"text","text":"(Mgh, K.) And"},{"kind":"arabic","text_bw":"lagaTa","text_ar":"لَغَطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lagoTN","text_ar":"لَغْطٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lagiyTN","text_ar":"لَغِيطٌ"},{"kind":"text","text":", is said of the pigeon, and of the [bird called]"},{"kind":"arabic","text_bw":"qaTaA","text_ar":"قَطَا"},{"kind":"text","text":", [meaning,"},{"kind":"italic_en","text":"It uttered its cry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries;"},{"kind":"text","text":"] (K;) or of each of these you say,"},{"kind":"arabic","text_bw":"lagaTa biSawotihi","text_ar":"لَغَطَ بِصَوْتِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlgT","text_ar":"الغط","orth_type":"arrow"},{"kind":"text","text":". (TA.) [Hence,]"},{"kind":"arabic","text_bw":"A^atayotuhu qabola lagiyTi AlqaTaA","text_ar":"اَتَيْتُهُ قَبْلَ لَغِيطِ القَطَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lagoTihi","text_ar":"لَغْطِهِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I came to him before the crying of the katà,"},{"kind":"text","text":"] meaning,"},{"kind":"italic_en","text":"early in the morning."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"laAgiTN","text_ar":"لَاغِطٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","Msb","K","TA"]},{"entry_id":"n37846","headword_ar":"لَغْطٌ","root":"lgT","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n37847","headword_ar":"لَغَطٌ","root":"lgT","body":[{"kind":"text","text":"(S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"lagoTN","text_ar":"لَغْطٌ","orth_type":"arrow"},{"kind":"text","text":"(Ks, K)"},{"kind":"italic_en","text":"Clamorous, confused, and indistinct, speech:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"sound, noise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"clamour, confused noise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a mixture of voices"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"indistinct and unintelligible sounds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries:"},{"kind":"text","text":"(Mgh, K:) pl."},{"kind":"arabic","text_bw":"A^alogaATN","text_ar":"اَلْغَاطٌ"},{"kind":"text","text":", (K,) of the latter as well as of the former. (TA.) You say,"},{"kind":"arabic","text_bw":"samiEotu lagaZa Alqawomi","text_ar":"سَمِعْتُ لَغَظَ القَوْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I heard the clamorous, and confused, and indistinct speech, &c., of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Mgh","Msb","K","Ks"]}]}}