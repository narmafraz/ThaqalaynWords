":["n8121"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AD%D9%92%D8%AA%D9%8E%D8%B4%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be ashamed, to be modest"}]},"etymology":null,"ipa":["/iħ.ta.ʃa.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8121","headword_ar":"احتشم","root":"H$m","body":[{"kind":"text","text":": see 1. ―         -b2-  Also"},{"kind":"italic_en","text":"He felt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a sense of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was moved"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected with, shame, or shyness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bashfulness."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"AHt$m minohu","text_ar":"احتشم مِنْهُ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"AHt$mhu","text_ar":"احتشمهُ"},{"kind":"text","text":", (S, Mgh,) or this last is not allowable except when"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":"is meant to be understood, (TA,) signify the same; (S, Mgh;) i. e."},{"kind":"italic_en","text":"He was ashamed of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abashed at him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was ashamed to do it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy of doing it:"},{"kind":"text","text":"(Mgh, K:) or it signifies, (Mgh,) or signifies also, (K,)"},{"kind":"italic_en","text":"he shrank from it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him:"},{"kind":"text","text":"(Mgh, K:) or, as some say, thus used it is vulgar; for"},{"kind":"arabic","text_bw":"Hi$omapN","text_ar":"حِشْمَةٌ"},{"kind":"text","text":", with the Arabs, is only anger: (Mgh:) but IB cites, from Kutheiyir,"},{"kind":"quote","text":"A_in~iY mataY lamo yakuno EaTaAw^uhumaA\n                      \n                     \n                        EinodiY bimaA qado faEalotu A^aHota$imu"},{"kind":"text","text":"as meaning ["},{"kind":"italic_en","text":"Verily I, when the gift of them two"},{"kind":"page_break","n":577},{"kind":"italic_en","text":"in my possession is not for what I have done,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"am ashamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abashed:"},{"kind":"text","text":"and in a trad. of 'Alee, respecting the thief, occurs the saying,"},{"kind":"arabic","text_bw":"A_in~iY laA^aHota$imu","text_ar":"اـِنِّى لَاَحْتَشِمُ"},{"kind":"arabic","text_bw":"A^ano laA A^adaEa lahu yadFA","text_ar":"اَنْ لَا اَدَعَ لَهُ يَدًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Verily I am ashamed not to leave him a hand;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I shrink from it."},{"kind":"text","text":"(TA.) [And ↓"},{"kind":"arabic","text_bw":"Ha$ama","text_ar":"حَشَمَ","orth_type":"arrow"},{"kind":"text","text":"app. signifies the same; for,] accord. to As, (TA,) [the inf. n.]"},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ"},{"kind":"text","text":"signifies The act of"},{"kind":"italic_en","text":"shrinking."},{"kind":"text","text":"(K.) You say also,"},{"kind":"arabic","text_bw":"A_in~iY","text_ar":"اـِنِّى"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"laA^ataHa$~amu","text_ar":"لَاَتَحَشَّمُ","orth_type":"arrow"},{"kind":"italic_en","text":"Verily I abstain from it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrain from it, to shun blame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"through disdain and pride; disdain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scorn, it;"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^ata*am~amu minohu","text_ar":"اَتَذَمَّمُ مِنْهُ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"and am ashamed of it."},{"kind":"text","text":"(K.)       -A2-  Also"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, master of many"},{"kind":"arabic","text_bw":"Ha$am","text_ar":"حَشَم"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"dependents"},{"kind":"text","text":"&c.]"},{"kind":"italic_en","text":"and servants."},{"kind":"text","text":"(KL.)"}],"source_refs":["S","Mgh","K","TA"]}]},"classical_definitions":null}