 [lizard of the species called]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"That feeds upon the plant called"},{"kind":"arabic","text_bw":"siHaA='","text_ar":"سِحَا=ء"},{"kind":"text","text":". (S.)"}],"source_refs":[]},{"entry_id":"n21150","headword_ar":"سَاحٌ","root":"swH","body":[{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"sawaHN","text_ar":"سَوَحٌ"},{"kind":"text","text":"]: see what follows."}],"source_refs":[]},{"entry_id":"n21390","headword_ar":"سَاحَ","root":"syH","body":[{"kind":"text","text":", (S, Mgh, K,) or"},{"kind":"arabic","text_bw":"saAHa EalaY wajohi AlA^aroDi","text_ar":"سَاحَ عَلَى وَجْهِ الاَرْضِ"},{"kind":"text","text":", (A,) aor."},{"kind":"arabic","text_bw":"yasiyHu","text_ar":"يَسِيحُ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"sayoHN","text_ar":"سَيْحٌ"},{"kind":"text","text":"(S, A, Mgh, K) and"},{"kind":"arabic","text_bw":"sayaHaAnN","text_ar":"سَيَحَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"ran upon the surface of the earth."},{"kind":"text","text":"(S, A, Mgh, K.) ―         -b2-  And hence, (TA,)"},{"kind":"arabic","text_bw":"saAHa fiY AlA^aroDi","text_ar":"سَاحَ فِى الاَرْضِ"},{"kind":"text","text":", (S, A, Msb,) aor. as above, (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"siyaAHapN","text_ar":"سِيَاحَةٌ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"sayoHN","text_ar":"سَيْحٌ"},{"kind":"text","text":", (Msb,) or both, and"},{"kind":"arabic","text_bw":"suyuwHN","text_ar":"سُيُوحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sayaHaAnN","text_ar":"سَيَحَانٌ"},{"kind":"text","text":", (S, K,) said of a man, (A,) (tropical:)"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, through the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth,"},{"kind":"text","text":"(S, L, K, &c.,)"},{"kind":"italic_en","text":"for the purpose of devoting himself to religious services"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercises:"},{"kind":"text","text":"(L, K:) or in this restricted sense, which MF asserts to be unmentioned in most of the older books, and thinks to be conventional, the verb has only the first of the inf. ns. above, and in the absolute sense it has the second and third and fourth. (TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA siyaAHapa fiY AlA_isolaAmi","text_ar":"لَا سِيَاحَةَ فِى الاـِسْلَامِ"},{"kind":"text","text":"(S, A, TA) i. e. (tropical:)  ["},{"kind":"italic_en","text":"There shall be no going about through the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth, in the way of devotees, in ElIslám:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"no quitting of the cities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towns, and going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeying, through the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"no quitting of the cities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towns, and dwelling in the deserts, and forsaking the being present at the congregational prayers and at assemblies:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no going about through the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth, doing evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief, and calumniating and corrupting."},{"kind":"text","text":"(IAth, TA.) The"},{"kind":"arabic","text_bw":"siyaAHap","text_ar":"سِيَاحَة"},{"kind":"text","text":"of the Muslims [in a religious sense, and such as is approvable,] is (assumed tropical:)"},{"kind":"italic_en","text":"Fasting."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"saAHa AlZ~il~u","text_ar":"سَاحَ الظِّلُّ"},{"kind":"italic_en","text":"The shade changed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moved, from side to side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from place to place."},{"kind":"text","text":"(S, K.)"}],"source_refs":["S","Mgh","K","A","TA","Msb","L"]}]}}