,"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n38698"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%85%D9%92%D8%B7%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38698","headword_ar":"استمطر","root":"mTr","body":[{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prayed, for rain;"},{"kind":"text","text":"(S, Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"tmT~r","text_ar":"تمطّر","orth_type":"arrow"},{"kind":"text","text":". (TA.) You say"},{"kind":"arabic","text_bw":"xarajuwA yasotamoTiruwna A@ll~`ha","text_ar":"خَرَجُوا يَسْتَمْطِرُونَ ا@للّٰهَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yatamaT~aruwnahu","text_ar":"يَتَمَطَّرُونَهُ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"They went forth praying to God for rain."},{"kind":"text","text":"] (A, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AstmTrhu","text_ar":"استمطرهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He sought, desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, his beneficence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounty;"},{"kind":"text","text":"(A, TA;)"},{"kind":"italic_en","text":"he asked him to give like rain."},{"kind":"text","text":"(S.) ―         -b3-  [And hence, perhaps,]"},{"kind":"arabic","text_bw":"AstmTr lils~iyaATi","text_ar":"استمطر لِلسِّيَاطِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He endured patiently the whips"},{"kind":"text","text":"[as though he desired that the stripes should fall like rain upon him]. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"AstmTr","text_ar":"استمطر"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was silent; he did not speak"},{"kind":"text","text":"[when spoken to, as though he desired that words should pour upon him like rain]: in the K, this meaning is assigned to"},{"kind":"arabic","text_bw":"A^amoTara","text_ar":"اَمْطَرَ"},{"kind":"text","text":", which should not be used in this sense: see also"},{"kind":"arabic","text_bw":"musotamoTirN","text_ar":"مُسْتَمْطِرٌ"},{"kind":"text","text":"; and see 4. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"AlmaAlu yasotamoTiru","text_ar":"المَالُ يَسْتَمْطِرُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheep,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"go out to the rain."},{"kind":"text","text":"(A.) See also 5. ―         -b6-"},{"kind":"arabic","text_bw":"AstmTr","text_ar":"استمطر"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"sough shelter from the rain."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"AstmTr vawobahu","text_ar":"استمطر ثَوْبَهُ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"put on his garment in the rain."},{"kind":"text","text":"(Ibn-Buzurj.)"}],"source_refs":[]}]},"classical_definitions":null}