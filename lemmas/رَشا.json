form": "رَشَوْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "رَشَوْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1ms", "form": "أَرْشَى", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَرْشَى", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 21, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 1}, "lanes": {"found": true, "entry_ids": ["n15556", "n15557", "n15619"], "search_url": "https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B4%D8%A7"}}, "translations": {"en": "to bribe", "fa": "رشا دادن", "ur": "رشا دینا", "tr": "rüşvet vermek", "id": "memberi suap", "bn": "রিশোত দেওয়া", "es": "sobornar", "fr": "donner un pot-de-vin", "de": "bestechen", "ru": "подкупать", "zh": "行贿"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to bribe"}]}, "etymology": null, "ipa": ["/ra.ʃaː/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n15556", "headword_ar": "رَشَاَ", "root": "r$A^", "body": [{"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "jaAmaEa", "text_ar": "جَامَعَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Inivit"}, {"kind": "text", "text": "feminam]. (K.)       -A2-"}, {"kind": "arabic", "text_bw": "ra$aA^ato", "text_ar": "رَشَاَتْ"}, {"kind": "italic_en", "text": "She"}, {"kind": "text", "text": "(a gazelle)"}, {"kind": "italic_en", "text": "brought forth."}, {"kind": "text", "text": "(K.)"}], "source_refs": []}, {"entry_id": "n15557", "headword_ar": "رَشَاٌ", "root": "r$A^", "body": [{"kind": "italic_en", "text": "A young gazelle,"}, {"kind": "text", "text": "(S, Msb, K,)"}, {"kind": "italic_en", "text": "that has become active,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in motion,"}, {"kind": "text", "text": "(S, Msb,) or"}, {"kind": "italic_en", "text": "that has become strong,"}, {"kind": "text", "text": "(K,)"}, {"kind": "italic_en", "text": "and has walked"}, {"kind": "text", "text": "(S, Msb, K)"}, {"kind": "italic_en", "text": "with its mother:"}, {"kind": "text", "text": "(K:) pl."}, {"kind": "arabic", "text_bw": "A^aro$aA='N", "text_ar": "اَرْشَا=ءٌ"}, {"kind": "text", "text": ". (Msb, K.) [In the following saying, I find it written as though with medd; app. for the sake of assimilation to"}, {"kind": "arabic", "text_bw": "Aln~isaA='", "text_ar": "النِّسَا=ء"}, {"kind": "text", "text": ":]"}, {"kind": "arabic", "text_bw": "EinodiY jaAriyapN mina Aln~isaA='i A^a$obahu $aYo'K", "text_ar": "عِنْدِى جَارِيَةٌ مِنَ النِّسَا=ءِ اَشْبَهُ شَىْءٍ"}, {"kind": "arabic", "text_bw": "biAlr~a$aA='i", "text_ar": "بِالرَّشَا=ءِ"}, {"kind": "text", "text": ", meaning ["}, {"kind": "italic_en", "text": "I have with me a young woman most like to"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "the"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "young"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "gazelle:"}, {"kind": "text", "text": "so in the A. (TA.)"}], "source_refs": ["S", "Msb", "K"]}, {"entry_id": "n15619", "headword_ar": "رَشَا", "root": "r$w", "body": [{"kind": "text", "text": ", said of a young bird,"}, {"kind": "italic_en", "text": "It stretched forth its head to its mother in order that she should put food into its beak."}, {"kind": "text", "text": "(Abu-l-'Abbás [Th], Msb, TA.) ―         -b2-  Hence, [accord. to Th, but see"}, {"kind": "arabic", "text_bw": "ri$owNp", "text_ar": "رِشْوٌة"}, {"kind": "text", "text": ", below,]"}, {"kind": "arabic", "text_bw": "ra$aAhu", "text_ar": "رَشَاهُ"}, {"kind": "text", "text": ", (S, Mgh, Msb, K,) aor."}, {"kind": "arabic", "text_bw": "wyaro$uw", "text_ar": "ويَرْشُو"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "ra$owN", "text_ar": "رَشْوٌ"}, {"kind": "text", "text": ", (S, Msb,)"}, {"kind": "italic_en", "text": "He gave him a"}, {"kind": "arabic", "text_bw": "ri$owap", "text_ar": "رِشْوَة"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "bribe"}, {"kind": "text", "text": "]. (S, * Mgh, Msb, K.) [See also 3.]"}], "source_refs": ["S", "Mgh", "Msb", "K"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%B1%D8%B4%D8%A7/", "headword_ar": "رشا", "entries": [{"lexicon_id": "dictionary_14", "lexicon_en": "Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)", "lexicon_ar": "مختار الصحاح للرازي", "permalink": "https://arabiclexicon.hawramani.com/?p=5735#b34718", "body_html": "<span class=\"title1\">ر ش ا</span><span>: (الرِّشَاءُ) الْحَبْلُ وَجَمْعُهُ (أَرْشِيَةٌ) . وَ (الرِّشْوَةُ) بِكَسْرِ الرَّاءِ وَضَمِّهَا وَالْجَمْعُ (رِشًا) بِكَسْرِ الرَّاءِ وَضَمِّهَا وَقَدْ (رَشَاهُ) مِنْ بَابِ عَدَا. وَ (ارْتَشَى) أَخَذَ الرِّشْوَةَ وَ (اسْتَرْشَى) فِي حُكْمِهِ طَلَبَ الرِّشْوَةَ عَلَيْهِ وَ (أَرْشَاهُ) أَعْطَاهُ الرِّشْوَةَ. وَ (أَرْشَى) الدَّلْوَ جَعَلَ لَهُ رِشَاءً. </span>"}, {"lexicon_id": "dictionary_10", "lexicon_en": "Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)", "lexicon_ar": "المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني", "permalink": "https://arabiclexicon.hawramani.com/?p=5735#4051c3", "body_html": "<span class=\"title1\">(رشا)</span><span> - في الحديث: \"الرّاشِى، والمُرتَشِى- وفي رواية - والرَّائشُ في النار\" .</span><span> </span><span>وقيل: هذا إذا رَشَا لِينالَ به بَاطِلاً، فأمَّا إذا أعطى ليتَوصَّل إلى حَقّ أو يَدفَع ظُلماً فغَيْر داخلٍ فيه.</span><br><span>رُوىِ: أنَّ ابنَ مَسْعود أُخِذَ بأرضِ الحَبَشة في شَىء، فأَعطَى دِينَارَين حتى خُلِّى سَبِيلُه.</span><br><span>ورُوِى عن الحَسَنِ والشَّعبى وأَبِى الشَّعْثاء قالوا: لا بَأسَ أن يُصانِعَ الرَّجلُ عن نَفسِه وماله، إذا خاف الظُّلمَ.</span><br><span>وأمَّا الرائِشُ فهو الذي يَمشِى بَيْنَهما، والرُّشوة بكسر الراء وضمها: الوُصلَة إلى الحاجة بالمصانَعَة، من الرِّشاء . يقال: رَشَاه فارتَشَى. وقيل: هو من رَشَا الفَرخُ إذا مَدَّ عُنقَه إلى أُمَّه لتَزُقَّه. والرَّيش: الاصْطِناع، من رِيشِ السَّهم.</span>"}, {"lexicon_id": "dictionary_1", "lexicon_en": "Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)", "lexicon_ar": "لسان العرب لابن منظور", "permalink": "https://arabiclexicon.hawramani.com/?p=5735#c028c8", "body_html": "<p>رشا: الرَّشْوُ: فِعْلُ الرَّشْوَةِ، يقال: رَشَوْتُه. والمُراشاةُ:</p><p>المُحاباةُ. ابن سيده: الرَّشْوَةُ والرُّشْوَةُ والرِّشْوَةُ معروفة:</p><p>الجُعْلُ، والجمع رُشىً ورِشىً؛ قال سيبويه: من العرب من يقول رُشْوَةٌ</p><p>ورُشىً، ومنهم من يقول رِشْوَةٌ ورِشىً، والأَصل رُشىً، وأَكثر العرب يقول</p><p>رِشىً. ورَشاه يَرْشُوه رَشْواً: أَعطاه الرَّشْوَةَ. وقد رَشا رَشْوَةَ</p><p>وارْتَشى منه رَشْوةً إذا أَخذَها. وراشاهُ: حاباه. وتَرَشَّاه: لايَنَهُ.</p><p>وراشاه إذا ظاهرهَ. قال أَبو العباس: الرُّشْوَةُ مأْخوذة من رَشا الفَرْخُ</p><p>إذا مدَّ رأْسَه إلى أُمِّه لتَزُقَّه. أَبو عبيد: الرَّشا من أَولاد</p><p>الظِّباء الذي قد تحرَّك وتمشَّى. والرِّشاءُ: رَسَنُ الدَّلوِ.</p><p>والرَّائِشُ: الذي يُسْدي بين الرَّاشي والمُرْتَشي. وفي الحديث: لعَنَ اللهُ</p><p>الرَّاشِيَ والمُرْتَشِيَ والرَّائِشَ. قال ابن الأَثير: الرَّشْوَةُ</p><p>والرُّشْوَةُ الوُصْلَةُ إلى الحاجة بالمُصانعة، وأَصله من الرِّشاءِ الذي</p><p>يُتَوَصَّلُ به إلى الماء، فالرَّاشي من يُعطي الذي يُعينُه على الباطل،</p><p>والمُرْتَشي الآخذُ، والرَّائش الذي يسعى بينهما يَسْتَزيد لهذا ويَسْتَنْقِصُ</p><p>لهذا، فأَما ما يُعطى توصُّلاً إلى أَخذِ حَقٍّ أَو دفعِِ ظلمٍ فغيرُ</p><p>داخِلٍ فيه. وروي أَن ابن مسعود أُخِذَ بأَرضِ الحَبَشة في شيء فأَعْطى</p><p>دينارين حتى خُلِّيَ سبيلُه، وروي عن جماعة من أَئمة التابعين قالوا: لا</p><p>بأْس أَن يُصانعَ الرجلُ عن نفسهِ ومالهِ إذا خافَ الظُّلْمَ.</p><p>والرِّشاءُ: الحبْلُ، والجمع أَرْشِيَةٌ. قال ابن سيده: وإنما حملناه</p><p>على الواو لأَنه يُوصَلُ به إلى الماء كما يوصَلُ بالرُّشْوَةِ إلى ما</p><p>يُطلَبُ من الأَشياء. قال اللحياني: ومن كلام المؤَخِّذات للرجال أَخَّذْتُه</p><p>بدُبَّاء مُمَّلاٍ من الماءِ مُعَلَّقٍ بتِرْشاء؛ قال: التِّرْشاءُ</p><p>الحبل، لا يُسْتَعمَلُ هكذا إلا في هذه الأُخْذةِ. وأَرْشى الدَّلْوَ: جعل</p><p>لها رِشاءَ أي حَبْلاً. والرِِّشاءُ: من منازل القمر، وهو على التشبيه</p><p>بالحبل. الجوهري الرِّشاءُ كواكبُ كثيرة صغارٌ على صورة السَّمَكة يقال</p><p>لها بطنُ الحُوت، وفي سُرَّتِها كوكَبٌ نَيِّرٌ يِنزِلُه القمر.</p><p>وأَرْشِيَةُ الحنظلِ واليقطينِ: خُيوطه. وقد أَرْشَت الشجرةُ وأَرْشى الحنظلُ إذا</p><p>امْتَدَّتْ أَغصانُه. قال الأَصمعي: إذا امْتَدَّتْ أََغصانُ الحَنظل قيل</p><p>قد أَرْشَتْ أَي صارت كالأَرْشِيَة، وهي الحِبال. أَبو عمرو: اسْتَرْشى</p><p>ما في الضَّرْع واسْتَوْشى ما فيه إذا أخرجه. واسْتَرْشى في حكمه: طلب</p><p>الرَّشْوَة عليه. واسْتَرْشى الفصيلُ إذا طلب الرِّضاع، وقد أَرْشَيْتُه</p><p>إرْشاءً. ابن الأعرابي: أَرْشى الرجلُ إذا حكَّ خَوْرانَ الفصيل ليعدُوَ،</p><p>ويقال للفصيل الرَّشيُّ. والرَّشاةُ: نَبْتٌ يُشْرَب للْمَشِيِّ؛ وقال</p><p>كراع: الرَّشاةُ عُشبةٌ نحوُ القَرْنُوَةِ، وجمعها رَشاً.</p><p>قال ابن سيده: وحملْنا الرَّشيّ على الواو لوجود ر ش و وعدم ر ش ي.</p>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}