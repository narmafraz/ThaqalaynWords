{"lemma":"جَبانَةٌ","slug":"جَبانَةٌ","root":"ج.ب.ن","root_slug":"ج-ب-ن","root_link":"/words/roots/ج-ب-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n4913","n5011"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%A8%D8%A7%D9%86%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of جَبُنَ (jabuna) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"feminine singular of جَبَان (jabān)","tags":["feminine","form-of","singular"]},{"pos":"noun","gloss":"cemetery"}]},"etymology":null,"ipa":["/d͡ʒa.baː.na/","/d͡ʒab.baː.na/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4913","headword_ar":"جَبَّانَةٌ","root":"jb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jabuwbN","text_ar":"جَبُوبٌ"},{"kind":"text","text":"; and see art."},{"kind":"arabic","text_bw":"jbn","text_ar":"جبن"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n5011","headword_ar":"جَبَّانَةٌ","root":"jbn","body":[{"kind":"text","text":"(S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"jab~aAnN","text_ar":"جَبَّانٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) the former of which is the more common, (Msb,)"},{"kind":"italic_en","text":"A place of prayer,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"common place of prayer,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"in a"},{"kind":"arabic","text_bw":"SaHoraA='","text_ar":"صَحْرَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desert tract"},{"kind":"text","text":"]. (Mgh, Msb.) ―         -b2-"},{"kind":"italic_en","text":"A burial-ground:"},{"kind":"text","text":"(K:) this is sometimes called"},{"kind":"arabic","text_bw":"jb~Anp","text_ar":"جب