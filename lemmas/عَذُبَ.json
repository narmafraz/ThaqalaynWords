9%8E%D8%B0%D9%8F%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to torment, afflict, torture"},{"pos":"verb","gloss":"to cause one to be deterred, to beat or chase away"},{"pos":"adj","gloss":"fresh, potable"},{"pos":"adj","gloss":"dulcet, sweet"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28405","headword_ar":"عَذُبَ","root":"E*b","body":[{"kind":"text","text":", (S, O, Msb, K, TA,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"Eu*uwbapN","text_ar":"عُذُوبَةٌ"},{"kind":"text","text":", said of water, (S, O, Msb, K, TA,) [and app. of wine or other beverage, and of food, (see"},{"kind":"arabic","text_bw":"Ea*obN","text_ar":"عَذْبٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sweet:"},{"kind":"text","text":"(S, O, * TA:) or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy and agreeable to be drunk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swallowed."},{"kind":"text","text":"(Msb.) [See also 12. ―         -b2-  Freytag has also assigned to it a meaning belonging to"},{"kind":"arabic","text_bw":"A^aEo*aba","text_ar":"اَعْذَبَ"},{"kind":"text","text":", q. v.]       -A2-"},{"kind":"arabic","text_bw":"Ea*aba","text_ar":"عَذَبَ"},{"kind":"text","text":": see 4, in two places.       -A3-  And see also 2, last sentence.       -A4-  ["},{"kind":"arabic","text_bw":"Ea*iba","text_ar":"عَذِبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ea*abN","text_ar":"عَذَبٌ"},{"kind":"text","text":", is mentioned by Golius as signifying “"},{"kind":"italic_en","text":"Quisquiliis"},{"kind":"text","text":"aut"},{"kind":"italic_en","text":"lente palustri obducta fuit,"},{"kind":"text","text":"” and in a similar manner by Freytag; by both as said of water, and as on the authority of the K: but I find, in the K, no ground for this, except an explanation of"},{"kind":"arabic","text_bw":"Ea*ibN","text_ar":"عَذِبٌ"},{"kind":"text","text":", q.v., of which ISd knew not a verb.]"}],"source_refs":["S","O","Msb","K","TA"]}]}}