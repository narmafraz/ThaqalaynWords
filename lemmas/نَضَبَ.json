n":"m","num":"p"},{"role":"present_2mp","form":"تَنْضُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْضُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْضُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْضُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْضُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْضُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْضُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْضُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْضُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْضُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْضُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"نَضَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَضَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَنْضُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْضُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n39945"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B6%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sink, to run off into the earth, to flow off, to disappear, to get absorbed, to be depleted, to dry up, to run short"}]},"etymology":null,"ipa":["/na.dˤa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39945","headword_ar":"نَضَبَ","root":"nDb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, K, &c.) and also"},{"kind":"text","text":", (Msb,) which latter is strange, (MF,) inf. n."},{"kind":"arabic","text_bw":"nuDuwbN","text_ar":"نُضُوبٌ"},{"kind":"text","text":"; (S, K, &c.;) and ↓"},{"kind":"arabic","text_bw":"nD~b","text_ar":"نضّب","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"sank into the earth; disappeared in the earth:"},{"kind":"text","text":"(S, M, K, &c.:) and"},{"kind":"italic_en","text":"became low:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"became remote."},{"kind":"text","text":"(S, M.) ―         -b2-"},{"kind":"arabic","text_bw":"naDaba AlHawoDu","text_ar":"نَضَبَ الحَوْضُ"},{"kind":"text","text":", occurring in a verse cited by Th, ["},{"kind":"italic_en","text":"The water of the tank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cistern, sank into the earth"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"naDabato","text_ar":"نَضَبَتْ"},{"kind":"arabic","text_bw":"Euyuwnu AlT~aAy^ifi","text_ar":"عُيُونُ الطَّايِفِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The sources of El-Táïf became dried up"},{"kind":"text","text":"]. (A.) ―         -b4-"},{"kind":"arabic","text_bw":"maA naDaba Eanohu AlbaHoru wahuwa HaY~N","text_ar":"مَا نَضَبَ عَنْهُ البَحْرُ وَهُوَ حَىٌّ"},{"kind":"arabic","text_bw":"famaAta fakuluwhu","text_ar":"فَمَاتَ فَكُلُوهُ"},{"kind":"italic_en","text":"That from which the water of the sea has become exhausted, and has dried up, it being alive, and which has then died, eat ye it."},{"kind":"text","text":"(TA, from a trad.) ―         -b5-"},{"kind":"arabic","text_bw":"kun~aA EalaY $aATiy^i Aln~ahori biAloA^ahowaAzi","text_ar":"كُنَّا عَلَى شَاطِيِ النَّهْرِ بِالْاَهْوَازِ"},{"kind":"arabic","text_bw":"waqado naDaba Eanohu AlmaA'u","text_ar":"وَقَدْ نَضَبَ عَنْهُ المَاءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We were on the bank of the river in El-Ahwáz, and the water had sunk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receded, from it, leaving it dry"},{"kind":"text","text":"]. (TA, from a trad.) ―         -b6-"},{"kind":"arabic","text_bw":"naDabato Eayonuhu","text_ar":"نَضَبَتْ عَيْنُهُ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nuDuwbN","text_ar":"نُضُوبٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"His eye sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became depressed, in the socket:"},{"kind":"text","text":"or it is only said of the eye of a she-camel. (K.) ―         -b7-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(herbage and the like, that had been abundant,)"},{"kind":"italic_en","text":"became little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"failed altogether."},{"kind":"text","text":"(TA.) ―         -b8-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"text","text":"is met. used with reference to accidents [as it is properly with respect to substances]: thus it is said in a trad.,"},{"kind":"arabic","text_bw":"naDaba Eumoruhu","text_ar":"نَضَبَ عُمْرُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His life passed away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ended."},{"kind":"text","text":"(IAth.) This is what F means by saying"},{"kind":"arabic","text_bw":"naDaba fulaAnN","text_ar":"نَضَبَ فُلَانٌ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"maAta","text_ar":"مَاتَ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Such a one died."},{"kind":"text","text":"(TA.) ―         -b9-"},{"kind":"arabic","text_bw":"naDaba xayoruhu","text_ar":"نَضَبَ خَيْرُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nuDuwbN","text_ar":"نُضُوبٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"His goodness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beneficence, became little."},{"kind":"text","text":"(AZ.) ―         -b10-"},{"kind":"arabic","text_bw":"naDaba maA'u wajohihi","text_ar":"نَضَبَ مَاءُ وَجْهِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was not ashamed."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"nuDuwbN","text_ar":"نُضُوبٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a desert)"},{"kind":"italic_en","text":"was far-extending."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nuDuwbN","text_ar":"نُضُوبٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a people, or party,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distant."},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a people, or party,)"},{"kind":"italic_en","text":"strove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"used exertion,"},{"kind":"text","text":"[app.,"},{"kind":"italic_en","text":"in a journey."},{"kind":"text","text":"] (TA.)       -A3-"},{"kind":"arabic","text_bw":"naDaba","text_ar":"نَضَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, TA,)"},{"kind":"italic_en","text":"flowed, and ran"},{"kind":"text","text":"(K.) By our saying “ a thing, ” we mean to exclude water, though water is included in the definition of a thing: so that we need not infer from what is said in the K that the verb bears two contr. significations. (TA.) [But this observation appears to me to be scarcely admissible.] ―         -b2-"},{"kind":"arabic","text_bw":"naDabati Ald~abarapu","text_ar":"نَضَبَتِ الدَّبَرَةُ"},{"kind":"text","text":"[in the copies of the K in my hands, written"},{"kind":"arabic","text_bw":"daborap","text_ar":"دَبْرَة"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"The sore on the back of a camel &c. became severe."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"naDaba Ald~abaru","text_ar":"نَضَبَ الدَّبَرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The scar of the sore became severe and deep in the back."},{"kind":"text","text":"(A.)       -A4-"},{"kind":"arabic","text_bw":"naDaba Alv~awoba","text_ar":"نَضَبَ الثَّوْبَ"},{"kind":"italic_en","text":"He pulled off the garment."},{"kind":"text","text":"(Msb.)"}],"source_refs":["Msb","MF","S","K"]}]},"classical_definitions":null}