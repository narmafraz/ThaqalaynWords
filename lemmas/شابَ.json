in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَشُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شُبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شُبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"شِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شِبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشُوب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشُوب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":51,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n21537","n23451"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"young man, youth, adolescent"},{"pos":"verb","gloss":"to be grey-haired, to grow grey hair"},{"pos":"verb","gloss":"to become older"},{"pos":"verb","gloss":"to mix (بِـ (bi-) with)","examples":[{"text":"شَابَ اللَبَنَ بِالْمَاءِ","english":"He mixed the milk with the water."},{"text":"أما العليق فمعروف وأما الورد الجبلي وورد الكلب وهو المعروف عند أهل الطب بالنسرين قال أبو حنيفة الورد الجبلي يشبه الورد ويشبه ذلك بعض سنة العليق وثمره شبيه العنب الدليك وهو أحمر يشبه البسر إلا أن طرفه محدود وفي داخله شبه الصوف ونواره نوار الورد أبيض يشوبه حمرة","english":"In what concerns the bramble, it is well known, and in what concerns the mountain-rose and the dog-rose, it is well-known with the physicians as nisrīn; Abū Ḥanīfa said the mountain-rose resembles the rose and this resembles a bit the image of the bramble, and the fruit is similar to the dust-vine, it is red and resembles the unripe date, except that its tip is pointed, and in its inner there is a kind of wool, and its blossom is a white rose blossom with an admixture of red."}]},{"pos":"verb","gloss":"to be dishonest, to be untrustworthy (فِي (fī))","tags":["figuratively"],"examples":[{"text":"شَابَ فِي قَوْلِهِ","english":"He was dishonest in his speech"},{"text":"شَابَ فِي البَيْعِ","english":"He was untrustworthy in the sale (i.e. cheated, defrauded)"}]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of شَبَّ (šabba, “to become a young man, to grow up”).\n\nSee the root."},"ipa":["/ʃaːbb/","/ʃaː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21537","headword_ar":"شَابٌّ","root":"$b","body":[{"kind":"text","text":"part. n. of"},{"kind":"arabic","text_bw":"$ab~a","text_ar":"شَبَّ"},{"kind":"text","text":"said of a boy; (Msb;) ["},{"kind":"italic_en","text":"Youthful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the prime of manhood; a youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a young man;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the state from puberty to the completion of thirty years;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from sixteen years to thirty-two;"},{"kind":"text","text":"after which a man is called"},{"kind":"arabic","text_bw":"kaholN","text_ar":"كَهْلٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"in the age before"},{"kind":"arabic","text_bw":"Alkuhuwlap","text_ar":"الكُهُولَة"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"in the state between thirty and forty:"},{"kind":"text","text":"(Mgh:) [or"},{"kind":"italic_en","text":"in the state from the seventeenth year to the completion of fifty-one years:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"$abaAbN","text_ar":"شَبَابٌ"},{"kind":"text","text":":)] and IAar mentions ↓"},{"kind":"arabic","text_bw":"$ab~N","text_ar":"شَبٌّ","orth_type":"arrow"},{"kind":"text","text":"as an epithet applied to a man [in the same sense as"},{"kind":"arabic","text_bw":"$aAb~N","text_ar":"شَابٌّ"},{"kind":"text","text":"]: (TA:) a female is termed"},{"kind":"arabic","text_bw":"$aAb~apN","text_ar":"شَابَّةٌ"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"$ab~apN","text_ar":"شَبَّةٌ","orth_type":"arrow"},{"kind":"text","text":"; both signifying the same: (S, K:) the pl. of"},{"kind":"arabic","text_bw":"$aAb~N","text_ar":"شَابٌّ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"$ub~aAnN","text_ar":"شُبَّانٌ"},{"kind":"text","text":"(S, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"$ababapN","text_ar":"شَبَبَةٌ"},{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"$abaAbN","text_ar":"شَبَابٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, * K,) or the last is an inf. n. used as an epithet applied to a pl. number, (Mgh, and Ham p. 50,) or it is a quasi-pl. n.: (TA:) females, (Msb,) or women, (K,) are termed"},{"kind":"arabic","text_bw":"$awaAb~N","text_ar":"شَوَابٌّ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"$abaAy^ibu","text_ar":"شَبَايِبُ"},{"kind":"text","text":", (K,) the latter said by AZ to be allowable in the sense of the former, (TA,) which is pl. of"},{"kind":"arabic","text_bw":"$aAb~apN","text_ar":"شَابَّةٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"arabic","text_bw":"$abaAy^ibu","text_ar":"شَبَايِبُ"},{"kind":"text","text":", accord. to Az, being pl. (not of"},{"kind":"arabic","text_bw":"$aAb~apN","text_ar":"شَابَّةٌ"},{"kind":"text","text":"but) of"},{"kind":"arabic","text_bw":"$ab~apN","text_ar":"شَبَّةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"DaraAy^iru","text_ar":"ضَرَايِرُ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"Dar~apN","text_ar":"ضَرَّةٌ"},{"kind":"text","text":": (TA:) the dim. of"},{"kind":"arabic","text_bw":"$aAb~apN","text_ar":"شَابَّةٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"$uwayob~apN","text_ar":"شُوَيْبَّةٌ","orth_type":"arrow"},{"kind":"text","text":", and some of the Arabs say ↓"},{"kind":"arabic","text_bw":"$uwaAb~apN","text_ar":"شُوَابَّةٌ","orth_type":"arrow"},{"kind":"text","text":", changing the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"before a double letter [as in"},{"kind":"arabic","text_bw":"duwaAb~apN","text_ar":"دُوَابَّةٌ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"duwayob~apN","text_ar":"دُوَيْبَّةٌ"},{"kind":"text","text":"]. (ISd, L in art."},{"kind":"arabic","text_bw":"hd","text_ar":"هد"},{"kind":"text","text":".) One says,"},{"kind":"arabic","text_bw":"mararotu birijaAl K $ababapK","text_ar":"مَرَرْتُ بِرِجَال ٍ شَبَبَةٍ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"$ub~aAnK","text_ar":"شُبَّانٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I passed by men that were youths,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persons in the prime of manhood"},{"kind":"text","text":"]. (S.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"$ababN","text_ar":"شَبَبٌ"},{"kind":"text","text":"."}],"source_refs":["Msb","Mgh","TA","S","K","A"]},{"entry_id":"n23451","headword_ar":"شَابَ","root":"$yb","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$iybu","text_ar":"يَشِيبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ayobN","text_ar":"شَيْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ayobapN","text_ar":"شَيْبَةٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"ma$iybN","text_ar":"مَشِيبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He became whitehaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary."},{"kind":"text","text":"(Msb, TA.) And"},{"kind":"arabic","text_bw":"$Ab","text_ar":"شاب"},{"kind":"arabic","text_bw":"raA^osuhu","text_ar":"رَاْسُهُ"},{"kind":"text","text":"(S,) and"},{"kind":"arabic","text_bw":"raA^osuhaA","text_ar":"رَاْسُهَا"},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"$ayobN","text_ar":"شَيْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ayobapN","text_ar":"شَيْبَةٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"His head,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"her head, became white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary."},{"kind":"text","text":"(S, Msb, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"$aAbato ruw^uwsu AlA=kaAmi","text_ar":"شَابَتْ رُوُوسُ الا=كَامِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The heads,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"summits, of the hills became white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary"},{"kind":"text","text":"]. (A.)       -A2-  And"},{"kind":"arabic","text_bw":"$Ab Alr~aA^osa","text_ar":"شاب الرَّاْسَ"},{"kind":"italic_en","text":"It whitened the head:"},{"kind":"text","text":"so expl. by ISk as used in the following saying, (S,) ascribed by J to 'Adee, but it is of 'Abeed Ibn-El-Abras: (IB, TA:)"},{"kind":"quote","text":"taSobuw waA^an~aY laka Alt~aSaAbiY\n                      \n                     ↓ \n      waAlr~aA^osu qado $aAbahu Alma$iybu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou inclinest to silly and youthful conduct: but whence cometh to thee the inclining to such conduct when hoariness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the entering upon the period of hoariness, hath whitened the head?"},{"kind":"text","text":"]. (S, * IB, TA.) [See also 2.]"}],"source_refs":["Msb","TA","S","IB"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B4%D8%A7%D8%A8/","headword_ar":"شاباش","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=51749#729f3f","body_html":"شاباش: أحسنت، مرحى. ففي كتاب أبو حمُّو واسطة السلوك في سياسة الملوك (ص165): فبكى أبو الفتح بكاء شديداً ثم قال شاباش يا أبت شاباش أكثر لي من هذا الجيش."}]}}