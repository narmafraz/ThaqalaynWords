{"lemma":"اِحْمَرَّ","slug":"اِحْمَرَّ","root":"ح.م.ر","root_slug":"ح-م-ر","root_link":"/words/roots/ح-م-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"اِحْمَرَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"اِحْمَرَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"اِحْمَرَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"اِحْمَرَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"اِحْمَرَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"اِحْمَرَّ","in_corpus":true,"count":21,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"اِحْمَرَّت","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"اِحْمَرّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"اِحْمَرَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"اِحْمَرُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"اِحْمَرَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْمَرّ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَحْمَرِر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْمَرِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْمَرِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْمَرّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْمَرّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْمَرُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْمَرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْمَرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْمَرّ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْمَرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْمَرّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْمَرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْمَرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْمَرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْمَرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْمَرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْمَرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْمَرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْمَرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَحْمَرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْمَرّ","in_corpus":true,"count":21,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِحْمَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِحْمَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":54,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n9056","n9059","n9085"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AD%D9%92%D9%85%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to turn red"},{"pos":"verb","gloss":"to blush"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9056","headword_ar":"احمر","root":"Hmr","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"had a white child"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"waladN A^aHomaru","text_ar":"وَلَدٌ اَحْمَرُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"born to him."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"italic_en","text":"He fed"},{"kind":"text","text":"a beast"},{"kind":"italic_en","text":"so as to cause its mouth to become altered in odour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stinking,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"from much barley."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA"]},{"entry_id":"n9059","headword_ar":"احمرّ","root":"Hmr","body":[{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"AiHomiraArN","text_ar":"اِحْمِرَارٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It became"},{"kind":"arabic","text_bw":"A^aHomar","text_ar":"اَحْمَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"red"},{"kind":"text","text":"]; (Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AHmAr~","text_ar":"احمارّ","orth_type":"arrow"},{"kind":"text","text":": (K:) both these verbs signify the same: (S:) or the former signifies"},{"kind":"italic_en","text":"it was red, constantly, not changing from one state to another:"},{"kind":"text","text":"and ↓ the latter,"},{"kind":"italic_en","text":"it became red, accidentally, not remaining so;"},{"kind":"text","text":"as when you say,"},{"kind":"arabic","text_bw":"jaEala yaHomaAr~u mar~apF wayaSofaAr~u A^uxoraY","text_ar":"جَعَلَ يَحْمَارُّ مَرَّةً وَيَصْفَارُّ اُخْرَى"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, began to become red one time and yellow another."},{"kind":"text","text":"(TA.) [It is also said that] every verb of the measure"},{"kind":"arabic","text_bw":"AifoEal~a","text_ar":"اِفْعَلَّ"},{"kind":"text","text":"is contracted from"},{"kind":"arabic","text_bw":"AifoEaAl~a","text_ar":"اِفْعَالَّ"},{"kind":"text","text":"; and that the former measure is the more common because [more] easy to be pronounced. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AHmr~ AlbaA^osu","text_ar":"احمرّ البَاْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"War,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the war, became vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fierce:"},{"kind":"text","text":"(S, A, IAth, Msb, K:) or"},{"kind":"italic_en","text":"the fire of war burned fiercely."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","A","IAth"]},{"entry_id":"n9085","headword_ar":"اَحْمَرُ","root":"Hmr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Red:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"brown,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"] a thing"},{"kind":"italic_en","text":"of the colour termed"},{"kind":"arabic","text_bw":"HumorapN","text_ar":"حُمْرَةٌ"},{"kind":"text","text":": (Msb, K:) it is in animals, and in garments &c.; and, accord. to IAar, in water [when muddy]: and so ↓"},{"kind":"arabic","text_bw":"yaHomuwrN","text_ar":"يَحْمُورٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) fem. of the former"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"HumorN","text_ar":"حُمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HumoraAnN","text_ar":"حُمْرَانٌ"},{"kind":"text","text":": (K:) or when it means"},{"kind":"italic_en","text":"dyed with the colour termed"},{"kind":"arabic","text_bw":"HumorapN","text_ar":"حُمْرَةٌ"},{"kind":"text","text":", the pl. is"},{"kind":"arabic","text_bw":"HumorN","text_ar":"حُمْرٌ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"HumoraAnN","text_ar":"حُمْرَانٌ"},{"kind":"text","text":"; for you say"},{"kind":"arabic","text_bw":"viyaAbN HumorN","text_ar":"ثِيَابٌ حُمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HumoraAnN","text_ar":"حُمْرَانٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"red garments"},{"kind":"text","text":"]: (TA:) but if you apply it as an epithet to a man, [in which case it has other meanings than those explained above, as will be shown in what follows,] the pl. is"},{"kind":"arabic","text_bw":"A^aHaAmiru","text_ar":"اَحَامِرُ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"HumorN","text_ar":"حُمْرٌ"},{"kind":"text","text":": (TA:) or if it means"},{"kind":"italic_en","text":"a thing having the colour termed"},{"kind":"arabic","text_bw":"HumorapN","text_ar":"حُمْرَةٌ"},{"kind":"text","text":", the pl. is"},{"kind":"arabic","text_bw":"A^aHaAmiru","text_ar":"اَحَامِرُ"},{"kind":"text","text":", because, in this case, it is a subst., not an epithet. (Msb.) ↓"},{"kind":"arabic","text_bw":"A^aHomariY~N","text_ar":"اَحْمَرِىٌّ","orth_type":"arrow"},{"kind":"text","text":"also signifies the same as"},{"kind":"arabic","text_bw":"A^aHomaru","text_ar":"اَحْمَرُ"},{"kind":"text","text":": (Ham p. 379:) or, as some say, it has an intensive sense. (TA voce"},{"kind":"arabic","text_bw":"karuwbiy~uwna","text_ar":"كَرُوبِيُّونَ"},{"kind":"text","text":".) It is said in the S, in art."},{"kind":"arabic","text_bw":"dk","text_ar":"دك"},{"kind":"text","text":", that"},{"kind":"arabic","text_bw":"HamoraAwaAtN","text_ar":"حَمْرَاوَاتٌ"},{"kind":"text","text":"is a pl. of"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"dak~aAwaAtN","text_ar":"دَكَّاوَاتٌ"},{"kind":"text","text":", is of"},{"kind":"arabic","text_bw":"dak~aA='u","text_ar":"دَكَّا=ءُ"},{"kind":"text","text":"; but it is not so. (IB in that art.) ―         -b2-  Applied to a camel,"},{"kind":"italic_en","text":"Of a colour like that of saffron when a garment is dyed with it so that it stands up by reason of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the thickness of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the dye:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"of an unmixed red colour;"},{"kind":"text","text":"(As, S in art."},{"kind":"arabic","text_bw":"kmt","text_ar":"كمت"},{"kind":"text","text":", and TA;) and so the fem. when applied to a she-goat. (TA.) It is said that, of she-camels, the"},{"kind":"arabic","text_bw":"HamoraA='","text_ar":"حَمْرَا=ء"},{"kind":"text","text":"is the most able to endure the summer midday-heat; and the"},{"kind":"arabic","text_bw":"waroqaA='","text_ar":"وَرْقَا=ء"},{"kind":"text","text":", to endure nightjourneying; and that the"},{"kind":"arabic","text_bw":"SahobaA='","text_ar":"صَهْبَا=ء"},{"kind":"text","text":"is the most notable and the most beautiful to look at: so said Aboo-Nasr En-Na'ámee: and the Arabs say that the best of camels are the"},{"kind":"arabic","text_bw":"Humor","text_ar":"حُمْر"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"Suhob","text_ar":"صُهْب"},{"kind":"text","text":". (TA.) [Hence,]"},{"kind":"arabic","text_bw":"Humoru Aln~aEami","text_ar":"حُمْرُ النَّعَمِ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"The high-bred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent, of camels:"},{"kind":"text","text":"and is proverbially applied to"},{"kind":"page_break","n":642},{"kind":"italic_en","text":"anything highly prized, precious, valuable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent."},{"kind":"text","text":"(Mgh, Msb.) ―         -b3-  Applied to a man, (AA, Sh, Az,)"},{"kind":"italic_en","text":"White"},{"kind":"text","text":"(AA, Sh, Az, K)"},{"kind":"italic_en","text":"in complexion;"},{"kind":"text","text":"(Az;) because"},{"kind":"arabic","text_bw":"A^aboyaDu","text_ar":"اَبْيَضُ"},{"kind":"text","text":"might be considered as of evil omen [implying the meaning of leprosy]: (AA, Sh:) or, accord. to Th, because the latter epithet, applied to a man, was only used by the Arabs as signifying “ pure, ” or “ free from faults: ” but they sometimes used this latter epithet in the sense of “ white in complexion, ” applied to a man &c.: (IAth:) fem., in the same sense,"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":": the dim. of which, ↓"},{"kind":"arabic","text_bw":"HumayoraA='u","text_ar":"حُمَيْرَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", occurs in a trad., applied to 'Áïsheh. (K, * TA.) So, accord. to some, in the trad.,"},{"kind":"arabic","text_bw":"buEivotu A_ilaY AlA^aHomari","text_ar":"بُعِثْتُ اـِلَى الاَحْمَرِ"},{"kind":"arabic","text_bw":"waAlA^asowadi","text_ar":"وَالاَسْوَدِ"},{"kind":"text","text":", (TA,) i. e."},{"kind":"italic_en","text":"I have been sent to the white and the black;"},{"kind":"text","text":"because these two epithets comprise all mankind: (Az, TA:) [therefore, by the former we should understand the white and the red races; and by the latter, the negroes: but some hold that by the former are meant the foreigners, and] by the latter are meant the Arabs. (TA.) One says also, [when speaking of Arabs and more northern races,]"},{"kind":"arabic","text_bw":"A^ataAniY kul~u A^asowada","text_ar":"اَتَانِى كُلُّ اَسْوَدَ"},{"kind":"arabic","text_bw":"minohumo waA^aHomara","text_ar":"مِنْهُمْ وَاَحْمَرَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Every Arab of them, and foreigner, came to me:"},{"kind":"text","text":"and one should not say, in this sense,"},{"kind":"arabic","text_bw":"A^aboyaDa","text_ar":"اَبْيَضَ"},{"kind":"text","text":". (AA, As, S.)"},{"kind":"arabic","text_bw":"AlHamoraA='u","text_ar":"الحَمْرَا=ءُ"},{"kind":"text","text":", also, is applied to"},{"kind":"italic_en","text":"The foreigners"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlEajamu","text_ar":"العَجَمُ"},{"kind":"text","text":") ["},{"kind":"italic_en","text":"collectively"},{"kind":"text","text":"]; (S, A, K;) because a reddish white is the prevailing hue of their complexion: (S:) or"},{"kind":"italic_en","text":"the Persians and Greeks:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"those foreigners mostly characterized by whiteness of complexion; as the Greeks and Persians."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"layosa fiY","text_ar":"لَيْسَ فِى"},{"kind":"arabic","text_bw":"AlHamoraA='i mivoluhu","text_ar":"الحَمْرَا=ءِ مِثْلُهُ"},{"kind":"italic_en","text":"There is not among the foreigners"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlEajam","text_ar":"العَجَم"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the like of him."},{"kind":"text","text":"(A.) And accord. to some,"},{"kind":"arabic","text_bw":"AlA^aHomaru waAlA^aboyaDu","text_ar":"الاَحْمَرُ وَالاَبْيَضُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The Arabs and the foreigners."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"AlHamoraA='u","text_ar":"الحَمْرَا=ءُ"},{"kind":"text","text":"[so in the TA, but correctly"},{"kind":"arabic","text_bw":"A^abonaA='u AlHamoraA='i","text_ar":"اَبْنَا=ءُ الحَمْرَا=ءِ"},{"kind":"text","text":",] is an appellation applied to"},{"kind":"italic_en","text":"Emancipated slaves:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Aibonu HamoraA='i AlEijaAni","text_ar":"اِبْنُ حَمْرَا=ءِ العِجَانِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Son of the female slave,"},{"kind":"text","text":"is an appellation used in reviling and blaming. (TA.) ―         -b4-  Also (tropical:)  A man"},{"kind":"italic_en","text":"having no weapons with him:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"HumorN","text_ar":"حُمْرٌ"},{"kind":"text","text":"(A, K) and"},{"kind":"arabic","text_bw":"HumoraAnN","text_ar":"حُمْرَانٌ"},{"kind":"text","text":". (K.) ―         -b5-"},{"kind":"arabic","text_bw":"AlHusonu A^aHomaru","text_ar":"الحُسْنُ اَحْمَرُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Beauty is in"},{"kind":"arabic","text_bw":"AlHumorap","text_ar":"الحُمْرَة"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"fairness of complexion;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"beauty is fair-complexioned"},{"kind":"text","text":"]: (TA:) or (assumed tropical:)"},{"kind":"italic_en","text":"beauty is attended by difficulty;"},{"kind":"text","text":"i. e. he who loves beauty must bear difficulty, or distress: (IAth:) or the lover experiences from beauty what is experienced from war. (ISd, K.) ―         -b6-"},{"kind":"arabic","text_bw":"AlA^aHomaru","text_ar":"الاَحْمَرُ"},{"kind":"italic_en","text":"A sort of dates:"},{"kind":"text","text":"(K:) so called because of their colour. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"AlA^aHomaru waAlA^aboyaDu","text_ar":"الاَحْمَرُ وَالاَبْيَضُ"},{"kind":"italic_en","text":"Gold and silver."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlA^aHomaraAni","text_ar":"الاَحْمَرَانِ"},{"kind":"italic_en","text":"Flesh-meat and wine;"},{"kind":"text","text":"(S, A, K;) said to destroy men: (S:) so in the saying,"},{"kind":"arabic","text_bw":"naHonu mino A^aholi AlA^asowadayoni laA AlA^aHomarayoni","text_ar":"نَحْنُ مِنْ اَهْلِ الاَسْوَدَيْنِ لَا الاَحْمَرَيْنِ"},{"kind":"italic_en","text":"We are of the people of dates and water, not of flesh-meat and wine:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"the beverage called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"italic_en","text":"and flesh-meat."},{"kind":"text","text":"(IAar.) Also"},{"kind":"italic_en","text":"Wine and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garments of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"buruwd","text_ar":"بُرُود"},{"kind":"text","text":". (Sh.) And"},{"kind":"italic_en","text":"Gold and saffron;"},{"kind":"text","text":"(Az, ISd, K;) said to destroy women; i. e. the love of ornaments and perfumes destroys them: (Az:) or these are called"},{"kind":"arabic","text_bw":"AlA^aSofaraAni","text_ar":"الاَصْفَرَانِ"},{"kind":"text","text":"; (AO, TA;) and milk and water,"},{"kind":"arabic","text_bw":"AlA^aboyaDaAni","text_ar":"الاَبْيَضَانِ"},{"kind":"text","text":"; (TA;) and dates and water,"},{"kind":"arabic","text_bw":"AlA^asowadaAni","text_ar":"الاَسْوَدَانِ"},{"kind":"text","text":". (A, TA.) And"},{"kind":"arabic","text_bw":"AlA^aHaAmirapu","text_ar":"الاَحَامِرَةُ"},{"kind":"italic_en","text":"Flesh-meat and wine and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the perfume called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Alxaluwq","text_ar":"الخَلُوق"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"gold and flesh-meat and wine;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"AlA^axaADiru","text_ar":"الاَخَاضِرُ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"xDr","text_ar":"خضر"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"gold and saffron and"},{"kind":"arabic","text_bw":"Alxaluwq","text_ar":"الخَلُوق"},{"kind":"text","text":". (ISd, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"Almawotu AlA^aHomaru","text_ar":"المَوْتُ الاَحْمَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Slaughter;"},{"kind":"text","text":"(L, K;) because it occasions the flowing of blood: (TA:) and [so in the L, but in the K “ or ”] (tropical:)"},{"kind":"italic_en","text":"violent death:"},{"kind":"text","text":"(S, A, L, K:) or"},{"kind":"italic_en","text":"death in which the sight of the man becomes dim by reason of terror, so that the world appears red and black before his eyes:"},{"kind":"text","text":"(A 'Obeyd:) or it may mean (assumed tropical:)"},{"kind":"italic_en","text":"recent, fresh, death;"},{"kind":"text","text":"from the phrase next following. (As.) ―         -b9-"},{"kind":"arabic","text_bw":"waToA^apN HamoraA='u","text_ar":"وَطْاَةٌ حَمْرَا=ءُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A new,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recent, footstep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint:"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"dahomaA='u","text_ar":"دَهْمَا=ءُ"},{"kind":"text","text":". (As, S, A.) ―         -b10-"},{"kind":"arabic","text_bw":"sanapN HamoraA='u","text_ar":"سَنَةٌ حَمْرَا=ءُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A severe year;"},{"kind":"text","text":"(S, K;) because it is a mean between the"},{"kind":"arabic","text_bw":"sawodaA='","text_ar":"سَوْدَا=ء"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"bayoDA='","text_ar":"بَيْضا=ء"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"a year of severe drought;"},{"kind":"text","text":"because, in such a year, the tracts of the horizon are red: (TA:) when"},{"kind":"arabic","text_bw":"Aljabohapu","text_ar":"الجَبْهَةُ"},{"kind":"text","text":"[the tenth Mansion of the Moon (see"},{"kind":"arabic","text_bw":"manaAzilu Alqamari","text_ar":"مَنَازِلُ القَمَرِ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"nzl","text_ar":"نزل"},{"kind":"text","text":")] breaks its promise [of bringing rain], the year is such as is thus called. (AHn.) ―         -b11-  See also"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"HamaAr~apN","text_ar":"حَمَارَّةٌ"},{"kind":"text","text":". ―         -b12-"},{"kind":"arabic","text_bw":"jaA='a biganamihi Humora AlkulaY","text_ar":"جَا=ءَ بِغَنَمِهِ حُمْرَ الكُلَى"},{"kind":"text","text":", and, in like manner,"},{"kind":"arabic","text_bw":"suwda AlbuTuwni","text_ar":"سُودَ البُطُونِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He brought his sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, in a lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an emaciated, state."},{"kind":"text","text":"(A, * TA.)"}],"source_refs":["Msb","K","S","TA","AA","Sh","Az","IAth","A","L"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D8%AD%D9%85%D8%B1/","headword_ar":"أحمر","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=117174#8388cd","body_html":"أحمر<br>من (ح م ر) بمعنى اللون القرمزي أو بمعنى صباحة وإشراق الوجه."}]}}