{"lemma":"سَبَئِيٌّ","slug":"سَبَئِيٌّ","root":"س.ب.#","root_slug":"س-ب-_","root_link":"/words/roots/س-ب-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"Sabaean"},{"pos":"noun","gloss":"Sabaean"}]},"etymology":{"source":"wiktextract","text":"سَبَأ (sabaʔ, “Saba”) + ـِيّ (-iyy)."},"ipa":["/sa.ba.ʔijj/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A8%D8%A6%D9%8A/","headword_ar":"سبئية","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23307#641d40","body_html":"<span>السبئية: هم أصحاب عبد الله بن سبأ، قال لعلي رضي الله عنه: أنت الإله حقًا، فنفاه علي إلى المدائن، وقال ابن سبأ: لم يمت علي ولم يُقتَل، وإنما قتل ابن ملجم شيطانًا تصور بصورة علي رضي الله عنه، وعلي في السحاب، والرعد صوته، والبرق سوطه، وأنه ينزل بعد هذا إلى الأرض ويملؤها عدلًا، وهؤلاء يقولون عند سماع الرعد: عليك السلام يا أمير المؤمنين.</span>"}]}}