{"lemma":"ثَمانِي","slug":"ثَمانِي","root":"ث.م.ن","root_slug":"ث-م-ن","root_link":"/words/roots/ث-م-ن","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"ثَمانِي","root":"ثمن","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":false}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AB%D9%85%D8%A7%D9%86%D9%8A/","headword_ar":"ثماني","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=138948#24f1bf","body_html":"ثماني:<br>بلفظ الثماني من العدد المؤنث، قيل: هي أجبال وغارات بالصمان، وقال نصر: الثماني هضبات ثمان في أرض بني تميم، وقيل: هي من بلاد بني سعد بن زيد مناة بن تميم وأنشدوا لذي الرّمة:<br>ولم يبق مما في الثماني بقية<br>وقال سوّار بن المضرّب المازني في أبيات ذكرت في شنظب:<br>أمن أهل النّقا طرقت سليمى ... طريدا بين شنظب فالثماني؟"}]}}