","text":": see"},{"kind":"arabic","text_bw":"HusonN","text_ar":"حُسْنٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n8027","headword_ar":"مُحْسِنٌ","root":"Hsn","body":[{"kind":"italic_en","text":"Doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who does, that which is"},{"kind":"arabic","text_bw":"Hasan","text_ar":"حَسَن"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"good, comely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing"},{"kind":"text","text":"]; (K, TA;) as also ↓"},{"kind":"arabic","text_bw":"miHosaAnN","text_ar":"مِحْسَانٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the latter [is an intensive epithet, meaning"},{"kind":"italic_en","text":"doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who does, much that is good, comely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing:"},{"kind":"text","text":"or] means"},{"kind":"italic_en","text":"constantly doing that which is"},{"kind":"arabic","text_bw":"Hasan","text_ar":"حَسَن"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A_in~aA naraAka mina AlmuHosiniyna","text_ar":"اـِنَّا نَرَاكَ مِنَ المُحْسِنِينَ"},{"kind":"text","text":", in the Kur xii. 36, means (tropical:)"},{"kind":"italic_en","text":"Verily we see thee to be of those who know,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"know well, the interpretation of dreams:"},{"kind":"text","text":"(Ksh, Bd, TA: *) or (assumed tropical:)"},{"kind":"italic_en","text":"of those endowed with knowledge:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the doers of good to the prisoners:"},{"kind":"text","text":"(Ksh, Bd:) or"},{"kind":"italic_en","text":"of those who aid the weak and the sufferer of wrong, and visit the sick."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","Ksh","Bd"]},{"entry_id":"n8029","headword_ar":"مُحَسَّنٌ","root":"Hsn","body":[{"kind":"text","text":": see"},{"kind":"a