xt_ar":"فُلَانٌ عَنِ البَلَدِ"},{"kind":"italic_en","text":"Such a one became absent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, from the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town."},{"kind":"text","text":"(Msb.)"}],"source_refs":["T","S","Msb","K","M"]},{"entry_id":"n34430","headword_ar":"اَفْلُّ","root":"fl","body":[{"kind":"text","text":", applied to a sword [or the like], (T, S, O, K,)"},{"kind":"italic_en","text":"Having breaks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notches, in its edge;"},{"kind":"text","text":"(T, S, * O; *) or"},{"kind":"italic_en","text":"broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notched, in its edge;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mafoluwlN","text_ar":"مَفْلُولٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"munofal~N","text_ar":"مُنْفَلٌّ","orth_type":"arrow"},{"kind":"text","text":". (M, K.)"},{"kind":"arabic","text_bw":"AlA^afal~u","text_ar":"الاَفَلُّ"},{"kind":"text","text":"was the name of a sword of 'Adee Ibn-Hátim (O, K) Et- Tá-ee. (O.)"}],"source_refs":["T","S","O","K"]}]}}