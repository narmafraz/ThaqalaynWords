{"lemma":"تَفَكُّرٌ","slug":"تَفَكُّرٌ","root":"ف.ك.ر","root_slug":"ف-ك-ر","root_link":"/words/roots/ف-ك-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ponder, to reflect"},{"pos":"noun","gloss":"verbal noun of تَفَكَّرَ (tafakkara) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thinking, pondering, reflecting reflection"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of تَفَكَّرَ (tafakkara)."},"ipa":["/ta.fak.ka.ra/","/ta.fak.kur/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D9%81%D9%83%D8%B1/","headword_ar":"تفكر","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23117#1bb2ce","body_html":"<span>التفكر: تصرف القلب في معاني الأشياء؛ لدرك المطلوب.</span>"},{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23117#a2a176","body_html":"<span>التفكر: سراج القلب يرى به خيره وشره، ومنافعه ومضاره، وكل قلب لا تفكر فيه فهو في ظلمات يتخبط، وقيل: هو إحضار ما في القلب من معرفة الأشياء وقيل: التفكر: تصفية القلب بموارد الفوائد، وقيل: مصباح الاعتبار، ومفتاح الاختيار، وقيل: حديقة أشجار الحقائق، وحدقة أنوار الدقائق، وقيل: مزرعة الحقيقة، ومشرعة الشريعة، وقيل: فناء الدنيا وزوالها، وميزان بقاء الآخرة ونوالها، وقيل: شبكة طائر الحكمة، وقيل: هو العبارة عن الشيء بأسهل وأيسر من لفظ الأصل.</span>"}]}}