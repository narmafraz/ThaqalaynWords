{"lemma":"زُهْدُ","slug":"زُهْدُ","root":"ز.ه.د","root_slug":"ز-ه-د","root_link":"/words/roots/ز-ه-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n18295","n18296"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8F%D9%87%D9%92%D8%AF%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to abstain, to refrain (+ فِي (fī)/عَنْ (ʕan): from)"},{"pos":"verb","gloss":"to renounce, to forsake, to abandon"},{"pos":"verb","gloss":"to withdraw"},{"pos":"noun","gloss":"abstinence, renunciation"},{"pos":"noun","gloss":"asceticism"},{"pos":"noun","gloss":"verbal noun of زَهَدَ (zahada) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18295","headword_ar":"زَهْدٌ","root":"zhd","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A small quantity."},{"kind":"text","text":"(A.) You say,"},{"kind":"arabic","text_bw":"xu*o","text_ar":"خُذْ"},{"kind":"arabic","text_bw":"zahoda maA yakofiyka","text_ar":"زَهْدَ مَا يَكْفِيكَ"},{"kind":"text","text":"(JK, S, K) (tropical:)"},{"kind":"italic_en","text":"Take thou the small quantity that is sufficient for thee:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"as much as is sufficient for thee."},{"kind":"text","text":"(JK, S.)"}],"source_refs":["JK","S","K","A"]},{"entry_id":"n18296","headword_ar":"زَهَدٌ","root":"zhd","body":[{"kind":"text","text":"(tropical:)  The"},{"kind":"italic_en","text":"poor-rate;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zakaApN","text_ar":"زَكَاةٌ"},{"kind":"text","text":": (A, K:) mentioned by Aboo-Sa'eed, on the authority of Mubtekir El-Bedawee: so called, accord. to Aboo-Sa'eed, because of its littleness; the"},{"kind":"arabic","text_bw":"zkAp","text_ar":"زكاة"},{"kind":"text","text":"of property being the least portion of it; or, accord. to the A, because the fortieth part [which is its general proportion] is little. (TA.) So in the saying,"},{"kind":"arabic","text_bw":"maA laka tamonaEu Alz~ahada","text_ar":"مَا لَكَ تَمْنَعُ الزَّهَدَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"What aileth thee that thou refusest the poor-rate?"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["A","K"]}]}}