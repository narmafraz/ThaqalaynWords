gen":"m","num":"d"},{"role":"present_2mp","form":"تُدَوُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدَوُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدَوِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدَوّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُدَوِّي","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدَوّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُدَوِّي","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدَوِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدَوِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدَوِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَوِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدَوُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَوُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدَوِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُدَوّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَوَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَوَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُدَوِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدَوِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n13342","n13510","n13344","n13528","n13345","n13529","n13509","n13515","n13521","n13522"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%88%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"alternative form of دَوَى (dawā)","tags":["alt-of","alternative"]},{"pos":"noun","gloss":"verbal noun of دَوَى (dawā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"hum, buzz, noise"},{"pos":"noun","gloss":"echo"},{"pos":"verb","gloss":"to become sick, to become ill"},{"pos":"verb","gloss":"to become consumptive, to get tuberculosis"},{"pos":"verb","gloss":"to become pestilential (of a land)"},{"pos":"verb","gloss":"to hold a grudge"},{"pos":"verb","gloss":"to become foolish"},{"pos":"noun","gloss":"desert"},{"pos":"noun","gloss":"inhabitant of the desert"},{"pos":"noun","gloss":"someone, somebody"}]},"etymology":null,"ipa":["/da.wi.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13342","headword_ar":"دوّى","root":"dw","body":[{"kind":"italic_en","text":"He took his way in the"},{"kind":"arabic","text_bw":"daw~","text_ar":"دَوّ"},{"kind":"text","text":"[q. v.]. (M, K.) And"},{"kind":"arabic","text_bw":"dw~Y fiYAlA^aroDi","text_ar":"دوّى فِىالاَرْضِ"},{"kind":"italic_en","text":"He went away into the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the land."},{"kind":"text","text":"(T.) Ru-beh uses the phrase"},{"kind":"arabic","text_bw":"dw~Y bihaA","text_ar":"دوّى بِهَا"},{"kind":"text","text":"as signifying"},{"kind":"italic_en","text":"He passed by them;"},{"kind":"text","text":"meaning, by them, a male [wild] ass and his she-asses. (T.) And it is said of the"},{"kind":"arabic","text_bw":"daw~iy~ap","text_ar":"دَوِّيَّة"},{"kind":"text","text":"that it is thus called"},{"kind":"arabic","text_bw":"liA^an~ahaA tudaw~iY SaAra fiyhaA","text_ar":"لِاَنَّهَا تُدَوِّى صَارَ فِيهَا"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Because it makes away with those who are in it."},{"kind":"text","text":"(T.)       -A2-  See also art."},{"kind":"arabic","text_bw":"dwY","text_ar":"دوى"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13510","headword_ar":"دوّى","root":"dwY","body":[{"kind":"text","text":", (T, S, M, K,) inf. n."},{"kind":"arabic","text_bw":"tadowiyapN","text_ar":"تَدْوِيَةٌ"},{"kind":"text","text":", (T, S, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made a sound;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is termed"},{"kind":"arabic","text_bw":"dawiY~","text_ar":"دَوِىّ"},{"kind":"text","text":"; (T, M;) [i. e.,"},{"kind":"italic_en","text":"a confused and continued sound;"},{"kind":"text","text":"such as the"},{"kind":"italic_en","text":"rustling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"murmuring,"},{"kind":"text","text":"of the wind; and the"},{"kind":"italic_en","text":"rustling"},{"kind":"text","text":"of a bird; and the"},{"kind":"italic_en","text":"humming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buzzing,"},{"kind":"text","text":"of bees; and the"},{"kind":"italic_en","text":"rumbling"},{"kind":"text","text":"of thunder; or the"},{"kind":"italic_en","text":"distant sound"},{"kind":"text","text":"of rain and of thunder;] accord. to some, particularly said of thunder [as meaning"},{"kind":"italic_en","text":"it made a rumbling sound"},{"kind":"text","text":"]; (M;) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a cloud)"},{"kind":"italic_en","text":"thundered:"},{"kind":"text","text":"(KL:) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a stallioncamel)"},{"kind":"italic_en","text":"brayed so as to make a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"rumbling"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound such as is termed"},{"kind":"arabic","text_bw":"dawiY~","text_ar":"دَوِىّ"},{"kind":"italic_en","text":"to be heard."},{"kind":"text","text":"(T, S, K.)       -A2-  [Also,] said of a bird,"},{"kind":"italic_en","text":"It circled in the air without moving its wings:"},{"kind":"text","text":"(Msb:) or, accord. to As, one says of a dog,"},{"kind":"arabic","text_bw":"dw~Y fiY AlA^aroDi","text_ar":"دوّى فِى الاَرْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he went round upon the ground"},{"kind":"text","text":"]; like as one says of a bird,"},{"kind":"arabic","text_bw":"daw~ama fiYAls~amaA='i","text_ar":"دَوَّمَ فِىالسَّمَا=ءِ"},{"kind":"text","text":", meaning “ it circled in its flight, rising: ” he says that"},{"kind":"arabic","text_bw":"Alt~adowiymu","text_ar":"التَّدْوِيمُ"},{"kind":"text","text":"is not upon the ground, nor"},{"kind":"arabic","text_bw":"Alt~adowiyapu","text_ar":"التَّدْوِيَةُ"},{"kind":"text","text":"in the sky; and he finds fault with the first of the verses of Dhu-r-Rummeh cited in the second paragraph of art."},{"kind":"arabic","text_bw":"dwm","text_ar":"دوم"},{"kind":"text","text":": but some say that the two verbs are dial. vars., both meaning"},{"kind":"italic_en","text":"he went round about."},{"kind":"text","text":"(S. [See also"},{"kind":"arabic","text_bw":"daw~ama","text_ar":"دَوَّمَ"},{"kind":"text","text":", in two places.]) ―         -b2-  See also 2 in art."},{"kind":"arabic","text_bw":"dw","text_ar":"دو"},{"kind":"text","text":".       -A3-  Also, (T, S, M, K,) and the like, (K,) and of broth, (T, S, M,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, overspread with the thin skin termed"},{"kind":"arabic","text_bw":"dawaAyapN","text_ar":"دَوَايَةٌ"},{"kind":"text","text":". (T, S, M, K.) And, said of water,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, overspread with what was raised and scattered by the wind,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"resembling what is termed"},{"kind":"arabic","text_bw":"duwaAyap","text_ar":"دُوَايَة"},{"kind":"text","text":". (M.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"daw~ati AlA^aroDu","text_ar":"دَوَّتِ الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land became overspread with various herbage;"},{"kind":"text","text":"as though it were the"},{"kind":"arabic","text_bw":"duwaAyap","text_ar":"دُوَايَة"},{"kind":"text","text":"of milk. (T.)       -A4-"},{"kind":"arabic","text_bw":"daw~ayotuhu","text_ar":"دَوَّيْتُهُ"},{"kind":"text","text":", (inf. n. as above, TA,)"},{"kind":"italic_en","text":"I gave him the"},{"kind":"arabic","text_bw":"duwaAyap","text_ar":"دُوَايَة"},{"kind":"italic_en","text":"of milk,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"of broth, to eat it."},{"kind":"text","text":"(M.)       -A5-  And"},{"kind":"arabic","text_bw":"dw~Y","text_ar":"دوّى"},{"kind":"italic_en","text":"He sold"},{"kind":"text","text":"[and app."},{"kind":"italic_en","text":"made"},{"kind":"text","text":"also (see"},{"kind":"arabic","text_bw":"mudaw~K","text_ar":"مُدَوٍّ"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"what is called"},{"kind":"arabic","text_bw":"dawaAp","text_ar":"دَوَاة"},{"kind":"text","text":". (TA.)"}],"source_refs":["T","S","M","K","KL","Msb"]},{"entry_id":"n13344","headword_ar":"دَوِّىٌّ","root":"dw","body":[{"kind":"text","text":"[a rel. n. from"},{"kind":"arabic","text_bw":"daw~N","text_ar":"دَوٌّ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"One inhabiting a"},{"kind":"arabic","text_bw":"daw~","text_ar":"دَوّ"},{"kind":"text","text":". (S.) [Hence the saying,]"},{"kind":"arabic","text_bw":"maA bihaA daw~iY~N","text_ar":"مَا بِهَا دَوِّىٌّ"},{"kind":"text","text":", (S, K, TA, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"dawiY~N","text_ar":"دَوِىٌّ"},{"kind":"text","text":",]) and ↓,"},{"kind":"arabic","text_bw":"duw~iY~N","text_ar":"دُوِّىٌّ"},{"kind":"text","text":"(Sgh, K, TA, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"duwiY~N","text_ar":"دُوِىٌّ"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"duwowiY~N","text_ar":"دُوْوِىٌّ"},{"kind":"text","text":", as in the M, or ↓"},{"kind":"arabic","text_bw":"dawawiY~N","text_ar":"دَوَوِىٌّ"},{"kind":"text","text":", as in the K, (TA,) i. e. ["},{"kind":"italic_en","text":"There is not in it"},{"kind":"text","text":"(meaning"},{"kind":"arabic","text_bw":"biAld~aAri","text_ar":"بِالدَّارِ"},{"kind":"italic_en","text":"in the house"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"any one"},{"kind":"text","text":"(S, M, K)"},{"kind":"italic_en","text":"of those who inhabit the"},{"kind":"arabic","text_bw":"daw~","text_ar":"دَوّ"},{"kind":"text","text":": like as one says"},{"kind":"arabic","text_bw":"maA bihaA TuwriY~N","text_ar":"مَا بِهَا طُورِىٌّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"duwriY~N","text_ar":"دُورِىٌّ"},{"kind":"text","text":". (S.) ―         -b2-  See"},{"kind":"arabic","text_bw":"daw~N","text_ar":"دَوٌّ"},{"kind":"text","text":", with which it is also syn. (S.)"}],"source_refs":["TA","S","M","K"]},{"entry_id":"n13528","headword_ar":"دَوِّىٌّ","root":"dwY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"dw","text_ar":"دو"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13345","headword_ar":"دُوِّىٌّ","root":"dw","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"duwowiY~N","text_ar":"دُوْوِىٌّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"dawawiY~N","text_ar":"دَوَوِىٌّ"},{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]},{"entry_id":"n13529","headword_ar":"دُوِّىٌّ","root":"dwY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"dw","text_ar":"دو"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13509","headword_ar":"دَوِىَ","root":"dwY","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"arabic","text_bw":"yadowaY","text_ar":"يَدْوَى"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"dawFY","text_ar":"دَوًى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, diseased, disordered, distempered, sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ill:"},{"kind":"text","text":"(S, M, Msb, K:) and"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with consumption,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ulceration of the lungs."},{"kind":"text","text":"(M.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"dawiYa Sadoruhu","text_ar":"دَوِىَ صَدْرُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His bosom was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite."},{"kind":"text","text":"(S.)"}],"source_refs":["S","M","Msb","K"]},{"entry_id":"n13515","headword_ar":"دَوًى","root":"dwY","body":[{"kind":"italic_en","text":"Disease, disorder, distemper, sickness, illness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"malady:"},{"kind":"text","text":"(S, M, K:) and"},{"kind":"italic_en","text":"consumption,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ulceration of the lungs:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"internal disease in the chest;"},{"kind":"text","text":"whereas"},{"kind":"arabic","text_bw":"daA='N","text_ar":"دَا=ءٌ"},{"kind":"text","text":"signifies such as is external or internal. (Lth, T.) [Being properly an inf. n., it is app. used alike as sing. and pl. in all its senses: or it may, when signifying as explained above, have for its pl."},{"kind":"arabic","text_bw":"A^adowaA='N","text_ar":"اَدْوَا=ءٌ"},{"kind":"text","text":", which is pl. of"},{"kind":"arabic","text_bw":"daA='N","text_ar":"دَا=ءٌ"},{"kind":"text","text":".]       -A2-  See also"},{"kind":"arabic","text_bw":"dawK","text_ar":"دَوٍ"},{"kind":"text","text":", below, in three places. ―         -b2-  Also"},{"kind":"italic_en","text":"Foolish; stupid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound, dull,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient, in intellect;"},{"kind":"text","text":"(S, M, K;) applied to a man. (S.) ―         -b3-  And (so applied, TA)"},{"kind":"italic_en","text":"Cleaving to his place;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"not quitting it."},{"kind":"text","text":"(M.)       -A3-  See also"},{"kind":"arabic","text_bw":"dawaApN","text_ar":"دَوَاةٌ"},{"kind":"text","text":"."}],"source_refs":["S","M","K"]},{"entry_id":"n13521","headword_ar":"دَوِىٌّ","root":"dwY","body":[{"kind":"text","text":":"},{"kind":"italic_en","text":"A sound:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"a confused and continued sound"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"HafiyfN","text_ar":"حَفِيفٌ"},{"kind":"text","text":"); as [the"},{"kind":"italic_en","text":"rustling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"murmuring,"},{"kind":"text","text":"] of the wind; and [the"},{"kind":"italic_en","text":"rustling"},{"kind":"text","text":"] of a bird; and [the"},{"kind":"italic_en","text":"humming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buzzing,"},{"kind":"text","text":"] of bees: (S, K:) and the"},{"kind":"italic_en","text":"distant sound"},{"kind":"text","text":"of rain and of thunder: (T:) or, as some say, particularly the ["},{"kind":"italic_en","text":"rumbling"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound"},{"kind":"text","text":"of thunder: (M:) [and"},{"kind":"italic_en","text":"a ringing in the"},{"kind":"page_break","n":941},{"kind":"italic_en","text":"ears;"},{"kind":"text","text":"as in the saying]"},{"kind":"arabic","text_bw":"xalaA baToniYmina AlT~aEaAmi","text_ar":"خَلَا بَطْنِىمِنَ الطَّعَامِ"},{"kind":"arabic","text_bw":"Hat~aYsamiEotu diway~FA limasaAmiEiY","text_ar":"حَتَّىسَمِعْتُ دِوَيًّا لِمَسَامِعِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My belly became empty of food so that I heard a ringing in my ears"},{"kind":"text","text":"]. (T.)       -A2-  [It is also an epithet; whence]"},{"kind":"arabic","text_bw":"A^aroDN daw~iyapN","text_ar":"اَرْضٌ دَوِّيَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dawK","text_ar":"دَوٍ"},{"kind":"text","text":", last sentence."}],"source_refs":["M","S","K","T"]},{"entry_id":"n13522","headword_ar":"دُوِىٌّ","root":"dwY","body":[{"kind":"text","text":"[an epithet; whence]"},{"kind":"arabic","text_bw":"A^aroDN duwiy~apN","text_ar":"اَرْضٌ دُوِيَّةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dawK","text_ar":"دَوٍ"},{"kind":"text","text":", last sentence."}],"source_refs":[]}]},"classical_definitions":null}