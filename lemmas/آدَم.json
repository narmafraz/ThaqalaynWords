rabic","text_bw":"A_idaAmN","text_ar":"اـِدَامٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"huwa A^udomu A^aholihi","text_ar":"هُوَ اُدْمُ اَهْلِهِ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A^udomu baniY A^abiyhi","text_ar":"اُدْمُ بَنِى اَبِيهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adamapN","text_ar":"اَدَمَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n446","headword_ar":"اَدَمٌ","root":"Adm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adiymN","text_ar":"اَدِيمٌ"},{"kind":"text","text":", in two places: ―         -b2-  and"},{"kind":"arabic","text_bw":"A^adamapN","text_ar":"اَدَمَةٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"A^adamu","text_ar":"اَدَمُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=damu","text_ar":"ا=دَمُ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13024","headword_ar":"ادمّ","root":"dm","body":[{"kind":"italic_en","text":"He did what was bad, evil, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aqobaHa","text_ar":"اَقْبَحَ"},{"kind":"text","text":"(Lth, T, K) and"},{"kind":"arabic","text_bw":"A^asaA='a","text_ar":"اَسَا=ءَ"},{"kind":"text","text":": (Lth, T: [see also 1, last sentence: in the K, also, and in the M, the sec. pers.,"},{"kind":"arabic","text_bw":"A^adomamota","text_ar":"اَدْمَمْتَ"},{"kind":"text","text":", is explained as meaning"},{"kind":"arabic","text_bw":"A^aqobaHota AlfiEola","text_ar":"اَقْبَحْتَ الفِعْلَ"},{"kind":"text","text":", which is a pleonasm for"},{"kind":"arabic","text_bw":"A^aqobaHota","text_ar":"اَقْبَحْتَ"},{"kind":"text","text":":]) or"},{"kind":"italic_en","text":"he had a child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring, borne to him such as is termed"},{"kind":"arabic","text_bw":"damiymN","text_ar":"دَمِيمٌ"},{"kind":"text","text":"(K, TA) or"},{"kind":"arabic","text_bw":"qabiyHN","text_ar":"قَبِيحٌ"},{"kind":"arabic","text_bw":"damiymN","text_ar":"دَمِيمٌ"},{"kind":"text","text":"(so in the CK)"},{"kind":"italic_en","text":"in make."},{"kind":"text","text":"(TA.)"}],"source_refs":["Lth","T","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A2%D8%AF%D9%85/","headword_ar":"آدم","entries":[{"lexicon_id":"dictionary_38","lexicon_en":"Hamiduddin Farahi, Mufradāt al-Qurʾān (d. 1930 CE)","lexicon_ar":"مفردات القرآن للفراهي","permalink":"https://arabiclexicon.hawramani.com/?p=59259#26763c","body_html":"<span class=\"title1\">آدم</span><br><span>من الأُدْمَة، وهي السُّمْرَة في الإنسان، والبياضُ الشديدُ في الإبل. يقال: بعير آدم وناقة أدماء. وإنما سُمّي أبو البشر آدمَ للونه ، كما سميت الحوّاء عليها السلام من الحُوّة، وهي لون أميل إلى السواد. وهذان الاسمان يوجدان في العبرانية بتغير يسير . والعربية أحفظ وأقرب إلى الأصل، إن لم تكن هي الأصل .</span>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=59259#2b36ae","body_html":"<span class=\"title1\">آدم</span><br><span>آدم أبو البشر، قيل: سمّي بذلك لكون جسده من أديم الأرض، وقيل: لسمرةٍ في لونه. يقال:</span><br><span>رجل آدم نحو أسمر، وقيل: سمّي بذلك لكونه من عناصر مختلفة وقوى متفرقة، كما قال تعالى:</span><br><span>مِنْ نُطْفَةٍ أَمْشاجٍ نَبْتَلِيهِ [الإنسان/ 2] .</span><br><span>ويقال: جعلت فلاناً أَدَمَة أهلي، أي: خلطته بهم ، وقيل: سمّي بذلك لما طيّب به من الروح المنفوخ فيه المذكور في قوله تعالى:</span><br><span>وَنَفَخْتُ فِيهِ مِنْ رُوحِي [الحجر/ 29] ، وجعل له العقل والفهم والرّوية التي فضّل بها على غيره، كما قال تعالى: وَفَضَّلْناهُمْ عَلى كَثِيرٍ مِمَّنْ خَلَقْنا تَفْضِيلًا [الإسراء/ 70] ، وذلك من قولهم: الإدام، وهو ما يطيّب به الطعام ، وفي الحديث: «لو نظرت إليها فإنّه أحرى أن يؤدم بينكما» أي: يؤلّف ويطيب.</span>"}]}}