{"lemma":"خَفَقَ","slug":"خَفَقَ","root":"خ.ف.ق","root_slug":"خ-ف-ق","root_link":"/words/roots/خ-ف-ق","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَفَقْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَفَقْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَفَقْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَفَقْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَفَقْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَفَقَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَفَقَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَفَقا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَفَقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَفَقُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَفَقْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْفِق","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَخْفُق","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْفِقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْفِقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْفُقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْفُقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْفِقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْفُقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْفِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْفِقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْفُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْفُقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْفِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَخْفُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْفِق","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخْفُق","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْفِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخْفُق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْفِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْفُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْفِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْفِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْفُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْفِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْفِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْفُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْفُقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْفِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَخْفُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْفِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْفُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْفُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَفَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَفَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n11124","n11127"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to beat, to whip","examples":[{"text":"خَفَقَ ٱلْأَرْضَ بِنَعْلِهِ","english":"He struck the ground with his sandal."},{"text":"خَفَقَتِ ٱلْبَيْضَ","english":"She beat the eggs."}]},{"pos":"verb","gloss":"to flap the wings","examples":[{"text":"خَفَقَ ٱلطَّائِرُ","english":"The bird flapped its wings."}]},{"pos":"verb","gloss":"to palpitate","examples":[{"text":"يَخْفُقُ قَلْبِي","english":"My heart palpitates."}]}]},"etymology":null,"ipa":["/xa.fa.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11124","headword_ar":"خَفْقٌ","root":"xfq","body":[{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slapping,"},{"kind":"text","text":"(JK, S, K,) a thing, ["},{"kind":"italic_en","text":"so as to make a slight sound,"},{"kind":"text","text":"] with a"},{"kind":"arabic","text_bw":"dir~ap","text_ar":"دِرَّة"},{"kind":"text","text":"[q. v.], (JK, K,) or with something broad. (JK, S, K.) You say,"},{"kind":"arabic","text_bw":"xafaqahu","text_ar":"خَفَقَهُ"},{"kind":"text","text":", (Mgh, Msb,) aor."},{"kind":"text","text":"[and"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"xafoqN","text_ar":"خَفْقٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slapped, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to make a slight sound,"},{"kind":"text","text":"] with something broad, (Mgh, Msb,) such as a"},{"kind":"arabic","text_bw":"dir~ap","text_ar":"دِرَّة"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"xafaqahu","text_ar":"خَفَقَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":","},{"kind":"italic_en","text":"He struck him slightly,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"so as to make a slight sound,"},{"kind":"text","text":"] with a sword, (S, K,) and with a whip, and with a"},{"kind":"arabic","text_bw":"dir~ap","text_ar":"دِرَّة"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xafaqa AlA^aroDa binaEolihi","text_ar":"خَفَقَ الاَرْضَ بِنَعْلِهِ"},{"kind":"italic_en","text":"He struck the ground"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to make a sound"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his sandal."},{"kind":"text","text":"(S, TA.) ―         -b2-  And hence, i. e. from"},{"kind":"arabic","text_bw":"xafaqahu","text_ar":"خَفَقَهُ"},{"kind":"text","text":"as first explained above, (Mgh,) The"},{"kind":"italic_en","text":"sounding"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the patting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pattering,"},{"kind":"text","text":"] (JK, Mgh, K) of the sandal, (JK, K,) or of the sandals, (Mgh,) and the like: (TA:) and"},{"kind":"arabic","text_bw":"xafoqu","text_ar":"خَفْقُ"},{"kind":"arabic","text_bw":"AlA^aqodaAmi EalaY AlA^aroDi","text_ar":"الاَقْدَامِ عَلَى الاَرْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the sounding of the patting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pattering, of the feet upon the ground"},{"kind":"text","text":"]. (Az, in TA, art."},{"kind":"arabic","text_bw":"hms","text_ar":"همس"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"xafaqa Aln~aEolu","text_ar":"خَفَقَ النَّعْلُ"},{"kind":"italic_en","text":"The sandal made a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sounds."},{"kind":"text","text":"(Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"xafaqati Alr~aAyapu","text_ar":"خَفَقَتِ الرَّايَةُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xafoqN","text_ar":"خَفْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xafaqaAnN","text_ar":"خَفَقَانٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The banner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"standard, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of commotion; moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, to and fro; trembled; fluttered;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quivered;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"Axtfqt","text_ar":"اختفقت","orth_type":"arrow"},{"kind":"text","text":": (JK, K:) and in the same sense the former verb is used in speaking of the heart; (S, Msb;)"},{"kind":"arabic","text_bw":"xafaqaAnu Alqalobi","text_ar":"خَفَقَانُ القَلْبِ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"the fluttering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"palpitating, of the heart;"},{"kind":"text","text":"(JK, T, K;) and in like manner"},{"kind":"arabic","text_bw":"xafaqaAnu","text_ar":"خَفَقَانُ"},{"kind":"arabic","text_bw":"AljinaAHi","text_ar":"الجِنَاحِ"},{"kind":"italic_en","text":"the fluttering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flapping, of the wing:"},{"kind":"text","text":"(JK:) so, too, the former verb is used in speaking of the mirage; (S, K;) and ↓ the latter verb likewise; (Lth, K;) and Ru-beh, by poetic license, makes the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"of [the inf. n.]"},{"kind":"arabic","text_bw":"Alxafoq","text_ar":"الخَفْق"},{"kind":"text","text":"to be with fet-h, in his saying,"},{"kind":"quote","text":"mu$otabihi AlA^aEolaAmi lam~aAEi Alxafaqo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Indistinct in respect of the signs of the way, glistening much in the quivering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fluttering"},{"kind":"text","text":"]: (S, K:) in like manner, also, the former verb is used in speaking of lightning, (S, * TA,) inf. n."},{"kind":"arabic","text_bw":"xafoqN","text_ar":"خَفْقٌ"},{"kind":"text","text":"; (S;) and of a sword, and of the wind, and the like: and ↓"},{"kind":"arabic","text_bw":"Axfq","text_ar":"اخفق","orth_type":"arrow"},{"kind":"text","text":", said of the heart, and of lightning, and of a sword, and ["},{"kind":"arabic","text_bw":"Axfqt","text_ar":"اخفقت"},{"kind":"text","text":"said] of a banner, or standard, and of the wind, signifies the same: (TA:) or"},{"kind":"arabic","text_bw":"xafaqati Alr~iyHu","text_ar":"خَفَقَتِ الرِّيحُ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"xafaqaAnN","text_ar":"خَفَقَانٌ"},{"kind":"text","text":", (S, TA,) signifies"},{"kind":"italic_en","text":"The wind made a rustling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"murmuring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused and continued, sound."},{"kind":"text","text":"(S, TA. *) And"},{"kind":"arabic","text_bw":"xafaqati Aln~aAqapu","text_ar":"خَفَقَتِ النَّاقَةُ"},{"kind":"italic_en","text":"The she-camel broke wind, with a sound."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"xafaqa","text_ar":"خَفَقَ"},{"kind":"text","text":"said of a bird, [because of the flapping, or sound, of its wings,]"},{"kind":"italic_en","text":"It flew."},{"kind":"text","text":"(S, K.) See also 4, first sentence. And said of an arrow, [because of its whizzing,]"},{"kind":"italic_en","text":"It went swiftly."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xafaqa fiY AlbilaAdi","text_ar":"خَفَقَ فِى البِلَادِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He went away into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in, the countries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lands,"},{"kind":"text","text":"&c. (TA.) ―         -b5-  Also, said of a man, [in the CK,"},{"kind":"arabic","text_bw":"fulaAnFA","text_ar":"فُلَانًا"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shook, his head,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"bent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"down"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his head,"},{"kind":"text","text":"(TA,) [or"},{"kind":"italic_en","text":"nodded,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"being drowsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozing;"},{"kind":"text","text":"(S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Axfq","text_ar":"اخفق","orth_type":"arrow"},{"kind":"text","text":": (Sgh, K:) or"},{"kind":"italic_en","text":"he drowsed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozed:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"he had a fit of drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozing, and then awoke:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he slept;"},{"kind":"text","text":"(JK, TA;) so says Ibn-Háni; (TA;) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (JK,) inf. n."},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xafaqa biraA^osihi","text_ar":"خَفَقَ بِرَاْسِهِ"},{"kind":"arabic","text_bw":"A^awo xafoqatayoni","text_ar":"اَوْ خَفْقَتَيْنِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xafoqapF","text_ar":"خَفْقَةً","orth_type":"arrow"},{"kind":"text","text":", (Mgh, Msb,) occurring in a trad., (Mgh,)"},{"kind":"italic_en","text":"He bent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"down"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his head, without the rest of his body,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"nodded,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"once, or twice, being taken by a fit of drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozing."},{"kind":"text","text":"(Msb.) It is said in another trad.,"},{"kind":"arabic","text_bw":"kaAnato ruw^uwsuhumo","text_ar":"كَانَتْ رُوُوسُهُمْ"},{"kind":"arabic","text_bw":"A^awo xafoqatayoni","text_ar":"اَوْ خَفْقَتَيْنِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taxofiqu xafoqapF","text_ar":"تَخْفِقُ خَفْقَةً","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Their heads used to nod by reason of drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozing, once or twice"},{"kind":"text","text":"]. (S.) And in another,"},{"kind":"arabic","text_bw":"kaAnuwA yanotaZiruwna","text_ar":"كَانُوا يَنْتَظِرُونَ"},{"kind":"arabic","text_bw":"AlEi$aA='a Hat~aY taxofiqu ruw^uwsuhumo","text_ar":"العِشَا=ءَ حَتَّى تَخْفِقُ رُوُوسُهُمْ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"They used to wait for nightfall until"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"they slept so that their chins dropped upon their breasts."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"xafaqati Aln~ujuwmu","text_ar":"خَفَقَتِ النُّجُومُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The stars set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disappeared."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"xafaqa Aln~axomu","text_ar":"خَفَقَ النَّخْمُ"},{"kind":"text","text":", (JK, Mgh, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"The star,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the asterism,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"the Pleiades,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disappeared;"},{"kind":"text","text":"(JK, Mgh, K;) as also ↓"},{"kind":"arabic","text_bw":"Axfq","text_ar":"اخفق","orth_type":"arrow"},{"kind":"text","text":": (JK:) or the former signifies"},{"kind":"italic_en","text":"the star,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"went down in the place of setting;"},{"kind":"text","text":"and in like manner the verb is used in speaking of the moon; (TA;) and of the sun: (IAar, TA:) and"},{"kind":"arabic","text_bw":"Aln~ujuwmu","text_ar":"النُّجُومُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Axfqt","text_ar":"اخفقت","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the stars retired to the place of setting:"},{"kind":"text","text":"(S, K:) or, as some say,"},{"kind":"italic_en","text":"shone with a flickering light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly:"},{"kind":"text","text":"[because of their twinkling, or apparent quivering: or] as though the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"in the verb had a privative effect. (TA.) One says,"},{"kind":"arabic","text_bw":"waradotu xufuwqa Aln~ajomi","text_ar":"وَرَدْتُ خُفُوقَ النَّجْمِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I came"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"at the time of the setting of the Pleiades;"},{"kind":"text","text":"making the inf. n. an adv. n. [of time]. (S, TA.) ―         -b7-  Hence, (Mgh, TA,) or, as some say, from the same word as signifying “ the act of striking [or"},{"kind":"page_break","n":775},{"kind":"text","text":"slapping], ” (TA,)"},{"kind":"arabic","text_bw":"Alxafoqu","text_ar":"الخَفْقُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The act of inserting;"},{"kind":"text","text":"(Mgh;) [i. e.]"},{"kind":"italic_en","text":"the causing the penis to become concealed in the vulva;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"the act of copulation:"},{"kind":"text","text":"(JK:) or [rather]"},{"kind":"italic_en","text":"the penis' becoming concealed in the vulva."},{"kind":"text","text":"(Az, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"xafaqa All~ayolu","text_ar":"خَفَقَ اللَّيْلُ"},{"kind":"italic_en","text":"The night for the most part passed away:"},{"kind":"text","text":"(JK, K:) [and in like manner the verb is said of the day:] see"},{"kind":"arabic","text_bw":"xaAfiqN","text_ar":"خَافِقٌ"},{"kind":"text","text":". ―         -b9-"},{"kind":"arabic","text_bw":"xafaqa AlmakaAnu","text_ar":"خَفَقَ المَكَانُ"},{"kind":"italic_en","text":"The place was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, void,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"arabic","text_bw":"xufuwqN","text_ar":"خُفُوقٌ"},{"kind":"text","text":"in a horse is The"},{"kind":"italic_en","text":"being slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lean, in the belly."},{"kind":"text","text":"(AO, K. [See"},{"kind":"arabic","text_bw":"xafiqN","text_ar":"خَفِقٌ"},{"kind":"text","text":".])"}],"source_refs":["JK","S","K","Mgh","Msb","TA","Sgh","IAar"]},{"entry_id":"n11127","headword_ar":"خُفَقٌ","root":"xfq","body":[{"kind":"text","text":"and [its fem.] with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xafiqN","text_ar":"خَفِقٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}