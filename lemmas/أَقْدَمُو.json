{"lemma":"أَقْدَمُو","slug":"أَقْدَمُو","root":"ق.د.م","root_slug":"ق-د-م","root_link":"/words/roots/ق-د-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَقْدَم","root":"قدم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n42568"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%82%D9%92%D8%AF%D9%8E%D9%85%D9%8F%D9%88"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42568","headword_ar":"اَقْدَمَ","root":"qdm","body":[{"kind":"italic_en","text":"He was bold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"audacious."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"A^aqodama","text_ar":"اَقْدَمَ"},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"italic_en","text":"He ventured upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"addressed himself to, the thing boldly, courageously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"daringly;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he attempted it."},{"kind":"text","text":"―         -b3-"},{"kind":"arabic","text_bw":"A^aqodama ElY qironihi","text_ar":"اَقْدَمَ على قِرْنِهِ"},{"kind":"italic_en","text":"He behaved boldly, courageously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"daringly, against his adversary;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he attached him."},{"kind":"text","text":"―         -b4-  See 1. ―         -b5-"},{"kind":"arabic","text_bw":"A^aqodimo","text_ar":"اَقْدِمْ"},{"kind":"text","text":", (improperly"},{"kind":"arabic","text_bw":"A_iqodimo","text_ar":"اـِقْدِمْ"},{"kind":"text","text":",) said to a horse,"},{"kind":"italic_en","text":"Advance boldly!"},{"kind":"text","text":"(S.) So rendered voce"},{"kind":"arabic","text_bw":"A^ahaAba","text_ar":"اَهَابَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"habo","text_ar":"هَبْ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}