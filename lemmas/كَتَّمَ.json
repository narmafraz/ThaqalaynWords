num":"p"},{"role":"present_2mp","form":"تُكَتِّمُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُكَتِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُكَتِّم","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُكَتِّم","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُكَتِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُكَتِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُكَتِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُكَتِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُكَتِّمُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُكَتِّمُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُكَتِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُكَتِّم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُكَتِّم","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"كَتَّمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَتَّمْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":41,"cross_references":{"qac":{"found":true,"lemma_key":"كَتَّمَ","root":"كتم","pos":"V","occurrence_count":21},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n42958"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D8%AA%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"A species of boxwood, Buxus dioica, used in Yemen with henna to dye hair reddish"},{"pos":"noun","gloss":"mock privet, Phillyrea spp., used in Al-Andalus with henna to dye hair reddish","examples":[{"text":"والكتم قال أبو الخير هو ثلاثة أنواع منها ما له ورق عريض مثل ورق الآس الذي ينبت في الشعرى وهو يعلو كثيرا ويأخذ من التدويح وورقه مشرفة مثل تشريف المنشار ومنه نوع آخر له ورق دون الأول في العرض وتعظم شجرته أيضا وله حب في قدر حب الفلفل والريحان ويعتصر منه دهن يستصبح به ونوع آخر له ورق طويل دقيق مثل ورق المسان وقيل إن مما جرب فصح إنه إن سقى من عصارة ورقه ثمانية دراهم لمن عضه الكلب فإنه يبرئ في ذلك اليوم ويخلص بإذن الله تعالى وأن فزع من الماء فإنه يبرئ والكتم هو شبيه للحناء ويجفف ورقه ويدق نعما ويخلط بالحناء وخضب به الشعر.","english":"About the mock privet says Abū al-Ḵayr that there are three kinds of it: The first has wide leaves similar to the leaves of the myrtle which grows in the maquis and it becomes very high and swollen and its leaves are humped like a saw, the second has leaves of lesser width but its tree is also poddy and its seeds are of the size of the seeds of peppers and myrtles and from them one can press oil for lighting, and another kind has long delicate leaves like sandpaper and it is said if someone is affected by scabies then he will regain health, that if he whom a dog has bitten drinks eight dirhem from the extract of its leaves he will becomes free from the ailment the same day and cleansed of it if God is gracious; so that he will fear water but he will be free of the pest. Mock privet is similar to henna and one dries its leaves and crushes them well and mixes with henna and dyes the hair with it."}]},{"pos":"verb","gloss":"to conceal, to suppress, to repress, to hide, to restrain, to damp"},{"pos":"verb","gloss":"to conceal, to suppress, to repress, to hide, to restrain, to damp"},{"pos":"noun","gloss":"verbal noun of كَتَمَ (katama) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew כְּתַם (katham, “to mark, to seal”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42958","headword_ar":"كَتَمَ","root":"ktm","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"katomN","text_ar":"كَتْمٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"kitomaAnN","text_ar":"كِتْمَانٌ"},{"kind":"text","text":"], doubly trans.,"},{"kind":"italic_en","text":"He concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suppressed,"},{"kind":"text","text":"a secret. (Mgh.) ―         -b2-"},{"kind":"arabic","text_bw":"katama Alr~abowa","text_ar":"كَتَمَ الرَّبْوَ"},{"kind":"text","text":": see a verse cited in the last paragraph of art."},{"kind":"arabic","text_bw":"Ewr","text_ar":"عور"},{"kind":"text","text":"."}],"source_refs":[]}]}}