{"lemma":"قَتّاتٌ","slug":"قَتّاتٌ","root":"ق.ت.ت","root_slug":"ق-ت-ت","root_link":"/words/roots/ق-ت-ت","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n35130"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%AA%D9%91%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35130","headword_ar":"قَتَّاتٌ","root":"qt","body":[{"kind":"text","text":"(S, M, A, O, K) and ↓"},{"kind":"arabic","text_bw":"qatuwtN","text_ar":"قَتُوتٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qit~iytaY","text_ar":"قِتِّيتَى","orth_type":"arrow"},{"kind":"text","text":", (M, K,) this last being used as an inf. n. and as an epithet, (TA,) A man"},{"kind":"italic_en","text":"wont to calumniate;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to make known, divulge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tell, discourse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conversation, in a malicious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischievous, manner, so as to occasion discord, dissension,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(S, * M, * A, * O, * K, * TA;) [or"},{"kind":"italic_en","text":"wont to falsify and embellish discourse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conversation:"},{"kind":"text","text":"(see 1:)] or"},{"kind":"italic_en","text":"who listens to the discourse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conversation, of others, without their knowing;"},{"kind":"text","text":"(M, K, TA;)"},{"kind":"italic_en","text":"whether he make it known in the manner explained above, or not:"},{"kind":"text","text":"(M, * K, * TA:) or"},{"kind":"arabic","text_bw":"qat~aAtN","text_ar":"قَتَّاتٌ"},{"kind":"text","text":", accord. to Khálid Ibn-Jembeh, signifies one"},{"kind":"italic_en","text":"who hears the discourses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conversations, of men, and informs their enemies:"},{"kind":"text","text":"or, as some say, one"},{"kind":"italic_en","text":"who is with a people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, and calumniates them:"},{"kind":"text","text":"(TA:) it is said in a trad. (S, O) of the Prophet (O) that the"},{"kind":"arabic","text_bw":"qat~aAt","text_ar":"قَتَّات"},{"kind":"text","text":"will not enter Paradise: (S, O:) the epithets"},{"kind":"arabic","text_bw":"qat~aAtapN","text_ar":"قَتَّاتَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fatuwtN","text_ar":"فَتُوتٌ","orth_type":"arrow"},{"kind":"text","text":"are applied to a woman: (M, TA:) and the pl. of"},{"kind":"arabic","text_bw":"qat~aAtN","text_ar":"قَتَّاتٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"qut~aAtN","text_ar":"قُتَّاتٌ"},{"kind":"text","text":", with damm. (TA.)"}],"source_refs":["S","M","A","O","K","TA"]}]},"classical_definitions":null}