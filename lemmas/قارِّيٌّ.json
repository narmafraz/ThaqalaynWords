ext":", q. v. (K.)       -A3-  See also"},{"kind":"arabic","text_bw":"qaro'N","text_ar":"قَرْءٌ"},{"kind":"text","text":", first quarter, in two places.       -A4-"},{"kind":"arabic","text_bw":"h`*aA waqotu","text_ar":"هٰذَا وَقْتُ"},{"kind":"arabic","text_bw":"qaAriy^i Alr~iyHi","text_ar":"قَارِيِ الرِّيحِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"This is the time of the blowing of the wind."},{"kind":"text","text":"(TA.)       -A5-  It is also said to signify The"},{"kind":"italic_en","text":"top,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upper part,"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"qaSor","text_ar":"قَصْر"},{"kind":"text","text":"[or pavilion, &c.]. (O.)"}],"source_refs":["K","TA","S","O","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%82%D8%A7%D8%B1%D9%8A/","headword_ar":"قاريش","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=121234#472dd4","body_html":"قاريش<br>عن اللغة العبرية بمعنى هلام لحمي يصنع منه اللحم وعصير الطماطم."}]}}