{"lemma":"غَلِمٌ","slug":"غَلِمٌ","root":"غ.ل.م","root_slug":"غ-ل-م","root_link":"/words/roots/غ-ل-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32303"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%84%D9%90%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be gripped with lust, to be sexually excited"},{"pos":"adj","gloss":"sexually excited, lustful, aroused"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32303","headword_ar":"غَلِمٌ","root":"glm","body":[{"kind":"text","text":", (Msb, K, TA,) and ↓"},{"kind":"arabic","text_bw":"gil~iymN","text_ar":"غِلِّيمٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) but this has an intensive signification, (S, TA,) and ↓"},{"kind":"arabic","text_bw":"migoliymN","text_ar":"مِغْلِيمٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) [but this also has an intensive signification,]"},{"kind":"italic_en","text":"Excited by lust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appetence:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"overcome thereby:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"vehemently affected with lust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carnal desire"},{"kind":"text","text":"(Msb:) [or the first may generally be better rendered"},{"kind":"italic_en","text":"in a state of excitement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of vehement excitement, by lust"},{"kind":"text","text":"and the second and third,"},{"kind":"italic_en","text":"lustful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently lustful:"},{"kind":"text","text":"] the epithets applied to a female are"},{"kind":"arabic","text_bw":"galimapN","text_ar":"غَلِمَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mugotalimapN","text_ar":"مُغْتَلِمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gil~iymapN","text_ar":"غِلِّيمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gil~iymN","text_ar":"غِلِّيمٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) this last being applied to a male and to a female, (Az, TA,) and [particularly] applied to a he-camel, (TA,) and ↓"},{"kind":"arabic","text_bw":"mgolymapN","text_ar":"مغْليمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"migoliymN","text_ar":"مِغْلِيمٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) the last [which is omitted in the CK] being, like"},{"kind":"arabic","text_bw":"gil~iymN","text_ar":"غِلِّيمٌ"},{"kind":"text","text":", applied to a male and to a female: (Az, TA:) and ↓"},{"kind":"arabic","text_bw":"gayolamN","text_ar":"غَيْلَمٌ","orth_type":"arrow"},{"kind":"text","text":"likewise is applied to a girl, or young woman. in the sense of"},{"kind":"arabic","text_bw":"mugotalimapN","text_ar":"مُغْتَلِمَةٌ"},{"kind":"text","text":". (S, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"xayoruAln~isaA='i","text_ar":"خَيْرُالنِّسَا=ءِ"},{"kind":"arabic","text_bw":"Algalimapu EalaY zawojihaA","text_ar":"الغَلِمَةُ عَلَى زَوْجِهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The best of women is the appetent to her husband"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb","K","TA","S","Az"]}]},"classical_definitions":null}