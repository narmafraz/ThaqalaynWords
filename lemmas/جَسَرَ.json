"num":"p"},{"role":"present_2mp","form":"تَجْسُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْسُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْسُر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْسُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْسُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْسُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْسُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْسُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْسُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْسُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْسُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَسَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَسَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْسُر","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْسُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n5794"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B3%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"bridge"},{"pos":"verb","gloss":"to arch, to vault (a bridge)","tags":["transitive"]},{"pos":"verb","gloss":"to span, to traverse, to cross (as if by a bridge)","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of جَسَرَ (jasara) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"verb","gloss":"to dare, to risk, to venture","tags":["transitive"],"examples":[{"text":"لَا يَجْسُرُ أَنْ يَفْعَلَ كَذَا.","english":"He dares not do such a thing."}]},{"pos":"verb","gloss":"to act boldly or courageously","tags":["transitive"]},{"pos":"noun","gloss":"Jessore (a city in Bangladesh)","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"From Aramaic גִּישְׁרָא / גִּשְׁרָא (gišrā) / ܓܫܪܐ (gešrā), with Hebrew גֶּשֶׁר (géšer) from Akkadian 𒄀𒅖𒊒 (gišru, “bridge”). Note the meaning “timber, beam” in Syriac – originally the Arabic word meant a wooden bridge in distinction from a stone bridge قَنْطَرَة (qanṭara). The word has a derivation in Akkadian from 𒄑𒃡 (GIŠ.ÙR), 𒄑𒃡𒋗 (GIŠ.ŠU.ÙR /⁠gušūru, gašūru⁠/, “tree-trunk; felled log, timber; beams”), itself considered a Sumerian loanword.\n\nDenominal verb of جِسْر (jisr, “bridge”).\n\nBorrowed from Classical Persian جَسَر (jasar), from Bengali যশোর (jośōr)."},"ipa":["/d͡ʒisr/","/d͡ʒa.sa.ra/","/d͡ʒasr/","/d͡ʒa.sar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5794","headword_ar":"جَسَرَ","root":"jsr","body":[{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"jasaArapN","text_ar":"جَسَارَةٌ"},{"kind":"text","text":"(A, K, KL) and"},{"kind":"arabic","text_bw":"jusuwrN","text_ar":"جُسُورٌ"},{"kind":"text","text":", said of a man, (K,)"},{"kind":"italic_en","text":"He was daring, courageous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bold:"},{"kind":"text","text":"(A, KL:)"},{"kind":"italic_en","text":"he acted with penetrating energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpness, vigorousness, and effectiveness;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"jasara EalaY ka*aA","text_ar":"جَسَرَ عَلَى كَذَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jasaArapN","text_ar":"جَسَارَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He ventured upon such a thing daringly, courageously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boldly;"},{"kind":"text","text":"(S, A;) as also ↓"},{"kind":"arabic","text_bw":"tjAsr","text_ar":"تجاسر","orth_type":"arrow"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjAsr","text_ar":"تجاسر","orth_type":"arrow"},{"kind":"italic_en","text":"he emboldened himself against it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"(A, K.) And"},{"kind":"arabic","text_bw":"jasara EalaY Eaduw~ihi","text_ar":"جَسَرَ عَلَى عَدُوِّهِ"},{"kind":"text","text":", (A, Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jusuwrN","text_ar":"جُسُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jasaArapN","text_ar":"جَسَارَةٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He acted daringly, conrageously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boldly, against his enemy."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"laA yajosuru A^ano yafoEala ka*aA","text_ar":"لَا يَجْسُرُ اَنْ يَفْعَلَ كَذَا"},{"kind":"italic_en","text":"He dares not to do such a thing."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"jasara","text_ar":"جَسَرَ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jasorN","text_ar":"جَسْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"arched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vaulted, a"},{"kind":"arabic","text_bw":"jisor","text_ar":"جِسْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bridge"},{"kind":"text","text":"]. (K.) ―         -b2-  It is said of [the giant] 'Ooj ("},{"kind":"arabic","text_bw":"Euwj","text_ar":"عُوج"},{"kind":"text","text":"), in a trad.,"},{"kind":"arabic","text_bw":"waqaEa EalaY niyli miSora","text_ar":"وَقَعَ عَلَى نِيلِ مِصْرَ"},{"kind":"arabic","text_bw":"fajasarahumo sanapF","text_ar":"فَجَسَرَهُمْ سَنَةً"},{"kind":"text","text":", i. e., (tropical:)  ["},{"kind":"italic_en","text":"He fell down upon the Nile of Egypt, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became a bridge to them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the space of a year"},{"kind":"text","text":"]. (A.) ―         -b3-  And one says,"},{"kind":"arabic","text_bw":"jasarati","text_ar":"جَسَرَتِ"},{"kind":"arabic","text_bw":"Alr~ikaAbu AlmafaAzapa","text_ar":"الرِّكَابُ المَفَازَةَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AijotasaratohaA","text_ar":"اِجْتَسَرَتْهَا","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The travellingcamels crossed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed over, the desert,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"as by a bridge:"},{"kind":"text","text":"(A:) and"},{"kind":"arabic","text_bw":"Als~afiynapu AlbaHora","text_ar":"السَّفِينَةُ البَحْرَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajtsrti","text_ar":"اجتسرتِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The ship crossed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed over, the sea:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"rode upon, and passed through, the sea."},{"kind":"text","text":"(K.)"}],"source_refs":["K","TA","A","KL","S","Msb"]}]}}