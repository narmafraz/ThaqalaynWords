","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبَلِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبَلِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبَلَّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبَلَّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبَلِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبَلِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبَلَّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبَلَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبَلِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُبَلَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُبَلِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبَلِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَلَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَلَّلْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبَلَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبَلَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":43,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n3112","n3113"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%84%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of بَلَّ (balla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wetness","examples":[{"text":"10th century, Al-Mutanabbi\nوَٱلْهَجْرُ أَقْتَلُ لِي مِمَّا أُرَاقِبُهُ / أَنَا الْغَرِيقُ فَمَا خَوْفِي مِنَ الْبَلَلِ\nwal-hajru ʔaqtalu lī mimmā ʔurāqibuhu / ʔanā l-ḡarīqu famā ḵawfī mina al-balali","english":"(please add an English translation of this quotation)"}]},{"pos":"verb","gloss":"to wet, to moisten, to sprinkle"}]},"etymology":null,"ipa":["/ba.lal/","/bal.la.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3112","headword_ar":"بَلَلٌ","root":"bl","body":[{"kind":"italic_en","text":"Moisture;"},{"kind":"text","text":"(S, M, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"bil~apN","text_ar":"بِلَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K) and ↓"},{"kind":"arabic","text_bw":"bilaAlN","text_ar":"بِلَالٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bulaAlapN","text_ar":"بُلَالَةٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) [and several other dial. vars. occurring in phrases in this paragraph]: or ↓"},{"kind":"arabic","text_bw":"bil~apN","text_ar":"بِلَّةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"an inferior,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable, degree of moisture;"},{"kind":"text","text":"(Lth, T, K; [an ambiguity in the K in this place has occasioned several mistakes in Freytag's Lex. voce"},{"kind":"arabic","text_bw":"balalN","text_ar":"بَلَلٌ"},{"kind":"text","text":";]) and ↓"},{"kind":"arabic","text_bw":"bilaAlN","text_ar":"بِلَالٌ","orth_type":"arrow"},{"kind":"text","text":"is an anomalous pl. of this word; (M, TA;) and is pl. also of ↓"},{"kind":"arabic","text_bw":"bul~apN","text_ar":"بُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, TA:) and"},{"kind":"arabic","text_bw":"bul~aAnN","text_ar":"بُلَّانٌ"},{"kind":"text","text":", occurring in a verse cited above (see 1) may be pl. of"},{"kind":"arabic","text_bw":"balalN","text_ar":"بَلَلٌ"},{"kind":"text","text":". (M.) [Using syns. of"},{"kind":"arabic","text_bw":"balalN","text_ar":"بَلَلٌ"},{"kind":"text","text":"in the sense explained above,] you say,"},{"kind":"arabic","text_bw":"Tawayotu","text_ar":"طَوَيْتُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Als~iqaA='a EalaY bululatihi","text_ar":"السِّقَا=ءَ عَلَى بُلُلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"bulalatihi","text_ar":"بُلَلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"balalatihi","text_ar":"بَلَلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (T, M,)"},{"kind":"italic_en","text":"I folded the skin while it was moist,"},{"kind":"text","text":"(T, S, M, K,) before it should break in pieces, (T,) or lest it should break in pieces. (M.) And [hence,] ↓"},{"kind":"arabic","text_bw":"Tawayotu fulaAnFA EalaY bululatihi","text_ar":"طَوَيْتُ فُلَانًا عَلَى بُلُلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (T, *S, M, *K, *) and ↓"},{"kind":"arabic","text_bw":"bulalatihi","text_ar":"بُلَلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (T, S, K,) and ↓"},{"kind":"arabic","text_bw":"balalatihi","text_ar":"بَلَلَتِهِ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bulaAlatihi","text_ar":"بُلَالَتِهِ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"balaAlatihi","text_ar":"بَلَالَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"bul~atihi","text_ar":"بُلَّتِهِ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"bal~atihi","text_ar":"بَلَّتِهِ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"bulaAtihi","text_ar":"بُلَاتِهِ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"balaAtihi","text_ar":"بَلَاتِهِ","orth_type":"arrow"},{"kind":"text","text":", (K) and ↓"},{"kind":"arabic","text_bw":"buluwlatihi","text_ar":"بُلُولَتِهِ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) which is of the dial. of Temeem, (TA,) and ↓"},{"kind":"arabic","text_bw":"buluwlihi","text_ar":"بُلُولِهِ","orth_type":"arrow"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"I bore with, suffered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tolerated, such a one,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"notwithstanding his vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"(T, S, M, K,)"},{"kind":"italic_en","text":"and evil conduct:"},{"kind":"text","text":"(S:) or [so in the M and K, but in the S “ and, ”]"},{"kind":"italic_en","text":"I treated him with gentleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blandishment,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"while some love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection, remained in him;"},{"kind":"text","text":"(S, M, K;) and this is the true meaning; (M;) and in like manner,"},{"kind":"arabic","text_bw":"nafosihi","text_ar":"نَفْسِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EalaY bilaAlN","text_ar":"عَلَى بِلَالٌ","orth_type":"arrow"},{"kind":"text","text":". (S, TA.) And ↓"},{"kind":"arabic","text_bw":"TawaAhu EalaY bilaAlihi","text_ar":"طَوَاهُ عَلَى بِلَالِهِ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"buluwlihi","text_ar":"بُلُولِهِ","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He feigned himself heedless of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inattentive to, his vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault;"},{"kind":"text","text":"like as one folds a skin upon its fault [to conceal that fault]. (T.) And"},{"kind":"arabic","text_bw":"AinoSarafa Alqawoma","text_ar":"اِنْصَرَفَ القَوْمَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"bibalalatihimo","text_ar":"بِبَلَلَتِهِمْ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bibululatihimo","text_ar":"بِبُلُلَتِهِمْ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bibuluwlatihimo","text_ar":"بِبُلُولَتِهِمْ","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, having some good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"somewhat good, remaining, in them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"among them;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"wafiyhimo baqiy~apN","text_ar":"وَفِيهِمْ بَقِيَّةٌ"},{"kind":"text","text":"[in which the last word generally implies something good; as, for instance, in the Kur xi. 118]: (M, K:) or,"},{"kind":"italic_en","text":"in a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition:"},{"kind":"text","text":"(K:) or this latter is meant when one says,"},{"kind":"arabic","text_bw":"bibululatihimo","text_ar":"بِبُلُلَتِهِمْ"},{"kind":"text","text":". (T.) ―         -b2-"},{"kind":"italic_en","text":"Abundance of herbage;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the goods, conveniences,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comforts, of life."},{"kind":"text","text":"(TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"bal~N","text_ar":"بَلٌّ"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"maA A^aHosana balalahu","text_ar":"مَا اَحْسَنَ بَلَلَهُ"},{"kind":"italic_en","text":"How good is his adornment of himself!"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his manner of undertaking a task,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"taking upon himself a responsibility!"},{"kind":"text","text":"(K: expl. in some copies by"},{"kind":"arabic","text_bw":"tajam~ulahu","text_ar":"تَجَمُّلَهُ"},{"kind":"text","text":"; and so in the TA: in others by"},{"kind":"arabic","text_bw":"taHam~ulahu","text_ar":"تَحَمُّلَهُ"},{"kind":"text","text":".)"}],"source_refs":["S","M","K","TA","T"]},{"entry_id":"n3113","headword_ar":"بُلَلٌ","root":"bl","body":[{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"SuradN","text_ar":"صُرَدٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"bululN","text_ar":"بُلُلٌ"},{"kind":"text","text":", (so in a copy of the T, accord. to the TT,)"},{"kind":"italic_en","text":"Seed; grain for sowing."},{"kind":"text","text":"(ISh, T, K.)"}],"source_refs":["K"]}]}}