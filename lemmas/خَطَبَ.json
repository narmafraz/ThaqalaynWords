:"m","num":"p"},{"role":"present_2mp","form":"تَخْطُبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْطُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْطُب","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْطُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْطُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْطُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْطُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْطُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْطُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْطُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْطُبْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَطَبْنا","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَطَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْطُب","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْطُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":58,"cross_references":{"qac":{"found":true,"lemma_key":"خَطَبَ","root":"خطب","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n10971"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B7%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to give a speech, lecture, or oration"},{"pos":"verb","gloss":"to give a sermon (specifically relating to Muslim Friday sermon Khutbah)"},{"pos":"verb","gloss":"to propose (ask to marry)"},{"pos":"verb","gloss":"to become a preacher"},{"pos":"noun","gloss":"fiancé, fiancée"},{"pos":"noun","gloss":"plural of خُطْبَة (ḵuṭba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10971","headword_ar":"خَطَبَ","root":"xTb","body":[{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"xaTaba xuTobapF","text_ar":"خَطَبَ خُطْبَةً"},{"kind":"text","text":", (A,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xuTobapN","text_ar":"خُطْبَةٌ"},{"kind":"text","text":", (S, K,) or this, accord. to some, is a subst. used as an inf. n., (TA,) and"},{"kind":"arabic","text_bw":"xaTaAbapN","text_ar":"خَطَابَةٌ"},{"kind":"text","text":", (K,) said of a"},{"kind":"arabic","text_bw":"xaTiyb","text_ar":"خَطِيب"},{"kind":"text","text":"(A) or"},{"kind":"arabic","text_bw":"xaATib","text_ar":"خَاطِب"},{"kind":"text","text":", (K,) ["},{"kind":"italic_en","text":"He recited a"},{"kind":"arabic","text_bw":"xuTobap","text_ar":"خُطْبَة"},{"kind":"text","text":"(q. v. infrà),]"},{"kind":"arabic","text_bw":"EalaY Alminobari","text_ar":"عَلَى المِنْبَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon the pulpit"},{"kind":"text","text":"]; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"AxtTb","text_ar":"اختطب"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"xaTaba Alqawoma","text_ar":"خَطَبَ القَوْمَ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"EalaY Alqawomi","text_ar":"عَلَى القَوْمِ"},{"kind":"text","text":", (Th, Msb,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xuTobapN","text_ar":"خُطْبَةٌ"},{"kind":"text","text":", (Th, Msb,) ["},{"kind":"italic_en","text":"He recited a"},{"kind":"arabic","text_bw":"xuTobap","text_ar":"خُطْبَة"},{"kind":"italic_en","text":"to the people,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"over the people,"},{"kind":"text","text":"i. e. on the pulpit, beneath which they sat: or]"},{"kind":"italic_en","text":"he delivered an exhortation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admonition, to the people."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"xaTaba AlmaroA^apa","text_ar":"خَطَبَ المَرْاَةَ"},{"kind":"text","text":", (S, A, * Msb, K,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"xiTobapN","text_ar":"خِطْبَةٌ"},{"kind":"text","text":", (S, A, K) or this is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"xaTobN","text_ar":"خَطْبٌ"},{"kind":"text","text":"(Lh, K) and"},{"kind":"arabic","text_bw":"xiT~iybaY","text_ar":"خِطِّيبَى"},{"kind":"text","text":"; (T, S, * K;) and ↓"},{"kind":"arabic","text_bw":"AxtTbhA","text_ar":"اختطبها"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, the woman in marriage."},{"kind":"text","text":"(Msb.) In the following verse of 'Adee Ibn-Zeyd, respecting Jedheemeh El-Abrash, and his asking in marriage Ez-Zebbà,"},{"kind":"quote","text":"lixiT~iybaY Al~atiY gadarato waxaAnato\n                      \n                     \n                        wahun~a *awaAtu gaAy^ilapK luHiynaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"For the asking in marriage of her who acted perfidiously and treacherously: for they"},{"kind":"text","text":"(i. e. women)"},{"kind":"italic_en","text":"are possessed of secret malevolence: may they be disgraced and accursed:"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xT~ybY","text_ar":"خطّيبى"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"xiTobap","text_ar":"خِطْبَة"},{"kind":"text","text":": (S:) accord. to Lth, it is a simple subst.; but AM says that he is in error, and that it is an inf. n. (TA.) You say also,"},{"kind":"arabic","text_bw":"xaTaba AlmaroA^apa","text_ar":"خَطَبَ المَرْاَةَ"},{"kind":"arabic","text_bw":"A_ilaY Alqawomi","text_ar":"اـِلَى القَوْمِ"},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, the woman in marriage, of the people."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xaTaba","text_ar":"خَطَبَ"},{"kind":"arabic","text_bw":"A_ilaY fulaAnK","text_ar":"اـِلَى فُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, a woman in marriage, of such a one"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"xaTaba EalaY","text_ar":"خَطَبَ عَلَى"},{"kind":"arabic","text_bw":"xiTobapi A^axiyhi","text_ar":"خِطْبَةِ اَخِيهِ"},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, a woman in marriage, when another had done so, and she had inclined to the latter, and he and she had agreed to a certain dowry, and had approved each other, and nothing remained but to conclude the contract;"},{"kind":"text","text":"the doing of which is forbidden: but it is not forbidden to ask in marriage a woman when another has done so if she and the latter have not agreed, nor approved each other, nor has either of them inclined to the other. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"yaxoTubu Eamala ka*aA","text_ar":"يَخْطُبُ عَمَلَ كَذَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one seeks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desires, to do such a thing."},{"kind":"text","text":"(A, TA.)       -A2-"},{"kind":"arabic","text_bw":"xaTuba","text_ar":"خَطُبَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"xaTaAbapN","text_ar":"خَطَابَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He became a"},{"kind":"arabic","text_bw":"xaTiyb","text_ar":"خَطِيب"},{"kind":"text","text":"(S.)       -A3-"},{"kind":"arabic","text_bw":"xaTiba","text_ar":"خَطِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, K,) inf. n."},{"kind":"arabic","text_bw":"xaTabN","text_ar":"خَطَبٌ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, of the colour termed"},{"kind":"arabic","text_bw":"xuTobapN","text_ar":"خُطْبَةٌ"},{"kind":"text","text":": (S, * K:) or his, or its, colour"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, what is thus termed."},{"kind":"text","text":"(JK.)"}],"source_refs":["S","K","A","TA","Msb","Th","Lh","JK"]}]}}