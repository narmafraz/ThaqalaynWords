pus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغْبِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغْبِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغْبَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغْبَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغْبِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغْبِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغْبَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغْبَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغْبِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُغْبَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُغْبِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغْبِر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُغْبَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغْبَر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَغْبَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَغْبَرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":11,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31336","n31338","n31358"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%BA%D9%92%D8%A8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become dust-colored"}]},"etymology":null,"ipa":["/iɣ.bar.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31336","headword_ar":"اغبر","root":"gbr","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"raised the dust;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"gb~r","text_ar":"غبّر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"tagobiyrN","text_ar":"تَغْبِيرٌ"},{"kind":"text","text":". (S.) [Hence,]"},{"kind":"arabic","text_bw":"fiY wajohihi","text_ar":"فِى وَجْهِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"gab~ara","text_ar":"غَبَّرَ","orth_type":"arrow"},{"kind":"text","text":"[so, evidently, but written in the TA without any syll. signs, lit."},{"kind":"italic_en","text":"He raised the dust in his face;"},{"kind":"text","text":"meaning,] (assumed tropical:)"},{"kind":"italic_en","text":"he outwent him; outstripped him; went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, before him."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Agbr fiY Talabi AlHaAjapi","text_ar":"اغبر فِى طَلَبِ الحَاجَةِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He strove, laboured, exerted himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employed himself vigorously"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diligently, in seeking after the thing that he wanted;"},{"kind":"text","text":"(ISk, S, K;)"},{"kind":"italic_en","text":"he hasted, made haste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick, in doing so;"},{"kind":"text","text":"as though, by reason of his eagerness and quickness, he raised the dust. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^agobarotu fiY Al$~ay^oi","text_ar":"اَغْبَرْتُ فِى الشَّيِْ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I set about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, doing the thing."},{"kind":"text","text":"(IKtt.) ―         -b4-"},{"kind":"arabic","text_bw":"A^agobarato","text_ar":"اَغْبَرَتْ"},{"kind":"arabic","text_bw":"EalayonaA Als~amaA='u","text_ar":"عَلَيْنَا السَّمَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sky rained upon us vehemently."},{"kind":"text","text":"(S, * K, * TA.)       -A2-  See also 9."}],"source_refs":["S","K"]},{"entry_id":"n31338","headword_ar":"اغبرّ","root":"gbr","body":[{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"AigobiraArN","text_ar":"اِغْبِرَارٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dust-coloured; of a colour like dust;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"gabara","text_ar":"غَبَرَ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"guyuwrN","text_ar":"غُيُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"guborapN","text_ar":"غُبْرَةٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"A^agobara","text_ar":"اَغْبَرَ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_igobaArN","text_ar":"اـِغْبَارٌ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a day)"},{"kind":"italic_en","text":"became very dusty."},{"kind":"text","text":"(Aboo-'Alee, K.)"}],"source_refs":["S","K"]},{"entry_id":"n31358","headword_ar":"اَغْبَرُ","root":"gbr","body":[{"kind":"italic_en","text":"Dust-coloured; of a colour like dust:"},{"kind":"text","text":"(S:) [fem."},{"kind":"arabic","text_bw":"gaboraA='u","text_ar":"غَبْرَا=ءُ"},{"kind":"text","text":": and pl."},{"kind":"arabic","text_bw":"guborN","text_ar":"غُبْرٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"AlA^agobaru","text_ar":"الاَغْبَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wolf;"},{"kind":"text","text":"(K, TA;) because of his [dusty] colour: like"},{"kind":"arabic","text_bw":"AlA^agovaru","text_ar":"الاَغْثَرُ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlgaboraA='u","text_ar":"الغَبْرَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The female of the"},{"kind":"arabic","text_bw":"Hajal","text_ar":"حَجَل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"partridge"},{"kind":"text","text":"]. (K.) ―         -b4-  Also ("},{"kind":"arabic","text_bw":"AlgaboraA='u","text_ar":"الغَبْرَا=ءُ"},{"kind":"text","text":") (tropical:)"},{"kind":"italic_en","text":"The earth;"},{"kind":"text","text":"(S, IAth, Msb, K;) because of its dusty colour; or because of the dust that is upon it: (TA:) opposed to"},{"kind":"arabic","text_bw":"AlxaDoraA='u","text_ar":"الخَضْرَا=ءُ"},{"kind":"text","text":", which means “ the sky, ” or “ heaven. ” (IAth.) ―         -b5-  And you say,"},{"kind":"arabic","text_bw":"jaA='a EalaY gaboraA='i AlZ~ahori","text_ar":"جَا=ءَ عَلَى غَبْرَا=ءِ الظَّهْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He came on foot:"},{"kind":"text","text":"(Z, TA:) [i. e.]"},{"kind":"italic_en","text":"he came upon the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"AlZ~ahori","text_ar":"الظَّهْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jaA='u EalaY gubayoraA='i","text_ar":"جَا=ءُ عَلَى غُبَيْرَا=ءِ","orth_type":"arrow"},{"kind":"text","text":": (M, TA:) or the latter means,"},{"kind":"italic_en","text":"he returned without his having obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, anything:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"he returned without his having been able to accomplish the object of his want."},{"kind":"text","text":"(El-Ahmar, TA.) And"},{"kind":"arabic","text_bw":"tarakahu","text_ar":"تَرَكَهُ"},{"kind":"arabic","text_bw":"AlZ~ahori","text_ar":"الظَّهْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EalaY gubayoraA='i","text_ar":"عَلَى غُبَيْرَا=ءِ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He left him in the possession of nothing:"},{"kind":"text","text":"(M, TA:) accord. to Zeyd Ibn-Kethweh, it is said by one who has contended in an altercation with another and overcome him so as to become master of all that was in his hands: in all the copies of the K, [probably in consequence of an omission by an early transcriber,] it is expl. as meaning"},{"kind":"italic_en","text":"he returned disappointed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsuccessful;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"trkh ElY gaboraA='i AlZhr","text_ar":"تركه على غَبْرَا=ءِ الظهر"},{"kind":"text","text":". (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"banuw AlgaboraA='i","text_ar":"بَنُو الغَبْرَا=ءِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The poor, needy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indigent;"},{"kind":"text","text":"(S, IB, K, TA;) [to which is strangely added in one of my copies of the S and the"},{"kind":"italic_en","text":"guests;"},{"kind":"text","text":"] so called because of their cleaving to the dust: (IB, TA:) and"},{"kind":"arabic","text_bw":"gaboraA='u Aln~aAsi","text_ar":"غَبْرَا=ءُ النَّاسِ"},{"kind":"text","text":"likewise means"},{"kind":"italic_en","text":"the poor of mankind:"},{"kind":"text","text":"or, as some say, the former means"},{"kind":"italic_en","text":"strangers from their homes:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"strangers,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"persons,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"who assemble together for"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the drinking of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"beverage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wine, without mutual acquaintance:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"persons who contribute equally to the expenses which they have to incur in journeys:"},{"kind":"text","text":"all of these meanings have been assigned to it in explaining a verse of Tarafeh: [see EM p. 85:] and it is also expl. in the A as meaning"},{"kind":"italic_en","text":"persons of whom one knows not to what family,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tribe, they belong:"},{"kind":"text","text":"(TA:) and [it is said that]"},{"kind":"arabic","text_bw":"Aibonu gaboraA='a","text_ar":"اِبْنُ غَبْرَا=ءَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the thief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"robber."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"bnY","text_ar":"بنى"},{"kind":"text","text":".) ―         -b7-"},{"kind":"arabic","text_bw":"gaboraA='u","text_ar":"غَبْرَا=ءُ"},{"kind":"text","text":"also signifies (assumed tropical:)  Land"},{"kind":"italic_en","text":"abounding with coverts of the kind termed"},{"kind":"arabic","text_bw":"xamar","text_ar":"خَمَر"},{"kind":"text","text":"[q. v.]: (TA:) and"},{"kind":"italic_en","text":"land abounding with trees;"},{"kind":"text","text":"(K;) or so"},{"kind":"arabic","text_bw":"A^aroDN gaboraA='u","text_ar":"اَرْضٌ غَبْرَا=ءُ"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"gabarapN","text_ar":"غَبَرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b8-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Herbage in plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, land."},{"kind":"text","text":"(Sgh, K.) [This is said in the TA to be more probably with"},{"kind":"arabic","text_bw":"v","text_ar":"ث"},{"kind":"text","text":"; but I do not find any meaning like this assigned to"},{"kind":"arabic","text_bw":"gavoraA='u","text_ar":"غَثْرَا=ءُ"},{"kind":"text","text":".] ―         -b9-  And (assumed tropical:)"},{"kind":"italic_en","text":"A species of plant."},{"kind":"text","text":"(S. [App. that called"},{"kind":"arabic","text_bw":"gubayoraA='u","text_ar":"غُبَيْرَا=ءُ"},{"kind":"text","text":", q. v.]) ―         -b10-"},{"kind":"arabic","text_bw":"waToA^apN gaboraA='u","text_ar":"وَطْاَةٌ غَبْرَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A footstep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint, that is becoming obliterated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effaced:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"such as is recent."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"dahomaA='u","text_ar":"دَهْمَا=ءُ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A^adohamu","text_ar":"اَدْهَمُ"},{"kind":"text","text":".]) ―         -b11-  And"},{"kind":"arabic","text_bw":"Eiz~N A^agabaru","text_ar":"عِزٌّ اَغَبَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Might departing;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"becoming effaced."},{"kind":"text","text":"(TA.) ―         -b12-"},{"kind":"arabic","text_bw":"sanapN gaboraA='u","text_ar":"سَنَةٌ غَبْرَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A year of drought;"},{"kind":"text","text":"(IAth, K;)"},{"kind":"italic_en","text":"a year in which is no rain:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"$hb","text_ar":"شهب"},{"kind":"text","text":":) pl."},{"kind":"arabic","text_bw":"guborN","text_ar":"غُبْرٌ"},{"kind":"text","text":": so called because of the dustiness of the tracts of the horizon therein from paucity [or want] of rain, and of the ground from there being no herbage. (IAth.) ―         -b13-  And"},{"kind":"arabic","text_bw":"juwEN A^agobaru","text_ar":"جُوعٌ اَغْبَرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Severe hanger"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"famine."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","TA","Z","M","T","IB","K","A"]}]}}