{"lemma":"صَدَقَ","slug":"صَدَقَ","root":"ص.د.ق","root_slug":"ص-د-ق","root_link":"/words/roots/ص-د-ق","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"صَدَقْتَ","in_corpus":true,"count":39,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"صَدَقْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"صَدَقْتُما","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"صَدَقْتُم","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"صَدَقْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"صَدَقَ","in_corpus":true,"count":45,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"صَدَقَت","in_corpus":true,"count":66,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"صَدَقا","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"صَدَقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"صَدَقُوا","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"صَدَقْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَصْدُق","in_corpus":true,"count":65,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَصْدُقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَصْدُقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَصْدُقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَصْدُقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَصْدُقُوا","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصْدُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْدُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْدُق","in_corpus":true,"count":22,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْدُق","in_corpus":true,"count":65,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْدُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْدُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْدُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْدُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْدُقُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْدُقُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْدُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصْدُق","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْدُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَدَقْنا","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَدَقْتُ","in_corpus":true,"count":66,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":416,"cross_references":{"qac":{"found":true,"lemma_key":"صَدَقَ","root":"صدق","pos":"V","occurrence_count":15},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":15},"lanes":{"found":true,"entry_ids":["n23996"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AF%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be truthful, to speak the truth","tags":["intransitive"],"examples":[{"text":"قَالَ سَنَنْظُرُ أَصَدَقْتَ أَمْ كُنْتَ مِنَ الْكَاذِبِينَ","english":"[Solomon] said, \"We will see whether you were truthful or were of the liars."}]},{"pos":"verb","gloss":"to tell (someone) the truth","tags":["ditransitive","transitive"],"examples":[{"text":"صَدِيقُكَ مَنْ صَدَقَكَ لَا مَنْ صَدَّقَكَ","english":"Your friend is he who is trustworthy, not he who trusts you."},{"text":"صَدَقَنِي القَوْلَ.","english":"He told me the truth in his speech."}]},{"pos":"verb","gloss":"to be sincere","tags":["ditransitive"],"examples":[{"text":"صَدَقَنِي النَّصِيحَة"}]},{"pos":"verb","gloss":"to prove true"},{"pos":"verb","gloss":"to become aware of"},{"pos":"verb","gloss":"to believe, to accept that (someone) is telling the truth"},{"pos":"verb","gloss":"to believe, to accept as true","examples":[{"text":"هل تقدر أن تصدِّق الكتاب المقدس؟","english":"Can you believe the Bible?"}]},{"pos":"verb","gloss":"to believe in","examples":[{"text":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ"},{"text":"إِنَّ سَعْيَكُمْ لَشَتَّى\n فَأَمَّا مَنْ أَعْطَى وَٱتَّقَى\n وَصَدَّقَ بِٱلْحُسْنَى\n فَسَنُيَسِّرُهُ لِلْيُسْرَى\n وَأَمَّا مَن بَخِلَ وَٱسْتَغْنَى\n وَكَذَّبَ بِٱلْحُسْنَى\n فَسَنُيَسِّرُهُ لِلْعُسْرَى","english":"Lo! your effort is dispersed (toward divers ends).\nAs for him who giveth and is dutiful (toward Allah)\nAnd believeth in goodness;\nSurely We will ease his way unto the state of ease.\nBut as for him who hoardeth and deemeth himself independent,\nAnd disbelieveth in goodness;\nSurely We will ease his way unto adversity."}]},{"pos":"verb","gloss":"to approve, to ratify"},{"pos":"noun","gloss":"verbal noun of صَدَقَ (ṣadaqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"truthfulness, sincerity, honesty"},{"pos":"adj","gloss":"true, truthful, sincere"},{"pos":"adj","gloss":"complete"},{"pos":"adj","gloss":"masculine plural of صَدْق (ṣadq)","tags":["form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine plural of صَدْق (ṣadq)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":["/sˤa.da.qa/","/sˤad.da.qa/","/sˤidq/","[sˤədəɡ]","[sˤɪd͡z]","/sˤadq/","/sˤudq/","/sˤu.duq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23996","headword_ar":"صَدَقَ","root":"Sdq","body":[{"kind":"text","text":", (S, M, O, Msb, K,) aor."},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"SidoqN","text_ar":"صِدْقٌ"},{"kind":"text","text":"(S, * M, O, * Msb, K, TA) and"},{"kind":"arabic","text_bw":"SadoqN","text_ar":"صَدْقٌ"},{"kind":"text","text":", (M, K,) the former of which is the more chaste, (TA,) or the latter is an inf. n. and the former is a simple subst., (K,) and"},{"kind":"arabic","text_bw":"taSodaAqN","text_ar":"تَصْدَاقٌ"},{"kind":"text","text":"(M) and"},{"kind":"arabic","text_bw":"maSoduwqapN","text_ar":"مَصْدُوقَةٌ"},{"kind":"text","text":", (O, K, TA,) which is one of the [few] inf. ns. of the measure"},{"kind":"arabic","text_bw":"mafoEuwlapN","text_ar":"مَفْعُولَةٌ"},{"kind":"text","text":", (O, TA,) [or a fem. pass. part. n. used as an inf. n. like as is said of its contr."},{"kind":"arabic","text_bw":"mako*uwbapN","text_ar":"مَكْذُوبَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"he spoke, said, uttered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"told, truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veraciously; contr. of"},{"kind":"arabic","text_bw":"ka*aba","text_ar":"كَذَبَ"},{"kind":"text","text":": (Msb: [and in like manner it is said in the S and M and O and K that"},{"kind":"arabic","text_bw":"SidoqN","text_ar":"صِدْقٌ"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"ka*ibN","text_ar":"كَذِبٌ"},{"kind":"text","text":":]) Er-Rághib says that"},{"kind":"arabic","text_bw":"SidoqN","text_ar":"صِدْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ka*ibN","text_ar":"كَذِبٌ"},{"kind":"text","text":"are primarily in what is said, whether relating to the past or to the future, and [in the latter case] whether it be a promise or other than a promise; and only in what is said in the way of information: but sometimes they are in other modes of speech, such as asking a question, and commanding, and supplicating; as when one says, “ Is Zeyd in the house? ” for this implies information of his being ignorant of the state of Zeyd; and when one says, “ Make me to share with thee, or to be equal with thee, ” for this implies his requiring to be made to share with the other, or to be made equal with him; and when one says, “ Do not thou hurt me, ” for this implies that the other is hurting him:"},{"kind":"arabic","text_bw":"SidoqN","text_ar":"صِدْقٌ"},{"kind":"text","text":", he says, is [by implication] the agreeing of what is said with what is conceived in the mind and with the thing told of, together; otherwise it is not complete"},{"kind":"arabic","text_bw":"Sidoq","text_ar":"صِدْق"},{"kind":"text","text":", but may be described either as"},{"kind":"arabic","text_bw":"Sidoq","text_ar":"صِدْق"},{"kind":"text","text":"or sometimes as"},{"kind":"arabic","text_bw":"Sidoq","text_ar":"صِدْق"},{"kind":"text","text":"and sometimes as"},{"kind":"arabic","text_bw":"ka*ib","text_ar":"كَذِب"},{"kind":"text","text":"according to two different points of view; as when one says without believing it, “ Mohammad is the Apostle of God, ” for this may be termed"},{"kind":"arabic","text_bw":"Sidoq","text_ar":"صِدْق"},{"kind":"text","text":"because what is told is such, and it may be termed"},{"kind":"arabic","text_bw":"ka*ib","text_ar":"كَذِب"},{"kind":"text","text":"because it is at variance with what the speaker conceives in his mind. (TA.) One says,"},{"kind":"arabic","text_bw":"Sadaqa fiY AlHadiyvi","text_ar":"صَدَقَ فِى الحَدِيثِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He spoke truth in the information,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narration"},{"kind":"text","text":"]. (S, O, K.) And"},{"kind":"arabic","text_bw":"Sadaqahu","text_ar":"صَدَقَهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"He told him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"informed him, with truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veracity,"},{"kind":"text","text":"(AHeyth, * M, Msb, *)"},{"kind":"arabic","text_bw":"fiY Alqawoli","text_ar":"فِى القَوْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the saying"},{"kind":"text","text":"]; for it is trans. as well as intrans. (Msb.) And"},{"kind":"arabic","text_bw":"Sadaqahu","text_ar":"صَدَقَهُ"},{"kind":"arabic","text_bw":"AlHadiyva","text_ar":"الحَدِيثَ"},{"kind":"text","text":"(S, O, K, in the CK [erroneously]"},{"kind":"arabic","text_bw":"Sad~aqa","text_ar":"صَدَّقَ"},{"kind":"arabic","text_bw":"fulAnFA AlHadiyva","text_ar":"فُلانًا الحَدِيثَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"He told him with truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veracity, the information,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narration;"},{"kind":"text","text":"for it is sometimes doubly trans. (TA.) And"},{"kind":"arabic","text_bw":"SadaqaniY sin~a bakorihi","text_ar":"صَدَقَنِى سِنَّ بَكْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He hath told me truly the age,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as to the age, of his youthful camel;"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"SadaqaniY sin~u bakorihi","text_ar":"صَدَقَنِى سِنُّ بَكْرِهِ"},{"kind":"italic_en","text":"the age of his youthful camel has spoken truly to me"},{"kind":"text","text":"]: (S, O, K:) a prov., (S, O,) expl. in art."},{"kind":"arabic","text_bw":"bkr","text_ar":"بكر"},{"kind":"text","text":"[q. v.]. (K.) And"},{"kind":"arabic","text_bw":"fulaAnN laA yaSoduqu A^avaruhu","text_ar":"فُلَانٌ لَا يَصْدُقُ اَثَرُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^avarahu","text_ar":"اَثَرَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Such a one,"},{"kind":"text","text":"when asked,"},{"kind":"italic_en","text":"will not tell truly whence he comes."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"Sadaqato yamiynuhu","text_ar":"صَدَقَتْ يَمِينُهُ"},{"kind":"italic_en","text":"His oath was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, true."},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"bt","text_ar":"بت"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"Sadaqotu A@ll~`ha","text_ar":"صَدَقْتُ ا@للّٰهَ"},{"kind":"arabic","text_bw":"HadiyvFA A_ino lamo A^afoEalo ka*aA","text_ar":"حَدِيثًا اـِنْ لَمْ اَفْعَلْ كَذَا"},{"kind":"text","text":"is an oath of the Arabs, meaning"},{"kind":"arabic","text_bw":"laA Sadaqotu Alx","text_ar":"لَا صَدَقْتُ الخ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May I not utter truly to God a saying,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"may I not speak truth to God, if I do not such a thing"},{"kind":"text","text":"]. (AHeyth, O, K.) One says also,"},{"kind":"arabic","text_bw":"Sadaqahu Aln~aSiyHapa","text_ar":"صَدَقَهُ النَّصِيحَةَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlA_ixaA='a","text_ar":"الاـِخَا=ءَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He rendered to him truly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sincerely, good advice,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"brotherly affection."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"Sada quwhumu AlqitaAla","text_ar":"صَدَ قُوهُمُ القِتَالَ"},{"kind":"text","text":"(S, M, K, * TA) ["},{"kind":"italic_en","text":"They gave them battle earnestly,"},{"kind":"page_break","n":1667},{"kind":"italic_en","text":"not with a false show of bravery;"},{"kind":"text","text":"as is implied in the S, and M, and K; i. e.]"},{"kind":"italic_en","text":"they advanced against them boldly in fight:"},{"kind":"text","text":"(M, TA:) and in like manner,"},{"kind":"arabic","text_bw":"SadaquwA fiY AlqitaAli","text_ar":"صَدَقُوا فِى القِتَالِ"},{"kind":"italic_en","text":"they advanced boldly in fight:"},{"kind":"text","text":"or, accord. to Er-Rághib, the former means"},{"kind":"italic_en","text":"they gave them battle so as to fulfil their duty:"},{"kind":"text","text":"and hence, in the Kur [xxxiii. 23],"},{"kind":"arabic","text_bw":"rijaAlN SadaquwA maA EaAhaduwA A@ll~`ha Ealayohi","text_ar":"رِجَالٌ صَدَقُوا مَا عَاهَدُوا ا@للّٰهَ عَلَيْهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Men who fulfilled the covenant that they had made with God."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Sadaqa All~iqaA='a","text_ar":"صَدَقَ اللِّقَا=ءَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SidoqN","text_ar":"صِدْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, in encounter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conflict."},{"kind":"text","text":"(M, TA.) And"},{"kind":"arabic","text_bw":"Sadaqa Zan~iY","text_ar":"صَدَقَ ظَنِّى"},{"kind":"italic_en","text":"My opinion was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, true,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correct,"},{"kind":"text","text":"like as one says [in the contrary case],"},{"kind":"arabic","text_bw":"ka*aba","text_ar":"كَذَبَ"},{"kind":"text","text":": (Er-Rághib, TA:) whence, in the Kur [xxxiv. 19],"},{"kind":"arabic","text_bw":"walaqado Sadaqa Ealayohimo A_iboliysu Zan~ahu","text_ar":"وَلَقَدْ صَدَقَ عَلَيْهِمْ اـِبْلِيسُ ظَنَّهُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"fiY Zan~ihi","text_ar":"فِى ظَنِّهِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"And assuredly Iblees was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, correct in his opinion"},{"kind":"text","text":"that he had formed"},{"kind":"italic_en","text":"against them"},{"kind":"text","text":"]: but some read ↓"},{"kind":"arabic","text_bw":"Sad~aqa","text_ar":"صَدَّقَ","orth_type":"arrow"},{"kind":"text","text":", meaning, as Fr says,"},{"kind":"arabic","text_bw":"Haq~aqa","text_ar":"حَقَّقَ"},{"kind":"text","text":"[i. e. Iblees"},{"kind":"italic_en","text":"proved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"found, to be true,"},{"kind":"text","text":"his opinion &c.]. (TA.) And"},{"kind":"arabic","text_bw":"Sadaqatohu nafosuhu","text_ar":"صَدَقَتْهُ نَفْسُهُ"},{"kind":"italic_en","text":"His soul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"told him truth;"},{"kind":"text","text":"meaning,]"},{"kind":"italic_en","text":"diverted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held him back, from an undertaking, causing him to imagine himself unable to prosecute it."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"k*b","text_ar":"كذب"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Sadaqa AlS~uboHu","text_ar":"صَدَقَ الصُّبْحُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The dawn shone clearly"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"sqT","text_ar":"سقط"},{"kind":"text","text":".) [And one says of a word or the like,"},{"kind":"arabic","text_bw":"yaSoduqu EalaY ka*aA","text_ar":"يَصْدُقُ عَلَى كَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It applies correctly to such a thing."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"Sadaqa AlwaHo$iY~u","text_ar":"صَدَقَ الوَحْشِىُّ"},{"kind":"text","text":": see 2, near the end."}],"source_refs":["S","M","O","Msb","K","TA"]}]}}