{"lemma":"اِتِّفاقٌ","slug":"اِتِّفاقٌ","root":"#.ف.ق","root_slug":"_-ف-ق","root_link":"/words/roots/_-ف-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of اِتَّفَقَ (ittafaqa) (form VIII)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"agreement, union, concord, harmony"},{"pos":"noun","gloss":"compact, league, alliance"},{"pos":"noun","gloss":"conspiracy"}]},"etymology":null,"ipa":["/it.ti.faːq/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D8%AA%D9%81%D8%A7%D9%82/","headword_ar":"اتفاقية","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22757#34b6b3","body_html":"<span>الاتفاقية: هي التي حكم فيها بصدق التالي على تقدير صدق المقدم؛ لا لعلاقة بينهما موجبة لذلك، بل لمجرد صدقهما، كقولنا: إن كان الإنسان ناطقًا فالحمار ناهق. وقد يقال: إنها هي التي يحكم فيها بصدق التالي فقط، ويجوز أن يكون المقدم فيها صادقًا أو كاذبًا، وتسمى بهذا المعنى: اتفاقية عامة، وبالمعنى الأول: اتفاقية خاصة، للعموم والخصوص بينهما؛ فإنه متى صدق المقدم صدق التالي، ولا ينعكس.</span>"}]}}