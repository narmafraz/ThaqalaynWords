      -b2-"},{"kind":"italic_en","text":"Beautiful in colour, and bright;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muniyrN","text_ar":"مُنِيرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^anowaru","text_ar":"اَنْوَرُ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or the last signifies [simply]"},{"kind":"italic_en","text":"beautiful;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"conspicuous and beautiful."},{"kind":"text","text":"(TA.) It is said of Mohammad."},{"kind":"arabic","text_bw":"Almutajar~adi","text_ar":"المُتَجَرَّدِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kaAna A^anowara","text_ar":"كَانَ اَنْوَرَ","orth_type":"arrow"},{"kind":"text","text":":"},{"kind":"italic_en","text":"He was beautiful and bright in the colour"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of what was unclad"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his body."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","TA"]}]},"classical_definitions":null}