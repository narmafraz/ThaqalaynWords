{"lemma":"بُتْرِ","slug":"بُتْرِ","root":"ب.ت.ر","root_slug":"ب-ت-ر","root_link":"/words/roots/ب-ت-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَبْتَر","root":"بتر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n1703"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D8%AA%D9%92%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"tailless"},{"pos":"adj","gloss":"childless, offspringless","examples":[{"text":"إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ","english":"Surely your antagonist is he who is without offspring."}]}]},"etymology":{"source":"wiktextract","text":"Color or defect adjective from the root ب ت ر (b t r)."},"ipa":["/ʔab.tar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1703","headword_ar":"بَتَرَ","root":"btr","body":[{"kind":"text","text":", (T, S, M, &c.,) aor"},{"kind":"text","text":", (M, Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"batorN","text_ar":"بَتْرٌ"},{"kind":"text","text":"; (T, S, M, &c.;) and ↓"},{"kind":"arabic","text_bw":"Abtr","text_ar":"ابتر","orth_type":"arrow"},{"kind":"text","text":"; (T;)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut off,"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"before it was complete:"},{"kind":"text","text":"(S, A, L, Msb:) or"},{"kind":"italic_en","text":"he cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut off,"},{"kind":"text","text":"(M, Mgh, K,)"},{"kind":"italic_en","text":"in any manner:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"he cut off"},{"kind":"text","text":"(a tail or the like, T)"},{"kind":"italic_en","text":"entirely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utterly."},{"kind":"text","text":"(Aboo-Is-hák, T, M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"batarahu","text_ar":"بَتَرَهُ"},{"kind":"text","text":", (K,) aor. and inf. n. as above; (TA;) or ↓"},{"kind":"arabic","text_bw":"Abtrhu","text_ar":"ابترهُ","orth_type":"arrow"},{"kind":"text","text":"; (M, L;)"},{"kind":"italic_en","text":"He cut off his tail:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amputated, his tail in any place."},{"kind":"text","text":"(M, L.) ―         -b3-"},{"kind":"arabic","text_bw":"batara raHimahu","text_ar":"بَتَرَ رَحِمَهُ"},{"kind":"text","text":", (M,) aor. as above, (M, K,) and so the inf. n., (M,) (assumed tropical:)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severed, the ties,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bonds, of his relationship; he disunited himself from his relations."},{"kind":"text","text":"(M, K. *)       -A2-"},{"kind":"arabic","text_bw":"batira","text_ar":"بَتِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"batarN","text_ar":"بَتَرٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(any beast, M)"},{"kind":"italic_en","text":"had his tail cut off:"},{"kind":"text","text":"(S, Msb, K:) or ["},{"kind":"italic_en","text":"had either the whole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of his tail cut off;] had his tail cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amputated, in any place."},{"kind":"text","text":"(M.)"}],"source_refs":["M","Mgh","Msb","S","A","L","K"]}]},"classical_definitions":null}