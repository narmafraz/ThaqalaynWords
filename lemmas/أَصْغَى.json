ry_id":"n24399","headword_ar":"اَصْغَى","root":"Sgw and SgY","body":[{"kind":"text","text":", applied to a man, (TA,)"},{"kind":"italic_en","text":"Having an inclining of the"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":"; (K, TA;) or"},{"kind":"italic_en","text":"of one of the lips:"},{"kind":"text","text":"(K, * TA: [see 1:]) fem."},{"kind":"arabic","text_bw":"SagowaA='u","text_ar":"صَغْوَا=ءُ"},{"kind":"text","text":". (TA.) ―         -b2-  And the fem., applied to a"},{"kind":"arabic","text_bw":"qaTaAp","text_ar":"قَطَاة"},{"kind":"text","text":"[or bird of the species termed"},{"kind":"arabic","text_bw":"qaTFA","text_ar":"قَطًا"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"Having an inclining of its beak,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of one of its mandibles:"},{"kind":"text","text":"and one says ↓"},{"kind":"arabic","text_bw":"SagowaA='u SagowapN","text_ar":"صَغْوَا=ءُ صَغْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"to give intensiveness to the meaning; like as one says"},{"kind":"arabic","text_bw":"layolN laAy^ilN","text_ar":"لَيْلٌ لَايِلٌ"},{"kind":"text","text":". (TA.) ―         -b3-  Also, i. e. the fem., applied to the sun,"},{"kind":"italic_en","text":"Inclining to setting."},{"kind":"text","text":"(K.)"}],"source_refs":["TA"]}]},"classical_definitions":null}