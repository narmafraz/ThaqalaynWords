role":"present_2mp","form":"تَكْسِبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْسِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكْسِب","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكْسِب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكْسِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكْسِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكْسِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكْسِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكْسِبُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْسِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْسِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكْسِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكْسِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"كَسَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَسَبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":52,"cross_references":{"qac":{"found":true,"lemma_key":"كَسَبَ","root":"كسب","pos":"V","occurrence_count":62},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n36926"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D8%B3%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to win (a struggle or war)"},{"pos":"verb","gloss":"to earn, to gain, to try to earn a living"},{"pos":"verb","gloss":"to gather riches, knowledge"},{"pos":"verb","gloss":"to make someone gain, let someone share the profit"},{"pos":"noun","gloss":"verbal noun of كَسَبَ (kasaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"revenue"},{"pos":"noun","gloss":"alternative form of كُسْبَة (kusba, “refuse of oil seeds”)","tags":["alt-of","alternative"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36926","headword_ar":"كَسَبَ","root":"ksb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kasobN","text_ar":"كَسْبٌ"},{"kind":"text","text":"(S, K, Msb) and"},{"kind":"arabic","text_bw":"kisobN","text_ar":"كِسْبٌ"},{"kind":"text","text":"(K),"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"(wealth &c.]; (S,"},{"kind":"page_break","n":2609},{"kind":"text","text":"K;) as also ↓"},{"kind":"arabic","text_bw":"Aktsbhu","text_ar":"اكتسبهُ","orth_type":"arrow"},{"kind":"text","text":". (S.) This is the original signification. (S.) ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"He gained, acquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"wealth or the like; as also ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"kasabotu $ayoy^FA","text_ar":"كَسَبْتُ شَيْيًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Akotasabotuhu","text_ar":"اكْتَسَبْتُهُ","orth_type":"arrow"},{"kind":"text","text":"are syn., [signifying"},{"kind":"italic_en","text":"I gained a thing"},{"kind":"text","text":"]. (S.) ―         -b3-  Hence [also],"},{"kind":"arabic","text_bw":"kasaba","text_ar":"كَسَبَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"text","text":"(S, K, Msb) and ↓"},{"kind":"arabic","text_bw":"tks~b","text_ar":"تكسّب","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"He sought, sought after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to gain, sustenance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(S, K,) for his family: (Msb:) or"},{"kind":"arabic","text_bw":"kasaba","text_ar":"كَسَبَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he got,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained, acquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sustenance,"},{"kind":"text","text":"&c.]; and ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he applied himself with art and diligence"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to get,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gain, acquire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earn, sustenance"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"he laboured to earn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gain, sustenance"},{"kind":"text","text":"]: (Sb, K:) [so] also ↓"},{"kind":"arabic","text_bw":"tks~b","text_ar":"تكسّب","orth_type":"arrow"},{"kind":"text","text":"is explained by"},{"kind":"arabic","text_bw":"takal~afa Alkasoba","text_ar":"تَكَلَّفَ الكَسْبَ"},{"kind":"italic_en","text":"he applied himself, as to a task, to gain, &c."},{"kind":"text","text":"(S.) ―         -b4-"},{"kind":"arabic","text_bw":"kasaba","text_ar":"كَسَبَ"},{"kind":"text","text":"is also said to signify, and originally, both"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought after,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sustenance"},{"kind":"text","text":"]; and"},{"kind":"italic_en","text":"he laboured in seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking after, sustenance."},{"kind":"text","text":"(TA.) ―         -b5-  ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"text","text":"has a more intensive signification than"},{"kind":"arabic","text_bw":"kasaba","text_ar":"كَسَبَ"},{"kind":"text","text":"; and hence, in the last verse of the second chap. of the Kur ["},{"kind":"arabic","text_bw":"lahaA maA kasabato waEalayohaA maA A@kotasabato","text_ar":"لَهَا مَا كَسَبَتْ وَعَلَيْهَا مَا ا@كْتَسَبَتْ"},{"kind":"italic_en","text":"To it"},{"kind":"text","text":"shall be given"},{"kind":"italic_en","text":"what"},{"kind":"text","text":"reward"},{"kind":"italic_en","text":"it hath earned, and upon it"},{"kind":"text","text":"shall be executed"},{"kind":"italic_en","text":"what punishment it hath drawn upon itself"},{"kind":"text","text":"], the latter is used with reference to what is good; and the former, with reference to what is evil. (IJ.) You say,"},{"kind":"arabic","text_bw":"kasaba xayorFA","text_ar":"كَسَبَ خَيْرًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did, good"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"arabic","text_bw":"$ar~FA","text_ar":"شَرًّا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did, evil"},{"kind":"text","text":"]. (A.) ―         -b6-  [This distinction, however, is not always observed: for]"},{"kind":"arabic","text_bw":"kasaba","text_ar":"كَسَبَ"},{"kind":"text","text":"signifies,"},{"kind":"italic_en","text":"He did"},{"kind":"text","text":"either a good or an evil deed: [because he who does so earns, or draws upon himself, reward or punishment.] (Jel in ii. 281; and iii. 24; &c.) And ↓"},{"kind":"arabic","text_bw":"Aktsb","text_ar":"اكتسب","orth_type":"arrow"},{"kind":"italic_en","text":"He committed"},{"kind":"text","text":"an act of which he was accusable. (Jel in xxxiii. 58.)"},{"kind":"arabic","text_bw":"kasaba A_ivomFA","text_ar":"كَسَبَ اـِثْمًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aktsbhu","text_ar":"اكتسبهُ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"["},{"kind":"italic_en","text":"committed,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"burdened himself with"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taHam~ala","text_ar":"تَحَمَّلَ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"a sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crime."},{"kind":"text","text":"(Msb.) ―         -b7-"},{"kind":"arabic","text_bw":"kasabahu maAlFA","text_ar":"كَسَبَهُ مَالًا"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"mAlA","text_ar":"مالا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aksbhu","text_ar":"اكسبهُ","orth_type":"arrow"},{"kind":"text","text":", (IAar, IAth, K,) but the former is the more approved: the latter is by Fr and some others rejected: (TA:)"},{"kind":"italic_en","text":"He caused him to gain, acquire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earn, wealth:"},{"kind":"text","text":"(IAth, Msb:) or"},{"kind":"italic_en","text":"he assisted him to gain, acquire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earn, wealth."},{"kind":"text","text":"(IAth.)"},{"kind":"arabic","text_bw":"ksbhu","text_ar":"كسبهُ"},{"kind":"arabic","text_bw":"EilomFA","text_ar":"عِلْمًا"},{"kind":"italic_en","text":"He caused him to gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquire, knowledge."},{"kind":"text","text":"(Msb.) [In like manner,]"},{"kind":"arabic","text_bw":"AlEaboda","text_ar":"العَبْدَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Asotakosabotu","text_ar":"اسْتَكْسَبْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I caused the slave to gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"make gain;"},{"kind":"text","text":"the verb having here the sense of the measure"},{"kind":"arabic","text_bw":"A^afoEalotuhu","text_ar":"اَفْعَلْتُهُ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"Aisotaxorajotuhu","text_ar":"اِسْتَخْرَجْتُهُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"A^axorajotuhu","text_ar":"اَخْرَجْتُهُ"},{"kind":"text","text":". (Msb.) [See an ex. voce"},{"kind":"arabic","text_bw":"A^adiymN","text_ar":"اَدِيمٌ"},{"kind":"text","text":".] ―         -b8-"},{"kind":"arabic","text_bw":"nahaY Eano kasobi AlA_imaA'i","text_ar":"نَهَى عَنْ كَسْبِ الاـِمَاءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(Mohammad)"},{"kind":"italic_en","text":"forbade the making female slaves to earn money,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"("},{"kind":"italic_en","text":"by prostitution"},{"kind":"text","text":")]. (TA, from a trad.) ―         -b9-"},{"kind":"arabic","text_bw":"maA kasaba","text_ar":"مَا كَسَبَ"},{"kind":"text","text":"in the Kur cxi, 2, is said to signify"},{"kind":"italic_en","text":"His children."},{"kind":"text","text":"A man's children are among the things termed his"},{"kind":"arabic","text_bw":"kasob","text_ar":"كَسْب"},{"kind":"text","text":". (TA.) ―         -b10-"},{"kind":"arabic","text_bw":"kasabahu EajabFA","text_ar":"كَسَبَهُ عَجَبًا"},{"kind":"italic_en","text":"It occasioned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused, him to wonder."},{"kind":"text","text":"(TA, voce"},{"kind":"arabic","text_bw":"A^aEojaba","text_ar":"اَعْجَبَ"},{"kind":"text","text":".)"}],"source_refs":["S","K","Msb","Sb","IAar","IAth","TA"]}]}}