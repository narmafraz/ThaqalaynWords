"role":"present_3fs","form":"تَسْلَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3mp","form":"يَسْلَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْلَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_1mp","form":"نَسْلَ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْلَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"سَلِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَلِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n20580","n20589","","n20587"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"placenta"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew שִׁלְיָה."},"ipa":["/sa.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20580","headword_ar":"سُلَّى","root":"slw","body":[{"kind":"text","text":", [said to be] like"},{"kind":"arabic","text_bw":"rub~aY","text_ar":"رُبَّى"},{"kind":"text","text":", [but it may be"},{"kind":"arabic","text_bw":"sul~FY","text_ar":"سُلًّى"},{"kind":"text","text":", as there is no apparent cause for its being imperfectly decl.,]"},{"kind":"italic_en","text":"A quality that renders forgetful of the objects of love"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that renders content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy, without them."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"slY","text_ar":"سلى"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n20589","headword_ar":"سُلَّى","root":"slY","body":[{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"sul~FY","text_ar":"سُلًّى"},{"kind":"text","text":",] mentioned in this art. in the TA: see art."},{"kind":"arabic","text_bw":"slw","text_ar":"سلو"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n20587","headword_ar":"سَلًى","root":"slY","body":[{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"salFA","text_ar":"سَلًا"},{"kind":"text","text":"[thus differently written, the former the more correct, unless the word be derived from"},{"kind":"arabic","text_bw":"Als~alowapu","text_ar":"السَّلْوَةُ"},{"kind":"text","text":", as it is said to be in the Ham p. 656, but this is improbable,] The"},{"kind":"italic_en","text":"secundine;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"skin,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"membrane,"},{"kind":"text","text":"] (M, K,) or"},{"kind":"italic_en","text":"thin skin,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"in which is the fœtus,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the womb,"},{"kind":"text","text":"] (S, M, Msb, K,) of human beings, and of horses and camels, (M,) or of human beings and of cattle, (K,) or [peculiarly] of cattle, (T, S,) that of human beings being termed"},{"kind":"arabic","text_bw":"ma$iymapN","text_ar":"مَشِيمَةٌ"},{"kind":"text","text":": (TA:) it is pulled off from the face of the young camel at the time of the birth, or else it kills it, like as it does when it becomes disrupted in the belly: when it comes forth, the she-camel is safe, and so is the young one; but if it becomes disrupted in the belly, she perishes, and so does the young one: (S:) pl."},{"kind":"arabic","text_bw":"A^asolaA='N","text_ar":"اَسْلَا=ءٌ"},{"kind":"text","text":". (M, Msb, K.) [Hence,] one says,"},{"kind":"arabic","text_bw":"AinoqaTaEa","text_ar":"اِنْقَطَعَ"},{"kind":"arabic","text_bw":"Als~alaY fiY AlbaToni","text_ar":"السَّلَى فِى البَطْنِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The secundine became disrupted in the belly"},{"kind":"text","text":"]; (S, Meyd, K;) i. e. artifice departed [or came to an end]; (S;) a prov. applied in the case of an affair's becoming beyond one's power of accomplishment, and coming to an end; (Meyd;) like the saying,"},{"kind":"arabic","text_bw":"balaga Als~ik~iynu AlEaZoma","text_ar":"بَلَغَ السِّكِّينُ العَظْمَ"},{"kind":"text","text":"[The knife reached to the bone]. (S, K.) And"},{"kind":"arabic","text_bw":"huwa A=kilu AlA^asolaA='i","text_ar":"هُوَ ا=كِلُ الاَسْلَا=ءِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He is the eater of secundines"},{"kind":"text","text":"]; meaning he is low, base, vile, or sordid. (TA.) And"},{"kind":"arabic","text_bw":"waqaEa Alqawomu fiY salaY jamalK","text_ar":"وَقَعَ القَوْمُ فِى سَلَى جَمَلٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, fell into"},{"kind":"text","text":"the like of"},{"kind":"italic_en","text":"the secundine of a hecamel"},{"kind":"text","text":"]; meaning they fell into a difficult affair or case; (S, K *) or they fell into an unparalleled evil; (Meyd;) for the he-camel has no"},{"kind":"arabic","text_bw":"slY","text_ar":"سلى"},{"kind":"text","text":". (S, Meyd.)"}],"source_refs":["M","K","S","Msb","T","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D9%84%D9%8A/","headword_ar":"سلي","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=17281#a8ca16","body_html":"سلي<br>من (س ل و) الكثير السلو: النسيان وطيب النفس بعد الفراق. يستخدم للذكور."},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=17281#0f7dfe","body_html":"<span class=\"title1\">السين واللام والياء س ل ي</span><br><br><span>السَّلَى الجلدة التي يكون فيها الوَلَد يكون ذلك للنَّاسِ والخَيْل والإِبِلِ والجمع أَسْلاءٌ وَقَع في سَلا جَمَلٍ أي في أَمْرٍ لا مَخْرَجَ له لأن الجَمَل لا سَلَى له وسَلِيَتِ الشاةُ سَلىً فهي سَلْيَاءُ انْقَطَعَ سَلاَها وسَلاها سَلْياً نَزَع سَلاها وقال اللّحْيانيُّ سَلَيْت الناقةَ مَدَدْت سَلاها بعد الرَحِم وقوله أنشده سيبويه</span><br><br><span>(قَبِّحَ مَنْ يَزْنِي بعوفٍ </span><span class=\"red\">...</span><span> من ذوات الخُمُرِ) </span><span>(الآكلِ الأسْلاء لا </span><span class=\"red\">...</span><span> يَحْفِلُ ضَوْءَ القَمَرِ)</span><br><br><span>ليس بالسَّلَى الذي تَقَدَّم ذكرُه وإنما كَنَى به عن الأَفْعال الخَسِيسَة لخِسَّة السَّلَى وقوله لا يَحْفِلُ ضَوْءَ القَمر أي لا يُبالي السَّهَرَ لأن القَمَر يَفْضَحُ المُكْتَتَم</span>"}]}}