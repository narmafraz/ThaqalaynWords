{"lemma":"خالَفَ","slug":"خالَفَ","root":"خ.ل.ف","root_slug":"خ-ل-ف","root_link":"/words/roots/خ-ل-ف","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خالَفْتَ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خالَفْتِ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خالَفْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خالَفْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خالَفْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خالَفَ","in_corpus":true,"count":36,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خالَفَت","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خالَفا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خالَفَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خالَفُوا","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خالَفْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُخالِف","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُخالِفِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُخالِفِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُخالِفا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُخالِفانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُخالِفُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُخالِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُخالِفْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُخالِف","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُخالِف","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُخالِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخالِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخالِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخالِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخالِفُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخالِفُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخالِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خالَفْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خالَفْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُخالِف","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخالِف","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":99,"cross_references":{"qac":{"found":true,"lemma_key":"خالَفَ","root":"خلف","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n11366"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D9%84%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to contradict, thwart, to disagree with [+ transitive (object)] on","examples":[{"text":".وخالف الرئيس ترمب مواقف قوى كبرى أخرى هذا الشهر برفضه أن يقر رسميا التزام طهران ببنود الاتفاق النووي","english":"President Trump diverged this month from the positions of other major powers by refusing to acknowledge formally the commitment of Teheran to the clauses of the nuclear deal."}]},{"pos":"verb","gloss":"to disobey, go against, contravene"},{"pos":"verb","gloss":"to transgress the law"},{"pos":"verb","gloss":"to caper in walking"}]},"etymology":null,"ipa":["/xaː.la.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11366","headword_ar":"خَالِفٌ","root":"xlf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xalofN","text_ar":"خَلْفٌ"},{"kind":"text","text":", in the former half of the paragraph. ―         -b2-  Also One"},{"kind":"italic_en","text":"who remains behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, another,"},{"kind":"text","text":"(Yz, K, TA,) or"},{"kind":"italic_en","text":"others, in the case of a war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a warring and plundering expedition,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in other cases:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"xaAlifuwna","text_ar":"خَالِفُونَ"},{"kind":"text","text":"(Yz, K, TA) and"},{"kind":"arabic","text_bw":"xawaAlifu","text_ar":"خَوَالِفُ"},{"kind":"text","text":", which latter is extr. [in this case], but is also said to be a [reg.] pl. of ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":", and as such to signify persons"},{"kind":"italic_en","text":"who do not go forth on a warring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warring and plundering, expedition:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlgaAziY","text_ar":"الغَازِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAlifapu","text_ar":"خَالِفَةُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he who remains behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, him who goes forth on such an expedition, being of his family."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"faA@qoEuduwA maEa AlxaAlifiyna","text_ar":"فَا@قْعُدُوا مَعَ الخَالِفِينَ"},{"kind":"text","text":", in the Kur [ix. 84], means"},{"kind":"italic_en","text":"Then stay ye with those who remain behind."},{"kind":"text","text":"(Yz, K. *)"},{"kind":"arabic","text_bw":"xawaAlifu","text_ar":"خَوَالِفُ"},{"kind":"text","text":"is also pl. of ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":"[as fem. of"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":"], (TA,) and signifies"},{"kind":"italic_en","text":"Women"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"remaining behind in the houses"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tents:"},{"kind":"text","text":"but some assign to it the first of the meanings explained above: and some say that it means the"},{"kind":"italic_en","text":"children remaining behind."},{"kind":"text","text":"(TA.) It is said in the Kur [ix. 88 and 94], ↓"},{"kind":"arabic","text_bw":"raDuwA biA^ano yakuwnuwA maEa AlxawaAlifi","text_ar":"رَضُوا بِاَنْ يَكُونُوا مَعَ الخَوَالِفِ","orth_type":"arrow"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"They chose to be"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with the women:"},{"kind":"text","text":"(S, K: *) thus it is explained by Ibn-'Arafeh: but some say that the meaning is,"},{"kind":"italic_en","text":"with the bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt,"},{"kind":"text","text":"persons; and that"},{"kind":"arabic","text_bw":"xwAlf","text_ar":"خوالف"},{"kind":"text","text":"is here a pl. [of"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"fawaArisu","text_ar":"فَوَارِسُ"},{"kind":"text","text":". (TA.) For ―         -b3-"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":"is applied to a man [as meaning"},{"kind":"italic_en","text":"Bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":"to a woman as meaning"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt, and remaining behind in her abode:"},{"kind":"text","text":"and the former to a slave as meaning"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"contrarious:"},{"kind":"text","text":"and in this last sense it is likewise applied to a companion: and some of the grammarians say that there is no word of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":"having its pl. of the measure"},{"kind":"arabic","text_bw":"fawaAEilu","text_ar":"فَوَاعِلُ"},{"kind":"text","text":", except"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"haAlikN","text_ar":"هَالِكٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faArisN","text_ar":"فَارِسٌ"},{"kind":"text","text":": but see this last: (TA:) and ↓"},{"kind":"arabic","text_bw":"xil~iyfapN","text_ar":"خِلِّيفَةٌ","orth_type":"arrow"},{"kind":"text","text":", also, has this last signification; (JK, TA;) or [rather] signifies"},{"kind":"italic_en","text":"very contrarious;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (JK;) and so ↓"},{"kind":"arabic","text_bw":"xilafonapN","text_ar":"خِلَفْنَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"xilafonaApN","text_ar":"خِلَفْنَاةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, JK, K,) in each of which the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"is augmentative, and each of which is applied to a man and to a woman and to a pl. number; (Lh, K;) but"},{"kind":"arabic","text_bw":"xilafonayaAtN","text_ar":"خِلَفْنَيَاتٌ"},{"kind":"text","text":"has been mentioned as pl. [of"},{"kind":"arabic","text_bw":"xlfnAp","text_ar":"خلفناة"},{"kind":"text","text":"], and as applied to males and females: (TA:) and"},{"kind":"arabic","text_bw":"xaAlifuwna","text_ar":"خَالِفُونَ"},{"kind":"text","text":"is likewise used in this sense applied to a number of men. (JK.) ―         -b4-  Also, applied to a slave, [and app. to any man, but in this latter case I find it written"},{"kind":"arabic","text_bw":"xlf","text_ar":"خلف"},{"kind":"text","text":", which I believe to be a mistranscription,] One"},{"kind":"italic_en","text":"who has withdrawn from the people of his house:"},{"kind":"text","text":"so says Lh. (TA.) ―         -b5-  Also"},{"kind":"italic_en","text":"Stupid; foolish;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no, intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) but in an intensive sense, and also applied to a woman; (TA;) and ↓"},{"kind":"arabic","text_bw":"A^axolafu","text_ar":"اَخْلَفُ","orth_type":"arrow"},{"kind":"text","text":", (JK, K,) of which the fem. is"},{"kind":"arabic","text_bw":"xalofaA='u","text_ar":"خَلْفَا=ءُ"},{"kind":"text","text":"; (JK, TA;) and ↓"},{"kind":"arabic","text_bw":"xulofufN","text_ar":"خُلْفُفٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"xulofafN","text_ar":"خُلْفَفٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) or both, (JK,) likewise applied to a woman, as also ↓"},{"kind":"arabic","text_bw":"xulofufapN","text_ar":"خُلْفُفَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"xulofafapN","text_ar":"خُلْفَفَةٌ","orth_type":"arrow"},{"kind":"text","text":": (JK:) or, as some say,"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":"signifies one"},{"kind":"italic_en","text":"in whom is no good:"},{"kind":"text","text":"and, as also ↓"},{"kind":"arabic","text_bw":"xaAlifapN","text_ar":"خَالِفَةٌ","orth_type":"arrow"},{"kind":"text","text":", one"},{"kind":"italic_en","text":"who has not what suffices:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who often breaks his promises:"},{"kind":"text","text":"(TA:) or both of these mean one"},{"kind":"italic_en","text":"who has not what suffices, and in whom is no good:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very contrarious."},{"kind":"text","text":"(JM.) One says that a man is"},{"kind":"arabic","text_bw":"A^aholi bayotihi","text_ar":"اَهْلِ بَيْتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAlifapu","text_ar":"خَالِفَةُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xaAlifu","text_ar":"خَالِفُ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"Ahl byth","text_ar":"اهل بيته"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The one in whom is no good, of the people of his house:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"the ungenerous:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"the stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the evil:"},{"kind":"text","text":"and it is [said to be] tropical. (TA.) And ↓"},{"kind":"arabic","text_bw":"qawomN xawaAlifN","text_ar":"قَوْمٌ خَوَالِفٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Persons in whom is no good."},{"kind":"text","text":"(JK.) ―         -b6-  And, [app. because he leaves his family behind him,]"},{"kind":"italic_en","text":"A drawer of water;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"musotaxolifN","text_ar":"مُسْتَخْلِفٌ","orth_type":"arrow"},{"kind":"text","text":"[q. v.]: both mentioned in the K; but"},{"kind":"arabic","text_bw":"Als~aq~aA='u","text_ar":"السَّقَّا=ءُ"},{"kind":"text","text":"is there erroneously put for"},{"kind":"arabic","text_bw":"AlmusotaqiY","text_ar":"المُسْتَقِى"},{"kind":"text","text":". (TA.) ―         -b7-  And"},{"kind":"italic_en","text":"Weak, without appetite for food."},{"kind":"text","text":"(TA.) ―         -b8-  And Flesh-meat"},{"kind":"italic_en","text":"from which a slight smell is perceived, but in the chewing of which is no harm."},{"kind":"text","text":"(Lth, TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"xulofN","text_ar":"خُلْفٌ"},{"kind":"text","text":"."}],"source_refs":["Yz","K","TA","Lh","JK","L","S"]}]},"classical_definitions":null}