{"lemma":"عاجِزُو","slug":"عاجِزُو","root":"ع.ج.ز","root_slug":"ع-ج-ز","root_link":"/words/roots/ع-ج-ز","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n28155"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D8%AC%D9%90%D8%B2%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"incapable"},{"pos":"adj","gloss":"helpless, powerless"},{"pos":"adj","gloss":"disabled, crippled"},{"pos":"adj","gloss":"weak, frail"},{"pos":"noun","gloss":"disabled person"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of عَجَزَ (ʕajaza, “to become incapable”)."},"ipa":["/ʕaː.d͡ʒiz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28155","headword_ar":"عَاجِزٌ","root":"Ejz","body":[{"kind":"italic_en","text":"Lacking strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability; powerless, unable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impotent;"},{"kind":"text","text":"(K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"EajuwzN","text_ar":"عَجُوزٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"EajizN","text_ar":"عَجِزٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl. of the first ["},{"kind":"arabic","text_bw":"EaAjizuwna","text_ar":"عَاجِزُونَ"},{"kind":"text","text":", and]"},{"kind":"arabic","text_bw":"EajazN","text_ar":"عَجَزٌ"},{"kind":"text","text":", [or rather this a quasi-pl. n.,] like as"},{"kind":"arabic","text_bw":"xadamN","text_ar":"خَدَمٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"xaAdimN","text_ar":"خَادِمٌ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"EawaAjizu","text_ar":"عَوَاجِزُ"},{"kind":"text","text":", (O, K,) but this is only in the dial. of Hudheyl, and, applied to men, is anomalous. (O, TA.) You say also,"},{"kind":"arabic","text_bw":"AimoraA^apN EaAjizN","text_ar":"اِمْرَاَةٌ عَاجِزٌ"},{"kind":"italic_en","text":"A woman lacking strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, to do a thing; unable to do a thing."},{"kind":"text","text":"(IAar, TA.) And it is said in a trad., respecting Paradise,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"yadoxuluniY A_il~aA saqaTu Aln~aAsi waEajazuhumo","text_ar":"يَدْخُلُنِى اـِلَّا سَقَطُ النَّاسِ وَعَجَزُهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There shall not enter me save the mean of mankind, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"those lacking in intelligence and in power with respect to worldly things."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"vawobN EaAjizN","text_ar":"ثَوْبٌ عَاجِزٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A garment that is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"too"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"short:"},{"kind":"text","text":"(A, O, TA:) or"},{"kind":"italic_en","text":"narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty."},{"kind":"text","text":"(O.)"}],"source_refs":["K","TA","O","A"]}]},"classical_definitions":null}