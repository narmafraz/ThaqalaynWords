{"lemma":"بَطانَة","slug":"بَطانَة","root":"ب.ط.ن","root_slug":"ب-ط-ن","root_link":"/words/roots/ب-ط-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بَطانَة","root":"بطن","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n2815"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B7%D8%A7%D9%86%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"inside (part), innings"},{"pos":"noun","gloss":"liner, lining"},{"pos":"noun","gloss":"clique, intimate circle of family or friends"},{"pos":"noun","gloss":"endothelium"}]},"etymology":null,"ipa":["/bi.tˤaː.na/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2815","headword_ar":"بِطَانَةٌ","root":"bTn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"lining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inner covering,"},{"kind":"text","text":"of a garment, or piece of cloth [&c.];"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"ZihaArapN","text_ar":"ظِهَارَةٌ"},{"kind":"text","text":"; (S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"baATinapN","text_ar":"بَاطِنَةٌ","orth_type":"arrow"},{"kind":"text","text":": (JK in art."},{"kind":"arabic","text_bw":"Zhr","text_ar":"ظهر"},{"kind":"text","text":":) pl. of the former"},{"kind":"arabic","text_bw":"baTaAy^nu","text_ar":"بَطَاينُ"},{"kind":"text","text":". (TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"A secret"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"that a man conceals."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"huwa *uw biTaAnapK bifulaAnK","text_ar":"هُوَ ذُو بِطَانَةٍ بِفُلَانٍ"},{"kind":"text","text":", i. e. (assumed tropical:)"},{"kind":"italic_en","text":"He is one who possesses knowledge of the inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances of the case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, of such a one."},{"kind":"text","text":"(TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"A particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimate, friend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associate;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"one who is particularly distinguished by entering into, and becoming acquainted with, the inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances of one's case"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"an intimate and familiar friend"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associate;"},{"kind":"text","text":"(Zj, TA;)"},{"kind":"italic_en","text":"a confidential friend, who is consulted respecting one's circumstances:"},{"kind":"text","text":"(TA:) it is from the same word in the sense first explained above, relating to a garment, or piece of cloth: (Mgh, Er-Rághib:) and is used in a pl. sense, as meaning"},{"kind":"italic_en","text":"intimate and familiar friends"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associates, to whom one is open,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unreserved, in conversation, and who know the"},{"kind":"italic_en","text":"inward state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of one's case"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair"},{"kind":"text","text":"]: (Zj, TA:) or one's"},{"kind":"italic_en","text":"family;"},{"kind":"text","text":"and one's"},{"kind":"italic_en","text":"particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimates, friends,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associates."},{"kind":"text","text":"(Mgh.) You say,"},{"kind":"arabic","text_bw":"huwa biTaAnatiY","text_ar":"هُوَ بِطَانَتِى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is my particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimate,"},{"kind":"text","text":"&c.]: and"},{"kind":"arabic","text_bw":"humo","text_ar":"هُمْ"},{"kind":"arabic","text_bw":"biTaAnatiY","text_ar":"بِطَانَتِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aholu biTaAnatiY","text_ar":"اَهْلُ بِطَانَتِى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"They are my particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimates,"},{"kind":"text","text":"&c.]. (A, TA.) See also 4. ―         -b4-  Coupled with"},{"kind":"arabic","text_bw":"EalaAwap","text_ar":"عَلَاوَة"},{"kind":"text","text":", it signifies"},{"kind":"italic_en","text":"What is put beneath"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the things that compose the main load of a camel"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"such as a water-skin and the like."},{"kind":"text","text":"(TA.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"baATinapN","text_ar":"بَاطِنَةٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA","Zj"]}]}}