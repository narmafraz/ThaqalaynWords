53"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%87%D9%8E%D9%91%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ready, to prepare, to furnish"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6553","headword_ar":"جهّز","root":"jhz","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajohiyzN","text_ar":"تَجْهِيزٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He fitted out, equipped, furnished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supplied,"},{"kind":"text","text":"a bride, and a traveller, and a corpse, (S, Msb, K,) and an army, (S,)"},{"kind":"italic_en","text":"with her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their,"},{"kind":"arabic","text_bw":"jahaAz","text_ar":"جَهَاز"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"requisites, equipage, furniture, accoutrements,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparatus"},{"kind":"text","text":"]: (S, Msb. K:)"},{"kind":"italic_en","text":"he provided"},{"kind":"text","text":"a warrior"},{"kind":"italic_en","text":"with a beast to ride, and with other requisites for his expedition:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he prepared"},{"kind":"text","text":"him or it. (TA.) You say also,"},{"kind":"arabic","text_bw":"jhaz Ealayohi Alxayola","text_ar":"جهَز عَلَيْهِ الخَيْلَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fitted out the horsemen and sent them against him"},{"kind":"text","text":"]. (S.)       -A2-  See also 4."}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}