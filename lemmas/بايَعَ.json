num":"p"},{"role":"present_3mp","form":"يُبايِعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبايَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُبايِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُبايَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبايَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بايَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بايَعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبايِع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُبايِع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بُويِعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بُويِعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":36,"cross_references":{"qac":{"found":true,"lemma_key":"بايَعَ","root":"بيع","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n3553","n3652"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D8%A7%D9%8A%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to recognize as leader, to pledge allegiance to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to pay homage to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to make a contract with (someone)","tags":["transitive"]}]},"etymology":null,"ipa":["/baː.ja.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3553","headword_ar":"بَايِعٌ","root":"bwE","body":[{"kind":"italic_en","text":"A young gazelle that stretches forth its fore legs to the full"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yabuwEu","text_ar":"يَبُوعُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in going along:"},{"kind":"text","text":"(K, TA:) an epithet in which the quality of a subst. is predominant: (TA:) pl."},{"kind":"arabic","text_bw":"buwEN","text_ar":"بُوعٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"bawaAy^iEu","text_ar":"بَوَايِعُ"},{"kind":"text","text":". (TA.) And ↓"},{"kind":"arabic","text_bw":"A^abowaAEu","text_ar":"اَبْوَاعُ","orth_type":"arrow"},{"kind":"text","text":", a determinate noun, is applied to"},{"kind":"italic_en","text":"The ewe,"},{"kind":"text","text":"because she does so in going along: and she is called to be milked thereby; (Ibn-'Abbád, K;) by saying,"},{"kind":"arabic","text_bw":"A^abowaAEu A^abowaAEu","text_ar":"اَبْوَاعُ اَبْوَاعُ"},{"kind":"text","text":". (Ibn-'Abbád.) You say also"},{"kind":"arabic","text_bw":"naAqapN baAy^iEapu","text_ar":"نَاقَةٌ بَايِعَةُ"},{"kind":"italic_en","text":"A she-camel that steps far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"takes long steps:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"bawaAy^iEu","text_ar":"بَوَايِعُ"},{"kind":"text","text":". (TA.) And ↓"},{"kind":"arabic","text_bw":"farasN bay~iEN","text_ar":"فَرَسٌ بَيِّعٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) originally"},{"kind":"arabic","text_bw":"bayowiEN","text_ar":"بَيْوِعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"A horse that steps far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"takes long steps."},{"kind":"text","text":"(Z, K.)"}],"source_refs":["K","TA"]},{"entry_id":"n3652","headword_ar":"بَايِعٌ","root":"byE","body":[{"kind":"italic_en","text":"Selling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a seller:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"buying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a buyer:"},{"kind":"text","text":"(Msb, K, * TA:) as also ↓"},{"kind":"arabic","text_bw":"bay~iEN","text_ar":"بَيِّعٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) the former signification is the more obvious when"},{"kind":"arabic","text_bw":"bAy^E","text_ar":"بايع"},{"kind":"text","text":"is used without restriction: (Msb:) and ↓"},{"kind":"arabic","text_bw":"bay~iEN","text_ar":"بَيِّعٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies [accord. to some]"},{"kind":"italic_en","text":"a bargainer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chafferer;"},{"kind":"text","text":"(K, TA;) not a seller nor a buyer; but Esh-Sháfi'ee and Az deny that this epithet is applied to a man before he has concluded the contract: (L, TA:) the pl. of"},{"kind":"arabic","text_bw":"bAy^E","text_ar":"بايع"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"baAEapN","text_ar":"بَاعَةٌ"},{"kind":"text","text":": (ISd, K:) and the pl. of ↓"},{"kind":"arabic","text_bw":"by~E","text_ar":"بيّع","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"biyaEaA='u","text_ar":"بِيَعَا=ءُ"},{"kind":"text","text":"[or rather this is a quasi-pl. n.] and"},{"kind":"arabic","text_bw":"A^aboyEaA='u","text_ar":"اَبْيعَا=ءُ"},{"kind":"text","text":": (K:) and Kr holds that"},{"kind":"arabic","text_bw":"baAEapN","text_ar":"بَاعَةٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"by~E","text_ar":"بيّع"},{"kind":"text","text":". (TA.) ↓"},{"kind":"arabic","text_bw":"Albay~iEaAni","text_ar":"البَيِّعَانِ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The seller and the buyer;"},{"kind":"text","text":"(S, Mgh;) and so ↓"},{"kind":"arabic","text_bw":"AlmutabaAyiEaAni","text_ar":"المُتَبَايِعَانِ","orth_type":"arrow"},{"kind":"text","text":". (TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"biAlxiyaAri maA","text_ar":"بِالخِيَارِ مَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Albay~iEaAni","text_ar":"البَيِّعَانِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"lamo yatafar~aqaA","text_ar":"لَمْ يَتَفَرَّقَا"},{"kind":"text","text":", and in another, ↓"},{"kind":"arabic","text_bw":"AlmutabaAyiEaAni","text_ar":"المُتَبَايِعَانِ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The seller and the buyer have the option"},{"kind":"text","text":"of cancelling the contract"},{"kind":"italic_en","text":"as long as they have not separated."},{"kind":"text","text":"] (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AimoraA^apN baAy^iEN","text_ar":"اِمْرَاَةٌ بَايِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A woman who easily obtains a suitor;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who is much in demand; by reason of her beauty:"},{"kind":"text","text":"(K, TA:) as though she sold herself: like"},{"kind":"arabic","text_bw":"naAqapN taAjirapN","text_ar":"نَاقَةٌ تَاجِرَةٌ"},{"kind":"text","text":". (Z, TA.)"}],"source_refs":["K","Msb","L","TA","ISd"]}]}}