oss_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n37590","n38106"],"search_url":"https://lanelexicon.com/?s=%D9%84%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to appear, to become visible, to begin to shine; to glimmer, to emerge, loom, to engender","tags":["figuratively"],"examples":[{"text":"[نائب رئيس مجلس ناحية السعدية في محافظة ديالى عدنان إسماعيل] مضيفًا أن \"المركز الصحي في المجمع يفتقر الى لقاحات مرض حبة بغداد بشكل عام ولا توجد فيه جرعة علاج واحدة الان\"، داعيا وزارة الصحة الى \"التدخل بأسرع وقت ممكن لإنقاذ قرى حمرين من كارثة صحية اصبحت تلوح في الافق\".","english":"Adding that “the health centre in the community misses vaccines against leishmaniasis in a general extent and there is now not a single treatment dose in it”, calling out the Ministry of Health to “intervene in the shortest possible time to save the villages of Ḥamrīn from a health disaster that looms in the horizon”."}]},{"pos":"verb","gloss":"to appear, to become visible, to begin to shine; to shine upon; to tan","tags":["rare"]}]},"etymology":null,"ipa":["/laː.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37590","headword_ar":"لَاحٌّ","root":"lH","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"laHiHN","text_ar":"لَحِحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"laHolaHN","text_ar":"لَحْلَحٌ","orth_type":"arrow"},{"kind":"text","text":"(K) A"},{"kind":"italic_en","text":"strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confined,"},{"kind":"text","text":"place. (S, K.) Also,"},{"kind":"arabic","text_bw":"laAH~N","text_ar":"لَاحٌّ"},{"kind":"text","text":", A valley"},{"kind":"italic_en","text":"with tangled, confused, intertwined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complicated, trees, which stick together:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confined, and abounding with tangled trees, and stones."},{"kind":"text","text":"In both senses, applied to a place and a valley, it is also written"},{"kind":"arabic","text_bw":"laAx~N","text_ar":"لَاخٌّ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"x","text_ar":"خ"},{"kind":"text","text":". (L.) [See"},{"kind":"arabic","text_bw":"laAx~N","text_ar":"لَاخٌّ"},{"kind":"text","text":".]"}],"source_refs":["S","K"]},{"entry_id":"n38106","headword_ar":"لَاحَ","root":"lwH","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"shone; gleamed; glistened."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"laAHa","text_ar":"لَاحَ"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"luw^uwHN","text_ar":"لُوُوحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lawaHaAnN","text_ar":"لَوَحَانٌ"},{"kind":"text","text":"; TA;) and ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(lightning)"},{"kind":"italic_en","text":"flashed slightly, not extending sideways in the adjacent tracts of cloud:"},{"kind":"text","text":"(S, K:) or ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"it lighted up what surrounded it."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"laAHa","text_ar":"لَاحَ"},{"kind":"text","text":", (S, Msb,) aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":"; (Msb;) inf. n. ["},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"liyaAHN","text_ar":"لِيَاحٌ"},{"kind":"text","text":"; (IAth;)"},{"kind":"italic_en","text":"It appeared:"},{"kind":"text","text":"(IAth, Msb:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a star)"},{"kind":"italic_en","text":"appeared,"},{"kind":"text","text":"(S, Msb,) as also ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"text","text":", (S, K,) ["},{"kind":"italic_en","text":"it loomed,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and shone, gleamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"text","text":": (Msb, TA:) ISk says,"},{"kind":"arabic","text_bw":"laAHa suhayol","text_ar":"لَاحَ سُهَيْل"},{"kind":"italic_en","text":"Canopus appeared;"},{"kind":"text","text":"(S;) and ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"italic_en","text":"it shone and glistened."},{"kind":"text","text":"(S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"lAH","text_ar":"لاح"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlAH","text_ar":"الاح","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"came forth and became apparent."},{"kind":"text","text":"(A 'Obeyd.) ―         -b5-"},{"kind":"arabic","text_bw":"laAHa liY A^amoruka","text_ar":"لَاحَ لِى اَمْرُكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tlw~H","text_ar":"تلوّح","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Thine affair became apparent and manifest to me."},{"kind":"text","text":"(A.) ―         -b6-"},{"kind":"arabic","text_bw":"laAHa Al$~ayobu fiY raA^osihi","text_ar":"لَاحَ الشَّيْبُ فِى رَاْسِهِ"},{"kind":"italic_en","text":"Hoariness appeared upon his head."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"laAHahu","text_ar":"لَاحَهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He saw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.) ―         -b8-"},{"kind":"arabic","text_bw":"laAHa A_ilaY ka*aA","text_ar":"لَاحَ اـِلَى كَذَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He looked at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, such a thing;"},{"kind":"text","text":"as a distant fire. (L.) ―         -b9-"},{"kind":"arabic","text_bw":"laAHahu bibaSarihi","text_ar":"لَاحَهُ بِبَصَرِهِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lawoHapN","text_ar":"لَوْحَةٌ"},{"kind":"text","text":", [so in the L,]"},{"kind":"italic_en","text":"He saw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, and then he"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became concealed from him."},{"kind":"text","text":"(L.) ―         -b10-  See 4.       -A2-"},{"kind":"arabic","text_bw":"laAHa","text_ar":"لَاحَ"},{"kind":"text","text":", (S,) aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"text","text":"(S, K,) and"},{"kind":"arabic","text_bw":"luwHN","text_ar":"لُوحٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"luwaAHN","text_ar":"لُوَاحٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"luw^uwHN","text_ar":"لُوُوحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lawaHaAnN","text_ar":"لَوَحَانٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AltAH","text_ar":"التاح","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He thirsted:"},{"kind":"text","text":"(S, K;) or"},{"kind":"italic_en","text":"he thirsted in the slightest degree:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he thirsted quickly."},{"kind":"text","text":"(Lh.) ―         -b2-"},{"kind":"arabic","text_bw":"laAHahu","text_ar":"لَاحَهُ"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yaluwHu","text_ar":"يَلُوحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(thirst, K, or travel, S, K, and cold, and disease or illness, and grief, TA,)"},{"kind":"italic_en","text":"altered him,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and made him lean, lank, light of flesh, slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lank in the belly;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"lw~Hhu","text_ar":"لوّحهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"talowiyHN","text_ar":"تَلْوِيحٌ"},{"kind":"text","text":": or the latter signifies"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the heat of fire or of the sun)"},{"kind":"italic_en","text":"altered the colour of his skin:"},{"kind":"text","text":"(TA:) or both verbs signify"},{"kind":"italic_en","text":"it parched, scorched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burned, and blackened, his skin."},{"kind":"text","text":"(Zj.)"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"law~aHatohu","text_ar":"لَوَّحَتْهُ","orth_type":"arrow"},{"kind":"italic_en","text":"The sun altered him, and scorched,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"slightly burned, and changed the colour of, his face;"},{"kind":"text","text":"(S;) and in like manner fire, and the hot wind called"},{"kind":"arabic","text_bw":"samuwm","text_ar":"سَمُوم"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"laAHatohu","text_ar":"لَاحَتْهُ"},{"kind":"text","text":". (A.)"}],"source_refs":["S","K","Msb","IAth","TA"]}]},"classical_definitions":null}