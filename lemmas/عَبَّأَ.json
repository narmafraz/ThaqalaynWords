{"lemma":"عَبَّأَ","slug":"عَبَّأَ","root":"ع.ب.#","root_slug":"ع-ب-_","root_link":"/words/roots/ع-ب-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَبَّأْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَبَّأْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَبَّأْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَبَّأْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَبَّأْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَبَّأَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَبَّأَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَبَّآ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَبَّأَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَبَّأُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3mp","form":"عَبَّؤُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَبَّأْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَبِّئ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَبِّئِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَبِّئِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَبِّئا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَبِّئانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَبِّئُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَبِّئُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَبِّئْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَبِّئ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَبِّئ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَبِّئا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَبِّئانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَبِّئا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَبِّئانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَبِّئُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَبِّئُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَبِّئْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَبَّأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَبَّأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُعَبِّئ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَبِّئ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27770","","n27906","n27908","n27916"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%A8%D9%8E%D9%91%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to arrange, to set in order, to pack well"},{"pos":"verb","gloss":"to burden oneself; to trouble oneself; to bother oneself; to care","examples":[{"text":"قُلْ مَا يَعْبَأُ بِكُمْ رَبِّي لَوْلَا دُعَاؤُكُمْ ۖ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزَامًا","english":"Say \"My Lord does not bother himself about you, without your prayers. You have disbelieved, and it shall be binding.\""}]},{"pos":"verb","gloss":"to load, to pack, to fill, to position for taking away, to set up, to field, to mobilize, to galvanize, to prime"}]},"etymology":null,"ipa":["/ʕa.ba.ʔa/","/ʕab.ba.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27770","headword_ar":"عَبَاَ","root":"EbA^","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eabo'N","text_ar":"عَبْءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He packed up"},{"kind":"text","text":"goods, or utensils;"},{"kind":"italic_en","text":"put"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"one upon another:"},{"kind":"text","text":"(TA:) you say,"},{"kind":"arabic","text_bw":"EabaA^otu Al$~aYo'a fiY AlwiEaA='i","text_ar":"عَبَاْتُ الشَّىْءَ فِى الوِعَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I packed the thing in the repository"},{"kind":"text","text":"], aor. as above: and some allow also"},{"kind":"arabic","text_bw":"Eab~ayotu","text_ar":"عَبَّيْتُ"},{"kind":"text","text":"with teshdeed and"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"[which is commonly used in the present day]: (Msb:) [and"},{"kind":"arabic","text_bw":"Eabawotu","text_ar":"عَبَوْتُ"},{"kind":"text","text":"also, inf. n."},{"kind":"arabic","text_bw":"EabowN","text_ar":"عَبْوٌ"},{"kind":"text","text":":] or"},{"kind":"arabic","text_bw":"EabaA^a","text_ar":"عَبَاَ"},{"kind":"text","text":", (S, O, K,) aor. as above, (K,) and so the inf. n.; (S, O;) and ↓"},{"kind":"arabic","text_bw":"Eb~A^","text_ar":"عبّا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEobiy^apN","text_ar":"تَعْبِيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taEobiYo'N","text_ar":"تَعْبِىْءٌ"},{"kind":"text","text":"; (S, O, K;)"},{"kind":"italic_en","text":"he prepared, set in order, disposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged,"},{"kind":"text","text":"goods, or utensils: (S, O, K:) and each, (K,) or the former, (Msb,) or the latter, (S, O,) and"},{"kind":"arabic","text_bw":"Eb~Y","text_ar":"عبّى"},{"kind":"text","text":", with teshdeed and"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", (Msb,) [agreeably with the authority of Yoo, for] Yoo used to say"},{"kind":"arabic","text_bw":"taEobiyapu Aljayo$i","text_ar":"تَعْبِيَةُ الجَيْشِ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"he fitted out with the requisite equipage &c.,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"prepared,"},{"kind":"text","text":"(O,) or"},{"kind":"italic_en","text":"set in order, disposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged,"},{"kind":"text","text":"(O, Msb,) or"},{"kind":"italic_en","text":"set in order, disposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged, in their places, and prepared for war"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fight,"},{"kind":"text","text":"(TA,) the horsemen, (S, O,) or the army. (Msb, K, TA.) And"},{"kind":"arabic","text_bw":"EabaA^otu lahu $ar~FA","text_ar":"عَبَاْتُ لَهُ شَرًّا"},{"kind":"italic_en","text":"I prepared for him evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EabaA^a","text_ar":"عَبَاَ"},{"kind":"text","text":", (AZ, S, O, K,) aor. as above, (TA,) and so the inf. n., (AZ, S, O,) also signifies"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"prepared and made,"},{"kind":"text","text":"(AZ, S, O,) and"},{"kind":"italic_en","text":"mixed,"},{"kind":"text","text":"perfume; (AZ, S, O, K;) and so ↓"},{"kind":"arabic","text_bw":"Eb~A^","text_ar":"عبّا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEobiy^apN","text_ar":"تَعْبِيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taEobiYo'N","text_ar":"تَعْبِىْءٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Eb~Y","text_ar":"عبّى"},{"kind":"text","text":". (TA.) [And accord. to an explanation of the inf. n. in the KL, it seems that"},{"kind":"arabic","text_bw":"EabaA^a","text_ar":"عَبَاَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He excited a good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasant, odour;"},{"kind":"text","text":"as rendered by Golius: but this I think doubtful.] ―         -b3-"},{"kind":"arabic","text_bw":"maA A^aEobaA^u bihi","text_ar":"مَا اَعْبَاُ بِهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"What shall I do with it?"},{"kind":"text","text":"(T, K, TA,) namely, the affair. (T, TA.)"},{"kind":"arabic","text_bw":"maA yaEobaA^u bikumo rab~iY","text_ar":"مَا يَعْبَاُ بِكُمْ رَبِّى"},{"kind":"text","text":", in the Kur [xxv. last verse], is said by Mujáhid to mean"},{"kind":"italic_en","text":"What will my Lord do with you?"},{"kind":"text","text":"but see another explanation of this in what follows. (TA.) ―         -b4-  And it signifies also"},{"kind":"italic_en","text":"I do not care for, mind, heed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard, him:"},{"kind":"text","text":"(S, O, Msb, K:) or"},{"kind":"italic_en","text":"I do not receive with approbation anything from him, nor anything of his discourse:"},{"kind":"text","text":"(Aboo-'Adnán, TA:) or, accord. to Aboo-Is-hák [i. e. Zj],"},{"kind":"italic_en","text":"I do not hold him to be of any weight or worth; do not esteem him:"},{"kind":"text","text":"and he says that"},{"kind":"arabic","text_bw":"maA yaEobaA^u bikumo rab~iY","text_ar":"مَا يَعْبَاُ بِكُمْ رَبِّى"},{"kind":"text","text":", of which an explanation has been given above, means"},{"kind":"italic_en","text":"What weight have ye in the estimation of my Lord?"},{"kind":"text","text":"(TA.) One says also,"},{"kind":"arabic","text_bw":"maA EabaA^otu bihi","text_ar":"مَا عَبَاْتُ بِهِ"},{"kind":"arabic","text_bw":"$ayoy^FA","text_ar":"شَيْيًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I did not reckon him as anything;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did not esteem him at all."},{"kind":"text","text":"(Aboo-'Abd-Er-Rahmán, TA.) And"},{"kind":"arabic","text_bw":"maA EabaA^otu lahu $ayoy^FA","text_ar":"مَا عَبَاْتُ لَهُ شَيْيًا"},{"kind":"italic_en","text":"I did not care for, mind, heed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard, him:"},{"kind":"text","text":"(T, TA:) or so"},{"kind":"arabic","text_bw":"maA EabaA^otu bihi","text_ar":"مَا عَبَاْتُ بِهِ"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"qado EabaA^a A@ll~`hu Eanohu","text_ar":"قَدْ عَبَاَ ا@للّٰهُ عَنْهُ"},{"kind":"italic_en","text":"God has received with approbation everything from him."},{"kind":"text","text":"(Aboo-'Adnán, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"EabaA^a lahu","text_ar":"عَبَاَ لَهُ"},{"kind":"italic_en","text":"He thought it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opined it, and held it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took to it as a tenet."},{"kind":"text","text":"(O, TA.)       -A2-"},{"kind":"arabic","text_bw":"EabaA^a wajohuhu","text_ar":"عَبَاَ وَجْهُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"His face shone:"},{"kind":"text","text":"(IAar, TA:) and so"},{"kind":"arabic","text_bw":"EabaA","text_ar":"عَبَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEobuw","text_ar":"يَعْبُو"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"Ebw","text_ar":"عبو"},{"kind":"text","text":".)"}],"source_refs":["TA","Msb","S","O","K","AZ","T","IAar"]},{"entry_id":"n27906","headword_ar":"عَبَا","root":"Ebw","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEobuw","text_ar":"يَعْبُو"},{"kind":"text","text":","},{"kind":"italic_en","text":"His face shone:"},{"kind":"text","text":"(K, TA:) [or so"},{"kind":"arabic","text_bw":"EabaA wajohuhu","text_ar":"عَبَا وَجْهُهُ"},{"kind":"text","text":"; for]"},{"kind":"arabic","text_bw":"EabaA^a wajohuhu","text_ar":"عَبَاَ وَجْهُهُ"},{"kind":"text","text":"signifies thus accord. to IAar: (TA in art."},{"kind":"arabic","text_bw":"EbA^","text_ar":"عبا"},{"kind":"text","text":":) app. from"},{"kind":"arabic","text_bw":"EabN","text_ar":"عَبٌ"},{"kind":"text","text":"signifying the “ light ” of the sun; this being originally"},{"kind":"arabic","text_bw":"EabowN","text_ar":"عَبْوٌ"},{"kind":"text","text":". (TA.)       -A2-  And"},{"kind":"arabic","text_bw":"EabowN AlmataAEi","text_ar":"عَبْوٌ المَتَاعِ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taEobiyatuhu","text_ar":"تَعْبِيَتُهُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) mentioned by ISd, and said by IKtt to be of the dial. of El-Yemen, (TA,) signifying"},{"kind":"italic_en","text":"The putting of the goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utensils, one upon another:"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"packing them up"},{"kind":"text","text":"in a repository: as also"},{"kind":"arabic","text_bw":"Eabow^uhu","text_ar":"عَبْوُهُ"},{"kind":"text","text":": see 1, in art."},{"kind":"arabic","text_bw":"EbA^","text_ar":"عبا"},{"kind":"text","text":":] IDrd says,"},{"kind":"arabic","text_bw":"Eabawotu AlmataAEa","text_ar":"عَبَوْتُ المَتَاعَ"},{"kind":"text","text":"is of the dial. of El-Yemen,"},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Eab~ayotuhu","text_ar":"عَبَّيْتُهُ","orth_type":"arrow"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"EbY","text_ar":"عبى"},{"kind":"text","text":".)"}],"source_refs":["K","TA"]},{"entry_id":"n27908","headword_ar":"عَبًا","root":"Ebw","body":[{"kind":"text","text":", applied to a man, [like"},{"kind":"arabic","text_bw":"EabaA='N","text_ar":"عَبَا=ءٌ"},{"kind":"text","text":"mentioned in art."},{"kind":"arabic","text_bw":"EbA^","text_ar":"عبا"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"Heavy, dull,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"impotent."},{"kind":"text","text":"(ISd, TA.) [But see this word in art."},{"kind":"arabic","text_bw":"EbY","text_ar":"عبى"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n27916","headword_ar":"عَبًا","root":"EbY","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EabaAyapN","text_ar":"عَبَايَةٌ","orth_type":"arrow"},{"kind":"text","text":", but the former the more chaste, are said to signify, as epithets applied to a man,"},{"kind":"italic_en","text":"Coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude, heavy, dull,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupid,"},{"kind":"text","text":"(K, * TA,) and"},{"kind":"italic_en","text":"impotent:"},{"kind":"text","text":"but this requires correction; for Lth mentions"},{"kind":"arabic","text_bw":"AlEabaA","text_ar":"العَبَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AlEabaA='u","text_ar":"العَبَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"as used by a poet, and says that they signify"},{"kind":"italic_en","text":"the coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude, impotent,"},{"kind":"text","text":"man; but Az says that he had not heard"},{"kind":"arabic","text_bw":"AlEabaA='","text_ar":"العَبَا=ء"},{"kind":"text","text":"in this sense on any authority other than that of Lth, and that he held the right reading in the verse cited as an ex. by Lth to be"},{"kind":"arabic","text_bw":"AlEayaA='","text_ar":"العَيَا=ء"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", meaning, as also"},{"kind":"arabic","text_bw":"AlEayaAyaA='","text_ar":"العَيَايَا=ء"},{"kind":"text","text":", “ the coarse, or rude, or the heavy, dull, or stupid, and impotent, who has no need of women. ” (TA.)"}],"source_refs":[]}]},"classical_definitions":null}