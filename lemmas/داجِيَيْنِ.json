:"italic_en","text":"desiring, to do so:"},{"kind":"text","text":"(S, K:) the"},{"kind":"italic_en","text":"treating hypocritically:"},{"kind":"text","text":"(Har ubi suprà:) the"},{"kind":"italic_en","text":"coaxing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wheedling, with comely behaviour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech, not rendering sincere brotherly affection;"},{"kind":"text","text":"or simply the"},{"kind":"italic_en","text":"treating with comely behaviour:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"putting"},{"kind":"text","text":"[one]"},{"kind":"italic_en","text":"off"},{"kind":"text","text":"[in the matter of a right, or due],"},{"kind":"italic_en","text":"as one does by repeated promises."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"daAjayotuhu","text_ar":"دَاجَيْتُهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I treated him with gentleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blandishment;"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"as though with concealment of enmity."},{"kind":"text","text":"(S.) ―         -b3-  Also The"},{"kind":"italic_en","text":"preventing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forbidding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refusing, in a manner between that of severity and that of laxness."},{"kind":"text","text":"(AA, S, K.)"}],"source_refs":["K","TA","S"]},{"entry_id":"n12176","headword_ar":"داجى","root":"djY","body":[{"kind":"text","text":", mentioned in this art. in the K: see art."},{"kind":"arabic","text_bw":"djw","text_ar":"دجو"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}