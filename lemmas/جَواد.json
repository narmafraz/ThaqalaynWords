{"lemma":"جَواد","slug":"جَواد","root":"ج.#.د","root_slug":"ج-_-د","root_link":"/words/roots/ج-_-د","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","name","noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n6655","n6656"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%88%D8%A7%D8%AF"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"goodness, generous, bountiful"},{"pos":"noun","gloss":"steed"},{"pos":"noun","gloss":"stallion"},{"pos":"name","gloss":"a male given name, Jawad"}]},"etymology":null,"ipa":["/d͡ʒa.waːd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6655","headword_ar":"جَوَادٌ","root":"jwd","body":[{"kind":"text","text":", used alike as masc. and fem., (S, K,)"},{"kind":"italic_en","text":"Liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous:"},{"kind":"text","text":"(S, * K:) or one"},{"kind":"italic_en","text":"who affects,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrains himself, to be generous:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"who gives without being asked, to preserve the receiver from the ignominy of asking:"},{"kind":"text","text":"(MF:) or"},{"kind":"italic_en","text":"who gives what is meet to him to whom it is meet:"},{"kind":"text","text":"(El-Karmánee, TA:) or"},{"kind":"italic_en","text":"who gives what is meet to him to whom it is meet, not for a compensation;"},{"kind":"text","text":"so that it has a more special signification than"},{"kind":"arabic","text_bw":"muHosinN","text_ar":"مُحْسِنٌ"},{"kind":"text","text":": (MF:) pl. [of pauc., masc.,]"},{"kind":"arabic","text_bw":"A^ajowaAdN","text_ar":"اَجْوَادٌ"},{"kind":"text","text":"and (of mult., TA)"},{"kind":"arabic","text_bw":"juwodN","text_ar":"جُوْدٌ"},{"kind":"text","text":", (S, A, K,) like as"},{"kind":"arabic","text_bw":"qu*ulN","text_ar":"قُذُلٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"qa*aAlN","text_ar":"قَذَالٌ"},{"kind":"text","text":", but the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is made quiescent because it is an unsound letter, (S,) [in some copies of the K"},{"kind":"arabic","text_bw":"juwudN","text_ar":"جُوُدٌ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"A^ajaAwidu","text_ar":"اَجَاوِدُ"},{"kind":"text","text":", (S, K,) contr. to analogy, (TA,) or"},{"kind":"arabic","text_bw":"A^ajaAwiydu","text_ar":"اَجَاوِيدُ"},{"kind":"text","text":", [reg., as pl. of"},{"kind":"arabic","text_bw":"A^ajowaAdN","text_ar":"اَجْوَادٌ"},{"kind":"text","text":",] (A,) and"},{"kind":"arabic","text_bw":"juwadaA='u","text_ar":"جُوَدَا=ءُ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"juwadapN","text_ar":"جُوَدَةٌ"},{"kind":"text","text":", (CK, [in some copies of the K omitted,]) or"},{"kind":"arabic","text_bw":"juwodapN","text_ar":"جُوْدَةٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"juwudapN","text_ar":"جُوُدَةٌ"},{"kind":"text","text":", [written in the latter manner in a MS. copy of the K,] with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"added to the [proper] pl. form ["},{"kind":"arabic","text_bw":"juwodN","text_ar":"جُوْدٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"juwudN","text_ar":"جُوُدٌ"},{"kind":"text","text":"], accord. to the doctrine of Sb: (TA:)"},{"kind":"arabic","text_bw":"juwodN","text_ar":"جُوْدٌ"},{"kind":"text","text":"is used as a fem. pl., (S, Msb,) and is like"},{"kind":"arabic","text_bw":"nuworN","text_ar":"نُوْرٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"nawaArN","text_ar":"نَوَارٌ"},{"kind":"text","text":". (S.) ―         -b2-  Also, applied alike to the male and the female, (S,)"},{"kind":"italic_en","text":"A courser; a fleet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, and excellent,"},{"kind":"text","text":"horse; (L;) a horse"},{"kind":"italic_en","text":"fleet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, in running;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent in running,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the motion of his legs;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ","orth_type":"arrow"},{"kind":"text","text":": (Bd in xxxviii. 30:) or"},{"kind":"italic_en","text":"that outstrips others:"},{"kind":"text","text":"(Jel ib.:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"raAy^iEN","text_ar":"رَايِعٌ"},{"kind":"text","text":": (S, L, K:) pl."},{"kind":"arabic","text_bw":"jiyaAdN","text_ar":"جِيَادٌ"},{"kind":"text","text":", (S, A, Bd, L, Msb, K,) which by rule should be"},{"kind":"arabic","text_bw":"jiwaAdN","text_ar":"جِوَادٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"TiwaAlN","text_ar":"طِوَالٌ"},{"kind":"text","text":", but this latter form has not been heard from the Arabs; (L;) or"},{"kind":"arabic","text_bw":"jiyaAdN","text_ar":"جِيَادٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":", or of"},{"kind":"arabic","text_bw":"jay~idN","text_ar":"جَيِّدٌ"},{"kind":"text","text":"; (Bd ubi suprá;) and"},{"kind":"arabic","text_bw":"jawaAdN","text_ar":"جَوَادٌ"},{"kind":"text","text":"has also for its pl."},{"kind":"arabic","text_bw":"A^ajoyaAdN","text_ar":"اَجْيَادٌ"},{"kind":"text","text":", [a pl. of pauc., and irregular, or this is pl. of"},{"kind":"arabic","text_bw":"jay~dN","text_ar":"جَيّدٌ"},{"kind":"text","text":", and therefore, though irregularly, retains the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"substituted for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"] (S, L,) and"},{"kind":"arabic","text_bw":"A^ajowaAdN","text_ar":"اَجْوَادٌ"},{"kind":"text","text":", [also a pl. of pauc., but agreeable with rule, or this is pl. of"},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":",] (L,) and"},{"kind":"arabic","text_bw":"A^ajaAwiydu","text_ar":"اَجَاوِيدُ"},{"kind":"text","text":"(S, L) is pl. of"},{"kind":"arabic","text_bw":"A^ajowaAdN","text_ar":"اَجْوَادٌ"},{"kind":"text","text":". (L.) Hence,"},{"kind":"arabic","text_bw":"A^aqobala jawaAdFA","text_ar":"اَقْبَلَ جَوَادًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He came on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced, like a horse that is termed"},{"kind":"arabic","text_bw":"jwAd","text_ar":"جواد"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"sirotu A_ilayohi jawaAdFA","text_ar":"سِرْتُ اـِلَيْهِ جَوَادًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I went to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, like a horse that is so termed."},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"g*","text_ar":"غذ"},{"kind":"text","text":".) You say also,"},{"kind":"arabic","text_bw":"EadaA EadowFA jawaAdFA","text_ar":"عَدَا عَدْوًا جَوَادًا"},{"kind":"italic_en","text":"He ran a long run."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"sironaA EuqobapF","text_ar":"سِرْنَا عُقْبَةً"},{"kind":"arabic","text_bw":"jawaAdFA","text_ar":"جَوَادًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Euqobatayoni jawaAdayoni","text_ar":"عُقْبَتَيْنِ جَوَادَيْنِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EuqabFA jiyaAdFA","text_ar":"عُقَبًا جِيَادًا"},{"kind":"text","text":"(S, A) and"},{"kind":"arabic","text_bw":"A^ajowaAdFA","text_ar":"اَجْوَادًا"},{"kind":"text","text":", (A, TA,)"},{"kind":"italic_en","text":"We journeyed a long march"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stage,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"two long marches"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stages,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"long marches"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stages."},{"kind":"text","text":"(S, A, TA.)"}],"source_refs":["S","K","Msb","MF","A","TA","L","Bd"]},{"entry_id":"n6656","headword_ar":"جُوَادٌ","root":"jwd","body":[{"kind":"text","text":"[accord. to the TA inf. n. of"},{"kind":"arabic","text_bw":"jiyda","text_ar":"جِيدَ"},{"kind":"text","text":", which see in two places,] (assumed tropical:)"},{"kind":"italic_en","text":"Thirst:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"vehemence of thirst."},{"kind":"text","text":"(K.) ―         -b2-  Also, [accord. to the K ↓"},{"kind":"arabic","text_bw":"jawodapN","text_ar":"جَوْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", but this is corrected in the TA,] (assumed tropical:)"},{"kind":"italic_en","text":"Drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slumber."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}