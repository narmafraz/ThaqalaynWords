tions":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to beam, to shine","tags":["intransitive"],"examples":[{"text":"اِعْلَمْ اِعْمَلْ وَٱلْمَعْ","english":"study (have knowledge), perform [it], and shine!"}]},{"pos":"verb","gloss":"to beckon, to gesture"},{"pos":"verb","gloss":"to make shiny or shinier"},{"pos":"verb","gloss":"to colorize colorfully, to make colorful"}]},"etymology":null,"ipa":["/la.ma.ʕa/","/lam.ma.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43400","headword_ar":"لَمَعَ","root":"lmE","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(lightning, &c.)"},{"kind":"italic_en","text":"shone; shone brightly; gleamed; glistened."},{"kind":"text","text":"(S, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"lamaEa biyadihi","text_ar":"لَمَعَ بِيَدِهِ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"bivawobihi","text_ar":"بِثَوْبِهِ"},{"kind":"text","text":", (TA, S, K, &c., in art."},{"kind":"arabic","text_bw":"xfq","text_ar":"خفق"},{"kind":"text","text":"&c.,) and"},{"kind":"arabic","text_bw":"bisayofihi","text_ar":"بِسَيْفِهِ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He signalled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a sign, with his hand"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arm,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"with his garment,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"with his sword;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did so for the purpose of information"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warning; by raising it, and moving it about,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"waving it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brandishing it,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"he waved it as a sign"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"signal,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in order that another might see it, and come to him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^alomaEa","text_ar":"اَلْمَعَ","orth_type":"arrow"},{"kind":"text","text":"; but the former is the more approved; ["},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"Lat."},{"kind":"italic_en","text":"micuit;"},{"kind":"text","text":"] and sometimes the verb is used without the mention of the hand or arm [&c.]. (TA.) See a verse cited voce"},{"kind":"arabic","text_bw":"faroDN","text_ar":"فَرْضٌ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"lamaEa bisayofihi","text_ar":"لَمَعَ بِسَيْفِهِ"},{"kind":"text","text":", (S, and K, art."},{"kind":"arabic","text_bw":"lwH","text_ar":"لوح"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"bivawobihi","text_ar":"بِثَوْبِهِ"},{"kind":"text","text":", (S, ibid, and S, K, &c., in art."},{"kind":"arabic","text_bw":"xfq","text_ar":"خفق"},{"kind":"text","text":".)"},{"kind":"italic_en","text":"He made a sign with his sword,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"with his garment,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"waving it about, to make it seen by some one whom he desired to see it"},{"kind":"text","text":"]. (S, K.)"}],"source_refs":["K","TA"]}]}}