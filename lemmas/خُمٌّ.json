{"lemma":"خُمٌّ","slug":"خُمٌّ","root":"خ.م.م","root_slug":"خ-م-م","root_link":"/words/roots/خ-م-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n11449"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D9%85%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become stinking, to get rotten, to acquire a foul smell"},{"pos":"noun","gloss":"verbal noun of خَمَّ (ḵamma) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to sweep, to scoop"},{"pos":"noun","gloss":"verbal noun of خَمَّ (ḵamma) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"coop for domestic birds to be fattened, pen for poultry, brooding cage, henhouse, pigeon’s home and the like"}]},"etymology":{"source":"wiktextract","text":"See ق م م (q m m) with this meaning.\n\nFrom Persian خم (xom)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11449","headword_ar":"خُمٌّ","root":"xm","body":[{"kind":"italic_en","text":"A cage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coop, for domestic fowls:"},{"kind":"text","text":"(ISd, K:) [and so, in modern Arabic,"},{"kind":"arabic","text_bw":"xun~N","text_ar":"خُنٌّ"},{"kind":"text","text":":] thought by ISd to be so called because of its foul smell. (TA.) ―         -b2-"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"receptacle made of matting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of reeds, such as is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qawoSar~ap","text_ar":"قَوْصَرَّة"},{"kind":"text","text":","},{"kind":"italic_en","text":"in which straw is put, for the domestic hen to lay her eggs therein,"},{"kind":"text","text":"(K,) or"},{"kin