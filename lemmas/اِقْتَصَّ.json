resent_1ms","form":"أَقْتَصّ","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":36,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n35695"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%82%D9%92%D8%AA%D9%8E%D8%B5%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to punish, repay"},{"pos":"verb","gloss":"to narrate"}]},"etymology":null,"ipa":["/aq.tasˤ.sˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35695","headword_ar":"اقتصّ","root":"qS","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(hair [or the like])"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clipped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shorn,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"miqaS~","text_ar":"مِقَصّ"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"tqS~S","text_ar":"تقصّص","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taqaS~aY","text_ar":"تَقَصَّى"},{"kind":"text","text":". (M, TA.)       -A2-"},{"kind":"arabic","text_bw":"AqtS~ A^avarahu","text_ar":"اقتصّ اَثَرَهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaS~a Avrh","text_ar":"قَصَّ اثره"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"AqtS~ AlHadiyva","text_ar":"اقتصّ الحَدِيثَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaS~a Ealayohi Alxabara","text_ar":"قَصَّ عَلَيْهِ الخَبَرَ"},{"kind":"text","text":".       -A3-"},{"kind":"italic_en","text":"He retaliated, slaying for slaying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wounding for wounding."},{"kind":"text","text":"(M.) You say,"},{"kind":"arabic","text_bw":"AqtS~ lifulaAnK mino fulaAnK","text_ar":"اقتصّ لِفُلَانٍ مِنْ فُلَانٍ"},{"kind":"text","text":"(S, A, K)"},{"kind":"italic_en","text":"He retaliated for such a one upon such a one, by wounding the latter like as he had wounded the former,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by slaying the latter for the slaughter of the former,"},{"kind":"text","text":"(S, K, TA,) and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(TA;) as also"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aqaS~ahu","text_ar":"اَقَصَّهُ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) [See the latter verb, first signification.] And ↓"},{"kind":"arabic","text_bw":"A^afaS~ahu","text_ar":"اَفَصَّهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iqoSaASN","text_ar":"اـِقْصَاصٌ"},{"kind":"text","text":", signifies [also]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the Sultán)"},{"kind":"italic_en","text":"slew him in retaliation."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"AiqotiSaASN","text_ar":"اِقْتِصَاصٌ"},{"kind":"text","text":", as a subst., [i. e., having no verb corresponding to the signification here following, though I do not see how this can be asserted, for one may certainly say"},{"kind":"arabic","text_bw":"AuqotuS~a minohu","text_ar":"اُقْتُصَّ مِنْهُ"},{"kind":"text","text":",] also signifies The"},{"kind":"italic_en","text":"being done to like as one has done, whether it be slaughter or mutilation or beating or wounding."},{"kind":"text","text":"(TA.) ―         -b3-  See also 10."}],"source_refs":["M","TA","S","A","K"]}]},"classical_definitions":null}