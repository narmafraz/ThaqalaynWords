"per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهْدَآ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهْدَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدَأُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهْدَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْدَأْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَهْدَأ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهْدَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"هَدَأْنا","in_corpus":true,"count":17,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَدَأْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n40978","n40982"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%AF%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be quiet, to quiet down, to pipe down","tags":["intransitive"]},{"pos":"verb","gloss":"to calm down, to settle down, to cool down, to abate, to cool off, to ease up","tags":["intransitive"]},{"pos":"verb","gloss":"to die down","tags":["intransitive"]},{"pos":"verb","gloss":"to temper, quiet, calm, cool, placate, quieten down, settle, soothe"}]},"etymology":null,"ipa":["/ha.da.ʔa/","/had.da.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40978","headword_ar":"هَدَاَ","root":"hdA^","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hado'N","text_ar":"هَدْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"huduwo'N","text_ar":"هُدُوْءٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"still, calm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unruffled;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"was motionless; was silent:"},{"kind":"text","text":"(TA:) [and so, app., ↓"},{"kind":"arabic","text_bw":"AhdA^","text_ar":"اهدا","orth_type":"arrow"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"muhodiy^N","text_ar":"مُهْدِيٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"tahodaY","text_ar":"تَهْدَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"haAdK","text_ar":"هَادٍ"},{"kind":"text","text":"occur for"},{"kind":"arabic","text_bw":"tahodaA^u","text_ar":"تَهْدَاُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"haAdiy^K","text_ar":"هَادِيٍ"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"hadaA^a Eanohu","text_ar":"هَدَاَ عَنْهُ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[pain or the like]"},{"kind":"italic_en","text":"became appeased, and quitted him."},{"kind":"text","text":"(TA.) ―         -b4-  See 4. ―         -b5-"},{"kind":"arabic","text_bw":"A^ataAnaA waqado hadaA^ati Alr~ijolu","text_ar":"اَتَانَا وَقَدْ هَدَاَتِ الرِّجْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He came to us when the foot"},{"kind":"text","text":"("},{"kind":"italic_en","text":"of the passenger by night"},{"kind":"text","text":")"},{"kind":"italic_en","text":"had become still."},{"kind":"text","text":"(S.) ―         -b6-"},{"kind":"arabic","text_bw":"AtAnA baEoda maA hadaA^ati Alr~ijolu","text_ar":"اتانا بَعْدَ مَا هَدَاَتِ الرِّجْلُ"},{"kind":"arabic","text_bw":"wAlEayonu","text_ar":"والعَيْنُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He came to us after the foot"},{"kind":"text","text":"("},{"kind":"italic_en","text":"of the passenger by night"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and the eye, were at rest."},{"kind":"text","text":"(S, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"hadaA^a biAlmakaAni","text_ar":"هَدَاَ بِالمَكَانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, in the place."},{"kind":"text","text":"(K.) ―         -b8-"},{"kind":"arabic","text_bw":"hadaA^a","text_ar":"هَدَاَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"huduwo'N","text_ar":"هُدُوْءٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"He died."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"hadiy^a","text_ar":"هَدِيَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"hadaA^N","text_ar":"هَدَاٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"janiy^a","text_ar":"جَنِيَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He had a curving back, &c.:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he had depressed and even shoulders, inclining towards the breast; not erect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated:"},{"kind":"text","text":"(Lth, and others:) or"},{"kind":"italic_en","text":"he was humpbacked."},{"kind":"text","text":"(S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"hadiy^a","text_ar":"هَدِيَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a camel's hump)"},{"kind":"italic_en","text":"was bent by much lading,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and had its soft hair"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"wabar","text_ar":"وَبَر"},{"kind":"text","text":")"},{"kind":"italic_en","text":"sticking upon it, without its being wounded."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","K"]},{"entry_id":"n40982","headword_ar":"هَدَاٌ","root":"hdA^","body":[{"kind":"italic_en","text":"Smallness of a camel's hump, occasioned by his being much laden."},{"kind":"text","text":"(K.) It is less than what is termed"},{"kind":"arabic","text_bw":"Hnb","text_ar":"حنب"},{"kind":"text","text":"[a word app. incorrectly written, but which I am unable to correct]. (TA.)"}],"source_refs":[]}]}}