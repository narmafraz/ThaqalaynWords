{"lemma":"مُجَسَّدِي","slug":"مُجَسَّدِي","root":"ج.س.د","root_slug":"ج-س-د","root_link":"/words/roots/ج-س-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n5791","n5792","n5793"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AC%D9%8E%D8%B3%D9%8E%D9%91%D8%AF%D9%90%D9%8A"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5791","headword_ar":"مُجْسَدٌ","root":"jsd","body":[{"kind":"italic_en","text":"Red."},{"kind":"text","text":"(S.) ―         -b2-  Also, (S, Msb, K,) and sometimes ↓"},{"kind":"arabic","text_bw":"mijosadN","text_ar":"مِجْسَدٌ","orth_type":"arrow"},{"kind":"text","text":", (IF, Msb,) and ↓"},{"kind":"arabic","text_bw":"mujas~adN","text_ar":"مُجَسَّدٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) A garment"},{"kind":"italic_en","text":"dyed with saffron:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"with bastard saffron:"},{"kind":"text","text":"(IAth, TA:)"},{"kind":"italic_en","text":"dyed with"},{"kind":"arabic","text_bw":"jisaAd","text_ar":"جِسَاد"},{"kind":"text","text":": (IF, Msb:) or"},{"kind":"italic_en","text":"saturated with dye:"},{"kind":"text","text":"(S:) or one says,"},{"kind":"arabic","text_bw":"EalaY fulaAnK vawobN mu$obaEN mina AlSibogi","text_ar":"عَلَى فُلَانٍ ثَوْبٌ مُشْبَعٌ مِنَ الصِبْغِ"},{"kind":"text","text":"[Upon such a one is a garment saturated with dye]; and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"arabic","text_bw":"vawobN mufodamN","text_ar":"ثَوْبٌ مُفْدَمٌ"},{"kind":"text","text":"[Upon him is a garment saturated with red dye]; and when it is"},{"kind":"italic_en","text":"standing up by reason of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the thickness of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the dye,"},{"kind":"text","text":"it is termed"},{"kind":"arabic","text_bw":"mujosadN","text_ar":"مُجْسَدٌ"},{"kind":"text","text":": (ISK, S:) the pl. of this word is"},{"kind":"arabic","text_bw":"majaAsidu","text_ar":"مَجَاسِدُ"},{"kind":"text","text":". (S.) ―         -b3-  See also what next follows: ―         -b4-  and see"},{"kind":"arabic","text_bw":"jasadN","text_ar":"جَسَدٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K","IF","IAth","TA","ISK"]},{"entry_id":"n5792","headword_ar":"مِجْسَدٌ","root":"jsd","body":[{"kind":"text","text":", (S, A, K,) or ↓"},{"kind":"arabic","text_bw":"mujosadN","text_ar":"مُجْسَدٌ","orth_type":"arrow"},{"kind":"text","text":", (A,) the latter is the original form, because it is from"},{"kind":"arabic","text_bw":"A^ujosida","text_ar":"اُجْسِدَ"},{"kind":"text","text":", meaning, \"it was made to stick, or adhere, to the body,” (Fr, S,) like"},{"kind":"arabic","text_bw":"miTorafN","text_ar":"مِطْرَفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muTorafN","text_ar":"مُطْرَفٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"miSoHafN","text_ar":"مِصْحَفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muSoHafN","text_ar":"مُصْحَفٌ"},{"kind":"text","text":", (Fr, TA,)"},{"kind":"italic_en","text":"A garment worn next the body"},{"kind":"text","text":"(IAar, S, A, K)"},{"kind":"italic_en","text":"by a woman, so that she sweats in it:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"a garment worn next the body dyed with saffron:"},{"kind":"text","text":"(A:) pl."},{"kind":"arabic","text_bw":"majaAsidu","text_ar":"مَجَاسِدُ"},{"kind":"text","text":". (IAar, A.) [Hence,]"},{"kind":"arabic","text_bw":"laA yaxorujan~a A_ilaY AlmasaAjidi fiY","text_ar":"لَا يَخْرُجَنَّ اـِلَى المَسَاجِدِ فِى"},{"kind":"arabic","text_bw":"AlmajaAsidi","text_ar":"المَجَاسِدِ"},{"kind":"text","text":"(IAar, A)"},{"kind":"italic_en","text":"They"},{"kind":"text","text":"(women)"},{"kind":"italic_en","text":"shall by no means go forth to the mosques in the shirts that are next the body."},{"kind":"text","text":"(IAar.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"mujosadN","text_ar":"مُجْسَدٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","K","Fr","TA","IAar"]},{"entry_id":"n5793","headword_ar":"مُجَسَّدٌ","root":"jsd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"mujosadN","text_ar":"مُجْسَدٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}