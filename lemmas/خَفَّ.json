form":"تَخِفُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخِفُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْفِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخِفّ","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخْفِف","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخِفّ","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخْفِف","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخِفّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخِفّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخِفّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخِفّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخِفُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخِفُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْفِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخِفّ","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخِفّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَفَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَفَفْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":123,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n11071"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%81%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be lightweight","examples":[{"text":"فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ ۝ فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ ۝ وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ ۝ فَأُمُّهُ هَاوِيَةٌ ۝ وَمَا أَدْرَاكَ مَا هِيَهْ ۝ نَارٌ حَامِيَةٌ"}]},{"pos":"verb","gloss":"to become lighter in weight, to lose weight"},{"pos":"verb","gloss":"to decrease, to abate, to lessen","tags":["intransitive"],"examples":[{"text":"خَفَّ الْمَطَرُ","english":"the rain abated"}]},{"pos":"verb","gloss":"to depart, go away"},{"pos":"verb","gloss":"to be less vivid, to be bleached"},{"pos":"noun","gloss":"the hoof of a camel","tags":["dated"]},{"pos":"noun","gloss":"boot","tags":["figuratively"],"examples":[{"text":"بَيْنَمَا رَجُلٌ يَمْشِي بِطَرِيقٍ ٱشْتَدَّ عَلَيْهِ الْعَطَشُ، فَوَجَدَ بِئْرًا فَنَزَلَ فِيهَا فَشَرِبَ ثُمَّ خَرَجَ، فَإِذَا كَلْبٌ يَلْهَثُ، يَأْكُلُ الثَّرَى مِنَ الْعَطَشِ، فَقَالَ الرَّجُلُ: لَقَدْ بَلَغَ هَذَا الْكَلْبَ مِنَ الْعَطَشِ مِثْلُ الَّذِي كَانَ بَلَغَ مِنِّي، فَنَزَلَ الْبِئْرَ فَمَلَأَ خُفَّهُ مَاءً ثُمَّ أَمْسَكَهُ بِفِيهِ حَتَّى رَقِيَ فَسَقَى الْكَلْبَ فَشَكَرَ اللَّهُ لَهُ فَغَفَرَ لَهُ"}]}]},"etymology":null,"ipa":["/xaf.fa/","/xuff/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11071","headword_ar":"خَفَّ","root":"xf","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xif~apN","text_ar":"خِفَّةٌ"},{"kind":"text","text":"(JK, S, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"xaf~N","text_ar":"خَفٌّ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"xaf~apN","text_ar":"خَفَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taxaw~ufN","text_ar":"تَخَوُّفٌ"},{"kind":"text","text":", but this last belongs to art."},{"kind":"arabic","text_bw":"xwf","text_ar":"خوف"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"vaqula","text_ar":"ثَقُلَ"},{"kind":"text","text":"[both properly and tropically]; (Msb;) properly, (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xafiyf","text_ar":"خَفِيف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"light"},{"kind":"text","text":"] (JK, S, Msb, K, TA)"},{"kind":"italic_en","text":"of weight,"},{"kind":"text","text":"(JK,)"},{"kind":"italic_en","text":"in body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"material substance."},{"kind":"text","text":"(TA.) Hence the saying of 'Atà, in a trad.,"},{"kind":"arabic","text_bw":"xif~uwA EalaY AlA^aroDi","text_ar":"خِفُّوا عَلَى الاَرْضِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Be ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bear ye, lightly upon the ground"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in prostration:"},{"kind":"text","text":"(A'Obeyd, TA:) or, as some relate it, ↓"},{"kind":"arabic","text_bw":"xaf~ifuwA","text_ar":"خَفِّفُوا","orth_type":"arrow"},{"kind":"text","text":": i. e."},{"kind":"italic_en","text":"prostrate yourselves"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lightly upon the ground;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not heavily, so as to make marks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impressions, upon your foreheads:"},{"kind":"text","text":"and in another trad. it is said, ↓"},{"kind":"arabic","text_bw":"A_i*aA sajadota fataxaAf~a","text_ar":"اـِذَا سَجَدْتَ فَتَخَافَّ","orth_type":"arrow"},{"kind":"italic_en","text":"When thou prostratest thyself, put thy forehead upon the ground lightly:"},{"kind":"text","text":"but A 'Obeyd says that some say"},{"kind":"arabic","text_bw":"fatujaAfi","text_ar":"فَتُجَافِ"},{"kind":"text","text":", [i. e."},{"kind":"arabic","text_bw":"fatujaAfi EaDudayoka Eano janobayoka","text_ar":"فَتُجَافِ عَضُدَيْكَ عَنْ جَنْبَيْكَ"},{"kind":"text","text":",] with"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":". (TA [See 3 in art."},{"kind":"arabic","text_bw":"jfw","text_ar":"جفو"},{"kind":"text","text":".]) [Hence also,]"},{"kind":"arabic","text_bw":"xaf~a AlmiyzaAnu","text_ar":"خَفَّ المِيزَانُ"},{"kind":"italic_en","text":"The balance had one of its two scales light, so that it rose."},{"kind":"text","text":"(TA.) ―         -b2-  [Used tropically, it means (assumed tropical:)"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light in estimation, lightly esteemed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of little account."},{"kind":"text","text":"] ―         -b3-  And (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xafiyf","text_ar":"خَفِيف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"light"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"active, agile,"},{"kind":"text","text":"&c.,] in work: (TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively, sprightly, active, agile, prompt,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"quick;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"na$iTa","text_ar":"نَشِطَ"},{"kind":"text","text":". (Msb and TA in art."},{"kind":"arabic","text_bw":"n$T","text_ar":"نشط"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"xaf~a fiY Eamalihi waxidomatihi","text_ar":"خَفَّ فِى عَمَلِهِ وَخِدْمَتِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"brisk,"},{"kind":"text","text":"&c., or]"},{"kind":"italic_en","text":"obedient and submissive, in his work and his service:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"xaf~a lahu fiY Alxidomapi","text_ar":"خَفَّ لَهُ فِى الخِدْمَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him in service"},{"kind":"text","text":"], aor."},{"kind":"arabic","text_bw":"yaxif~u","text_ar":"يَخِفُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xif~apN","text_ar":"خِفَّةٌ"},{"kind":"text","text":": (S:) and in like manner,"},{"kind":"arabic","text_bw":"xaf~a lifulaAnK","text_ar":"خَفَّ لِفُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"promptly"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"obedient and submissive, to such a one."},{"kind":"text","text":"(TA.) [Hence,]"},{"kind":"arabic","text_bw":"xafafotu A_ilaY fulaAnK","text_ar":"خَفَفْتُ اـِلَى فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly, in behaviour to such a one"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"h$","text_ar":"هش"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"xaf~ati AlA^unovaY lilofaHoli","text_ar":"خَفَّتِ الاُنْثَى لِلْفَحْلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The female was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, submissive to the male."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"xaf~ati","text_ar":"خَفَّتِ"},{"kind":"arabic","text_bw":"AlA^utunu liEayorihaA","text_ar":"الاُتُنُ لِعَيْرِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The she-asses obeyed their he-ass."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"xuf~a A_ilaY AlEaduw~i","text_ar":"خُفَّ اـِلَى العَدُوِّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xufuwfN","text_ar":"خُفُوفٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He hastened to the enemy."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xaf~a","text_ar":"خَفَّ"},{"kind":"arabic","text_bw":"Alqawomu Eano waTanihimo","text_ar":"القَوْمُ عَنْ وَطَنِهِمْ"},{"kind":"text","text":", (K, * TA,) inf. n."},{"kind":"arabic","text_bw":"xufuwfN","text_ar":"خُفُوفٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, quickly from their home:"},{"kind":"text","text":"or, as some say, simply"},{"kind":"italic_en","text":"removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, from it."},{"kind":"text","text":"(TA.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"xafiyf","text_ar":"خَفِيف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"] in intellect, or understanding: (TA:) [and in conduct, or behaviour: generally meaning] (assumed tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light, inconstant, unsteady, irresolute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fickle;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light of intellect; lightwitted;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TaA$a","text_ar":"طَاشَ"},{"kind":"text","text":": (Msb:) the inf. n. of the verb in this sense is"},{"kind":"arabic","text_bw":"xif~apN","text_ar":"خِفَّةٌ"},{"kind":"text","text":". (Msb and K &c. in art."},{"kind":"arabic","text_bw":"Ty$","text_ar":"طيش"},{"kind":"text","text":", and TA in the present art.) [But sometimes, when relating to the intellect, or understanding, it means, (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quick, acute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharp;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"clever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ingenious:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"xafiyfN","text_ar":"خَفِيفٌ"},{"kind":"text","text":".] And you say of him whose hearing is good,"},{"kind":"arabic","text_bw":"fiY A^u*unihi xif~apN","text_ar":"فِى اُذُنِهِ خِفَّةٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"In his ear is quickness, acuteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpness, of hearing"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"vql","text_ar":"ثقل"},{"kind":"text","text":".) ―         -b5-  [(assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, flurried, agitated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited,"},{"kind":"text","text":"by reason of fear, and by anger, or the like: see 10. ―         -b6-  (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lighthearted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful; one whose company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"converse, was acceptable and cheering."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"xaf~a fulaAnN EalaY Almaliki","text_ar":"خَفَّ فُلَانٌ عَلَى المَلِكِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, acceptable and cheering to the king."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"page_break","n":770},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an action, or an affair, and a case, or the like,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it become alleviated."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"xaf~ato Ealayohi AlHarakapu","text_ar":"خَفَّتْ عَلَيْهِ الحَرَكَةُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moving, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy to him"},{"kind":"text","text":"]; opposed to"},{"kind":"arabic","text_bw":"vaqulato","text_ar":"ثَقُلَتْ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xaf~ato HaAluhu","text_ar":"خَفَّتْ حَالُهُ"},{"kind":"text","text":": see 4. ―         -b8-  [(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a word)"},{"kind":"italic_en","text":"was light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy, of utterance:"},{"kind":"text","text":"and in like manner said of a sound, (assumed tropical:)"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light to the ear;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slight."},{"kind":"text","text":"―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(food)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light to the stomach; easy of digestion."},{"kind":"text","text":"―         -b10-  Said of the hair of the head, and of the beard, (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light, thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty."},{"kind":"text","text":"] ―         -b11-  Said of a people, or company of men, ("},{"kind":"arabic","text_bw":"qawomN","text_ar":"قَوْمٌ"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"xufuwfN","text_ar":"خُفُوفٌ"},{"kind":"text","text":", it means"},{"kind":"arabic","text_bw":"qal~uwA waqado xaf~ato zaHomatuhumo","text_ar":"قَلُّوا وَقَدْ خَفَّتْ زَحْمَتُهُمْ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"They became few in number, their crowding having diminished"},{"kind":"text","text":"]. (S.) ―         -b12-  Said of rain, [&c.,] (assumed tropical:)"},{"kind":"italic_en","text":"It diminished; decreased;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"deficient."},{"kind":"text","text":"(TA.) ―         -b13-  [Said of a blow, a disease, an affection of the mind, &c.,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light, slight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable."},{"kind":"text","text":"] ―         -b14-"},{"kind":"arabic","text_bw":"xaf~ato manaAziluhumo minohumo wamaDawoA","text_ar":"خَفَّتْ مَنَازِلُهُمْ مِنْهُمْ وَمَضَوْا"},{"kind":"text","text":"(assumed tropical:)  [means"},{"kind":"italic_en","text":"Their abodes became clear of them, and they went away"},{"kind":"text","text":"]. (K * and TA in art."},{"kind":"arabic","text_bw":"$wl","text_ar":"شول"},{"kind":"text","text":".)"}],"source_refs":["Msb","K","TA","JK","S"]}]}}