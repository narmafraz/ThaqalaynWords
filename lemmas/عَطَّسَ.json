":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَطِّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَطِّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَطِّس","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَطِّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَطِّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَطِّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَطِّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَطِّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَطِّسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَطِّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَطِّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"عَطَّسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَطَّسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعَطِّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَطِّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29549"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B7%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sneeze"},{"pos":"noun","gloss":"verbal noun of عَطَسَ (ʕaṭasa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Probably onomatopoeic; compare the noun عَطْسة (ʕaṭsa) with German hatzi, English achoo, and similar forms in many languages of the world."},"ipa":["/ʕa.tˤa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29549","headword_ar":"عَطَسَ","root":"ETs","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"text","text":", (S, O, Msb, K,) the former of which is the more approved, and therefore it alone is mentioned in some copies [of the K], (TA,) inf. n."},{"kind":"arabic","text_bw":"EaTosN","text_ar":"عَطْسٌ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"EuTaAsN","text_ar":"عُطَاسٌ"},{"kind":"text","text":", (S, * A,) or both, (O, K,) or the latter is a simple subst., (TA,)"},{"kind":"italic_en","text":"He sneezed;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"A^atatohu AlEaTosapu","text_ar":"اَتَتْهُ العَطْسَةُ"},{"kind":"text","text":": (A, K:) [properly] said only of a man. (MF, from the “ Iktiráh. ”) It is said in a trad.,"},{"kind":"arabic","text_bw":"kaAna yuHib~u AlEuTaAsa wayakorahu Alt~avaAw^uba","text_ar":"كَانَ يُحِبُّ العُطَاسَ وَيَكْرَهُ التَّثَاوُبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(Mohammad)"},{"kind":"italic_en","text":"used to like sneezing, and dislike yawning"},{"kind":"text","text":"]: (O, TA:) because the former is accompanied by lightness of the body, and openness of the pores, and facilitation of movements; whereas, in yawning, the contrary is the case; and these properties are caused by taking light nourishment and little food and drink: (TA:) but the Arabs used to augur evil from sneezing; (A, O;) so that if a man were journeying and heard a sneeze, it prevented him from going on. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"EaTasa AlS~uboHu","text_ar":"عَطَسَ الصُّبْحُ"},{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"EaTosN","text_ar":"عَطْسٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The dawn broke:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"shone forth."},{"kind":"text","text":"(A, Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"EaTasato bihi All~ujamu","text_ar":"عَطَسَتْ بِهِ اللُّجَمُ"},{"kind":"text","text":", (A, O, K,) and"},{"kind":"arabic","text_bw":"All~ujumu","text_ar":"اللُّجُمُ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"Evil omens brought ill luck upon him:"},{"kind":"text","text":"(A, O: *)"},{"kind":"arabic","text_bw":"lujamN","text_ar":"لُجَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lujumN","text_ar":"لُجُمٌ"},{"kind":"text","text":"are pls. of"},{"kind":"arabic","text_bw":"lujomapN","text_ar":"لُجْمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lijaAmN","text_ar":"لِجَامٌ"},{"kind":"text","text":", which are syn. with"},{"kind":"arabic","text_bw":"TiyarapN","text_ar":"طِيَرَةٌ"},{"kind":"text","text":", because the"},{"kind":"arabic","text_bw":"Tyrp","text_ar":"طيرة"},{"kind":"text","text":"refrains one from a thing that he wants: for they used to augur evil from sneezing [as remarked above]: (A:) or"},{"kind":"italic_en","text":"he died;"},{"kind":"text","text":"(A, O, K;) as also"},{"kind":"arabic","text_bw":"EaTasa","text_ar":"عَطَسَ"},{"kind":"text","text":", alone. (K.) [See also"},{"kind":"arabic","text_bw":"gaTasa","text_ar":"غَطَسَ"},{"kind":"text","text":".]"}],"source_refs":["S","A","O","Msb","K","TA"]}]},"classical_definitions":null}