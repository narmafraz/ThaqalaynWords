requency_in_corpus":6,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n39748"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ooze, to sputter","examples":[{"text":"ربّما ارتفع ضغط دمي، لأنّني شعرتُ بنشيش يسري في جسمي، وكأنّني سمكة في مقلاة.","english":"Perhaps my blood pressure rose, by reason that I felt a sizzle running in my body, as if I were a fish in a frying-pan."}]}]},"etymology":{"source":"wiktextract","text":"Of imitative origin."},"ipa":["/naʃ.ʃa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39748","headword_ar":"نَشَّ","root":"n$","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (A, TA,) inf. n."},{"kind":"arabic","text_bw":"na$iy$N","text_ar":"نَشِيشٌ"},{"kind":"text","text":"(S, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"na$~N","text_ar":"نَشٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(said of water, S, Mgh, Msb, K, and of other things, S, K, such as wine, and flesh-meat, TA)"},{"kind":"italic_en","text":"made a sound in boiling, estuating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fermenting:"},{"kind":"text","text":"(S, Mgh, Msb, K:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"made a sound like that of boiling, estuating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fermenting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of beginning to do so:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"made a sound in pouring forth."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"na$~ati Alqidoru","text_ar":"نَشَّتِ القِدْرُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"na$iy$N","text_ar":"نَشِيشٌ"},{"kind":"text","text":"; (IDrd, K;) and ↓"},{"kind":"arabic","text_bw":"na$ona$at","text_ar":"نَشْنَشَت","orth_type":"arrow"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"na$ona$apN","text_ar":"نَشْنَشَةٌ"},{"kind":"text","text":"; (IDrd, K;)"},{"kind":"italic_en","text":"The cooking-pot made a sound in boiling:"},{"kind":"text","text":"(IDrd, K:) or"},{"kind":"italic_en","text":"began to boil, and so made a sound."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"na$~a AlmaA'u fiY","text_ar":"نَشَّ المَاءُ فِى"},{"kind":"arabic","text_bw":"kuwzK jadiydK","text_ar":"كُوزٍ جَدِيدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The water made a sound in a new"},{"kind":"text","text":"earthen"},{"kind":"italic_en","text":"mug"},{"kind":"text","text":"]: (A:) or"},{"kind":"arabic","text_bw":"na$~a Alkuwzu Aljadiydu fiY AlmaA='i","text_ar":"نَشَّ الكُوزُ الجَدِيدُ فِى المَا=ءِ"},{"kind":"italic_en","text":"The new"},{"kind":"text","text":"[earthen]"},{"kind":"italic_en","text":"mug made a sound in the water."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"Ald~iroEu","text_ar":"الدِّرْعُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"na$ona$a","text_ar":"نَشْنَشَ","orth_type":"arrow"},{"kind":"italic_en","text":"The coat of mail made a sound,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"clinking."},{"kind":"text","text":"(Fr.) ―         -b2-  Also,"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(wine, A, Mgh, or the beverage called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"estuated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fermented:"},{"kind":"text","text":"(A, Mgh, TA:) or"},{"kind":"arabic","text_bw":"na$iy$N","text_ar":"نَشِيشٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"beginning to estuate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ferment,"},{"kind":"text","text":"of the first of expressed juice [of grapes or dates &c.]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"na$~ati All~aHomapu","text_ar":"نَشَّتِ اللَّحْمَةُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"na$~N","text_ar":"نَشٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The piece of flesh-meat dripped."},{"kind":"text","text":"(Sh, from certain of the Kilábees.)       -A2-  Also"},{"kind":"arabic","text_bw":"na$~a","text_ar":"نَشَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"na$iy$N","text_ar":"نَشِيشٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"na$~N","text_ar":"نَشٌّ"},{"kind":"text","text":", (TA,) said of a pool of water left by a torrent,"},{"kind":"italic_en","text":"Its water began to sink into the earth:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"its water dried up, and sank into the earth."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water upon the surface of the ground)"},{"kind":"italic_en","text":"dried up."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a full-grown unripe date)"},{"kind":"italic_en","text":"lost its moisture."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"na$~a Ald~uhona","text_ar":"نَشَّ الدُّهْنَ"},{"kind":"arabic","text_bw":"bAlr~ayoHaAni","text_ar":"بالرَّيْحَانِ"},{"kind":"text","text":"[aor., app.,"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He infused the oil,"},{"kind":"text","text":"or other"},{"kind":"italic_en","text":"ointment, with perfume, by boiling it with sweet-smelling plants until it made a sound in boiling."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"saliyxapN","text_ar":"سَلِيخَةٌ"},{"kind":"text","text":".]       -A4-"},{"kind":"arabic","text_bw":"na$~a Al*~ubaAba","text_ar":"نَشَّ الذُّبَابَ"},{"kind":"text","text":"[aor., accord. to analogy,"},{"kind":"text","text":", but vulgarly, in the present day,"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He drove"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"whisked"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a way the flies."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","TA","S","Mgh","Msb","K","IDrd"]}]},"classical_definitions":null}