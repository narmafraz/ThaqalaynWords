alse, "count": null, "asp": "i", "per": "3", "gen": "f", "num": "p"}, {"role": "present_1ms", "form": "أَنِشّ", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَنِشّ", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1mp", "form": "نَشَشْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "نَشَشْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 6, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": true, "sense_count": 1}, "lanes": {"found": true, "entry_ids": ["n39748"], "search_url": "https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%8E%D9%91"}}, "translations": {"en": "to ooze", "fa": "نشتن", "ur": "رگڑنا", "tr": "sızmak", "id": "merembes", "bn": "সুড়সুড়ানো", "es": "filtrarse", "fr": "s'infiltrer", "de": "sickern", "ru": "просачиваться", "zh": "渗出"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to ooze, to sputter", "examples": [{"text": "ربّما ارتفع ضغط دمي، لأنّني شعرتُ بنشيش يسري في جسمي، وكأنّني سمكة في مقلاة.", "english": "Perhaps my blood pressure rose, by reason that I felt a sizzle running in my body, as if I were a fish in a frying-pan."}]}]}, "etymology": {"source": "wiktextract", "text": "Of imitative origin."}, "ipa": ["/naʃ.ʃa/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n39748", "headword_ar": "نَشَّ", "root": "n$", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", (A, TA,) inf. n."}, {"kind": "arabic", "text_bw": "na$iy$N", "text_ar": "نَشِيشٌ"}, {"kind": "text", "text": "(S, A, Mgh, Msb, K) and"}, {"kind": "arabic", "text_bw": "na$~N", "text_ar": "نَشٌّ"}, {"kind": "text", "text": ", (TA,)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(said of water, S, Mgh, Msb, K, and of other things, S, K, such as wine, and flesh-meat, TA)"}, {"kind": "italic_en", "text": "made a sound in boiling, estuating,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fermenting:"}, {"kind": "text", "text": "(S, Mgh, Msb, K:) and"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(anything)"}, {"kind": "italic_en", "text": "made a sound like that of boiling, estuating,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fermenting;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "of beginning to do so:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(water)"}, {"kind": "italic_en", "text": "made a sound in pouring forth."}, {"kind": "text", "text": "(TA.) You say also,"}, {"kind": "arabic", "text_bw": "na$~ati Alqidoru", "text_ar": "نَشَّتِ القِدْرُ"}, {"kind": "text", "text": ", (TA,) inf. n."}, {"kind": "arabic", "text_bw": "na$iy$N", "text_ar": "نَشِيشٌ"}, {"kind": "text", "text": "; (IDrd, K;) and ↓"}, {"kind": "arabic", "text_bw": "na$ona$at", "text_ar": "نَشْنَشَت", "orth_type": "arrow"}, {"kind": "text", "text": ", (TA,) inf. n."}, {"kind": "arabic", "text_bw": "na$ona$apN", "text_ar": "نَشْنَشَةٌ"}, {"kind": "text", "text": "; (IDrd, K;)"}, {"kind": "italic_en", "text": "The cooking-pot made a sound in boiling:"}, {"kind": "text", "text": "(IDrd, K:) or"}, {"kind": "italic_en", "text": "began to boil, and so made a sound."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "na$~a AlmaA'u fiY", "text_ar": "نَشَّ المَاءُ فِى"}, {"kind": "arabic", "text_bw": "kuwzK jadiydK", "text_ar": "كُوزٍ جَدِيدٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The water made a sound in a new"}, {"kind": "text", "text": "earthen"}, {"kind": "italic_en", "text": "mug"}, {"kind": "text", "text": "]: (A:) or"}, {"kind": "arabic", "text_bw": "na$~a Alkuwzu Aljadiydu fiY AlmaA='i", "text_ar": "نَشَّ الكُوزُ الجَدِيدُ فِى المَا=ءِ"}, {"kind": "italic_en", "text": "The new"}, {"kind": "text", "text": "[earthen]"}, {"kind": "italic_en", "text": "mug made a sound in the water."}, {"kind": "text", "text": "(Mgh.) And"}, {"kind": "arabic", "text_bw": "Ald~iroEu", "text_ar": "الدِّرْعُ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "na$ona$a", "text_ar": "نَشْنَشَ", "orth_type": "arrow"}, {"kind": "italic_en", "text": "The coat of mail made a sound,"}, {"kind": "text", "text": "(K,) or"}, {"kind": "italic_en", "text": "clinking."}, {"kind": "text", "text": "(Fr.) ―         -b2-  Also,"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(wine, A, Mgh, or the beverage called"}, {"kind": "arabic", "text_bw": "nabiy*", "text_ar": "نَبِيذ"}, {"kind": "text", "text": ", TA,)"}, {"kind": "italic_en", "text": "estuated,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fermented:"}, {"kind": "text", "text": "(A, Mgh, TA:) or"}, {"kind": "arabic", "text_bw": "na$iy$N", "text_ar": "نَشِيشٌ"}, {"kind": "text", "text": "signifies the"}, {"kind": "italic_en", "text": "beginning to estuate,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ferment,"}, {"kind": "text", "text": "of the first of expressed juice [of grapes or dates &c.]. (TA.) ―         -b3-"}, {"kind": "arabic", "text_bw": "na$~ati All~aHomapu", "text_ar": "نَشَّتِ اللَّحْمَةُ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "na$~N", "text_ar": "نَشٌّ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "The piece of flesh-meat dripped."}, {"kind": "text", "text": "(Sh, from certain of the Kilábees.)       -A2-  Also"}, {"kind": "arabic", "text_bw": "na$~a", "text_ar": "نَشَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "na$iy$N", "text_ar": "نَشِيشٌ"}, {"kind": "text", "text": "(S, K) and"}, {"kind": "arabic", "text_bw": "na$~N", "text_ar": "نَشٌّ"}, {"kind": "text", "text": ", (TA,) said of a pool of water left by a torrent,"}, {"kind": "italic_en", "text": "Its water began to sink into the earth:"}, {"kind": "text", "text": "(S, K:) or"}, {"kind": "italic_en", "text": "its water dried up, and sank into the earth."}, {"kind": "text", "text": "(TA.)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(water upon the surface of the ground)"}, {"kind": "italic_en", "text": "dried up."}, {"kind": "text", "text": "(TA.)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a full-grown unripe date)"}, {"kind": "italic_en", "text": "lost its moisture."}, {"kind": "text", "text": "(TA.)       -A3-"}, {"kind": "arabic", "text_bw": "na$~a Ald~uhona", "text_ar": "نَشَّ الدُّهْنَ"}, {"kind": "arabic", "text_bw": "bAlr~ayoHaAni", "text_ar": "بالرَّيْحَانِ"}, {"kind": "text", "text": "[aor., app.,"}, {"kind": "text", "text": ",]"}, {"kind": "italic_en", "text": "He infused the oil,"}, {"kind": "text", "text": "or other"}, {"kind": "italic_en", "text": "ointment, with perfume, by boiling it with sweet-smelling plants until it made a sound in boiling."}, {"kind": "text", "text": "(TA.) [See also"}, {"kind": "arabic", "text_bw": "saliyxapN", "text_ar": "سَلِيخَةٌ"}, {"kind": "text", "text": ".]       -A4-"}, {"kind": "arabic", "text_bw": "na$~a Al*~ubaAba", "text_ar": "نَشَّ الذُّبَابَ"}, {"kind": "text", "text": "[aor., accord. to analogy,"}, {"kind": "text", "text": ", but vulgarly, in the present day,"}, {"kind": "text", "text": ",]"}, {"kind": "italic_en", "text": "He drove"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "whisked"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "a way the flies."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["A", "TA", "S", "Mgh", "Msb", "K", "IDrd"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D9%86%D8%B4/", "headword_ar": "نش", "entries": [{"lexicon_id": "dictionary_36", "lexicon_en": "Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)", "lexicon_ar": "المحيط في اللغة للصاحب بن عباد", "permalink": "https://arabiclexicon.hawramani.com/?p=53124#7de2b3", "body_html": "<div>نش: النَّشُّ: نَشِيْشُ الماءِ والخَمْرِ إذا غلى. ونَشَّ الغَدِيْرُ: أخَذَ ماؤه في النَّضْبِ. وسَبِخَةٌ نَشّاشَةٌ. وفي مَثَلٍ: \" نِشْنِشَةٌ أعْرِفُها من أخْزَمِ \" على القَلْبِ. والنَّشُّ: وَزْنُ نَوَاةٍ من ذَهَبٍ في الحَدِيثِ. وانْتَشَّتِ الشَّجَرَةُ انْتِشَاشاً: وهو أنْ يَطُولَ حَتّى يَسْتَمْكِنَ منه الظِّبَاءُ والبَهْمُ. ونَشْنَشَ الشَّيْءُ: إذا حَرَّكَه حَرَكَةً شَدِيْدَةً. وانَّشْنَشَةُ: حَلُّ السَّرَاوِيْلِ ونَحْوِها. ونَشْنَشَ ثَوْبَه: خَلَعَه. ورَجُلٌ نَشْنَشِيُّ الذِّرَاعِ: وهو الرَّقِيْقُ اليَدِ الخَفِيْفُ العَملِ. ونَشْنَشَها الرَّجُلُ والفَحْلُ: خَالَطَها.</div>"}, {"lexicon_id": "dictionary_32", "lexicon_en": "Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)", "lexicon_ar": "تكملة المعاجم العربية لرينهارت دوزي", "permalink": "https://arabiclexicon.hawramani.com/?p=53124#8856b1", "body_html": "نش: نش على: أبعد الذبان عن، ابعد الذباب باستعمال المروحة (ألف ليلة وليلة 1: 857).<br>نش: ضرب (ألف ليلة 1: 119): ثم حطني على سطح وأنزلني ونشني بذيله على وجهي وقلع عيني اليمنى أما (برسل) فقد أتى على ذكر كلمة (ضرب).<br>نش: درب، روض كلبا (هلو).<br>مش: في الحديث عن الورق: شرب (بوشر، همبرت 112).<br>نش: في الحديث عن الحائط أو عن الإناء الذي يحتوي السائل، عرق، نضح (محيط المحيط).<br>نش: اسم المصدر نشيش: فرقع، تلألأ، إلى. في الحديث عن الصوت الذي تحدثه الشمعة التي هي على وشك الانطفاء (باين سميث 1502).<br>نش: رشح أو نضوح أو عرقان الحائط (انظر هامش 402).<br>ورق نشاش: أي الذي يمتص الكتابة (انظر هامش 402) (همبرت 112، محيط المحيط).<br>منشة: مروحة طرد الذباب (شيرب ديال 140، ريشاردسون صحارى 1: 212)؛ منشة من ريش: منفضة ريش، مكنسة ريش (بوشر)."}, {"lexicon_id": "dictionary_49", "lexicon_en": "Arabic-English Lexicon by Edward William Lane (d. 1876)", "lexicon_ar": "المعجم العربي الإنجليزي لإدوارد وليام لين", "permalink": "https://arabiclexicon.hawramani.com/?p=53124#4e4af3", "body_html": "<h3>نش</h3><span class=\"sense\">1</span> نَشَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> نَشِيشٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and نَشٌّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) It (said of water, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, and of other things, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, such as wine, and flesh-meat, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) made a sound in boiling, estuating, or fermenting: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) and it (anything) made a sound like that of boiling, estuating, or fermenting; or of beginning to do so: and it (water) made a sound in pouring forth. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) You say also, نَشَّتِ القِدْرُ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> نَشِيشٌ; (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and ↓ نَشْنَشَت, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> نَشْنَشَةٌ; (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) The cooking-pot made a sound in boiling: (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or began to boil, and so made a sound. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And نَشَّ المَاءُ فِى<br><br>كُوزٍ جَدِيدٍ [The water made a sound in a new earthen mug]: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>:) or نَشَّ الكُوزُ الجَدِيدُ فِى المَآءِ The new [earthen] mug made a sound in the water. (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>.) And الدِّرْعُ ↓ نَشْنَشَ The coat of mail made a sound, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or clinking. (<abbr title=\"al-Farrāʾ\">Fr</abbr>.) <span class=\"sub-sense\">b2:</span> Also, It (wine, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, or the beverage called نَبِيذ, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) estuated, or fermented: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or نَشِيشٌ signifies the beginning to estuate, or ferment, of the first of expressed juice [of grapes or dates &amp;c.]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> نَشَّتِ اللَّحْمَةُ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> نَشٌّ, The piece of flesh-meat dripped. (<abbr title=\"Shemir (Shamir bin Hamadawayh?)\">Sh</abbr>, from certain of the Kilábees.) <span class=\"sub-sense\">A2:</span> Also نَشَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـِ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> نَشِيشٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and نَشٌّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) said of a pool of water left by a torrent, Its water began to sink into the earth: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or its water dried up, and sank into the earth. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) It (water upon the surface of the ground) dried up. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) It (a full-grown unripe date) lost its moisture. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">A3:</span> نَشَّ الدُّهْنَ بالرَّيْحَانِ [<abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr>, <abbr title=\"apparently\">app.</abbr>, نَشُّ,] He infused the oil, or other ointment, with perfume, by boiling it with sweet-smelling plants until it made a sound in boiling. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [See also سَلِيخَةٌ.]<br><br><span class=\"sub-sense\">A4:</span> نَشَّ الذُّبَابَ [<abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr>, <abbr title=\"according\">accord.</abbr> to <abbr title=\"قِيَاسٌ\">analogy</abbr>, نَشُّ, but vulgarly, in the present day, نَشِّ,] He drove [or whisked] a way the flies. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <abbr title=\"al-Rawḍ al-Unuf of al-Suhaylī\">R</abbr>. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1 نَشْنَشَ, see 1. in two places. See also شِنْشِنَةٌ.<br><br>نَشٌّ The half of an أُوقِيَّة [or ounce]; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) i. e., twenty dirhems; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) the اوقيّة being forty dirhems; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) and five dirhems being called نَوَاةٌ: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) or the weight of a date-stone (نواة) of gold: or the weight of five dirhems: or the quarter of an اوقيّة: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) and the half of anything; (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"Shemir (Shamir bin Hamadawayh?)\">Sh</abbr>, <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) as, for instance, of a dirhem, and of a cake of bread. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"Shemir (Shamir bin Hamadawayh?)\">Sh</abbr>, <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>.) نَشَاشَةٌ: see نَشَّاشَةٌ.<br><br>أَرْضٌ نَشِيشَةٌ and ↓ نَشْنَاشَةٌ Salt land that produces no herbage. (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) سَبَحَةٌ نَشَّاشَةٌ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and ↓ نَشَاشَةٌ, (<abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) A tract of salt land of which the moisture [or, as in a copy of the <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, the earth,] does not dry up, nor its pasture, or herbage, grow: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or what appears of the water of salt lands, and begins to sink therein, so that it becomes salt. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) نَشْنَاشَةٌ: see نَشِيشَةٌ.<br><br>مَنَشُّ السَّاحِلِ The part of the shore of a sea or great river from which the water has retired. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) مِنَشَّةٌ [A fly-whisk;] a thing with which the flies are driven a way. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) دُهْنٌ مَنْشُوشٌ Oil, or other ointment, infused with perfume, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) by boiling it with sweetsmelling plants until it makes a sound in boiling. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) [See also سَلِيخَةٌ.]"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}