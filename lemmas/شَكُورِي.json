},{"kind":"text","text":"(TA:) or one"},{"kind":"italic_en","text":"who does his utmost in showing his thankfulness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gratitude, with his heart and his tongue and his members,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limbs, with firm belief, and with acknowledgment"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of benefits received"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"who sees his inability to be"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sufficiently"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thankful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grateful:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who renders thanks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is thankful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grateful, for probation:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"for what is denied him:"},{"kind":"text","text":"(KT:) pl."},{"kind":"arabic","text_bw":"$ukurN","text_ar":"شُكُرٌ"},{"kind":"text","text":". (TA.) ―         -b2-  (tropical:)  A beast"},{"kind":"italic_en","text":"that is sufficed by little fodder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage,"},{"kind":"text","text":"(S, A,)"},{"kind":"italic_en","text":"and that fattens upon it:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"that fattens upon little fodder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"(K:) as though thankful for that small benefit. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Al$~akuwru","text_ar":"الشَّكُورُ"},{"kind":"text","text":", applied to God, (tropical:)  ["},{"kind":"italic_en","text":"He who approves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rewards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forgives, much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"largely:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He who gives large reward for small,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"few, works: He in whose estimation small,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"few, works performed by his servants increase, and who multiplies his rewards to them."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","K","KT","S","A"]}]},"classical_definitions":null}