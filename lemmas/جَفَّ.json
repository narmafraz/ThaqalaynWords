":41,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n5947"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%81%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become dry"},{"pos":"noun","gloss":"the spathe of the palm-tree, the envelope of the طَلْع (ṭalʕ, “the spadix of the palm”) when it has become dry"},{"pos":"noun","gloss":"worn-out waterskin"},{"pos":"noun","gloss":"anything hollow, such as has something in it"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5947","headword_ar":"جَفَّ","root":"jf","body":[{"kind":"text","text":", (S, Mgh, Msb,) sec. pers."},{"kind":"arabic","text_bw":"jafafota","text_ar":"جَفَفْتَ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yajif~u","text_ar":"يَجِفُّ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"yajaf~u","text_ar":"يَجَفُّ"},{"kind":"text","text":", (S, K,) the latter aor. mentioned by AZ, but rejected by Ks; (S;) and sec. pers."},{"kind":"arabic","text_bw":"jaffota","text_ar":"جَففْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajaf~u","text_ar":"يَجَفُّ"},{"kind":"text","text":", (Sgh, Msb, K,) of the dial. of Benoo-Asad; (Msb;) inf. n."},{"kind":"arabic","text_bw":"jafaAfN","text_ar":"جَفَافٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jufuwfN","text_ar":"جُفُوفٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,) which are assigned by J and Sgh to"},{"kind":"arabic","text_bw":"jaf~a","text_ar":"جَفَّ"},{"kind":"text","text":"aor."},{"kind":"arabic","text_bw":"yajif~N","text_ar":"يَجِفٌّ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Mgh, or a garment, S, Msb, K, and also said of other things, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dry; it dried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up."},{"kind":"text","text":"(Mgh, Msb.) Hence the saying,"},{"kind":"arabic","text_bw":"mani A@Hotalama vum~a A^aSobaHa EalaY","text_ar":"مَنِ ا@حْتَلَمَ ثُمَّ اَصْبَحَ عَلَى"},{"kind":"arabic","text_bw":"jafaAfK","text_ar":"جَفَافٍ"},{"kind":"italic_en","text":"He who experiences an emission of semen in sleep, then rises in the morning with what is on his garment, of the semen, dry."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"jaf~a Aln~ahoru","text_ar":"جَفَّ النَّهْرُ"},{"kind":"text","text":", an elliptical phrase, for"},{"kind":"arabic","text_bw":"jaf~a maA='u Aln~ahori","text_ar":"جَفَّ مَا=ءُ النَّهْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The water of the river dried up"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"fulaAnN laA yajif~u liboduhu","text_ar":"فُلَانٌ لَا يَجِفُّ لِبْدُهُ"},{"kind":"italic_en","text":"Such a one does not remit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become remiss, in his work,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"labour:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"does not cease to go to and fro."},{"kind":"text","text":"(Har p. 589.) ―         -b2-"},{"kind":"arabic","text_bw":"jaf~a","text_ar":"جَفَّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jufuwfN","text_ar":"جُفُوفٌ"},{"kind":"text","text":", said of a man,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent; he did not speak."},{"kind":"text","text":"(Msb.)       -A2-"},{"kind":"arabic","text_bw":"jafafotu Al$~aYo'a A_ilaY~a","text_ar":"جَفَفْتُ الشَّىْءَ اـِلَىَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^ajuf~u","text_ar":"اَجُفُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaf~N","text_ar":"جَفٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I collected the thing to me."},{"kind":"text","text":"(Nawádir of AZ, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jaf~uwA A^amowaAlahumo","text_ar":"جَفُّوا اَمْوَالَهُمْ"},{"kind":"italic_en","text":"They collected together their camels, and took them away."},{"kind":"text","text":"(Sgh, * K, * TA.)"}],"source_refs":["S","Mgh","Msb","K","Sgh","TA"]}]}}