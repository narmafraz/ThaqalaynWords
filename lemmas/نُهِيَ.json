,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":3149,"cross_references":{"qac":{"found":true,"lemma_key":"نَهَى","root":"نهي","pos":"V","occurrence_count":32},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40589"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8F%D9%87%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of نَهَى (nahā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"an order not to do something, a prohibition, a proscription"},{"pos":"noun","gloss":"negative imperative, prohibitive; a grammatical form used to express prohibition or to instruct someone not to perform a particular action. In Arabic grammar, it uses the word لَا (lā) followed by the verb, as in لَا تَذْهَبْ (lā taḏhab, “do not go”)."}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40589","headword_ar":"نَهِيَ","root":"nhA^","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"nahuw^a","text_ar":"نَهُوَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, K;) and"},{"kind":"arabic","text_bw":"nahuw^a","text_ar":"نَهُوَ"},{"kind":"text","text":"; (as in one copy of the S;) inf. n."},{"kind":"arabic","text_bw":"naho'N","text_ar":"نَهْءٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"nahaA^N","text_ar":"نَهَاٌ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"nahaA='ap'","text_ar":"نَهَا=ءَةء"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"nuhuwo'apN","text_ar":"نُهُوْءَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"nuhuwo'N","text_ar":"نُهُوْءٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"nahaAwapN","text_ar":"نَهَاوَةٌ"},{"kind":"text","text":", (the last dev. from rule); (K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(flesh-meat)"},{"kind":"italic_en","text":"was not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did not become, thoroughly cooked."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"maA A^ubaAliY maA nahiy^a","text_ar":"مَا اُبَالِى مَا نَهِيَ"},{"kind":"arabic","text_bw":"mino Dab~ika walaA maA nDija","text_ar":"مِنْ ضَبِّكَ وَلَا مَا نضِجَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I care not what is insufficiently cooked, of thy"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"nor what is thoroughly cooked:"},{"kind":"text","text":"i. e. I care not whether evil or good befall thee]. (S, * TA,) A proverb. (TA.)       -A2-"},{"kind":"arabic","text_bw":"$ariba Hat~aY nahaA^a","text_ar":"شَرِبَ حَتَّى نَهَاَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He drank till he was full."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":["S","K"]}]}}