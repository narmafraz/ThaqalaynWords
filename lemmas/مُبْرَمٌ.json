{"lemma":"مُبْرَمٌ","slug":"مُبْرَمٌ","root":"ب.ر.م","root_slug":"ب-ر-م","root_link":"/words/roots/ب-ر-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُبْرَمٌ","root":"برم","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n2393","n2394"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%A8%D9%92%D8%B1%D9%8E%D9%85%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2393","headword_ar":"مُبْرَمٌ","root":"brm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bariymN","text_ar":"بَرِيمٌ"},{"kind":"text","text":". ―         -b2-  Also A garment, or piece of cloth,"},{"kind":"italic_en","text":"of which the thread is twisted of two yarns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct twists."},{"kind":"text","text":"(S, K.) And hence, (S,)"},{"kind":"italic_en","text":"A certain kind of garments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloths."},{"kind":"text","text":"(S, K.) ―         -b3-  [(assumed tropical:)  A thing, or an affair, or a compact,"},{"kind":"page_break","n":196},{"kind":"italic_en","text":"made firm, strong, solid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound; established, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arranged, firmly, strongly, solidly, soundly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thoroughly."},{"kind":"text","text":"See its verb, 4. ―         -b4-  And hence,"},{"kind":"arabic","text_bw":"qaDaA='N muboramN","text_ar":"قَضَا=ءٌ مُبْرَمٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Ratified destiny; such as is rendered inevitable."},{"kind":"text","text":"]"}],"source_refs":["S"]},{"entry_id":"n2394","headword_ar":"مُبْرَمٌ","root":"brm","body":[{"kind":"text","text":"[act. part. n. of 4.       -A2-  And also]"},{"kind":"italic_en","text":"A gatherer of"},{"kind":"arabic","text_bw":"baram","text_ar":"بَرَم"},{"kind":"text","text":"[q. v.]: (M:) or,"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"baram","text_ar":"بَرَم"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":": (K:) or, specially,"},{"kind":"italic_en","text":"a gatherer of the"},{"kind":"arabic","text_bw":"baram","text_ar":"بَرَم"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"A^araAk","text_ar":"اَرَاك"},{"kind":"text","text":". (M.)       -A3-"},{"kind":"italic_en","text":"A maker of"},{"kind":"arabic","text_bw":"biraAm","text_ar":"بِرَام"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stone cookingpots"},{"kind":"text","text":"]: (K:) or"},{"kind":"italic_en","text":"one who wrenches out the stones of which they are made from the mountain,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"and fashions them, and hews them out."},{"kind":"text","text":"(TA.)       -A4-  And hence, (M,) (assumed tropical:)  A"},{"kind":"italic_en","text":"heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sluggish,"},{"kind":"text","text":"man; as though [in the CK"},{"kind":"arabic","text_bw":"lAan~ahu","text_ar":"لاَنَّهُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"kaA^an~ahu","text_ar":"كَاَنَّهُ"},{"kind":"text","text":"] he cut off for himself something from the persons sitting with him: (M, K: *) or, as some say, [so in the M; but in the K, “and”]"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt, in discourse;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"who discourses to others of that in which is no profit nor meaning;"},{"kind":"text","text":"(TA;) from the same word as signifying “a gatherer of the fruit of the"},{"kind":"arabic","text_bw":"ArAk","text_ar":"اراك"},{"kind":"text","text":",” (M, TA,) which has no taste nor sweetness nor sourness nor virtue, or efficacy: (AO, TA:) or one"},{"kind":"italic_en","text":"who is a burden upon his companion, without profit and without good; like the"},{"kind":"arabic","text_bw":"baram","text_ar":"بَرَم"},{"kind":"italic_en","text":"who takes no part with others in the game of"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"text","text":","},{"kind":"italic_en","text":"though he eats of the flesh-meat thereof."},{"kind":"text","text":"(As, TA.)"}],"source_refs":["M","K","TA","AO"]}]},"classical_definitions":null}