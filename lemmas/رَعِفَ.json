ource":"lanes","entries":[{"entry_id":"n15912","headword_ar":"رَعَفَ","root":"rEf","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"raEofN","text_ar":"رَعْفٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"preceded; went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, before; outwent, outran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outstripped;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AstrEf","text_ar":"استرعف","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"ArtEf","text_ar":"ارتعف","orth_type":"arrow"},{"kind":"text","text":". (K.) [This is held by some, and is said in the O, to be the primary signification: see"},{"kind":"arabic","text_bw":"ruEaAfN","text_ar":"رُعَافٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"raEifa Ald~amu","text_ar":"رَعِفَ الدَّمُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"The blood flowed."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"raEafa A^anofuhu","text_ar":"رَعَفَ اَنْفُهُ"},{"kind":"italic_en","text":"His nose bled; blood flowed from his nose:"},{"kind":"text","text":"this is the chaste form of the verb:"},{"kind":"arabic","text_bw":"ruEifa","text_ar":"رُعِفَ"},{"kind":"text","text":", from which is formed the part. n."},{"kind":"arabic","text_bw":"maroEuwfN","text_ar":"مَرْعُوفٌ"},{"kind":"text","text":", is incorrect; (Mgh;) unknown to As: (O:) [or]"},{"kind":"arabic","text_bw":"raEafa","text_ar":"رَعَفَ"},{"kind":"text","text":"alone, aor."},{"kind":"text","text":"and"},{"kind":"text","text":", has this last signification; as also"},{"kind":"arabic","text_bw":"raEufa","text_ar":"رَعُفَ"},{"kind":"text","text":", (S, O, * Msb, K,) but this is a dial. var. of weak authority, (S, O,) or is rare; (Msb;) and"},{"kind":"arabic","text_bw":"raEifa","text_ar":"رَعِفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"ruEifa","text_ar":"رُعِفَ"},{"kind":"text","text":"[mentioned above as incorrect]; (K;) and the inf. n. is"},{"kind":"arabic","text_bw":"raEofN","text_ar":"رَعْفٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"ruEaAfN","text_ar":"رُعَافٌ"},{"kind":"text","text":", (K,) or the latter is a simple subst. (Msb.) [And hence"},{"kind":"arabic","text_bw":"raEafa","text_ar":"رَعَفَ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a vessel, such as a skin,)"},{"kind":"italic_en","text":"overflowed:"},{"kind":"text","text":"] see 4, in two places. ―         -b3-"},{"kind":"arabic","text_bw":"raEafa bihi","text_ar":"رَعَفَ بِهِ"},{"kind":"arabic","text_bw":"AlbaAba","text_ar":"البَابَ"},{"kind":"italic_en","text":"He entered with him the door."},{"kind":"text","text":"(O, K.)"}],"source_refs":["S","K","TK","O","Msb"]}]}}