y_ids":["n39431","n39434","n39435","n39436","n39437","n39438","n39439"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AC%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be unclean, to be impure"},{"pos":"verb","gloss":"to defile, to besmirch"},{"pos":"noun","gloss":"verbal noun of نَجِسَ (najisa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"filth, impurity"},{"pos":"adj","gloss":"unclean, impure"},{"pos":"adj","gloss":"irremediable"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39431","headword_ar":"نَجِسَ","root":"njs","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"najasa","text_ar":"نَجَسَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"najusa","text_ar":"نَجُسَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) accord. to some, but the books of good repute are silent respecting this last; (Msb;) inf. n."},{"kind":"arabic","text_bw":"najasN","text_ar":"نَجَسٌ"},{"kind":"text","text":", (S, Msb, TA,) of the first; (Msb;) and"},{"kind":"arabic","text_bw":"najaAsapN","text_ar":"نَجَاسَةٌ"},{"kind":"text","text":", (TA,) or this last is a simple subst. [as the verb"},{"kind":"arabic","text_bw":"najusa","text_ar":"نَجُسَ"},{"kind":"text","text":"to which by rule it should belong is not of good authority]; (Msb;)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unclean, dirty, filthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impure;"},{"kind":"text","text":"(Msb;) [i. e.,]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"Tahara","text_ar":"طَهَرَ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Tahura","text_ar":"طَهُرَ"},{"kind":"text","text":": (Msb, K: *)"},{"kind":"arabic","text_bw":"najaAsap","text_ar":"نَجَاسَة"},{"kind":"text","text":"is of two kinds; one kind is perceived by sense; and one kind is perceived by the mind; of which latter kind is that which is attributed, in the Kur, ix. 28, to those who assert God to have associates: (Er-Rághib, B:) but in this latter sense, it is said by Z, to be tropical. (TA.) [See also"},{"kind":"arabic","text_bw":"najaAsapN","text_ar":"نَجَاسَةٌ"},{"kind":"text","text":"below.] You also say, (of a garment, A, Msb,) ↓"},{"kind":"arabic","text_bw":"tnj~s","text_ar":"تنجّس","orth_type":"arrow"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rendered unclean, dirty, filthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impure."},{"kind":"text","text":"(A, Msb, K.)       -A2-"},{"kind":"arabic","text_bw":"najosN","text_ar":"نَجْسٌ"},{"kind":"text","text":", [app. an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"najasa","text_ar":"نَجَسَ"},{"kind":"text","text":",] The"},{"kind":"italic_en","text":"making a child's"},{"kind":"arabic","text_bw":"Euwdap","text_ar":"عُودَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"amulet, of any of the kinds described below, voce"},{"kind":"arabic","text_bw":"tanojiysN","text_ar":"تَنْجِيسٌ"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K","S","Msb","TA"]},{"entry_id":"n39434","headword_ar":"نَجْسٌ","root":"njs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n39435","headword_ar":"نِجْسٌ","root":"njs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n39436","headword_ar":"نَجَسٌ","root":"njs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n39437","headword_ar":"نَجُسٌ","root":"njs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n39438","headword_ar":"نَجِسٌ","root":"njs","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"najasN","text_ar":"نَجَسٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"najusN","text_ar":"نَجُسٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"najosN","text_ar":"نَجْسٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nijosN","text_ar":"نِجْسٌ","orth_type":"arrow"},{"kind":"text","text":"(A, O, K)"},{"kind":"italic_en","text":"Unclean, dirty, filthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impure:"},{"kind":"text","text":"(A, Msb, K:) the last of these is only used when the word is preceded or followed by"},{"kind":"arabic","text_bw":"rijosN","text_ar":"رِجْسٌ"},{"kind":"text","text":": (ISd:) or only when it is preceded by"},{"kind":"arabic","text_bw":"rijosN","text_ar":"رِجْسٌ"},{"kind":"text","text":": (Fr, S, * and Har in the Durrat-el-Ghowwás:) but this remark correctly applies only to the greater number of instances: (M, F:) the second of the above five forms is an inf. n. used as an epithet; (A, Msb;) and is [therefore] used as sing. and dual. and pl. and masc. and fem., without variation: (TA:) [and the first and last are also used as pls., as will be seen below; but when so used, I suppose"},{"kind":"arabic","text_bw":"qawomN","text_ar":"قَوْمٌ"},{"kind":"text","text":"or some other coll. gen. n. to be understood:] the pl. [of every one of the other forms] is"},{"kind":"arabic","text_bw":"A^anojaAsN","text_ar":"اَنْجَاسٌ"},{"kind":"text","text":"(A, Msb, TA) and [of the fourth and fifth, and perhaps of the first and third also, though I do not remember similar instances,]"},{"kind":"arabic","text_bw":"nijosapN","text_ar":"نِجْسَةٌ"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"najaAsapN","text_ar":"نَجَاسَةٌ"},{"kind":"text","text":", below.]"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"najosN","text_ar":"نَجْسٌ","orth_type":"arrow"},{"kind":"text","text":"[&c.], applied to a man, signify"},{"kind":"italic_en","text":"Unclean,"},{"kind":"text","text":"&c., [both properly and tropically]. (TA.) [The two following examples are said in the A to be tropical.]"},{"kind":"arabic","text_bw":"Aln~aAsu A^ajonaAsN waA^akovaruhumo A^anojaAsN","text_ar":"النَّاسُ اَجْنَاسٌ وَاَكْثَرُهُمْ اَنْجَاسٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Men are of several kinds, and most of them are unclean."},{"kind":"text","text":"] (A, TA.) And"},{"kind":"arabic","text_bw":"A_in~amaA A@lomu$orikuwna najasN","text_ar":"اـِنَّمَا ا@لْمُشْرِكُونَ نَجَسٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily the associaters"},{"kind":"text","text":"of others with God"},{"kind":"italic_en","text":"are but unclean"},{"kind":"text","text":"], said in the Kur, [ix. 28,] (S, A, TA,) or"},{"kind":"arabic","text_bw":"najisN","text_ar":"نَجِسٌ"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"nijosN","text_ar":"نِجْسٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to certain readers. (TA.)       -A2-  Also, all the above forms, A man"},{"kind":"italic_en","text":"having an incurable disease."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"naAjisN","text_ar":"نَاجِسٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","O","Msb","K","ISd","M","F","TA"]},{"entry_id":"n39439","headword_ar":"نُجُسٌ","root":"njs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"munaj~isN","text_ar":"مُنَجِّسٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}