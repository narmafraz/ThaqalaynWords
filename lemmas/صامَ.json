rpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصُومُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصُم","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَصُوم","in_corpus":true,"count":92,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصُم","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَصُوم","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصُومانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصُوما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصُومانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصُوما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصُومُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصُومُوا","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صُمْنا","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صُمْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصُوم","in_corpus":true,"count":16,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصُوم","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":489,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n25259"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D8%A7%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stand still, to become calm","tags":["obsolete"]},{"pos":"verb","gloss":"to fast (to abstain, usually from food and drink)"}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-Semitic. Compare Hebrew צָם (ṣām) and Ge'ez ጾመ (ṣomä, “to fast”). Nöldeke was convinced that the meaning “to fast” is a semantic loan from Aramaic צום / ܨܳܡ (ṣām, “to fast”), referring to the meaning “to stand still”, Jeffery says that the Arabic verb is “obviously denominative from صَوْم (ṣawm)” and notes that the term is only used in late Qurʾānic passages."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25259","headword_ar":"صَامَ","root":"Swm","body":[{"kind":"text","text":", (S, M, &c.,) aor."},{"kind":"arabic","text_bw":"yaSuwmu","text_ar":"يَصُومُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"SiyaAmN","text_ar":"صِيَامٌ"},{"kind":"text","text":"; (S, M, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AiSoTaAma","text_ar":"اِصْطَامَ","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He abstained,"},{"kind":"text","text":"(Msb, TA,) in an absolute sense: (Msb:) this is the primary signification: (TA:) [or] this is said to be the signification in the proper language of the Arabs: (Msb:) and in the language of the law, (Msb, TA,)"},{"kind":"italic_en","text":"he observed a particular kind of abstinence;"},{"kind":"text","text":"(Msb;) i. e. (TA)"},{"kind":"italic_en","text":"he abstained from food"},{"kind":"text","text":"(S, M, K, TA)"},{"kind":"italic_en","text":"and drink"},{"kind":"text","text":"(M, K, TA)"},{"kind":"italic_en","text":"and coïtus:"},{"kind":"text","text":"(M, K:) and (S, * M, &c.) by a tropical application, (TA,) (tropical:)"},{"kind":"italic_en","text":"from speech:"},{"kind":"text","text":"(S, * M, Mgh, Msb, * K, TA:) or"},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":"in the proper language of the Arabs signifies a man's"},{"kind":"italic_en","text":"abstaining from eating:"},{"kind":"text","text":"and by a secondary application,"},{"kind":"italic_en","text":"a particular serving of God"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by fasting"},{"kind":"text","text":"]; (Mgh;) [i. e.] the"},{"kind":"italic_en","text":"abstaining from eating and drinking and coïtus from daybreak to sunset:"},{"kind":"text","text":"(KT:) accord. to Kh, it signifies [properly] the"},{"kind":"italic_en","text":"standing without work."},{"kind":"text","text":"(S.)"},{"kind":"arabic","text_bw":"SAm Al$~ahora","text_ar":"صام الشَّهْرَ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"SAm fiY Al$~ahori","text_ar":"صام فِى الشَّهْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fasted during the month"},{"kind":"text","text":"]: agreeably with what is said in the Kur ii. 181. (TA.) And it is said (S, M) by I'Ab (S) that the saying, in the Kur [xix. 27], (S, M,)"},{"kind":"arabic","text_bw":"A_in~iY na*arotu lilr~aHom`ni SawomFA","text_ar":"اـِنِّى نَذَرْتُ لِلرَّحْمٰنِ صَوْمًا"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"Verily I have vowed unto the Compassionate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"an abstaining from speech."},{"kind":"text","text":"(S, M, Msb.) One says also,"},{"kind":"arabic","text_bw":"SAm Alfarasu","text_ar":"صام الفَرَسُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":"(S, M) and"},{"kind":"arabic","text_bw":"SiyaAmN","text_ar":"صِيَامٌ"},{"kind":"text","text":", (M,) (assumed tropical:)"},{"kind":"italic_en","text":"The horse stood without eating of fodder;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"abstained from the eating of fodder."},{"kind":"text","text":"(M, A, Mgh.) And"},{"kind":"arabic","text_bw":"SAm Eani Als~ayori","text_ar":"صام عَنِ السَّيْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He abstained from going along,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeying."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"page_break","n":1750},{"kind":"arabic","text_bw":"SAmt Al$~amosu","text_ar":"صامت الشَّمْسُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sun became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"apparently"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"stationary"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the mid-heaven"},{"kind":"text","text":"]: (T, TA:) or"},{"kind":"italic_en","text":"attained its full height."},{"kind":"text","text":"(M, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"SAm","text_ar":"صام"},{"kind":"arabic","text_bw":"Aln~ahaAru","text_ar":"النَّهَارُ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":", S,) (tropical:)"},{"kind":"italic_en","text":"The day reached its midpoint."},{"kind":"text","text":"(S, M, Mgh, K, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"SAmt Alr~iyHu","text_ar":"صامت الرِّيحُ"},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":", (S, K,) (tropical:)"},{"kind":"italic_en","text":"The wind became still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm."},{"kind":"text","text":"(S, M, K, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"SAm AlmaA='u","text_ar":"صام المَا=ءُ"},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"SiyaAmN","text_ar":"صِيَامٌ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"SulaAqapN","text_ar":"صُلَاقَةٌ"},{"kind":"text","text":") and probably"},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":"also,] (assumed tropical:)"},{"kind":"italic_en","text":"The water became still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":". (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"SAm Aln~aEaAmu","text_ar":"صام النَّعَامُ"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":", (M,) (tropical:)"},{"kind":"italic_en","text":"The ostrich cast forth its dung;"},{"kind":"text","text":"(M, K, TA;) and in the same sense the verb is used in relation to the domestic fowl; because each stands still in doing this, or because each becomes tranquil by reason of the passing forth of that which occasions annoyance: and accord. to [some one or more of the copies of] the M,"},{"kind":"arabic","text_bw":"SAm","text_ar":"صام"},{"kind":"arabic","text_bw":"Aln~ahaAru","text_ar":"النَّهَارُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"nhAr","text_ar":"نهار"},{"kind":"text","text":", by which is here meant the"},{"kind":"italic_en","text":"young one of the"},{"kind":"arabic","text_bw":"karawaAn","text_ar":"كَرَوَان"},{"kind":"text","text":", [or rather"},{"kind":"italic_en","text":"of the bustard called"},{"kind":"arabic","text_bw":"HubaAraY","text_ar":"حُبَارَى"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"cast forth what was in its belly."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"SAm maniy~atahu","text_ar":"صام مَنِيَّتَهُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"*aAqahaA","text_ar":"ذَاقَهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He tasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experienced, his death"},{"kind":"text","text":"]. (K.)       -A3-  And"},{"kind":"arabic","text_bw":"SaAma","text_ar":"صَامَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"shaded himself by means of the tree called"},{"kind":"arabic","text_bw":"Sawom","text_ar":"صَوْم"},{"kind":"text","text":". (K.)"}],"source_refs":["Msb","TA","S","M","K","KT","T"]}]}}