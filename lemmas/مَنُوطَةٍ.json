{"lemma":"مَنُوطَةٍ","slug":"مَنُوطَةٍ","root":"ن.#.ط","root_slug":"ن-_-ط","root_link":"/words/roots/ن-_-ط","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n40768"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%86%D9%8F%D9%88%D8%B7%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40768","headword_ar":"مَنُوطٌ","root":"nwT","body":[{"kind":"italic_en","text":"Suspended; hung."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"arabic","text_bw":"manuwTN bihi","text_ar":"مَنُوطٌ بِهِ"},{"kind":"italic_en","text":"This is suspended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hung, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.) ―         -b2-  [Hence the saying,]"},{"kind":"arabic","text_bw":"h`*aA rajulN manuwTN biAlqawomi","text_ar":"هٰذَا رَجُلٌ مَنُوطٌ بِالقَوْمِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"This is a man adventive to the people; one who has introduced himself among them, and lives among them, not being of their race:"},{"kind":"text","text":"(K, * TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"daEiY~N","text_ar":"دَعِىٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one whose origin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage, is suspected;"},{"kind":"text","text":"&c.]: (K:) and"},{"kind":"arabic","text_bw":"manuwTN mu*abo*ibN","text_ar":"مَنُوطٌ مُذَبْذِبٌ"},{"kind":"text","text":"is also applied to"},{"kind":"italic_en","text":"a person of this latter description who betakes himself to a people;"},{"kind":"text","text":"the latter epithet being added to denote that he knows not to whom to assert himself related, like the wind wavering to the right and left. (TA.) See also"},{"kind":"arabic","text_bw":"tanowaATN","text_ar":"تَنْوَاطٌ"},{"kind":"text","text":".]"}],"source_refs":["K"]}]},"classical_definitions":null}