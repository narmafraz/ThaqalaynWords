{"lemma":"جَلَمٌ","slug":"جَلَمٌ","root":"ج.ل.م","root_slug":"ج-ل-م","root_link":"/words/roots/ج-ل-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n6160"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%8E%D9%85%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6160","headword_ar":"جَلَمٌ","root":"jlm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"instrument with which one shears"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"wool and hair:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"jalamaAni","text_ar":"جَلَمَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a pair thereof; a pair of shears:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"jalamN","text_ar":"جَلَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jalamaAni","text_ar":"جَلَمَانِ"},{"kind":"text","text":"signify alike,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"miqoraADN","text_ar":"مِقْرَاضٌ"},{"kind":"text","text":"; like as one says"},{"kind":"arabic","text_bw":"miqoraADN","text_ar":"مِقْرَاضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"miqoraADaAni","text_ar":"مِقْرَاضَانِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qalamN","text_ar":"قَلَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qalamaAni","text_ar":"قَلَمَانِ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"jalamaAnN","text_ar":"جَلَمَانٌ","orth_type":"arrow"},{"kind":"text","text":"is also allowable, as a sing.; (Msb;) authorized by Ks; (TA;) and in like manner,"},{"kind":"arabic","text_bw":"qalamaAnN","text_ar":"قَلَمَانٌ"},{"kind":"text","text":". (Msb. [But see"},{"kind":"arabic","text_bw":"miqoraADN","text_ar":"مِقْرَاضٌ"},{"kind":"text","text":".]) ―         -b2-  (assumed tropical:)  The"},{"kind":"italic_en","text":"moon;"},{"kind":"text","text":"(Az, K;) as also ↓"},{"kind":"arabic","text_bw":"jayolamN","text_ar":"جَيْلَمٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the ["},{"kind":"italic_en","text":"new moon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moon when it is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hilaAl","text_ar":"هِلَال"},{"kind":"text","text":": (K:) likened to the"},{"kind":"arabic","text_bw":"jalam","text_ar":"جَلَم"},{"kind":"text","text":"[as meaning the blade of a pair of shears]. (TA.) ―         -b3-  [Hence also, probably,] (assumed tropical:)"},{"kind":"italic_en","text":"A certain mark of camels, made with a hot iron."},{"kind":"text","text":"(Ibn-Habeeb, K.) ―         -b4-  [Hence also,] (assumed tropical:)  The"},{"kind":"italic_en","text":"tick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ticks."},{"kind":"text","text":"(K.) ―         -b5-  And, accord. to some, as being likened to these, because of their smallness, (TA,) (assumed tropical:)  The"},{"kind":"italic_en","text":"sheep of Mekkeh:"},{"kind":"text","text":"(A'Obeyd, TA:) or"},{"kind":"italic_en","text":"certain sheep with long and hairless legs, found at Et-Táïf."},{"kind":"text","text":"(K.) And (assumed tropical:)  The"},{"kind":"italic_en","text":"male of the gazelle,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the sheep:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"jilaAmN","text_ar":"جِلَامٌ"},{"kind":"text","text":". (K.) And (assumed tropical:)"},{"kind":"italic_en","text":"A kid:"},{"kind":"text","text":"(Kr, K:) pl. as above. (S, TA.)"}],"source_refs":["S","K","TA","Kr"]}]},"classical_definitions":null}