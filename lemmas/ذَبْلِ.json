{"lemma":"ذَبْلِ","slug":"ذَبْلِ","root":"ذ.ب.ل","root_slug":"ذ-ب-ل","root_link":"/words/roots/ذ-ب-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n13705","n13708","n13709"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D8%A8%D9%92%D9%84%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13705","headword_ar":"ذَبَلَ","root":"*bl","body":[{"kind":"text","text":", (T, S, M, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*abolN","text_ar":"ذَبْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*ubuwlN","text_ar":"ذُبُولٌ"},{"kind":"text","text":"; (S, M, Msb, K;) and"},{"kind":"arabic","text_bw":"*abula","text_ar":"ذَبُلَ"},{"kind":"text","text":"; (S, Sgh, K;) said of a branch, (T,) or a herb, (S,) or a plant, (M, K,) or a thing, (Msb,)"},{"kind":"italic_en","text":"It withered;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"lost its moisture;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"became thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsubstantial, after being succulent;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"*awiYa","text_ar":"ذَوِىَ"},{"kind":"text","text":". (S, K.) And in like manner it is said of a man: (M:) or"},{"kind":"arabic","text_bw":"*ubuwlN","text_ar":"ذُبُولٌ"},{"kind":"text","text":"[in relation to a human being] signifies the"},{"kind":"italic_en","text":"drying up by reason of the loss of the beauty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodliness, of youth."},{"kind":"text","text":"(Ham p. 478.) And said of a horse, (S, K,) inf. n."},{"kind":"arabic","text_bw":"*abolN","text_ar":"ذَبْلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light of flesh; slender and lean;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lean, and lank in the belly."},{"kind":"text","text":"(S, K.) You say also,"},{"kind":"arabic","text_bw":"*abala fuwhu","text_ar":"ذَبَلَ فُوهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*ubuwlN","text_ar":"ذُبُولٌ"},{"kind":"text","text":"(T, TA) and"},{"kind":"arabic","text_bw":"*abolN","text_ar":"ذَبْلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"May his mouth, and his saliva,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spittle, dry up."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA lahu *abala","text_ar":"مَا لَهُ ذَبَلَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*aboluhu","text_ar":"ذَبْلُهُ","orth_type":"arrow"},{"kind":"text","text":", (M, K, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"*abolapF","text_ar":"ذَبْلَةً"},{"kind":"text","text":",]) i. e. ["},{"kind":"italic_en","text":"What aileth him?"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"may his stock"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aSoluhu","text_ar":"اَصْلُهُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"wither:"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"his body and his flesh:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"may his marriage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coition, be ineffectual:"},{"kind":"text","text":"(M, TA:) said in reviling: (TA:) as also"},{"kind":"arabic","text_bw":"dabala daboluhu","text_ar":"دَبَلَ دَبْلُهُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"dbl","text_ar":"دبل"},{"kind":"text","text":".) One says also, in reviling, (TA,) ↓"},{"kind":"arabic","text_bw":"*abalatohumo *ubayolapN","text_ar":"ذَبَلَتْهُمْ ذُبَيْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"dubayolapF","text_ar":"دُبَيْلَةً"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"May a calamity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortune, befall them:"},{"kind":"text","text":"or]"},{"kind":"page_break","n":956},{"kind":"italic_en","text":"may they perish."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"*blt *bAy^lh","text_ar":"ذبلت ذبايله"},{"kind":"text","text":"[app. a mistranscription for ↓"},{"kind":"arabic","text_bw":"*abalatohu *abaAy^ilu","text_ar":"ذَبَلَتْهُ ذَبَايِلُ","orth_type":"arrow"},{"kind":"italic_en","text":"May calamities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortunes, befall him"},{"kind":"text","text":"]. (TA.) And ↓"},{"kind":"arabic","text_bw":"*abalatohu *abuwlN","text_ar":"ذَبَلَتْهُ ذَبُولٌ","orth_type":"arrow"},{"kind":"text","text":"(T, TA) and"},{"kind":"arabic","text_bw":"dabuwlN","text_ar":"دَبُولٌ"},{"kind":"text","text":"(T)"},{"kind":"italic_en","text":"May a calamity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortune, befall him."},{"kind":"text","text":"(TA.) [See the latter part of the first paragraph of art."},{"kind":"arabic","text_bw":"dbl","text_ar":"دبل"},{"kind":"text","text":".]"}],"source_refs":["T","S","M","Msb","K","TA"]},{"entry_id":"n13708","headword_ar":"ذَبْلٌ","root":"*bl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"prime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first part,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mayoEap","text_ar":"مَيْعَة"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of youth."},{"kind":"text","text":"(Ibn- 'Abbád, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"maA lahu *abala *aboluhu","text_ar":"مَا لَهُ ذَبَلَ ذَبْلُهُ"},{"kind":"text","text":": see 1.       -A2-  Accord. to As, one says ↓"},{"kind":"arabic","text_bw":"*abolN *aAbilN","text_ar":"ذَبْلٌ ذَابِلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"*aAbilN","text_ar":"ذَابِلٌ","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*ibolN","text_ar":"ذِبْلٌ","orth_type":"arrow"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Deep"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"abasement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy:"},{"kind":"text","text":"and accord. to IAar, (T,) ↓"},{"kind":"arabic","text_bw":"*abiylN","text_ar":"ذَبِيلٌ","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*ibolN","text_ar":"ذِبْلٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"severe bereavement."},{"kind":"text","text":"(T, K.) ↓"},{"kind":"arabic","text_bw":"*abolFA *abiylFA","text_ar":"ذَبْلًا ذَبِيلًا","orth_type":"arrow"},{"kind":"text","text":", (M, K,) or ↓"},{"kind":"arabic","text_bw":"*abiylFA","text_ar":"ذَبِيلًا","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*ibolFA","text_ar":"ذِبْلًا","orth_type":"arrow"},{"kind":"text","text":", (M,) is a form of imprecation [but app. not intended as such, lit. meaning May God send upon such a one"},{"kind":"italic_en","text":"deep abasement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severe bereavement"},{"kind":"text","text":"]: (M, K:) and one says also ↓"},{"kind":"arabic","text_bw":"*abolFA *aAbilFA","text_ar":"ذَبْلًا ذَابِلًا","orth_type":"arrow"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"*aAbilFA","text_ar":"ذَابِلًا","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*ibolFA","text_ar":"ذِبْلًا","orth_type":"arrow"},{"kind":"text","text":", (M,) meaning [likewise"},{"kind":"italic_en","text":"deep"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"abasement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"severe bereavement."},{"kind":"text","text":"(M, TA.) [See also"},{"kind":"arabic","text_bw":"dibolN","text_ar":"دِبْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dabiylN","text_ar":"دَبِيلٌ"},{"kind":"text","text":".]       -A3-  Also ["},{"kind":"italic_en","text":"Turtle-shell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tortoise-shell;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"(IAar, S, Msb,) or"},{"kind":"italic_en","text":"skin,"},{"kind":"text","text":"(M, K,) [meaning"},{"kind":"italic_en","text":"shell,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the sea-tortoise"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"turtle"},{"kind":"text","text":"], (IAar, S, M, Msb, K,) or"},{"kind":"italic_en","text":"of the land-tortoise,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"of which are made combs,"},{"kind":"text","text":"(IAar, TA,)"},{"kind":"italic_en","text":"and,"},{"kind":"text","text":"as some say,"},{"kind":"italic_en","text":"signet-rings"},{"kind":"text","text":"&c., (TA,) or"},{"kind":"italic_en","text":"of which bracelets are made:"},{"kind":"text","text":"(S:) or the"},{"kind":"italic_en","text":"bones of the back of a certain marine beast, of which are made,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"by women,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"bracelets"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"and combs; and the combing wherewith removes nits and the scurf of the hair:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"horns of which are made"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the bracelets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anklets, called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"masaka","text_ar":"مَسَكَ"},{"kind":"text","text":": (En-Nadr, TA:) or"},{"kind":"italic_en","text":"a certain thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"substance"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"resembling ivory:"},{"kind":"text","text":"(Msb:) Th cites a poet as using the phrase"},{"kind":"arabic","text_bw":"*aAtu Al*~abalaAt","text_ar":"ذَاتُ الذَّبَلَات"},{"kind":"text","text":", forming the pl. of"},{"kind":"arabic","text_bw":"*abolN","text_ar":"ذَبْلٌ"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"; but accord. to the citation of IAar, the word in this instance is"},{"kind":"arabic","text_bw":"Alr~abalaAt","text_ar":"الرَّبَلَات"},{"kind":"text","text":". (M.)"}],"source_refs":["T","M","K","TA","IAar","S","Msb"]},{"entry_id":"n13709","headword_ar":"ذِبْلٌ","root":"*bl","body":[{"kind":"text","text":": see the next preceding paragraph, in four places."}],"source_refs":[]}]},"classical_definitions":null}