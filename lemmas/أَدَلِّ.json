{"lemma":"أَدَلِّ","slug":"أَدَلِّ","root":"د.ل.ل","root_slug":"د-ل-ل","root_link":"/words/roots/د-ل-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n12875","n12877","n12900"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%8E%D9%84%D9%90%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12875","headword_ar":"ادلّ","root":"dl","body":[{"kind":"text","text":": see 1.       -A2-"},{"kind":"arabic","text_bw":"Adl~ Ealayohi","text_ar":"ادلّ عَلَيْهِ"},{"kind":"italic_en","text":"He acted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved, with boldness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"presumptuousness, towards him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AinobasaTa Ealayohi","text_ar":"اِنْبَسَطَ عَلَيْهِ"},{"kind":"text","text":"; (M, K;) as also ↓"},{"kind":"arabic","text_bw":"tdl~l","text_ar":"تدلّل","orth_type":"arrow"},{"kind":"text","text":": (M, Mgh, * K:) and"},{"kind":"arabic","text_bw":"hiYa tudil~u Ealayohi","text_ar":"هِىَ تُدِلُّ عَلَيْهِ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"tatadal~alu","text_ar":"تَتَدَلَّلُ","orth_type":"arrow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"She emboldens herself against him."},{"kind":"text","text":"(T.) Imrael-Keys says,"},{"kind":"quote","text":"↓ \n      A^afaATima maholFA baEoDa h`*Aa Alt~adal~uli\n                      \n                     \n                        faA_ino kunoti qado A^azomaEoti SaromiY faA^ajomiliY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O Fátimeh"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"fATm","text_ar":"فاطم"},{"kind":"text","text":"being a contraction of"},{"kind":"arabic","text_bw":"faATimapu","text_ar":"فَاطِمَةُ"},{"kind":"text","text":"), act thou"},{"kind":"italic_en","text":"gently:"},{"kind":"text","text":"relinquish"},{"kind":"italic_en","text":"somewhat of this boldness;"},{"kind":"text","text":"(or, as is said in the EM, p. 15,"},{"kind":"italic_en","text":"of this amorous gesture"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaviour, and coquettish boldness, and feigned coyness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opposition;"},{"kind":"text","text":"see 1;)"},{"kind":"italic_en","text":"and if thou have determined upon cutting me, act with goodness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moderation"},{"kind":"text","text":"]. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He confided in his love, and therefore acted presumptuously towards him."},{"kind":"text","text":"(IDrd, M, K. *) In the copies of the K,"},{"kind":"arabic","text_bw":"A^awovaqa","text_ar":"اَوْثَقَ"},{"kind":"text","text":"is here put in the place of"},{"kind":"arabic","text_bw":"waviqa","text_ar":"وَثِقَ"},{"kind":"text","text":". (TA.) [And in the CK,"},{"kind":"arabic","text_bw":"A^awovaqa biHab~atih","text_ar":"اَوْثَقَ بِحَبَّتِه"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"waviqa bimuHab~itihi","text_ar":"وَثِقَ بِمُحَبِّتِهِ"},{"kind":"text","text":".] Hence, (TA,) one says,"},{"kind":"arabic","text_bw":"A^adal~a faA^amal~a","text_ar":"اَدَلَّ فَاَمَلَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He acted presumptuously, confiding in another's love, and disgusted"},{"kind":"text","text":"]: (S, M, TA:) a prov. (M, TA.) ―         -b3-  One says also,"},{"kind":"arabic","text_bw":"huwa yudil~u bifulaAnK","text_ar":"هُوَ يُدِلُّ بِفُلَانٍ"},{"kind":"text","text":", meaning [simply]"},{"kind":"italic_en","text":"He confides in such a one."},{"kind":"text","text":"(S.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Adl~ EalaY A^aqoraAnihi","text_ar":"ادلّ عَلَى اَقْرَانِهِ"},{"kind":"text","text":", (S, M, K,) meaning"},{"kind":"arabic","text_bw":"A^axa*ahumo mino fawoqK","text_ar":"اَخَذَهُمْ مِنْ فَوْقٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He overcame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overpowered, his adversaries"},{"kind":"text","text":"], (M, K,) in war, or battle: (S:) and so"},{"kind":"arabic","text_bw":"AlbaAziY EalaY","text_ar":"البَازِى عَلَى"},{"kind":"arabic","text_bw":"Sayodihi","text_ar":"صَيْدِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the hawk, his prey,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarry"},{"kind":"text","text":"]. (S, M, K.)       -A3-"},{"kind":"arabic","text_bw":"Adl~","text_ar":"ادلّ"},{"kind":"text","text":"said of a wolf,"},{"kind":"italic_en","text":"He became mangy,"},{"kind":"text","text":"or"},{"kind":"page_break","n":901},{"kind":"italic_en","text":"scabby, and lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated, and small in body."},{"kind":"text","text":"(Sgh, K.)"}],"source_refs":["TA","S","M","K"]},{"entry_id":"n12877","headword_ar":"اِدَّلَّ","root":"dl","body":[{"kind":"text","text":", first pers."},{"kind":"arabic","text_bw":"Aid~alalotu","text_ar":"اِدَّلَلْتُ"},{"kind":"text","text":": see 1."}],"source_refs":[]},{"entry_id":"n12900","headword_ar":"اَدَلٌّ","root":"dl","body":[{"kind":"italic_en","text":"Very bountiful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beneficent."},{"kind":"text","text":"(IAar, T.)"}],"source_refs":[]}]},"classical_definitions":null}