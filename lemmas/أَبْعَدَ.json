{"lemma":"أَبْعَدَ","slug":"أَبْعَدَ","root":"ب.ع.د","root_slug":"ب-ع-د","root_link":"/words/roots/ب-ع-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n2863","n2877"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D9%92%D8%B9%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2863","headword_ar":"ابعد","root":"bEd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iboEaAdN","text_ar":"اـِبْعَادٌ"},{"kind":"text","text":": see 1, in seven places.       -A2-"},{"kind":"arabic","text_bw":"AbEdhu","text_ar":"ابعدهُ"},{"kind":"text","text":"; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"bAEdhu","text_ar":"باعدهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"mubaAEadapN","text_ar":"مُبَاعَدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biEaAdN","text_ar":"بِعَادٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"bE~dhu","text_ar":"بعّدهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"taboEiydN","text_ar":"تَبْعِيدٌ"},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, distant, remote, far off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aloof;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to go, remove, retire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdraw himself, to a distance, far away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off; he placed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, at a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sent, away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he removed far away, alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, Msb.) You say,"},{"kind":"arabic","text_bw":"nafosaka Eano zayodK","text_ar":"نَفْسَكَ عَنْ زَيْدٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baAEido","text_ar":"بَاعِدْ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Remove thyself far from;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoid thou, Zeyd"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"zayodFA Eanoka","text_ar":"زَيْدًا عَنْكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baAEido","text_ar":"بَاعِدْ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Remove thou Zeyd far from thee"},{"kind":"text","text":"]. (TA, voce"},{"kind":"arabic","text_bw":"A_iy~aA","text_ar":"اـِيَّا"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"bayonahumaA","text_ar":"بَيْنَهُمَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baE~adotu","text_ar":"بَعَّدْتُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taboEiydN","text_ar":"تَبْعِيدٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I made a wide separation between them two"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"baAEadotu","text_ar":"بَاعَدْتُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mubaAEadapN","text_ar":"مُبَاعَدَةٌ"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"A@ll~`hu","text_ar":"ا@للّٰهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baAEada","text_ar":"بَاعَدَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"maA bayonahumaA","text_ar":"مَا بَيْنَهُمَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God make the space between them two far extending! may He make a wide separation between them two!"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"baE~ada","text_ar":"بَعَّدَ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"bayona A^asofaArinaA","text_ar":"بَيْنَ اَسْفَارِنَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rab~anaA baAEido","text_ar":"رَبَّنَا بَاعِدْ","orth_type":"arrow"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"baE~ido","text_ar":"بَعِّدْ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"O our Lord, make to be far-extending the spaces between our journeys!"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"put wide distances between our journeys!"},{"kind":"text","text":"] accord. to different readings [in the Kur xxxiv. 18]: the former of these is the common reading: Yaakoob El-Hadramee read ↓"},{"kind":"arabic","text_bw":"rab~unaA baAEada","text_ar":"رَبُّنَا بَاعَدَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Alx","text_ar":"الخ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Our Lord, He hath made to be far extending"},{"kind":"text","text":"&c.]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^aboEadahu A@ll~`hu","text_ar":"اَبْعَدَهُ ا@للّٰهُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"May God alienate him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estrange him, from good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity!"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"curse him!"},{"kind":"text","text":"(K;) i. e., may he not be pitied with respect to that which has befallen him! (TA.) [You say also,"},{"kind":"arabic","text_bw":"A^aboEada A@ll~`hu AlA^axira","text_ar":"اَبْعَدَ ا@للّٰهُ الاَخِرَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^axirN","text_ar":"اَخِرٌ"},{"kind":"text","text":".] ―         -b3-  See also 10.       -A3-"},{"kind":"arabic","text_bw":"maA A^aboEadahu mina AlS~awaAbi","text_ar":"مَا اَبْعَدَهُ مِنَ الصَّوَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How far is it"},{"kind":"text","text":"(namely the saying)"},{"kind":"italic_en","text":"from what is right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correct!"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","K"]},{"entry_id":"n2877","headword_ar":"اَبْعَدُ","root":"bEd","body":[{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, distant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote; further,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"furthest:"},{"kind":"text","text":"by poetic licence written"},{"kind":"arabic","text_bw":"A^aboEad~u","text_ar":"اَبْعَدُّ"},{"kind":"text","text":": (L:) [pl."},{"kind":"arabic","text_bw":"A^abaAEidu","text_ar":"اَبَاعِدُ"},{"kind":"text","text":"; as in the saying,]"},{"kind":"arabic","text_bw":"fulaAnN yasotajir~u","text_ar":"فُلَانٌ يَسْتَجِرُّ"},{"kind":"arabic","text_bw":"AlHadiyva mino A^abaAEidi A^aToraAfihi","text_ar":"الحَدِيثَ مِنْ اَبَاعِدِ اَطْرَافِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one draws forth talk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"news,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, from its most remote sources"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, extreme, excessive, egregious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinary,"},{"kind":"text","text":"in its kind. (IAth.) [Hence, perhaps,]"},{"kind":"arabic","text_bw":"A_in~ahu lagayoru","text_ar":"اـِنَّهُ لَغَيْرُ"},{"kind":"arabic","text_bw":"A^aboEada","text_ar":"اَبْعَدَ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"A^aboEadK","text_ar":"اَبْعَدٍ"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"buEadK","text_ar":"بُعَدٍ","orth_type":"arrow"},{"kind":"italic_en","text":"Verily there is no good in him:"},{"kind":"text","text":"(K:) or,"},{"kind":"italic_en","text":"no depth in him in anything:"},{"kind":"text","text":"(IAar:) [or,"},{"kind":"italic_en","text":"he is not extraordinary"},{"kind":"text","text":"in his kind: see also"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":":] said in dispraising one. (TA.) And"},{"kind":"arabic","text_bw":"maA Einodahu A^aboEadu","text_ar":"مَا عِنْدَهُ اَبْعَدُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"buEadN","text_ar":"بُعَدٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has not what is extraordinary"},{"kind":"text","text":"in its kind: or]"},{"kind":"italic_en","text":"he possesses not excellence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"riches:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he possesses not anything profitable:"},{"kind":"text","text":"(L, K:) said only in dispraising one: (AZ:) or it may mean"},{"kind":"italic_en","text":"he possesses not anything which one would go far to seek;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"anything of value:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he possesses, of things or qualities that are desirable, is more extraordinary than what others possess."},{"kind":"text","text":"(MF.) ―         -b3-"},{"kind":"italic_en","text":"Remote from good:"},{"kind":"text","text":"[which is the meaning generally intended in the present day when it is used absolutely as an epithet applied to a man; but meaning also"},{"kind":"italic_en","text":"remote"},{"kind":"text","text":"from him or those in whose presence this epithet is used, both"},{"kind":"italic_en","text":"as to place and as to moral condition:"},{"kind":"text","text":"] and,"},{"kind":"italic_en","text":"from continence:"},{"kind":"text","text":"(L:) and"},{"kind":"italic_en","text":"stupid; foolish;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no, intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAy^inN","text_ar":"حَايِنٌ"},{"kind":"text","text":": (so in a copy of the S and in the L and TA:) or"},{"kind":"italic_en","text":"treacherous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfaithful;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xaAy^inN","text_ar":"خَايِنٌ"},{"kind":"text","text":"(So in two copies of the S and in a copy of the A.) It is used as an allusion to the name of a person whom one would mention with dispraise; as when one says,"},{"kind":"arabic","text_bw":"halaka AlA^aboEadu","text_ar":"هَلَكَ الاَبْعَدُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May such a one, the remote from good,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"perish!"},{"kind":"text","text":"]: with respect to a woman, one says,"},{"kind":"arabic","text_bw":"halakati AlbuEodaY","text_ar":"هَلَكَتِ البُعْدَى"},{"kind":"text","text":". (En-Nadr, Az.) One says also,"},{"kind":"arabic","text_bw":"kab~a A@ll~`hu AlA^aboEada lifiyhi","text_ar":"كَبَّ ا@للّٰهُ الاَبْعَدَ لِفِيهِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"May God cast down prostrate such a one, the remote from good,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"upon his mouth!"},{"kind":"text","text":"or,]"},{"kind":"italic_en","text":"cast him down upon his face!"},{"kind":"text","text":"(S.) [It is a rule observed in decent society, by the Arabs, to avoid, as much as possible, the mention of opprobrious epithets, lest any person present should imagine an epithet of this kind to be slily applied to himself: therefore, when any malediction or vituperation is uttered, it is usual to allude to the object by the term"},{"kind":"arabic","text_bw":"AlA^aboEad","text_ar":"الاَبْعَد"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"AlbaEiyd","text_ar":"البَعِيد"},{"kind":"text","text":", as meaning the remote from good, &c., and also the remote from the person or persons present. See also"},{"kind":"arabic","text_bw":"AlA^axiru","text_ar":"الاَخِرُ"},{"kind":"text","text":", which is used in a similar manner.] ―         -b4-"},{"kind":"italic_en","text":"A more distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very distant, relation;"},{"kind":"text","text":"(Lth;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^aqorabu","text_ar":"اَقْرَبُ"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"A^abaAEidu","text_ar":"اَبَاعِدُ"},{"kind":"text","text":"(Lth, S, A, Msb, K) and"},{"kind":"arabic","text_bw":"A^aboEaduwna","text_ar":"اَبْعَدُونَ"},{"kind":"text","text":"; (Lth;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^aqaAribu","text_ar":"اَقَارِبُ"},{"kind":"text","text":"(Lth, S, K) and"},{"kind":"arabic","text_bw":"A^aqorabuwna","text_ar":"اَقْرَبُونَ"},{"kind":"text","text":". (Lth.)"}],"source_refs":["L","K","IAar","AZ","Msb","Lth","S","A"]}]}}