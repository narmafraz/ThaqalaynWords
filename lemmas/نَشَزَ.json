search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%8E%D8%B2%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39822","headword_ar":"نَشَزٌ","root":"n$z","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"na$ozN","text_ar":"نَشْزٌ"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"nu$uwzN","text_ar":"نُشُوزٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raised himself,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"arabic","text_bw":"fiY AlmakaAni","text_ar":"فِى المَكَانِ"},{"kind":"italic_en","text":"in the place,"},{"kind":"text","text":"(S,) and"},{"kind":"arabic","text_bw":"fiY majolisihi","text_ar":"فِى مَجْلِسِهِ"},{"kind":"italic_en","text":"in his sitting-place,"},{"kind":"text","text":"(TA,) and"},{"kind":"arabic","text_bw":"Eano makaAnihi","text_ar":"عَنْ مَكَانِهِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"mino makaAnihi","text_ar":"مِنْ مَكَانِهِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"from his place:"},{"kind":"text","text":"(A, Msb:) or"},{"kind":"italic_en","text":"he rose a little"},{"kind":"text","text":"in his sittingplace: (TA:) or"},{"kind":"italic_en","text":"he stood up after sitting."},{"kind":"text","text":"(TA.) Both forms of the aor. occur, accord. to different readings, (the former being the reading of the people of El-Hijáz, and the latter that of others, Fr, TA,) in the Kur, [lviii. 12,]"},{"kind":"arabic","text_bw":"waA_i*aA qiyla A@no$uizuwA","text_ar":"وَاـِذَا قِيلَ ا@نْشُِزُوا"},{"kind":"arabic","text_bw":"faA@no$uizuwA","text_ar":"فَا@نْشُِزُوا"},{"kind":"text","text":", (Msb, TA,) meaning, accord. to Aboo-Is-hák,"},{"kind":"italic_en","text":"And when it is said, Rise ye and stand up, then do ye rise and stand up."},{"kind":"text","text":"(TA.) Accord. to IKtt,"},{"kind":"arabic","text_bw":"na$aza Alqawomu fiY majolisihimo","text_ar":"نَشَزَ القَوْمُ فِى مَجْلِسِهِمْ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The people drew themselves together"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in their sitting-place"},{"kind":"text","text":"to make room] for those sitting with them: and also"},{"kind":"italic_en","text":"they rose from their sitting-place, and stood up."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"na$aza biAlqawomi fiY AlxuSuwmapi","text_ar":"نَشَزَ بِالقَوْمِ فِى الخُصُومَةِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nu$uwzN","text_ar":"نُشُوزٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He rose with the people for the purpose of contention, altercation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, overtopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overlooked, an elevated piece of ground, and appeared."},{"kind":"text","text":"(TA.) ―         -b3-  ["},{"kind":"italic_en","text":"It rose; rose from its place; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, protuberant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prominent; it protruded."},{"kind":"text","text":"] ―         -b4-"},{"kind":"arabic","text_bw":"na$azato nafosuhu","text_ar":"نَشَزَتْ نَفْسُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stomach, heaved,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"by reason of fright."},{"kind":"text","text":"(A, TA.)       -A2-  Hence, from"},{"kind":"arabic","text_bw":"na$aza","text_ar":"نَشَزَ"},{"kind":"text","text":"in the first of the senses explained above, (Msb,) or from"},{"kind":"arabic","text_bw":"na$ozN","text_ar":"نَشْزٌ"},{"kind":"text","text":", signifying “ high, or elevated, ground, ” (Aboo-Is- hák, TA,)"},{"kind":"arabic","text_bw":"na$azati AlmaroA^apu","text_ar":"نَشَزَتِ المَرْاَةُ"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"na$azato EalaY zawojihaA","text_ar":"نَشَزَتْ عَلَى زَوْجِهَا"},{"kind":"text","text":", (A, Mgh, TA,) or"},{"kind":"arabic","text_bw":"mino zawojihaA","text_ar":"مِنْ زَوْجِهَا"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"bizawojihaA","text_ar":"بِزَوْجِهَا"},{"kind":"text","text":", (TA,) aor. - and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nu$uwzN","text_ar":"نُشُوزٌ"},{"kind":"text","text":", (S, Msb, K,) (tropical:)"},{"kind":"italic_en","text":"The woman,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wife, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disobedient to her husband,"},{"kind":"text","text":"(S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"and exalted herself against him,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and resisted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withstood him,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and hated him,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"and deserted him:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"she disliked him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated him,"},{"kind":"text","text":"(Zj, Mgh, TA,)"},{"kind":"italic_en","text":"and was an evil companion to him."},{"kind":"text","text":"(Zj, TA.) And"},{"kind":"arabic","text_bw":"na$aza baEoluhaA","text_ar":"نَشَزَ بَعْلُهَا"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"text","text":", (S, A, K,) or"},{"kind":"arabic","text_bw":"minohaA","text_ar":"مِنْهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"nu$uwzN","text_ar":"نُشُوزٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"Her husband treated her injuriously, and was unkind to her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged himself from her:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"forsook her, and was unkind to her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged himself from her:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"disliked her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated her,"},{"kind":"text","text":"(Zj, Mgh, TA,)"},{"kind":"italic_en","text":"and was an evil companion to her."},{"kind":"text","text":"(Zj, TA.)"}],"source_refs":["S","Msb","K","A","TA","Mgh","Zj"]},{"entry_id":"n39825","headword_ar":"نَشَزٌ","root":"n$z","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"na$ozN","text_ar":"نَشْزٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n39824","headword_ar":"نَشْزٌ","root":"n$z","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"na$azN","text_ar":"نَشَزٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an elevated, place;"},{"kind":"text","text":"(S, A, Mgh, K;) as also ↓"},{"kind":"arabic","text_bw":"na$aAzN","text_ar":"نَشَازٌ","orth_type":"arrow"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, ground:"},{"kind":"text","text":"(Zj, TA:) or"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, and hard, ground:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"what rises from a valley to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"adjacent"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ground, and is not rugged:"},{"kind":"text","text":"(TA:) pl. (of the first, S, Msb)"},{"kind":"arabic","text_bw":"nu$uwzN","text_ar":"نُشُوزٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,) and (of the second, S, TA, or of the first, Msb)"},{"kind":"arabic","text_bw":"ni$aAzN","text_ar":"نِشَازٌ"},{"kind":"text","text":", (S, Msb, K,) and (of the second, S, Msb,)"},{"kind":"arabic","text_bw":"A^ano$aAzN","text_ar":"اَنْشَازٌ"},{"kind":"text","text":". (S, Mgh, Msb, K.) You say,"},{"kind":"arabic","text_bw":"qaEada EalaY na$ozK mina AlA^aroDi","text_ar":"قَعَدَ عَلَى نَشْزٍ مِنَ الاَرْضِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"na$azK","text_ar":"نَشَزٍ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He sat upon a high piece of ground."},{"kind":"text","text":"] (Msb.) And"},{"kind":"arabic","text_bw":"A^uqoEudo ElY *`lika Aln~a$aAzi","text_ar":"اُقْعُدْ على ذٰلِكَ النَّشَازِ"},{"kind":"italic_en","text":"Sit thou upon that high place."},{"kind":"text","text":"(S.)"}],"source_refs":["S","K","Zj","TA","M","Mgh","Msb"]}]},"classical_definitions":null}