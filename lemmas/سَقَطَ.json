{"lemma":"سَقَطَ","slug":"سَقَطَ","root":"س.ق.ط","root_slug":"س-ق-ط","root_link":"/words/roots/س-ق-ط","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَقَطْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَقَطْتِ","in_corpus":true,"count":26,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَقَطْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَقَطْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَقَطْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَقَطَ","in_corpus":true,"count":61,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَقَطَت","in_corpus":true,"count":26,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَقَطا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَقَطَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَقَطُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَقَطْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْقُط","in_corpus":true,"count":11,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْقُطِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْقُطِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْقُطانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْقُطا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْقُطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْقُطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْقُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْقُط","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْقُط","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْقُطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْقُطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْقُطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْقُطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْقُطُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْقُطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْقُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَقَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَقَطْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْقُط","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْقُط","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":188,"cross_references":{"qac":{"found":true,"lemma_key":"سَقَطَ","root":"سقط","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n20075"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%82%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fall, to collapse, to descend"},{"pos":"adj","gloss":"defective; worthless; inadequate"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20075","headword_ar":"سَقَطَ","root":"sqT","body":[{"kind":"text","text":", (S, M, &c.,) aor."},{"kind":"text","text":", (M, MS,) inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":"(S, M, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"masoqaTN","text_ar":"مَسْقَطٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"It fell; fell down; dropped; dropped down; tumbled down;"},{"kind":"text","text":"(M, Mgh, Msb, K;)"},{"kind":"italic_en","text":"upon the ground;"},{"kind":"text","text":"(Mgh;) or"},{"kind":"italic_en","text":"from a higher to a lower place;"},{"kind":"text","text":"(Msb;) namely, a thing from the hand; (S;) or from a high place, as a roof of a house; and from a low place, as when said of a person in an erect posture; (B;) also said of a building; (TA in art."},{"kind":"arabic","text_bw":"hwr","text_ar":"هور"},{"kind":"text","text":";) and of a"},{"kind":"arabic","text_bw":"jurof","text_ar":"جُرْف"},{"kind":"text","text":"[q. v.]: (Msb and TA in that art.:) [and often used by anatomists and physicians, as meaning"},{"kind":"italic_en","text":"it delapsed; it slipped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fell, down:"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"Ais~aAqaTa","text_ar":"اِسَّاقَطَ","orth_type":"arrow"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"tasaAqaTa","text_ar":"تَسَاقَطَ"},{"kind":"text","text":"] signifies the same; (K;) as in the phrase in the Kur [xix. 25],"},{"kind":"arabic","text_bw":"tas~aAqaTo Ealayoki ruTabFA janiy~FA","text_ar":"تَسَّاقَطْ عَلَيْكِ رُطَبًا جَنِيًّا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"yas~aAqaTo","text_ar":"يَسَّاقَطْ"},{"kind":"text","text":", accord. to different readings,"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"namely the palm-tree ("},{"kind":"arabic","text_bw":"naxolap","text_ar":"نَخْلَة"},{"kind":"text","text":") accord. to the former reading, and the trunk ("},{"kind":"arabic","text_bw":"ji*oE","text_ar":"جِذْع"},{"kind":"text","text":") accord. to the latter reading,"},{"kind":"italic_en","text":"shall drop upon thee with fresh ripe dates, plucked;"},{"kind":"arabic","text_bw":"rTbA jny~A","text_ar":"رطبا جنيّا"},{"kind":"text","text":"being transferred from its proper place, and used as a specificative; the meaning being,"},{"kind":"arabic","text_bw":"yas~aAqaTo ruTabu Alji*oEi","text_ar":"يَسَّاقَطْ رُطَبُ الجِذْعِ"},{"kind":"text","text":": so says Fr. (Az, TA.) [This phrase of the Kur, with the above-mentioned explanation, but less fully given, occurs in a copy of the S which, throughout this art., differs much from other copies.] You say also,"},{"kind":"arabic","text_bw":"saqaTa fulaAnN mago$iy~FA Ealayohi","text_ar":"سَقَطَ فُلَانٌ مَغْشِيًّا عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one fell down in a swoon"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"mano naAzaEa A^aTowala minohu saqaTa","text_ar":"مَنْ نَازَعَ اَطْوَلَ مِنْهُ سَقَطَ"},{"kind":"arabic","text_bw":"Al$~agozabiy~apa","text_ar":"الشَّغْزَبِيَّةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who contends with one taller than himself falls by the trick which consists in one's twisting his leg with the leg of the other"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"saqaTa Alwaladu mino baToni A^umihi","text_ar":"سَقَطَ الوَلَدُ مِنْ بَطْنِ اُمِهِ"},{"kind":"text","text":", (Kh, S, Msb, K,)"},{"kind":"page_break","n":1380},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"The child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fœtus, came forth"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fell"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the belly of its mother"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"abortively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in an immature,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfect, state,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"dead,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"but having the form developed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifest:"},{"kind":"text","text":"(Msb:) you do not say"},{"kind":"arabic","text_bw":"waqaEa","text_ar":"وَقَعَ"},{"kind":"text","text":"(Kh, S, Msb, K) unless the child is born alive. (A, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"suqiTa fiYyadihi","text_ar":"سُقِطَ فِىيَدِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^usoqiTa","text_ar":"اُسْقِطَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"ydh","text_ar":"يده"},{"kind":"text","text":", (Fr, Zj, S, M, K,) but the former is more common, and better, (Fr,) the latter allowed by Akh, but disallowed by AA and by Ahmad Ibn-Yahyà [i. e. Th], (S,) [lit."},{"kind":"italic_en","text":"There was a falling,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"there was a making to fall, upon his hand;"},{"kind":"text","text":"i. e., of his hand upon his hand, or of his teeth upon his hand, by reason of repentance, and grief, or regret; meaning] (tropical:)"},{"kind":"italic_en","text":"he repented,"},{"kind":"text","text":"(Fr, Zj, S, M, K,)"},{"kind":"italic_en","text":"of what he had done; and grieved for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regretted, an act of inadvertence;"},{"kind":"text","text":"(Zj, M;) or,"},{"kind":"italic_en","text":"and became confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course:"},{"kind":"text","text":"(O, K:) or both signify, (TA,) or signify also, (K,) or the former signifies also, (M,)"},{"kind":"italic_en","text":"he slipped; fell into an error,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a fault; committed a mistake."},{"kind":"text","text":"(M, K.) Hence the saying in the Kur [vii. 148],"},{"kind":"arabic","text_bw":"walam~aA suqiTa fiY A^ayodiyhimo","text_ar":"وَلَمَّا سُقِطَ فِى اَيْدِيهِمْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"And when they repented:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"struck their hands upon their hands, by reason of repentance;"},{"kind":"text","text":"accord. to AAF: (M:) or"},{"kind":"italic_en","text":"repented greatly;"},{"kind":"text","text":"because he who repents, and grieves, or regrets, bites his hand in sorrow, so that his hand is fallen upon [by his teeth]: (Bd:) the phrase was not known to the Arabs before the time of the Kur-án: (O:) it has also been read"},{"kind":"arabic","text_bw":"saqaTa fY Aydyhm","text_ar":"سَقَطَ فى ايديهم"},{"kind":"text","text":", (Akh, S, M,) as though"},{"kind":"arabic","text_bw":"Aln~adamu","text_ar":"النَّدَمُ"},{"kind":"text","text":"were understood; (Akh, S;) i. e."},{"kind":"arabic","text_bw":"saqaTa Aln~adamu","text_ar":"سَقَطَ النَّدَمُ"},{"kind":"text","text":"; like as you say,"},{"kind":"arabic","text_bw":"qado HaSala","text_ar":"قَدْ حَصَلَ"},{"kind":"arabic","text_bw":"fiY yadihi mino h`*aA makoruwhN","text_ar":"فِى يَدِهِ مِنْ هٰذَا مَكْرُوهٌ"},{"kind":"text","text":", likening what comes into the heart, and into the mind, to what comes into the hand, and is seen with the eye: (M, TA:) and this, as well as the former, is tropical. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"saqaTa Alqamaru","text_ar":"سَقَطَ القَمَرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The moon set:"},{"kind":"text","text":"and in like manner"},{"kind":"arabic","text_bw":"Aln~ajomu","text_ar":"النَّجْمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the star,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asterism;"},{"kind":"text","text":"generally meaning"},{"kind":"italic_en","text":"the Pleiades;"},{"kind":"text","text":"and when this is the case, the phrase in most instances means"},{"kind":"italic_en","text":"the Pleiades set at dawn:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"masoqTN","text_ar":"مَسْقطٌ"},{"kind":"text","text":"]. (Mgh, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"saqaTa","text_ar":"سَقَطَ"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man died."},{"kind":"text","text":"(TA.) ―         -b6-  [And (assumed tropical:)"},{"kind":"italic_en","text":"The man tottered"},{"kind":"text","text":"by reason of age.] You say of an old man,"},{"kind":"arabic","text_bw":"saqaTa mina Alkibari","text_ar":"سَقَطَ مِنَ الكِبَرِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He tottered by reason of age"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"drhm","text_ar":"درهم"},{"kind":"text","text":".) ―         -b7-"},{"kind":"arabic","text_bw":"saqaTa A_ilaY~a Alqawomu","text_ar":"سَقَطَ اـِلَىَّ القَوْمُ"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, alighted at my abode:"},{"kind":"text","text":"(M, K, TA:)"},{"kind":"italic_en","text":"they came to me."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"saqaTa A_ilaY jiyraAnK lahu","text_ar":"سَقَطَ اـِلَى جِيرَانٍ لَهُ"},{"kind":"text","text":", occurring in a trad., means (tropical:)"},{"kind":"italic_en","text":"He came to some neighbours of his, and they gave him refuge, and protected him."},{"kind":"text","text":"(M, TA.) And it is said in a postclassical prov.,"},{"kind":"arabic","text_bw":"HayovumaA saqaTa laqaTa","text_ar":"حَيْثُمَا سَقَطَ لَقَطَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Wherever he alights he picks up"},{"kind":"text","text":"something]: applied to him who practises evasions, shifts, artifices, or the like. (Meyd, and Har p. 660.) ―         -b8-"},{"kind":"arabic","text_bw":"saqaTa EalaY DaAl~atihi","text_ar":"سَقَطَ عَلَى ضَالَّتِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He stumbled upon, lighted on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became acquainted with, the place of his stray,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lost, beast; he lighted on his stray,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lost, beast."},{"kind":"text","text":"(TA.) Mohammad said to El-Hárith Ibn-Hassán, on the latter's asking him respecting a thing,"},{"kind":"arabic","text_bw":"EalaY Alxabiyri saqaTota","text_ar":"عَلَى الخَبِيرِ سَقَطْتَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"On the possessor of knowledge thou hast lighted:"},{"kind":"text","text":"and this is a prov. current among the Arabs. (TA.) And it is said in a prov.,"},{"kind":"quote","text":"saqaTa AlEa$aA='u bihi EalaY siroHaAni"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The evening-meal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supper,"},{"kind":"text","text":"(i. e. the seeking for it,)"},{"kind":"italic_en","text":"made him to fall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light, upon a wolf:"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"srHAn","text_ar":"سرحان"},{"kind":"text","text":", as is said in a copy of the S, is here the name of a certain man: see also art."},{"kind":"arabic","text_bw":"srH","text_ar":"سرح"},{"kind":"text","text":"]: applied to him who seeks an object of desire, and falls into a thing that destroys him. (TA.) ―         -b9-"},{"kind":"arabic","text_bw":"saqaTa","text_ar":"سَقَطَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He descended"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the place which he occupied"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and his place became vacant."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"saqaTa fulaAnN mino manozilatihi","text_ar":"سَقَطَ فُلَانٌ مِنْ مَنْزِلَتِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one fell from his honourable station"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"saqaTa fulaAnN mino EayoniY","text_ar":"سَقَطَ فُلَانٌ مِنْ عَيْنِى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one fell from the place which he held in my regard"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"saqaATapN","text_ar":"سَقَاطَةٌ"},{"kind":"text","text":", as an inf. n., meaning (assumed tropical:)  The"},{"kind":"italic_en","text":"being ignoble in respect of the deeds or qualities of one's ancestors, and of oneself,"},{"kind":"text","text":"[as though its verb were"},{"kind":"arabic","text_bw":"saquTa","text_ar":"سَقُطَ"},{"kind":"text","text":",] is a mistake, although it has been used, for the purpose of assimilation, coupled with"},{"kind":"arabic","text_bw":"waqaAHapN","text_ar":"وَقَاحَةٌ"},{"kind":"text","text":". (Mgh.) ―         -b10-  [Also, (assumed tropical:)"},{"kind":"italic_en","text":"He dropped off; fell behind: he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, remained behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the rear."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"saAqiTN","text_ar":"سَاقِطٌ"},{"kind":"text","text":".] ―         -b11-"},{"kind":"arabic","text_bw":"saqaTa Eani AlT~ariyqi","text_ar":"سَقَطَ عَنِ الطَّرِيقِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He deviated from the road"},{"kind":"text","text":"]. (IAar, TA in art."},{"kind":"arabic","text_bw":"fjr","text_ar":"فجر"},{"kind":"text","text":".) ―         -b12-"},{"kind":"arabic","text_bw":"saqaTa fiY kalaAmihi","text_ar":"سَقَطَ فِى كَلَامِهِ"},{"kind":"text","text":", (M, K,) and"},{"kind":"arabic","text_bw":"bikalaAmihi","text_ar":"بِكَلَامِهِ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":"; (M, TA;) and"},{"kind":"arabic","text_bw":"fY klAmh","text_ar":"فى كلامه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asoqaTa","text_ar":"اَسْقَطَ","orth_type":"arrow"},{"kind":"text","text":"; (S, TA;) (tropical:)"},{"kind":"italic_en","text":"He committed a mistake in his speech."},{"kind":"text","text":"(M, K, TA.) And"},{"kind":"arabic","text_bw":"takal~ama famaA saqaTa bikalimapK","text_ar":"تَكَلَّمَ فَمَا سَقَطَ بِكَلِمَةٍ"},{"kind":"text","text":", (M, TA,) and"},{"kind":"arabic","text_bw":"kalimapF","text_ar":"كَلِمَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^asoqaTa","text_ar":"مَا اَسْقَطَ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY kalimapK","text_ar":"فِى كَلِمَةٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maAA^asoqaTa","text_ar":"مَااَسْقَطَ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) (tropical:)"},{"kind":"italic_en","text":"He spoke, and did not commit a mistake in a word."},{"kind":"text","text":"(M, K, TA.) And"},{"kind":"arabic","text_bw":"takal~ama bikalaAmK","text_ar":"تَكَلَّمَ بِكَلَامٍ"},{"kind":"arabic","text_bw":"famaA saqaTa biHarofK","text_ar":"فَمَا سَقَطَ بِحَرْفٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HarofFA","text_ar":"حَرْفًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^asoqaTa","text_ar":"مَا اَسْقَطَ","orth_type":"arrow"},{"kind":"text","text":", [held by him on whose authority it is mentioned to mean (assumed tropical:)"},{"kind":"italic_en","text":"He spoke speech, and did not drop a letter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a word;"},{"kind":"text","text":"for this is] said by Yaakoob to be like"},{"kind":"arabic","text_bw":"daxalotu bihi","text_ar":"دَخَلْتُ بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^adoxalotuha","text_ar":"اَدْخَلْتُهَ"},{"kind":"text","text":", &c. (S.) ―         -b13-"},{"kind":"arabic","text_bw":"saqaTa *ikoruhu","text_ar":"سَقَطَ ذِكْرُهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The mention of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dropped, left out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"omitted"},{"kind":"text","text":"]. (TA, passim.) And"},{"kind":"arabic","text_bw":"saqaTa Alr~ajulu","text_ar":"سَقَطَ الرَّجُلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man's name fell out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became dropped, from the register of soldiers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pensioners."},{"kind":"text","text":"(TA.) ―         -b14-"},{"kind":"arabic","text_bw":"saqaTato quw~atuhu duwna buluwgi AlA^mori","text_ar":"سَقَطَتْ قُوَّتُهُ دُونَ بُلُوغِ الامْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His power fell short of the attainment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplishment, of the affair."},{"kind":"text","text":"] (TA in art."},{"kind":"arabic","text_bw":"*rE","text_ar":"ذرع"},{"kind":"text","text":".) ―         -b15-  ["},{"kind":"arabic","text_bw":"saqaTa","text_ar":"سَقَطَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":", likewise signifies (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a claim or demand, a due, an argument or a plea, a condition, a law, a command or prohibition, a gift, a reward, a punishment, a good action, a sin, &c.,)"},{"kind":"italic_en","text":"became null, annulled, void, of no force,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no account; as though it fell to the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became dropped;"},{"kind":"text","text":"whence"},{"kind":"arabic","text_bw":"saqaTa Hukomuhu","text_ar":"سَقَطَ حُكْمُهُ"},{"kind":"text","text":", by which phrase"},{"kind":"arabic","text_bw":"baTala","text_ar":"بَطَلَ"},{"kind":"text","text":", q. v., is expl. in the Msb.] You say,"},{"kind":"arabic","text_bw":"saqaTa AlfaroDu","text_ar":"سَقَطَ الفَرْضُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The assigned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soldier's stipend"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pay, became annulled"},{"kind":"text","text":"], meaning"},{"kind":"arabic","text_bw":"saqaTa Talabuhu waAlA^amoru bihi","text_ar":"سَقَطَ طَلَبُهُ وَالاَمْرُ بِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"the demand for it and the order for it became dropped"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"A_i*aASaH~ati Almawad~apu saqaTatN $uruwTu AlA^adabi wa Alt~akoliyfi","text_ar":"اـِذَاصَحَّتِ المَوَدَّةُ سَقَطَتٌ شُرُوطُ الاَدَبِ وَ التَّكْلِيفِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"When love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection, is free from imperfection, the conditions of politeness and constraint become annulled"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"saqaTato xaTaAyaAhu","text_ar":"سَقَطَتْ خَطَايَاهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His sins fell"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from him"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"went away;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"xr","text_ar":"خر"},{"kind":"text","text":".) ―         -b16-"},{"kind":"arabic","text_bw":"saqaTa AlHar~u","text_ar":"سَقَطَ الحَرُّ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suquwTN","text_ar":"سُقُوطٌ"},{"kind":"text","text":", (M,) (tropical:)"},{"kind":"italic_en","text":"The heat fell"},{"kind":"text","text":"[like as one says of rain]; (M, K;)"},{"kind":"italic_en","text":"it befell;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"it came."},{"kind":"text","text":"(K.) But"},{"kind":"arabic","text_bw":"saqaTa Ean~aA AlHar~a","text_ar":"سَقَطَ عَنَّا الحَرَّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The heat left us"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted us:"},{"kind":"text","text":"(IAar, M, K:) as though the verb had two contr. significations. (M, K. *) ―         -b17-"},{"kind":"arabic","text_bw":"saqaTa AlHadiyvu minoka A_ilayohi waminohu A_ilayoka","text_ar":"سَقَطَ الحَدِيثُ مِنْكَ اـِلَيْهِ وَمِنْهُ اـِلَيْكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Discourse fell from thee to him, and from him to thee"},{"kind":"text","text":"]: (M:) or"},{"kind":"arabic","text_bw":"saqaTa mino kulK EalaY AlA~xari","text_ar":"سَقَطَ مِنْ كُلٍ عَلَى الاّخَرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"it fell from each to the other"},{"kind":"text","text":"]. (K.)"}],"source_refs":["M","MS","S","Mgh","Msb","K","Kh","A","Fr","Zj","O","TA","Bd","Akh","IAar"]}]}}