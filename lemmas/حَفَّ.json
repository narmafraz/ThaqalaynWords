:"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحُفّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحُفّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"حَفَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَفَفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":15},"lanes":{"found":true,"entry_ids":["","n8446","n8456","n8546"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%81%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to surround, to enclose, to encompass, to border","examples":[{"text":"ثُمَّ وصلتُ إلى مدينة طرابلس. وهي إحدى قواعد الشام وبلدانها الضخام. تخترقها الأنهار، وتَحُفُّهَا البساتين والأشجار، ويكنفها البحر بمرافقه العميقة، والبر بخيراته المقيمة، ولها الأسواق العجيبة، والمسارحُ الخصيبة،[…]","english":"I came next to the town of Atrabulus [Tripoli], one of the capitals of Syria and of its great cities, traversed by flowing streams, and surrounded by gardens and trees, flanked by the sea with its copious resources and by the land with its sustaining bounties, and possessed of admirable bazaars and fertile lands."}]},{"pos":"verb","gloss":"to surround with, to cause to be surrounded by","examples":[{"text":"وَٱضْرِبْ لَهُم مَثَلًا رَجُلَيْنِ جَعَلْنَا لِأَحَدِهِمَا جَنَّتَيْنِ مِنْ أَعْنَابٍ وَحَفَفْنَاهُمَا بِنَخْلٍ وَجَعَلْنَا بَيْنَهُمَا زَرْعًا"}]},{"pos":"verb","gloss":"to clip short the hair of, to pluck out the hair of"},{"pos":"verb","gloss":"to shave"},{"pos":"verb","gloss":"to rub off, to scrape off, to erase"},{"pos":"verb","gloss":"to shave"},{"pos":"verb","gloss":"to be disheveled"},{"pos":"verb","gloss":"to bear dry herbs"},{"pos":"verb","gloss":"to vanish entirely"},{"pos":"verb","gloss":"to rumble (bowels)"},{"pos":"verb","gloss":"to snort"},{"pos":"verb","gloss":"to hiss (snake)"},{"pos":"noun","gloss":"verbal noun of حَفَّ (ḥaffa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"loom"},{"pos":"noun","gloss":"trace"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8446","headword_ar":"حَفٌّ","root":"Hf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Haf~apN","text_ar":"حَفَّةٌ"},{"kind":"text","text":", in three places. ―         -b2-  [It is said, accord. to the KL, to signify also"},{"kind":"italic_en","text":"What is called in Persian"},{"kind":"arabic","text_bw":"zyn kwhh","text_ar":"زين كوهه"},{"kind":"text","text":", app. meaning"},{"kind":"italic_en","text":"a saddlebow:"},{"kind":"text","text":"but this signification, if correct, is probably post-classical.]       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"HafafN","text_ar":"حَفَفٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HifaAfN","text_ar":"حِفَافٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"A time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^avarN","text_ar":"اَثَرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a track,"},{"kind":"text","text":"&c.]. (K.) You say,"},{"kind":"arabic","text_bw":"jaA='a EalaY Haf~i *`lika","text_ar":"جَا=ءَ عَلَى حَفِّ ذٰلِكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Hafafihi","text_ar":"حَفَفِهِ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"HifaAfihi","text_ar":"حِفَافِهِ","orth_type":"arrow"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came in the time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season, of that:"},{"kind":"text","text":"(L:) or the meaning is"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"arabic","text_bw":"A^avarihi","text_ar":"اَثَرِهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"in the track thereof;"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near after, that"},{"kind":"text","text":"]. (K.)       -A3-"},{"kind":"arabic","text_bw":"fulaAnN Haf~N binafosihi","text_ar":"فُلَانٌ حَفٌّ بِنَفْسِهِ"},{"kind":"italic_en","text":"Such a one is busied with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxious about, himself."},{"kind":"text","text":"(TA.)"}],"source_refs":["L","K"]},{"entry_id":"n8456","headword_ar":"حَفٌّ","root":"Hf","body":[{"kind":"italic_en","text":"Going round about, circuiting, compassing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surrounding."},{"kind":"text","text":"(S, Msb, K.) It is said in the Kur [xxxix. last verse],"},{"kind":"arabic","text_bw":"wataray AlmalaAy^ikapa HaAf~iyna","text_ar":"وَتَرَي المَلَايِكَةَ حَافِّينَ"},{"kind":"arabic","text_bw":"mino Hawoli AlEaro$i","text_ar":"مِنْ حَوْلِ العَرْشِ"},{"kind":"text","text":"(Zj, S, K *)"},{"kind":"italic_en","text":"And thou shalt see the angels surrounding the"},{"kind":"arabic","text_bw":"Er$","text_ar":"عرش"},{"kind":"text","text":": (Zj, TA:) or"},{"kind":"italic_en","text":"surrounding the sides thereof:"},{"kind":"text","text":"(Sgh, K:) or"},{"kind":"italic_en","text":"going round about on either side thereof."},{"kind":"text","text":"(Er-Rághib, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"maA lahu HaAf~N walaA raAf~N","text_ar":"مَا لَهُ حَافٌّ وَلَا رَافٌّ"},{"kind":"text","text":": see 1.       -A2-"},{"kind":"arabic","text_bw":"sawiyqN HaAf~N","text_ar":"سَوِيقٌ حَافٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Meal of parched barley"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not moistened with water"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with clarified butter"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(Lth, K.) ["},{"kind":"arabic","text_bw":"xubozN HaAf~N","text_ar":"خُبْزٌ حَافٌّ"},{"kind":"text","text":", in the present day, means"},{"kind":"italic_en","text":"Dry bread;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"bread without anything savoury."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"huwaHaAf~u AlmaToEam","text_ar":"هُوَحَافُّ المَطْعَم"},{"kind":"italic_en","text":"He is one whose food is dry."},{"kind":"text","text":"(TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"HaAfN","text_ar":"حَافٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Hwf","text_ar":"حوف"},{"kind":"text","text":"."}],"source_refs":["Zj","TA","Sgh","K"]},{"entry_id":"n8546","headword_ar":"حَفٍ","root":"Hfw and HfY","body":[{"kind":"text","text":", applied to a man, (S, Mgh, Msb, K,) and a camel, (K,) and a horse or the like, (Zj, S, K, Ham p. 476,)"},{"kind":"italic_en","text":"Having his foot,"},{"kind":"text","text":"(S, Mgh, Msb, K,) or"},{"kind":"italic_en","text":"hoof,"},{"kind":"text","text":"(Zj, S, K, Ham,)"},{"kind":"italic_en","text":"attenuated"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the sole"},{"kind":"text","text":"], (Zj, S, Mgh, Msb, K,) or"},{"kind":"italic_en","text":"chafed, abraded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worn,"},{"kind":"text","text":"(Ham, PS,) by much walking or treading or travel; (S, Mgh, Msb, Ham;) as also ↓"},{"kind":"arabic","text_bw":"HaAfK","text_ar":"حَافٍ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":["S","Mgh","Msb","K","Zj","Ham","PS"]}]},"classical_definitions":null}