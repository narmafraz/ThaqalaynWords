{"lemma":"راياتٌ","slug":"راياتٌ","root":"ر.#.#","root_slug":"ر-_-_","root_link":"/words/roots/ر-_-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14338","n17200"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D9%8A%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"obsolete form of رَايَة (rāya)","tags":["alt-of","obsolete"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14338","headword_ar":"رَاْيَةٌ","root":"rA^Y","body":[{"kind":"text","text":", originally thus, with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; (T, Msb;) but the Arabs prefer omitting it, [saying"},{"kind":"arabic","text_bw":"raAyapN","text_ar":"رَايَةٌ"},{"kind":"text","text":",] and some of them say that it has not been heard with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; (Msb;) [Az says,] the Arabs did not pronounce it with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": accord. to Lth, its radical letters are"},{"kind":"arabic","text_bw":"rYY","text_ar":"رىى"},{"kind":"text","text":": (T:)"},{"kind":"italic_en","text":"A banner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"standard,"},{"kind":"text","text":"(T, Msb,)"},{"kind":"italic_en","text":"of an army:"},{"kind":"text","text":"(Msb:) pl."},{"kind":"arabic","text_bw":"raAyaAtN","text_ar":"رَايَاتٌ"},{"kind":"text","text":"(T, Msb.) [See also art."},{"kind":"arabic","text_bw":"rY","text_ar":"رى"},{"kind":"text","text":".]"}],"source_refs":["T","Msb"]},{"entry_id":"n17200","headword_ar":"رَايَةٌ","root":"rY","body":[{"kind":"text","text":", (T, S, M, Msb, K,) and"},{"kind":"arabic","text_bw":"raA='apN","text_ar":"رَا=ءَةٌ"},{"kind":"text","text":", mentioned by Sb on the authority of Abu-l-Khattáb, the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"raAyapN","text_ar":"رَايَةٌ"},{"kind":"text","text":", though a substitute for the medial radical, [i. e."},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":",] being likened by him to the augmentative"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", and therefore the final radical is made"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", like as is done in the case of"},{"kind":"arabic","text_bw":"siqaA='N","text_ar":"سِقَا=ءٌ"},{"kind":"text","text":"&c., (M,)"},{"kind":"italic_en","text":"A banner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"standard,"},{"kind":"text","text":"(T, S, M, Msb, K,)"},{"kind":"italic_en","text":"of an army:"},{"kind":"text","text":"(Msb:) accord. to some, (Msb,) originally with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", [see"},{"kind":"arabic","text_bw":"raA^oyapN","text_ar":"رَاْيَةٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"rA^Y","text_ar":"راى"},{"kind":"text","text":",] though pronounced by the Arabs without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; (T, Msb;) but others deny this, and say that it has not been heard with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"raAyaAtN","text_ar":"رَايَاتٌ"},{"kind":"text","text":"(M, Msb, K) and [coll. gen. n.] ↓"},{"kind":"arabic","text_bw":"raAYN","text_ar":"رَاىٌ","orth_type":"arrow"},{"kind":"text","text":". (M, K.) ―         -b2-  Also"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"qilaAadp","text_ar":"قِلَاَدة"},{"kind":"text","text":"[app. here meaning"},{"kind":"italic_en","text":"collar"},{"kind":"text","text":"]: (K:) or"},{"kind":"italic_en","text":"a thing that is put upon the neck"},{"kind":"text","text":"(Lth, T, M, K)"},{"kind":"italic_en","text":"of a runaway male slave,"},{"kind":"text","text":"(M, K.)"},{"kind":"italic_en","text":"to show that he is a runaway: it is an iron ring, of the size of the neck."},{"kind":"text","text":"(TA.)       -A2-  It is also said to be an inf. n. of"},{"kind":"arabic","text_bw":"raA^aY","text_ar":"رَاَى"},{"kind":"text","text":": see this latter word."}],"source_refs":["T","S","M","Msb","K","Lth"]}]}}