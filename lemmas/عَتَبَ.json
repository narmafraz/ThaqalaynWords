sense_count":2},"lanes":{"found":true,"entry_ids":["n27927","n27928","n27929"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AA%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to blame, to censure, to reprove (عَلَى (ʕalā))"},{"pos":"noun","gloss":"plural of عَتَبَة (ʕataba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":["/ʕa.ta.ba/","/ʕa.tab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27927","headword_ar":"عَتْبٌ","root":"Etb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EitobaAnN","text_ar":"عِتْبَانٌ"},{"kind":"text","text":", in four places."}],"source_refs":[]},{"entry_id":"n27928","headword_ar":"عِتْبٌ","root":"Etb","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"who reproves, blames,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"censures,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"his companion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his friend,"},{"kind":"text","text":"(O, TA,)"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frequently,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"in respect of everything,"},{"kind":"text","text":"(O, TA,)"},{"kind":"italic_en","text":"from a motive of solicitous affection for him, and to give him good advice."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"Eat~aAbN","text_ar":"عَتَّابٌ"},{"kind":"text","text":".]"}],"source_refs":["O","K","TA"]},{"entry_id":"n27929","headword_ar":"عَتَبٌ","root":"Etb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EatabapN","text_ar":"عَتَبَةٌ"},{"kind":"text","text":", in five places. ―         -b2-  Also The"},{"kind":"arabic","text_bw":"dasotaAnaAt","text_ar":"دَسْتَانَات"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"frets"},{"kind":"text","text":"] (O, TA)"},{"kind":"italic_en","text":"that are bound upon the"},{"kind":"arabic","text_bw":"Eamuwd","text_ar":"عَمُود"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"neck"},{"kind":"text","text":"] (O) of a lute: (O, TA:) [app. as likened to a series of steps:] or the"},{"kind":"italic_en","text":"transverse pieces of wood upon the face"},{"kind":"text","text":"of a lute, [i. e., app.,"},{"kind":"italic_en","text":"upon the face of the neck,"},{"kind":"text","text":"] from which the chords"},{"kind":"italic_en","text":"are extended to the extremity"},{"kind":"text","text":"of the lute: (O, K, TA:) or, accord. to IAar, the"},{"kind":"italic_en","text":"thing"},{"kind":"text","text":"[app. the"},{"kind":"italic_en","text":"small ridge at the angle of the neck"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon which are"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lie"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the extremities of the chords, in the fore part,"},{"kind":"text","text":"of the lute. (TA.) [See an engraving and a description of a lute in my work on the Modern Egyptians.] ―         -b3-  And The"},{"kind":"italic_en","text":"places of ascent"},{"kind":"text","text":"of mountains, and of rugged and hard pieces of ground. (TA.) ―         -b4-  And"},{"kind":"italic_en","text":"Ruggedness of ground."},{"kind":"text","text":"(O, K.) ―         -b5-  And The"},{"kind":"italic_en","text":"space between two mountains."},{"kind":"text","text":"(TA.) ―         -b6-  And The"},{"kind":"italic_en","text":"space between the fore finger and middle finger"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when they are extended apart"},{"kind":"text","text":"]: (Msb in art."},{"kind":"arabic","text_bw":"$br","text_ar":"شبر"},{"kind":"text","text":", and K:) or the"},{"kind":"italic_en","text":"space between the middle finger and third finger:"},{"kind":"text","text":"(S, O, K:) or the ["},{"kind":"italic_en","text":"space that is measured by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"placing the four fingers close together."},{"kind":"text","text":"(Msb ubi suprà.) [See also"},{"kind":"arabic","text_bw":"buSomN","text_ar":"بُصْمٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ratabN","text_ar":"رَتَبٌ"},{"kind":"text","text":".] ―         -b7-  Also"},{"kind":"italic_en","text":"A bending at the"},{"kind":"arabic","text_bw":"Dariybap","text_ar":"ضَرِيبَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"part with which one strikes"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and a bluntness,"},{"kind":"text","text":"of a sword. (TA.) One says,"},{"kind":"arabic","text_bw":"maA fiY TaAEapi fulaAnK EatabN","text_ar":"مَا فِى طَاعَةِ فُلَانٍ عَتَبٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"There is not in the obedience of such a one any bending nor a recoiling."},{"kind":"text","text":"(TA.) ―         -b8-  And"},{"kind":"italic_en","text":"A defect"},{"kind":"text","text":"in a bone,"},{"kind":"italic_en","text":"when it has not been well set, after a fracture, and there remains a constant swelling in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a lameness."},{"kind":"text","text":"(TA.) ―         -b9-  And"},{"kind":"italic_en","text":"An unsoundness"},{"kind":"text","text":"(O, K, TA) in an animal's leg, (O, TA,) and (assumed tropical:)  in an affair. (TA.) One says,"},{"kind":"arabic","text_bw":"maA fiY mawad~atihi EatabN","text_ar":"مَا فِى مَوَدَّتِهِ عَتَبٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"There is not in his love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection, anything mingling with it that vitiates it, impairs it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"renders it unsound."},{"kind":"text","text":"(TA.)"}],"source_refs":["O","TA","K","S"]}]},"classical_definitions":null}