ُؤْنِق", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "present_1ms", "form": "أُونِق", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": false}, "lanes": {"found": true, "entry_ids": ["n1385", "n1386", "n1389", "n1390"], "search_url": "https://lanelexicon.com/?s=%D8%A2%D9%86%D9%8E%D9%82%D9%8E"}}, "translations": {"en": "to please, to rejoice", "fa": "خوش آمدن، شاد شدن", "ur": "خوش ہونا، مسرور ہونا", "tr": "hoşlanmak, sevinmek", "id": "menyenangkan, bergembira", "bn": "আনন্দিত হওয়া, সন্তুষ্ট হওয়া", "es": "complacer, regocijarse", "fr": "plaire, se réjouir", "de": "gefallen, sich freuen", "ru": "нравиться, радоваться", "zh": "使高兴，喜悦"}, "definition": null, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n1385", "headword_ar": "اَنِقَ", "root": "Anq", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^anaqN", "text_ar": "اَنَقٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "It excited admiration and approval by its beauty"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "goodliness; it pleased,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rejoiced."}, {"kind": "text", "text": "(Msb.) ―         -b2-  Also, aor. and inf. n. as above,"}, {"kind": "italic_en", "text": "He rejoiced; was joyful, happy,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pleased."}, {"kind": "text", "text": "(S, K.) You say,"}, {"kind": "arabic", "text_bw": "A^aniqotu bihi", "text_ar": "اَنِقْتُ بِهِ"}, {"kind": "text", "text": ", (Lth, JK, Msb, K,) aor. and inf. n. as above, (Lth, JK,)"}, {"kind": "italic_en", "text": "I was pleased with it,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "by it;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "was rejoiced by it."}, {"kind": "text", "text": "(Lth, JK, Msb, K. [In the CK"}, {"kind": "arabic", "text_bw": "AaEojaba", "text_ar": "اَعْجَبَ"}, {"kind": "text", "text": "is erroneously put for"}, {"kind": "arabic", "text_bw": "A^uEojiba", "text_ar": "اُعْجِبَ"}, {"kind": "text", "text": "] It is said in a trad.,"}, {"kind": "arabic", "text_bw": "maA mino EaA$iyapK A^a$ad~u A^anaqFA walaA A^aboEadu $ibaEFA mino", "text_ar": "مَا مِنْ عَاشِيَةٍ اَشَدُّ اَنَقًا وَلَا اَبْعَدُ شِبَعًا مِنْ"}, {"kind": "arabic", "text_bw": "TaAlibi EilomK", "text_ar": "طَالِبِ عِلْمٍ"}, {"kind": "italic_en", "text": "There is not any eater by night"}, {"kind": "text", "text": "[i. e. any man]"}, {"kind": "italic_en", "text": "who hath more pleasure and approval and desire and love"}, {"kind": "text", "text": "[in his pursuit,"}, {"kind": "italic_en", "text": "nor any who is further from satiation"}, {"kind": "text", "text": "therein,"}, {"kind": "italic_en", "text": "than the student,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pursuer, of science"}, {"kind": "text", "text": "]; meaning that the man of learning is excessively greedy and insatiable, persevering in vehement desire. (L.) ―         -b3-  And"}, {"kind": "arabic", "text_bw": "A^anaqa Al$~aYo'a", "text_ar": "اَنَقَ الشَّىْءَ"}, {"kind": "text", "text": ", (AZ, K,) inf. n. as above, (AZ,)"}, {"kind": "italic_en", "text": "He loved the thing."}, {"kind": "text", "text": "(AZ, K.)"}], "source_refs": ["Lth", "JK", "Msb", "K", "AZ"]}, {"entry_id": "n1386", "headword_ar": "انّق", "root": "Anq", "body": [{"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "taA^oniyqN", "text_ar": "تَاْنِيقٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He made,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "caused, to wonder."}, {"kind": "text", "text": "(K, TA.)"}], "source_refs": []}, {"entry_id": "n1389", "headword_ar": "اَنَقٌ", "root": "Anq", "body": [{"kind": "text", "text": "inf. n. of 1 [q. v.] (Lth, JK, &c.) ―         -b2-  [Hence,"}, {"kind": "italic_en", "text": "A pleasing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rejoicing, state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition."}, {"kind": "text", "text": "] You say,"}, {"kind": "arabic", "text_bw": "huwa fiY A^anaqK mino Eayo$ihi waxiSobK", "text_ar": "هُوَ فِى اَنَقٍ مِنْ عَيْشِهِ وَخِصْبٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He is in a pleasing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rejoicing, state,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition, in respect of his life, and in a state of plenty"}, {"kind": "text", "text": "]. (JK.) ―         -b3-"}, {"kind": "italic_en", "text": "Goodliness, or beauty, and"}, {"kind": "page_break", "n": 118}, {"kind": "italic_en", "text": "pleasingness, of aspect,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "outward appearance:"}, {"kind": "text", "text": "or, as some say,"}, {"kind": "italic_en", "text": "a uniform and uninterrupted state of verdure before the eye;"}, {"kind": "text", "text": "because it pleases, or rejoices, its beholder. (TA.) ―         -b4-"}, {"kind": "italic_en", "text": "Herbage,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pasturage,"}, {"kind": "text", "text": "(K, TA,)"}, {"kind": "italic_en", "text": "that is goodly, or beautiful, and pleasing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rejoicing:"}, {"kind": "text", "text": "an inf. n. used as a subst. (TA.)"}], "source_refs": ["K", "TA"]}, {"entry_id": "n1390", "headword_ar": "اَنِقٌ", "root": "Anq", "body": [{"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "A^aniyqN", "text_ar": "اَنِيقٌ"}, {"kind": "text", "text": "."}], "source_refs": []}]}, "classical_definitions": null, "translations_at