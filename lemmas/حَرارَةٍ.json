{"lemma":"حَرارَةٍ","slug":"حَرارَةٍ","root":"ح.ر.ر","root_slug":"ح-ر-ر","root_link":"/words/roots/ح-ر-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n7514"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D8%A7%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"heat"},{"pos":"noun","gloss":"warmth, congeniality, friendliness"},{"pos":"noun","gloss":"enthusiasm, fervor, zeal"},{"pos":"noun","gloss":"temperature"}]},"etymology":null,"ipa":["/ħa.raː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7514","headword_ar":"حَرَارَةٌ","root":"Hr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Har~N","text_ar":"حَرٌّ"},{"kind":"text","text":", in two places. ―         -b2-  Also"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"HarowapN","text_ar":"حَرْوَةٌ"},{"kind":"text","text":"as used in the saying,"},{"kind":"arabic","text_bw":"A_in~iY laA^ajidu lih`*aA AlT~aEaAmi","text_ar":"اـِنِّى لَاَجِدُ لِهٰذَا الطَّعَامِ"},{"kind":"arabic","text_bw":"HarowapF fiY famiY","text_ar":"حَرْوَةً فِى فَمِى"},{"kind":"text","text":", (S, TA,) meaning"},{"kind":"italic_en","text":"Verily I find that this food has a burning effect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pungency, in my mouth."},{"kind":"text","text":"(TA.) It signifies"},{"kind":"italic_en","text":"A burning"},{"kind":"text","text":"in the mouth, from the taste of a thing: and in the heart, from pain: and hence one says,"},{"kind":"arabic","text_bw":"wajada HaraArapa","text_ar":"وَجَدَ حَرَارَةَ"},{"kind":"arabic","text_bw":"Als~ayofi","text_ar":"السَّيْفِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlD~arobi","text_ar":"الضَّرْبِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Almawoti","text_ar":"المَوْتِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlfiraAqi","text_ar":"الفِرَاقِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He felt the burning effect of the sword,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of beating,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of death,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of separation."},{"kind":"text","text":"] (IDrst, TA.) [See also"},{"kind":"arabic","text_bw":"Hir~apN","text_ar":"حِرَّةٌ"},{"kind":"text","text":".]       -A2-  See also"},{"kind":"arabic","text_bw":"Hur~iy~apN","text_ar":"حُرِّيَّةٌ"},{"kind":"text","text":"."}],"source_refs":["S","TA"]}]},"classical_definitions":null}