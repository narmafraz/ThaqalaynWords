},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to win, to gain; to profit","tags":["intransitive","transitive"]},{"pos":"noun","gloss":"verbal noun of رَبِحَ (rabiḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"profit"},{"pos":"noun","gloss":"interest"},{"pos":"noun","gloss":"usury"},{"pos":"noun","gloss":"verbal noun of رَبِحَ (rabiḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"foal of a camel"}]},"etymology":null,"ipa":["/ra.bi.ħa/","/ribħ/","/ra.baħ/","/rubħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14444","headword_ar":"رِبْحٌ","root":"rbH","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rabaHN","text_ar":"رَبَحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rabaAHN","text_ar":"رَبَاحٌ","orth_type":"arrow"},{"kind":"text","text":"[all originally inf. ns.]"},{"kind":"italic_en","text":"Gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profit;"},{"kind":"text","text":"(IAar, S, A, K, and Mgh in explanation of the first and last;)"},{"kind":"italic_en","text":"increase"},{"kind":"text","text":"["},{"kind":"italic_en","text":"obtained"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in traffic;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"excess,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surplus,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"obtained,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"above the capital"},{"kind":"text","text":"["},{"kind":"italic_en","text":"expended"},{"kind":"text","text":"]; wherefore it is also termed"},{"kind":"arabic","text_bw":"$if~N","text_ar":"شِفٌّ"},{"kind":"text","text":". (Ksh and Bd in explanation of the first in ii. 15.) [Hence,] ↓"},{"kind":"arabic","text_bw":"Albir~u xayoru tijaArapK rabaAHFA","text_ar":"البِرُّ خَيْرُ تِجَارَةٍ رَبَاحًا","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Piety is the best traffic in respect of gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profit."},{"kind":"text","text":"] (A.)"}],"source_refs":[]},{"entry_id":"n14445","headword_ar":"رَبَحٌ","root":"rbH","body":[{"kind":"text","text":": see the next preceding paragraph. ―         -b2-"},{"kind":"italic_en","text":"Horses and camels that are brought from one place to another for sale."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"Fat"},{"kind":"text","text":", as a subst. (S, K.) A poet says, (S,) namely, Khufáf Ibn-Nudbeh, (TA,)"},{"kind":"quote","text":"qarawoA A^aDoyaAfahumo rabaHFA bibuH~K\n                      \n                     \n                        yEiy$u bifaDolihin~a AlHaY~u sumori"},{"kind":"text","text":"[as though meaning"},{"kind":"italic_en","text":"They entertained their guests with fat, on the superabundant remains of which the tribe lived, by means of tawny-coloured gaming-arrows whereby the lots"},{"kind":"text","text":"that determined who should afford the entertainment"},{"kind":"italic_en","text":"were divided"},{"kind":"text","text":"]: (S, * TA:) but [this is inconsistent with the affixed pronoun relating to"},{"kind":"arabic","text_bw":"rbHA","text_ar":"ربحا"},{"kind":"text","text":", wherefore], in this case, as some say, (S, TA,) it means"},{"kind":"italic_en","text":"young weaned camels;"},{"kind":"text","text":"(S, K, TA;) [as a quasi-pl. n.;] and its sing. is ↓"},{"kind":"arabic","text_bw":"raAbiHN","text_ar":"رَابِحٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) like as that of"},{"kind":"arabic","text_bw":"HarasN","text_ar":"حَرَسٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"HaArisN","text_ar":"حَارِسٌ"},{"kind":"text","text":"; and that of"},{"kind":"arabic","text_bw":"xaAdimN xadamN","text_ar":"خَادِمٌ خَدَمٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"a young weaned camel;"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"rubaHN","text_ar":"رُبَحٌ"},{"kind":"text","text":";] and its pl. is"},{"kind":"arabic","text_bw":"ribaAHN","text_ar":"رِبَاحٌ"},{"kind":"text","text":": (K:) or it means here the"},{"kind":"italic_en","text":"gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profit, obtained by means of the game called"},{"kind":"arabic","text_bw":"Alamyosir","text_ar":"الَميْسِر"},{"kind":"text","text":". (S, TA.) ―         -b4-  See also the next paragraph."}],"source_refs":["S","TA","K"]},{"entry_id":"n14446","headword_ar":"رُبَحٌ","root":"rbH","body":[{"kind":"italic_en","text":"A young weaned camel;"},{"kind":"text","text":"(S, K:) app. a dial. var. of"},{"kind":"arabic","text_bw":"rubaEN","text_ar":"رُبَعٌ"},{"kind":"text","text":". (S.) [See also"},{"kind":"arabic","text_bw":"rabaHN","text_ar":"رَبَحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rub~aAHN","text_ar":"رُبَّاحٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"A lamb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kid:"},{"kind":"text","text":"(ISd, TA in art."},{"kind":"arabic","text_bw":"nSH","text_ar":"نصح"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"the latter:"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"rub~aAHN","text_ar":"رُبَّاحٌ","orth_type":"arrow"},{"kind":"text","text":". (IAar, K.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"rub~aAHN","text_ar":"رُبَّاحٌ"},{"kind":"text","text":", first sentence. ―         -b4-  Also"},{"kind":"italic_en","text":"A certain bird,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"resembling the"},{"kind":"arabic","text_bw":"raAmij","text_ar":"رَامِج"},{"kind":"text","text":"[which is an owl employed for catching hawks]: or, accord. to Kr, the word is ↓"},{"kind":"arabic","text_bw":"rabaHN","text_ar":"رَبَحٌ","orth_type":"arrow"},{"kind":"text","text":", and signifies"},{"kind":"italic_en","text":"a certain bird resembling the"},{"kind":"arabic","text_bw":"zaAg","text_ar":"زَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rook"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","K"]}]}}