:"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُحِقُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحِقُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحْقِقْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحِقّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُحْقِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحِقّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُحْقِق","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحِقّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحِقّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحِقّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحِقّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحِقُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحِقُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحْقِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُحِقّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحِقّ","in_corpus":true,"count":87,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَحْقَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَحْقَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":113,"cross_references":{"qac":{"found":true,"lemma_key":"أَحَقّ","root":"حقق","pos":"N","occurrence_count":10},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n8558","n8579"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AD%D9%8E%D9%82%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tell the truth, to be right"},{"pos":"verb","gloss":"to enforce"},{"pos":"adj","gloss":"elative degree of حَقِيق (ḥaqīq)"},{"pos":"adj","gloss":"elative degree of حَقِيق (ḥaqīq):; worthier, more deserving; worthiest, most deserving"}]},"etymology":{"source":"wiktextract","text":"Elative of حَقِيق (ḥaqīq, “worthy, deserving”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8558","headword_ar":"احقّ","root":"Hq","body":[{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"A_iHoqaAqN","text_ar":"اـِحْقَاقٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He spoke truth; said what was true:"},{"kind":"text","text":"[very common in this sense;"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^aboTala","text_ar":"اَبْطَلَ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"he revealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed, a truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a right"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he laid claim to a right,"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"to a thing,"},{"kind":"text","text":"TA)"},{"kind":"italic_en","text":"and it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, due to him."},{"kind":"text","text":"(Msb.)       -A2-  See also"},{"kind":"arabic","text_bw":"Haq~a","text_ar":"حَقَّ"},{"kind":"text","text":", as an intrans. verb, in three places; relating to camels. ―         -b2-"},{"kind":"arabic","text_bw":"AHq~ Alqawomu","text_ar":"احقّ القَوْمُ"},{"kind":"italic_en","text":"The people's cattle became fat."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AHq~ Alqawomu mina Alr~abiyEi","text_ar":"احقّ القَوْمُ مِنَ الرَّبِيعِ"},{"kind":"italic_en","text":"The people's cattle became fat by means of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"herbage called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"text","text":". (AHn, * ISd, TA.)       -A3-  As a trans. verb: see"},{"kind":"arabic","text_bw":"Haq~ahu","text_ar":"حَقَّهُ"},{"kind":"text","text":", in nine places. You say also,"},{"kind":"arabic","text_bw":"A^aHoqaqotu AlA^amora","text_ar":"اَحْقَقْتُ الاَمْرَ"},{"kind":"text","text":", inf. n. as above, (tropical:)"},{"kind":"italic_en","text":"I did, performed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"executed, the affair in a firm, solid, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, manner;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put it into a firm, solid, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"ramaY faA^aHaq~a Alr~amiy~apa","text_ar":"رَمَى فَاَحَقَّ الرَّمِيَّةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shot, and killed on the spot the animal at which he cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shot."},{"kind":"text","text":"(Ibn-'Abbád, Z, K, * TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^aHaq~ato A_ibilunaA rabiyEFA","text_ar":"اَحَقَّتْ اـِبِلُنَا رَبِيعًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstHq~t","text_ar":"استحقّت","orth_type":"arrow"},{"kind":"arabic","text_bw":"rbyEA","text_ar":"ربيعا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Our camels found"},{"kind":"text","text":"["},{"kind":"italic_en","text":"herbage such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"italic_en","text":"full-grown, and pastured upon it."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n8579","headword_ar":"اَحَقُّ","root":"Hq","body":[{"kind":"text","text":"[comparative and superlative of"},{"kind":"arabic","text_bw":"HaqiyqN","text_ar":"حَقِيقٌ"},{"kind":"text","text":"]. You say,"},{"kind":"arabic","text_bw":"huwa A^aHaq~u bika*aA","text_ar":"هُوَ اَحَقُّ بِكَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is more,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, adapted, disposed, apt, meet, suited, suitable, fitted, fit, proper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competent, for such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, worthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deserving, of it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he has a better,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the best, right to such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a more just,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the most just, title"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claim"},{"kind":"page_break","n":610},{"kind":"italic_en","text":"to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he is more,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, entitled to it"},{"kind":"text","text":"]: this phrase is used in two senses: first, as denoting the possession of an exclusive right or title, i. e., without the participation of another; as when you say,"},{"kind":"arabic","text_bw":"zayodN A^aHaq~u bimaAlihi","text_ar":"زَيْدٌ اَحَقُّ بِمَالِهِ"},{"kind":"italic_en","text":"Zeyd is entitled to his property exclusively of any other person:"},{"kind":"text","text":"secondly, as denoting the possession of a right or title in participation with another person, but in a superior degree; as in the saying,"},{"kind":"arabic","text_bw":"AlA^ay~imu A^aHaq~u binafosihaA","text_ar":"الاَيِّمُ اَحَقُّ بِنَفْسِهَا"},{"kind":"arabic","text_bw":"mino waliy~ihaA","text_ar":"مِنْ وَلِيِّهَا"},{"kind":"text","text":", (Msb,) i. e."},{"kind":"italic_en","text":"The woman that has not a husband and is not a virgin"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is more entitled to dispose of herself than is her guardian"},{"kind":"text","text":"]; (Mgh in art."},{"kind":"arabic","text_bw":"Aym","text_ar":"ايم"},{"kind":"text","text":";) meaning that they participate [in the right], but that her right is the stronger: (Msb:) a saying of Mohammad, in which the"},{"kind":"arabic","text_bw":"Ay~m","text_ar":"ايّم"},{"kind":"text","text":"is opposed to the"},{"kind":"arabic","text_bw":"bikor","text_ar":"بِكْر"},{"kind":"text","text":", for it is added that the"},{"kind":"arabic","text_bw":"bkr","text_ar":"بكر"},{"kind":"text","text":"is to be asked her permission: but one reading substitutes"},{"kind":"arabic","text_bw":"Alv~ay~ibu","text_ar":"الثَّيِّبُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AlAy~m","text_ar":"الايّم"},{"kind":"text","text":". (Mgh ubi suprà.) In the saying, in the Kur [v. 106],"},{"kind":"arabic","text_bw":"la$ahaAdatunaA A^aHaq~u","text_ar":"لَشَهَادَتُنَا اَحَقُّ"},{"kind":"arabic","text_bw":"mino $ahaAdatihimaA","text_ar":"مِنْ شَهَادَتِهِمَا"},{"kind":"text","text":", it may be formed from"},{"kind":"arabic","text_bw":"AisotaHaq~a","text_ar":"اِسْتَحَقَّ"},{"kind":"text","text":"by rejection of the augmentative letters, so that the meaning is, ["},{"kind":"italic_en","text":"Verily our testimony is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"more deserving of being accepted"},{"kind":"text","text":"["},{"kind":"italic_en","text":"than the testimony of them two"},{"kind":"text","text":"]: or it may be from"},{"kind":"arabic","text_bw":"Haq~a Al$~aYo'u","text_ar":"حَقَّ الشَّىْءُ"},{"kind":"text","text":"signifying"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":", and so mean"},{"kind":"italic_en","text":"more true,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"valid."},{"kind":"text","text":"(TA.)       -A2-  Applied to a horse,"},{"kind":"italic_en","text":"That does not sweat."},{"kind":"text","text":"(S, K.) ―         -b2-  And, likewise thus applied,"},{"kind":"italic_en","text":"That puts down his hind hoof in the place"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that has just before been that"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his fore hoof."},{"kind":"text","text":"(S, * K.) [See"},{"kind":"arabic","text_bw":"HaqaqN","text_ar":"حَقَقٌ"},{"kind":"text","text":".]"}],"source_refs":["Msb"]}]},"classical_definitions":null}