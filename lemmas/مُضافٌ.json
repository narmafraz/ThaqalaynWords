{"lemma": "مُضافٌ", "slug": "مُضافٌ", "root": "ض.#.ف", "root_slug": "ض-_-ف", "root_link": "/words/roots/ض-_-ف", "pos": "ADJ", "pos_camel": "adj", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": false}, "lanes": {"found": true, "entry_ids": ["n26214"], "search_url": "https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B6%D8%A7%D9%81%D9%8C"}}, "translations": {"en": "adjunct", "fa": "پیوسته", "ur": "منسلک", "tr": "ek", "id": "terikat", "bn": "সংযুক্ত", "es": "anexo", "fr": "adjoint", "de": "Anhang", "ru": "прибавочный", "zh": "附属的"}, "definition": null, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n26214", "headword_ar": "مُضَافٌ", "root": "Dyf", "body": [{"kind": "text", "text": "; and"}, {"kind": "arabic", "text_bw": "muDaAfN A_ilayohi", "text_ar": "مُضَافٌ اـِلَيْهِ"}, {"kind": "text", "text": ": see 4. ―         -b2-  The former signifies also (tropical:)  One who is"}, {"kind": "italic_en", "text": "made an adjunct,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "adherent, to a people,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "party,"}, {"kind": "text", "text": "(S, M, O, K, TA,) and"}, {"kind": "italic_en", "text": "made to incline to them,"}, {"kind": "text", "text": "(M,)"}, {"kind": "italic_en", "text": "not being of them."}, {"kind": "text", "text": "(M, TA.) One says,"}, {"kind": "arabic", "text_bw": "maA huwa A_il~aA muDaAfN", "text_ar": "مَا هُوَ اـِلَّا مُضَافٌ"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "He is none other than an adjunct,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "adherent"}, {"kind": "text", "text": "]. (TA.) ―         -b3-  And (tropical:)  One"}, {"kind": "italic_en", "text": "whose origin,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "lineage,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "parentage, is suspected;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "who makes a claim to relationship not having it:"}, {"kind": "text", "text": "(O, K, TA:) and (K)"}, {"kind": "italic_en", "text": "whose origin,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "relationship, is referred to a people,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "party, of whom he is not a member."}, {"kind": "text", "text": "(O, K, TA.) ―         -b4-  And One"}, {"kind": "italic_en", "text": "who is constrained to betake himself to a place of refuge,"}, {"kind": "text", "text": "(M, O, K, TA,)"}, {"kind": "italic_en", "text": "to a narrow,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "confined, place, and who is burdened with evil:"}, {"kind": "text", "text": "(TA:) El-Bureyk ElHudhalee says,"}, {"kind": "quote", "text": "wayaHomiY AlmuDaAfa A_i*aA maA daEaA"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "And he protects him who is constrained to betake himself to a place of refuge, when he calls for aid"}, {"kind": "text", "text": "]. (M.) And ↓"}, {"kind": "arabic", "text_bw": "musotaDaAfN", "text_ar": "مُسْتَضَافٌ", "orth_type": "arrow"}, {"kind": "text", "text": "signifies the same as"}, {"kind": "arabic", "text_bw": "muDaAfN", "text_ar": "مُضَافٌ"}, {"kind": "text", "text": "[app. in the last of the senses expl. above]: so says IB; and he cites the saying of Jowwás Ibn-Heiyán El-Azdee,"}, {"kind": "quote", "text": "Ei waA^aHomiY AlmusotaDaAfaA ↓ \n      walaqado A^aqodamu fiY Alr~awN"}, {"kind": "text", "text": "[app. meaning"}, {"kind": "italic_en", "text": "And verily I advance boldly in the case of fear, and I protect him who is constrained to betake himself to a place of refuge"}, {"kind": "text", "text": "]. (TA.) [See also"}, {"kind": "arabic", "text_bw": "maDuwfN", "text_ar": "مَضُوفٌ"}, {"kind": "text", "text": ".] ―         -b5-  Also One who is"}, {"kind": "italic_en", "text": "beset, hemmed in,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "encompassed,"}, {"kind": "text", "text": "in war, or battle: (S, O, K: said in the TA to be tropical:) or one"}, {"kind": "italic_en", "text": "falling among the horsemen and men of valour, having in him no strength."}, {"kind": "text", "text": "(M.) [See, again,"}, {"kind": "arabic", "text_bw": "maDuwfN", "text_ar": "مَضُوفٌ"}, {"kind": "text", "text": ".] ―         -b6-  And One"}, {"kind": "italic_en", "text": "in a state of fear."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["S", "M", "O", "K", "TA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}