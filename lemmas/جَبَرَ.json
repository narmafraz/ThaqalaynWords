{"lemma":"جَبَرَ","slug":"جَبَرَ","root":"ج.ب.ر","root_slug":"ج-ب-ر","root_link":"/words/roots/ج-ب-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَبَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَبَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَبَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَبَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَبَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَبَرَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَبَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَبَرا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَبَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَبَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَبَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْبُر","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْبُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْبُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْبُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْبُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْبُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْبُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْبُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْبُر","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْبُر","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْبُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْبُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْبُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْبُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْبُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْبُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْبُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْبُر","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْبُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَبَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَبَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n4935"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%A8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to set (a broken bone)"},{"pos":"verb","gloss":"to restore"},{"pos":"verb","gloss":"to force, to compel"},{"pos":"verb","gloss":"to set (a broken bone)"},{"pos":"noun","gloss":"verbal noun of جَبَرَ (jabara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"setting of broken bones"},{"pos":"noun","gloss":"force, compulsion, coercion, duress"},{"pos":"noun","gloss":"determinism, fatalism, predestination, predetermination"},{"pos":"noun","gloss":"algebra"}]},"etymology":{"source":"wiktextract","text":"Cognate with Biblical Hebrew גָּבַר (gɔḇar)."},"ipa":["/d͡ʒa.ba.ra/","/d͡ʒab.ba.ra/","/d͡ʒabr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4935","headword_ar":"جَبَرَ","root":"jbr","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"jaborN","text_ar":"جَبْرٌ"},{"kind":"text","text":"(S, A, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"jubuwrN","text_ar":"جُبُورٌ"},{"kind":"text","text":", (M, K,) which latter, accord. to MF, is an inf. n. of the intrans. verb only, but it has been heard as an inf. n. of the trans. verb also, (TA,) and"},{"kind":"arabic","text_bw":"jibaArapN","text_ar":"جِبَارَةٌ"},{"kind":"text","text":", (Lh, K,)"},{"kind":"italic_en","text":"He set"},{"kind":"text","text":"a bone;"},{"kind":"italic_en","text":"reduced"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"from a fractured state;"},{"kind":"text","text":"(S, A, Msb, K, &c.;) as also ↓"},{"kind":"arabic","text_bw":"jb~r","text_ar":"جبّر","orth_type":"arrow"},{"kind":"text","text":", (A, IAmb, K,) inf. n."},{"kind":"arabic","text_bw":"tajobiyrN","text_ar":"تَجْبِيرٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Ajbr","text_ar":"اجبر","orth_type":"arrow"},{"kind":"text","text":", (Ibn-Talhah, MF, TA,) but this is extremely strange, and not found in the lexicons of celebrity, (MF,) and not heard by AO; (TA;) [and ↓"},{"kind":"arabic","text_bw":"Ajtbr","text_ar":"اجتبر","orth_type":"arrow"},{"kind":"text","text":".] One says also,"},{"kind":"arabic","text_bw":"yadahu","text_ar":"يَدَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jb~r","text_ar":"جبّر","orth_type":"arrow"},{"kind":"text","text":", (A, IAmb,) or"},{"kind":"arabic","text_bw":"jabarahaA","text_ar":"جَبَرَهَا"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bone-setter)"},{"kind":"italic_en","text":"set his arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reduced it from a fractured state:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"put upon it the"},{"kind":"arabic","text_bw":"jabiyrap","text_ar":"جَبِيرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"splints"},{"kind":"text","text":"]. (Msb.) ―         -b2-  Hence, (TA,)"},{"kind":"arabic","text_bw":"jabara","text_ar":"جَبَرَ"},{"kind":"text","text":", (AAF, M, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"jaborN","text_ar":"جَبْرٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"jubuwrN","text_ar":"جُبُورٌ"},{"kind":"text","text":"[but respecting this latter see above] and"},{"kind":"arabic","text_bw":"jibaArapN","text_ar":"جِبَارَةٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"jb~r","text_ar":"جبّر","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tajobiyrN","text_ar":"تَجْبِيرٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Ajbr","text_ar":"اجبر","orth_type":"arrow"},{"kind":"text","text":"; (Ibn- Talhah, MF, TA; [but respecting this form see above;]) and ↓"},{"kind":"arabic","text_bw":"Ajtbr","text_ar":"اجتبر","orth_type":"arrow"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"He restored"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"from a state of poverty to wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency:"},{"kind":"text","text":"(AAF, S, A, K, &c.:) or"},{"kind":"italic_en","text":"he benefited"},{"kind":"text","text":"a poor man;"},{"kind":"italic_en","text":"conferred a benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits, upon"},{"kind":"text","text":"him: (M, K:) but the former is the more appropriate explanation: (AAF, TA:) and this signification is tropical; (IDrst, MF, TA;) the poor man being likened to one who has a broken bone, and his restoration to wealth, or competence, being likened to the setting of the bone; wherefore he is called"},{"kind":"arabic","text_bw":"faqiyrN","text_ar":"فَقِيرٌ"},{"kind":"text","text":", as though the vertebræ of his back were broken: (IDrst, TA:) in the A it is mentioned as proper, not tropical; but the author of the A afterwards mentions"},{"kind":"arabic","text_bw":"jabarotu fulaAnFA","text_ar":"جَبَرْتُ فُلَانًا"},{"kind":"text","text":"as tropical in the sense of"},{"kind":"arabic","text_bw":"naEa$otuhu","text_ar":"نَعَشْتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I recovered such a one from his embarrassment,"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"repaired his broken fortune,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his condition"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"jabarotu faAqapa Alr~ajuli","text_ar":"جَبَرْتُ فَاقَةَ الرَّجُلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I repaired the broken fortune of the man;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I restored the man to wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency."},{"kind":"text","text":"(A Heyth, TA.) And"},{"kind":"arabic","text_bw":"jabarotu Alyatiyma","text_ar":"جَبَرْتُ اليَتِيمَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I put the affairs of the orphan into a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"I gave to the orphan."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jabara","text_ar":"جَبَرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He restored anything to a sound, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state."},{"kind":"text","text":"(IDrst, TA.) And"},{"kind":"arabic","text_bw":"jabarahu A@ll~`hu","text_ar":"جَبَرَهُ ا@للّٰهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"May God render him sound, and strong"},{"kind":"text","text":"]: said in relation to a child. (S and K in art."},{"kind":"arabic","text_bw":"zrE","text_ar":"زرع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"jabarotu niSaAba Alz~akaApi bika*aA","text_ar":"جَبَرْتُ نِصَابَ الزَّكَاةِ بِكَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I made the amount of the property equal to that which renders it incumbent on the possessor to pay the poor-rate, by"},{"kind":"text","text":"[adding]"},{"kind":"italic_en","text":"such a thing:"},{"kind":"text","text":"the name of that thing is"},{"kind":"arabic","text_bw":"jbrAn","text_ar":"جبران"},{"kind":"text","text":"[app. ↓"},{"kind":"arabic","text_bw":"juboraAnN","text_ar":"جُبْرَانٌ","orth_type":"arrow"},{"kind":"text","text":"]: and the person who does this is termed ↓"},{"kind":"arabic","text_bw":"jaAbirN","text_ar":"جَابِرٌ","orth_type":"arrow"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"jabara","text_ar":"جَبَرَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He compelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained,"},{"kind":"text","text":"another. (B.) You say,"},{"kind":"arabic","text_bw":"jabarahu EalaY AlA^amori","text_ar":"جَبَرَهُ عَلَى الاَمْرِ"},{"kind":"text","text":", (Lh, Az, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaborN","text_ar":"جَبْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jubuwrN","text_ar":"جُبُورٌ"},{"kind":"text","text":", (Msb,) a chaste form of the verb, of the dial. of El- Hijáz, (Az, TA,) or of the Benoo-Temeem and of many of the people of El-Hijáz, (Msb,) or of Temeem alone; (Lh, TA;) [but said in the Mgh to be of weak authority;] and ↓"},{"kind":"arabic","text_bw":"Ajbrhu","text_ar":"اجبرهُ","orth_type":"arrow"},{"kind":"text","text":"; (Th, S, Msb, K, &c.;) both these forms of the verb mentioned by AZ, Fr, A 'Obeyd, and others, (Msb,) but the latter is the form used by the generality of the Arabs, (Lh, TA,) and by the grammarians [in general]; (TA;)"},{"kind":"italic_en","text":"He compelled him, against his will, to do the thing:"},{"kind":"text","text":"(Lh, Th, Az, S, Msb, K:) ↓"},{"kind":"arabic","text_bw":"A_ijobaArN","text_ar":"اـِجْبَارٌ","orth_type":"arrow"},{"kind":"text","text":"originally signifying the"},{"kind":"italic_en","text":"inciting, urging,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inducing,"},{"kind":"text","text":"another"},{"kind":"italic_en","text":"to restore a thing to a sound, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state."},{"kind":"text","text":"(B.) And"},{"kind":"arabic","text_bw":"EalaY AlHukomi","text_ar":"عَلَى الحُكْمِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajbrhu","text_ar":"اجبرهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a judge)"},{"kind":"italic_en","text":"compelled him to submit to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to perform, the sentence."},{"kind":"text","text":"(L.)       -A3-  Also"},{"kind":"arabic","text_bw":"jabara","text_ar":"جَبَرَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"jubuwrN","text_ar":"جُبُورٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"jaborN","text_ar":"جَبْرٌ"},{"kind":"text","text":", (Msb, K,) which latter, accord. to MF [and the Mgh], is an inf. n. of the trans. verb only, but it has been heard as an inf. n. of the intrans. verb also; (TA;) and ↓"},{"kind":"arabic","text_bw":"Anjbr","text_ar":"انجبر","orth_type":"arrow"},{"kind":"text","text":", (T, S, K,) and ↓"},{"kind":"arabic","text_bw":"Ajtbr","text_ar":"اجتبر","orth_type":"arrow"},{"kind":"text","text":", (T, S,) and ↓"},{"kind":"arabic","text_bw":"tjb~r","text_ar":"تجبّر","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a bone)"},{"kind":"italic_en","text":"became set,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reduced from a fractured state."},{"kind":"text","text":"(T, S, Msb, K.) ―         -b2-  And [hence,] the first of these verbs, with the same inf. ns.; (K;) and ↓"},{"kind":"arabic","text_bw":"Ajtbr","text_ar":"اجتبر","orth_type":"arrow"},{"kind":"text","text":", (S, * K,) and ↓"},{"kind":"arabic","text_bw":"Anjbr","text_ar":"انجبر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tjb~r","text_ar":"تجبّر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Astjbr","text_ar":"استجبر","orth_type":"arrow"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a poor man, K, and an orphan, TA)"},{"kind":"italic_en","text":"became restored from a state of poverty to wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency:"},{"kind":"text","text":"(S, * K:) or"},{"kind":"italic_en","text":"received a benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits:"},{"kind":"text","text":"(K:) ↓"},{"kind":"arabic","text_bw":"Ajtbr","text_ar":"اجتبر","orth_type":"arrow"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"AntE$","text_ar":"انتعش"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"he recovered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became recovered, from his embarrassment,"},{"kind":"text","text":"&c.]. (A.) [And (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"became restored to a sound, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state."},{"kind":"text","text":"] El-' Ajjáj has used"},{"kind":"arabic","text_bw":"jabara","text_ar":"جَبَرَ"},{"kind":"text","text":"transitively and intransitively in the same sentence, saying,"},{"kind":"quote","text":"qado jabara Ald~iyna AlA_ilaAhu fajabaro"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"God hath restored the religion to a sound, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state, and it hath become restored thereto"},{"kind":"text","text":"]: (S:) or, accord. to some, the second verb is corroborative of the first; the meaning being,"},{"kind":"italic_en","text":"God hath desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed, to restore the religion,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and hath completed its restoration."},{"kind":"text","text":"(B.)"}],"source_refs":["Msb","M","K","TA","Lh","A","IAmb","MF","S","AAF","IDrst","Az","Th","T"]}]}}