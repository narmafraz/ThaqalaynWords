{"lemma":"ذَبَحَ","slug":"ذَبَحَ","root":"ذ.ب.ح","root_slug":"ذ-ب-ح","root_link":"/words/roots/ذ-ب-ح","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ذَبَحْتَ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ذَبَحْتِ","in_corpus":true,"count":14,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ذَبَحْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ذَبَحْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ذَبَحْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ذَبَحَ","in_corpus":true,"count":40,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ذَبَحَت","in_corpus":true,"count":14,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ذَبَحا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ذَبَحَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ذَبَحُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ذَبَحْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَذْبَح","in_corpus":true,"count":12,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَذْبَحِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَذْبَحِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَذْبَحانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَذْبَحا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَذْبَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَذْبَحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَذْبَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَذْبَح","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَذْبَح","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَذْبَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَذْبَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَذْبَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَذْبَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَذْبَحُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَذْبَحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَذْبَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَذْبَح","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَذْبَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ذَبَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ذَبَحْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":146,"cross_references":{"qac":{"found":true,"lemma_key":"ذَبَحَ","root":"ذبح","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n13676","","n13679","n13680","n13681"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D8%A8%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to kill by slitting the throat"},{"pos":"verb","gloss":"to slaughter, to butcher","examples":[{"text":"إِنَّ اللَّهَ يَأْمُرُكُمْ أَن تَذْبَحُوا بَقَرَةً","english":"Allah commands you to slaughter a cow"}]},{"pos":"verb","gloss":"to massacre"},{"pos":"verb","gloss":"to murder, to slay"},{"pos":"verb","gloss":"to sacrifice, to offer up, to immolate"},{"pos":"verb","gloss":"to kill, to slaughter, to butcher, to massacre, to murder","examples":[{"text":"وَإِذْ نَجَّيْنَاكُم مِّنْ آلِ فِرْعَوْنَ يَسُومُونَكُمْ سُوءَ الْعَذَابِ يُذَبِّحُونَ أَبْنَاءَكُمْ وَيَسْتَحْيُونَ نِسَاءَكُمْ وَفِي ذَٰلِكُم بَلَاءٌ مِّن رَّبِّكُمْ عَظِيمٌ","english":"(Remember) how We delivered you from the people of Pharaoh, who afflicted you with dreadful torment, slaughtering your sons and keeping your women. That was a severe test from your Lord."},{"text":"فَلَمَّا دَخَلَ الصَّلِيبِيُّونَ بَيْتَ الْمَقْدِسِ ذَبَّحُوا كُلَّ مَنِ ٱلْتَجَأَ إِلَى الْمَسْجِدِ ٱلْأَقْصَى تَذْبِيحًا عَامًّا، وَقَدْ بَلَغَ مَنْ ذَبَّحُوا فِيهِ سَبْعِينَ أَلْفًا مِنَ الْعُلَمَاءِ، وَٱلزُّهَّادِ، وَٱلنِّسَاءِ، وَٱلْأَطْفَالِ."}]},{"pos":"noun","gloss":"verbal noun of ذَبَحَ (ḏabaḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"slaughter, slaughtering"},{"pos":"noun","gloss":"sacrificial victim, blood sacrifice"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew זבח (“to slaughter”) and Ugaritic 𐎄𐎁𐎈 (dbḥ)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13676","headword_ar":"ذُبَحَ","root":"*bH","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"*aboHN","text_ar":"ذَبْحٌ"},{"kind":"text","text":"(S, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"*ubaAHN","text_ar":"ذُبَاحٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided, lengthwise; clave; split; slit; rent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent open; ripped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ripped open."},{"kind":"text","text":"(S, Msb, K.) [Accord. to Fei,] this is the primary signification. (Msb.) [But see what follows.] You say,"},{"kind":"arabic","text_bw":"*abaHa","text_ar":"ذَبَحَ"},{"kind":"arabic","text_bw":"faA^orapa Almisoka","text_ar":"فَاْرَةَ المِسْكَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a perfumer, A)"},{"kind":"italic_en","text":"ripped open the follicle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vesicle, of mush,"},{"kind":"text","text":"(A, TA,)"},{"kind":"italic_en","text":"and took forth the mush that was in it."},{"kind":"text","text":"(TA.) [In the A and TA this is said to be tropical; the authors evidently holding it to be from"},{"kind":"arabic","text_bw":"*abaHa","text_ar":"ذَبَحَ"},{"kind":"text","text":"in the sense here next following.] ―         -b2-"},{"kind":"italic_en","text":"He slaughtered"},{"kind":"text","text":"[for food, or"},{"kind":"italic_en","text":"sacrificed,"},{"kind":"text","text":"] (L, TA) and animal, (Msb,) or a sheep or goat, (S, TA,) or an ox or a cow, and a sheep or goat, and the like, (Mgh,) ["},{"kind":"italic_en","text":"in the manner prescribed by the law,"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"by cutting the"},{"kind":"arabic","text_bw":"wadajaAni","text_ar":"وَدَجَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"two external jugular veins"},{"kind":"text","text":"], (Mgh,) or"},{"kind":"italic_en","text":"by cutting the throat, from beneath, at the part next the head:"},{"kind":"text","text":"(L, TA:) accord. to the K,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"naHara","text_ar":"نَحَرَ"},{"kind":"text","text":": but correctly,"},{"kind":"arabic","text_bw":"Al*~aboHu","text_ar":"الذَّبْحُ"},{"kind":"text","text":"is in the throat; and"},{"kind":"arabic","text_bw":"Aln~aHoru","text_ar":"النَّحْرُ"},{"kind":"text","text":"is in the pit above the breast, between the collar-bones, where camels are stabbed: the latter word is used in relation to camels and bulls and cows; and the former, in relation to other animals: or, not improbably, both may have originally signified"},{"kind":"italic_en","text":"the causing the soul to depart by wounding the throat, or the pit above the breast, which is the stabbing-place in the camel;"},{"kind":"text","text":"and may then have been applied in peculiar [and different] senses by the lawyers. (MF. [See also"},{"kind":"arabic","text_bw":"*akaApN","text_ar":"ذَكَاةٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"*kw","text_ar":"ذكو"},{"kind":"text","text":".]) Also (assumed tropical:)"},{"kind":"italic_en","text":"He slaughtered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slew, in any manner."},{"kind":"text","text":"(L.) [You say,"},{"kind":"arabic","text_bw":"*abaHa Eanohu","text_ar":"ذَبَحَ عَنْهُ"},{"kind":"italic_en","text":"He slaughtered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sacrificed, for him, by way of expiation."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"*abaHa baEoDuhumo baEoDFA","text_ar":"ذَبَحَ بَعْضُهُمْ بَعْضًا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"They slaughtered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slew, one another"},{"kind":"text","text":"]. (S, K.) And"},{"kind":"arabic","text_bw":"A^axa*ahumo banuw","text_ar":"اَخَذَهُمْ بَنُو"},{"kind":"arabic","text_bw":"fulaAnK biAl*~ubaAHi","text_ar":"فُلَانٍ بِالذُّبَاحِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sons of such a one slaughtered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slew, them."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"*b~H","text_ar":"ذبّح","orth_type":"arrow"},{"kind":"text","text":"(inf. n."},{"kind":"arabic","text_bw":"ta*obiyHN","text_ar":"تَذْبِيحٌ"},{"kind":"text","text":", KL) signifies the same as"},{"kind":"arabic","text_bw":"*abaHa","text_ar":"ذَبَحَ"},{"kind":"text","text":", except that it applies [only] to many objects; whereas the latter applies to few and to many: thus it is said in the Kur [ii. 46, and in like manner in xiv. 6],"},{"kind":"arabic","text_bw":"yu*ab~iHuwna A^abonaA='akumo","text_ar":"يُذَبِّحُونَ اَبْنَا=ءَكُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"They slaughtering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slaying, your sons"},{"kind":"text","text":"], accord. to the reading commonly obtaining. (Aboo-Is-hák, TA.) ―         -b3-  Hence, (tropical:)"},{"kind":"italic_en","text":"He killed;"},{"kind":"text","text":"because"},{"kind":"arabic","text_bw":"Al*~aboHu","text_ar":"الذَّبْحُ"},{"kind":"text","text":"[in its proper sense, when the object is an animal,] is one of the quickest modes of killing. (TA.) It is said in a trad., (Mgh, TA,) cautioning against accepting the office of a Kádee, (Mgh,)"},{"kind":"arabic","text_bw":"mano juEila qaADiyFA bayona","text_ar":"مَنْ جُعِلَ قَاضِيًا بَيْنَ"},{"kind":"arabic","text_bw":"Aln~aAsi fakaA^an~amaA *ubiHa bigayori sik~iynK","text_ar":"النَّاسِ فَكَاَنَّمَا ذُبِحَ بِغَيْرِ سِكِّينٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Whoso is made a Kádee among the people, he is as though he were slaughtered without a knife"},{"kind":"text","text":"]: (Mgh, TA: *) expl. by some as meaning, (tropical:)"},{"kind":"italic_en","text":"he is as though he were killed"},{"kind":"text","text":"[&c.]. (TA.) ―         -b4-  [Hence, also, because"},{"kind":"arabic","text_bw":"Al*~aboHu","text_ar":"الذَّبْحُ"},{"kind":"text","text":"renders the flesh of an animal allowable, or lawful, as food,] (tropical:)"},{"kind":"italic_en","text":"It rendered allowable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lawful:"},{"kind":"text","text":"as salt and the sun and the fishes called"},{"kind":"arabic","text_bw":"niynaAn","text_ar":"نِينَان"},{"kind":"text","text":"(pl. of"},{"kind":"arabic","text_bw":"nuwnN","text_ar":"نُونٌ"},{"kind":"text","text":") do wine, by changing its quality, as is said in a trad. (TA.) ―         -b5-  Also (tropical:)"},{"kind":"italic_en","text":"He broached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"dan~","text_ar":"دَنّ"},{"kind":"text","text":"[or wine-jar,"},{"kind":"italic_en","text":"making a hole in the mouth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removing the clay that closed the mouth"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"so as to draw forth the contents."},{"kind":"text","text":"(S, A, Msb, K.) ―         -b6-  And (tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, choked."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"*abaHatohu AlEaborapu","text_ar":"ذَبَحَتْهُ العَبْرَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Weeping choked him."},{"kind":"text","text":"(A, TA.) ―         -b7-  And, said of thirst, (tropical:)"},{"kind":"italic_en","text":"It affected him severely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressed him."},{"kind":"text","text":"(A, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"*abaHati All~iHoyapu fulaAnFA","text_ar":"ذَبَحَتِ اللِّحْيَةُ فُلَانًا"},{"kind":"text","text":"(tropical:)  The"},{"kind":"italic_en","text":"beard flowed down beneath the chin of such a one so that the anterior portion of the part beneath his lower jaw was apparent:"},{"kind":"text","text":"in which case, the man is said to be"},{"kind":"arabic","text_bw":"biliHoyatihi","text_ar":"بِلِحْيَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ma*obuwHN","text_ar":"مَذْبُوحٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.)"}],"source_refs":["K","A","TA","L","Msb","S","Mgh"]},{"entry_id":"n13679","headword_ar":"ذِبْحٌ","root":"*bH","body":[{"kind":"italic_en","text":"An animal prepared for slaughter"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sacrifice;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"an intended victim"},{"kind":"text","text":"]: (T, A, Msb, TA:) [see also"},{"kind":"arabic","text_bw":"*abiyHN","text_ar":"ذَبِيحٌ"},{"kind":"text","text":", which occurs in this sense in a trad. as applied to a human being:] or"},{"kind":"italic_en","text":"an animal that is slaughtered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sacrificed"},{"kind":"text","text":"]; (S, Mgh, K, TA;) and so ↓"},{"kind":"arabic","text_bw":"*abiyHapN","text_ar":"ذَبِيحَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, Msb;) or this signifies"},{"kind":"italic_en","text":"a slaughtered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sacrificed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat;"},{"kind":"text","text":"(TA;) and is [nominally] fem. of"},{"kind":"arabic","text_bw":"*abiyHN","text_ar":"ذَبِيحٌ"},{"kind":"text","text":", but the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is affixed only because the quality of a subst. is predominant in it: (S:) or the"},{"kind":"arabic","text_bw":"*abiyHN","text_ar":"ذَبِيحٌ"},{"kind":"text","text":"is added to denote that the word is applied to"},{"kind":"italic_en","text":"a sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to be slaughtered"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sacrificed,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not yet slaughtered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sacrificed"},{"kind":"text","text":"]; and when the act has been executed upon it, it is [said to be]"},{"kind":"arabic","text_bw":"*abiyHN","text_ar":"ذَبِيحٌ"},{"kind":"text","text":": (M, voce"},{"kind":"arabic","text_bw":"ramiy~apN","text_ar":"رَمِيَّةٌ"},{"kind":"text","text":":)"},{"kind":"arabic","text_bw":"*iboHN","text_ar":"ذِبْحٌ"},{"kind":"text","text":"is applied to"},{"kind":"italic_en","text":"an animal that is slaughtered"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"as a sacrifice on the occasion of the pilgrimage"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise;"},{"kind":"text","text":"and is like"},{"kind":"arabic","text_bw":"TiHonN","text_ar":"طِحْنٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"maToHuwnN","text_ar":"مَطْحُونٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EiTofN","text_ar":"عِطْفٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"maEoTuwfN","text_ar":"مَعْطُوفٌ"},{"kind":"text","text":", &c.: (TA:) the pl. of ↓"},{"kind":"arabic","text_bw":"*abiyHapN","text_ar":"ذَبِيحَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"*abaAy^iHu","text_ar":"ذَبَايِحُ"},{"kind":"text","text":". (Mgh, Msb.) It is said in the Kur [xxxvii. 107],"},{"kind":"arabic","text_bw":"wafadayonaAhu bidiboHK EaZiymK","text_ar":"وَفَدَيْنَاهُ بِدِبْحٍ عَظِيمٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we ransomed him with a great victim"},{"kind":"text","text":"]. (S, A.)"},{"kind":"arabic","text_bw":"Aljin~i","text_ar":"الجِنِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"*abaAy^iHu","text_ar":"ذَبَايِحُ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Animals sacrificed to the Jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Genii:"},{"kind":"text","text":"for it was customary for a man, when he bought a house, or drew forth [for the first time] the water of a spring, and the like, to sacrifice an animal to the Jinn with the view of avoiding ill luck, (A, TA,) lest some disagreeable accident should happen to him from the Jinn thereof: (A:) and the doing this is forbidden. (A, TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"*ubaHapN","text_ar":"ذُبَحَةٌ"},{"kind":"text","text":"."}],"source_refs":["T","A","Msb","TA","S"]},{"entry_id":"n13680","headword_ar":"ذُبَحٌ","root":"*bH","body":[{"kind":"italic_en","text":"A certain plant which ostriches eat:"},{"kind":"text","text":"(S:) this word and ↓"},{"kind":"arabic","text_bw":"*ibaHN","text_ar":"ذِبَحٌ","orth_type":"arrow"},{"kind":"text","text":"signify the"},{"kind":"italic_en","text":"plant called"},{"kind":"arabic","text_bw":"Aljazaru","text_ar":"الجَزَرُ"},{"kind":"arabic","text_bw":"Alb~arY~u","text_ar":"البَّرىُّ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"which is of a red colour:"},{"kind":"text","text":"and, accord. to the K,"},{"kind":"italic_en","text":"another plant:"},{"kind":"text","text":"but correctly"},{"kind":"italic_en","text":"a red plant"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"nabotN A^aHomaru","text_ar":"نَبْتٌ اَحْمَرُ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"nbt A=xaru","text_ar":"نبت ا=خَرُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"having a stem,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"root,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aSolN","text_ar":"اَصْلٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from which is peeled off a black peel, whereupon there is taken forth a white substance, resembling a white"},{"kind":"arabic","text_bw":"xzrp","text_ar":"خزرة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bead,"},{"kind":"text","text":"but perhaps this is a mistranscription for"},{"kind":"arabic","text_bw":"jazarap","text_ar":"جَزَرَة"},{"kind":"text","text":", i. e. a"},{"kind":"italic_en","text":"carrot"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"which is sweet and good, and is eaten:"},{"kind":"text","text":"[each word is a coll. gen. n.;] and the n. un. is"},{"kind":"arabic","text_bw":"*ubaHapN","text_ar":"ذُبَحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*ibaHapN","text_ar":"ذِبَحَةٌ"},{"kind":"text","text":": so says AHn, on the authority of Fr: and he says also, on the authority of AA, that the"},{"kind":"arabic","text_bw":"*ubaHap","text_ar":"ذُبَحَة"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a tree that grows upon a stem, and in a manner resembling the"},{"kind":"arabic","text_bw":"krAv","text_ar":"كراث"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"karaAv","text_ar":"كَرَاث"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"kur~aAv","text_ar":"كُرَّاث"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and then has a yellow flower; its root is like a"},{"kind":"arabic","text_bw":"jzrp","text_ar":"جزرة"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"jazarap","text_ar":"جَزَرَة"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"carrot"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and it is sweet, and of a red colour:"},{"kind":"text","text":"(TA:) or the"},{"kind":"arabic","text_bw":"*ubaH","text_ar":"ذُبَح"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a plant having a stem,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"root,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aSolN","text_ar":"اَصْلٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"which is peeled, and there comes forth what resembles the"},{"kind":"arabic","text_bw":"jizr","text_ar":"جِزر"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"jizar","text_ar":"جِزَر"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"jazar","text_ar":"جَزَر"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"carrot"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"and a black skin is peeled from it; and it is sweet, and is eaten; and has a red flower."},{"kind":"text","text":"(Ham p. 777.) ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"*ibaHN","text_ar":"ذِبَحٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) the former the more common, (Th, TA,)"},{"kind":"italic_en","text":"A species of the"},{"kind":"arabic","text_bw":"kamoA^apN","text_ar":"كَمْاَةٌ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"truffle"},{"kind":"text","text":"], (K,)"},{"kind":"italic_en","text":"of a white colour."},{"kind":"text","text":"(TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"*ubaAHN","text_ar":"ذُبَاحٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","TA","Th"]},{"entry_id":"n13681","headword_ar":"ذِبَحٌ","root":"*bH","body":[{"kind":"text","text":": see the next preceding paragraph, in two places."}],"source_refs":[]}]}}