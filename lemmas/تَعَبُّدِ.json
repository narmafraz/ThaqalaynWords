{"lemma":"تَعَبُّدِ","slug":"تَعَبُّدِ","root":"ع.ب.د","root_slug":"ع-ب-د","root_link":"/words/roots/ع-ب-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27789"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D8%A8%D9%8F%D9%91%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to enslave"},{"pos":"verb","gloss":"to devote oneself to the service of God"},{"pos":"noun","gloss":"verbal noun of تَعَبَّدَ (taʕabbada) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27789","headword_ar":"تعبّد","root":"Ebd","body":[{"kind":"italic_en","text":"He became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, a servant of God; devoted himself to religious services"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercises; applied himself to acts of devotion."},{"kind":"text","text":"(S, A, O, L, Msb, K.) And"},{"kind":"arabic","text_bw":"tEb~d biA@loA_isolaAmi","text_ar":"تعبّد بِا@لْاـِسْلَامِ"},{"kind":"italic_en","text":"He became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, a servant of God by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"following the religion of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"El-Islám;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he followed El-Islám as his religion;"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"*aAna bihi","text_ar":"ذَانَ بِهِ"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"dyn","text_ar":"دين"},{"kind":"text","text":".)       -A2-  Also,"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"became refractory, and difficult to manage,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"like a wild animal."},{"kind":"text","text":"(L.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"Eabida","text_ar":"عَبِدَ"},{"kind":"text","text":", first sentence.       -A3-"},{"kind":"arabic","text_bw":"tEb~dhu","text_ar":"تعبّدهُ"},{"kind":"text","text":": see 2, first sentence, in two places. ―         -b2-  Also"},{"kind":"italic_en","text":"He called him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"invited him, to obedience."},{"kind":"text","text":"(Msb.)       -A4-"},{"kind":"arabic","text_bw":"tEb~d AlbaEiyra","text_ar":"تعبّد البَعِيرَ"},{"kind":"italic_en","text":"He drove away the camel until he became fatigued"},{"kind":"text","text":"(O, K, TA)"},{"kind":"italic_en","text":"and was obliged to stop."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","O","TA"]}]},"classical_definitions":null}