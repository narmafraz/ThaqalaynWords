rpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَلْتَبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَلْتَبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَلْتَبِس","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَلْتَبِس","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَلْتَبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَلْتَبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَلْتَبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَلْتَبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَلْتَبِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْتَبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَلْتَبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِلْتَبَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِلْتَبَسْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَلْتَبِس","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَلْتَبِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n37503"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%84%D9%92%D8%AA%D9%8E%D8%A8%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be ambiguous, dubious, confused, equivocal"},{"pos":"verb","gloss":"to get mixed up with"},{"pos":"verb","gloss":"to mistake"}]},"etymology":null,"ipa":["/il.ta.ba.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37503","headword_ar":"التبس","root":"lbs","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(spun thread)"},{"kind":"italic_en","text":"became entangled."},{"kind":"text","text":"(Lth, Az, Sgh, in TA, art."},{"kind":"arabic","text_bw":"Esr","text_ar":"عسر"},{"kind":"text","text":".) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, or an affair, or a case)"},{"kind":"italic_en","text":"became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"involved, complicated,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused,"},{"kind":"text","text":"(S, M, Msb, *)"},{"kind":"italic_en","text":"and dubious;"},{"kind":"text","text":"(S, Msb;) as also ↓"},{"kind":"arabic","text_bw":"A^alobasa","text_ar":"اَلْبَسَ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"lab~asa","text_ar":"لَبَّسَ","orth_type":"arrow"},{"kind":"text","text":", which last belongs to the class of"},{"kind":"arabic","text_bw":"bay~ana","text_ar":"بَيَّنَ"},{"kind":"text","text":"in the phrase"},{"kind":"quote","text":"qado bay~ana AlS~uboHu li*iY Eayonayoni"},{"kind":"text","text":"(M, TA.) [You say,"},{"kind":"arabic","text_bw":"Altbs Al$~aYo'u bi$aYo'K A=xara","text_ar":"التبس الشَّىْءُ بِشَىْءٍ ا=خَرَ"},{"kind":"italic_en","text":"The thing became confounded with another thing;"},{"kind":"text","text":"as, for instance, a subst. with a part. n. when both are written in the same manner, as in the case of"},{"kind":"arabic","text_bw":"kaAhilN","text_ar":"كَاهِلٌ"},{"kind":"text","text":".] And"},{"kind":"arabic","text_bw":"Altbs Ealayohi AlA^amoru","text_ar":"التبس عَلَيْهِ الاَمْرُ"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, became confused and dubious to him."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"jaEalaniY A^alotabisu fiY A^amorihi","text_ar":"جَعَلَنِى اَلْتَبِسُ فِى اَمْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made me to become confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in doubt, respecting his case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"Aulotubisa biY","text_ar":"اُلْتُبِسَ بِى"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disordered in my mind."},{"kind":"text","text":"(K, * TA, from a trad.) ―         -b3-"},{"kind":"arabic","text_bw":"Altbs biEamalihi","text_ar":"التبس بِعَمَلِهِ"},{"kind":"text","text":"&c.: see 5. ―         -b4-"},{"kind":"arabic","text_bw":"Ailotabasato bihi Alxayolu","text_ar":"اِلْتَبَسَتْ بِهِ الخَيْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The horsemen overtook him."},{"kind":"text","text":"(A, TA.) ―         -b5-  ["},{"kind":"arabic","text_bw":"Altbs bihi","text_ar":"التبس بِهِ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made it to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had it, as an accompaniment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an adjunct."},{"kind":"text","text":"Hence, one of the uses of the preposition"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"is explained by some as being"},{"kind":"arabic","text_bw":"liloAilotibaAsi","text_ar":"لِلْاِلْتِبَاسِ"},{"kind":"text","text":": by others, ↓"},{"kind":"arabic","text_bw":"lilomulaAbasapi","text_ar":"لِلْمُلَابَسَةِ","orth_type":"arrow"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"lilomuSaAHabapi","text_ar":"لِلْمُصَاحَبَةِ"},{"kind":"text","text":": all of which signify nearly the same. For instance, it is said in the Mgh, art."},{"kind":"arabic","text_bw":"twj","text_ar":"توج"},{"kind":"text","text":", that in the phrase"},{"kind":"arabic","text_bw":"Alt~amaAviylu biAltiyjaAni","text_ar":"التَّمَاثِيلُ بِالتِيجَانِ"},{"kind":"text","text":"“ the effigies with the crowns ” upon pieces of money,"},{"kind":"arabic","text_bw":"bAltyjAn","text_ar":"بالتيجان"},{"kind":"text","text":"is used as a denotative of state, meaning"},{"kind":"arabic","text_bw":"mulotabisapF biAlit~yjaAni","text_ar":"مُلْتَبِسَةً بِالِتّيجَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maqoruwnapF maEahaA","text_ar":"مَقْرُونَةً مَعَهَا"},{"kind":"italic_en","text":"accompanied with the crowns,"},{"kind":"text","text":"as their attributes: and"},{"kind":"arabic","text_bw":"nusab~iHu","text_ar":"نُسَبِّحُ"},{"kind":"arabic","text_bw":"biHamodika","text_ar":"بِحَمْدِكَ"},{"kind":"text","text":"“ we declare thy remoteness from evil, with the praising of Thee, ” in the Kur ii. 28, is explained by Bd and others as meaning,"},{"kind":"arabic","text_bw":"mulotabisiyna biHamodika","text_ar":"مُلْتَبِسِينَ بِحَمْدِكَ"},{"kind":"italic_en","text":"making the praising of Thee to be as an accompaniment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an adjunct,"},{"kind":"text","text":"to our doing that: and"},{"kind":"arabic","text_bw":"tanobutu biA@ld~uhoni","text_ar":"تَنْبُتُ بِا@لدُّهْنِ"},{"kind":"text","text":"“ growing, with oil ”, in the same, xxiii. 20, as meaning,"},{"kind":"arabic","text_bw":"mulotabisFA","text_ar":"مُلْتَبِسًا"},{"kind":"page_break","n":2648},{"kind":"arabic","text_bw":"biAld~uhoni","text_ar":"بِالدُّهْنِ"},{"kind":"italic_en","text":"having oil as an accompaniment"},{"kind":"text","text":"to its growth. Sometimes, in such instances, we find"},{"kind":"arabic","text_bw":"mutalab~isFA","text_ar":"مُتَلَبِّسًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mutalab~isiyna","text_ar":"مُتَلَبِّسِينَ"},{"kind":"text","text":"in the places of"},{"kind":"arabic","text_bw":"mulotabisFA","text_ar":"مُلْتَبِسًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mulotabisiyna","text_ar":"مُلْتَبِسِينَ"},{"kind":"text","text":": see 5.]"}],"source_refs":["TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D9%84%D8%AA%D8%A8%D8%B3/","headword_ar":"التبسم","entries":[{"lexicon_id":"dictionary_23","lexicon_en":"Aḥmadnagarī, Dastūr al-ʿUlamāʾ, or Jāmiʿ al-ʿUlūm fī Iṣṭilāḥāt al-Funūn (d. 18th Century CE)","lexicon_ar":"دستور العلماء للأحمدنكري","permalink":"https://arabiclexicon.hawramani.com/?p=38875#820fc4","body_html":"<span>التبسم: مَا لَا يكون مسموعا لَهُ ولجيرانه بِخِلَاف الضحك والقهقهة فَإِن الضحك مَا يكون مسموعا لَهُ فَقَط والقهقهة مَا يكون مسموعا لَهُ ولجيرانه نعم النَّاظِم رَحمَه الله.</span><br><span>(بَرى رخى بشكر خنده قتل عَالم كرد </span><span class=\"red\">...</span><span> بكفتمش كه مرا هم بكش تَبَسم كرد}</span>"}]}}