,"per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُذَرَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُذَرِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُذَرِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُذَرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُذَرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُذَرَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُذَرِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُذَرّ","in_corpus":true,"count":25,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُذَرَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُذَرَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"ذَرَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ذَرَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُذَرِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُذَرِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":44,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n13738","n13841","n13842","n13846"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D8%B1%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"alternative form of ذَرَا (ḏarā)","tags":["alt-of","alternative"]},{"pos":"verb","gloss":"to disperse, to scatter","tags":["transitive"]},{"pos":"verb","gloss":"to carry away (dust) (of the wind)","tags":["transitive"]},{"pos":"verb","gloss":"to winnow (grain)","tags":["transitive"]},{"pos":"verb","gloss":"to atomize","tags":["transitive"]},{"pos":"noun","gloss":"plural of ذُرْوَة (ḏurwa, “peak, summit”)","tags":["form-of","plural","transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13738","headword_ar":"ذَرِّىٌّ","root":"*r","body":[{"kind":"text","text":"a rel. n. from"},{"kind":"arabic","text_bw":"*ar~N","text_ar":"ذَرٌّ"},{"kind":"text","text":", (T,) (tropical:)  The"},{"kind":"italic_en","text":"diversified wavy marks, streaks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grain,"},{"kind":"text","text":"of a sword: (T, M, A, K:) likened to the track of young ants. (M, A.) It occurs in poetry, in which some read"},{"kind":"arabic","text_bw":"dur~iY~N","text_ar":"دُرِّىٌّ"},{"kind":"text","text":"[q. v.]. (M.) ―         -b2-  And (assumed tropical:)  A sword"},{"kind":"italic_en","text":"having much of such wavy marks,"},{"kind":"text","text":"&c. (K.)"}],"source_refs":["T","M","A","K"]},{"entry_id":"n13841","headword_ar":"ذَرًى","root":"*rw and *rY","body":[{"kind":"text","text":", also written"},{"kind":"arabic","text_bw":"*arFA","text_ar":"ذَرًا"},{"kind":"text","text":", (or, accord. to some copies of the S, ↓"},{"kind":"arabic","text_bw":"*urFY","text_ar":"ذُرًى","orth_type":"arrow"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"A thing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"such as dust &c."},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that the wind has raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to fly, and carried away:"},{"kind":"text","text":"(S:) or it signifies"},{"kind":"italic_en","text":"what one has winnowed;"},{"kind":"text","text":"(M;) or"},{"kind":"arabic","text_bw":"maA ta*oruwhu","text_ar":"مَا تَذْرُوهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what thou winnowest,"},{"kind":"text","text":"as is indicated by the context of this explanation]; like as"},{"kind":"arabic","text_bw":"nafaDN","text_ar":"نَفَضٌ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"maAtanofuDuhu","text_ar":"مَاتَنْفُضُهُ"},{"kind":"text","text":". (T.) ―         -b2-  And"},{"kind":"arabic","text_bw":"*arFY","text_ar":"ذَرًى"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"*urFY","text_ar":"ذُرًى","orth_type":"arrow"},{"kind":"text","text":"(accord. to different copies of the S)"},{"kind":"italic_en","text":"Tears poured forth:"},{"kind":"text","text":"(S:) or so ↓"},{"kind":"arabic","text_bw":"*ariY~N","text_ar":"ذَرِىٌّ","orth_type":"arrow"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"damoEN *ariY~N","text_ar":"دَمْعٌ ذَرِىٌّ"},{"kind":"text","text":"]. (M, TA.)       -A2-  Also"},{"kind":"italic_en","text":"A shelter;"},{"kind":"text","text":"(M, TA;)"},{"kind":"italic_en","text":"anything by which one is protected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheltered:"},{"kind":"text","text":"(S, Msb:)"},{"kind":"italic_en","text":"a shelter from the cold wind, consisting of a wall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of trees:"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"a shelter that is made for camels such as are termed"},{"kind":"arabic","text_bw":"$awol","text_ar":"شَوْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"by pulling up trees of the kind called"},{"kind":"arabic","text_bw":"Earofaj","text_ar":"عَرْفَج"},{"kind":"italic_en","text":"&c. and placing them one upon another in the direction whence blows the north,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"northerly, wind, in the camel's nightly resting-place."},{"kind":"text","text":"(T.) [Hence,] one says,"},{"kind":"arabic","text_bw":"fulaAnN fiY *araY fulaAnK","text_ar":"فُلَانٌ فِى ذَرَى فُلَانٍ"},{"kind":"italic_en","text":"Such a one is in the protection of such a one."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"A^anaA fiY Zil~i fulaAnN wafiY *araAhu","text_ar":"اَنَا فِى ظِلِّ فُلَانٌ وَفِى ذَرَاهُ"},{"kind":"italic_en","text":"I am in the protection of such a one, and in his shelter."},{"kind":"text","text":"(S.) And [hence, perhaps,]"},{"kind":"arabic","text_bw":"A_in~a fulaAnFA lakariymu Al*~araY","text_ar":"اـِنَّ فُلَانًا لَكَرِيمُ الذَّرَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Verily such a one is generous in disposition."},{"kind":"text","text":"(AZ, T.) ―         -b2-  Also The"},{"kind":"italic_en","text":"court,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"yard,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"finaA='","text_ar":"فِنَا=ء"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of a house."},{"kind":"text","text":"(Har pp. 56 and 442.)       -A3-  see also"},{"kind":"arabic","text_bw":"*arowN","text_ar":"ذَرْوٌ"},{"kind":"text","text":", in two places."}],"source_refs":["S","Msb"]},{"entry_id":"n13842","headword_ar":"ذُرًى","root":"*rw and *rY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"*arFY","text_ar":"ذَرًى"},{"kind":"text","text":", in two places: ―         -b2-  and"},{"kind":"arabic","text_bw":"*uraAwapN","text_ar":"ذُرَاوَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13846","headword_ar":"ذَرِىٌّ","root":"*rw and *rY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"*arFY","text_ar":"ذَرًى"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"*arFY *ariY~N","text_ar":"ذَرًى ذَرِىٌّ"},{"kind":"italic_en","text":"A warm shelter."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B0%D8%B1%D9%89/","headword_ar":"ذرى","entries":[{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=22221#058d46","body_html":"<span>(ذرى) : ذَرِىَ به ذَرىً: فَرح به.</span>"},{"lexicon_id":"dictionary_13","lexicon_en":"Al-Ṣaghānī, al-Shawārid (d. 1252 CE)","lexicon_ar":"الشوارد للصغاني","permalink":"https://arabiclexicon.hawramani.com/?p=22221#719b65","body_html":"<span>(ذرى) : ذَرَّيْتُ القَوْمَ: جَعَلْتُهم في ذَرىً من الرِّيحِ.</span>"},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=22221#bb2d80","body_html":"<div>ذرى: الإِذْرَاءُ: ضَرْبُكَ الشَّيْءَ تَرْمي به أو تَصْرَعُه. يُقال: ضَرَبْتُه بالسَّيْفِ فأذْرَيْتُ رَأْسَه، وطَعَنْتُه فأذْرَيْتُه عن فَرَسِه: أي صَرَعْته. والسَّيْفُ يُذْري ضَرِيْبَتَه: أي يَرْمي به.</div><div>والذَّرى من الدَّمْعِ: ما انْصَبَّ، أذْرَتِ العَيْنُ دَمْعَها تُذْري إذْرَاءً.</div><div>وذَرَّيْتُ الشّاةَ تَذْرِيَةً فهي مُذَرّاةٌ: إذا جَزَزْتَ صُوْفَها فَتَركْتَ على ظَهْرِها شَيْئاً لتُعْرَفَ به، ولا تكونُ في المِعْزى ولكنْ في الإِبِلِ والضَّأْنِ خاصَّةً.</div><div>وذَرَّيْتُ فلاناً: إذا مَدَحْتَه. وإذا أعَنْتَه.</div><div>وذَرِيَ فُوْهُ يَذْرى: أي سَقَطَتْ أسْنَانُه.</div>"}]}}