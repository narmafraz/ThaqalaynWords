{"lemma":"رُعْبٌ","slug":"رُعْبٌ","root":"ر.ع.ب","root_slug":"ر-ع-ب","root_link":"/words/roots/ر-ع-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رُعْب","root":"رعب","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15843"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D8%B9%D9%92%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be terrified","tags":["intransitive"]},{"pos":"verb","gloss":"to terrify, to horrify, to frighten","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15843","headword_ar":"رُعْبٌ","root":"rEb","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"ruEubN","text_ar":"رُعُبٌ","orth_type":"arrow"},{"kind":"text","text":", (A, Msb, K,) both said to be inf. ns., (TA,) or the former is an inf. n. of"},{"kind":"arabic","text_bw":"raEaba","text_ar":"رَعَبَ"},{"kind":"text","text":"as intrans. (K, TA) or as trans., (A, MA,) and the latter is a simple subst., (TA,) or each of them is a simple subst., (Msb, TA,)"},{"kind":"italic_en","text":"Fear, fright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terror:"},{"kind":"text","text":"(S, A, Msb, K:) or"},{"kind":"italic_en","text":"fear that fills the bosom and heart;"},{"kind":"text","text":"as Er-Rághib and Z have indicated, following Aboo-'Alee and IJ: or the"},{"kind":"italic_en","text":"utmost fear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terror."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"faEala *`lika ruEobFA laA rugobFA","text_ar":"فَعَلَ ذٰلِكَ رُعْبًا لَا رُغْبًا"},{"kind":"italic_en","text":"He did that from fear, not from desire."},{"kind":"text","text":"(A.)       -A2-  Also the former, The"},{"kind":"italic_en","text":"socket of the head"},{"kind":"text","text":"of an arrow; the"},{"kind":"italic_en","text":"part into which the head enters, over which are the twists of sinew;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ruEoZN","text_ar":"رُعْظٌ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"riEabapN","text_ar":"رِعَبَةٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","A","Msb","K","TA","MA"]}]},"classical_definitions":null}