"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"text","text":", (M, Mgh,) inf. n."},{"kind":"arabic","text_bw":"tawotiydN","text_ar":"تَوْتِيدٌ"},{"kind":"text","text":";"},{"kind":"page_break","n":2917},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"He knocked with a mallet,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"and fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made from"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast,"},{"kind":"text","text":"a wooden pin, peg, or"},{"kind":"italic_en","text":"stake,"},{"kind":"text","text":"(S, * M, A, * L, Msb, K,) in the ground or in a wall. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"watada","text_ar":"وَتَدَ"},{"kind":"text","text":", (M, L, K,) [aor."},{"kind":"arabic","text_bw":"yatidu","text_ar":"يَتِدُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"watodN","text_ar":"وَتْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tidapN","text_ar":"تِدَةٌ"},{"kind":"text","text":"; (M, L;) and ↓"},{"kind":"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"text","text":"; (M, L, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wooden pin, peg, or stake,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fixed, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast."},{"kind":"text","text":"(M, L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"wat~ada A@ll~`hu AlA^aroDa biAljibaAli","text_ar":"وَتَّدَ ا@للّٰهُ الاَرْضَ بِالجِبَالِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A^awotadahaA","text_ar":"اَوْتَدَهَا","orth_type":"arrow"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"God made the earth firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast by means of the mountains."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"rjolahu fiY AlA^aroDi","text_ar":"رجْلَهُ فِى الاَرْضِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He fixed his foot firmly upon the ground."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"fiY bayotihi","text_ar":"فِى بَيْتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He remained fixed in his house."},{"kind":"text","text":"(L.) ―         -b6-  ↓"},{"kind":"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(growing corn)"},{"kind":"italic_en","text":"put forth its stalks, and became firm and strong."},{"kind":"text","text":"(L.) ―         -b7-  ↓"},{"kind":"arabic","text_bw":"wt~d","text_ar":"وتّد","orth_type":"arrow"},{"kind":"text","text":", (S, L,) inf. n."},{"kind":"arabic","text_bw":"tawotiydN","text_ar":"تَوْتِيدٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"Libidine veneres exarsit"},{"kind":"text","text":"vir: (S, L:)"},{"kind":"italic_en","text":"erexit"},{"kind":"text","text":"penem. (K.) ―         -b8-  It was said to an Arab of the desert, What is"},{"kind":"arabic","text_bw":"naTo$aAn","text_ar":"نَطْشَان"},{"kind":"text","text":"? and he answered,"},{"kind":"arabic","text_bw":"AlEaTo$aAna","text_ar":"العَطْشَانَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yuwat~idu","text_ar":"يُوَتِّدُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It corroborates the word"},{"kind":"arabic","text_bw":"ET$An","text_ar":"عطشان"},{"kind":"text","text":"]: or, as some relate it,"},{"kind":"arabic","text_bw":"$aYo'N","text_ar":"شَىْءٌ"},{"kind":"arabic","text_bw":"natidu bihi kalaAmanaA","text_ar":"نَتِدُ بِهِ كَلَامَنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A thing,"},{"kind":"text","text":"meaning a word,"},{"kind":"italic_en","text":"by which we corroborate our speech"},{"kind":"text","text":"]. (A.)"}],"source_refs":["M","Mgh","L","K","S"]},{"entry_id":"n41588","headword_ar":"وَتَدٌ","root":"wtd","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"watodN","text_ar":"وَتْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wad~N","text_ar":"وَدٌّ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"watidN","text_ar":"وَتِدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n41589","headword_ar":"وَتِدٌ","root":"wtd","body":[{"kind":"text","text":", (S, M, K, &c.,) of the dial. of El-Hijáz, and the most chaste form, (Msb,) and ↓"},{"kind":"arabic","text_bw":"watadN","text_ar":"وَتَدٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"watodN","text_ar":"وَتْدٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"wad~N","text_ar":"وَدٌّ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Msb,) of the dial. of Nejd, (Msb,) the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"being made quiescent, and then changed into"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", and incorporated into the final"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", (S, * Msb,) and ↓"},{"kind":"arabic","text_bw":"watiydN","text_ar":"وَتِيدٌ","orth_type":"arrow"},{"kind":"text","text":", (L, art."},{"kind":"arabic","text_bw":"wd","text_ar":"ود"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"A wooden pin, peg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake, which is fixed in the ground"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a wall:"},{"kind":"text","text":"(M, L, K:) pl."},{"kind":"arabic","text_bw":"A^awotaAdN","text_ar":"اَوْتَادٌ"},{"kind":"text","text":". (S, M, L, K.) [You say,]"},{"kind":"arabic","text_bw":"A^a*al~u mano watidK biqaAEK","text_ar":"اَذَلُّ مَنْ وَتِدٍ بِقَاعٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More vile than a wooden peg in a plain"},{"kind":"text","text":"]: because it is always knocked. A proverb. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"watidN waAtidN","text_ar":"وَتِدٌ وَاتِدٌ"},{"kind":"text","text":", an expression like"},{"kind":"arabic","text_bw":"$ugolN $aAglN","text_ar":"شُغْلٌ شَاغلٌ"},{"kind":"text","text":", (As, S,) the latter word a corroborative; (K;) or"},{"kind":"italic_en","text":"A wooden pin, peg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast,"},{"kind":"text","text":"(A, L,)"},{"kind":"italic_en","text":"and erect."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"A^awotaAdu AlA^aroDi","text_ar":"اَوْتَادُ الاَرْضِ"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"The pegs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stakes, of the earth;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"the mountains:"},{"kind":"text","text":"(A, L, K:) so called because they make the earth firm, or fast. (L.) ―         -b4-"},{"kind":"arabic","text_bw":"A^awotaAdu AlbilaAdi","text_ar":"اَوْتَادُ البِلَادِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The chiefs of the towns, provinces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"countries."},{"kind":"text","text":"(L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"A^awotaAdu Alfam","text_ar":"اَوْتَادُ الفَم"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The teeth."},{"kind":"text","text":"(L, K, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"watidN","text_ar":"وَتِدٌ"},{"kind":"text","text":", of a sandal, (assumed tropical:)  The"},{"kind":"italic_en","text":"part that projects from the ear"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"loop"},{"kind":"text","text":"]. (L.) ―         -b7-"},{"kind":"arabic","text_bw":"watidN","text_ar":"وَتِدٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A peg of a"},{"kind":"arabic","text_bw":"bayot","text_ar":"بَيْت"},{"kind":"text","text":", q. v.;]"},{"kind":"italic_en","text":"a portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"division, of a foot of a verse, consisting of three letters:"},{"kind":"text","text":"(L, K *:) it is"},{"kind":"italic_en","text":"of two kinds: one consisting of two movent letters followed by a quiescent letter;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"faEuw","text_ar":"فَعُو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eiluno","text_ar":"عِلُنْ"},{"kind":"text","text":"; which kind is called"},{"kind":"arabic","text_bw":"watidN maqoruwnN","text_ar":"وَتِدٌ مَقْرُونٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a conjoined peg;"},{"kind":"text","text":"because each two letters are conjoined by a vowel:"},{"kind":"italic_en","text":"the other consisting of three letters; one movent, then one quiescent, then one movent;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"laAtu","text_ar":"لَاتُ"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"mafoEuwlaAtu","text_ar":"مَفْعُولَاتُ"},{"kind":"text","text":"; which kind is called"},{"kind":"arabic","text_bw":"watidN maforuwqN","text_ar":"وَتِدٌ مَفْرُوقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a disjoined peg;"},{"kind":"text","text":"because the quiescent letter disjoins the two movent letters: pl."},{"kind":"arabic","text_bw":"A^awotaAdN","text_ar":"اَوْتَادٌ"},{"kind":"text","text":"."},{"kind":"arabic","text_bw":"ziHaAf","text_ar":"زِحَاف"},{"kind":"text","text":"does not take place in the"},{"kind":"arabic","text_bw":"AwtAd","text_ar":"اوتاد"},{"kind":"text","text":", because the foot depends upon them; but it does in the"},{"kind":"arabic","text_bw":"A^asobaAb","text_ar":"اَسْبَاب"},{"kind":"text","text":". (L.) ―         -b8-"},{"kind":"arabic","text_bw":"watidN","text_ar":"وَتِدٌ"},{"kind":"text","text":"(A, L, K) and"},{"kind":"arabic","text_bw":"watidapN","text_ar":"وَتِدَةٌ"},{"kind":"text","text":"(L) of the ear., (tropical:)  [The"},{"kind":"italic_en","text":"tragus;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"small prominent thing in the anterior part,"},{"kind":"text","text":"(A, L, K,)"},{"kind":"italic_en","text":"like a teat,"},{"kind":"text","text":"(A, L,)"},{"kind":"italic_en","text":"next the uppermost part of the side of the beard:"},{"kind":"text","text":"(L:) or the"},{"kind":"italic_en","text":"prominent part next the temple:"},{"kind":"text","text":"(L:) or the"},{"kind":"arabic","text_bw":"watidaAni","text_ar":"وَتِدَانِ"},{"kind":"text","text":"of the two ears are the"},{"kind":"italic_en","text":"two parts in the interior thereof resembling a"},{"kind":"arabic","text_bw":"watid","text_ar":"وَتِد"},{"kind":"text","text":","},{"kind":"italic_en","text":"also called the"},{"kind":"arabic","text_bw":"EayoraAni","text_ar":"عَيْرَانِ"},{"kind":"text","text":". (S.)"}],"source_refs":["Msb","S","M","K","L","As","A"]}]},"classical_definitions":null}