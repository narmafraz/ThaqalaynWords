rm":"يَفْرِضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفْرَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَفْرِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فُرِضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فُرِضْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَرَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرَضْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفْرَض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْرَض","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْرِض","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْرِض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":221,"cross_references":{"qac":{"found":true,"lemma_key":"فُرِضَ","root":"فرض","pos":"V","occurrence_count":9},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["","n33574","n33575"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8F%D8%B1%D9%90%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ordain"},{"pos":"verb","gloss":"to make obligatory, to oblige","examples":[{"text":"السَّفَرُ يَفْرِضُ عَلَيْنَا أَنْ نَضِعَ ثِقَتَنَا فِي عَطْفِ الْغُرَبَاءِ.","english":"Travel forces us to put our trust in the kindness of strangers."},{"text":"إِنَّ أَكْبَرَ قِيَمِ ٱلۡإِنْسَانِ هِيَ تِلْكَ ٱلَّتِي يَبْدَأُ مِنْهَا (بِٱلرَّفْضِ) وَ(عَدَمِ ٱلتَّسْلِيمِ) ٱللَّذَيْنِ يَتَلَخَّصَانِ بِكَلِمَةِ (لَا) وَمِنْهَا بَدَأَ آدَمٌ أَبُو ٱلۡبَشَرِ.. أُمِرَ أَنْ لَا يَأْكُلَ مِنْ تِلْكَ ٱلثَّمَرَةِ، لٰكِنَّهُ اَكَلَ، فَصَارَ بَعْدَئِذٍ بَشَرًا وَهَبَطَ إِلَىٰ ٱلۡأَرْضِ، وِإِلَّا لَكَانَ مَلَكًا لَا مِيزَةَ لَهُ، وَلَصَارَ غَيْرُهُ آدَمَ وَلَفُرِضَ عَلَيْهِ أَنْ يَسْجُدَ أَمَامَهُ، لَكِنَّهُ تَمَرَّدَ فَصَارَ آدَم.","english":"For sure the biggest human value is that from which s/he begings by \"refusing\" and \"not consenting\" that are summarised in the word \"no\" and from it began Adam the father of humanity.. He had been ordered not to eat from that fruit, but he ate, and henceforth he became a human and landed on Earth, if he had not he would have been an angel with no distinguishing feature, and someone else would have become Adam and he would have been obliged to prostrate before him, but he rebelled and so he became Adam."}]},{"pos":"verb","gloss":"to impose"},{"pos":"verb","gloss":"to notch, to make incisions in"},{"pos":"noun","gloss":"verbal noun of فَرَضَ (faraḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"duty"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew פָּרַץ (pāraṣ), Aramaic פְּרַץ (pəraṣ) and Akkadian paraṣum."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33574","headword_ar":"فَرْضٌ","root":"frD","body":[{"kind":"italic_en","text":"A mark"},{"kind":"text","text":"["},{"kind":"italic_en","text":"made by notching,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise;"},{"kind":"text","text":"as is shown by the first explanation of 1]: (TA:)"},{"kind":"italic_en","text":"a notch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an incision,"},{"kind":"text","text":"in a thing: (O, TA:) of a bow, (S, A, K,) the"},{"kind":"italic_en","text":"place of the string;"},{"kind":"text","text":"(K;) the"},{"kind":"italic_en","text":"notch"},{"kind":"text","text":"(S, A, O)"},{"kind":"italic_en","text":"in the curved extremity"},{"kind":"text","text":"thereof, (A,)"},{"kind":"italic_en","text":"into which the string falls;"},{"kind":"text","text":"(S, O;) as also ↓"},{"kind":"arabic","text_bw":"furoDapN","text_ar":"فُرْضَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (A, TA;) or this is the"},{"kind":"italic_en","text":"place of the notch for the string thereof:"},{"kind":"text","text":"(Msb:) pl. of the former"},{"kind":"arabic","text_bw":"firaADN","text_ar":"فِرَاضٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"furuwDN","text_ar":"فُرُوضٌ"},{"kind":"text","text":"; (TA;) and of the latter"},{"kind":"arabic","text_bw":"furaDN","text_ar":"فُرَضٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"firaADN","text_ar":"فِرَاضٌ"},{"kind":"text","text":": (Msb:) also, of a"},{"kind":"arabic","text_bw":"zanod","text_ar":"زَنْد"},{"kind":"text","text":", (S, K,) or [rather] of a"},{"kind":"arabic","text_bw":"zanodap","text_ar":"زَنْدَة"},{"kind":"text","text":", (A,) the"},{"kind":"italic_en","text":"notch;"},{"kind":"text","text":"(K;) or the"},{"kind":"italic_en","text":"place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"part, whence the fire is produced;"},{"kind":"text","text":"(S, K;) the"},{"kind":"italic_en","text":"hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforation, that is made in the head"},{"kind":"text","text":"thereof,"},{"kind":"italic_en","text":"into which the"},{"kind":"arabic","text_bw":"zanod","text_ar":"زَنْد"},{"kind":"italic_en","text":"is put, and then twisted round, in producing fire;"},{"kind":"text","text":"also called"},{"kind":"arabic","text_bw":"wakorN","text_ar":"وَكْرٌ"},{"kind":"text","text":"; (A;) and ↓"},{"kind":"arabic","text_bw":"furoDapN","text_ar":"فُرْضَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (TA:) and"},{"kind":"arabic","text_bw":"furaDN","text_ar":"فُرَضٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"notches"},{"kind":"text","text":"in an unfeathered and headless arrow [such as is used in the game called"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"italic_en","text":"I. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maforuwDN","text_ar":"مَفْرُوضٌ","orth_type":"arrow"},{"kind":"text","text":"(A, Msb, K) ["},{"kind":"italic_en","text":"Apportioned: appointed; made lawful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allowable:"},{"kind":"text","text":"and] a thing"},{"kind":"italic_en","text":"made obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"binding, by God;"},{"kind":"text","text":"(S, A, O, K;)"},{"kind":"italic_en","text":"for neglecting which one will be punished;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"waAjibN","text_ar":"وَاجِبٌ"},{"kind":"text","text":"; accord. to EshSháfi'ee; (TA in art."},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب"},{"kind":"text","text":";) because it has marks and limits; (S, O, TA;) said to be from the same word signifying “ a mark, ” because it inseparably pertains to a man, like a mark; (TA;) or, as some say, because it necessarily pertains to a man like as does the"},{"kind":"arabic","text_bw":"faroD","text_ar":"فَرْض"},{"kind":"text","text":", i. e. notch, to the arrow; (O, TA;) as also ↓"},{"kind":"arabic","text_bw":"mufotaraDN","text_ar":"مُفْتَرَضٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl."},{"kind":"arabic","text_bw":"furuwDN","text_ar":"فُرُوضٌ"},{"kind":"text","text":". (Msb.) As a law-term, it is of two sorts,"},{"kind":"arabic","text_bw":"faroDu EayonK","text_ar":"فَرْضُ عَيْنٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faroDu kifaAyapK","text_ar":"فَرْضُ كِفَايَةٍ"},{"kind":"text","text":": the former is That"},{"kind":"italic_en","text":"whereof the observance is obligatory on every one, and does not become of no force in respect of some in consequence of the observance"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by some"},{"kind":"text","text":"["},{"kind":"italic_en","text":"others"},{"kind":"text","text":"]; as religious belief, and the like: the latter is That"},{"kind":"italic_en","text":"whereof the observance is obligatory on the collective body of the Muslims, and, in consequence of the observance"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by some, becomes of no force in respect of the rest;"},{"kind":"text","text":"as warring against unbelievers, and the prayer over the dead in the bier. (KT.) You say,"},{"kind":"arabic","text_bw":"h`*aA A^amorN faroDN Ealayohimo","text_ar":"هٰذَا اَمْرٌ فَرْضٌ عَلَيْهِمْ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"maforuwDN","text_ar":"مَفْرُوضٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mufotaraDN","text_ar":"مُفْتَرَضٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"This is"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"made obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"binding, on them by God."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Haq~uka","text_ar":"حَقُّكَ"},{"kind":"arabic","text_bw":"faroDN","text_ar":"فَرْضٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"maforuwDN","text_ar":"مَفْرُوضٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mufotaraDN","text_ar":"مُفْتَرَضٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"Thy right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, is"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"made obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"binding, by God."},{"kind":"text","text":"(A.) ↓"},{"kind":"arabic","text_bw":"naSiybFA maforuwDFA","text_ar":"نَصِيبًا مَفْرُوضًا","orth_type":"arrow"},{"kind":"text","text":", in the Kur [iv. 8 and 118], means"},{"kind":"italic_en","text":"A share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, determined, defined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limited, as to time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise:"},{"kind":"text","text":"(Zj, Ibn-'Arafeh:) or, in iv. 118,"},{"kind":"italic_en","text":"a share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, cut off and limited."},{"kind":"text","text":"(S, O.) [See also"},{"kind":"arabic","text_bw":"fariyDapN","text_ar":"فَرِيضَةٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"A statute, an ordinance, a command"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prohibition,"},{"kind":"text","text":"of the Apostle of God; syn."},{"kind":"arabic","text_bw":"sun~apN","text_ar":"سُنَّةٌ"},{"kind":"text","text":". (IAar, O, K.) [But"},{"kind":"arabic","text_bw":"faroDN","text_ar":"فَرْضٌ"},{"kind":"text","text":"is generally distinguished from"},{"kind":"arabic","text_bw":"sun~apN","text_ar":"سُنَّةٌ"},{"kind":"text","text":": the former, for instance, being applied to prayer appointed in the Kur-án; and the latter, to prayer appointed by Mohammad without allegation of a divine order.] ―         -b3-"},{"kind":"italic_en","text":"A gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a soldier's stipend"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pay,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EaTaA='N","text_ar":"عَطَا=ءٌ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"EaTiy~apN","text_ar":"عَطِيَّةٌ"},{"kind":"text","text":", (S, O, K,)"},{"kind":"italic_en","text":"assigned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed."},{"kind":"text","text":"(S, O, K. *) In the copies of the K,"},{"kind":"arabic","text_bw":"mawosuwmap","text_ar":"مَوْسُومَة"},{"kind":"text","text":"is put by mistake for"},{"kind":"arabic","text_bw":"marosuwmap","text_ar":"مَرْسُومَة"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"maA A^aSabotu minohu faroDFA walaA qaroDFA","text_ar":"مَا اَصَبْتُ مِنْهُ فَرْضًا وَلَا قَرْضًا"},{"kind":"italic_en","text":"I did not obtain from him an assigned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soldier's stipend,"},{"kind":"text","text":"(S, O, TA,)"},{"kind":"italic_en","text":"nor a gift to be requited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a loan."},{"kind":"text","text":"(O, TA.) And"},{"kind":"arabic","text_bw":"faroDN","text_ar":"فَرْضٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A thing which one makes obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"binding, on himself, and freely gives:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thing which one gives liberally, not for a recompense."},{"kind":"text","text":"(IDrd, O, K.)       -A3-  Also"},{"kind":"italic_en","text":"Soldiers who receive stipends;"},{"kind":"text","text":"(K:) so accord. to Lth, as related by Az; but [Sgh says] I have not found it in the book of Lth: (O:) or"},{"kind":"italic_en","text":"soldiers having definite portions assigned to them:"},{"kind":"text","text":"(A:) pl."},{"kind":"arabic","text_bw":"furuwDN","text_ar":"فُرُوضٌ"},{"kind":"text","text":". (A, TA.) You say,"},{"kind":"arabic","text_bw":"Einodahu miAy^apN mina AlfaroDi","text_ar":"عِنْدَهُ مِايَةٌ مِنَ الفَرْضِ"},{"kind":"italic_en","text":"He has with him a hundred soldiers"},{"kind":"text","text":"&c. (A.)       -A4-"},{"kind":"italic_en","text":"A shield."},{"kind":"text","text":"(S, O, K.) Sakhr-el-Gheí says, describing lightning, (O, TA,) likening it to a light shield which an announcer of tidings was turning over and over with his hands that a party might see it and be gladdened [by the signal], (TA,)"},{"kind":"quote","text":"A^ariqotu lahu mivola lamoEi Alba$iyri\n                      \n                     \n                        yuqal~ibu biAlkaf~i faroDFA xafiyfFA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was sleepless by reason of it, it being"},{"kind":"text","text":"(in its flickering)"},{"kind":"italic_en","text":"like the signalling of the announcer of tidings turning over and over with the hand a light shield"},{"kind":"text","text":"]: one should not say"},{"kind":"arabic","text_bw":"quroSFA xfyfA","text_ar":"قُرْصًا خفيفا"},{"kind":"text","text":". (S, O, TA: but my copies of the S have"},{"kind":"arabic","text_bw":"qal~aba","text_ar":"قَلَّبَ"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"yuqal~ibu","text_ar":"يُقَلِّبُ"},{"kind":"text","text":".) [See also what follows.] ―         -b2-  And"},{"kind":"italic_en","text":"A stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of wood;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EuwdN","text_ar":"عُودٌ"},{"kind":"text","text":"; thus [it means] in the verse ("},{"kind":"arabic","text_bw":"fiY Albayoti","text_ar":"فِى البَيْتِ"},{"kind":"text","text":") accord. to El-Jumahee, (O, TA,) i. e. in the verse above-cited: (TA:) he says,"},{"kind":"arabic","text_bw":"AlfaroDu fiY Albayoti EuwdN","text_ar":"الفَرْضُ فِى البَيْتِ عُودٌ"},{"kind":"text","text":": (O, TA:) whence the author of the K has been misled to explain"},{"kind":"arabic","text_bw":"AlfaroDu","text_ar":"الفَرْضُ"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"EuwdN mino A^aEowaAdi Albayoti","text_ar":"عُودٌ مِنْ اَعْوَادِ البَيْتِ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"An arrow before it has been furnished with feathers and a head:"},{"kind":"text","text":"(Akh, S, O, TA:) a meaning also heard by El-Jumahee: (O, TA:) and to this, in the hand of the player, 'Abeed ElAbras has likened lightning, accord. to the S; but Sgh says, in the TS, that he did not find the verse cited by J in the poetry of 'Abeed. (TA.) ―         -b4-  And"},{"kind":"italic_en","text":"A piece of rag:"},{"kind":"text","text":"another explanation heard by El-Jumahee. (O.) ―         -b5-  And"},{"kind":"italic_en","text":"A garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth:"},{"kind":"text","text":"(O, K:) a meaning mentioned by As on the authority of some one or more of the Arabs of the desert, of Hudheyl. (O.) [See also"},{"kind":"arabic","text_bw":"firaADN","text_ar":"فِرَاضٌ"},{"kind":"text","text":".] ―         -b6-  And it is said that in the verse cited above it means the notch in the"},{"kind":"arabic","text_bw":"zanod","text_ar":"زَنْد"},{"kind":"text","text":"[or rather"},{"kind":"arabic","text_bw":"zanodap","text_ar":"زَنْدَة"},{"kind":"text","text":", mentioned in the first sentence of this paragraph]. (O, TA.)       -A5-"},{"kind":"italic_en","text":"A sort of dates"},{"kind":"text","text":"(S, O, Msb, K)"},{"kind":"italic_en","text":"of 'Omán:"},{"kind":"text","text":"(Msb:) As says that the best dates of 'Omán are these and the"},{"kind":"arabic","text_bw":"baloEaq","text_ar":"بَلْعَق"},{"kind":"text","text":": (S, O:) and AHn says, Certain of the desertArabs of 'Omán informed me that when the tree thereof has its fruit ripened, and the gathering is delayed, the fruit falls from its stones, and the raceme remains with nothing upon it but stones hanging to the"},{"kind":"arabic","text_bw":"vafaAriyq","text_ar":"ثَفَارِيق"},{"kind":"text","text":"[by which they are attached to the ends of the stalks]. (TA.)"}],"source_refs":["TA","O","S","A","K","Msb","Akh"]},{"entry_id":"n33575","headword_ar":"فِرْضٌ","root":"frD","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"fruit of the"},{"kind":"arabic","text_bw":"dawom","text_ar":"دَوْم"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Theban palm"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"while continuing red."},{"kind":"text","text":"(AA, O, * K.)"}],"source_refs":[]}]}}