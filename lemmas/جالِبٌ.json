{"lemma":"جالِبٌ","slug":"جالِبٌ","root":"ج.ل.ب","root_slug":"ج-ل-ب","root_link":"/words/roots/ج-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["","n6076"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D8%A7%D9%84%D9%90%D8%A8%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6076","headword_ar":"جَالَِبٌ","root":"jlb","body":[{"kind":"text","text":"(A) and ↓"},{"kind":"arabic","text_bw":"jaAlibapN","text_ar":"جَالِبَةٌ","orth_type":"arrow"},{"kind":"text","text":"(L) and ↓"},{"kind":"arabic","text_bw":"majolabapN","text_ar":"مَجْلَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"(Har p. 194 &c.) [all signify] (assumed tropical:)"},{"kind":"italic_en","text":"A cause of bringing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drawing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attracting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"procuring"},{"kind":"text","text":"of a thing: (Har p. 194, in explanation of the last:) thus"},{"kind":"arabic","text_bw":"majolabapu Ald~amoEi","text_ar":"مَجْلَبَةُ الدَّمْعِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"the cause of drawing tears:"},{"kind":"page_break","n":441},{"kind":"text","text":"(1d p. 15:) pl. of the second,"},{"kind":"arabic","text_bw":"jawaAlibu","text_ar":"جَوَالِبُ"},{"kind":"text","text":"; as in the phrase"},{"kind":"arabic","text_bw":"jawaAlibu Alqadari","text_ar":"جَوَالِبُ القَدَرِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"the drawing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"procuring, causes of destiny"},{"kind":"text","text":"]: (L, TA:) pl. of the third,"},{"kind":"arabic","text_bw":"majaAlibu","text_ar":"مَجَالِبُ"},{"kind":"text","text":". (Har p. 430.) You say,"},{"kind":"arabic","text_bw":"likul~i qaDaA='K jaAlibN","text_ar":"لِكُلِّ قَضَا=ءٍ جَالِبٌ"},{"kind":"arabic","text_bw":"walikul~i dar~K HaAlibN","text_ar":"وَلِكُلِّ دَرٍّ حَالِبٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"For every decree of fate there is a drawing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"procuring, cause; and for every flow of milk there is a milker"},{"kind":"text","text":"]. (A, TA.) And [hence] the pl."},{"kind":"arabic","text_bw":"jawaAlibu","text_ar":"جَوَالِبُ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"Calamities, misfortunes, evil accidents, adversities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulties."},{"kind":"text","text":"(TA.) See an ex. in the first paragraph, near the beginning. ―         -b2-"},{"kind":"arabic","text_bw":"quruwHN jawaAlibu","text_ar":"قُرُوحٌ جَوَالِبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jul~abN","text_ar":"جُلَّبٌ"},{"kind":"italic_en","text":"Wounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ulcers, healing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming covered with skin in healing."},{"kind":"text","text":"(As, TA.)"}],"source_refs":["A","L","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AC%D8%A7%D9%84%D8%A8/","headword_ar":"جالب","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=127712#f91a88","body_html":"جالب<br>عن التركية \"جالاب\" لفظ الجلالة ولقب الاحترام."}]}}