":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُبَصْبِصُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُبَصْبِصْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُبَصْبِص","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُبَصْبِص","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُبَصْبِصا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُبَصْبِصانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبَصْبِصا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبَصْبِصانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبَصْبِصُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبَصْبِصُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبَصْبِصْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُبَصْبِص","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبَصْبِص","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"بَصْبَصْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَصْبَصْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n2629"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B5%D9%92%D8%A8%D9%8E%D8%B5%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2629","headword_ar":"بَصْبَصَ","root":"bS","body":[{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"baSobaSa bi*anabihi","text_ar":"بَصْبَصَ بِذَنَبِهِ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"baSobaSapN","text_ar":"بَصْبَصَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a dog, S, M, K, and a beast of prey, and a gazelle, and a camel when urged on by the driver's singing, TA)"},{"kind":"italic_en","text":"wagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moved about, his tail;"},{"kind":"text","text":"(S, K;) which a dog does by reason of cupidity, or fear; (TA;) as also ↓"},{"kind":"arabic","text_bw":"tabaSobaSa","text_ar":"تَبَصْبَصَ","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a dog)"},{"kind":"italic_en","text":"struck with his tail."},{"kind":"text","text":"(ISd.) The inf. n."},{"kind":"arabic","text_bw":"baSobaSapN","text_ar":"بَصْبَصَةٌ"},{"kind":"text","text":"has a pl., namely,"},{"kind":"arabic","text_bw":"baSaAbiSu","text_ar":"بَصَابِصُ"},{"kind":"text","text":"; as in the following ex.:"},{"kind":"quote","text":"Hat~aY A_i*aA A^aboSaronahu wa Ealimonahu\n                      \n                     \n                        Hay~ayonahu bibaSaAbiSi AlA^a*onaAbi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Until, when they see him and know him, they greet him with waggings of the tails"},{"kind":"text","text":"]. (TA.) It is said in a prov., respecting the flight and submissiveness of the coward,"},{"kind":"quote","text":"baSobaSona A_i*o Hudiyona biAlA^a*onaAbi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They wagged the tails when they were urged on by the driver's singing"},{"kind":"text","text":"]. (As.)       -A2-"},{"kind":"arabic","text_bw":"baSobaSati AlA_ibilu","text_ar":"بَصْبَصَتِ الاـِبِلُ"},{"kind":"arabic","text_bw":"qarabahaA","text_ar":"قَرَبَهَا"},{"kind":"italic_en","text":"The camels performed quickly their nightjourney to water."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"baSobaASN","text_ar":"بَصْبَاصٌ"},{"kind":"text","text":".]"}],"source_refs":["S","K","M","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D8%B5%D8%A8%D8%B5/","headword_ar":"بصبص","entries":[{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=17690#c9a1c3","body_html":"بصبص<br> بَصْبَصَ<br> a. Wagged (the tail).<br> <br> بَصْبُوص<br> a. Pupil, apple of the eye."},{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=17690#841a82","body_html":"<span class=\"title1\">[بصبص]</span><span> فيه: يلحسنه و\"يبصبصن\" إليه، يقال بصبص الكلب بذنبه إذا حركه من طمع أو خوف. </span>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=17690#33e98b","body_html":"<span class=\"title1\">(بصبص)</span><span> - في حديث دانيال عليه السلام \"حين أُلِقى في الجُبِّ، وأُلقِى عليه السِّباع فَجَعَلْن يَلْحَسْنه ويُبَصْبِصْن إليه\".</span><br><span>يقال: بَصبَص الكلبُ بذَنَبه، إذا حَرَّكه، ويُقال للإِبل أَيضًا. قال رؤبة:</span><br><span>* يُبَصْبِصْنَ بالأَذناب من لُوْحٍ وَبَقْ * </span><br><span>وإنَّما تَفعَل ذلك من طَمَع أو خَوْف.</span>"}]}}