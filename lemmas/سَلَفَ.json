d":"text","text":"or"},{"kind":"italic_en","text":"became cut off:"},{"kind":"text","text":"(Msb:) and, (K,) inf. n."},{"kind":"arabic","text_bw":"salofN","text_ar":"سَلْفٌ"},{"kind":"text","text":", (M, MF, and so in copies of the K,) or"},{"kind":"arabic","text_bw":"safN","text_ar":"سَفٌ"},{"kind":"text","text":", (so in the CK,) and"},{"kind":"arabic","text_bw":"suluwfN","text_ar":"سُلُوفٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, K) [and also"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)]"},{"kind":"italic_en","text":"went before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preceded;"},{"kind":"text","text":"(M, K;) and so ↓"},{"kind":"arabic","text_bw":"sAlf","text_ar":"سالف","orth_type":"arrow"},{"kind":"text","text":", said of a camel. (K.) In a verse cited voce"},{"kind":"arabic","text_bw":"salofa radaAdN","text_ar":"سَلْفَ رَدَادٌ"},{"kind":"text","text":"is used by poetic"},{"kind":"page_break","n":1408},{"kind":"text","text":"license for"},{"kind":"arabic","text_bw":"salafa","text_ar":"سَلَفَ"},{"kind":"text","text":": but this kind of contraction is allowed by the Basrees only in verbs of which the medial radical letter is with kesr or damm, as in"},{"kind":"arabic","text_bw":"Ealoma","text_ar":"عَلْمَ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"Ealima","text_ar":"عَلِمَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"karoma","text_ar":"كَرْمَ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"karuma","text_ar":"كَرُمَ"},{"kind":"text","text":". (M. [See"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":".]) ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"salafa lahu EamalN SaAliHN","text_ar":"سَلَفَ لَهُ عَمَلٌ صَالِحٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"righteous, deed of his preceded"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to prepare for him a future reward"},{"kind":"text","text":"]. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"salafati Aln~aAqapu","text_ar":"سَلَفَتِ النَّاقَةُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suluwfN","text_ar":"سُلُوفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The she-camel was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, among the foremost of the camels in arriving at the water."},{"kind":"text","text":"(TA.) ―         -b4-  [Golius and Freytag mention also"},{"kind":"arabic","text_bw":"salafa","text_ar":"سَلَفَ"},{"kind":"text","text":"as a trans. verb; the former explaining it as signifying “"},{"kind":"italic_en","text":"Præteriit, præcessit,"},{"kind":"text","text":"rem; ” and the latter adding “"},{"kind":"italic_en","text":"tempore,"},{"kind":"text","text":"” and assigning to it the inf. ns."},{"kind":"arabic","text_bw":"salofN","text_ar":"سَلْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suluwfN","text_ar":"سُلُوفٌ"},{"kind":"text","text":"; as on the authority of the K; in which I find no indication of such a usage of this verb.]       -A2-"},{"kind":"arabic","text_bw":"salafa AlA^aroDa","text_ar":"سَلَفَ الاَرْضَ"},{"kind":"text","text":", (S, M, K;) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"salofN","text_ar":"سَلْفٌ"},{"kind":"text","text":"; (S, M;) and ↓"},{"kind":"arabic","text_bw":"AslfhA","text_ar":"اسلفها","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He turned over the land for sowing:"},{"kind":"text","text":"(M, K:) or (so in the K, but in the M “ and ”)"},{"kind":"italic_en","text":"he made it even with the"},{"kind":"arabic","text_bw":"misolafap","text_ar":"مِسْلَفَة"},{"kind":"text","text":"[q. v.]. (S, M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"salafa AlmazaAdapa","text_ar":"سَلَفَ المَزَادَةَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"salofN","text_ar":"سَلْفٌ"},{"kind":"text","text":", [in some copies of the K"},{"kind":"arabic","text_bw":"salaf","text_ar":"سَلَف"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He oiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greased, the"},{"kind":"arabic","text_bw":"mzAdp","text_ar":"مزادة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leathern water-bag"},{"kind":"text","text":"]. (K.)"}],"source_refs":["S","M","Msb","K","MF"]}]}}