","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْتَشِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْتَشِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْتَشِر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْتَشِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْتَشِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْتَشِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْتَشِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْتَشِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْتَشِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْتَشِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْتَشِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِنْتَشَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِنْتَشَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْتَشِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْتَشِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n39810"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AA%D9%8E%D8%B4%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to disperse","tags":["intransitive"],"examples":[{"text":"فَإِذَا قُضِيَتِ الصَّلَاةُ فَٱنْتَشِرُوا فِي الْأَرْضِ وَٱبْتَغُوا مِن فَضْلِ اللَّهِ","english":"And when the prayer has been concluded, disperse within the land and seek from the bounty of Allah"}]},{"pos":"verb","gloss":"to expand, to be widespread","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39810","headword_ar":"انتشر","root":"n$r","body":[{"kind":"text","text":"[quasi-pass. of 1,]"},{"kind":"italic_en","text":"It spread, expanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfolded; it became spread, expanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfolded;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tn$~r","text_ar":"تنشّر","orth_type":"arrow"},{"kind":"text","text":": (K:) [or the latter, being quasi-pass. of 2, denotes muchness, &c.] ―         -b2-"},{"kind":"arabic","text_bw":"Ant$rt","text_ar":"انتشرت"},{"kind":"arabic","text_bw":"Aln~axolapu","text_ar":"النَّخْلَةُ"},{"kind":"italic_en","text":"The branches of the palm-tree spread forth."},{"kind":"text","text":"(K.) [And"},{"kind":"arabic","text_bw":"Ant$rt AlA^agoSaAnu","text_ar":"انتشرت الاَغْصَانُ"},{"kind":"italic_en","text":"The branches spread forth:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the branches straggled."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"Ant$r Alxabaru","text_ar":"انتشر الخَبَرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The news spread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became published,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"arabic","text_bw":"fiY Aln~aAsi","text_ar":"فِى النَّاسِ"},{"kind":"italic_en","text":"among the people."},{"kind":"text","text":"(A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Ant$rt","text_ar":"انتشرت"},{"kind":"arabic","text_bw":"Alr~aAy^iHapu","text_ar":"الرَّايِحَةُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The odour spread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diffused itself."},{"kind":"text","text":"] (K in art."},{"kind":"arabic","text_bw":"fwH","text_ar":"فوح"},{"kind":"text","text":"; &c.) ―         -b5-"},{"kind":"arabic","text_bw":"Ant$r Aln~ahaAru","text_ar":"انتشر النَّهَارُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The day became long and extended:"},{"kind":"text","text":"(K:) and so one says of other things. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"Ant$r AlEaSabu","text_ar":"انتشر العَصَبُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sinews,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tendons, became inflated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swollen,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"by reason of fatigue:"},{"kind":"text","text":"(TA:)"},{"kind":"arabic","text_bw":"A_inoti$aArN","text_ar":"اـِنْتِشَارٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a state of inflation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swelling, in the sinews,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tendons, of a beast, occasioned by fatigue:"},{"kind":"text","text":"(S:) AO says, that"},{"kind":"italic_en","text":"the sinew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tendon, which becomes inflated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swollen, is the"},{"kind":"arabic","text_bw":"EujaAyap","text_ar":"عُجَايَة"},{"kind":"text","text":", (S, * TA,) and that what is termed"},{"kind":"arabic","text_bw":"taHar~uku Al$~aZaY","text_ar":"تَحَرُّكُ الشَّظَى"},{"kind":"text","text":"is similar to this affection, excepting in its not being so well endured by the horse: by another, or others, it is said, that"},{"kind":"arabic","text_bw":"Ant$Ar","text_ar":"انتشار"},{"kind":"text","text":"of the sinews, or tendons, of a beast, in his fore leg, is"},{"kind":"italic_en","text":"a breaking, and consequent displacement,"},{"kind":"text","text":"of those sinews. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"Ant$r *akarohu","text_ar":"انتشر ذَكَرْهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His penis became erect."},{"kind":"text","text":"(TA.) [And hence,]"},{"kind":"arabic","text_bw":"Ant$r Alr~ajulu","text_ar":"انتشر الرَّجُلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man became excited by lust."},{"kind":"text","text":"(S, K.) ―         -b8-"},{"kind":"arabic","text_bw":"Ant$r AlmaA='u","text_ar":"انتشر المَا=ءُ"},{"kind":"text","text":"[In my copy of the A,"},{"kind":"arabic","text_bw":"Astn$r","text_ar":"استنشر"},{"kind":"text","text":", but this I regard as a mistranscription,]"},{"kind":"italic_en","text":"The water became sprinkled;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tn$~r","text_ar":"تنشّر","orth_type":"arrow"},{"kind":"text","text":": (A:) [or the latter signifies"},{"kind":"italic_en","text":"it became much sprinkled."},{"kind":"text","text":"] ―         -b9-"},{"kind":"arabic","text_bw":"Ant$rwA fY","text_ar":"انتشروا فى"},{"kind":"arabic","text_bw":"AlA^aroDi","text_ar":"الاَرْضِ"},{"kind":"italic_en","text":"They became scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, themselves, in the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth."},{"kind":"text","text":"(A.) ―         -b10-"},{"kind":"arabic","text_bw":"Ant$rt Alganama","text_ar":"انتشرت الغَنَمَ"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"The sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"the camels"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, after having been confined in their nightly resting-place:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats"},{"kind":"text","text":"(TA) and"},{"kind":"italic_en","text":"the camels"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"became scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, through negligence of their pastor."},{"kind":"text","text":"(K, TA.) ―         -b11-"},{"kind":"arabic","text_bw":"Ant$r AlA^amoru","text_ar":"انتشر الاَمْرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The state of things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs, became dissolved, broken up, decomposed, disorganized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ta$~atata","text_ar":"تَشَّتَتَ"},{"kind":"text","text":". (TA, art."},{"kind":"arabic","text_bw":"$t","text_ar":"شت"},{"kind":"text","text":".)       -A2-  See also 1, latter part of the paragraph. ―         -b2-"},{"kind":"arabic","text_bw":"Ant$r","text_ar":"انتشر"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He put himself in motion, and went on a journey."},{"kind":"text","text":"(TA, in art."},{"kind":"arabic","text_bw":"bsr","text_ar":"بسر"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"Ant$r Al*~iy^bu fiY Alganami","text_ar":"انتشر الذِّيبُ فِى الغَنَمِ"},{"kind":"italic_en","text":"The wolf made an incursion among the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"$E","text_ar":"شع"},{"kind":"text","text":".)"}],"source_refs":["K","S","A","TA","Msb"]}]}}