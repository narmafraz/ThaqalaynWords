},{"role":"present_2mp","form":"تَخْشَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْشَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْشَع","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْشَع","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْشَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْشَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْشَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْشَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْشَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْشَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْشَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْشَع","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْشَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَشَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَشَعْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n10677"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B4%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to show humility, to submit (to God)"}]},"etymology":null,"ipa":["/xa.ʃa.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10677","headword_ar":"خَشَعَ","root":"x$E","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xu$uwEN","text_ar":"خُشُوعٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Axt$E","text_ar":"اختشع","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"tx$~E","text_ar":"تخشّع","orth_type":"arrow"},{"kind":"text","text":"; (Abu-lFet-h, Ham pp. 24 and 127;)"},{"kind":"arabic","text_bw":"xu$uwEN","text_ar":"خُشُوعٌ"},{"kind":"text","text":"being"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xuDuwEN","text_ar":"خُضُوعٌ"},{"kind":"text","text":": (S, Msb, K:) or"},{"kind":"arabic","text_bw":"x$wE","text_ar":"خشوع"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"nearly the same as"},{"kind":"arabic","text_bw":"xDwE","text_ar":"خضوع"},{"kind":"text","text":": (Lth, K:) or the former is mostly used as meaning"},{"kind":"italic_en","text":"in the voice;"},{"kind":"text","text":"and the latter, in the necks: (Msb:) or the latter is in the body; and the former is"},{"kind":"italic_en","text":"in the voice"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the eyes:"},{"kind":"text","text":"(K:) or, as we read in the 'Eyn, the former is nearly the same as the latter, except that the latter is in the body, and signifies the acknowledging of humility and submission, and the former is in the voice and in the eyes; and the like is said in the Nh [and in the Msb in art."},{"kind":"arabic","text_bw":"xDE","text_ar":"خضع"},{"kind":"text","text":"]. (TA.) You say,"},{"kind":"arabic","text_bw":"xa$aEati AlA^aSowaAtu","text_ar":"خَشَعَتِ الاَصْوَاتُ"},{"kind":"italic_en","text":"The voices were"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shall be"},{"kind":"text","text":"(as in the Kur xx. 107])"},{"kind":"italic_en","text":"still and low:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"low:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"still."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xa$aEa bibaSarihi","text_ar":"خَشَعَ بِبَصَرِهِ"},{"kind":"italic_en","text":"He lowered his eye."},{"kind":"text","text":"(S.) And ↓"},{"kind":"arabic","text_bw":"Axt$E","text_ar":"اختشع","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tx$~E","text_ar":"تخشّع","orth_type":"arrow"},{"kind":"italic_en","text":"He cast his eye towards the ground, and lowered his voice."},{"kind":"text","text":"(TA.) Lth says that you say,"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Axt$E","text_ar":"اختشع","orth_type":"arrow"},{"kind":"text","text":", but not"},{"kind":"arabic","text_bw":"Axt$E bibaSarihi","text_ar":"اختشع بِبَصَرِهِ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xa$aEa baSaruhu","text_ar":"خَشَعَ بَصَرُهُ"},{"kind":"italic_en","text":"His eye became contracted."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xa$aEato duwnahu","text_ar":"خَشَعَتْ دُونَهُ"},{"kind":"arabic","text_bw":"AlA^aboSaAru","text_ar":"الاَبْصَارُ"},{"kind":"text","text":"(tropical:)  [meaning"},{"kind":"italic_en","text":"The eyes were cast down before him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"xu$uwEN","text_ar":"خُشُوعٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, still:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"abasing oneself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowering oneself."},{"kind":"text","text":"(K, TA.) And ↓"},{"kind":"arabic","text_bw":"Axt$E","text_ar":"اختشع","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stooped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent down, his breast."},{"kind":"text","text":"(TA.) ―         -b2-  Also, inf. n. as above,"},{"kind":"italic_en","text":"He feared;"},{"kind":"text","text":"for instance, in prayer: (TA:) or"},{"kind":"arabic","text_bw":"xa$aEa fiY SalaAtihi","text_ar":"خَشَعَ فِى صَلَاتِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiY duEaAy^ihi","text_ar":"فِى دُعَايِهِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He applied himself with his heart to"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"in"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his prayer,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his supplication."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"xa$aEati AlkawaAkibu","text_ar":"خَشَعَتِ الكَوَاكِبُ"},{"kind":"text","text":", (Aboo-'Adnán,) inf. n. as above, (K,) (tropical:)"},{"kind":"italic_en","text":"The stars approached to the place of setting;"},{"kind":"text","text":"(Aboo-'Adnán;) or"},{"kind":"italic_en","text":"approached to setting:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"sank, and nearly disappeared in their setting-place."},{"kind":"text","text":"(Aboo- Sálih El-Kilábee.) [The corresponding phrase in Hebrew, occurring in Gen. xxxvii. 9, probably has the same meaning.] ―         -b4-"},{"kind":"arabic","text_bw":"xa$aEati Al$~amosu","text_ar":"خَشَعَتِ الشَّمْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The sun became eclipsed."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"xa$aEa Als~anaAmu","text_ar":"خَشَعَ السَّنَامُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The hump for the most part went away;"},{"kind":"text","text":"(O, K;) i. e. the hump of the camel: (TA:) or"},{"kind":"italic_en","text":"became lean; its fat going away, and its height becoming lowered."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"fulaAnN ji*olN HikaAkN","text_ar":"فُلَانٌ جِذْلٌ حِكَاكٌ"},{"kind":"arabic","text_bw":"xa$aEati Eanohu AlA^ubanu","text_ar":"خَشَعَتِ عَنْهُ الاُبَنُ"},{"kind":"text","text":"is a saying of the Arabs, explained in art."},{"kind":"arabic","text_bw":"Hk","text_ar":"حك"},{"kind":"text","text":". (TA in that art.) ―         -b7-"},{"kind":"arabic","text_bw":"xa$aEa","text_ar":"خَشَعَ"},{"kind":"arabic","text_bw":"Alwaraqu","text_ar":"الوَرَقُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The leaves withered."},{"kind":"text","text":"(TA.) ―         -b8-"},{"kind":"arabic","text_bw":"xa$aEati","text_ar":"خَشَعَتِ"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land, dried up, not being rained upon."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xa$aEa fulaAnN xaraA$iY~N Sadorihi","text_ar":"خَشَعَ فُلَانٌ خَرَاشِىٌّ صَدْرِهِ"},{"kind":"italic_en","text":"Such a one ejected the viscous saliva"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"phlegm of his chest"},{"kind":"text","text":"]. (O, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xa$aEato xaraA$iY~N","text_ar":"خَشَعَتْ خَرَاشِىٌّ"},{"kind":"arabic","text_bw":"Sarihi","text_ar":"صَرِهِ"},{"kind":"italic_en","text":"The viscous saliva"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"phlegm of his chest"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became ejected."},{"kind":"text","text":"(O, K.) The verb is thus intrans., as well as trans. (O.)"}],"source_refs":["S","K","Msb","Lth","TA"]}]}}