ons":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be in want of water, to thirst, to require irrigation"},{"pos":"verb","gloss":"to make thirsty"},{"pos":"noun","gloss":"verbal noun of عَطِشَ (ʕaṭiša) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thirst"},{"pos":"adj","gloss":"thirsty"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29558","headword_ar":"عَطِشَ","root":"ET$","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaTa$N","text_ar":"عَطَشٌ"},{"kind":"text","text":", (S, O, Msb, K,) and sometimes"},{"kind":"arabic","text_bw":"maEoTa$N","text_ar":"مَعْطَشٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He thirsted; was thirsty: was in want of drink;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was in want of irrigation:"},{"kind":"arabic","text_bw":"EaTa$N","text_ar":"عَطَشٌ"},{"kind":"text","text":"being the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"riY~N","text_ar":"رِىٌّ"},{"kind":"text","text":". (S, O, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EaTi$a A_ilaY liqaAy^ihi","text_ar":"عَطِشَ اـِلَى لِقَايِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He longed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"thirsted,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to meet with him:"},{"kind":"text","text":"like as they say"},{"kind":"arabic","text_bw":"Zamiy^a","text_ar":"ظَمِيَ"},{"kind":"text","text":". (IDrd, O.) And"},{"kind":"arabic","text_bw":"A^anaA $adiydu","text_ar":"اَنَا شَدِيدُ"},{"kind":"arabic","text_bw":"AlEaTa$i A_ilaY liqaAy^ika","text_ar":"العَطَشِ اـِلَى لِقَايِكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I am vehemently longing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring, to meet with thee"},{"kind":"text","text":"]. (A.) [See also the first paragraph of art."},{"kind":"arabic","text_bw":"EmY","text_ar":"عمى"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"EaATa$ahu faEaTa$ahu","text_ar":"عَاطَشَهُ فَعَطَشَهُ"},{"kind":"text","text":": see 3."}],"source_refs":["S","O","Msb","K","TA"]}]}}