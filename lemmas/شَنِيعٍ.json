{"lemma":"شَنِيعٍ","slug":"شَنِيعٍ","root":"ش.ن.ع","root_slug":"ش-ن-ع","root_link":"/words/roots/ش-ن-ع","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n23141"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%86%D9%90%D9%8A%D8%B9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"ugly, sickening, terrible, repugnant"}]},"etymology":null,"ipa":["/ʃa.niːʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23141","headword_ar":"شَنِيعٌ","root":"$nE","body":[{"kind":"italic_en","text":"Bad, evil, abominable, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unseemly;"},{"kind":"page_break","n":1606},{"kind":"text","text":"(S, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"$aniEN","text_ar":"شَنِعٌ","orth_type":"arrow"},{"kind":"text","text":"(O, K) and ↓"},{"kind":"arabic","text_bw":"A^a$onaEu","text_ar":"اَشْنَعُ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) the last like"},{"kind":"arabic","text_bw":"A^akobaru","text_ar":"اَكْبَرُ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"Aall~`hu","text_ar":"اَللّٰهُ"},{"kind":"arabic","text_bw":"A^akobaru","text_ar":"اَكْبَرُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"kabiyrN","text_ar":"كَبِيرٌ"},{"kind":"text","text":", accord. to one of the two interpretations of this phrase: (O, TA:) pl. of the first"},{"kind":"arabic","text_bw":"$unuEN","text_ar":"شُنُعٌ"},{"kind":"text","text":". (Msb, TA. *) It is applied to a day, in this sense: or as meaning"},{"kind":"italic_en","text":"disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated:"},{"kind":"text","text":"(TA:) and so is ↓"},{"kind":"arabic","text_bw":"A^a$onaEu","text_ar":"اَشْنَعُ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K, TA,) in the former sense, (TA,) or in the latter. (O, K, TA.) And you say"},{"kind":"arabic","text_bw":"manoZarN $aniyEN","text_ar":"مَنْظَرٌ شَنِيعٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mu$an~aEu","text_ar":"مُشَنَّعُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An aspect that is bad, evil,"},{"kind":"text","text":"&c.] and ↓"},{"kind":"arabic","text_bw":"AimoraA^apN mu$an~aEapN","text_ar":"اِمْرَاَةٌ مُشَنَّعَةٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"qabiyHapN","text_ar":"قَبِيحَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"An unseemly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugly, woman"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"AisomN $aniyEN","text_ar":"اِسْمٌ شَنِيعٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable, name"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"qawomN $unuEu AlA^asaAmiY","text_ar":"قَوْمٌ شُنُعُ الاَسَامِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, having evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable, names"},{"kind":"text","text":"]. (A, TA.) And ↓"},{"kind":"arabic","text_bw":"qiS~apN $anoEaA='u","text_ar":"قِصَّةٌ شَنْعَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a foul, story"},{"kind":"text","text":"]. (TA.) And ↓"},{"kind":"arabic","text_bw":"gayorapN $anoEaA='u","text_ar":"غَيْرَةٌ شَنْعَا=ءُ","orth_type":"arrow"},{"kind":"italic_en","text":"Abominable, excessive jealousy:"},{"kind":"text","text":"(O, K, TA:) in [some of] the copies of the K, erroneously,"},{"kind":"arabic","text_bw":"gbrp","text_ar":"غبرة"},{"kind":"text","text":". (TA.)"}],"source_refs":["O","K","S","TA"]}]},"classical_definitions":null}