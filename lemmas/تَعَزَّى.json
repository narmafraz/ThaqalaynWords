:"p"},{"role":"past_1ms","form":"تَعَزَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتَعَزَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَعَزَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n29025","n29032"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D8%B2%D9%8E%D9%91%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29025","headword_ar":"تعزّى","root":"EzY","body":[{"kind":"italic_en","text":"He took patience;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself to be patient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enduring;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taSab~ara","text_ar":"تَصَبَّرَ"},{"kind":"text","text":", (S, Msb, TA,) and"},{"kind":"arabic","text_bw":"tA^as~aY","text_ar":"تاَسَّى"},{"kind":"text","text":"[q. v.]; (TA;) the sign of doing which is the saying,"},{"kind":"arabic","text_bw":"A_in~aA lil~`hi waA_in~aA A_ilayohi raAjiEuwna","text_ar":"اـِنَّا لِلّٰهِ وَاـِنَّا اـِلَيْهِ رَاجِعُونَ"},{"kind":"text","text":"[Verily to God we belong, and verily unto Him we return]. (Msb.) It is said in a trad., [as some relate it,]"},{"kind":"arabic","text_bw":"mano lamo yataEaz~a biEazaA='i A@ll~`hi falayosa min~aA","text_ar":"مَنْ لَمْ يَتَعَزَّ بِعَزَا=ءِ ا@للّٰهِ فَلَيْسَ مِنَّا"},{"kind":"text","text":", expl. by some as meaning"},{"kind":"italic_en","text":"Such as does not constrain himself to be patient"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with the patience of God, he is not of us"},{"kind":"text","text":"]. (TA. [See another reading voce"},{"kind":"arabic","text_bw":"taEaz~aza","text_ar":"تَعَزَّزَ"},{"kind":"text","text":".]) And you say,"},{"kind":"arabic","text_bw":"taEaz~ayotu Eanohu","text_ar":"تَعَزَّيْتُ عَنْهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I constrained myself to endure with patience the loss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"[and hence,"},{"kind":"italic_en","text":"I consoled myself for the loss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"held by some to be] originally"},{"kind":"arabic","text_bw":"taEaz~azotu","text_ar":"تَعَزَّزْتُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I exerted my strength"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"energy"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to divert myself from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; like"},{"kind":"arabic","text_bw":"taZan~ayotu","text_ar":"تَظَنَّيْتُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"taZan~anotu","text_ar":"تَظَنَّنْتُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"Ez","text_ar":"عز"},{"kind":"text","text":".) You say also"},{"kind":"arabic","text_bw":"tEz~Y bihi","text_ar":"تعزّى بِهِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"taA^as~uY bh","text_ar":"تَاَسُّى به"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He took patience,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself to be patient, by reflecting upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he took example by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became consoled by his example,"},{"kind":"text","text":"meaning the example of a person who had suffered in like manner and had been patient]. (S in art."},{"kind":"arabic","text_bw":"Asw","text_ar":"اسو"},{"kind":"text","text":".)"}],"source_refs":["S","Msb","TA"]},{"entry_id":"n29032","headword_ar":"تَعْزَى","root":"EzY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EazowaY","text_ar":"عَزْوَى"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Ezw","text_ar":"عزو"},{"kind":"text","text":"."}],"source_refs":[]}]}}