"},{"role":"present_2mp","form":"تَهِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَهِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَهْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَهِرّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَهْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَهِرّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَهْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَهِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَهِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَهِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَهِرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهِرّ","in_corpus":true,"count":26,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"هَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n41079","n44275"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"cat"},{"pos":"verb","gloss":"to purr, to whirr, to bray, to grumble, to snarl, to howl","tags":["ambitransitive"]},{"pos":"verb","gloss":"to abhor, to detest, to loathe","tags":["transitive"]},{"pos":"verb","gloss":"to have violent diarrhoea","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of هَرَّ (harra, “to snarl”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"great quantity of water or milk","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of هُرَّ (hurra, “to have violent diarrhoea”)","tags":["form-of","noun-from-verb","obsolete"]}]},"etymology":{"source":"wiktextract","text":"Compare ه د ر (h d r)."},"ipa":["/hirr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41079","headword_ar":"هَرَّ","root":"hr","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"arabic","text_bw":"yahir~u","text_ar":"يَهِرُّ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"hariyrN","text_ar":"هَرِيرٌ"},{"kind":"text","text":", (S, A, &c.,) said of a dog, ["},{"kind":"italic_en","text":"He snarled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"howled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whined;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he uttered a cry less vehement than barking"},{"kind":"text","text":"(S, A, Msb, K.)"},{"kind":"italic_en","text":"by reason of his little patience of cold;"},{"kind":"text","text":"(S, K)"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"italic_en","text":"at him."},{"kind":"text","text":"(K.) or"},{"kind":"italic_en","text":"barked and grinned, displaying his fangs."},{"kind":"text","text":"(L, TA.) It is said in a trad,"},{"kind":"arabic","text_bw":"A_in~a Alkaloba yahir~u mino waraA='i A^aholihi","text_ar":"اـِنَّ الكَلْبَ يَهِرُّ مِنْ وَرَا=ءِ اَهْلِهِ"},{"kind":"italic_en","text":"Verily the dog"},{"kind":"text","text":"["},{"kind":"italic_en","text":"snarls,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"harks and grins, displaying his fangs, behind his master:"},{"kind":"text","text":"meaning, that courage is a quality implanted by nature in a man, so that he engages in wars naturally, and from care to defend what should be inviolable, not reckoning upon a reward, like as the dog naturally barks and grins, displaying his tangs, to defend his masters. (L, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"hariyrN","text_ar":"هَرِيرٌ"},{"kind":"text","text":"is also applied to other sounds than the cry of the dog; as in the instance of"},{"kind":"arabic","text_bw":"hariyru Alr~HaY","text_ar":"هَرِيرُ الرّحَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sound of the turning of the mill-stone."},{"kind":"text","text":"(TA.) You say also"},{"kind":"arabic","text_bw":"har~ati Alqawosu","text_ar":"هَرَّتِ القَوْسُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The bow made a sound."},{"kind":"text","text":"(AHn, K.) And the looking of courageous men, one at another, is likened to"},{"kind":"arabic","text_bw":"hariyr","text_ar":"هَرِير"},{"kind":"text","text":". (ISd, Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"har~a fiY wajohi Als~aAy^ili","text_ar":"هَرَّ فِى وَجْهِ السَّايِلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He grinned in the face of the beggar, showing his teeth, and looking sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely"},{"kind":"text","text":"(A, TA.) ―         -b4-  [Hence, perhaps,]"},{"kind":"arabic","text_bw":"har~ahu","text_ar":"هَرَّهُ"},{"kind":"text","text":". (S, K,) aor."},{"kind":"arabic","text_bw":"yahur~u","text_ar":"يَهُرُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yahir~a","text_ar":"يَهِرَّ"},{"kind":"text","text":", (K,) [the latter irreg., like"},{"kind":"arabic","text_bw":"yarim~u","text_ar":"يَرِمُّ"},{"kind":"text","text":"as aor. of the trans. v."},{"kind":"arabic","text_bw":"ram~a","text_ar":"رَمَّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"har~N","text_ar":"هَرٌّ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"hariyrN","text_ar":"هَرِيرٌ"},{"kind":"text","text":". (K,) (tropical:)"},{"kind":"italic_en","text":"He disliked, disapproved of or hated, him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, K.) You say,"},{"kind":"arabic","text_bw":"har~ahu Aln~aAsu","text_ar":"هَرَّهُ النَّاسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The people disliked,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"his vicinity."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"har~a AlkaAsa","text_ar":"هَرَّ الكَاسَ"},{"kind":"text","text":". and"},{"kind":"arabic","text_bw":"AlHaroba","text_ar":"الحَرْبَ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"hariyrN","text_ar":"هَرِيرٌ"},{"kind":"text","text":". (S.) (tropical:)"},{"kind":"italic_en","text":"He disliked."},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the cup of wine,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"war."},{"kind":"text","text":"(S, A.)       -A2-"},{"kind":"arabic","text_bw":"har~ahu Albaroda","text_ar":"هَرَّهُ البَرْدَ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yahur~uhu","text_ar":"يَهُرُّهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"har~N","text_ar":"هَرٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The cold made him"},{"kind":"text","text":"(a dog) ["},{"kind":"italic_en","text":"to snarl,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whine;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"to cry"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the manner described above"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"A^ahar~ahu","text_ar":"اَهَرَّهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_ihoraArN","text_ar":"اـِهْرَارٌ"},{"kind":"text","text":". (TA.) It is said in a proverb, (TA,)"},{"kind":"arabic","text_bw":"*aA naAbK","text_ar":"ذَا نَابٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$ar~N A^ahr~a","text_ar":"شَرٌّ اَهرَّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was, an evil thing that made the fanged animal to snarl,"},{"kind":"text","text":"&c.]: alluding to the appearance of the signs and symptoms of evil: the sayer thereof, hearing the cry ("},{"kind":"arabic","text_bw":"hariyr","text_ar":"هَرِير"},{"kind":"text","text":") of a dog, feared the assault of evil, and therefore said this to denote the magnitude of the case in his mind: meaning, nought but an evil thing made the fanged animal to cry: and for this reason, the use of an indeterminate word as an inchoative is well. (K.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n44275","headword_ar":"هَرَّ","root":"hr","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hir~N","text_ar":"هِرٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He drove"},{"kind":"text","text":"sheep or goats:"},{"kind":"page_break","n":3043},{"kind":"text","text":"(IAar, in S, K, voce"},{"kind":"arabic","text_bw":"bir","text_ar":"بِر"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"he called"},{"kind":"text","text":"them. (Yoo, in TA, ibid.)"}],"source_refs":[]}]}}