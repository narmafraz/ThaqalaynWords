nition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29070","headword_ar":"عَسُرَ","root":"Esr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"EusurN","text_ar":"عُسُرٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"EasaArapN","text_ar":"عَسَارَةٌ"},{"kind":"text","text":"(Msb, K) [and"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusorapN","text_ar":"عُسْرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosarapN","text_ar":"مَعْسَرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosurapN","text_ar":"مَعْسُرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusoraY","text_ar":"عُسْرَى"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"below)]; and"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":"; (S, O, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"tEs~r","text_ar":"تعسّر","orth_type":"arrow"},{"kind":"text","text":", (A, O, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"tEAsr","text_ar":"تعاسر","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AstEsr","text_ar":"استعسر","orth_type":"arrow"},{"kind":"text","text":"; (A, O, Msb, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an affair, or a thing, S, A, O, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate."},{"kind":"text","text":"(S, A, O, Msb, K, * TA.) You say,"},{"kind":"arabic","text_bw":"Easura Ealayohi","text_ar":"عَسُرَ عَلَيْهِ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", (S, O,) and ↓"},{"kind":"arabic","text_bw":"tEs~r","text_ar":"تعسّر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tEAsr","text_ar":"تعاسر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AstEsr","text_ar":"استعسر","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate, to him."},{"kind":"text","text":"(S, * O, * K.) ―         -b2-"},{"kind":"arabic","text_bw":"Easura maA fiY AlbaToni","text_ar":"عَسُرَ مَا فِى البَطْنِ"},{"kind":"text","text":", (as in the CK and a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (accord. to the TA,)"},{"kind":"italic_en","text":"What was in the belly would not come forth."},{"kind":"text","text":"(K.) You say"},{"kind":"arabic","text_bw":"Easara Ealayohi maA fiY AlbaToni","text_ar":"عَسَرَ عَلَيْهِ مَا فِى البَطْنِ"},{"kind":"italic_en","text":"What was in his belly would not come forth."},{"kind":"text","text":"(TA.) ―         -b3-  See also 4. ―         -b4-"},{"kind":"arabic","text_bw":"Easura","text_ar":"عَسُرَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (IKtt, TA,) or"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EasaArapN","text_ar":"عَسَارَةٌ"},{"kind":"text","text":"(Msb, IKtt, TA) and"},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":", (IKtt, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had little gentleness,"},{"kind":"text","text":"(Msb, IKtt,)"},{"kind":"arabic","text_bw":"fiY AlA^umuwri","text_ar":"فِى الاُمُورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in"},{"kind":"text","text":"the execucution of"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"]; (Msb;)"},{"kind":"italic_en","text":"and was narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"niggardly, in disposition:"},{"kind":"text","text":"(IKtt:) or"},{"kind":"italic_en","text":"he was hard in disposition;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illnatured."},{"kind":"text","text":"(K, * TK.) ―         -b5-"},{"kind":"arabic","text_bw":"Easura","text_ar":"عَسُرَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (A, and so in the CK and a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (as in the TA,) inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He acted contrarily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversely, to him; opposed him;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"Es~r","text_ar":"عسّر","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taEosiyrN","text_ar":"تَعْسِيرٌ"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Es~r","text_ar":"عسّر","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"he straitened him."},{"kind":"text","text":"(Sb, O, * TA.) ―         -b6-"},{"kind":"arabic","text_bw":"Easura Alz~amaAnu","text_ar":"عَسُرَ الزَّمَانُ"},{"kind":"text","text":", (so in the CK and in a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (so in the TA,)"},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, became severe, rigorous, afflictive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adverse,"},{"kind":"text","text":"(K,)"},{"kind":"arabic","text_bw":"EalayonaA","text_ar":"عَلَيْنَا"},{"kind":"italic_en","text":"to us."},{"kind":"text","text":"(TA. ―         -b7-"},{"kind":"arabic","text_bw":"Easurati Aln~aAqapu","text_ar":"عَسُرَتِ النَّاقَةُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Easirat","text_ar":"عَسِرَت"},{"kind":"italic_en","text":"The she-camel was untrained."},{"kind":"text","text":"(O.) ―         -b8-  And"},{"kind":"arabic","text_bw":"Easarato","text_ar":"عَسَرَتْ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"Easarato bi*anabihaA","text_ar":"عَسَرَتْ بِذَنَبِهَا"},{"kind":"text","text":", (S, O, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EasaraAnN","text_ar":"عَسَرَانٌ"},{"kind":"text","text":"(S, O, K, TA) and"},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":", (O, K, TA,)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"raised her tail, after conception, to show the stallion that she was pregnant:"},{"kind":"text","text":"(S, * O, TA:) and [as also, app., ↓"},{"kind":"arabic","text_bw":"Es~rt","text_ar":"عسّرت","orth_type":"arrow"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Es~rt danabahaA","text_ar":"عسّرت دَنَبَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEosiyrN","text_ar":"تَعْسِيرٌ"},{"kind":"text","text":", (see"},{"kind":"arabic","text_bw":"nAqp EasiyrN","text_ar":"ناقة عَسِيرٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"EasirN","text_ar":"عَسِرٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"raised her tail in her running."},{"kind":"text","text":"(K, TA.) [In the former case, the action denotes repugnance to the stallion: in the latter, a degree of refractoriness: in both, difficulty.]       -A2-"},{"kind":"arabic","text_bw":"Easara Algariyma","text_ar":"عَسَرَ الغَرِيمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":"; (S, O;) and ↓"},{"kind":"arabic","text_bw":"A^aEosarahu","text_ar":"اَعْسَرَهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, Msb, K;)"},{"kind":"italic_en","text":"He demanded the debt of the debtor, it being difficult to him to pay it:"},{"kind":"text","text":"(S, O, Msb, K: *) and"},{"kind":"italic_en","text":"he took it of him, it being difficult to him to pay it, and was not lenient towards him until he was in easy circumstances."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Easarahu","text_ar":"عَسَرَهُ"},{"kind":"text","text":", (As, TA,) and ↓"},{"kind":"arabic","text_bw":"AEtsrhu","text_ar":"اعتسرهُ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He forced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compelled, him, against his wish;"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"italic_en","text":"to do the thing;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qasarahu","text_ar":"قَسَرَهُ"},{"kind":"text","text":", (As, TA,) and"},{"kind":"arabic","text_bw":"Aqtsrhu","text_ar":"اقتسرهُ"},{"kind":"text","text":". (S, O, TA.)       -A3-"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Easirato","text_ar":"عَسِرَتْ"},{"kind":"text","text":", (TK,) or"},{"kind":"arabic","text_bw":"Easarato","text_ar":"عَسَرَتْ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":", (S, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, TK,) and"},{"kind":"italic_en","text":"she,"},{"kind":"text","text":"(a woman, TK,)"},{"kind":"italic_en","text":"was left-handed."},{"kind":"text","text":"(S, Mgh, O, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"EasaraniY","text_ar":"عَسَرَنِى"},{"kind":"text","text":", (O, L, and K, and so in a copy of the S,) aor."},{"kind":"text","text":", (L,) or"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":"; (L, TA;) and ↓"},{"kind":"arabic","text_bw":"Eas~araniY","text_ar":"عَسَّرَنِى","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"EasiraniY","text_ar":"عَسِرَنِى"},{"kind":"text","text":", (L and TA, and so in a copy of the S,) aor."},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He came on my right side."},{"kind":"text","text":"(S, O, L, K, TA.)"}],"source_refs":["S","A","O","Msb","K","TA","IKtt","TK","As","Mgh","L"]}]}}