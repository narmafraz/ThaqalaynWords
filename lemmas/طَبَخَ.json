unt":6},"lanes":{"found":true,"entry_ids":["n26288"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%A8%D9%8E%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cook","tags":["transitive"]},{"pos":"verb","gloss":"to cook thoroughly","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of طَبَخَ (ṭabaḵa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"cooking"},{"pos":"noun","gloss":"cooked food"},{"pos":"noun","gloss":"celluloid"}]},"etymology":{"source":"wiktextract","text":"From the root ط ب خ (ṭ b ḵ). Cognate with Hebrew טבח (tavákh, “to slaughter, to massacre, to butcher”)."},"ipa":["/tˤa.ba.xa/","/tˤab.ba.xa/","/tˤabx/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26288","headword_ar":"طَبَخَ","root":"Tbx","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":"(L, Msb, K) and"},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"TaboxN","text_ar":"طَبْخٌ"},{"kind":"text","text":"; (L, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AiT~abaxa","text_ar":"اِطَّبَخَ","orth_type":"arrow"},{"kind":"text","text":", (Sb, L;)"},{"kind":"italic_en","text":"He cooked"},{"kind":"text","text":"(S, L, K;) flesh-meat, (S, A, L,) &c., (L,) either"},{"kind":"italic_en","text":"in a cookingpot"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by boiling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stewing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"by roasting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broiling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frying;"},{"kind":"text","text":"(S, * L, K;) the former verb [accord. to some] said of one who cooks"},{"kind":"italic_en","text":"for himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for others;"},{"kind":"text","text":"and the latter, of one who cooks only"},{"kind":"italic_en","text":"for himself:"},{"kind":"text","text":"(L: [but see an ex. in what follows, of this paragraph; and see also the latter verb below:]) or the former signifies"},{"kind":"italic_en","text":"he cooked"},{"kind":"text","text":"flesh-meat"},{"kind":"italic_en","text":"with broth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy."},{"kind":"text","text":"(Az, Msb.) And you say also"},{"kind":"arabic","text_bw":"Tabaxa Alqidora","text_ar":"طَبَخَ القِدْرَ"},{"kind":"italic_en","text":"He cooked"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the contents of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the cooking-pot."},{"kind":"text","text":"(S, L.) And"},{"kind":"arabic","text_bw":"Tabaxa Almaraqa","text_ar":"طَبَخَ المَرَقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He cooked the broth"},{"kind":"text","text":"]. (A.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Tabaxa","text_ar":"طَبَخَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a dyer)"},{"kind":"italic_en","text":"decocted"},{"kind":"text","text":"Brazil-wood ("},{"kind":"arabic","text_bw":"baq~am","text_ar":"بَقَّم"},{"kind":"text","text":") &c. (A. [See"},{"kind":"arabic","text_bw":"TubaAxapN","text_ar":"طُبَاخَةٌ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"italic_en","text":"He baked"},{"kind":"text","text":"bread, and wheat, and bricks [and clay and pottery]. (L.) One says,"},{"kind":"arabic","text_bw":"h`*ihi xubozapN jay~idapu AlT~aboxi","text_ar":"هٰذِهِ خُبْزَةٌ جَيِّدَةُ الطَّبْخِ"},{"kind":"italic_en","text":"This is a cake of bread well baked"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the hot ashes"},{"kind":"text","text":"]. (S, A, * L, Msb.) And"},{"kind":"arabic","text_bw":"h`*ihi A=jur~apN xay~idapu AlT~aboxi","text_ar":"هٰذِهِ ا=جُرَّةٌ خَيِّدَةُ الطَّبْخِ"},{"kind":"italic_en","text":"This is a brick well baked."},{"kind":"text","text":"(L, Msb.) And ↓"},{"kind":"arabic","text_bw":"AiT~abixuwA","text_ar":"اِطَّبِخُوا","orth_type":"arrow"},{"kind":"arabic","text_bw":"lanaA quroSFA","text_ar":"لَنَا قُرْصًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Bake ye for us"},{"kind":"text","text":"(app. meaning for us including yourselves)"},{"kind":"italic_en","text":"a round cake of bread"},{"kind":"text","text":"]. (S.) ―         -b4-  Also (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the heat)"},{"kind":"italic_en","text":"ripened"},{"kind":"text","text":"the fruit. (TA.) And"},{"kind":"arabic","text_bw":"Tabaxatohumu AlhawaAjiru","text_ar":"طَبَخَتْهُمُ الهَوَاجِرُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The vehement midday-heats fevered them"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Tabaxahu","text_ar":"طَبَخَهُ"},{"kind":"arabic","text_bw":"AljudariY~u","text_ar":"الجُدَرِىُّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The small-pox affected him with a hot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burning, fever"},{"kind":"text","text":"]: and in like manner one says of the"},{"kind":"arabic","text_bw":"HaSobap","text_ar":"حَصْبَة"},{"kind":"text","text":"[i. e. measles, or spotted fever: see"},{"kind":"arabic","text_bw":"TaAbixN","text_ar":"طَابِخٌ"},{"kind":"text","text":"]. (A.) ―         -b5-  [And (assumed tropical:)"},{"kind":"italic_en","text":"He dressed"},{"kind":"text","text":"silk: see the pass. part. n., below.]       -A2-  ["},{"kind":"arabic","text_bw":"Tabixa","text_ar":"طَبِخَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"TabaxN","text_ar":"طَبَخٌ"},{"kind":"text","text":", accord. to the L, seems to signify"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confirmed in stupidity:"},{"kind":"text","text":"but only the inf. n. is there mentioned: and this is doubtful: see"},{"kind":"arabic","text_bw":"A^aTobaxu","text_ar":"اَطْبَخُ"},{"kind":"text","text":".]"}],"source_refs":["L","Msb","K","S","A"]}]},"classical_definitions":null}