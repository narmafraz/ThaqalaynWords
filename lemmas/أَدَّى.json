m":"تُؤَدَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَدِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَدِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤَدُّوا","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَدُّونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤَدَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُؤَدِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُؤَدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَدَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَدَّيْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُؤَدَّى","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَدَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَدِّي","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَدِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":189,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n463","n473"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%8E%D9%91%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n463","headword_ar":"اَدِىٌّ","root":"Adw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adaApN","text_ar":"اَدَاةٌ"},{"kind":"text","text":", in three places.       -A2-  Also"},{"kind":"italic_en","text":"A journey;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a journeying:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"A=daY lils~afari","text_ar":"ا=دَى لِلسَّفَرِ"},{"kind":"text","text":". (M.)"}],"source_refs":[]},{"entry_id":"n473","headword_ar":"اَدِىٌّ","root":"AdY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Adw","text_ar":"ادو"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%AF%D9%89/","headword_ar":"أدى","entries":[{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=17512#35ead3","body_html":"<span class=\"title1\">أد ى</span><br><br><span>أخذ للحرب أداته، حتى قهر عداته. وفلان مؤد على هذا الأمر أي قوي عليه، من قولهم: شاك مؤد للكامل الأداة. وهو آدى للأمانة منك.</span><br><br><span>ومن المجاز قول الراعي:</span><br><br><span>غدت برعال من قطا في حلوقه </span><span class=\"red\">...</span><span> أداوي لطاف الطي موثقة العقد</span><br><br><span>أراد الحواصل.</span>"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=17512#fb5550","body_html":"أدى: أدّى. يقال أدّى الإتاوة له: سلمها اليه، وقد يقال أدى له فقط (معجم أبو الفداء).<br>وكل تُؤَدَّى عنه الحجة: أي يستدل من كل هذه الأشياء على وجود الله (عباد 1: 308) وتؤدى المبني للمجهول من أدّى يعني سلم.<br>وأدى عنه: والأصل أدى الخبر عنه فحذف الخبر (راجع لين في تأدى): نقل، وأوصل. (فالتون 5 و7 رقم 6).<br>تأدى: سُلّم وقُضي (فوك).<br>ادى: هذا (بوشر).<br>أداء. أداء الحروف (راجع لين): إخراج الحروف من مخارجها (المقدمة 2: 388، 398) - والأداء: تلاوة القرآن كما يتلوها القراء (المقدمة 2: 357، 358، والمقري 1: 606).<br>تودية: تحريف تأدية أي أداء وتسليم، دفع (الكالا).<br>مُؤَدّا (كذا): المكان تؤدى فيه الإتاوة والمكس (معجم البلاذري).<br>مودّ (كذا): اتاوة، مكس (هيلو)."},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=17512#cfa0ac","body_html":"<span class=\"title1\">أدى</span><br><span>الأداء: دفع الحق دفعةً وتوفيته، كأداء الخراج والجزية وأداء الأمانة، قال الله تعالى: فَلْيُؤَدِّ الَّذِي اؤْتُمِنَ أَمانَتَهُ [البقرة/ 283] ، إِنَّ اللَّهَ يَأْمُرُكُمْ أَنْ تُؤَدُّوا الْأَماناتِ إِلى أَهْلِها [النساء/ 58] ، وقال: وَأَداءٌ إِلَيْهِ بِإِحْسانٍ [البقرة/ 178] ، وأصل ذلك من الأداة، تقول: أدوت بفعل كذا، أي: احتلت، وأصله: تناولت الأداة التي بها يتوصل إليه، واستأديت على فلان نحو:</span><br><span>استعديت .</span>"}]}}