{"lemma":"حُقْبُ","slug":"حُقْبُ","root":"ح.ق.ب","root_slug":"ح-ق-ب","root_link":"/words/roots/ح-ق-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"حُقْبُ","root":"حقب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n8587","n8590","n8591","n8592","n8593"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D9%82%D9%92%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be delayed, withheld"},{"pos":"verb","gloss":"to be ruined"},{"pos":"verb","gloss":"to carry"},{"pos":"noun","gloss":"ornamental belt"},{"pos":"noun","gloss":"bag handle"},{"pos":"noun","gloss":"plural of حِقَاب (ḥiqāb)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of حِقْبَة (ḥiqba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8587","headword_ar":"حَقِبَ","root":"Hqb","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HaqabN","text_ar":"حَقَبٌ"},{"kind":"text","text":", (Msb, TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a camel's urine)"},{"kind":"italic_en","text":"became suppressed:"},{"kind":"text","text":"and, elliptically, (Msb,)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"suffered suppression of his urine,"},{"kind":"text","text":"(S, Msb,) or"},{"kind":"italic_en","text":"had difficulty in staling,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"in consequence of the pressure of his"},{"kind":"arabic","text_bw":"Haqab","text_ar":"حَقَب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hind girth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon his sheath,"},{"kind":"text","text":"(S, A, K,) which sometimes kills the beast; as also ↓"},{"kind":"arabic","text_bw":"AHqb","text_ar":"احقب","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"Haqibato","text_ar":"حَقِبَتْ"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"suffered suppression of her milk in consequence of the pressure of the"},{"kind":"arabic","text_bw":"Haqab","text_ar":"حَقَب"},{"kind":"italic_en","text":"upon her udder."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,] said of rain, (IAar, L, Msb, K,) &c., (K,) (tropical:)"},{"kind":"italic_en","text":"It was delayed;"},{"kind":"text","text":"(L, Msb;)"},{"kind":"italic_en","text":"was withheld;"},{"kind":"text","text":"(IAar, L, K;) as also ↓"},{"kind":"arabic","text_bw":"AHqb","text_ar":"احقب","orth_type":"arrow"},{"kind":"text","text":". (TA.) And of a year ("},{"kind":"arabic","text_bw":"EAm","text_ar":"عام"},{"kind":"text","text":"), (tropical:)"},{"kind":"italic_en","text":"Its rain was withheld."},{"kind":"text","text":"(S, R, A.) And of a mine, (tropical:)  ["},{"kind":"italic_en","text":"It ceased to yield;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"nothing was found in it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHqb","text_ar":"احقب","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) And of a gift, or benefit, (tropical:)"},{"kind":"italic_en","text":"It became little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased."},{"kind":"text","text":"(TA.) And of an affair, (tropical:)"},{"kind":"italic_en","text":"It became perverted, marred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, and impeded."},{"kind":"text","text":"(L.)       -A2-  See also 8."}],"source_refs":["S","A","Msb","K","TA","IAar","L"]},{"entry_id":"n8590","headword_ar":"حُقْبٌ","root":"Hqb","body":[{"kind":"text","text":", (A, Msb, K,) or ↓"},{"kind":"arabic","text_bw":"HuqubN","text_ar":"حُقُبٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) or the latter also, (A, Msb, K,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dahorN","text_ar":"دَهْرٌ"},{"kind":"text","text":"; (S, A, Msb, K, and Bd in xviii. 59;) [as meaning]"},{"kind":"italic_en","text":"A long time:"},{"kind":"text","text":"(Bd ib.:) and the former, (S,) or both, (A, Msb, * K,)"},{"kind":"italic_en","text":"eighty years;"},{"kind":"text","text":"(S, A, Msb, K, and Bd ubi suprà;) as some say: (Msb and Bd:) or"},{"kind":"italic_en","text":"more:"},{"kind":"text","text":"(S, A, K:) or, as some say,"},{"kind":"italic_en","text":"seventy;:"},{"kind":"text","text":"(Bd:) and"},{"kind":"italic_en","text":"a year;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"HiqobapN","text_ar":"حِقْبَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, A, K:) or"},{"kind":"italic_en","text":"years:"},{"kind":"text","text":"(A, K:) pl. of the former"},{"kind":"arabic","text_bw":"HiqaAbN","text_ar":"حِقَابٌ"},{"kind":"text","text":"[a pl. of mult.], (S, TA,) and of the latter, (S, TA,) or former, (Msb,) or of both, (TA,)"},{"kind":"arabic","text_bw":"A^aHoqaAbN","text_ar":"اَحْقَابٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"A^aHoqubN","text_ar":"اَحْقُبٌ"},{"kind":"text","text":"[both pls. of pauc.]. (Az, K.)"}],"source_refs":["A","Msb","K","S","Bd","TA"]},{"entry_id":"n8591","headword_ar":"حَقَبٌ","root":"Hqb","body":[{"kind":"italic_en","text":"A camel's hind girth;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"girth that is next to the flank:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"a rope with which a camel's saddle is bound to his belly,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"next to the sheath of his penis, in order that the fore girth may not draw it forward"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"nor hurt him,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"in order that the saddle may not shift forward to his withers:"},{"kind":"text","text":"(Msb:) pl."},{"kind":"arabic","text_bw":"A^aHoqaAbN","text_ar":"اَحْقَابٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  And"},{"kind":"italic_en","text":"A cord with which the"},{"kind":"arabic","text_bw":"Haqiybap","text_ar":"حَقِيبَة"},{"kind":"italic_en","text":"is bound."},{"kind":"text","text":"(ISh, TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"HiqaAbN","text_ar":"حِقَابٌ"},{"kind":"text","text":".       -A2-  In excellent she-camels,"},{"kind":"italic_en","text":"Smallness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slenderness, of the flanks, with tenseness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firmness, of the skin of those parts:"},{"kind":"text","text":"a quality approved. (Az, TA.)"}],"source_refs":["A","K","S","Msb","TA"]},{"entry_id":"n8592","headword_ar":"حَقِبٌ","root":"Hqb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaAqibN","text_ar":"حَاقِبٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n8593","headword_ar":"حُقُبٌ","root":"Hqb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HuqobN","text_ar":"حُقْبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}