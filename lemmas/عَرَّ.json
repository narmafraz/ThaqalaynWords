"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["","n28513","n28514","n28896"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28513","headword_ar":"عَرٌّ","root":"Er","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab;"},{"kind":"text","text":"(S, A, Mgh, O, K;) as also ↓"},{"kind":"arabic","text_bw":"Eur~N","text_ar":"عُرٌّ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"Eur~apN","text_ar":"عُرَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(IF, Msb, K) and ↓"},{"kind":"arabic","text_bw":"Ear~apN","text_ar":"عَرَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (IF, Msb, and so in a copy of the A:) see also"},{"kind":"arabic","text_bw":"EararN","text_ar":"عَرَرٌ"},{"kind":"text","text":": or"},{"kind":"arabic","text_bw":"Ear~N","text_ar":"عَرٌّ"},{"kind":"text","text":"has this signification; but ↓"},{"kind":"arabic","text_bw":"Eur~N","text_ar":"عُرٌّ","orth_type":"arrow"},{"kind":"text","text":", with damm, signifies"},{"kind":"italic_en","text":"purulent pustules in the necks of young,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unweaned, camels:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a certain disease, in consequence of which the fur of the camel falls off,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"so that the skin appears and shines;"},{"kind":"text","text":"as some say: (TA:) or"},{"kind":"italic_en","text":"purulent pustules, like the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cutaneous eruption called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"quwabaA='","text_ar":"قُوَبَا=ء"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"which comes forth in camels, dispersedly, in their lips"},{"kind":"text","text":"(S, O)"},{"kind":"italic_en","text":"and their legs,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"discharging a fluid which resembles yellow water; in consequence of which the healthy camels are cauterized, in order that the diseased may not communicate to them the malady."},{"kind":"text","text":"(S, O.) En-Nábighah says, (addressing En-Noamán Ibn-El-Mundhir, O,)"},{"kind":"quote","text":"faHam~alotaniY *anoba A@moriy^K watarakotahu\n                      \n                     \n                        yukowaY gayoruhu wahowa raAtiEu ↓ \n      ka*iY AlEur~i"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And thou hast charged me with the crime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence, of a man"},{"kind":"text","text":"other than myself,"},{"kind":"italic_en","text":"and left him like that which has the disease called"},{"kind":"arabic","text_bw":"Eur~","text_ar":"عُرّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"another than which is cauterized while he is pasturing at pleasure"},{"kind":"text","text":"]: he who says"},{"kind":"arabic","text_bw":"AlEar~","text_ar":"العَرّ"},{"kind":"text","text":", in relating this verse, errs; for cauterization is not practised as a preservative from the mange, or scab. (IDrd, S, O.) ―         -b2-  [Hence, app.,] (assumed tropical:)"},{"kind":"italic_en","text":"A vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(Har p. 366.) [See also"},{"kind":"arabic","text_bw":"Eur~ap","text_ar":"عُرَّة"},{"kind":"text","text":".] ―         -b3-  And (assumed tropical:)"},{"kind":"italic_en","text":"Evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief."},{"kind":"text","text":"(Har ibid.) One says,"},{"kind":"arabic","text_bw":"laqiytu minohu $ar~FA waEar~FA","text_ar":"لَقِيتُ مِنْهُ شَرًّا وَعَرًّا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I experienced from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, evil and mischief:"},{"kind":"text","text":"the two nouns being synonymous: and the latter of them also an inf. n. of"},{"kind":"arabic","text_bw":"Ear~ahu","text_ar":"عَرَّهُ"},{"kind":"text","text":", q. v.]. (TA: but written without any syll. signs.) [See also an instance of the use of the phrase"},{"kind":"arabic","text_bw":"$ar~N waEar~N","text_ar":"شَرٌّ وَعَرٌّ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"dafiynN","text_ar":"دَفِينٌ"},{"kind":"text","text":".] ―         -b4-  See also"},{"kind":"arabic","text_bw":"EaAr~N","text_ar":"عَارٌّ"},{"kind":"text","text":"."}],"source_refs":["K","IF","Msb","TA","S","O"]},{"entry_id":"n28514","headword_ar":"عُرٌّ","root":"Er","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Ear~N","text_ar":"عَرٌّ"},{"kind":"text","text":", in three places: ―         -b2-  and see"},{"kind":"arabic","text_bw":"Eur~apN","text_ar":"عُرَّةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28896","headword_ar":"عَرٍ","root":"ErY","body":[{"kind":"text","text":": see 1, last quarter."}],"source_refs":[]}]},"classical_definitions":null}