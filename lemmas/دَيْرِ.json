originally"},{"kind":"arabic","text_bw":"dayowaArN","text_ar":"دَيْوَارٌ"},{"kind":"text","text":", i. e. of the measure"},{"kind":"arabic","text_bw":"fayoEaAlN","text_ar":"فَيْعَالٌ"},{"kind":"text","text":"; and ISd himself seems in one place to express the same opinion; in like manner as"},{"kind":"arabic","text_bw":"day~uwrN","text_ar":"دَيُّورٌ"},{"kind":"text","text":"is held by the latter to be originally"},{"kind":"arabic","text_bw":"dayowuwrN","text_ar":"دَيْوُورٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"taday~ara","text_ar":"تَدَيَّرَ"},{"kind":"text","text":"is evidently altered from"},{"kind":"arabic","text_bw":"tadaw~ara","text_ar":"تَدَوَّرَ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"A convent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"monastery,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xAn","text_ar":"خان"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of Christians:"},{"kind":"text","text":"(M, K:) and also the"},{"kind":"arabic","text_bw":"SawomaEap","text_ar":"صَوْمَعَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"cloister,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cell,"},{"kind":"text","text":"] of a monk: (A:) the pl. is"},{"kind":"arabic","text_bw":"A^adoyaArN","text_ar":"اَدْيَارٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"duyuwrapN","text_ar":"دُيُورَةٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"rA^osu","text_ar":"راْسُ"},{"kind":"arabic","text_bw":"Ald~ayori","text_ar":"الدَّيْرِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"The head of the convent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"monastery"},{"kind":"text","text":"] is an appellation given to (tropical:)  Any one who has become"},{"kind":"italic_en","text":"the head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, of his companions."},{"kind":"text","text":"(IAar, S, A, K.)"}],"source_refs":["M","K","A","S"]},{"entry_id":"n13548","headword_ar":"دَيْرٌ","root":"dyr","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"dwr","text_ar":"دور"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13402","headword_ar":"دَيِّرٌ","root":"dwr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daAarpN","text_ar":"دَاَرةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n13550","headword_ar":"دَيِّرٌ","root":"dyr","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"dwr","text_ar":"دور"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}