ical:)  ["},{"kind":"italic_en","text":"The journey caused the man to fall sick after it;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the man fell sick after arriving from the journey."},{"kind":"text","text":"(ISd, K.)       -A2-"},{"kind":"arabic","text_bw":"tHl~lhu","text_ar":"تحلّلهُ"},{"kind":"text","text":": see 4."}],"source_refs":[]}]},"classical_definitions":null}