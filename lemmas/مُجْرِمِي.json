{"lemma":"مُجْرِمِي","slug":"مُجْرِمِي","root":"ج.ر.م","root_slug":"ج-ر-م","root_link":"/words/roots/ج-ر-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُجْرِم","root":"جرم","pos":"N","occurrence_count":52},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5602","n5603"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AC%D9%92%D8%B1%D9%90%D9%85%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"criminal"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb أَجْرَمَ (ʔajrama), from the root ج ر م (j r m)."},"ipa":["/mud͡ʒ.rim/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5602","headword_ar":"مُجْرِمٌ","root":"jrm","body":[{"kind":"italic_en","text":"A sinner; a criminal; committing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a committer of, a sin, a crime, a fault, an offence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an act of disobedience;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jariymN","text_ar":"جَرِيمٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"jaArimN","text_ar":"جَارِمٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"Almujorimuwna","text_ar":"المُجْرِمُونَ"},{"kind":"text","text":"particularly signifies"},{"kind":"italic_en","text":"the unbelievers:"},{"kind":"text","text":"(Zj, K:) so in the Kur vii. 38. (Zj, TA.) You say,"},{"kind":"arabic","text_bw":"EalaY nafosihi","text_ar":"عَلَى نَفْسِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa jaArimN","text_ar":"هُوَ جَارِمٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"waqawomihi","text_ar":"وَقَوْمِهِ"},{"kind":"text","text":", [as also"},{"kind":"arabic","text_bw":"mujorimN","text_ar":"مُجْرِمٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He is committing a crime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an offence for which he should be punished, against himself and his people"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","Zj"]},{"entry_id":"n5603","headword_ar":"مُجَرَّمٌ","root":"jrm","body":[{"kind":"text","text":", (fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", S,) A"},{"kind":"italic_en","text":"complete"},{"kind":"text","text":"year (S, K) and month; (Ibn-Háni, TA;) a year"},{"kind":"italic_en","text":"past, completed."},{"kind":"text","text":"(AZ, TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}