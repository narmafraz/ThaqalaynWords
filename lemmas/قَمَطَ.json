ymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n36237"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D9%85%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"restraint, fetter, rope or clamp"},{"pos":"noun","gloss":"a kind of flatbread","tags":["Yemen"]},{"pos":"verb","gloss":"to fetter, to restrain"},{"pos":"verb","gloss":"to tighten, to bandage or swaddle"},{"pos":"verb","gloss":"to tighten, to bandage or swaddle"},{"pos":"noun","gloss":"plural of قِمَاط (qimāṭ, “swaddle”)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of قَمْطَة (qamṭa, “a kind of kerchief”)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From Aramaic קמט / ܩܡܛ (qmaṭ), and noun ܩܡܛܐ (qemṭā, qamṭā). See also from the same semantic domain صَفَد (ṣafad), كِبْل (kibl), قَيْد (qayd)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36237","headword_ar":"قَمَطَ","root":"qmT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, M, Mgh, Msb, K) and"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"qamoTN","text_ar":"قَمْطٌ"},{"kind":"text","text":", (S, M, Mgh, Msb,)"},{"kind":"italic_en","text":"He bound"},{"kind":"text","text":"a child (S, Msb) in the cradle, and a sheep or goat on the occasion of slaughtering it, (S,) with the"},{"kind":"arabic","text_bw":"qimaAT","text_ar":"قِمَاط"},{"kind":"text","text":"[q. v.]: (S, Msb:) or"},{"kind":"arabic","text_bw":"qamaTahu","text_ar":"قَمَطَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he bound his arms and legs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands and feet, together, like as is done with a child in the cradle,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and elsewhere, putting his limbs"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"arms"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"next to the body, and then winding upon him the"},{"kind":"arabic","text_bw":"qimaAT","text_ar":"قِمَاط"},{"kind":"text","text":": (TA:) and"},{"kind":"italic_en","text":"he bound his"},{"kind":"text","text":"(a captive's, Mgh, Msb, K, or others', Mgh)"},{"kind":"italic_en","text":"arms and legs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands and feet, together,"},{"kind":"text","text":"(Mgh, Msb, K, *)"},{"kind":"italic_en","text":"with a rope;"},{"kind":"text","text":"(Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"qm~Thu","text_ar":"قمّطهُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"taqomiyTN","text_ar":"تَقْمِيطٌ"},{"kind":"text","text":": (M, TA:) and"},{"kind":"arabic","text_bw":"qumiTa","text_ar":"قُمِطَ"},{"kind":"text","text":"he (a captive) was thus bound. (S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"qamaTa AlA_ibila","text_ar":"قَمَطَ الاـِبِلَ"},{"kind":"text","text":", (TA,) inf. n. as above, (K,)"},{"kind":"italic_en","text":"He disposed the camels in a file, string,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"series."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","M","Mgh","Msb","K","TA"]}]},"classical_definitions":null}