{"lemma":"رُوعٌ","slug":"رُوعٌ","root":"ر.#.ع","root_slug":"ر-_-ع","root_link":"/words/roots/ر-_-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رُوعٌ","root":"روع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n17080"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D9%88%D8%B9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to terrify, to scare, to frighten, to terrorize, to intimidate"},{"pos":"noun","gloss":"verbal noun of رَاعَ (rāʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"bosom, heart, animus, the place where fear is felt"},{"pos":"noun","gloss":"amazing beauty, terrific fairness"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17080","headword_ar":"رُوعٌ","root":"rwE","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"heart:"},{"kind":"text","text":"(S, Msb, K:) or the"},{"kind":"italic_en","text":"part thereof which is the place of"},{"kind":"arabic","text_bw":"rawoE","text_ar":"رَوْع"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"fear:"},{"kind":"text","text":"(K, * TA:) or the"},{"kind":"arabic","text_bw":"sawaAd","text_ar":"سَوَاد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"core,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"thereof:"},{"kind":"text","text":"(K:) and the"},{"kind":"italic_en","text":"mind:"},{"kind":"text","text":"(S, Msb, K, * TA:) and the"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect."},{"kind":"text","text":"(S, K.) See"},{"kind":"arabic","text_bw":"rawoEN","text_ar":"رَوْعٌ"},{"kind":"text","text":", in five places. You say,"},{"kind":"arabic","text_bw":"waqaEa *`lika fiY ruwEiY","text_ar":"وَقَعَ ذٰلِكَ فِى رُوعِى"},{"kind":"italic_en","text":"That came into my mind."},{"kind":"text","text":"(S, Msb, * TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a Alr~uwHa nafava fiY ruwEiY","text_ar":"اـِنَّ الرُّوحَ نَفَثَ فِى رُوعِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily the Trusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Trusty, Spirit"},{"kind":"text","text":"(meaning"},{"kind":"italic_en","text":"Gabriel"},{"kind":"text","text":")"},{"kind":"italic_en","text":"inspired into my mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heart"},{"kind":"text","text":"]. (S.) You say also,"},{"kind":"arabic","text_bw":"vaAbi ruwEuhu","text_ar":"ثَابِ رُوعُهُ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He went to"},{"kind":"text","text":"[app. a mistake for"},{"kind":"italic_en","text":"from"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing, and then returned to it."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}