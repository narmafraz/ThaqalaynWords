alayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nam~N","text_ar":"نَمٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"namiymapN","text_ar":"نَمِيمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"namiymN","text_ar":"نَمِيمٌ"},{"kind":"text","text":", or this last is pl. of"},{"kind":"arabic","text_bw":"namiymapN","text_ar":"نَمِيمَةٌ"},{"kind":"text","text":", (M,) meaning,"},{"kind":"italic_en","text":"He calumniated him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misrepresented him."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"nam~a AlHadiyva","text_ar":"نَمَّ الحَدِيثَ"},{"kind":"italic_en","text":"He made known, divulged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"told, conversation, in a malicious or mischievous manner, so as to occasion discord, dissension, or the like."},{"kind":"text","text":"(TA, art."},{"kind":"arabic","text_bw":"qt","text_ar":"قت"},{"kind":"text","text":"; and Msb. *)"}],"source_refs":["M"]}]}}