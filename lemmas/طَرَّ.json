"},{"role":"present_3fs","form":"تَطْرُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطُرّا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطِرّا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطُرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطُرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطُرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطُرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْرُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَطْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَطُرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطُرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطِرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطِرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"طَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n26470"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26470","headword_ar":"طَرَّ","root":"Tr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (A, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":", (S, A, Msb, K,)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided, lengthwise; slit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent;"},{"kind":"text","text":"(S, A, Msb, K;) a garment or piece of cloth: (TA:) and"},{"kind":"italic_en","text":"he cut"},{"kind":"text","text":"[in any manner] (S, A, K) the same, (A, TA,) or some other thing. (A.) ―         -b2-"},{"kind":"italic_en","text":"He cut off"},{"kind":"text","text":"a man's arm or hand, by a blow, or stroke; (A;) as also ↓"},{"kind":"arabic","text_bw":"ATr~","text_ar":"اطرّ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K; *) and so"},{"kind":"arabic","text_bw":"Atr~","text_ar":"اترّ"},{"kind":"text","text":". (TA.)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clipped,"},{"kind":"text","text":"his mustache. (TA.) And one says of a woman,"},{"kind":"arabic","text_bw":"taTur~u","text_ar":"تَطُرُّ"},{"kind":"arabic","text_bw":"$aEarahaA","text_ar":"شَعَرَهَا"},{"kind":"italic_en","text":"She cuts her hair short."},{"kind":"text","text":"(A.) [And app."},{"kind":"italic_en","text":"She cuts her hair over the forehead so as to form what is termed a"},{"kind":"arabic","text_bw":"Tur~ap","text_ar":"طُرَّة"},{"kind":"text","text":": see also 2.] ―         -b3-  And"},{"kind":"arabic","text_bw":"Tar~ati AlA_ibilu AljibaAla wAlA=kaAma","text_ar":"طَرَّتِ الاـِبِلُ الجِبَالَ والا=كَامَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The camels traversed the mountains and the hills."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"Tararotu","text_ar":"طَرَرْتُ"},{"kind":"arabic","text_bw":"Alqawoma","text_ar":"القَوْمَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I passed by the people, all of them."},{"kind":"text","text":"(Yoo, TA.)       -A2-  Also,"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":", (S, A,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":"(A, K) and"},{"kind":"arabic","text_bw":"TuruwrN","text_ar":"طُرُورٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He sharpened"},{"kind":"text","text":"(S, A, K, TA) a spear-head, (S,) or a knife (A, K) &c., (K,) or an iron implement. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"italic_en","text":"He polished"},{"kind":"text","text":"a sword. (O.) ―         -b3-  And, (TA,) inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He renovated"},{"kind":"text","text":"a building. (K, TA. [In the CK,"},{"kind":"arabic","text_bw":"taHodiyd","text_ar":"تَحْدِيد"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"tajodiyd","text_ar":"تَجْدِيد"},{"kind":"text","text":"as the explanation of the inf. n.]) ―         -b4-  And"},{"kind":"italic_en","text":"He plastered with clay"},{"kind":"text","text":"his wateringtrough, or tank: (S, TA:) and likewise his mosque, or oratory,"},{"kind":"italic_en","text":"and decorated"},{"kind":"text","text":"it. (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Tar~ahu bivanaA='K HasanK","text_ar":"طَرَّهُ بِثَنَا=ءٍ حَسَنٍ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He eulogized him."},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"xam~a","text_ar":"خَمَّ"},{"kind":"text","text":".)       -A3-  And, aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":", (S, A, K,)"},{"kind":"italic_en","text":"He drove away;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$al~a","text_ar":"شَلَّ"},{"kind":"text","text":"; (S, A, K, TA;) and ↓"},{"kind":"arabic","text_bw":"ATr~","text_ar":"اطرّ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iToraArN","text_ar":"اـِطْرَارٌ"},{"kind":"text","text":", signifies [the same, i. e.]"},{"kind":"arabic","text_bw":"Tarada","text_ar":"طَرَدَ"},{"kind":"text","text":". (As, TA.) In some copies of the K, [and in a copy of the A,]"},{"kind":"arabic","text_bw":"Al$~ad~u","text_ar":"الشَّدُّ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Al$~al~u","text_ar":"الشَّلُّ"},{"kind":"text","text":"as an explanation of"},{"kind":"arabic","text_bw":"AlT~ar~u","text_ar":"الطَّرُّ"},{"kind":"text","text":". (TA.) ―         -b2-  And you say"},{"kind":"arabic","text_bw":"Tararotu AlA_ibila","text_ar":"طَرَرْتُ الاـِبِلَ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"I drove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gathered, the camels together, from their several quarters;"},{"kind":"text","text":"(S, K; *) like"},{"kind":"arabic","text_bw":"TaradotuhaA","text_ar":"طَرَدْتُهَا"},{"kind":"text","text":": (S:) or, accord. to Yaakoob,"},{"kind":"italic_en","text":"I walked on one side of the camels, and then on the other side, to put them in right order."},{"kind":"text","text":"(S.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":"signifies also The act of"},{"kind":"italic_en","text":"seizing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carrying-off, by force;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"snatching at unawares."},{"kind":"text","text":"(Kr, K.) ―         -b4-  And The act of"},{"kind":"italic_en","text":"slapping with the palm of the hand."},{"kind":"text","text":"(Kr, K.)       -A4-  As an intrans. v.,"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"text","text":", (Msb, K,) the latter agreeable with analogy, (TA,) [but the former the more common,] inf. n."},{"kind":"arabic","text_bw":"TuruwrN","text_ar":"طُرُورٌ"},{"kind":"text","text":", (S, Msb,) or"},{"kind":"arabic","text_bw":"Tar~N","text_ar":"طَرٌّ"},{"kind":"text","text":", (K,) or both, (TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"clave the earth:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"grew forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprouted:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"came up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(K.) And it is likewise said of the mustache (S, A, Msb, K) of a boy, (S, A, Msb,) and of hair in general; meaning (tropical:)"},{"kind":"italic_en","text":"It burst through the skin:"},{"kind":"text","text":"(A:) some say,"},{"kind":"arabic","text_bw":"Tur~a $aAribuhu","text_ar":"طُرَّ شَارِبُهُ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"his mustache grew forth"},{"kind":"text","text":"]; (O, TA;) but"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":"is more chaste. (Az, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Tar~ati Aln~ujuwmu","text_ar":"طَرَّتِ النُّجُومُ"},{"kind":"text","text":", occurring in a trad., means (assumed tropical:)"},{"kind":"italic_en","text":"The stars rose;"},{"kind":"text","text":"(O, TA;) from"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":"said of a plant: (TA:) or the phrase, as some relate it, is"},{"kind":"arabic","text_bw":"Tur~ati Alnjwm","text_ar":"طُرَّتِ النجوم"},{"kind":"text","text":", which means (assumed tropical:)"},{"kind":"italic_en","text":"the stars shone;"},{"kind":"text","text":"(O, TA;) from"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":"meaning “ he polished ” a sword. (O.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Tar~ato yaduhu","text_ar":"طَرَّتْ يَدُهُ"},{"kind":"text","text":", (S, K, * TA,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":"(K, TA) by common consent of the authorities on inflection, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"His arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, fell off;"},{"kind":"text","text":"(S, K, * TA;) ["},{"kind":"italic_en","text":"being severed"},{"kind":"text","text":"by a blow, or stroke;] like"},{"kind":"arabic","text_bw":"tar~ato","text_ar":"تَرَّتْ"},{"kind":"text","text":". (S, TA.)       -A5-  See also 4.       -A6-"},{"kind":"arabic","text_bw":"Tar~a","text_ar":"طَرَّ"},{"kind":"text","text":"said of a man, [app. of the measure"},{"kind":"arabic","text_bw":"faEula","text_ar":"فَعُلَ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"Tarura","text_ar":"طَرُرَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"TaraArapN","text_ar":"طَرَارَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful, goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comely."},{"kind":"text","text":"(ISh, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Tar~ato naAqatiY","text_ar":"طَرَّتْ نَاقَتِى"},{"kind":"text","text":", [app. of the measure"},{"kind":"arabic","text_bw":"faEilato","text_ar":"فَعِلَتْ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"Tarirato","text_ar":"طَرِرَتْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taTar~u","text_ar":"تَطَرُّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"TararN","text_ar":"طَرَرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"My she-camel was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, clear in colour."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["A","Msb","TA","S","K"]}]}}