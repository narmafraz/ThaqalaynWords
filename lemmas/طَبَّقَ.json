per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُطَبِّقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُطَبِّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُطَبِّق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُطَبِّق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُطَبِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطَبِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُطَبِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطَبِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُطَبِّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطَبِّقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُطَبِّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طَبَّقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَبَّقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُطَبِّق","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطَبِّق","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":true,"lemma_key":"طَبَّقَ","root":"طبق","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n26342","n26343","n26344"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%A8%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plate (serving dish)"},{"pos":"noun","gloss":"anything in the shape of a serving dish, such as a satellite dish (طَبَق الْقَمَر (ṭabaq al-qamar)), flying saucer (طَبَق طَائِر (ṭabaq ṭāʔir))"},{"pos":"noun","gloss":"a thing that is the equal of another thing so that it covers it, lid, cover"},{"pos":"noun","gloss":"a joint, a limb or member of the body; bone of the head","tags":["obsolete"]},{"pos":"noun","gloss":"velum, the soft palate"},{"pos":"verb","gloss":"to superpose, to make cover or covered so that there is congruence, to fold into one another or together","examples":[{"text":"قرّرتُ إكمال المقالة في وقت آخر. طبّقتُ الكمبيوتر المحمول، وذهبتُ إلى الحمّام.","english":"I decided to finish the article another time. I closed the portable computer and went to the bathroom."}]},{"pos":"verb","gloss":"to apply, to implement","tags":["broadly"]},{"pos":"noun","gloss":"thing that matches in form, what suits, conforms, corresponds, tallies, what is of the like measure (often in the adverbial accusative)"}]},"etymology":{"source":"wiktextract","text":"Alteration of طَابَق (ṭābaq)."},"ipa":["/tˤa.baq/","/tˤab.ba.qa/","/tˤibq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26342","headword_ar":"طَبْقٌ","root":"Tbq","body":[{"kind":"text","text":": see an ex. of the accus. case, in the phrase"},{"kind":"arabic","text_bw":"waladati Alganamu TaboqFA","text_ar":"وَلَدَتِ الغَنَمُ طَبْقًا"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":", last quarter.       -A2-"},{"kind":"arabic","text_bw":"TaboqN","text_ar":"طَبْقٌ"},{"kind":"text","text":"is also expl., by IAar, as meaning The"},{"kind":"italic_en","text":"doing wrong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"injuring, by false pretence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false allegation."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n26343","headword_ar":"طِبْقٌ","root":"Tbq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":", in the latter part of the former half. ―         -b2-"},{"kind":"arabic","text_bw":"Tiboqu AlA^aroDi","text_ar":"طِبْقُ الاَرْضِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TibaAqN","text_ar":"طِبَاقٌ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"h`*aA Al$~aYo'u","text_ar":"هٰذَا الشَّىْءُ"},{"kind":"arabic","text_bw":"Tiboqu h`*aA","text_ar":"طِبْقُ هٰذَا"},{"kind":"text","text":", (IAar, O, K, *) and ↓"},{"kind":"arabic","text_bw":"Tabaquhu","text_ar":"طَبَقُهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"TibaAquhu","text_ar":"طِبَاقُهُ","orth_type":"arrow"},{"kind":"text","text":", (IAar, * O, * K,) and ↓"},{"kind":"arabic","text_bw":"Tabiyquhu","text_ar":"طَبِيقُهُ","orth_type":"arrow"},{"kind":"text","text":", (IAar, O, K,) and ↓"},{"kind":"arabic","text_bw":"TaAbaquhu","text_ar":"طَابَقُهُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"muTobaquhu","text_ar":"مُطْبَقُهُ","orth_type":"arrow"},{"kind":"text","text":", (IAar, O, TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muTaAbiquhu","text_ar":"مُطَابِقُهُ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"This thing is the match of this;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what suits, matches, tallies, conforms, corresponds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agrees, with this; what is equal to this;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like of this in measure, size, quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (IAar, O, K, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"TiboqN","text_ar":"طِبْقٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"A space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEapN","text_ar":"سَاعَةٌ"},{"kind":"text","text":",) of the day; and so ↓"},{"kind":"arabic","text_bw":"TiboqapN","text_ar":"طِبْقَةٌ","orth_type":"arrow"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"TabiyqN","text_ar":"طَبِيقٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same of the night: (K:) you say,"},{"kind":"arabic","text_bw":"A^aqamotu Einodahu TiboqFA mina Aln~ahaAri","text_ar":"اَقَمْتُ عِنْدَهُ طِبْقًا مِنَ النَّهَارِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"TiboqapF","text_ar":"طِبْقَةً","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"I remained at his abode during a space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEapF","text_ar":"سَاعَةً"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of the day:"},{"kind":"text","text":"(Ibn-'Abbád, O:) and"},{"kind":"arabic","text_bw":"TiboqFA","text_ar":"طِبْقًا"},{"kind":"text","text":", (K, TA,) with kesr, (TA,) or ↓"},{"kind":"arabic","text_bw":"TabaqFA","text_ar":"طَبَقًا","orth_type":"arrow"},{"kind":"text","text":", (so in the O,) and ↓"},{"kind":"arabic","text_bw":"TabiyqFA","text_ar":"طَبِيقًا","orth_type":"arrow"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a while,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a long time,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maliy~FA","text_ar":"مَلِيًّا"},{"kind":"text","text":": (Ibn-'Abbád, O, K:) or, accord. to the L, one says,"},{"kind":"arabic","text_bw":"A^ataAnaA baEoda TiboqK mina","text_ar":"اَتَانَا بَعْدَ طِبْقٍ مِنَ"},{"kind":"page_break","n":1826},{"kind":"arabic","text_bw":"All~ayoli","text_ar":"اللَّيْلِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Tabiyq","text_ar":"طَبِيق","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he came to us after a space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"HiynK","text_ar":"حِينٍ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of the night;"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"mina Aln~ahaAri","text_ar":"مِنَ النَّهَارِ"},{"kind":"italic_en","text":"of the day:"},{"kind":"text","text":"(TA:) the pl. of"},{"kind":"arabic","text_bw":"TabiyqN","text_ar":"طَبِيقٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"TuboqN","text_ar":"طُبْقٌ"},{"kind":"text","text":". (K.) [See also"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":", in, or near, the middle of the paragraph.]       -A2-  Also"},{"kind":"italic_en","text":"Bird-lime;"},{"kind":"text","text":"a dial. var. of"},{"kind":"arabic","text_bw":"diboqN","text_ar":"دِبْقٌ"},{"kind":"text","text":". (IDrd, O, K.) And The"},{"kind":"italic_en","text":"fruit of a certain kind of tree"},{"kind":"text","text":"[app. meaning the"},{"kind":"italic_en","text":"berries of the viscum,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mistletoe,"},{"kind":"text","text":"of which birdlime is mostly prepared, and which are called"},{"kind":"arabic","text_bw":"diboq","text_ar":"دِبْق"},{"kind":"text","text":"in the present day]. (K.) And"},{"kind":"italic_en","text":"Anything with which a thing is stuck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to stick."},{"kind":"text","text":"(K.) And [particularly]"},{"kind":"italic_en","text":"A thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"substance"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to which the exterior lamina of the pearl is stuck so that it becomes like it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muTab~aqN","text_ar":"مُطَبَّقٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Snares for birds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"things with which birds are caught;"},{"kind":"text","text":"(Ibn-'Abbád, O;)"},{"kind":"italic_en","text":"like"},{"kind":"arabic","text_bw":"fixaAx","text_ar":"فِخَاخ"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"TibaqN","text_ar":"طِبَقٌ"},{"kind":"text","text":"; of which [latter] the sing is ↓"},{"kind":"arabic","text_bw":"TiboqapN","text_ar":"طِبْقَةٌ","orth_type":"arrow"},{"kind":"text","text":". (Ibn-'Abbád, O, K.)       -A3-  Also"},{"kind":"italic_en","text":"A road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way:"},{"kind":"text","text":"-A4-  and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dasotuwr","text_ar":"دَسْتُور"},{"kind":"text","text":"[as a Pers. word, generally meaning"},{"kind":"italic_en","text":"Permission,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leave,"},{"kind":"text","text":"as expl. by Golius in this instance]. (KL. [But for these two significations I have not found any other authority.])"}],"source_refs":["IAar","O","K","TA"]},{"entry_id":"n26344","headword_ar":"طَبَقٌ","root":"Tbq","body":[{"kind":"italic_en","text":"A thing that is the equal"},{"kind":"text","text":"of another thing (Msb, K) of any kind (K)"},{"kind":"italic_en","text":"in its measure so that it covers the whole extent of the latter like the lid:"},{"kind":"text","text":"this is its primary signification: (Msb:) [whence] one says,"},{"kind":"arabic","text_bw":"h`*aA Al$~aYo'u Tabaqu h`*aA","text_ar":"هٰذَا الشَّىْءُ طَبَقُ هٰذَا"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Tiboquhu","text_ar":"طِبْقُهُ"},{"kind":"text","text":", q. v.: (IAar, O, K:) and [hence] it signifies The"},{"kind":"italic_en","text":"cover,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lid,"},{"kind":"text","text":"(Mgh, K,) of a jar, (Mgh,) or of anything: (K:) pl."},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":"(S, * O, * K) [and"},{"kind":"arabic","text_bw":"TibaAqN","text_ar":"طِبَاقٌ"},{"kind":"text","text":", mentioned in the Msb as a pl. of"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"in another, but similar, sense, which will be found in what follows, but better known as a pl. of"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"A^aTobiqapN","text_ar":"اَطْبِقَةٌ"},{"kind":"text","text":"is added as another pl. in the K, but [SM says] this is strange; I have not found it in the [other] lexicons; and it may be that the right reading is"},{"kind":"arabic","text_bw":"waA^aTobaqahu","text_ar":"وَاَطْبَقَهُ"},{"kind":"text","text":", as syn. with what immediately there follows it, i. e."},{"kind":"arabic","text_bw":"waTab~aqahu","text_ar":"وَطَبَّقَهُ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"waAfaqa $an~N Tabaqaho","text_ar":"وَافَقَ شَنٌّ طَبَقَهْ"},{"kind":"text","text":"is [a prov.] expl. (O, K, TA) by As (O, TA) as said of a company of men who had a receptacle of skin [i. e. a water-skin] that had become old and worn out, wherefore they made a"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":"[or cover] for it: (O, K, TA:) [so that the meaning is,"},{"kind":"italic_en","text":"A water-skin that had become old and worn out suited its cover:"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"$an~N","text_ar":"شَنٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"[in the O"},{"kind":"arabic","text_bw":"Tbqh","text_ar":"طبقه"},{"kind":"text","text":"] were two tribes; (S, * O, K * TA;) and, as ISd says,"},{"kind":"arabic","text_bw":"$an~N","text_ar":"شَنٌّ"},{"kind":"text","text":"does not here mean a water-skin, for this has no"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":": (TA:) or ["},{"kind":"arabic","text_bw":"TabaqahN","text_ar":"طَبَقَهٌ"},{"kind":"text","text":"is for"},{"kind":"arabic","text_bw":"Tabaqapa","text_ar":"طَبَقَةَ"},{"kind":"text","text":", and]"},{"kind":"arabic","text_bw":"Tabaqapu","text_ar":"طَبَقَةُ"},{"kind":"text","text":"was an intelligent woman, whom an intelligent man took as his wife. (O, K, TA. [See Freytag's Arab. Prov., ii. 800.]) ―         -b2-  Also"},{"kind":"italic_en","text":"A certain household utensil;"},{"kind":"text","text":"(Msb;) [i. e."},{"kind":"italic_en","text":"a dish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plate;"},{"kind":"text","text":"perhaps thus called because the cover of a cooking-vessel is often used as a dish or plate;] the"},{"kind":"italic_en","text":"thing upon which one eats,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"in which one eats;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"thing upon which fruit is placed"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a dish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plate, used for that purpose;"},{"kind":"text","text":"and likewise"},{"kind":"italic_en","text":"a round tray,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]: (TA:) pl."},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TibaAqN","text_ar":"طِبَاقٌ"},{"kind":"text","text":". (Msb.) ―         -b3-  ―         -b4-  (tropical:)  The"},{"kind":"italic_en","text":"surface of the earth"},{"kind":"text","text":"[considered as a cover]. (K, TA.) [And in like manner applied to"},{"kind":"italic_en","text":"A layer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stratum,"},{"kind":"text","text":"of earth."},{"kind":"arabic","text_bw":"dafanotu Al$~aYo'a","text_ar":"دَفَنْتُ الشَّىْءَ"},{"kind":"text","text":"is expl. in the Msb as meaning"},{"kind":"arabic","text_bw":"A^axofayotuhu taHota A^aTobaAqi Alt~uraAbi","text_ar":"اَخْفَيْتُهُ تَحْتَ اَطْبَاقِ التُّرَابِ"},{"kind":"italic_en","text":"I concealed it beneath the layers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strata, of the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust."},{"kind":"text","text":"See also"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ"},{"kind":"text","text":".] ―         -b5-  (tropical:)  The"},{"kind":"italic_en","text":"exterior part of the pudendum muliebre"},{"kind":"text","text":"[considered as a cover]. (Ibn-'Abbád, O, K, TA.) ―         -b6-"},{"kind":"italic_en","text":"A fold, a ply,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an overlapping part,"},{"kind":"text","text":"of a thing. (PS. [See"},{"kind":"arabic","text_bw":"HafivN","text_ar":"حَفِثٌ"},{"kind":"text","text":".]) ―         -b7-  [And hence, app., (tropical:)"},{"kind":"italic_en","text":"A roller"},{"kind":"text","text":"of the sea: see"},{"kind":"arabic","text_bw":"A=*iY~N","text_ar":"ا=ذِىٌّ"},{"kind":"text","text":".] ―         -b8-"},{"kind":"italic_en","text":"A thin bone"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"cartilage"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that forms a division between any two vertebræ:"},{"kind":"text","text":"(S, O, K:)"},{"kind":"italic_en","text":"what is between any two vertebræ"},{"kind":"text","text":"of a horse [&c.]: pl."},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":": (Kr:) and some say, the"},{"kind":"italic_en","text":"vertebræ altogether:"},{"kind":"text","text":"and some say,"},{"kind":"italic_en","text":"a vertebra, in any part."},{"kind":"text","text":"(TA.) It is said in a trad. respecting the day of resurrection,"},{"kind":"arabic","text_bw":"taboqaY A^aSolaAbu AlmunaAfiqiyna","text_ar":"تَبْقَى اَصْلَابُ المُنَافِقِينَ"},{"kind":"arabic","text_bw":"TabaqFA waAHidFA","text_ar":"طَبَقًا وَاحِدًا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"The backbones of the hypocrites shall be"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"continue to be"},{"kind":"text","text":") as though they were]"},{"kind":"italic_en","text":"one vertebra:"},{"kind":"text","text":"or, as some say, ↓"},{"kind":"arabic","text_bw":"TabaqapF","text_ar":"طَبَقَةً","orth_type":"arrow"},{"kind":"text","text":"; and [they say that]"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"is the pl. [or coll. gen. n.]. (O. [See also 1 in art."},{"kind":"arabic","text_bw":"Eqm","text_ar":"عقم"},{"kind":"text","text":".]) ―         -b9-  [And"},{"kind":"italic_en","text":"Any of the successively-superimposed cartilages of the windpipe:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":". (See"},{"kind":"arabic","text_bw":"HanojarapN","text_ar":"حَنْجَرَةٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Hjr","text_ar":"حجر"},{"kind":"text","text":"; and see also"},{"kind":"arabic","text_bw":"HuloquwmN","text_ar":"حُلْقُومٌ"},{"kind":"text","text":".)] ―         -b10-"},{"kind":"italic_en","text":"Any of the stages of Hell"},{"kind":"text","text":"[whereof every one except the lowest is imagined to be like a cover over another]. (TA.) [And in like manner,"},{"kind":"italic_en","text":"Any of the Seven Heavens:"},{"kind":"text","text":"] one says,"},{"kind":"arabic","text_bw":"Als~am`waAtu TibaAqN","text_ar":"السَّمٰوَاتُ طِبَاقٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The Heavens are"},{"kind":"text","text":"[composed of"},{"kind":"italic_en","text":"stages"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one above another;"},{"kind":"text","text":"(S, O, Msb; *) every heaven [except the lowest] being like a"},{"kind":"arabic","text_bw":"Tbq","text_ar":"طبق"},{"kind":"text","text":"to another: (Msb:) or this is said because of their being conformable, one with another: (K:) and it is said in the Kur lxvii. 3,"},{"kind":"arabic","text_bw":"Aal~a*iY xalaqa saboEa sam`waAtK TibaAqFA","text_ar":"اَلَّذِى خَلَقَ سَبْعَ سَمٰوَاتٍ طِبَاقًا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Who hath created seven heavens"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"placed one above another;"},{"kind":"arabic","text_bw":"TbAqA","text_ar":"طباقا"},{"kind":"text","text":"being the inf. n. of"},{"kind":"arabic","text_bw":"TaAbaqotu Aln~aEola","text_ar":"طَابَقْتُ النَّعْلَ"},{"kind":"text","text":"[q. v.], used as an epithet; or for"},{"kind":"arabic","text_bw":"Tuwbiqato TibaAqFA","text_ar":"طُوبِقَتْ طِبَاقًا"},{"kind":"text","text":"; or"},{"kind":"arabic","text_bw":"*aAta TibaAqK","text_ar":"ذَاتَ طِبَاقٍ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"or of ↓"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ","orth_type":"arrow"},{"kind":"text","text":". (Bd.) ―         -b11-  ["},{"kind":"italic_en","text":"Any of the bones"},{"kind":"text","text":"of the head; because they compose a covering: or]"},{"kind":"arabic","text_bw":"A^aTobaAqu","text_ar":"اَطْبَاقُ"},{"kind":"arabic","text_bw":"Alr~aA^osi","text_ar":"الرَّاْسِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the bones of the head"},{"kind":"text","text":"because they suit one another and have certain parts of them inserted and infixed into other parts. (TA. [See 8 in art."},{"kind":"arabic","text_bw":"$jr","text_ar":"شجر"},{"kind":"text","text":".]) ―         -b12-"},{"kind":"italic_en","text":"Any joint of a limb:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":". (As, TA.) ―         -b13-"},{"kind":"italic_en","text":"A collective number"},{"kind":"text","text":"of men, and of locusts; (S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"TiboqN","text_ar":"طِبْقٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) which is thus expl. by As in relation to men: (TA:) or"},{"kind":"italic_en","text":"a multitude"},{"kind":"text","text":"of men, and of locusts: (K:) [app. considered as covering a space of ground:] or"},{"kind":"italic_en","text":"a company"},{"kind":"text","text":"of men"},{"kind":"italic_en","text":"that are equal with a company like them."},{"kind":"text","text":"(ISd, TA.) ―         -b14-"},{"kind":"italic_en","text":"A generation of mankind;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"people of one time;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaronN","text_ar":"قَرْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAlamN","text_ar":"عَالَمٌ"},{"kind":"text","text":"; as in the saying of El- 'Abbás,"},{"kind":"quote","text":"A_i*aA maDaY EaAlamN badaA Tabaqu"},{"kind":"text","text":"[metre"},{"kind":"arabic","text_bw":"munosariH","text_ar":"مُنْسَرِح"},{"kind":"text","text":"] i. e."},{"kind":"arabic","text_bw":"A_i*aA maDaY qaronN badaA qaronN","text_ar":"اـِذَا مَضَى قَرْنٌ بَدَا قَرْنٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When a generation passes away, a generation appears"},{"kind":"text","text":"in its place]: the"},{"kind":"arabic","text_bw":"qaron","text_ar":"قَرْن"},{"kind":"text","text":"being called"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":"because they are a"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":"[i. e. cover] to the earth: then they pass away and another"},{"kind":"arabic","text_bw":"Tabq","text_ar":"طَبق"},{"kind":"text","text":"comes: (O, TA:) or, as IAar says,"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a people after a people."},{"kind":"text","text":"(TA.) And (TA)"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"qaron","text_ar":"قَرْن"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"generation"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of time:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"twenty years:"},{"kind":"text","text":"(K, TA:) or, as in the book of El-Hejeree, on the authority of I'Ab, ↓"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ","orth_type":"arrow"},{"kind":"text","text":"has this latter meaning. (TA.) ―         -b15-  (tropical:)  A rain"},{"kind":"italic_en","text":"such as fills and covers the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"such as is general,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"and of wide extent;"},{"kind":"text","text":"termed by a poet (namely, Imra-el-Keys, O, TA)"},{"kind":"arabic","text_bw":"Tabaqu AlA^aroDi","text_ar":"طَبَقُ الاَرْضِ"},{"kind":"text","text":": (S, O, TA:) or a"},{"kind":"italic_en","text":"lasting"},{"kind":"text","text":"rain,"},{"kind":"italic_en","text":"consecutive in its falls."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^aSobaHati AlA^aroDu TabaqFA waAHidFA","text_ar":"اَصْبَحَتِ الاَرْضُ طَبَقًا وَاحِدًا"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"The land became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became in the morning,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"covered with water over its surface."},{"kind":"text","text":"(TA.) ―         -b16-"},{"kind":"italic_en","text":"A main portion"},{"kind":"text","text":"of the night and of the day: (S, O, K:) or, accord. to the Mufradát [of Er-Rághib],"},{"kind":"arabic","text_bw":"Tabaqu","text_ar":"طَبَقُ"},{"kind":"arabic","text_bw":"All~ayoli waAln~ahaAri","text_ar":"اللَّيْلِ وَالنَّهَارِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"saAEaAtuhu AlmTAbqp","text_ar":"سَاعَاتُهُ المطابقة"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"AlmutaTaAbiqapu","text_ar":"المُتَطَابِقَةُ"},{"kind":"text","text":", and meaning"},{"kind":"italic_en","text":"the commensurate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"equal, portions of the night and of the day"},{"kind":"text","text":"]. (TA.) See also"},{"kind":"arabic","text_bw":"TiboqN","text_ar":"طِبْقٌ"},{"kind":"text","text":". ―         -b17-  And"},{"kind":"italic_en","text":"A state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"(S, O, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ","orth_type":"arrow"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"TibaAqN","text_ar":"طِبَاقٌ"},{"kind":"text","text":": the pl. of the former in this sense is"},{"kind":"arabic","text_bw":"A^aTobaAqN","text_ar":"اَطْبَاقٌ"},{"kind":"text","text":". (TA.) Hence the phrase,"},{"kind":"arabic","text_bw":"latarokabun~a TabaqFA Eano TabaqK","text_ar":"لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ"},{"kind":"text","text":", (S, O, K, TA,) in the Kur [lxxxiv. 19], meaning ["},{"kind":"italic_en","text":"Ye shall assuredly enter upon"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"state after state,"},{"kind":"text","text":"(S, * O, TA,) and"},{"kind":"italic_en","text":"predicament after predicament;"},{"kind":"text","text":"as in the A; (TA;) on the day of resurrection; (S;) the state being termed"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":"because it will fill the hearts [as though the dread thereof covered them], or will be near to doing so; (O, TA;) and"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"being put in this instance, as it is in many others, in the place of"},{"kind":"arabic","text_bw":"baEoda","text_ar":"بَعْدَ"},{"kind":"text","text":": (TA:) or the meaning is,"},{"kind":"italic_en","text":"one after another of similar states of hardship:"},{"kind":"text","text":"or it may be,"},{"kind":"italic_en","text":"degrees of hardship after degrees thereof;"},{"kind":"arabic","text_bw":"TabaqN","text_ar":"طَبَقٌ"},{"kind":"text","text":"accord. to this rendering being regarded as pl. [or coll. gen. n.] of ↓"},{"kind":"arabic","text_bw":"TabaqapN","text_ar":"طَبَقَةٌ","orth_type":"arrow"},{"kind":"text","text":": (Ksh and Bd:) or ["},{"kind":"italic_en","text":"ye shall assuredly mount upon"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the heaven in one state after another state;"},{"kind":"text","text":"for it (the heaven) shall be like"},{"kind":"arabic","text_bw":"muhol","text_ar":"مُهْل"},{"kind":"text","text":"[i. e. molten brass or iron &c., as is said in the Kur lxx. 8,] and then successively in other states: (O, TA:) so says Aboo-Bekr: accord. to Er-Rághib, it points to the various successive states of man in the present world from his creation, and in the world to come until his resting in one of the two abodes [Paradise or Hell]: or, accord. to Ibn-Abi-l- Hadeed, it means ["},{"kind":"italic_en","text":"ye shall assuredly enter upon"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"difficulty after difficulty;"},{"kind":"text","text":"as is related by MF; and the same is said by Az on the authority of I'Ab: (TA:) some read"},{"kind":"arabic","text_bw":"latarokaban~a","text_ar":"لَتَرْكَبَنَّ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"thou,"},{"kind":"text","text":"O Mohammad,"},{"kind":"italic_en","text":"shalt assuredly mount upon stage after stage"},{"kind":"text","text":"of the stages ("},{"kind":"arabic","text_bw":"A^aTobaAq","text_ar":"اَطْبَاق"},{"kind":"text","text":") of heaven; and I'Ab and Ibn-Mes-ood read"},{"kind":"arabic","text_bw":"latarokabin~a","text_ar":"لَتَرْكَبِنَّ"},{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":", which is accord. to the dial. of Temeem, and Keys and Asad and Rabee'ah pronounce the first letter of the future with kesr except when it is"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":": 'Omar read"},{"kind":"arabic","text_bw":"layarokaban~a","text_ar":"لَيَرْكَبَنَّ"},{"kind":"text","text":", either as relating to the Prophet or as referring to him who is mentioned in verses 10-15 of the same chapter. (O, TA.) One says also,"},{"kind":"arabic","text_bw":"baAta yaroEaY Tabaqa Aln~ujuwmi","text_ar":"بَاتَ يَرْعَى طَبَقَ النُّجُومِ"},{"kind":"text","text":", meaning (tropical:)  ["},{"kind":"italic_en","text":"He passed the night watching"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the state of the stars in their course:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"Tabaqu","text_ar":"طَبَقُ"},{"kind":"page_break","n":1827},{"kind":"arabic","text_bw":"Aln~ujuwmi","text_ar":"النُّجُومِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the falling"},{"kind":"text","text":"[or app."},{"kind":"italic_en","text":"setting"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of stars after"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"stars:"},{"kind":"text","text":"or, accord. to Es-Sadoosee,"},{"kind":"italic_en","text":"the rising of a star and the setting of another:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a collective number thereof after a collective number"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of others"},{"kind":"text","text":"]: and such, he says, are termed"},{"kind":"arabic","text_bw":"mina Aln~ujuwmi","text_ar":"مِنَ النُّجُومِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"TabaqaAtN","text_ar":"طَبَقَاتٌ","orth_type":"arrow"},{"kind":"text","text":". (O.) ―         -b18-"},{"kind":"arabic","text_bw":"jaA='ati AlA_ibilu TabaqFA","text_ar":"جَا=ءَتِ الاـِبِلُ طَبَقًا"},{"kind":"arabic","text_bw":"waAHidFA","text_ar":"وَاحِدًا"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"EalaY xuf~K waAHidK","text_ar":"عَلَى خُفٍّ وَاحِدٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The camels came following one another, in a single line:"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"xf","text_ar":"خف"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"waladati Alganamu","text_ar":"وَلَدَتِ الغَنَمُ"},{"kind":"arabic","text_bw":"TabaqFA","text_ar":"طَبَقًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"TaboqFA","text_ar":"طَبْقًا","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, brought forth one after another:"},{"kind":"text","text":"(L:) El-Umawee says, when they do thus, one says,"},{"kind":"arabic","text_bw":"waladatohaA Alr~ujayolaA='i","text_ar":"وَلَدَتْهَا الرُّجَيْلَا=ءِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waladatohaA TabaqFA","text_ar":"وَلَدَتْهَا طَبَقًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"TabaqapF","text_ar":"طَبَقَةً","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They brought them forth"},{"kind":"text","text":"(i. e. their young ones)"},{"kind":"italic_en","text":"one after another"},{"kind":"text","text":"]. (S, O.) ―         -b19-  [The pl.]"},{"kind":"arabic","text_bw":"AlA^aTobaAqu","text_ar":"الاَطْبَاقُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Those who are remote, and those who are remotely connected:"},{"kind":"text","text":"so in a trad. respecting the signs of the resurrection, or of the time thereof; in which it is said,"},{"kind":"arabic","text_bw":"yuwoSalu AlA^aTobaAqu wayuqoTaEu AlA^aroHaAmu","text_ar":"يُوْصَلُ الاَطْبَاقُ وَيُقْطَعُ الاَرْحَامُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Those who are remote, and those who are remotely related, shall be brought into close connection, and the ties of relationship shall be severed"},{"kind":"text","text":"]. (TA.) ―         -b20-"},{"kind":"arabic","text_bw":"binotu","text_ar":"بِنْتُ"},{"kind":"arabic","text_bw":"TabaqK","text_ar":"طَبَقٍ"},{"kind":"text","text":"is an appellation of"},{"kind":"italic_en","text":"A female tortoise,"},{"kind":"text","text":"[app. because of the cover of her back,]"},{"kind":"italic_en","text":"which,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"as the Arabs assert,"},{"kind":"text","text":"(S, O,)"},{"kind":"italic_en","text":"lays ninety-nine eggs, all of them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"eventually"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"tortoises, and lays one egg which discloses"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"a serpent"},{"kind":"text","text":"(K) [or"},{"kind":"italic_en","text":"a serpent such as is termed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"an"},{"kind":"arabic","text_bw":"A^asowad","text_ar":"اَسْوَد"},{"kind":"text","text":"; (S, O;) or, accord. to Az,"},{"kind":"italic_en","text":"sixty-nine"},{"kind":"text","text":"["},{"kind":"italic_en","text":"eggs"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and the seventieth is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"eventually"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a viper."},{"kind":"text","text":"(So in a marg. note in one of my copies of the S; in which, also, the appellation is written"},{"kind":"arabic","text_bw":"binotu Tabaqa","text_ar":"بِنْتُ طَبَقَ"},{"kind":"text","text":", instead of"},{"kind":"arabic","text_bw":"binotu","text_ar":"بِنْتُ"},{"kind":"arabic","text_bw":"TabaqK","text_ar":"طَبَقٍ"},{"kind":"text","text":".) Hence the phrase"},{"kind":"arabic","text_bw":"A_iHodaY banaAti TabaqK","text_ar":"اـِحْدَى بَنَاتِ طَبَقٍ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"A calamity;"},{"kind":"text","text":"(S, O, TA;) as also"},{"kind":"arabic","text_bw":"binotu TabaqK","text_ar":"بِنْتُ طَبَقٍ"},{"kind":"text","text":": (TA:)"},{"kind":"arabic","text_bw":"banaAtu TabaqK","text_ar":"بَنَاتُ طَبَقٍ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"calamities"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"muTobiqaAtN","text_ar":"مُطْبِقَاتٌ"},{"kind":"text","text":"]: as well as"},{"kind":"italic_en","text":"tortoises:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"serpents:"},{"kind":"text","text":"(K:) and"},{"kind":"arabic","text_bw":"A^um~u TabaqK","text_ar":"اُمُّ طَبَقٍ"},{"kind":"text","text":"[in like manner] means"},{"kind":"italic_en","text":"calamity:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Trq","text_ar":"طرق"},{"kind":"text","text":":) or, accord. to EthTha'álibee,"},{"kind":"arabic","text_bw":"Tabaqu","text_ar":"طَبَقُ"},{"kind":"text","text":"[thus, imperfectly decl., as written in the L,) signifies"},{"kind":"italic_en","text":"a yellow serpent:"},{"kind":"text","text":"(L, TA:) and"},{"kind":"arabic","text_bw":"A^um~u TabaqK","text_ar":"اُمُّ طَبَقٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"binotu TabaqK","text_ar":"بِنْتُ طَبَقٍ"},{"kind":"text","text":"are said to signify"},{"kind":"italic_en","text":"the serpent,"},{"kind":"text","text":"because of its coiling itself round: or"},{"kind":"arabic","text_bw":"banaAtu TabaqK","text_ar":"بَنَاتُ طَبَقٍ"},{"kind":"text","text":"is an appellation applied to"},{"kind":"italic_en","text":"serpents"},{"kind":"text","text":"because of their winding themselves round ("},{"kind":"arabic","text_bw":"lA_iTobaAqihaA","text_ar":"لاـِطْبَاقِهَا"},{"kind":"text","text":") upon him whom they bite; or, as some say, because the"},{"kind":"arabic","text_bw":"Haw~aA='","text_ar":"حَوَّا=ء"},{"kind":"text","text":"[q. v.] confines them beneath the lids ("},{"kind":"arabic","text_bw":"A^aTobaAq","text_ar":"اَطْبَاق"},{"kind":"text","text":") of the baskets ("},{"kind":"arabic","text_bw":"A^asofaAT","text_ar":"اَسْفَاط"},{"kind":"text","text":") covered with leather; or, as Z says, because they resemble the"},{"kind":"arabic","text_bw":"Tabaq","text_ar":"طَبَق"},{"kind":"text","text":"[i. e. cover, or dish, or plate,] when they coil themselves round. (TA.)"}],"source_refs":["Msb","K","IAar","O","Mgh","TA","S","Kr","L"]}]}}