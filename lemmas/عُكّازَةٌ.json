{"lemma":"عُكّازَةٌ","slug":"عُكّازَةٌ","root":"ع.ك.ز","root_slug":"ع-ك-ز","root_link":"/words/roots/ع-ك-ز","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30078"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D9%83%D9%91%D8%A7%D8%B2%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"alternative form of عُكَّاز (ʕukkāz)","tags":["alt-of","alternative"]}]},"etymology":null,"ipa":["/ʕuk.kaː.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30078","headword_ar":"عُكَّازَةٌ","root":"Ekz","body":[{"kind":"text","text":"(S, A, O, Msb, K *) and ↓"},{"kind":"arabic","text_bw":"Euk~aAzN","text_ar":"عُكَّازٌ","orth_type":"arrow"},{"kind":"text","text":", (A, K,) or this is a pl., (O,) [or a coll. gen. n.,] and accord. to the K ↓"},{"kind":"arabic","text_bw":"EakowazN","text_ar":"عَكْوَزٌ","orth_type":"arrow"},{"kind":"text","text":", but correctly ↓"},{"kind":"arabic","text_bw":"Eak~uwzN","text_ar":"عَكُّوزٌ","orth_type":"arrow"},{"kind":"text","text":", as written by Sgh, (TA,)"},{"kind":"italic_en","text":"A staff having a"},{"kind":"arabic","text_bw":"zuj~","text_ar":"زُجّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a pointed iron foot"},{"kind":"text","text":"] (S, A, O, K)"},{"kind":"italic_en","text":"at the lower extremity,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"upon which a man leans,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stays himself:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EanazapN","text_ar":"عَنَزَةٌ"},{"kind":"text","text":"[q. v.]: (Msb:) pl."},{"kind":"arabic","text_bw":"EakaAkiyzu","text_ar":"عَكَاكِيزُ"},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"arabic","text_bw":"Euk~aAzaAtN","text_ar":"عُكَّازَاتٌ"},{"kind":"text","text":". (O, Msb.) ―         -b2-  The first of these words is also used metonymically for"},{"kind":"arabic","text_bw":"manoSibN","text_ar":"مَنْصِبٌ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"A post, an office, a function,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a magistracy"},{"kind":"text","text":"]: hence the saying"},{"kind":"arabic","text_bw":"fulaAnN mino A^arobaAbi","text_ar":"فُلَانٌ مِنْ اَرْبَابِ"},{"kind":"arabic","text_bw":"AlEakaAkiyzi","text_ar":"العَكَاكِيزِ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"Such a one is of the functionaries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magistrates:"},{"kind":"text","text":"because officers of rank made use of walking-sticks]. (TA.)"}],"source_refs":["A","K","O","TA","S","Msb"]}]},"classical_definitions":null}