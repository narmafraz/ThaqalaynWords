en":"m","num":"p"},{"role":"present_2mp","form":"تُعَزِّمُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَزِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَزِّم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَزِّم","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَزِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَزِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَزِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَزِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَزِّمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَزِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَزِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَزَّمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَزَّمْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَزِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَزِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":35,"cross_references":{"qac":{"found":true,"lemma_key":"عَزَّمَ","root":"عزم","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n29001"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B2%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to decide, to resolve"},{"pos":"verb","gloss":"to determine, to make up one's mind, to be firmly resolved"},{"pos":"verb","gloss":"to adjure, to command formally"},{"pos":"verb","gloss":"to go, to resort"},{"pos":"verb","gloss":"to conjure, to charm, to read spells"},{"pos":"verb","gloss":"to summon, invite","tags":["colloquial","transitive"]},{"pos":"noun","gloss":"verbal noun of عَزَمَ (ʕazama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"firm resolution, resolve, determination","examples":[{"text":"كَانَ ٱلْأُفُقُ مَجْمُوعَةً مِنَ ٱلْخُطُوطِ ٱلْمُسْتَقِيمَةِ، وَلٰكِنَّهُ كَانَ قَدْ عَقَدَ عَزْمَهُ عَلَى ٱلْمَسِيرِ بِجِدٍّ","english":"The horizon was a collection of straight, orange lines, but he had taken a firm decision to go forward, doggedly."}]},{"pos":"noun","gloss":"decision"},{"pos":"noun","gloss":"energy"},{"pos":"noun","gloss":"torque"}]},"etymology":null,"ipa":["/ʕa.za.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29001","headword_ar":"عَزْمٌ","root":"Ezm","body":[{"kind":"text","text":"an inf. n. of 1. (S, Msb, K, &c.) [Hence,]"},{"kind":"arabic","text_bw":"A^uwluw AlEazomi mina Alr~usuli","text_ar":"اُولُو العَزْمِ مِنَ الرُّسُلِ"},{"kind":"text","text":", (K, &c.,) mentioned in the Kur [xlvi. 34], (TA,)"},{"kind":"italic_en","text":"Those, of the apostles, who determined upon doing what God had enjoined them:"},{"kind":"text","text":"or they were"},{"kind":"italic_en","text":"Noah and Abraham and Moses and Mohammad;"},{"kind":"text","text":"(K, TA;) to which several add"},{"kind":"italic_en","text":"and Jesus:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"those, of the apostles, who were endowed with earnestness and constancy and patience:"},{"kind":"text","text":"(Ksh, K, TA:)"},{"kind":"arabic","text_bw":"EazomN","text_ar":"عَزْمٌ"},{"kind":"text","text":"in the dial. of Hudheyl meaning"},{"kind":"italic_en","text":"patience;"},{"kind":"text","text":"as in their saying,"},{"kind":"arabic","text_bw":"maA liY Eanoka EazomN","text_ar":"مَا لِى عَنْكَ عَزْمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have not patience of separation from thee"},{"kind":"text","text":"]: (TA:) or, (K,) it is said, (Ksh,) they were"},{"kind":"italic_en","text":"Noah and Abraham and Isaac and Jacob and Joseph and Job and Moses and David and Jesus:"},{"kind":"text","text":"(Ksh, K:) or"},{"kind":"italic_en","text":"Noah and Hood and Abraham and Mohammad:"},{"kind":"text","text":"thus accord. to Aboo-Is-hák. (Yoo, R, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"EaziymapN","text_ar":"عَزِيمَةٌ"},{"kind":"text","text":", in three places. ―         -b3-"},{"kind":"arabic","text_bw":"EazomN","text_ar":"عَزْمٌ"},{"kind":"text","text":"is expl. by Lth as meaning"},{"kind":"italic_en","text":"An affair upon the doing of which one's heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, is firmly settled"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determined."},{"kind":"text","text":"(TA.)       -A2-  Also The"},{"kind":"italic_en","text":"dregs of pressed raisins:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"EuzumN","text_ar":"عُزُمٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["TA","Ksh","K"]}]}}