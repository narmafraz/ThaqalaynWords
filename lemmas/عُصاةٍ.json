{"lemma":"عُصاةٍ","slug":"عُصاةٍ","root":"ع.ص.#","root_slug":"ع-ص-_","root_link":"/words/roots/ع-ص-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n29386","n29394"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D8%B5%D8%A7%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29386","headword_ar":"عَصَاهُ","root":"ESw","body":[{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"yaEoSuwhu","text_ar":"يَعْصُوهُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EaSowN","text_ar":"عَصْوٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"He struck him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat him, with the staff"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rod"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"biAlEaSaA","text_ar":"بِالعَصَا"},{"kind":"text","text":"): (K, TA:) or"},{"kind":"arabic","text_bw":"EaSawotuhu","text_ar":"عَصَوْتُهُ"},{"kind":"arabic","text_bw":"biAlEaSaA","text_ar":"بِالعَصَا"},{"kind":"italic_en","text":"I struck him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat him, with the staff"},{"kind":"text","text":"&c. (S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EaSiYa bihaA","text_ar":"عَصِىَ بِهَا"},{"kind":"italic_en","text":"He took it,"},{"kind":"text","text":"i. e. the staff &c.: and"},{"kind":"arabic","text_bw":"EaSiYa bisayofihi","text_ar":"عَصِىَ بِسَيْفِهِ"},{"kind":"italic_en","text":"he took his sword as one takes the staff:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat, with it as one does with the staff;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"EaSaA","text_ar":"عَصَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaSFA","text_ar":"عَصًا"},{"kind":"text","text":": or you say"},{"kind":"arabic","text_bw":"EaSawotu biAls~ayofi","text_ar":"عَصَوْتُ بِالسَّيْفِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaSiytu","text_ar":"عَصِيتُ"},{"kind":"arabic","text_bw":"biAlEaSaA","text_ar":"بِالعَصَا"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"EaSayotu","text_ar":"عَصَيْتُ"},{"kind":"text","text":"]: or the reverse of this: or each of these verbs followed by"},{"kind":"arabic","text_bw":"bAlsyf","text_ar":"بالسيف"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bAlESA","text_ar":"بالعصا"},{"kind":"text","text":": (K, TA:) all these phrases are mentioned by the leading lexicologists and by ISd in the M: (TA:) or you say"},{"kind":"arabic","text_bw":"EaSiYa biAls~ayofi","text_ar":"عَصِىَ بِالسَّيْفِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaSFA","text_ar":"عَصًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he struck with the sword."},{"kind":"text","text":"(S.) [See also 5.] ―         -b3-"},{"kind":"arabic","text_bw":"EaASaAniY faEaSawotuhu","text_ar":"عَاصَانِى فَعَصَوْتُهُ"},{"kind":"text","text":": see 3. ―         -b4-  [See also 2.]       -A2-"},{"kind":"arabic","text_bw":"EaSawotu Alqawoma","text_ar":"عَصَوْتُ القَوْمَ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"A^aEoSuwhumo","text_ar":"اَعْصُوهُمْ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"I collected together the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, for good"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for evil."},{"kind":"text","text":"(K, TA.) [This seems to be regarded by some as the primary signification; (see"},{"kind":"arabic","text_bw":"EaSFA","text_ar":"عَصًا"},{"kind":"text","text":";) but, I think, without good reason.] ―         -b2-  And"},{"kind":"arabic","text_bw":"EaSawotu","text_ar":"عَصَوْتُ"},{"kind":"arabic","text_bw":"AljuroHa","text_ar":"الجُرْحَ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"EaSowN","text_ar":"عَصْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I bound the wound."},{"kind":"text","text":"(S, K.)       -A3-"},{"kind":"arabic","text_bw":"EaSaA","text_ar":"عَصَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaSowN","text_ar":"عَصْوٌ"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard:"},{"kind":"text","text":"as though for"},{"kind":"arabic","text_bw":"EasaA","text_ar":"عَسَا"},{"kind":"text","text":"; the"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":". (TA.)       -A4-  And"},{"kind":"arabic","text_bw":"EaSaA","text_ar":"عَصَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEoSuw","text_ar":"يَعْصُو"},{"kind":"text","text":", said of a bird,"},{"kind":"italic_en","text":"It flew."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","TK","S"]},{"entry_id":"n29394","headword_ar":"عَصَاهُ","root":"ESY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEoSiyhi","text_ar":"يَعْصِيهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaSoYN","text_ar":"عَصْىٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEoSiyapN","text_ar":"مَعْصِيَةٌ"},{"kind":"text","text":"(S, Msb, K, TA) and"},{"kind":"arabic","text_bw":"EiSoyaAnN","text_ar":"عِصْيَانٌ"},{"kind":"text","text":", (TA, and so in some copies of the S,) or this last is a simple subst., (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"([for instance] a slave, Msb, TA)"},{"kind":"italic_en","text":"disobeyed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebelled against him,"},{"kind":"text","text":"(S, K, TA,) i. e., his master; (Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"EASAhu","text_ar":"عاصاهُ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K, TA,) inf. n."},{"kind":"arabic","text_bw":"muEaASaApN","text_ar":"مُعَاصَاةٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstESY","text_ar":"استعصى","orth_type":"arrow"},{"kind":"text","text":", (S,) meaning"},{"kind":"italic_en","text":"he opposed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resisted him,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"did not obey him,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he rebelled against him,"},{"kind":"text","text":"] namely, his prince, or commander. (TA.) [See also an ex. of the first in a verse cited voce"},{"kind":"arabic","text_bw":"zuj~N","text_ar":"زُجٌّ"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"fulaAnN yaEoSiY AlriyHa","text_ar":"فُلَانٌ يَعْصِى الرِيحَ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Such a one faces the quarter from which the wind blows, not opposing his side to the wind."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}