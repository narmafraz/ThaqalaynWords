{"lemma":"ثَوِيِّ","slug":"ثَوِيِّ","root":"ث.#.#","root_slug":"ث-_-_","root_link":"/words/roots/ث-_-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n4791","n4845","","n4853","n4854"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D9%88%D9%90%D9%8A%D9%90%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4791","headword_ar":"ثُوىٌّ","root":"vw","body":[{"kind":"text","text":": see above."}],"source_refs":[]},{"entry_id":"n4845","headword_ar":"ثَوَى","root":"vwY","body":[{"kind":"text","text":"(T, S, M, Mgh, Msb, K)"},{"kind":"arabic","text_bw":"biAlmakaAni","text_ar":"بِالمَكَانِ"},{"kind":"text","text":", (S, M, Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"arabic","text_bw":"AlmakaAna","text_ar":"المَكَانَ"},{"kind":"text","text":", (S, * M, Msb, K,) aor."},{"kind":"text","text":", (T, S, Msb,"},{"kind":"page_break","n":366},{"kind":"text","text":"K,) inf. n."},{"kind":"arabic","text_bw":"vawaA='u","text_ar":"ثَوَا=ءُ"},{"kind":"text","text":"(T, S, M, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"vuwiY~N","text_ar":"ثُوِىٌّ"},{"kind":"text","text":"(S, M, Mgh, K) and"},{"kind":"arabic","text_bw":"mavowFY","text_ar":"مَثْوًى"},{"kind":"text","text":"; (T, M;) and ↓"},{"kind":"arabic","text_bw":"AvwY","text_ar":"اثوى","orth_type":"arrow"},{"kind":"text","text":"(T, S, M, Msb, K)"},{"kind":"arabic","text_bw":"bAlmkAn","text_ar":"بالمكان"},{"kind":"text","text":", (S, M, K,) or"},{"kind":"arabic","text_bw":"fyh","text_ar":"فيه"},{"kind":"text","text":"; (so in the CK;)"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"(T, S, Mgh, Msb,)"},{"kind":"italic_en","text":"in the place:"},{"kind":"text","text":"(S, Mgh, Msb:) or"},{"kind":"italic_en","text":"he remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, long"},{"kind":"text","text":"(Lth, T, M, K)"},{"kind":"italic_en","text":"therein:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alighted and abode, in the place:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"he alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alighted and abode,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"he settled,"},{"kind":"text","text":"(TA,)"},{"kind":"arabic","text_bw":"bAlmkAn","text_ar":"بالمكان"},{"kind":"italic_en","text":"in the place."},{"kind":"text","text":"(M.) Hence,"},{"kind":"arabic","text_bw":"A_in~aA nuTiylu Alv~uwiY~a","text_ar":"اـِنَّا نُطِيلُ الثُّوِىَّ"},{"kind":"arabic","text_bw":"fiY d~Ari AlHarobi","text_ar":"فِى دّارِ الحَرْبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily we prolong the stay in the seat of war"},{"kind":"text","text":"]. (Mgh.) [You say also,"},{"kind":"arabic","text_bw":"vaway A_ilaY","text_ar":"ثَوَي اـِلَى"},{"kind":"arabic","text_bw":"AlmaroA^api","text_ar":"المَرْاَةِ"},{"kind":"italic_en","text":"He betook himself to the woman to remain, stay, dwell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abide, with her:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"vawiy~apN","text_ar":"ثَوِيَّةٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"text","text":", (T, M, IB, TA,) aor."},{"kind":"text","text":"; in the K, incorrectly, ↓"},{"kind":"arabic","text_bw":"vw~Y","text_ar":"ثوّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tavowiyapN","text_ar":"تَثْوِيَةٌ"},{"kind":"text","text":"; (TA;) signifies also"},{"kind":"italic_en","text":"He was slain,"},{"kind":"text","text":"(T, M,)"},{"kind":"italic_en","text":"and remained where he was:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"he remained in his grave:"},{"kind":"text","text":"(IB, TA:) or, as the latter verb is explained in the K,"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(TA.) [See a verse cited in art."},{"kind":"arabic","text_bw":"Hsb","text_ar":"حسب"},{"kind":"text","text":", conj. 2.]       -A2-"},{"kind":"arabic","text_bw":"vuwiYa","text_ar":"ثُوِىَ"},{"kind":"italic_en","text":"He was buried:"},{"kind":"text","text":"(M, K:) because there is no longer dwelling than that of him who is buried. (M.)"}],"source_refs":["T","S","M","Mgh","Msb","K","Lth","TA","IB"]},{"entry_id":"n4853","headword_ar":"ثَوِىٌّ","root":"vwY","body":[{"kind":"italic_en","text":"A guest:"},{"kind":"text","text":"(IAar, T, S, M, K:) the vulgar erroneously pronounce it"},{"kind":"arabic","text_bw":"tiwiY~N","text_ar":"تِوِىٌّ"},{"kind":"text","text":". (TA. [See also"},{"kind":"arabic","text_bw":"mavowFY","text_ar":"مَثْوًى"},{"kind":"text","text":".]) ―         -b2-"},{"kind":"italic_en","text":"Remaining, staying, dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"tawiY~N","text_ar":"تَوِىٌّ"},{"kind":"text","text":"; but the former is better known in this sense. (M in art."},{"kind":"arabic","text_bw":"twY","text_ar":"توى"},{"kind":"text","text":".) ―         -b3-"},{"kind":"italic_en","text":"One who abides"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mujaAwirN","text_ar":"مُجَاوِرٌ"},{"kind":"text","text":"[generally meaning"},{"kind":"italic_en","text":"for the purpose of study"},{"kind":"text","text":"])"},{"kind":"italic_en","text":"in either of the two sacred cities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"territories"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of Mekkeh and El-Medeeneh"},{"kind":"text","text":"]. (IAar, T, K.) ―         -b4-"},{"kind":"italic_en","text":"One who is very patient in military and predatory expeditions, who is detained in the territory of the enemy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the frontier of the enemies' country."},{"kind":"text","text":"(IAar, T.) ―         -b5-"},{"kind":"italic_en","text":"A captive."},{"kind":"text","text":"(Th, M, K.)       -A2-"},{"kind":"italic_en","text":"A chamber,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, prepared for a guest:"},{"kind":"text","text":"(T, M, K:) and, (M,) accord. to Lth, (T,)"},{"kind":"italic_en","text":"a chamber within a chamber."},{"kind":"text","text":"(T, M.)"}],"source_refs":["IAar","T","S","M","K"]},{"entry_id":"n4854","headword_ar":"ثُوِىٌّ","root":"vwY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"vw","text_ar":"ثو"},{"kind":"text","text":".       -A2-  Also an inf. n. of 1. (S &c.)"}],"source_refs":[]}]},"classical_definitions":null}