nt_3mp","form":"يُنْشَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْشُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُنْشَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَشَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَشَرْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْشُر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْشُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نُشِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نُشِرْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُنْشَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُنْشَر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":69,"cross_references":{"qac":{"found":true,"lemma_key":"نَشَرَ","root":"نشر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":16},"lanes":{"found":true,"entry_ids":["n39807"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to spread out, unroll, exhibit"},{"pos":"verb","gloss":"to spread about, make publicly known, communicate"},{"pos":"verb","gloss":"to publish","examples":[{"text":"لقد نشرتُ أكثر من خمسة وعشرين كتابا في الدراسات الإسلاميّة باللغتين الإِنْكْلِيزِيَّة والعَرَبِيَّة.","english":"I have published more than twenty-five books on Islamic studies in both English and Arabic."}]},{"pos":"verb","gloss":"to propagate"},{"pos":"verb","gloss":"to separate, disperse"},{"pos":"verb","gloss":"to be scattered"},{"pos":"verb","gloss":"to put forth leaves"},{"pos":"verb","gloss":"to blow"},{"pos":"verb","gloss":"to carve wood"},{"pos":"verb","gloss":"to saw"},{"pos":"noun","gloss":"verbal noun of نَشَرَ (našara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"spreading, publishing"},{"pos":"noun","gloss":"sawing"},{"pos":"noun","gloss":"life, resurrection"},{"pos":"noun","gloss":"first germination of a plant"},{"pos":"noun","gloss":"fragrance, odor, scent, smell"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39807","headword_ar":"نَشَرَ","root":"n$r","body":[{"kind":"text","text":", (S, A, Msb,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":", (S, A, Msb, K,)"},{"kind":"italic_en","text":"He spread, spread out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open, expanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfolded,"},{"kind":"text","text":"(S, TA,) a garment or piece of cloth (A, Msb, TA) or the like, (TA,) goods, &c., (S,) and a writing; (A;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"TawaY","text_ar":"طَوَى"},{"kind":"text","text":"; (A, K;) as also ↓"},{"kind":"arabic","text_bw":"n$~r","text_ar":"نشّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tano$iyrN","text_ar":"تَنْشِيرٌ"},{"kind":"text","text":": (K, TA:) [or the latter is with teshdeed to denote muchness, or frequency, or repetition, of the action, or its application to many objects, as is shown by an explanation of its act. part. n., which see below. Hence"},{"kind":"arabic","text_bw":"laf~N wana$orN","text_ar":"لَفٌّ وَنَشْرٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"lf","text_ar":"لف"},{"kind":"text","text":".] ―         -b2-  ["},{"kind":"italic_en","text":"He spread out,"},{"kind":"text","text":"or, as we say,"},{"kind":"italic_en","text":"pricked up,"},{"kind":"text","text":"his ears: and hence the saying,]"},{"kind":"arabic","text_bw":"na$ara li*`lika AlA^amori A^u*unayohi","text_ar":"نَشَرَ لِذٰلِكَ الاَمْرِ اُذُنَيْهِ"},{"kind":"text","text":", lit.,"},{"kind":"italic_en","text":"He spread out his ears at that thing:"},{"kind":"text","text":"meaning, (tropical:)"},{"kind":"italic_en","text":"he was covetous of that thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eager for it."},{"kind":"text","text":"(Har. p. 206.) [See"},{"kind":"arabic","text_bw":"naA$irN","text_ar":"نَاشِرٌ"},{"kind":"text","text":", below.] ―         -b3-"},{"kind":"arabic","text_bw":"na$ara Alxabara","text_ar":"نَشَرَ الخَبَرَ"},{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"He spread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"published, the news."},{"kind":"text","text":"(S, A, K.) ―         -b4-  Also"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":"; (Msb, K;) [and ↓"},{"kind":"arabic","text_bw":"n$~r","text_ar":"نشّر","orth_type":"arrow"},{"kind":"text","text":", or this is with teshdeed for the purpose mentioned above;]"},{"kind":"italic_en","text":"He scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"(Msb, K, TA,) [people, &c.; or] sheep or goats, (Msb, TA,) and camels, (TA,)"},{"kind":"italic_en","text":"after confining"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"in the nightly resting-place."},{"kind":"text","text":"(Msb.) ―         -b5-"},{"kind":"italic_en","text":"He sprinkled"},{"kind":"text","text":"water. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"na$arati Alr~iyHu","text_ar":"نَشَرَتِ الرِّيحُ"},{"kind":"italic_en","text":"The wind blew in a misty"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloudy day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to disperse the mist"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clouds"},{"kind":"text","text":"]. (IAar, K.) ―         -b7-"},{"kind":"arabic","text_bw":"na$ara Eanohu","text_ar":"نَشَرَ عَنْهُ"},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":"; (A;) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"n$~r","text_ar":"نشّر","orth_type":"arrow"},{"kind":"text","text":", (A, L, TA,) inf. n."},{"kind":"arabic","text_bw":"tano$iyrN","text_ar":"تَنْشِيرٌ"},{"kind":"text","text":"; (S, A, L, TA;) and in like manner ↓"},{"kind":"arabic","text_bw":"n$~rhu","text_ar":"نشّرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, TA;) (tropical:)"},{"kind":"italic_en","text":"He charmed away"},{"kind":"page_break","n":2794},{"kind":"italic_en","text":"from him sickness,"},{"kind":"text","text":"(S, * A, L, K, *) and"},{"kind":"italic_en","text":"diabolical possession,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"madness,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"by a"},{"kind":"arabic","text_bw":"nu$orap","text_ar":"نُشْرَة"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"a charm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an amulet;"},{"kind":"text","text":"(S, A, L, K;)"},{"kind":"italic_en","text":"as though he dispersed it from him:"},{"kind":"text","text":"(A:) and in like manner ↓"},{"kind":"arabic","text_bw":"n$~rhu","text_ar":"نشّرهُ","orth_type":"arrow"},{"kind":"italic_en","text":"he wrote for him a"},{"kind":"arabic","text_bw":"nu$orap","text_ar":"نُشْرَة"},{"kind":"text","text":". (S.) El-Kilábee says,"},{"kind":"arabic","text_bw":"faA_i*aA nu$ira AlmasofuwEu kaAna kaA^an~amaA A^uno$iTa","text_ar":"فَاـِذَا نُشِرَ المَسْفُوعُ كَانَ كَاَنَّمَا اُنْشِطَ"},{"kind":"arabic","text_bw":"mino EiqaAlK","text_ar":"مِنْ عِقَالٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"And when he who is smitten by the evil eye is charmed by a"},{"kind":"arabic","text_bw":"nu$orap","text_ar":"نُشْرَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"he is as though he were loosed from a bond"},{"kind":"text","text":"]: i. e., it [the effect of the eye] departs from him speedily. (S [in two copies of which I find"},{"kind":"arabic","text_bw":"nu$ira","text_ar":"نُشِرَ"},{"kind":"text","text":", as above; but in the TA, ↓"},{"kind":"arabic","text_bw":"nu$~ira","text_ar":"نُشِّرَ","orth_type":"arrow"},{"kind":"text","text":".]) And in a trad. it is said,"},{"kind":"arabic","text_bw":"biqulo A^aEuw*u birab~i Aln~aAsi","text_ar":"بِقُلْ اَعُوذُ بِرَبِّ النَّاسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"na$~arahu","text_ar":"نَشَّرَهُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He charmed away the effect of enchantment from him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by"},{"kind":"text","text":"the words “"},{"kind":"italic_en","text":"Say I seek refuge in the Lord of men:"},{"kind":"text","text":"” the commencement of the last chap. of the Kur-án]. (S.)       -A2-"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":", (El-Hasan, Zj, A, K.) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nu$uwrN","text_ar":"نُشُورٌ"},{"kind":"text","text":"; (K, TA;) or ↓"},{"kind":"arabic","text_bw":"A^ano$ara","text_ar":"اَنْشَرَ","orth_type":"arrow"},{"kind":"text","text":"; (I'Ab, Fr, S, A, Mgh, Msb;) or both; (A, K;) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God, S, A, &c.)"},{"kind":"italic_en","text":"raised"},{"kind":"text","text":"the dead"},{"kind":"italic_en","text":"to life; quickened"},{"kind":"text","text":"them;"},{"kind":"italic_en","text":"revivified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revived,"},{"kind":"text","text":"them. (Zj, S, A, Mgh, Msb, K, &c.) I'Ab reads [in the Kur, ii. 261,]"},{"kind":"arabic","text_bw":"kayofa nuno$iruhaA","text_ar":"كَيْفَ نُنْشِرُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How we will raise them to life"},{"kind":"text","text":"], and adduces in his favour the words [in the Kur. lxxx. 22,] ↓"},{"kind":"arabic","text_bw":"vum~a A_i*aA $aA='a A^ano$arahu","text_ar":"ثُمَّ اـِذَا شَا=ءَ اَنْشَرَهُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Then, when He pleaseth, He raiseth him to life"},{"kind":"text","text":"]: El-Hasan reads"},{"kind":"arabic","text_bw":"nano$uruhaA","text_ar":"نَنْشُرُهَا"},{"kind":"text","text":": [and others read"},{"kind":"arabic","text_bw":"nuno$izuhaA","text_ar":"نُنْشِزُهَا"},{"kind":"text","text":", with záy:] but Fr says, that El-Hasan holds it to refer to unfolding and folding, and that the proper way is to use"},{"kind":"arabic","text_bw":"An$r","text_ar":"انشر"},{"kind":"text","text":"[in this sense,] transitively, and"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":"intransitively. (S, TA.) [See also"},{"kind":"arabic","text_bw":"TawaYa","text_ar":"طَوَىَ"},{"kind":"text","text":", which has the contr. meaning.] ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"Alr~aDaAEu AlEaZoma","text_ar":"الرَّضَاعُ العَظْمَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ano$ara","text_ar":"اَنْشَرَ","orth_type":"arrow"},{"kind":"text","text":":"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^ano$aza","text_ar":"اَنْشَزَ"},{"kind":"text","text":", with záy: (Msb:) or (tropical:)"},{"kind":"italic_en","text":"The sucking strengthened the bone."},{"kind":"text","text":"(Mgh.)       -A3-"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"nu$uwrN","text_ar":"نُشُورٌ"},{"kind":"text","text":"(S, A, Msb, TA) and"},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":", (Msb,) agreeably with what Fr says, (S,) signifies (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a dead person)"},{"kind":"italic_en","text":"lived after death; came to life again; revived;"},{"kind":"text","text":"(S, TA;) or"},{"kind":"italic_en","text":"lived; came to life;"},{"kind":"text","text":"(A, Msb;) as also ↓"},{"kind":"arabic","text_bw":"Ant$r","text_ar":"انتشر","orth_type":"arrow"},{"kind":"text","text":". (A.) Hence"},{"kind":"arabic","text_bw":"yawomu Aln~u$uwri","text_ar":"يَوْمُ النُّشُورِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The day of resurrection."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":", (K, TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(herbage, or pasturage,)"},{"kind":"italic_en","text":"became green in consequence of rain in the end of summer after it had dried up."},{"kind":"text","text":"(TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"began to grow forth in the ground."},{"kind":"text","text":"(K, * TA.) You say,"},{"kind":"arabic","text_bw":"maA A^aHosana na$orahaA","text_ar":"مَا اَحْسَنَ نَشْرَهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"How good is its first growth!"},{"kind":"text","text":"(TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a tree)"},{"kind":"italic_en","text":"put forth its leaves."},{"kind":"text","text":"(K.) ―         -b5-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(foliage)"},{"kind":"italic_en","text":"spread."},{"kind":"text","text":"(K.) ―         -b6-"},{"kind":"arabic","text_bw":"na$arati AlA^aroDu","text_ar":"نَشَرَتِ الاَرْضُ"},{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"nu$uwrN","text_ar":"نُشُورٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The land being rained upon in the end of summer, its herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasturage, became green after it had dried up:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"the land, being watered by the rain called"},{"kind":"arabic","text_bw":"Alr~abiyE","text_ar":"الرَّبِيع"},{"kind":"text","text":","},{"kind":"italic_en","text":"put forth its herbage."},{"kind":"text","text":"(A, K.) See"},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":".       -A4-"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":", (S, A, Msb,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"na$orN","text_ar":"نَشْرٌ"},{"kind":"text","text":", (K,) (tropical:)  ["},{"kind":"italic_en","text":"He sawed"},{"kind":"text","text":"wood;]"},{"kind":"italic_en","text":"he cut"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qaTaEa","text_ar":"قَطَعَ"},{"kind":"text","text":", S, or"},{"kind":"arabic","text_bw":"naHata","text_ar":"نَحَتَ"},{"kind":"text","text":", K) wood, (S, A, Msb, K,)"},{"kind":"italic_en","text":"with a"},{"kind":"arabic","text_bw":"mino$aAr","text_ar":"مِنْشَار"},{"kind":"text","text":". (S, A, Msb.)"}],"source_refs":["S","A","Msb","TA","K","L"]}]}}