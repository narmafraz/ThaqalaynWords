سْمُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْمُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":245,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n20811","n20819","n20820"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%85%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be high, lofty; to rise up, to tower"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20811","headword_ar":"سَمَا","root":"smw","body":[{"kind":"text","text":", (S, M, Msb, K,) first pers."},{"kind":"arabic","text_bw":"samawotu","text_ar":"سَمَوْتُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Ealawotu","text_ar":"عَلَوْتُ"},{"kind":"text","text":", (S,) aor."},{"kind":"arabic","text_bw":"yasomuw","text_ar":"يَسْمُو"},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"sumuw~N","text_ar":"سُمُوٌّ"},{"kind":"text","text":"; (S, M, K;) and"},{"kind":"arabic","text_bw":"samiYa","text_ar":"سَمِىَ"},{"kind":"text","text":", first pers."},{"kind":"arabic","text_bw":"samiytu","text_ar":"سَمِيتُ"},{"kind":"text","text":", (Th, S, TA,) like"},{"kind":"arabic","text_bw":"Ealiytu","text_ar":"عَلِيتُ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, Th, S,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, M,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high, lofty, raised, upraised, uplifted, upreared, exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated; it rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rose high:"},{"kind":"text","text":"(S, M, Msb, K:) and ↓"},{"kind":"arabic","text_bw":"tsAmY","text_ar":"تسامى","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (MA. [See also 5.]) ―         -b2-"},{"kind":"arabic","text_bw":"samaAliYa Al$~aYo'u","text_ar":"سَمَالِىَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing became raised from afar so that I plainly distinguished it:"},{"kind":"text","text":"(K:) or, as in the S,"},{"kind":"arabic","text_bw":"samaA liYa Al$~axoSu","text_ar":"سَمَا لِىَ الشَّخْصُ"},{"kind":"italic_en","text":"the form,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figure, seen from a distance, rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became raised, to me"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"to my view"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"so that I plainly distinguished it."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"samaA AlhilaAlu","text_ar":"سَمَا الهِلَالُ"},{"kind":"italic_en","text":"The moon near the change rose"},{"kind":"arabic","text_bw":"murotafiEFA","text_ar":"مُرْتَفِعًا"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"upreared, not decumbent:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^adofaqu","text_ar":"اَدْفَقُ"},{"kind":"text","text":"]. (TA.) ―         -b4-  ["},{"kind":"arabic","text_bw":"samaA lahu","text_ar":"سَمَا لَهُ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"naHowahu","text_ar":"نَحْوَهُ"},{"kind":"italic_en","text":"He rose, and betook himself, to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"Hence,]"},{"kind":"arabic","text_bw":"maAsamawotu lakumo","text_ar":"مَاسَمَوْتُ لَكُمْ"},{"kind":"italic_en","text":"I will not"},{"kind":"text","text":"[or (unless the phrase be an apodosis)"},{"kind":"italic_en","text":"I did not"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"rise and hasten to fight you."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"samaA baSarahu","text_ar":"سَمَا بَصَرَهُ"},{"kind":"italic_en","text":"His sight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eye, rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became raised."},{"kind":"text","text":"(S, TA.) [And"},{"kind":"arabic","text_bw":"samaATarofuhu","text_ar":"سَمَاطَرْفُهُ"},{"kind":"text","text":"lit. signifies the same; but means (assumed tropical:)"},{"kind":"italic_en","text":"His look was lofty;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was proud:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"saAmK","text_ar":"سَامٍ"},{"kind":"text","text":", below.] ―         -b6-"},{"kind":"arabic","text_bw":"samaA","text_ar":"سَمَا"},{"kind":"text","text":"is also said of him who is termed"},{"kind":"arabic","text_bw":"HasiybN","text_ar":"حَسِيبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ariyfN","text_ar":"شَرِيفٌ"},{"kind":"text","text":"[i. e. it signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, noble;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exalted, in rank"},{"kind":"text","text":"]. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"samatp him~atuhu A_ilaY maEaAliY AlA^umowri","text_ar":"سَمَتة هِمَّتُهُ اـِلَى مَعَالِى الاُمْورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His ambition soared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aspired, to high things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the means of attaining eminence;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he sought glory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"might, and eminence."},{"kind":"text","text":"(Msb, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"samaAbiY","text_ar":"سَمَابِى"},{"kind":"arabic","text_bw":"$awoqa baEoda A^ano kaAna A^aqoSara","text_ar":"شَوْقَ بَعْدَ اَنْ كَانَ اَقْصَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A yearning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"longing, of the soul arose in me after it had ceased"},{"kind":"text","text":"]. (TA.) ―         -b9-"},{"kind":"arabic","text_bw":"humo yasomuwna EalaY AlmiAy^api","text_ar":"هُمْ يَسْمُونَ عَلَى المِايَةِ"},{"kind":"italic_en","text":"They exceed"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"are above"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the number of a hundred."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"arabic","text_bw":"samawoA","text_ar":"سَمَوْا"},{"kind":"text","text":", (S, K, TA,) and ↓"},{"kind":"arabic","text_bw":"AstmwA","text_ar":"استموا","orth_type":"arrow"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"They went forth to pursue the animals of the chase"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"in their deserts:"},{"kind":"text","text":"(TA:) [or] one says of the hunter, or sportsman,"},{"kind":"arabic","text_bw":"yasomuw AlwaHo$a","text_ar":"يَسْمُو الوَحْشَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yasotamiyhaA","text_ar":"يَسْتَمِيهَا","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he sees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looks to see,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yataEay~anu","text_ar":"يَتَعَيَّنُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"the coming forth of the wild animals, and pursues them."},{"kind":"text","text":"(M. [See also 8 below.]) ―         -b11-"},{"kind":"arabic","text_bw":"samaA AlfaHolu","text_ar":"سَمَا الفَحْلُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"samaAwapN","text_ar":"سَمَاوَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The stallion sprang,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rushed, upon,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"he overbore,"},{"kind":"text","text":"(S, * M, K,)"},{"kind":"italic_en","text":"his she-camels that had passed seven or eight months since the period of their bringing forth."},{"kind":"text","text":"(S, M, K.)       -A2-"},{"kind":"arabic","text_bw":"samaAbihi","text_ar":"سَمَابِهِ"},{"kind":"text","text":": see 4.       -A3-  See also 2."}],"source_refs":["S","M","Msb","K","TA","Th"]},{"entry_id":"n20819","headword_ar":"سَمًا","root":"smw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"samaA='N","text_ar":"سَمَا=ءٌ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"AisomN","text_ar":"اِسْمٌ"},{"kind":"text","text":", near the beginning of the paragraph."}],"source_refs":[]},{"entry_id":"n20820","headword_ar":"سُمًا","root":"smw","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"simFA","text_ar":"سِمًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"AisomN","text_ar":"اِسْمٌ"},{"kind":"text","text":", in two places, near the beginning of the paragraph; and in the last sentence but one of the same."}],"source_refs":[]}]}}