n":"m","num":"p"},{"role":"present_2mp","form":"تَبْهَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْهَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْهَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْهَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْهَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَهَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَهَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْهَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْهَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n3413","n3414"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%87%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to allure, to blind, to seduce"},{"pos":"verb","gloss":"to dazzle"},{"pos":"verb","gloss":"to glimmer, to shine, to illuminate","examples":[{"text":"بَهَرَتِ ٱلشَّمْسُ ٱلْبِقَاعَ وَٱلسُّهُولَ","english":"The sun illuminated the places and the plains."}]},{"pos":"verb","gloss":"to add spices"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew בָּהִיר (bahír, “bright, light, clear”).\n\nVerbification of بَهَار (bahār, “spice”)"},"ipa":["/ba.ha.ra/","/bah.ha.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3413","headword_ar":"بَهْرٌ","root":"bhr","body":[{"kind":"text","text":"inf. n. of 1 [q. v.]. (S, Msb, K.) You say,"},{"kind":"arabic","text_bw":"bahorFA lahu","text_ar":"بَهْرًا لَهُ"},{"kind":"text","text":", an imprecation, meaning"},{"kind":"italic_en","text":"May he be overcome!"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"taEosFA lahu","text_ar":"تَعْسًا لَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"may he fall, having stumbled!"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stumble and fall!"},{"kind":"text","text":"&c.]: (AA, S, K:) and thus used [app. in the latter sense] as an imprecation, accord. to Sb, it has no verb, but is put in the accus. case on the supposition of a verb. (TA.) One says also, ↓"},{"kind":"arabic","text_bw":"quhorFA wabuhorFA","text_ar":"قُهْرًا وَبُهْرًا","orth_type":"arrow"},{"kind":"text","text":", with damm to each. (TA in art."},{"kind":"arabic","text_bw":"qhr","text_ar":"قهر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"bahorFA maA","text_ar":"بَهْرًا مَا"},{"kind":"arabic","text_bw":"A^asoxaAhu","text_ar":"اَسْخَاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May he fall, having stumbled!"},{"kind":"text","text":"&c.:"},{"kind":"italic_en","text":"how bountiful is he!"},{"kind":"text","text":"], like as one says"},{"kind":"arabic","text_bw":"taEosFA lahu","text_ar":"تَعْسًا لَهُ"},{"kind":"text","text":"[when not meaning it to be understood as an imprecation]. (A.) ―         -b2-  It also signifies"},{"kind":"italic_en","text":"Distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remoteness:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"remoteness from good"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"italic_en","text":"Disappointment."},{"kind":"text","text":"(IAar, TA.) ―         -b4-"},{"kind":"italic_en","text":"Wonder;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":". (K.) One says,"},{"kind":"arabic","text_bw":"bahorA","text_ar":"بَهْرا"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"EajabFA","text_ar":"عَجَبًا"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"A^aEojabu EajabFA","text_ar":"اَعْجَبُ عَجَبًا"},{"kind":"italic_en","text":"I do wonder:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wonderful!"},{"kind":"text","text":"]. (S.) So [sometimes] in the phrase"},{"kind":"arabic","text_bw":"bahorFA lahu","text_ar":"بَهْرًا لَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I do wonder at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (IAar, TA.) ―         -b5-"},{"kind":"italic_en","text":"Love."},{"kind":"text","text":"(K.) Accord. to some,"},{"kind":"arabic","text_bw":"bahorFA lakumo","text_ar":"بَهْرًا لَكُمْ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Love to you."},{"kind":"text","text":"(JK.) ―         -b6-"},{"kind":"arabic","text_bw":"AlA^azowaAju valAavapN zawoju","text_ar":"الاَزْوَاجُ ثَلاَثَةٌ زَوْجُ"},{"kind":"arabic","text_bw":"bahorK wazawoju dahorK wazawoju mahorK","text_ar":"بَهْرٍ وَزَوْجُ دَهْرٍ وَزَوْجُ مَهْرٍ"},{"kind":"text","text":"is a saying of the Arabs, meaning"},{"kind":"italic_en","text":"Husbands are three: a husband who overcomes the eyes by his goodliness,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"a husband of noble race, though he may be of little wealth;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"and a husband prepared for the accidents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calamities, of fortune; and a husband from whom a dowry is got,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"a husband who has not nobility of race, and who therefore doubles the dowry to make himself desired."},{"kind":"text","text":"(TA.)       -A2-  (assumed tropical:)"},{"kind":"italic_en","text":"Distress that affects the breath"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respiration,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"karobN","text_ar":"كَرْبٌ"},{"kind":"text","text":", (K, TA,) [particularly]"},{"kind":"italic_en","text":"of a camel when he is spurred on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a man when a labour above his power is imposed upon him."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","AA","S","K","TA"]},{"entry_id":"n3414","headword_ar":"بُهْرٌ","root":"bhr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bahorN","text_ar":"بَهْرٌ"},{"kind":"text","text":". ―         -b2-  Also (tropical:)  The"},{"kind":"italic_en","text":"state of being out of breath; interruption of the breath, by reason of fatigue,"},{"kind":"text","text":"(K, TA,) [or"},{"kind":"italic_en","text":"by bearing a heavy load,"},{"kind":"text","text":"(see 1,)] or"},{"kind":"italic_en","text":"by hard work,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"by running:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"a panting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breathing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shortly"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"uninterruptedly."},{"kind":"text","text":"(S, A, TA,)       -A2-"},{"kind":"italic_en","text":"Wide-spreading land; a wide tract of land;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"buhorapN","text_ar":"بُهْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"[q. v.]. (K.) ―         -b2-"},{"kind":"italic_en","text":"A country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a city,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"baladN","text_ar":"بَلَدٌ"},{"kind":"text","text":": (K:) or the"},{"kind":"italic_en","text":"middle thereof."},{"kind":"text","text":"(TA.) ―         -b3-  The"},{"kind":"italic_en","text":"middle,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"best part,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sir~","text_ar":"سِرّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"xayor","text_ar":"خَيْر"},{"kind":"text","text":", for the former of which words we find"},{"kind":"arabic","text_bw":"$ar~","text_ar":"شَرّ"},{"kind":"text","text":"erroneously put in the copies of the K, TA,)"},{"kind":"italic_en","text":"of a valley;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"buhorapu","text_ar":"بُهْرَةُ","orth_type":"arrow"},{"kind":"text","text":"[q. v.]. (K, TA.)"},{"kind":"page_break","n":266}],"source_refs":["K","TA","S","A"]}]},"classical_definitions":null}