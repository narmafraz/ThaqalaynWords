{"lemma":"فَطِن","slug":"فَطِن","root":"ف.ط.ن","root_slug":"ف-ط-ن","root_link":"/words/roots/ف-ط-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n34170","n34174","n34175","n34176"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B7%D9%90%D9%86"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to understand, to be apprehend, to be aware of, to remember"},{"pos":"verb","gloss":"to be smart, to be intelligent"},{"pos":"verb","gloss":"to make realize, to remind of, to secrete"},{"pos":"noun","gloss":"verbal noun of فَطَنَ (faṭana) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"intelligence, comprehension"},{"pos":"adj","gloss":"intelligent, sagacious"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34170","headword_ar":"فَطِنَ","root":"fTn","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"fiTonapN","text_ar":"فِطْنَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faTaAnapN","text_ar":"فَطَانَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faTaAniyapN","text_ar":"فَطَانِيَةٌ"},{"kind":"text","text":"[&c. as in the next sentence,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, intelligent, understanding, knowing, sagacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful:"},{"kind":"text","text":"see the explanations of"},{"kind":"arabic","text_bw":"fiTonapN","text_ar":"فِطْنَةٌ"},{"kind":"text","text":"below]; (S;) and"},{"kind":"arabic","text_bw":"faTuna","text_ar":"فَطُنَ"},{"kind":"text","text":"signifies [the same, i. e.]"},{"kind":"italic_en","text":"he became such as is termed"},{"kind":"arabic","text_bw":"faTin","text_ar":"فَطِن"},{"kind":"text","text":". (Lth, TA.) You say,"},{"kind":"arabic","text_bw":"faTina lahu","text_ar":"فَطِنَ لَهُ"},{"kind":"text","text":", (Msb, K,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"faTana","text_ar":"فَطَنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"faTuna","text_ar":"فَطُنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n."},{"kind":"arabic","text_bw":"faTonN","text_ar":"فَطْنٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"faTonN","text_ar":"فَطْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuTonN","text_ar":"فُطْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faTanN","text_ar":"فَطَنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuTunN","text_ar":"فُطُنٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"fiTonapN","text_ar":"فِطْنَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiTaAnN","text_ar":"فِطَانٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"fuTuwnapN","text_ar":"فُطُونَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faTaAnapN","text_ar":"فَطَانَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faTaAniyapN","text_ar":"فَطَانِيَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"intelligent, understanding, knowing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sagacious, respecting it;"},{"kind":"text","text":"(agreeably with explanations above;) or]"},{"kind":"italic_en","text":"skilled of it,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"skilful in it;"},{"kind":"text","text":"(K;) namely, an affair: (Msb:) [and"},{"kind":"italic_en","text":"he understood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knew,"},{"kind":"text","text":"it; often used in this sense:] and sometimes they said"},{"kind":"arabic","text_bw":"faTanahu","text_ar":"فَطَنَهُ"},{"kind":"text","text":", making the verb trans. by itself, because it implies the meaning of"},{"kind":"arabic","text_bw":"fahima","text_ar":"فَهِمَ"},{"kind":"text","text":"; (TA;) or"},{"kind":"arabic","text_bw":"faTanotu Al$~aYo'i","text_ar":"فَطَنْتُ الشَّىْءِ"},{"kind":"text","text":", with fet-h, signifies"},{"kind":"italic_en","text":"I understood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knew, the thing:"},{"kind":"text","text":"(S:) and some say that"},{"kind":"arabic","text_bw":"faTaAnapN","text_ar":"فَطَانَةٌ"},{"kind":"text","text":"[as inf. n., agreeably with analogy, of"},{"kind":"arabic","text_bw":"faTuna","text_ar":"فَطُنَ"},{"kind":"text","text":", which see in what follows,] signifies [the"},{"kind":"italic_en","text":"possessing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"excellence in respect of readiness of intelligence for the perception of what comes to one from another."},{"kind":"text","text":"(TA.) ["},{"kind":"arabic","text_bw":"faTana lahu","text_ar":"فَطَنَ لَهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He took notice of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paid attention to, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"see Har p. 626, and Ham p. 695.] And"},{"kind":"arabic","text_bw":"faTuna","text_ar":"فَطُنَ"},{"kind":"text","text":"signifies [also]"},{"kind":"italic_en","text":"He became one of whom"},{"kind":"arabic","text_bw":"fiTonap","text_ar":"فِطْنَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"intelligence,"},{"kind":"text","text":"&c., as expl. below,]"},{"kind":"italic_en","text":"was a"},{"kind":"arabic","text_bw":"sajiy~ap","text_ar":"سَجِيَّة"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"faculty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality, firmly rooted in the mind"},{"kind":"text","text":"]. (Msb.)"}],"source_refs":["Msb","K","S"]},{"entry_id":"n34174","headword_ar":"فَطْنٌ","root":"fTn","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n34175","headword_ar":"فَطُنٌ","root":"fTn","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n34176","headword_ar":"فَطِنٌ","root":"fTn","body":[{"kind":"text","text":"(S, Msb, K, KL) and ↓"},{"kind":"arabic","text_bw":"faTunN","text_ar":"فَطُنٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K, KL) and ↓"},{"kind":"arabic","text_bw":"faTonN","text_ar":"فَطْنٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"faTiynN","text_ar":"فَطِينٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"faTuwnN","text_ar":"فَطُونٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"faATinN","text_ar":"فَاطِنٌ","orth_type":"arrow"},{"kind":"text","text":"(K) are epithets (S, K, TA) applied to a man, (S, TA,) signifying"},{"kind":"italic_en","text":"Intelligent, understanding, knowing, sagacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful;"},{"kind":"text","text":"(S, * K, * KL;) the first expl. by Lth as signifying"},{"kind":"italic_en","text":"possessing"},{"kind":"arabic","text_bw":"fiTonap","text_ar":"فِطْنَة"},{"kind":"italic_en","text":"respecting things:"},{"kind":"text","text":"(TA:) and it signifies one"},{"kind":"italic_en","text":"of whom"},{"kind":"arabic","text_bw":"fiTonap","text_ar":"فِطْنَة"},{"kind":"italic_en","text":"has become a"},{"kind":"arabic","text_bw":"sajiy~ap","text_ar":"سَجِيَّة"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"faculty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality, firmly rooted in the mind"},{"kind":"text","text":"]: (Msb:) the pl. [of this] is"},{"kind":"arabic","text_bw":"fuTonN","text_ar":"فُطْنٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"fuzunN","text_ar":"فُزُنٌ"},{"kind":"text","text":", with two dammehs, (Msb,) or both: (TA:) and the fem. is"},{"kind":"arabic","text_bw":"faTinapN","text_ar":"فَطِنَةٌ"},{"kind":"text","text":". (K.)"},{"kind":"arabic","text_bw":"faTinN bixuSuwmatihi","text_ar":"فَطِنٌ بِخُصُومَتِهِ"},{"kind":"text","text":"means A man"},{"kind":"italic_en","text":"knowing in the various modes of his disputation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"skilful therein."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","Msb","K","KL","TA"]}]}}