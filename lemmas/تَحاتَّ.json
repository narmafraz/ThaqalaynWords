nd":"italic_en","text":"fell"},{"kind":"text","text":"(K) from the branch &c.: or"},{"kind":"italic_en","text":"fell successively, one after another."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"tHAt~t Al$~ajarapu","text_ar":"تحاتّت الشَّجَرَةُ"},{"kind":"italic_en","text":"The tree shed its leaves, one after another."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"$aEaruhu Eano raA^osihi","text_ar":"شَعَرُهُ عَنْ رَاْسِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnHt","text_ar":"انحت","orth_type":"arrow"},{"kind":"italic_en","text":"His hair fell off from his head."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"tHAt~t A^asonaAnuhu","text_ar":"تحاتّت اَسْنَانُهُ"},{"kind":"italic_en","text":"His teeth fell out, one after another."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"tHAt~t *unuwbuhu","text_ar":"تحاتّت ذُنُوبُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His sins fell from him."},{"kind":"text","text":"(TA, from a trad.)"}],"source_refs":["K","A","TA"]}]},"classical_definitions":null}