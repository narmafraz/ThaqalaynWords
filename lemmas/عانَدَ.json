n":"m","num":"p"},{"role":"present_2mp","form":"تُعانِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعانِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعانِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعانِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعانِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعانِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعانِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعانِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعانِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعانِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعانِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"عانَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عانَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعانِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعانِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n30722","n30736"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%86%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30722","headword_ar":"عاند","root":"End","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EinaAdN","text_ar":"عِنَادٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"muEaAnadapN","text_ar":"مُعَانَدَةٌ"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"He acted with opposition, disobedience,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellion."},{"kind":"text","text":"(Msb.) ―         -b2-  See also 1.       -A2-"},{"kind":"arabic","text_bw":"EAndhu","text_ar":"عاندهُ"},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"muEaAnadapN","text_ar":"مُعَانَدَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He separated himself from him;"},{"kind":"text","text":"(L, * K;)"},{"kind":"italic_en","text":"he went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retired, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a place apart, from him."},{"kind":"text","text":"(L, K. [See also 1, first and second sentences.]) ―         -b2-  And"},{"kind":"arabic","text_bw":"EAndhu","text_ar":"عاندهُ"},{"kind":"text","text":", (T, S, O, L, Msb,) inf. n."},{"kind":"arabic","text_bw":"muEaAnadapN","text_ar":"مُعَانَدَةٌ"},{"kind":"text","text":"(T, S, L, Msb, K) and"},{"kind":"arabic","text_bw":"EinaAdN","text_ar":"عِنَادٌ"},{"kind":"text","text":", (T, S, L, K,)"},{"kind":"italic_en","text":"He opposed him, disagreeing with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doing the contrary of what he"},{"kind":"text","text":"(the other)"},{"kind":"italic_en","text":"did;"},{"kind":"text","text":"(T, S, O, L, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AEndhu","text_ar":"اعندهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, L, K;) syn."},{"kind":"arabic","text_bw":"EaAraDahu","text_ar":"عَارَضَهُ"},{"kind":"text","text":"; (S, O, Msb, all in explanation of the former; [but it should be observed that"},{"kind":"arabic","text_bw":"EArDh","text_ar":"عارضه"},{"kind":"text","text":"bears the signification expressed above and also that given in the sentence next following;]) or"},{"kind":"arabic","text_bw":"EaAraDahu biAlxilaAfi","text_ar":"عَارَضَهُ بِالخِلَافِ"},{"kind":"text","text":"; (O in explanation of the latter, and Msb in explanation of the former, as on the authority of Az [in the T], and K in explanation of both;) or"},{"kind":"arabic","text_bw":"xaAlafahu","text_ar":"خَالَفَهُ"},{"kind":"text","text":": (MA in explanation of the former:) [this is the sense in which the former is most commonly known: or as meaning"},{"kind":"italic_en","text":"he contended with him in an altercation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did so vehemently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstinately:"},{"kind":"text","text":"(see 6:)] the author of the T, however, says, the common people expl."},{"kind":"arabic","text_bw":"yuEaAniduhu","text_ar":"يُعَانِدُهُ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"he does the contrary of what he"},{"kind":"text","text":"[another]"},{"kind":"italic_en","text":"does;"},{"kind":"text","text":"but this I know not [as occurring in the genuine language of the Arabs], nor do I admit it as of established authority. (TA.) ―         -b3-  And, sometimes,"},{"kind":"italic_en","text":"He imitated him, doing the like of what he"},{"kind":"text","text":"(the other)"},{"kind":"italic_en","text":"did;"},{"kind":"text","text":"(T, L, Msb;) [and] so ↓"},{"kind":"arabic","text_bw":"AEndhu","text_ar":"اعندهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, L, K;) thus having two contr. significations; (K;) syn."},{"kind":"arabic","text_bw":"EaAraDahu","text_ar":"عَارَضَهُ"},{"kind":"text","text":"[respecting which see the sentence next preceding]; (S, O, Msb, all in explanation of the former;) or"},{"kind":"arabic","text_bw":"EaAraDahu","text_ar":"عَارَضَهُ"},{"kind":"arabic","text_bw":"biAliwfaAqi","text_ar":"بِالِوفَاقِ"},{"kind":"text","text":"; (O and K in explanation of the latter;) and"},{"kind":"arabic","text_bw":"baAraAhu","text_ar":"بَارَاهُ"},{"kind":"text","text":"; (T and TA in explanation of the former;)"},{"kind":"arabic","text_bw":"EinaAdN","text_ar":"عِنَادٌ"},{"kind":"text","text":"sometimes signifying"},{"kind":"arabic","text_bw":"muEaAraDapN bigayori","text_ar":"مُعَارَضَةٌ بِغَيْرِ"},{"kind":"arabic","text_bw":"xilaAfK","text_ar":"خِلَافٍ"},{"kind":"text","text":", as is said by As, who derives it from"},{"kind":"arabic","text_bw":"Eanadu","text_ar":"عَنَدُ"},{"kind":"arabic","text_bw":"AlHubaAraY","text_ar":"الحُبَارَى"},{"kind":"text","text":", making"},{"kind":"arabic","text_bw":"Eanad","text_ar":"عَنَد"},{"kind":"text","text":"in this phrase a subst. from"},{"kind":"arabic","text_bw":"EAnd AlHubaAraY faroxahu","text_ar":"عاند الحُبَارَى فَرْخَهُ"},{"kind":"italic_en","text":"The bustard imitated the actions of his young one in flying,"},{"kind":"text","text":"on the first occasion of its rising, as though he would teach it to fly: and"},{"kind":"arabic","text_bw":"EAnd AlbaEiyru xiTaAmahu","text_ar":"عاند البَعِيرُ خِطَامَهُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The camel conformed to"},{"kind":"text","text":"[and perhaps it may also mean"},{"kind":"italic_en","text":"resisted"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the motion of his halter."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"EAndhu","text_ar":"عاندهُ"},{"kind":"text","text":", (O,) inf. n."},{"kind":"arabic","text_bw":"muEaAnadapN","text_ar":"مُعَانَدَةٌ"},{"kind":"text","text":", (K,) also signifies"},{"kind":"italic_en","text":"He kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clave, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(O, K:) the contr. of the first signification assigned to it above. (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"muEaAnadapN","text_ar":"مُعَانَدَةٌ"},{"kind":"text","text":"means also The"},{"kind":"italic_en","text":"disputing with another without knowledge of the truth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falsity of what he himself says and also of what his opponent says."},{"kind":"text","text":"(Kull p. 342.)"}],"source_refs":["L","K","T","S","O","Msb"]},{"entry_id":"n30736","headword_ar":"عَانِدٌ","root":"End","body":[{"kind":"text","text":"A camel"},{"kind":"italic_en","text":"that deviates from the road,"},{"kind":"text","text":"(S, O, L, K,)"},{"kind":"italic_en","text":"and from the right course;"},{"kind":"text","text":"(S, O, L;) as also ↓"},{"kind":"arabic","text_bw":"EanuwdN","text_ar":"عَنُودٌ","orth_type":"arrow"},{"kind":"text","text":": (O:) pl. of the former"},{"kind":"arabic","text_bw":"Eun~adN","text_ar":"عُنَّدٌ"},{"kind":"text","text":". (S, O, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"EanuwdN","text_ar":"عَنُودٌ"},{"kind":"text","text":", in two places. ―         -b3-  And see"},{"kind":"arabic","text_bw":"EaniydN","text_ar":"عَنِيدٌ"},{"kind":"text","text":", likewise in two places. ―         -b4-  Also (assumed tropical:)  Blood"},{"kind":"italic_en","text":"flowing on one side."},{"kind":"text","text":"(L.) ―         -b5-  And (tropical:)  A vein"},{"kind":"italic_en","text":"flowing with blood, and not ceasing to flow:"},{"kind":"text","text":"(S, Mgh, O, L:) or"},{"kind":"italic_en","text":"flowing, and hardly ceasing:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"flowing copiously:"},{"kind":"text","text":"(Msb:) likened to a man who exceeds the proper bound or limit, or acts exorbitantly; (A'Obeyd, L;) or to one who disallows, or rejects, what is true, or just, knowing it to be so. (Mgh.) ―         -b6-  And"},{"kind":"arabic","text_bw":"TaEonapN EaAnidapN","text_ar":"طَعْنَةٌ عَانِدَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A spear-wound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stab, pouring forth blood to a distance:"},{"kind":"text","text":"(L:) [or"},{"kind":"arabic","text_bw":"TaEonN EaAnidN","text_ar":"طَعْنٌ عَانِدٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"lightest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slightest, piercing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thrusting;"},{"kind":"text","text":"for] AA says that the lightest, or slightest, piercing or thrusting ("},{"kind":"arabic","text_bw":"A^axaf~u AlT~aEoni","text_ar":"اَخَفُّ الطَّعْنِ"},{"kind":"text","text":") is termed"},{"kind":"arabic","text_bw":"Alwaloqu","text_ar":"الوَلْقُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlEaAnidu","text_ar":"العَانِدُ"},{"kind":"text","text":"signifies the like thereof. (S, O.)"}],"source_refs":["S","O","L","K","Mgh","Msb"]}]},"classical_definitions":null}