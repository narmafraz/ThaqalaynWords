8E%D8%B1%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of غَرَّ (ḡarra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"risk, chance, danger"},{"pos":"noun","gloss":"plural of غُرَّة (ḡurra)","tags":["form-of","plural"]}]},"etymology":null,"ipa":["/ɣa.rar/","/ɣu.rar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31590","headword_ar":"غَرَرٌ","root":"gr","body":[{"kind":"italic_en","text":"Peril; danger; jeopardy; hazard;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"risk."},{"kind":"text","text":"(S, Mgh, Msb, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"nahaY Eano bayoEi Algarari","text_ar":"نَهَى عَنْ بَيْعِ الغَرَرِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(Mohammad)"},{"kind":"italic_en","text":"forbade the sale of hazard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"risk;"},{"kind":"text","text":"(S, Mgh, Msb;)"},{"kind":"italic_en","text":"of which it is unknown whether the thing will be"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"such as the sale of fish in the water, and of birds in the air:"},{"kind":"text","text":"(S, Mgh:) or, accord. to 'Alee,"},{"kind":"italic_en","text":"in which one is not secure from being deceived:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"of which the outward semblance deceives the buyer, and the intrinsic reality is unknown:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"that is without any written statement"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Euhodap","text_ar":"عُهْدَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and without confidence."},{"kind":"text","text":"(As, Mgh.) ―         -b2-"},{"kind":"arabic","text_bw":"HabolN gararN","text_ar":"حَبْلٌ غَرَرٌ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"gayoru mawovuwqK bihi","text_ar":"غَيْرُ مَوْثُوقٍ بِهِ"},{"kind":"text","text":"[i. e., app.,"},{"kind":"italic_en","text":"A bond,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact, in which trust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confidence, is not placed"},{"kind":"text","text":"]. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"gariyrN","text_ar":"غَرِيرٌ"},{"kind":"text","text":"."}],"source_refs":["S","Mgh","TA"]}]},"classical_definitions":null}