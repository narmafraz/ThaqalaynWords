n":"m","num":"p"},{"role":"present_2mp","form":"تَكْبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكْبِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكْبِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكْبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكْبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكْبِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكْبِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكْبِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْبِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْبِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"كَبَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"كَبَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَكْبِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَكْبِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n36595"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D8%A8%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of كَبَسَ (kabasa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"pressure, squeeze, pressing"},{"pos":"noun","gloss":"raid, attack"},{"pos":"noun","gloss":"pickling, preservation (in vinegar, etc.)"},{"pos":"noun","gloss":"intercalation"},{"pos":"verb","gloss":"to press, to exert pressure, to squeeze"},{"pos":"verb","gloss":"to attack, to raid"},{"pos":"verb","gloss":"to intercalate"},{"pos":"verb","gloss":"to pickle, to preserve (in vinegar, etc.)"},{"pos":"verb","gloss":"to marinate"},{"pos":"verb","gloss":"to conserve"},{"pos":"verb","gloss":"to press hard, to squeeze hard"},{"pos":"verb","gloss":"to massage"},{"pos":"noun","gloss":"earth, sludge, especially one which one presses into watercourses to control them or which divides ditches or another pressed construction"}]},"etymology":{"source":"wiktextract","text":"The “intercalation” meaning is a semantic loan from Classical Syriac ܟܒܰܫ (kḇaš) – the etymologically corresponding verb in Syriac – and its derivatives."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36595","headword_ar":"كَبَسَ","root":"kbs","body":[{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"kabosN","text_ar":"كَبْسٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He filled up with earth"},{"kind":"text","text":"a well, (S, A, K,) and a river, (A, Mgh, K,) and a hollow, or cavity, or pit, dug in the ground. (A, Mgh.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He covered over,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread, with earth, and made even,"},{"kind":"text","text":"a piece of ground: and in like manner, the roof of a house, before plastering it with mud or clay. (Mgh.) ―         -b3-  [And"},{"kind":"italic_en","text":"He spread"},{"kind":"text","text":"earth upon a roof &c. (See"},{"kind":"arabic","text_bw":"dak~a","text_ar":"دَكَّ"},{"kind":"text","text":".)]       -A2-  Also, aor. and inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He pressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"squeezed,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"kneaded,"},{"kind":"text","text":"] a limb with the hand: (TA, art."},{"kind":"arabic","text_bw":"gmz","text_ar":"غمز"},{"kind":"text","text":":) and ↓"},{"kind":"arabic","text_bw":"kb~s","text_ar":"كبّس","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takobiysN","text_ar":"تَكْبِيسٌ"},{"kind":"text","text":", [signifies the same, accord. to present usage: and] (tropical:)"},{"kind":"italic_en","text":"he suppled"},{"kind":"text","text":"the body ["},{"kind":"italic_en","text":"by kneading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"squeezing"},{"kind":"text","text":"it, as is done in the bath,]"},{"kind":"italic_en","text":"with the hands."},{"kind":"text","text":"(TA, in the present art.) ―         -b2-  And, aor. as above, (tropical:)"},{"kind":"italic_en","text":"Inivit unâ vice"},{"kind":"text","text":"feminam. (K.)       -A3-"},{"kind":"arabic","text_bw":"kabasuwA daAra fulaAnK","text_ar":"كَبَسُوا دَارَ فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They made a sudden attack upon the house of such a one,"},{"kind":"text","text":"(S, IKtt, * K,)"},{"kind":"italic_en","text":"and surrounded it."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"kabasuwA Ealayohimo","text_ar":"كَبَسُوا عَلَيْهِمْ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"kb~swA","text_ar":"كبّسوا","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"They threw themselves upon them suddenly and without consideration."},{"kind":"text","text":"(A.) And in like manner,"},{"kind":"arabic","text_bw":"EalaY Al$~aYo'i","text_ar":"عَلَى الشَّىْءِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kb~swA","text_ar":"كبّسوا","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tk~bswA","text_ar":"تكّبسوا","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"They threw themselves upon the thing suddenly and without consideration."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"kabasa raA^osahu","text_ar":"كَبَسَ رَاْسَهُ"},{"kind":"text","text":", [aor. as above,]"},{"kind":"italic_en","text":"He put his head within his garments:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"kabasa raA^osahu fiY vawobihi","text_ar":"كَبَسَ رَاْسَهُ فِى ثَوْبِهِ"},{"kind":"italic_en","text":"he hid his head in his garment, and put it within it:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he put it on in the manner of a"},{"kind":"arabic","text_bw":"qinaAE","text_ar":"قِنَاع"},{"kind":"text","text":", ("},{"kind":"arabic","text_bw":"taqan~aEa","text_ar":"تَقَنَّعَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and then covered himself with part of it."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"kabasa raA^osahu fiY","text_ar":"كَبَسَ رَاْسَهُ فِى"},{"kind":"arabic","text_bw":"jayobi qamiySihi","text_ar":"جَيْبِ قَمِيصِهِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"biraA^osihi","text_ar":"بِرَاْسِهِ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He put his head within the opening at the neck and bosom of his shirt;"},{"kind":"text","text":"(A;) and so ↓"},{"kind":"arabic","text_bw":"tkb~s","text_ar":"تكبّس","orth_type":"arrow"},{"kind":"text","text":"alone. (TA.) And"},{"kind":"arabic","text_bw":"yakobisu Alr~ajulu vawobahu fiY raA^osihi","text_ar":"يَكْبِسُ الرَّجُلُ ثَوْبَهُ فِى رَاْسِهِ"},{"kind":"text","text":"[app. meaning,"},{"kind":"italic_en","text":"The man puts his garment as a covering over his head."},{"kind":"text","text":"] (Sh, TA.)"}],"source_refs":["S","A","K","Mgh","TA"]}]},"classical_definitions":null}