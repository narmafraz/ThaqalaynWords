":"text","text":"or"},{"kind":"italic_en","text":"have trusted to their Lord:"},{"kind":"text","text":"(A, * TA:) for the Arabs put"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"li","text_ar":"لِ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K","TA","L"]}]},"classical_definitions":null}