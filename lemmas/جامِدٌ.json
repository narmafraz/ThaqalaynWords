_en", "text": "unimproving, state"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "condition"}, {"kind": "text", "text": "]. (S, L.) ―         -b8-  And to the eye: you say"}, {"kind": "arabic", "text_bw": "EayonN jaAmidapN", "text_ar": "عَيْنٌ جَامِدَةٌ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "An eye that sheds no tears;"}, {"kind": "text", "text": "(Ks, K;) as also ↓"}, {"kind": "arabic", "text_bw": "jumaAdaY", "text_ar": "جُمَادَى", "orth_type": "arrow"}, {"kind": "text", "text": ", (Ks, K,) and ↓"}, {"kind": "arabic", "text_bw": "jamuwdN", "text_ar": "جَمُودٌ", "orth_type": "arrow"}, {"kind": "text", "text": "; (S, K;) or this last signifies (tropical:)  an eye"}, {"kind": "italic_en", "text": "that sheds few tears."}, {"kind": "text", "text": "(A.) And"}, {"kind": "arabic", "text_bw": "rajulN", "text_ar": "رَجُلٌ"}, {"kind": "arabic", "text_bw": "jaAmidu AlEayoni", "text_ar": "جَامِدُ العَيْنِ"}, {"kind": "text", "text": ", (A, K,) and"}, {"kind": "arabic", "text_bw": "AlEyn", "text_ar": "العين"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "jamiydu", "text_ar": "جَمِيدُ", "orth_type": "arrow"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "AlEyn", "text_ar": "العين"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "jamaAdu", "text_ar": "جَمَادُ", "orth_type": "arrow"}, {"kind": "text", "text": ", (A,) (tropical:)"}, {"kind": "italic_en", "text": "A man whose eye sheds few tears;"}, {"kind": "text", "text": "(A;) or"}, {"kind": "italic_en", "text": "whose eye sheds no tears."}, {"kind": "text", "text": "(K.) ―         -b9-  See also"}, {"kind": "arabic", "text_bw": "jamaAdN", "text_ar": "جَمَادٌ"}, {"kind": "text", "text": ". ―         -b10-  Also, (L,) and ↓"}, {"kind": "arabic", "text_bw": "mujomidN", "text_ar": "مُجْمِدٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (M, A, K,) and"}, {"kind": "arabic", "text_bw": "Alkaf~i", "text_ar": "الكَفِّ