d that is elevated so as to be like a small"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hill of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"text","text":". (K.)       -A3-  The"},{"kind":"italic_en","text":"envelope"},{"kind":"text","text":"of fruit; (K;) [or of the spadix of a palm-tree;] like"},{"kind":"arabic","text_bw":"juf~N","text_ar":"جُفٌّ"},{"kind":"text","text":"; the"},{"kind":"arabic","text_bw":"v","text_ar":"ث"},{"kind":"text","text":"being a substitute for"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":". (TA.)"}],"source_refs":["TA"]}]},"classical_definitions":null}