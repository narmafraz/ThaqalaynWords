,"text_ar":"دَمَىٌ"},{"kind":"text","text":",]) said of a thing, (S,) or of a wound, (Msb,) and"},{"kind":"arabic","text_bw":"damiyato","text_ar":"دَمِيَتْ"},{"kind":"text","text":"said of the arm or hand, (T,)"},{"kind":"italic_en","text":"It bled; blood issued from it:"},{"kind":"text","text":"(Msb:) [and]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bloody;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"smeared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defiled, with blood."},{"kind":"text","text":"(MA.)"}],"source_refs":["T","S","M","MA","Msb","K"]},{"entry_id":"n13166","headword_ar":"دَمِىٌّ","root":"(dmw or dmY)","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to, blood;"},{"kind":"text","text":"] rel. n. from"},{"kind":"arabic","text_bw":"damN","text_ar":"دَمٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"damawiY~N","text_ar":"دَمَوِىٌّ","orth_type":"arrow"},{"kind":"text","text":". (S.) ―         -b2-  [In the phrase"},{"kind":"arabic","text_bw":"x* mA dm~Y","text_ar":"خذ ما دمّى"},{"kind":"text","text":", in Freytag's Lex.,"},{"kind":"arabic","text_bw":"dmY~","text_ar":"دمىّ"},{"kind":"text","text":"is a mistake for"},{"kind":"arabic","text_bw":"dam~aY","text_ar":"دَمَّى"},{"kind":"text","text":": see 2, last sentence.]"}],"source_refs":[]},{"entry_id":"n13167","headword_ar":"دُمَىٌّ","root":"(dmw or dmY)","body":[{"kind":"text","text":"dim. of"},{"kind":"arabic","text_bw":"damN","text_ar":"دَمٌ"},{"kind":"text","text":", q. v. (S.)"}],"source_refs":[]}]}}