,"text_bw":"SaAfaHahu biyadihi","text_ar":"صَافَحَهُ بِيَدِهِ"},{"kind":"italic_en","text":"He took him by his hand."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"SaAfaHotuhu","text_ar":"صَافَحْتُهُ"},{"kind":"text","text":", inf. n. as above [and"},{"kind":"arabic","text_bw":"SifaAHN","text_ar":"صِفَاحٌ"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"I applied my hand to his hand;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"I put the palm of my hand upon the palm of his hand."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"laqiyahu SifaAHFA","text_ar":"لَقِيَهُ صِفَاحًا"},{"kind":"italic_en","text":"He met him turning towards him the"},{"kind":"arabic","text_bw":"SafoH","text_ar":"صَفْح"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his face:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he met him face to face; i. q."},{"kind":"arabic","text_bw":"SiqaAbFA","text_ar":"صِقَابًا"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"Sqb","text_ar":"صقب"},{"kind":"text","text":":) [and]"},{"kind":"italic_en","text":"he met him suddenly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unexpectedly."},{"kind":"text","text":"(Ham p. 802.)"}],"source_refs":["TA"]}]},"classical_definitions":null}