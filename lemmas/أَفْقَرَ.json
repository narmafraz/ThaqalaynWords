rb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n34292","n34312"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D9%82%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34292","headword_ar":"افقر","root":"fqr","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a colt)"},{"kind":"italic_en","text":"became fit for riding upon his"},{"kind":"arabic","text_bw":"faqaAr","text_ar":"فَقَار"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vertebræ"},{"kind":"text","text":"]; like"},{"kind":"arabic","text_bw":"A^arokaba","text_ar":"اَرْكَبَ"},{"kind":"text","text":": (O:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a colt, Msb), or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the back of a colt, L),"},{"kind":"italic_en","text":"became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"strong in the vertebræ and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"fit for being ridden."},{"kind":"text","text":"(L, Msb.)       -A2-"},{"kind":"arabic","text_bw":"Afqrhu naAqatahu","text_ar":"افقرهُ نَاقَتَهُ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"baEiyrahu","text_ar":"بَعِيرَهُ"},{"kind":"text","text":", (ISk, K,) or"},{"kind":"arabic","text_bw":"Zahora baEiyrihi","text_ar":"ظَهْرَ بَعِيرِهِ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"baEiyrFA","text_ar":"بَعِيرًا"},{"kind":"text","text":", (Mgh,) or"},{"kind":"arabic","text_bw":"daAb~atahu","text_ar":"دَابَّتَهُ"},{"kind":"text","text":", (A 'Obeyd, TA,) or"},{"kind":"arabic","text_bw":"Almuhora","text_ar":"المُهْرَ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He lent him the vertebræ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"the back"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his she-camel, that he might ride thereon:"},{"kind":"text","text":"(S, O:) and"},{"kind":"italic_en","text":"he lent him the back of his camel"},{"kind":"text","text":"(ISk, K, TA)"},{"kind":"italic_en","text":"during a journey,"},{"kind":"text","text":"(ISk, TA)"},{"kind":"italic_en","text":"for carrying a burden,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"for riding,"},{"kind":"text","text":"(ISk, K, TA,)"},{"kind":"italic_en","text":"to be returned afterwards:"},{"kind":"text","text":"(ISk, TA:) and"},{"kind":"italic_en","text":"he lent him a camel, that he might ride thereon;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"faqaAr","text_ar":"فَقَار"},{"kind":"text","text":"signifying the “ vertebræ ” of the back: (Mgh:) and"},{"kind":"italic_en","text":"he lent him his beast to ride as long as he pleased during a journey and then to return it to him:"},{"kind":"text","text":"(A 'Obeyd, TA:) and"},{"kind":"italic_en","text":"he lent him the colt to ride upon its vertebræ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"back"},{"kind":"text","text":"]. (Msb.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"Afqrhu A^aroDahu","text_ar":"افقرهُ اَرْضَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He lent him his land for sowing."},{"kind":"text","text":"(TA, from a trad.) ―         -b3-"},{"kind":"arabic","text_bw":"A^afoqaraka AlS~ayodu","text_ar":"اَفْقَرَكَ الصَّيْدُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The object of the chase has enabled thee to have its vertebræ within thy power;"},{"kind":"text","text":"therefore shoot it, or shoot at it: (O, TA:) or"},{"kind":"italic_en","text":"has enabled thee to have its side"},{"kind":"text","text":"[which is sometimes termed"},{"kind":"arabic","text_bw":"fuqor","text_ar":"فُقْر"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"within thy power:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"has become near to thee."},{"kind":"text","text":"(TA.) [The Khaleefeh] El-Weleed the son of Yezeed the son of 'AbdEl-Melik is related to have said,"},{"kind":"arabic","text_bw":"A^afoqara baEoda masolamapa","text_ar":"اَفْقَرَ بَعْدَ مَسْلَمَةَ"},{"kind":"arabic","text_bw":"AlS~ayodu limano ramaY","text_ar":"الصَّيْدُ لِمَنْ رَمَى"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"The object of the chase has enabled the shooter at it to have its vertebræ within his power after Meslemeh;"},{"kind":"text","text":"meaning that, since the death of his paternal uncle Meslemeh, the territory of the Muslims had become assailable to him who might attempt it. (TA.)       -A3-"},{"kind":"arabic","text_bw":"Afqrhu","text_ar":"افقرهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(i. e. God, S, O, K, or a man, Msb)"},{"kind":"italic_en","text":"rendered him"},{"kind":"arabic","text_bw":"faqiyr","text_ar":"فَقِير"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"poor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needy,"},{"kind":"text","text":"&c.]. (S, O, Msb, K.)       -A4-"},{"kind":"arabic","text_bw":"maA A^afoqarahu","text_ar":"مَا اَفْقَرَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"How poor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needy,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"is he!"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"maA A^agonaAhu","text_ar":"مَا اَغْنَاهُ"},{"kind":"text","text":"[which has the contr. meaning] are [said to be] anomalous; for their [respective primitive] verbs are"},{"kind":"arabic","text_bw":"Aifotaqara","text_ar":"اِفْتَقَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AisotagonaY","text_ar":"اِسْتَغْنَى"},{"kind":"text","text":", from either of which the verb of wonder is not properly [or regularly] formed. (S, O. [But see 8.])"}],"source_refs":["O","S","ISk","K","TA","Mgh","Msb"]},{"entry_id":"n34312","headword_ar":"اَفْقَرُ","root":"fqr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, poor"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needy"},{"kind":"text","text":"&c.: said to be formed irregularly from"},{"kind":"arabic","text_bw":"Aifotaqara","text_ar":"اِفْتَقَرَ"},{"kind":"text","text":", not from an unaugmented form of the verb; like"},{"kind":"arabic","text_bw":"maA A^afoqarahu","text_ar":"مَا اَفْقَرَهُ"},{"kind":"text","text":"]. (See Ham pp. 573-4.)"}],"source_refs":[]}]},"classical_definitions":null}