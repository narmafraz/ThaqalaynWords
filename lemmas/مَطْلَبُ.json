{"lemma":"مَطْلَبُ","slug":"مَطْلَبُ","root":"ط.ل.ب","root_slug":"ط-ل-ب","root_link":"/words/roots/ط-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n26907","n26908","n26910"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B7%D9%92%D9%84%D9%8E%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of طَلَبَ (ṭalaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"something sought"}]},"etymology":null,"ipa":["/matˤ.lab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26907","headword_ar":"مَطْلَبٌ","root":"Tlb","body":[{"kind":"italic_en","text":"A place,"},{"kind":"text","text":"(Msb, KL,) or"},{"kind":"italic_en","text":"time,"},{"kind":"text","text":"(KL,)"},{"kind":"italic_en","text":"of seeking:"},{"kind":"text","text":"(Msb, KL:) [and so ↓"},{"kind":"arabic","text_bw":"muT~alabN","text_ar":"مُطَّلَبٌ","orth_type":"arrow"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"maTaAlibu","text_ar":"مَطَالِبُ"},{"kind":"text","text":". (KL.) [And particularly applied to"},{"kind":"italic_en","text":"A place in which treasure is buried and sought."},{"kind":"text","text":"And"},{"kind":"italic_en","text":"A place where anything remarkable is to be sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looked for, in a book."},{"kind":"text","text":"] ―         -b2-  [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"A person from whom one seeks a thing."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"layosa liY maTolabN siwaAka","text_ar":"لَيْسَ لِى مَطْلَبٌ سِوَاكَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I have none from whom to seek the accomplishment of my desires but Thee"},{"kind":"text","text":"] occurs in a trad. respecting prayer. (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"maToluwbN","text_ar":"مَطْلُوبٌ"},{"kind":"text","text":". ―         -b4-  It is also an inf. n. of 1 [q. v.]. (A, MA, Msb.)"}],"source_refs":["Msb","KL"]},{"entry_id":"n26908","headword_ar":"مُطْلِبٌ","root":"Tlb","body":[{"kind":"text","text":", applied to water, and to pasture, or herbage,"},{"kind":"italic_en","text":"Distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote,"},{"kind":"text","text":"(S, A, O,)"},{"kind":"italic_en","text":"so as not to be attainable but by seeking,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"so that it is sought:"},{"kind":"text","text":"(A:) or, applied to pasture, or herbage,"},{"kind":"italic_en","text":"distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote:"},{"kind":"text","text":"and, applied to water,"},{"kind":"italic_en","text":"distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, from the pasture"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between which and the pasture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, is twice the space termed a"},{"kind":"arabic","text_bw":"miyl","text_ar":"مِيل"},{"kind":"text","text":", (K, TA,) or"},{"kind":"italic_en","text":"thrice that space,"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"myl","text_ar":"ميل"},{"kind":"text","text":"being"},{"kind":"italic_en","text":"the space from one"},{"kind":"arabic","text_bw":"Ealam","text_ar":"عَلَم"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sign of the way"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to another;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"a day,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two days,"},{"kind":"text","text":"(K, TA,) i. e."},{"kind":"italic_en","text":"a day's journey,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two days' journey;"},{"kind":"text","text":"in the latter case being termed"},{"kind":"arabic","text_bw":"muTolibu A_ibilK","text_ar":"مُطْلِبُ اـِبِلٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"distant to be sought of camels"},{"kind":"text","text":"]. (TA.) It is also applied to other things: a poet says,"},{"kind":"quote","text":"A^ahaAjaka baroqN A=xira All~ayoli muTolibu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Has distant lightning, in the latter part of the night, excited thee?"},{"kind":"text","text":"]. (S, O.)"}],"source_refs":["S","A","O","K","TA"]},{"entry_id":"n26910","headword_ar":"مُطَّلَبٌ","root":"Tlb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maTolabN","text_ar":"مَطْلَبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}