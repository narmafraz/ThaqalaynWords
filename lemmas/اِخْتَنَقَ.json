d upon one's throat:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlAixotinaAqu","text_ar":"الاِخْتِنَاقُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"the compressing it upon one's own throat."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}