{"lemma":"غُبارٌ","slug":"غُبارٌ","root":"غ.ب.ر","root_slug":"غ-ب-ر","root_link":"/words/roots/غ-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31351"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8F%D8%A8%D8%A7%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dust"}]},"etymology":null,"ipa":["/ɣu.baːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31351","headword_ar":"غُبَارٌ","root":"gbr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gabarapN","text_ar":"غَبَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"signify the same, (S, L, K,) as also ↓"},{"kind":"arabic","text_bw":"guborapN","text_ar":"غُبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (IAar, K:) i. e."},{"kind":"italic_en","text":"Dust;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"rahajN","text_ar":"رَهَجٌ"},{"kind":"text","text":": (L:) or the first,"},{"kind":"italic_en","text":"dust raised and spreading:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"what remains of dust raised and spreading:"},{"kind":"text","text":"(B, TA:) and the second, the"},{"kind":"italic_en","text":"moving to and fro of dust."},{"kind":"text","text":"(L.) ―         -b2-  You say"},{"kind":"arabic","text_bw":"Talaba fulaAnFA famaA","text_ar":"طَلَبَ فُلَانًا فَمَا"},{"kind":"arabic","text_bw":"$aq~a gubaArahu","text_ar":"شَقَّ غُبَارَهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He pursued after such a one but did not cleave his dust;"},{"kind":"text","text":"] i. e.,"},{"kind":"italic_en","text":"he did not overtake him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA yu$aq~u gubaAruhu","text_ar":"مَا يُشَقُّ غُبَارُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maA yuHaT~u gubaAruhu","text_ar":"مَا يُحَطُّ غُبَارُهُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He is not to be outgone, outstripped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got before."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"baAEa fulaAnN EalaY bayoEi fulaAnK","text_ar":"بَاعَ فُلَانٌ عَلَى بَيْعِ فُلَانٍ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"byE","text_ar":"بيع"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"laA gubaAra Ealayohi","text_ar":"لَا غُبَارَ عَلَيْهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"There is no dust upon it;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a phrase or the like)"},{"kind":"italic_en","text":"is clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from obscurity;"},{"kind":"text","text":"like the saying"},{"kind":"arabic","text_bw":"laA Eafara fiyhi","text_ar":"لَا عَفَرَ فِيهِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"laA Eafora lahu","text_ar":"لَا عَفْرَ لَهُ"},{"kind":"text","text":"]. (TA, in many places.)"}],"source_refs":["S","L","K","IAar","B","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%BA%D8%A8%D8%A7%D8%B1/","headword_ar":"غبار","entries":[{"lexicon_id":"dictionary_15","lexicon_en":"Ibn Mālik, al-Alfāẓ al-Mukhtalifa fī l-Maʿānī al-Muʾtalifa (d. 1274 CE)","lexicon_ar":"الألفاظ المختلفة في المعاني المؤتلفة لابن مالك","permalink":"https://arabiclexicon.hawramani.com/?p=22423#d2a142","body_html":"<span class=\"title1\">بَاب الْغُبَار</span><br><br><span>الْغُبَار والرهج والعجاج وَالنَّقْع والهبوة والعثان والمور والعثير والقسطل والسافياء والعكوب</span>"}]}}