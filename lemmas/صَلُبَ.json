gen":"m","num":"p"},{"role":"present_2mp","form":"تَصْلُبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْلُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْلُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْلُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْلُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْلُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْلُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْلُبُوا","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْلُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صَلُبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَلُبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْلُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْلُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":true,"lemma_key":"صَلُبَ","root":"صلب","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n24675"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%84%D9%8F%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to crucify"},{"pos":"verb","gloss":"to barbecue"},{"pos":"verb","gloss":"to enkindle, to set on fire, to ignite"},{"pos":"verb","gloss":"to crucify","examples":[{"text":"لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَافٍ ثُمَّ لَأُصَلِّبَنَّكُمْ أَجْمَعِينَ"}]},{"pos":"verb","gloss":"to make crossed, to cross"},{"pos":"verb","gloss":"to cross oneself, to make the sign of the cross"},{"pos":"noun","gloss":"crucifixion","tags":["uncountable"]},{"pos":"verb","gloss":"to be or become rigid, to be or become solid, to be or become stiff, to be or become unyielding, to be or become sturdy"},{"pos":"verb","gloss":"to stiffen, to harden, to make sturdy, to render tough"},{"pos":"verb","gloss":"to support, to prop"},{"pos":"adj","gloss":"firm, stiff, solid","examples":[{"text":"وَٱلشَّكْوَسُ قَالَ أَبُو ٱلْخَيْرِ وَغَيْرِهِ هُوَ ٱلْوَرْدُ ٱلْفَحْصِيُّ وَقِيلَ ٱلْبَرِيُّ وَهُوَ نَوْعَانِ أَحَدُهُمَا يُسَمَّى بِٱلْعَجَمِيَّةِ ٱلرَّحْبَلُ وَرَقُهُ فِي قَدْرِ وَرَقِ ٱلزَّيْتُونِ وَأَطْوَلُ وَأَعْرَضُ أََغْبَرُ أَحْرَشُ وَأَغْصَانُهُ خَشِنَةٌ صُلْبَةٌ إِلَى ٱلْبَيَاضِ مَا هِيَ تَطْلَعُ فِي زَمَنِ ٱلرَّبِيعِ نُوْرُهُ كَٱلْوَرْدِ حَمْرَاءُ فَائِتَةٌ وَفِي وَسَطِهَا صُفْرَةٌ وَهَذَا هُوَ ٱلْمُسَمَّى ٱلْوَرْدُ ٱلْفَحْصِيُّ وَيُقَالُ إِنَّ ٱلْوَرْدَ إِنْ رَكِبَ فِيهِ فَيَنْجِبُ وَٱلنَّوْعُ ٱلثَّانِي مِنَ ٱلشَّكْوَسِ وَرَقُهُ أَصْغَرُ مِنْ وَرَقِ ٱلْأَوَّلِ وَأَشَدُّ خُضْرَةً وَهًوَ أَحْرَشُ بَيْنَ ٱلْاِسْتِدَارِ وَٱلطُّولِ وَأَغْصَانِهِ إِلَى ٱلْحَمْرَاءِ مَا هِيَ تَطْلَعُ وَرْدًا أَبْيَضَا نَاصِعَةً فِي وَسَطِهَا وَكِلَاهُمَا لَاحِقٌ بِٱلْأَشْجَارِ.","english":"And the rockrose, say Abū al-Ḵayr and others, is the field rose, and also the land rose, it is said, and there are two kinds: One is called in Berber raḥbal and its leaves are of the dimensions of the leaves of the olive but longer and wider, more gray and rugged, and its branches are rough, stiff and lean into white, and in spring it blossoms in roses of a red hue you almost miss, and in their mid there is yellow and this is called field rose, and it is said that if a rose is grafted onto it it will prevail. The second kind of rockrose has smaller leaves than the first, of a more intense green, and it is more rugged around and along, and its branches lean into red and spawn white roses, vivid in the middle. And both liaise with trees."}]},{"pos":"noun","gloss":"backbone, the bone extending from the base of the neck to the coccyx","examples":[{"text":"فَلْيَنْظُرِ ٱلْإِنْسَانُ مِمَّ خُلِقَ خُلِقَ مِنْ مَاءٍ دَافِقٍ يَخْرُجُ مِنْ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَائِبِ","english":"So let man look around: what is it that he was made of? / He was made out of out-flowing water. / From between the spine and the breastbone, it gushes out."}]},{"pos":"noun","gloss":"loins"},{"pos":"noun","gloss":"steel"},{"pos":"noun","gloss":"plural of صَلِيب (ṣalīb, “hard, solid”)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Also Aramaic / Hebrew צָלַב (ṣāláḇ), Ge'ez ጸለበ (ṣäläbä), but mostly within Arabic a denominal verb of صَلِيب (ṣalīb, “cross”), plausibly also interpreted after the native صَلَّبَ (ṣallaba, “to prop up, to support”).\n\nDerived from the verbal noun of صَلَبَ (ṣalaba)."},"ipa":["/sˤulb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24675","headword_ar":"صَلُبَ","root":"Slb","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"SalaAbapN","text_ar":"صَلَابَةٌ"},{"kind":"text","text":"; (S, M, A, Msb, K, &c.;) and"},{"kind":"arabic","text_bw":"Saliba","text_ar":"صَلِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (IKtt, A, K;) and ↓"},{"kind":"arabic","text_bw":"Sl~b","text_ar":"صلّب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taSoliybN","text_ar":"تَصْلِيبٌ"},{"kind":"text","text":"; (K; [but this last, accord. to the TA, is trans. only;]) said of a thing, (S, Msb,) [and of a man,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, firm, rigid, stiff, tough, strong, robust, sturdy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hardy;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ai$otad~a","text_ar":"اِشْتَدَّ"},{"kind":"text","text":"; (S, * A, * Msb, K; *)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"laAna","text_ar":"لَانَ"},{"kind":"text","text":". (M, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Salubati AlA^aroDu muno*u A^aEowaAmK","text_ar":"صَلُبَتِ الاَرْضُ مُنْذُ اَعْوَامٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The land has been hard"},{"kind":"text","text":"by lying waste"},{"kind":"italic_en","text":"for years"},{"kind":"text","text":"]; said of land that has not been sown for a long time. (A, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Saluba EalaY AlmaAli","text_ar":"صَلُبَ عَلَى المَالِ"},{"kind":"text","text":", inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tenacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious, of property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the property."},{"kind":"text","text":"(M, L.) ―         -b4-  [And"},{"kind":"arabic","text_bw":"Saluba Al$~araAbu","text_ar":"صَلُبَ الشَّرَابُ"},{"kind":"text","text":", inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"The wine became strong."},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Had~u","text_ar":"حَدُّ"},{"kind":"arabic","text_bw":"Al$~araAbi","text_ar":"الشَّرَابِ"},{"kind":"text","text":"is expl. in the S and L, in art."},{"kind":"arabic","text_bw":"Hd","text_ar":"حد"},{"kind":"text","text":", as meaning"},{"kind":"arabic","text_bw":"SalaAbatuhu","text_ar":"صَلَابَتُهُ"},{"kind":"text","text":".)]       -A2-"},{"kind":"arabic","text_bw":"Salaba AlEiZaAma","text_ar":"صَلَبَ العِظَامَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"ASTlbhA","text_ar":"اصطلبها","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He cooked,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"collected and cooked,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"the bones,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"and extracted their grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"to make use of it as a seasoning:"},{"kind":"text","text":"(TA:) or ↓"},{"kind":"arabic","text_bw":"ASTlb","text_ar":"اصطلب","orth_type":"arrow"},{"kind":"text","text":"[alone]"},{"kind":"italic_en","text":"he extracted the grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter, of bones,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"he collected bones, and extracted their grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"to make use of it as a seasoning."},{"kind":"text","text":"(S, Msb.) ―         -b2-  And in like manner one says of one who roasts, or broils, or fries, flesh-meat and makes its grease to flow: (M:) i. e. one says,"},{"kind":"arabic","text_bw":"Salaba All~aHoma","text_ar":"صَلَبَ اللَّحْمَ"},{"kind":"text","text":", (M, * K, TA,) and ↓"},{"kind":"arabic","text_bw":"ASTlb","text_ar":"اصطلب","orth_type":"arrow"},{"kind":"text","text":"[alone], (M,)"},{"kind":"italic_en","text":"He roasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fried, the flesh-meat,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"and made its grease to flow."},{"kind":"text","text":"(M, TA.) ―         -b3-  And, (K,) as Sh says, (TA,),"},{"kind":"arabic","text_bw":"Salabahu","text_ar":"صَلَبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, burned him:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"arabic","text_bw":"Salabatohu Al$~amosu","text_ar":"صَلَبَتْهُ الشَّمْسُ"},{"kind":"italic_en","text":"The sun burned him"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"causing his sweat to flow"},{"kind":"text","text":"]. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Salabahu","text_ar":"صَلَبَهُ"},{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":"; (S, M, Msb;) and ↓"},{"kind":"arabic","text_bw":"Sl~bhu","text_ar":"صلّبهُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"taSoliybN","text_ar":"تَصْلِيبٌ"},{"kind":"text","text":", (K,) or the verb with teshdeed is said of a pl. number; (S, A;;) ["},{"kind":"italic_en","text":"He crucified him;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put him to death in a certain well-known manner;"},{"kind":"text","text":"(M, L;)"},{"kind":"italic_en","text":"he made him to be"},{"kind":"arabic","text_bw":"maSoluwb","text_ar":"مَصْلُوب"},{"kind":"text","text":"; (K) namely, one who had slain another; (Msb;) or a thief: (A:) from"},{"kind":"arabic","text_bw":"Salaba AlEiZaAma","text_ar":"صَلَبَ العِظَامَ"},{"kind":"text","text":"; because the oily matter, and the ichor mixed with blood, of the person so put to death flows. (M.) ―         -b5-  [Hence]"},{"kind":"arabic","text_bw":"AlS~alobu","text_ar":"الصَّلْبُ"},{"kind":"text","text":"in prayer means"},{"kind":"italic_en","text":"The placing the hands upon the flanks, in standing, and separating the arms from the body:"},{"kind":"text","text":"a posture forbidden by the Prophet because resembling that of a man when he is crucified ("},{"kind":"arabic","text_bw":"A_i*aA Suliba","text_ar":"اـِذَا صُلِبَ"},{"kind":"text","text":"), the arms of the man in this case being extended upon the timber. (TA.) ―         -b6-  [Hence also,]"},{"kind":"arabic","text_bw":"Salaba Ald~alowa","text_ar":"صَلَبَ الدَّلْوَ"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"Sal~abahaA","text_ar":"صَلَّبَهَا","orth_type":"arrow"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He put upon the"},{"kind":"arabic","text_bw":"dlw","text_ar":"دلو"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leathern"},{"kind":"page_break","n":1712},{"kind":"italic_en","text":"bucket"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what are called"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaliybaAni","text_ar":"صَلِيبَانِ","orth_type":"arrow"},{"kind":"text","text":", (M, L, K,) which are"},{"kind":"italic_en","text":"two pieces of wood placed cross-wise"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to keep it from collapsing"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"like what are called the"},{"kind":"arabic","text_bw":"EaroquwataAni","text_ar":"عَرْقُوَتَانِ"},{"kind":"text","text":". (M, L.)       -A3-"},{"kind":"arabic","text_bw":"Salabato Ealayohi Hum~aAhu","text_ar":"صَلَبَتْ عَلَيْهِ حُمَّاهُ"},{"kind":"text","text":", (S, M, A, Msb, * K,) aor."},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"His fever was continual,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"and vehement:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"was of the kind termed"},{"kind":"arabic","text_bw":"SaAlib","text_ar":"صَالِب"},{"kind":"text","text":"[q. v.]. (M, TA.)"}],"source_refs":["S","Msb","M","K","TA","A","L"]}]}}