talic_en","text":"That cannot see in the sun;"},{"kind":"text","text":"(S, A, Msb, K;) applied to a man, (A, Msb,) and to a ram: (S:) fem. as above: (S, A, Msb, K:) or"},{"kind":"italic_en","text":"weak-sighted in the sun:"},{"kind":"text","text":"(Lh, TA:) or"},{"kind":"italic_en","text":"that cannot see in the daytime;"},{"kind":"arabic","text_bw":"A^aEo$aY","text_ar":"اَعْشَى"},{"kind":"text","text":"signifying “ that cannot see in the night: ” (TA:) and the fem., a woman"},{"kind":"italic_en","text":"who closes her eyes in the sun."},{"kind":"text","text":"(A.) ―         -b5-  A horse"},{"kind":"italic_en","text":"having a blaze that covers his face:"},{"kind":"text","text":"fem. as above. (K.) ―         -b6-  Also the fem.,"},{"kind":"italic_en","text":"Open, bare,"},{"kind":"text","text":"land,"},{"kind":"italic_en","text":"not concealed by anything:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"plain"},{"kind":"text","text":"land,"},{"kind":"italic_en","text":"in which are no trees nor hills"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"nor sands:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"jahoraAwaAtN","text_ar":"جَهْرَاوَاتٌ"},{"kind":"text","text":". (A, TA.) ―         -b7-  And"},{"kind":"italic_en","text":"A company"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"consisting of the distinguished part"},{"kind":"text","text":"(TA) of a people: (S:) the"},{"kind":"italic_en","text":"more,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, excellent persons"},{"kind":"text","text":"of a tribe. (K.) You say, [with reference to distinguished persons,]"},{"kind":"arabic","text_bw":"kayofa jahoraAw^ukumo","text_ar":"كَيْفَ جَهْرَاوُكُمْ"},{"kind":"italic_en","text":"How is your company?"},{"kind":"text","text":"(S.)"}],"source_refs":["K","AA","A","Msb","S","Lh","TA"]}]}}