nt":0},"lanes":{"found":true,"entry_ids":["n9167"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AD%D9%92%D8%AA%D9%8E%D9%85%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9167","headword_ar":"احتمل","root":"Hml","body":[{"kind":"italic_en","text":"He raised"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"upon his back."},{"kind":"text","text":"(Har p. 41.) ―         -b2-  See also 1, in five places: and see 5, in three places. ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"He bore, endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sustained."},{"kind":"text","text":"(KL.) You say,"},{"kind":"arabic","text_bw":"AiHotamalotu maA kaAna minohu","text_ar":"اِحْتَمَلْتُ مَا كَانَ مِنْهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured, what proceeded from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he did"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"said,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"I forgave what proceeded from him, and feigned myself neglectful of it."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A_idolaAlahu","text_ar":"اـِدْلَالَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hamalotu","text_ar":"حَمَلْتُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AiHotamalotu","text_ar":"اِحْتَمَلْتُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured, his presumptuousness occasioned by his confiding in my love"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"AHtmlhu","text_ar":"احتملهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He bore with, endured, suffered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tolerated, him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured, his annoyance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"molestation,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AHtml A^a*aAhu","text_ar":"احتمل اَذَاهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and feigned himself neglectful of what proceeded from him, and did not reprove him."},{"kind":"text","text":"(Har p. 41.) And"},{"kind":"arabic","text_bw":"AHtml","text_ar":"احتمل"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was forbearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clement; he acted with forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency; he treated with forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency, him who reviled him:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he forgave an offence;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tHm~l","text_ar":"تحمّل","orth_type":"arrow"},{"kind":"text","text":": (Har p. 637:) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hamala","text_ar":"حَمَلَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he treated him with forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency."},{"kind":"text","text":"(K, TA.) [And"},{"kind":"arabic","text_bw":"AHtml Aln~iEomap","text_ar":"احتمل النِّعْمَة"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He bore wealth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercised, the quality of doing so;"},{"kind":"text","text":"generally meaning,"},{"kind":"italic_en","text":"in a becoming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, manner;"},{"kind":"text","text":"but also"},{"kind":"italic_en","text":"absolutely,"},{"kind":"text","text":"as is shown by the phrase]"},{"kind":"arabic","text_bw":"suwo'u","text_ar":"سُوْءُ"},{"kind":"arabic","text_bw":"AHotimaAli Aln~iEomapi","text_ar":"احْتِمَالِ النِّعْمَةِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The bearing of wealth ill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in an evil manner"},{"kind":"text","text":"]. (Er-Rághib voce"},{"kind":"arabic","text_bw":"baTarN","text_ar":"بَطَرٌ"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"AHtml AlS~aniyEapa","text_ar":"احتمل الصَّنِيعَةَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He bore the benefit as a badge, and was thankful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grateful, for it."},{"kind":"text","text":"(ISd, K.) ―         -b4-  [In lexicology, said of a word or phrase or sentence, (assumed tropical:)"},{"kind":"italic_en","text":"It bore, admitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was susceptible of,"},{"kind":"text","text":"a meaning, a sense, or an interpretation: and, elliptically, (assumed tropical:)"},{"kind":"italic_en","text":"it bore, admitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was susceptible of, two,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more, different meanings, senses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interpretations; it was equivocal."},{"kind":"text","text":"] In the conventional language of the lawyers, and the Muslim theologians [and men of science in general], (Msb,) it is used, (Kull,) or may be used, (Msb,) as importing supposition, and admissibleness, or allowableness; and thus used, it is intrans.: and also as importing necessary implication, and inclusion; and thus used, it is trans.: you say,"},{"kind":"arabic","text_bw":"yaHotamilu A^ano yakuwna ka*aA","text_ar":"يَحْتَمِلُ اَنْ يَكُونَ كَذَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"It is supposable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admissible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allowable, that it may be thus;"},{"kind":"text","text":"or simply"},{"kind":"italic_en","text":"it may be thus;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"yuHotamalu","text_ar":"يُحْتَمَلُ"},{"kind":"text","text":", which is often used in this sense]: and"},{"kind":"arabic","text_bw":"AiHotamala AlHaAlu wujuwhFA","text_ar":"اِحْتَمَلَ الحَالُ وُجُوهًا"},{"kind":"arabic","text_bw":"kaviyrapF","text_ar":"كَثِيرَةً"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The case necessarily implied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"included, many"},{"kind":"text","text":"("},{"kind":"italic_en","text":"possible"},{"kind":"text","text":")"},{"kind":"italic_en","text":"modes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manners of being;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admitted of being put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understood, in many ways;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bore many kinds of interpretation"},{"kind":"text","text":"]. (Msb, Kull.) ―         -b5-"},{"kind":"arabic","text_bw":"AHtmlhu AlgaDabu","text_ar":"احتملهُ الغَضَبُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Anger disquieted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flurried, him."},{"kind":"text","text":"(Mj, TA.) And"},{"kind":"arabic","text_bw":"AuHotumila","text_ar":"اُحْتُمِلَ"},{"kind":"text","text":"[alone] (assumed tropical:)"},{"kind":"italic_en","text":"He was disquieted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flurried, by anger:"},{"kind":"text","text":"(T, TA:) or, accord. to the Mj and M and O; but accord. to the K, followed by"},{"kind":"arabic","text_bw":"lawonuhu","text_ar":"لَوْنُهُ"},{"kind":"text","text":"; (TA;) (assumed tropical:)"},{"kind":"italic_en","text":"he was angry, and his colour changed."},{"kind":"text","text":"(K, TA.) ―         -b6-  ["},{"kind":"arabic","text_bw":"AiHotamalato","text_ar":"اِحْتَمَلَتْ"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"used"},{"kind":"text","text":"a drug, or the like,"},{"kind":"italic_en","text":"in the manner of a suppository in the ragina:"},{"kind":"text","text":"so in the present day: and so in the K, on the words"},{"kind":"arabic","text_bw":"qun~abiyTN","text_ar":"قُنَّبِيطٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nifoTN","text_ar":"نِفْطٌ"},{"kind":"text","text":"&c.] ―         -b7-"},{"kind":"arabic","text_bw":"AHtml","text_ar":"احتمل"},{"kind":"italic_en","text":"He bought what is termed"},{"kind":"arabic","text_bw":"Hamiyl","text_ar":"حَمِيل"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a thing"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"lls~aboYi","text_ar":"للسَّبْىِ"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"lil$~aYo'i","text_ar":"لِلشَّىْءِ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"carried from one country or town to another"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"among a party of captives."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","Msb","Kull","T","K"]}]}}