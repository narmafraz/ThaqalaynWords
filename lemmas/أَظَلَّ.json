"m","num":"d"},{"role":"present_3md","form":"يُظَلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُظَلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُظِلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُظِلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُظَلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُظَلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُظِلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُظِلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُظَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُظَلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُظْلِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُظِلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُظِلّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُظَلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُظَلّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَظْلَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَظْلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n27589","n27604"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B8%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27589","headword_ar":"اظلّ","root":"Zl","body":[{"kind":"text","text":", said of a day,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"shady,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a day having shade:"},{"kind":"text","text":"(S, M, O, K:) or"},{"kind":"italic_en","text":"it was a day having clouds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other"},{"kind":"text","text":"["},{"kind":"italic_en","text":"causes of shade"},{"kind":"text","text":"]: (T:) or"},{"kind":"italic_en","text":"it was continually shady;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Zal~a","text_ar":"ظَلَّ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaZil~u","text_ar":"يَظِلُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ZilaAlapN","text_ar":"ظِلَالَةٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  And, said of a thing, ["},{"kind":"italic_en","text":"It extended its shade;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"its shade extended;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Zl~l","text_ar":"ظلّل","orth_type":"arrow"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"A^aZal~atoniY Al$~ajarapu","text_ar":"اَظَلَّتْنِى الشَّجَرَةُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The tree shaded me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afforded me shade"},{"kind":"text","text":"]: and in like manner one says of other things than trees. (S, O.)"},{"kind":"arabic","text_bw":"A^aZal~aka","text_ar":"اَظَلَّكَ"},{"kind":"text","text":"said of a building, or of a mountain, or of a cloud, means"},{"kind":"italic_en","text":"It protected thee,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"cast its shade upon thee."},{"kind":"text","text":"(Mgh.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AZl~hu","text_ar":"اظلّهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He took him into his shelter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protection:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he guarded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected, him,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"placed him within the scope of his might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power of resistance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defence."},{"kind":"text","text":"(Er-Rághib, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A^aZal~aniY","text_ar":"اَظَلَّنِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"covered me:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"it approached me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near to me, so as to cast its shade upon me:"},{"kind":"text","text":"(K:) or it has both of these meanings: (M:) or"},{"kind":"arabic","text_bw":"A^aZal~aka","text_ar":"اَظَلَّكَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(T, S,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"approached thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near to thee, as though he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, cast his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, shade upon thee."},{"kind":"text","text":"(T, S, O.) And hence one says,"},{"kind":"arabic","text_bw":"A^aZal~aka A^amorN","text_ar":"اَظَلَّكَ اَمْرٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"An event approached thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near to thee:"},{"kind":"text","text":"(S, O:) and in like manner one says of a month. (T, S, O.) And"},{"kind":"arabic","text_bw":"AZl~","text_ar":"اظلّ"},{"kind":"text","text":"[alone] (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"advanced:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near."},{"kind":"text","text":"(Msb.) And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^a$orafa","text_ar":"اَشْرَفَ"},{"kind":"text","text":"[app. as meaning (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became within sight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"view"},{"kind":"text","text":"]. (Msb.)"}],"source_refs":["S","O","M","K","T","TA"]},{"entry_id":"n27604","headword_ar":"اَظَلُّ","root":"Zl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, dense in shade"},{"kind":"text","text":"]. The Arabs say,"},{"kind":"arabic","text_bw":"layosa $aYo'N A^aZal~a mino HajarK","text_ar":"لَيْسَ شَىْءٌ اَظَلَّ مِنْ حَجَرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is not anything more dense in shade than a stone"},{"kind":"text","text":"]. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"A^aZal~","text_ar":"اَظَلّ"},{"kind":"text","text":", [as a subst., i. e."},{"kind":"arabic","text_bw":"A^aZal~N","text_ar":"اَظَلٌّ"},{"kind":"text","text":"accord. to a general rule, or, if regarded as originally an epithet, it may be"},{"kind":"arabic","text_bw":"A^aZal~u","text_ar":"اَظَلُّ"},{"kind":"text","text":",] by poetic license"},{"kind":"arabic","text_bw":"A^aZolal","text_ar":"اَظْلَل"},{"kind":"text","text":", (S, M, O, K,) signifies The"},{"kind":"italic_en","text":"under part,"},{"kind":"text","text":"(S, O,) or the"},{"kind":"italic_en","text":"concealed part,"},{"kind":"text","text":"(M, AHei, K,)"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"manosim","text_ar":"مَنْسِم"},{"kind":"text","text":", (S, M, O, K,) or"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"xuf~","text_ar":"خُفّ"},{"kind":"text","text":", (AHei, TA,) [the former app. here used, as it is said be in other cases, in the same sense as the latter, meaning the"},{"kind":"italic_en","text":"foot,"},{"kind":"text","text":"] of the camel; (S, M, O, AHei, K;) so called because of its being concealed: (AHei, TA:) and, (M, K,) in a human being, (M,)"},{"kind":"arabic","text_bw":"AlA^aZal~u","text_ar":"الاَظَلُّ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"baTonu AlA_iSobaEi","text_ar":"بَطْنُ الاـِصْبَعِ"},{"kind":"text","text":"; (M, K;) and [ISd says] this is in my opinion the right explanation; but it is said that"},{"kind":"arabic","text_bw":"A^aZal~u","text_ar":"اَظَلُّ"},{"kind":"arabic","text_bw":"AlA_inosaAni","text_ar":"الاـِنْسَانِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"buTuwnu A^aSaAbiEihi","text_ar":"بُطُونُ اَصَابِعِهِ"},{"kind":"text","text":", which means"},{"kind":"italic_en","text":"the portion, of what is next to the fore part"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the bottom"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the foot, from the root of the great toe to the root of the little toe, of the human being:"},{"kind":"text","text":"(M:) the pl. is"},{"kind":"arabic","text_bw":"Zul~N","text_ar":"ظُلٌّ"},{"kind":"text","text":", which is anomalous, (M, K,) or formed after the manner of the pl. of an epithet: (M:) or"},{"kind":"arabic","text_bw":"AlZ~ul~u fiY AlA_inosaAni","text_ar":"الظُّلُّ فِى الاـِنْسَانِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the roots,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bases,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^uSuwl","text_ar":"اُصُول"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of what are termed"},{"kind":"arabic","text_bw":"buTuwnu","text_ar":"بُطُونُ"},{"kind":"arabic","text_bw":"AlA^aSaAbiEi","text_ar":"الاَصَابِعِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"next to the fore part"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the bottom"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the foot."},{"kind":"text","text":"(Ibn-'Abbád, O.) Hence the prov.,"},{"kind":"arabic","text_bw":"A_ino yadoma A^aZal~uka faqado naqiba xuf~iY","text_ar":"اـِنْ يَدْمَ اَظَلُّكَ فَقَدْ نَقِبَ خُفِّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If the fore part of the sole of thy foot be bleeding, the sole of my foot has become worn through, in holes:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"naqiba","text_ar":"نَقِبَ"},{"kind":"text","text":"]: said to the complainer to him who is in a worse condition than he. (AHei, TA.)"}],"source_refs":["S","M","O","K","AHei","TA"]}]}}