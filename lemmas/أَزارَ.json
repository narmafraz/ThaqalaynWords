ole":"present_2fs","form":"تُزِيرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُزِيرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُزارانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُزارا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُزِيرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُزِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُزارُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُزارُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُزِيرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُزِيرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُزَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُزِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُزار","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُزِر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُزِير","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُزار","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُزِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُزِير","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُزارانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُزارا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُزِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُزِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُزارانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُزارا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُزِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُزِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُزارُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُزارُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُزِيرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُزِيرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُزَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُزِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَزَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَزَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُزار","in_corpus":true,"count":29,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُزار","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُزِير","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُزِير","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":64,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n662"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B2%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"an item of menswear made up of a piece of cloth that is wrapped around the lower body; a men's skirt (such as a kilt or a sarong)","examples":[{"text":"قَالَ رَبِّ ٱشْرَحْ لِي صَدْرِي 25 وَيَسِّرْ لِي أَمْرِي 26 وَاحْلُلْ عُقْدَةً مِنْ لِسَانِي 27 يَفْقَهُوا قَوْلِي 28 وَاجْعَلْ لِي وَزِيرًا مِنْ أَهْلِي 29 هَارُونَ أَخِي 30 اُشْدُدْ بِهِ أَزْرِي 31 وَأَشْرِكْهُ فِي أَمْرِي 32 كَيْ نُسَبِّحَكَ كَثِيرًا 33 وَنَذْكُرَكَ كَثِيرًا 34 إِنَّكَ كُنْتَ بِنَا بَصِيرًا 35","english":"25 He said, \"My Lord, clear out my chest, 26 and ease my affairs, 27 and loosen the knot in my tongue 28 so that they may understand my words, 29 and name a councilor for me, from my own people: 30 Aaron, my brother. 31 Fasten up my skirt with him, 32 and split up my powers with him 33 so that we can praise You, again and again, 34 and remember and speak of You, again and again. 35 You have been ever-watchful of us.\""}]},{"pos":"noun","gloss":"robes","tags":["obsolete"]}]},"etymology":{"source":"wiktextract","text":"Similar to the root ء س ر (ʔ s r), whence also إِسَار (ʔisār, “strap”), but perhaps more closely via Aramaic אזרא (ʾizārā), איזרא / ܐܝܙܪܐ (ʾīzārā, “a kind of wide belt as a garment”) from a root cognate to Arabic عَزَرَ (ʕazara, “to withhold, to restrain”), as it derives best in Hebrew אָזַר (ʾāzar, “to press, to trouble; to be a pressing pain to, to wound, to besiege etc.; to bind, to gird”), forming Hebrew אֵיזֹור, אֵזֹור (ʾēzōr, “girdle, belt”), in which shape it has been borrowed into Jewish Palestinian Aramaic אֵיזֹורא, אֵזֹורא (ʾēzōrā, “girdle, belt”). Hardly thus another clothing term from Proto-Armenian but more likely coincidentally similar to Old Armenian եզր (ezr, “edge of a cloth, end”)."},"ipa":["/ʔi.zaːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n662","headword_ar":"اـِزَارٌ","root":"Azr","body":[{"kind":"text","text":", masc. and fem., and ↓"},{"kind":"arabic","text_bw":"A_izaArapN","text_ar":"اـِزَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"miy^ozarN","text_ar":"مِيْزَرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"miy^ozarapN","text_ar":"مِيْزَرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh,) and ↓"},{"kind":"arabic","text_bw":"A_izorN","text_ar":"اـِزْرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"A thing well known;"},{"kind":"text","text":"(S, Msb;) ["},{"kind":"italic_en","text":"a waist-wrapper;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a wrapper for covering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"which covers, the lower part of the body,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the waist downwards, concealing the thighs, and generally the upper half, or more, of the shanks,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"A^azorN","text_ar":"اَزْرٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^uzorN","text_ar":"اُزْرٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A_izorapN","text_ar":"اـِزْرَةٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"not sewed:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as is beneath the shoulders,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the lower half of the body:"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"ridaA='i","text_ar":"رِدَا=ءِ"},{"kind":"text","text":"is that which covers the upper half of the body; or that which is upon the shoulders and back; and this also is not sewed: each of these explanations is correct: (MF:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"miloHafapN","text_ar":"مِلْحَفَةٌ"},{"kind":"text","text":": (K:) [in the present day,"},{"kind":"arabic","text_bw":"A_izaAr","text_ar":"اـِزَار"},{"kind":"text","text":", vulgarly pronounced"},{"kind":"arabic","text_bw":"A_iyzaAr","text_ar":"اـِيزَار"},{"kind":"text","text":", is also applied to"},{"kind":"italic_en","text":"a woman's outer covering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrapper, of white calico;"},{"kind":"text","text":"described in my “Modern Egyptians:” and ↓"},{"kind":"arabic","text_bw":"miy^ozarN","text_ar":"مِيْزَرٌ","orth_type":"arrow"},{"kind":"text","text":", to"},{"kind":"italic_en","text":"a pair of drawers:"},{"kind":"text","text":"and app., in post-classical writings, to"},{"kind":"italic_en","text":"anything resembling a waist-wrapper, worn on any part of the person, and in any manner; sometimes as a turban:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"A_izaArN","text_ar":"اـِزَارٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"anything with which one is veiled, concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covered:"},{"kind":"text","text":"(Th, K:) its pl. is"},{"kind":"arabic","text_bw":"A=zirapN","text_ar":"ا=زِرَةٌ"},{"kind":"text","text":", (S, Msb, K,) a pl. of pauc., (S, Msb,) and (of mult., S, Msb)"},{"kind":"arabic","text_bw":"A^uzurN","text_ar":"اُزُرٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"A^uzorN","text_ar":"اُزْرٌ"},{"kind":"text","text":", (K,) which is of the dial. of Temeem, or, accord. to MF, a contraction of"},{"kind":"arabic","text_bw":"A^uzurN","text_ar":"اُزُرٌ"},{"kind":"text","text":": (TA:) and the pl. of"},{"kind":"arabic","text_bw":"my^zr","text_ar":"ميزر"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"maA=ziru","text_ar":"مَا=زِرُ"},{"kind":"text","text":"(Msb.) You say, ↓"},{"kind":"arabic","text_bw":"$ad~a lilA^amori miy^ozarahu","text_ar":"شَدَّ لِلاَمْرِ مِيْزَرَهُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He prepared himself for the thing, affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"business."},{"kind":"text","text":"(A.) And ↓"},{"kind":"arabic","text_bw":"$ad~a Almiy^ozara","text_ar":"شَدَّ المِيْزَرَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He abstained from sexual intercourse:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he prepared himself for religious service."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"AixoDar~a A_izaAriY","text_ar":"اِخْضَرَّ اـِزَارِى"},{"kind":"text","text":"(tropical:) ("},{"kind":"italic_en","text":"The place of"},{"kind":"text","text":")"},{"kind":"italic_en","text":"my"},{"kind":"arabic","text_bw":"AzAr","text_ar":"ازار"},{"kind":"italic_en","text":"became black:"},{"kind":"text","text":"or, rather,"},{"kind":"italic_en","text":"became of a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"blackish"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hue inclining to green:"},{"kind":"text","text":"because the hair when it first grows is of that hue. (Har p. 494.) And"},{"kind":"arabic","text_bw":"daAriY A_izaAriY","text_ar":"دَارِى اـِزَارِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My house is my covering"},{"kind":"text","text":"]: said by Es-Sarawee to IAar, on the latter's expressing his surprise at the former's walking in his house naked. (TA.) ―         -b2- (tropical:)"},{"kind":"italic_en","text":"Continence; chastity."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN Eafiyfu AlA_i zaAri","text_ar":"فُلَانٌ عَفِيفُ الاـِ زَارِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Almiy^ozari","text_ar":"المِيْزَرِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one is continent, abstaining from women with whom it is unlawful to him to have commerce:"},{"kind":"text","text":"(A 'Obeyd:) and in like manner,"},{"kind":"arabic","text_bw":"fulaAnN Tay~bu AlA_izaAri","text_ar":"فُلَانٌ طَيّبُ الاـِزَارِ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"Hjz","text_ar":"حجز"},{"kind":"text","text":".) ―         -b3- (tropical:)  One's"},{"kind":"italic_en","text":"wife:"},{"kind":"text","text":"(S, M, K:) or one's"},{"kind":"italic_en","text":"self:"},{"kind":"text","text":"(IKt, Suh:) or one's"},{"kind":"italic_en","text":"wife and family:"},{"kind":"text","text":"or one's"},{"kind":"italic_en","text":"family and self."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"fidFY","text_ar":"فِدًى"},{"kind":"arabic","text_bw":"laka A_izaAriY","text_ar":"لَكَ اـِزَارِى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"May my wife be a ransom for thee:"},{"kind":"text","text":"(Aboo-'Omar El-Jarmee, S:) or"},{"kind":"italic_en","text":"myself."},{"kind":"text","text":"(IKt, Suh.) And it is said in a trad. respecting the vow of allegiance made at the 'Akabeh,"},{"kind":"arabic","text_bw":"lanamonaEan~aka","text_ar":"لَنَمْنَعَنَّكَ"},{"kind":"arabic","text_bw":"mim~aA namonaEu minohu A^uzuranaA","text_ar":"مِمَّا نَمْنَعُ مِنْهُ اُزُرَنَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We will assuredly defend thee from that from which we defend our wives and our families:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ourselves."},{"kind":"text","text":"(TA.) ―         -b4- (tropical:)"},{"kind":"italic_en","text":"A ewe."},{"kind":"text","text":"(K, TA.) [But see"},{"kind":"arabic","text_bw":"$aApN muw^az~arapN","text_ar":"شَاةٌ مُوَزَّرَةٌ"},{"kind":"text","text":".] And"},{"kind":"arabic","text_bw":"A_izaAro A_izaAro","text_ar":"اـِزَارْ اـِزَارْ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"A cry by which a ewe is called to be milked."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","K","Lh","MF","Th","TA","M","IKt","Suh"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%B2%D8%A7%D8%B1/","headword_ar":"أزارقة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22815#947353","body_html":"<span>الأزارقة: هم أصحاب نافع بن أزرق، قالوا: كفر عليٌّ -رضي الله عنه- بالتحكيم، وابن ملجم محق، وكفرت الصحابة -رضي الله عنهم- وقضوا بتخليدهم في النار.</span>"}]}}