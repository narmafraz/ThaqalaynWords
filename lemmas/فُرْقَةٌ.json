{"lemma":"فُرْقَةٌ","slug":"فُرْقَةٌ","root":"ف.ر.ق","root_slug":"ف-ر-ق","root_link":"/words/roots/ف-ر-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"فُرْقَةٌ","root":"فرق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n33670"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8F%D8%B1%D9%92%D9%82%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"part, portion"},{"pos":"noun","gloss":"troop of people, number of men, distinct body"},{"pos":"noun","gloss":"division, detachment, section, unit"},{"pos":"noun","gloss":"party, group, band, company"},{"pos":"noun","gloss":"sect"},{"pos":"noun","gloss":"class"},{"pos":"noun","gloss":"class (in school)"},{"pos":"noun","gloss":"a separate herd"},{"pos":"noun","gloss":"a portion of a thing in a state of dispersion"},{"pos":"noun","gloss":"separation"}]},"etymology":{"source":"wiktextract","text":"From ف ر ق (f r q); compare فَرَقَ (faraqa, “to separate”)."},"ipa":["/fir.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33670","headword_ar":"فُرْقَةٌ","root":"frq","body":[{"kind":"text","text":"the subst. from"},{"kind":"arabic","text_bw":"faAraqahu","text_ar":"فَارَقَهُ"},{"kind":"text","text":"; (S, MA, * TA;) or from"},{"kind":"arabic","text_bw":"Aifotaraqa","text_ar":"اِفْتَرَقَ"},{"kind":"text","text":", (Msb,) [i. e.] a quasi-inf. n. used in the sense of"},{"kind":"arabic","text_bw":"AifotiraAqN","text_ar":"اِفْتِرَاقٌ"},{"kind":"text","text":"; (TA;) signifying"},{"kind":"italic_en","text":"Separation, disunion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abandonment;"},{"kind":"text","text":"(MA, KL, PS;) and ↓"},{"kind":"arabic","text_bw":"faraAqN","text_ar":"فَرَاقٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. therewith,