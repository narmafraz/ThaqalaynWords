{"lemma":"ثُلَّةٌ","slug":"ثُلَّةٌ","root":"ث.ل.ل","root_slug":"ث-ل-ل","root_link":"/words/roots/ث-ل-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"ثُلَّة","root":"ثلل","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n4599"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8F%D9%84%D9%8E%D9%91%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"bunch of people, crew, caboodle"}]},"etymology":null,"ipa":["/θul.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4599","headword_ar":"ثُلَّةٌ","root":"vl","body":[{"kind":"italic_en","text":"A party of men;"},{"kind":"text","text":"(T;)"},{"kind":"italic_en","text":"a company of men:"},{"kind":"text","text":"(S, M, K:) or"},{"kind":"italic_en","text":"a numerous company."},{"kind":"text","text":"(Bd in lvii. 13.) You say,"},{"kind":"arabic","text_bw":"fulaAnN laA yaforuqu bayona Alv~al~api waAlv~ul~api","text_ar":"فُلَانٌ لَا يَفْرُقُ بَيْنَ الثَّلَّةِ وَالثُّلَّةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one will not distinguish"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between a flock of sheep or goats and a company of men."},{"kind":"text","text":"(Z, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"val~apN","text_ar":"ثَلَّةٌ"},{"kind":"text","text":"."}],"source_refs":["S","M","K"]}]},"classical_definitions":null}