{"lemma":"فاضَ","slug":"فاضَ","root":"ف.#.ض","root_slug":"ف-_-ض","root_link":"/words/roots/ف-_-ض","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فِضْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فِضْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فِضْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فِضْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فِضْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فاضَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فاضَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فاضا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فاضَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فاضُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فِضْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفِض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَفِيض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفِيضِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفِيضِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفِيضا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفِيضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفِيضُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفِض","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَفِيض","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفِض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَفِيض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفِيضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفِيضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفِيضُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفِيضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فِضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فِضْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفِيض","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفِيض","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n34109","n34961"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to overflow, to run over"},{"pos":"verb","gloss":"to flood, to inundate"},{"pos":"verb","gloss":"to emanate"},{"pos":"verb","gloss":"to abound, to be plentiful"},{"pos":"adj","gloss":"empty"},{"pos":"adj","gloss":"hollow"},{"pos":"adj","gloss":"unoccupied, free"}]},"etymology":null,"ipa":["/faː.dˤa/","/faː.dˤin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34109","headword_ar":"فَاضٍ","root":"fDw and fDY","body":[{"kind":"text","text":"(Msb, TA) and ↓"},{"kind":"arabic","text_bw":"mufoDK","text_ar":"مُفْضٍ","orth_type":"arrow"},{"kind":"text","text":"(M, * TA)"},{"kind":"italic_en","text":"Wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spacious,"},{"kind":"text","text":"(M, * Msb, TA,) as also ↓"},{"kind":"arabic","text_bw":"faSaA='N","text_ar":"فَصَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (Az, Er-Rághib, Mgh, Msb, TA,)"},{"kind":"italic_en","text":"open and plain, and vacant."},{"kind":"text","text":"(TA.) ―         -b2-  [The first of these words, in the present day, pronounced"},{"kind":"arabic","text_bw":"faADiY","text_ar":"فَاضِى"},{"kind":"text","text":", is commonly used in the sense of"},{"kind":"arabic","text_bw":"faArigN","text_ar":"فَارِغٌ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"Unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure."},{"kind":"text","text":"]"}],"source_refs":["Msb","TA"]},{"entry_id":"n34961","headword_ar":"فَاضَ","root":"fyD","body":[{"kind":"text","text":", (S, M, Mgh, &c.,) aor."},{"kind":"arabic","text_bw":"yafiyDu","text_ar":"يَفِيضُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":"(S, M, O, Msb, K) and"},{"kind":"arabic","text_bw":"fayoDuwDapN","text_ar":"فَيْضُوضَةٌ"},{"kind":"text","text":"(S, O, K)"},{"kind":"page_break","n":2472},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuyuwDN","text_ar":"فُيُوضٌ"},{"kind":"text","text":"(M, O, K) and"},{"kind":"arabic","text_bw":"fiyuwDN","text_ar":"فِيُوضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuyuwDapN","text_ar":"فُيُوضَةٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"fayaDaAnN","text_ar":"فَيَضَانٌ"},{"kind":"text","text":", (M, O, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"overflowed: poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, from fulness:"},{"kind":"text","text":"(Mgh:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(water, S, O, K, or a torrent, Msb)"},{"kind":"italic_en","text":"became abundant,"},{"kind":"text","text":"(S, O, Msb, K"},{"kind":"italic_en","text":"and flowed from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"over"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the brink of the valley,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"so as to flow over the side of the valley,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"so as to flow like a valley;"},{"kind":"text","text":"(K;) and ↓"},{"kind":"arabic","text_bw":"AfAD","text_ar":"افاض","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (Msb, TA:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became abundant:"},{"kind":"text","text":"(TA:) ["},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"gaADa","text_ar":"غَاضَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagiyDu","text_ar":"يَغِيضُ"},{"kind":"text","text":":]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(water, and that of the eyes, and the like, M, or anything fluid, Msb)"},{"kind":"italic_en","text":"ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed:"},{"kind":"text","text":"(M, Msb:) or"},{"kind":"italic_en","text":"it poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, vehemently; gushed out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth:"},{"kind":"text","text":"(M:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(water, and blood,)"},{"kind":"italic_en","text":"fell in drops."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a vessel)"},{"kind":"italic_en","text":"became full:"},{"kind":"text","text":"(Msb:) [or"},{"kind":"italic_en","text":"it overflowed:"},{"kind":"text","text":"for you say,]"},{"kind":"arabic","text_bw":"faADa Aln~ahoru bimaAy^ihi","text_ar":"فَاضَ النَّهْرُ بِمَايِهِ"},{"kind":"italic_en","text":"The river overflowed with its water:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faADa AlA_inaA='u bimaA fiyhi","text_ar":"فَاضَ الاـِنَا=ءُ بِمَا فِيهِ"},{"kind":"italic_en","text":"The vessel overflowed with what was in it:"},{"kind":"text","text":"(Msb:) and a poet says,"},{"kind":"quote","text":"$akawotu wamaA Al$~akowaY limivoliYa EaAdapF\n                      \n                     \n                        wal`kino tafiyDu AlkaA^osu Einoda A@motilaAy^ihaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I complained; and complaint is not a custom of the like of me; but the cup overflows on the occasion of its being full"},{"kind":"text","text":"]. (A) You say also"},{"kind":"arabic","text_bw":"faADato","text_ar":"فَاضَتْ"},{"kind":"arabic","text_bw":"Eayonuhu","text_ar":"عَيْنُهُ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The eye flowed"},{"kind":"text","text":"[with tears]. (TA.) And"},{"kind":"arabic","text_bw":"faASa EaraqFA","text_ar":"فَاصَ عَرَقًا"},{"kind":"text","text":", said of a man, ["},{"kind":"italic_en","text":"He sweated;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sweat appeared upon his body,"},{"kind":"text","text":"on an occasion of grief. (IKtt) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, much, abundant, many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmerous."},{"kind":"text","text":"(O, K.) You say,"},{"kind":"arabic","text_bw":"faADa All~iy^aAmu","text_ar":"فَاضَ اللِّيَامُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The mean became many:"},{"kind":"text","text":"(S, O:) opposed to"},{"kind":"arabic","text_bw":"gaADa","text_ar":"غَاضَ"},{"kind":"text","text":", q. v. (S and A in art."},{"kind":"arabic","text_bw":"gyD","text_ar":"غيض"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"faADa Alxayoru","text_ar":"فَاضَ الخَيْرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"became abundant,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"arabic","text_bw":"fiyhimo","text_ar":"فِيهِمْ"},{"kind":"italic_en","text":"among them."},{"kind":"text","text":"(A.) ―         -b4-  Aor. as above, (S,) inf. n."},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a piece of news, or a story,)"},{"kind":"italic_en","text":"spread abroad;"},{"kind":"text","text":"(S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"AstfAD","text_ar":"استفاض","orth_type":"arrow"},{"kind":"text","text":"; (S, M, A, Msb, K, TA;)"},{"kind":"italic_en","text":"it spread abroad among the people."},{"kind":"text","text":"(Msb and TA in explanation of the latter verb,)"},{"kind":"italic_en","text":"like water."},{"kind":"text","text":"(TA.) ↓ The latter is also said of a place, meaning (tropical:)"},{"kind":"italic_en","text":"It became wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ample."},{"kind":"text","text":"(A.) And you say,"},{"kind":"arabic","text_bw":"faADa","text_ar":"فَاضَ"},{"kind":"arabic","text_bw":"Ealayohi Ald~iroEu","text_ar":"عَلَيْهِ الدِّرْعُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The coat of mail spread over him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covered him"},{"kind":"text","text":"]. (A.) ―         -b5-  Aor. as above, inf. n."},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuyuwDN","text_ar":"فُيُوضٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, O, K)"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S, M, O, K:) and, (S, M, O, K,) in like manner, (S, O,)"},{"kind":"arabic","text_bw":"faADatN nafosuhu","text_ar":"فَاضَتٌ نَفْسُهُ"},{"kind":"text","text":", (S, M, A, Mgh, O, Msb, K,) aor. as above, (M,) inf. n."},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":", (M, Msb,) (tropical:)"},{"kind":"italic_en","text":"his soul departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forth;"},{"kind":"text","text":"(S, M, A, * Mgh, * O, Msb, K;) of the dial. of Temeem; (S, M, O;) on the authority of AO and Fr; and AZ says the like; but As says that one should not say,"},{"kind":"arabic","text_bw":"fAD","text_ar":"فاض"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"text","text":", nor"},{"kind":"arabic","text_bw":"fADt nfsh","text_ar":"فاضت نفسه"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"fAD","text_ar":"فاض"},{"kind":"text","text":"is only said of tears and of water: (S, O:) to which is added in the O, but one says,"},{"kind":"arabic","text_bw":"faAZa","text_ar":"فَاظَ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"Z","text_ar":"ظ"},{"kind":"text","text":", [as is also said in the Mgh,] as meaning “ he died, ” and not"},{"kind":"arabic","text_bw":"fAD","text_ar":"فاض"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":", decidedly: (TA:) [see, however, the remarks of IB below:] or the more chaste expression is"},{"kind":"arabic","text_bw":"fAZ","text_ar":"فاظ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"Z","text_ar":"ظ"},{"kind":"text","text":", without the mention of the"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"; and some do not allow any other: (Msb:) but in the L we find as follows: IAar says."},{"kind":"arabic","text_bw":"fAD Alrjl","text_ar":"فاض الرجل"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fAZ","text_ar":"فاظ"},{"kind":"text","text":", meaning “ the man died: ” and Abu-l-Hasan says,"},{"kind":"arabic","text_bw":"fAZt nfsh","text_ar":"فاظت نفسه"},{"kind":"text","text":", the verb relating to the"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"fAD Alrjl","text_ar":"فاض الرجل"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fAZ","text_ar":"فاظ"},{"kind":"text","text":": but As says, I heard AA say that one should not say,"},{"kind":"arabic","text_bw":"fAZt nfsh","text_ar":"فاظت نفسه"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"fAZ","text_ar":"فاظ"},{"kind":"text","text":", meaning “ he died; ” and not"},{"kind":"arabic","text_bw":"fAD","text_ar":"فاض"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":", decidedly: IB, however, says that what IDrd has cited from As is different from that which J has ascribed to him; for IDrd cites the words of As thus: the Arabs says,"},{"kind":"arabic","text_bw":"fAZ Alrjl","text_ar":"فاظ الرجل"},{"kind":"text","text":", meaning “ the man died; ” but when they speak of the"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":", they say"},{"kind":"arabic","text_bw":"fADt nfsh","text_ar":"فاضت نفسه"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":"; and he quotes the ex."},{"kind":"quote","text":"fafuqiy^ato EayonN wafaADato nafosu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And an eye was put out, and a soul departed"},{"kind":"text","text":"]: and he [IB] adds that this is what is commonly known to be the opinion of As: but J has committed and error; for As quotes from AA that one should not say,"},{"kind":"arabic","text_bw":"fAZt nfsh","text_ar":"فاظت نفسه"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"fAZ","text_ar":"فاظ"},{"kind":"text","text":", meaning “ he died; ” not"},{"kind":"arabic","text_bw":"fAD","text_ar":"فاض"},{"kind":"text","text":", decidedly and he also says, nor does it necessarily follow from what he relates that he firmly believed it: AO says that"},{"kind":"arabic","text_bw":"fAZt nfsh","text_ar":"فاظت نفسه"},{"kind":"text","text":"is of the dial. of Keys; and"},{"kind":"arabic","text_bw":"fADt","text_ar":"فاضت"},{"kind":"text","text":", of the dial of Temeem and AHát says, I heard AZ say that Benoo-Dabbeh alone say,"},{"kind":"arabic","text_bw":"fADt nfsh","text_ar":"فاضت نفسه"},{"kind":"text","text":": in like manner also El-Mázinee says. on the authority of AZ. that all the Arabs say,"},{"kind":"arabic","text_bw":"fAZt","text_ar":"فاظت"},{"kind":"arabic","text_bw":"nfsh","text_ar":"نفسه"},{"kind":"text","text":". except Benoo-Dabbeh, who say,"},{"kind":"arabic","text_bw":"fADt nfsh","text_ar":"فاضت نفسه"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"D","text_ar":"ض"},{"kind":"text","text":". (TA.) [See also art."},{"kind":"arabic","text_bw":"fyZ","text_ar":"فيظ"},{"kind":"text","text":". It is further said, that]"},{"kind":"arabic","text_bw":"AlfayoDu","text_ar":"الفَيْضُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Death:"},{"kind":"text","text":"(A, K;) as occurring in a trad respecting Ed-Dejjál, where it is said,"},{"kind":"arabic","text_bw":"vum~a yakuwnu EalaY A^avari *`lika AlfayoDu","text_ar":"ثُمَّ يَكُونُ عَلَى اَثَرِ ذٰلِكَ الفَيْضُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Then shall be, after that, death"},{"kind":"text","text":"] (A, TA:) Sh says, I asked El-Bekráwee respecting this, and he asserted"},{"kind":"arabic","text_bw":"AlfyD","text_ar":"الفيض"},{"kind":"text","text":", in this case, to signify “ death; ” but I have not heard it from any other; unless it be from"},{"kind":"arabic","text_bw":"faADato nafosahu","text_ar":"فَاضَتْ نَفْسَهُ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"His slaver collecting upon his lips at the departure of his soul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"flowed"},{"kind":"text","text":"]. (TA.) ―         -b6-  You say also"},{"kind":"arabic","text_bw":"faADa","text_ar":"فَاضَ"},{"kind":"arabic","text_bw":"Sdoruhu mina AlgayoZi","text_ar":"صدْرُهُ مِنَ الغَيْظِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His bosom overflowed with wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage"},{"kind":"text","text":"], (A, TA.) And"},{"kind":"arabic","text_bw":"faADa Sadoruhu","text_ar":"فَاضَ صَدْرُهُ"},{"kind":"arabic","text_bw":"biAls~ir~i","text_ar":"بِالسِّرِّ"},{"kind":"italic_en","text":"His bosom disclosed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, the secret;"},{"kind":"text","text":"(S, O, K;)"},{"kind":"italic_en","text":"his bosom could not conceal the secret;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"his bosom was full with the secret, and disclosed it, not being able to conceal it."},{"kind":"text","text":"(TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"fayoDN","text_ar":"فَيْضٌ"},{"kind":"text","text":"is used as meaning (assumed tropical:)  God's"},{"kind":"italic_en","text":"suggesting"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A_iloqaA='","text_ar":"اـِلْقَا=ء"},{"kind":"text","text":") [of a thing]: what the Devil suggests ("},{"kind":"arabic","text_bw":"yuloqiyhi","text_ar":"يُلْقِيهِ"},{"kind":"text","text":") is termed"},{"kind":"arabic","text_bw":"Alwasowasapu","text_ar":"الوَسْوَسَةُ"},{"kind":"text","text":". (Kull p. 277.) ―         -b8-"},{"kind":"arabic","text_bw":"faADa AlbaEiyru bijir~atihi","text_ar":"فَاضَ البَعِيرُ بِجِرَّتِهِ"},{"kind":"text","text":": see 4, latter half."}],"source_refs":["S","M","O","Msb","K","Mgh","TA","A","IKtt"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%A7%D8%B6/","headword_ar":"فاضَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=28729#8f2d62","body_html":"<span>فاضَ الماء يَفيضُ فَيْضاً وفُيوضاً، بالضم والكسر، وفَيْضُوضَةً وفَيَضاناً: كثُرَ حتى سالَ كالوادي،</span><br><span>وـ صَدْرُهُ بالسِّرِّ: باحَ،</span><br><span>وـ الرجُلُ فَيْضاً وفُيوضاً: مات،</span><br><span>وـ نَفْسُهُ: خَرَجَتْ رُوحُهُ،</span><br><span>وـ الخَبَرُ: شاعَ،</span><br><span>وـ الشيءُ: كَثُرَ. وفَيَّاضٌ، ككَتَّانٍ: فَرَسٌ لبَنِي جَعْدٍ. وشاذُّ بن فَيَّاضٍ: محدِّثٌ. واشْتَرَى طَلْحَةُ بنُ عُبَيْدِ اللهِ بئْراً، فَتَصَدَّقَ بها، ونَحَرَ جزوراً، فأطْعَمَهَا، فقال له، صلى الله عليه وسلم: أنْتَ الفَيَّاضُ، فَلُقِّبَ به.</span><br><span>والفَيْضُ: المَوْتُ، ونيل مصر، ونَهْرُ البَصْرَةِ، والكثيرُ الجَرْيِ من الخَيْلِ، وفَرَسٌ لبني ضُبَيْعَةَ بنِ نِزارٍ، وأخرى لِعُتْبَةَ بنِ أبي سُفْيَانَ.</span><br><span>وأمْرُهُمْ فَيْضيضَى بينهم، وفَيْضُوضَى، ويُمَدَّانِ،</span><br><span>وفَيوضَى، بالفتح، أي: فَوْضَى.</span><br><span>وأرْضٌ ذاتُ فُيوضٍ: فيها مياهٌ تَفيضُ.</span><br><span>وأفاضَ الماءَ على نَفْسِهِ: أفْرَغَهُ،</span><br><span>وـ الناسُ من عَرَفاتٍ: دَفَعُوا، أو رَجَعوا وتَفَرَّقُوا، أو أسرعوا منها إلى مكانٍ آخَرَ،</span><br><span>وكلُّ دَفْعَةٍ: إفاضَةٌ،</span><br><span>وـ في الحديثِ: انْدَفَعُوا، وحديثٌ مُفاضٌ فيه،</span><br><span>وـ الإِناءَ: مَلأَهُ حتى فاضَ،</span><br><span>وـ القِدَاح،</span><br><span>وـ بها: ضَرَبَ بها،</span><br><span>وـ البعيرُ: دَفَعَ جِرَّتَهُ من كِرْشِهِ.</span><br><span>والمُفاضَةُ من الدُّرُوعِ: الواسِعَةُ،</span><br><span>وـ من النِّساء: الضَّخْمَةُ البَطْنِ.</span><br><span>وكان النبيُّ، صلى الله عليه وسلم، مُفَاضَ البَطْنِ، أي: مُسْتَوِيَ البَطْنِ مع الصَّدْرِ.</span><br><span>واسْتَفَاضَ: سألَ إفاضَةَ الماء،</span><br><span>وـ الوادي شَجَراً: اتَّسَعَ وكَثُرَ شَجَرُهُ،</span><br><span>وـ الخَبَرُ: انْتَشَرَ، فهو مُسْتَفِيضٌ ومُسْتَفَاضٌ فيه، ولا تَقُلْ: مُسْتَفاضٌ، أو لُغَيَّةٌ. ومحمدُ بنُ جَعْفَرِ بنِ المُسْتَفَاضِ: محدِّثٌ.</span>"}]}}