"text","text":", (S, Msb,) ["},{"kind":"italic_en","text":"This is the time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season, of reaping:"},{"kind":"text","text":"for] both are also inf. ns. of"},{"kind":"arabic","text_bw":"HaSada","text_ar":"حَصَدَ"},{"kind":"text","text":"in the first of the senses explained above. (Lh, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"HaSiydN","text_ar":"حَصِيدٌ"},{"kind":"text","text":". ―         -b2-  Also"},{"kind":"italic_en","text":"What remains upon the ground,"},{"kind":"text","text":"of seed-produce,"},{"kind":"italic_en","text":"among the lower parts of the stalks of that which has been reaped;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"HaSaAy^idu","text_ar":"حَصَايِدُ"},{"kind":"text","text":", pl. of ↓"},{"kind":"arabic","text_bw":"HaSiydN","text_ar":"حَصِيدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HaSiydapN","text_ar":"حَصِيدَةٌ","orth_type":"arrow"},{"kind":"text","text":". (Mgh.) ―         -b3-  And"},{"kind":"italic_en","text":"What falls off, and becomes scattered,"},{"kind":"text","text":"of seeds of wild leguminous plants when they dry up. (L.) ―         -b4-  And The"},{"kind":"italic_en","text":"fruit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produce,"},{"kind":"text","text":"of any tree. (L.)"}],"source_refs":["S","A","Msb"]},{"entry_id":"n8199","headword_ar":"حِصَادٌ","root":"HSd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaSaAdN","text_ar":"حَصَادٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}