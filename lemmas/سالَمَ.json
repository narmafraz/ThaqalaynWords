,"num":"p"},{"role":"present_2mp","form":"تُسالِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُسالِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُسالِم","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُسالِم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُسالِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُسالِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسالِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسالِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسالِمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسالِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسالِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سالَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سالَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُسالِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسالِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":373,"cross_references":{"qac":{"found":true,"lemma_key":"سالَمَ","root":"سلم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","name","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n20554"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%84%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make peace with, to treat peaceably, to make up with"},{"pos":"adj","gloss":"safe, secure, safe and sound"},{"pos":"adj","gloss":"sound, whole, perfect, complete"},{"pos":"adj","gloss":"healthy, unimpaired, unhurt"},{"pos":"adj","gloss":"undamaged, intact, unblemished, flawless"},{"pos":"adj","gloss":"regular (verb)"},{"pos":"adj","gloss":"sound (plural)"},{"pos":"name","gloss":"a male given name, Salem or Salim"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of سَلِمَ (salima, “to be safe, sound, healthy, etc.”)."},"ipa":["/saː.la.ma/","/saː.lim/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20554","headword_ar":"سَالِمٌ","root":"slm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saliymN","text_ar":"سَلِيمٌ"},{"kind":"text","text":"; and see"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":", near the middle of the paragraph. [See also an ex. voce"},{"kind":"arabic","text_bw":"$aAjibN","text_ar":"شَاجِبٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"kalimapN saAlimapu AlEayonayoni","text_ar":"كَلِمَةٌ سَالِمَةُ العَيْنَيْنِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A good word"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expression"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentence."},{"kind":"text","text":"(TA.)       -A2-  The saying of J [in the S], (K,) in which he has followed his maternal uncle El-Fárábee, (TA,) that it signifies The"},{"kind":"italic_en","text":"portion of skin between the eye and the nose,"},{"kind":"text","text":"is a mistake; (IB, K;) and his citation, as an authority, of the verse of 'AbdAllah Ibn-'Omar (K) in which he says,"},{"kind":"quote","text":"wajilodapu bayona AlEayoni waAlA^anofi saAlimu"},{"kind":"text","text":"(TA,) is futile: (K:) for, as IB says, Sálim was the son of Ibn-'Omar, who, by reason of his love of him, thus makes him to be as the skin between his eyes and his nose: or, as MF says, the truth is, that the said verse is by Zuheyr, and Ibn-'Omar used it as a proverb: and [SM says], if this be correct, it strengthens the saying of J. (TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D9%84%D9%85/","headword_ar":"سالم","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23302#7b3fa6","body_html":"<span>السالم: عند الصرفيين ما سلمت حروفه الأصلية، التي تقابل بالفاء والعين واللام، من حروف العلة، والهمزة، والتضعيف، وعند النحويين: ما ليس في آخره حرف علة، سواء كان في غيره أو لا، وسواء كان أصليًا أو زائدًا، فيكون نصر سالمًا عند الطائفتين، ورمى غير سالم عندهما، وباع غير سالم عند الصرفيين وسالمًا عند النحويين، وسنلقى سالمًا عند الصرفيين، وغير سالم عند النحويين.</span>"}]}}