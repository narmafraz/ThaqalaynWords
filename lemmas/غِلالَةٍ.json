{"lemma":"غِلالَةٍ","slug":"غِلالَةٍ","root":"غ.ل.ل","root_slug":"غ-ل-ل","root_link":"/words/roots/غ-ل-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n32173","n32174"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%90%D9%84%D8%A7%D9%84%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"garment that sits directly on the body, undergarment, tunic"},{"pos":"noun","gloss":"a diaphanous cape, mantilla, veil"},{"pos":"noun","gloss":"the rivet that closes the ring of a mailcoat (in the plural: mailcoat, gambeson beneath a mailcoat) (obsolete)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32173","headword_ar":"غَلَالَةٌ","root":"gl","body":[{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"gulaAlapN","text_ar":"غُلَالَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"galalN","text_ar":"غَلَلٌ"},{"kind":"text","text":", last sentence."}],"source_refs":[]},{"entry_id":"n32174","headword_ar":"غِلَالَةٌ","root":"gl","body":[{"kind":"italic_en","text":"A garment that is worn next the body, beneath the other garment,"},{"kind":"text","text":"(S, O, K,) and"},{"kind":"italic_en","text":"likewise beneath the coat of mail;"},{"kind":"text","text":"(S, O;) also called ↓"},{"kind":"arabic","text_bw":"gul~apN","text_ar":"غُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) pl. [of the former]"},{"kind":"arabic","text_bw":"galaAy^ilu","text_ar":"غَلَايِلُ"},{"kind":"text","text":"and [of the latter]"},{"kind":"arabic","text_bw":"gulalN","text_ar":"غُلَلٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"A piece of cloth with which a woman makes her posteriors"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to appear"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"large,"},{"kind":"text","text":"(O, * K, * TA,)"},{"kind":"italic_en","text":"binding it upon her hinder part, beneath her waist-wrapper;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"gul~apN","text_ar":"غُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"gulalN","text_ar":"غُلَلٌ"},{"kind":"text","text":". (IB, TA.) ―         -b3-  And The"},{"kind":"italic_en","text":"pin that connects the two heads of the ring"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a coat of mail"},{"kind":"text","text":"]: (O, K:) pl."},{"kind":"arabic","text_bw":"galaAy^ilu","text_ar":"غَلَايِلُ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"galaAy^ilu","text_ar":"غَلَايِلُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Coats of mail:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"pins thereof that connect the heads of the rings:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"linings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inner coverings, that are worn beneath them,"},{"kind":"text","text":"(K, TA,) i. e."},{"kind":"italic_en","text":"beneath the coats of mail:"},{"kind":"text","text":"and [it is said that] the sing. thereof is ↓"},{"kind":"arabic","text_bw":"galiylapN","text_ar":"غَلِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.)"}],"source_refs":["S","O","K","TA"]}]},"classical_definitions":null}