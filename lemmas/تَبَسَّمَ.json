etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n2573"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D9%8E%D8%B3%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to smile"},{"pos":"noun","gloss":"verbal noun of تَبَسَّمَ (tabassama) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"smiling"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2573","headword_ar":"تبسّم","root":"bsm","body":[{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Abtsm","text_ar":"ابتسم","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"basama","text_ar":"بَسَمَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"basomN","text_ar":"بَسْمٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"mabosamN","text_ar":"مَبْسَمٌ"},{"kind":"text","text":"; (K, * TA;) ["},{"kind":"italic_en","text":"He smiled;"},{"kind":"text","text":"] these verbs signify less than"},{"kind":"arabic","text_bw":"DaHika","text_ar":"ضَحِكَ"},{"kind":"text","text":"[so that they are properly explained by the Latin"},{"kind":"italic_en","text":"subrisit"},{"kind":"text","text":"]: (S, Msb:) or"},{"kind":"italic_en","text":"he opened his lips like him who displays to another his teeth:"},{"kind":"text","text":"(Lth, TA:) or"},{"kind":"italic_en","text":"he laughed in the least degree and in the most beautiful manner:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he laughed a little without any sound:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"tabas~umN","text_ar":"تَبَسُّمٌ"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"beginning of"},{"kind":"arabic","text_bw":"DaHikN","text_ar":"ضَحِكٌ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"laughter"},{"kind":"text","text":"]: (Towsheeh, and Neseem er-Riyád, in TA art."},{"kind":"arabic","text_bw":"DHk","text_ar":"ضحك"},{"kind":"text","text":", q. v.:) accord. to Zj, it is the utmost degree of laughing of the prophets. (M.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Als~aHaAbu","text_ar":"السَّحَابُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Abtsm","text_ar":"ابتسم","orth_type":"arrow"},{"kind":"arabic","text_bw":"Eani Albaroqi","text_ar":"عَنِ البَرْقِ"},{"kind":"text","text":"(M,) or"},{"kind":"arabic","text_bw":"tbs~m Eanohu","text_ar":"تبسّم عَنْهُ"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ainokal~a Enh","text_ar":"اِنْكَلَّ عنه"},{"kind":"text","text":"[i. e. (tropical:)"},{"kind":"italic_en","text":"The clouds displayed a faint flashing of lightning"},{"kind":"text","text":"]. (M, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"tbs~m AlT~aloEu","text_ar":"تبسّم الطَّلْعُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The extremities of the"},{"kind":"arabic","text_bw":"TlE","text_ar":"طلع"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"spadix,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"spathe, of the palm-tree,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"burst asunder."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","Msb","K","Lth","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%A8%D8%B3%D9%85/","headword_ar":"تبسم","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23037#e11dec","body_html":"<span>التبسم: ما لا يكون مسموعًا له ولجيرانه.</span>"}]}}