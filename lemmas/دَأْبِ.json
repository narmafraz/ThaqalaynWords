{"lemma":"دَأْبِ","slug":"دَأْبِ","root":"د.#.ب","root_slug":"د-_-ب","root_link":"/words/roots/د-_-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"دَأْب","root":"دأب","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n11922","n11925","n11924"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%A3%D9%92%D8%A8%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to persevere, to persist"},{"pos":"verb","gloss":"to devote oneself, to be zealous, to strive"}]},"etymology":null,"ipa":["/da.ʔa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11922","headword_ar":"دَاَبَ","root":"dA^b","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"text","text":", (T, M, A, K,) inf. n."},{"kind":"arabic","text_bw":"daA^obN","text_ar":"دَاْبٌ"},{"kind":"text","text":"(T, S, M, A, K) and"},{"kind":"arabic","text_bw":"daA^abN","text_ar":"دَاَبٌ"},{"kind":"text","text":"(T, M, A, K) and"},{"kind":"arabic","text_bw":"duw^uwbN","text_ar":"دُوُوبٌ"},{"kind":"text","text":", (T, S, M, A, K,)"},{"kind":"italic_en","text":"He strove, laboured, toiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exerted himself;"},{"kind":"text","text":"(T, S, A, K;) and"},{"kind":"italic_en","text":"wearied himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became wearied;"},{"kind":"text","text":"(S, A, K;) in his work, (S, A, K,) or in a thing, (T,) and in a journey or journeying; (T, A;) in which last case,"},{"kind":"arabic","text_bw":"daA^abato","text_ar":"دَاَبَتْ"},{"kind":"text","text":"is said of a she-camel, (T,) or of a"},{"kind":"arabic","text_bw":"daAb~ap","text_ar":"دَابَّة"},{"kind":"text","text":"[or horse or the like]: (A:) or"},{"kind":"italic_en","text":"he held on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued,"},{"kind":"text","text":"(M, and Bd in viii. 54,) in his work, and his way. (Bd ibid.) See also 4. Hence,"},{"kind":"arabic","text_bw":"All~ayolu waAln~ahaAru yadoA^abaAni fiY A@EotiqaAbihimaA","text_ar":"اللَّيْلُ وَالنَّهَارُ يَدْاَبَانِ فِى ا@عْتِقَابِهِمَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The night and the day hold on their course in their alternating"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"daA^obN","text_ar":"دَاْبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"duw^uwbN","text_ar":"دُوُوبٌ"},{"kind":"text","text":"(TA) also signify The"},{"kind":"italic_en","text":"act of driving vehemently;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"TarodN","text_ar":"طَرْدٌ"},{"kind":"text","text":"[the"},{"kind":"italic_en","text":"act of driving away, hunting,"},{"kind":"text","text":"&c.]. (K, TA.)"}],"source_refs":["T","M","A","K","S","TA"]},{"entry_id":"n11925","headword_ar":"دَاَبَ","root":"dA^b","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]},{"entry_id":"n11924","headword_ar":"دَاْبٌ","root":"dA^b","body":[{"kind":"text","text":"(T, S, M, A, K) and ↓"},{"kind":"arabic","text_bw":"daA^abN","text_ar":"دَاَبٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, K) [both originally inf. ns. of 1: and hence,] (tropical:)"},{"kind":"italic_en","text":"A custom, manner, habit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wont:"},{"kind":"text","text":"(A'Obeyd, T, S, M, K:)"},{"kind":"italic_en","text":"an affair, a business,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a concern:"},{"kind":"text","text":"(Zj, T, S, A, K:) and"},{"kind":"italic_en","text":"a case, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition:"},{"kind":"text","text":"(Zj, * T, * S, * M, A, * K: *) and"},{"kind":"italic_en","text":"a deed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"work."},{"kind":"text","text":"(A.) You say,"},{"kind":"arabic","text_bw":"h`*aA daA^obuka","text_ar":"هٰذَا دَاْبُكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"This is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thy custom,"},{"kind":"text","text":"&c.:]"},{"kind":"italic_en","text":"thy affair, business,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concern:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy case, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"thy deed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"work."},{"kind":"text","text":"(A.) Zj says that"},{"kind":"arabic","text_bw":"kadaA^obi A=li firoEawona","text_ar":"كَدَاْبِ ا=لِ فِرْعَوْنَ"},{"kind":"text","text":"[in the Kur iii. 9 &c.] means, accord. to the lexicologists, (assumed tropical:)"},{"kind":"italic_en","text":"Like the case of the people of Pharaoh:"},{"kind":"text","text":"but in his opinion,"},{"kind":"italic_en","text":"like the striving, labouring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toiling, of the people of Pharaoh in their unbelief, and their leaguing together and aiding one another"},{"kind":"text","text":"against Moses. (T.)"}],"source_refs":["T","S","M","A","K","Zj"]}]},"classical_definitions":null}