{"lemma":"بَخْسِ","slug":"بَخْسِ","root":"ب.خ.س","root_slug":"ب-خ-س","root_link":"/words/roots/ب-خ-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بَخْس","root":"بخس","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1888"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%AE%D9%92%D8%B3%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to belittle, debase"}]},"etymology":null,"ipa":["/bax.xa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1888","headword_ar":"بَخْسٌ","root":"bxs","body":[{"kind":"italic_en","text":"Deficient; defective."},{"kind":"text","text":"(S.) It is said in the Kur [xii. 20],"},{"kind":"arabic","text_bw":"wa$arawohu bivamanK baxosK","text_ar":"وَشَرَوْهُ بِثَمَنٍ بَخْسٍ"},{"kind":"italic_en","text":"And they sold him for a deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective, price:"},{"kind":"text","text":"(S, * Msb, * TA:) or"},{"kind":"italic_en","text":"for a price less than was incumbent:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for an insufficient price:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for an unjust price;"},{"kind":"text","text":"accord. to Zj; because the sale of a man that has been found is unlawful. (TA.)       -A2-"},{"kind":"italic_en","text":"Land that produces herbage without being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"artificially"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"watered:"},{"kind":"text","text":"(JK, S, K:) or"},{"kind":"italic_en","text":"land which is watered by the rain;"},{"kind":"text","text":"because it has deficient watering: (Mgh:) pl."},{"kind":"arabic","text_bw":"buxuwsN","text_ar":"بُخُوسٌ"},{"kind":"text","text":". (JK, TA.) ―         -b2-  Also, (TA, as from Ibn-Málik,) or ↓"},{"kind":"arabic","text_bw":"baxosiY~N","text_ar":"بَخْسِىٌّ","orth_type":"arrow"},{"kind":"text","text":", [which is more probably the correct form,] a rel. n. from"},{"kind":"arabic","text_bw":"baxosN","text_ar":"بَخْسٌ"},{"kind":"text","text":"in the sense immediately preceding, explained in the T as signifying, (Mgh,) Seed-produce"},{"kind":"italic_en","text":"that is not irrigated with water from a spring or well or the like, but only by the rain."},{"kind":"text","text":"(Mgh, and TA from Ibn-Málik.)"}],"source_refs":["JK","S","K","Mgh"]}]},"classical_definitions":null}