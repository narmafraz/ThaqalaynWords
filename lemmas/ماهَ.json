s":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to produce water (of a well, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to abound with water (of a well, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to take on water (of a ship)","tags":["intransitive"]},{"pos":"verb","gloss":"to give water to, to hydrate; to water (an animal)","tags":["transitive"]},{"pos":"verb","gloss":"to give water to, to hydrate; to gild, to coat with gold or similar material","tags":["transitive"]},{"pos":"verb","gloss":"to give water to, to hydrate; to err [with فِي (fī) ‘in one's words’], to make a slip of the tongue","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to abound with water","tags":["intransitive"]},{"pos":"verb","gloss":"to mix","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Formally from م و ه (m w h) and its variant, م ي ه (m y h), both of which derive denominally from مَاء (māʔ), itself being ultimately from Proto-Semitic *māy-."},"ipa":["/maː.ha/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%A7%D9%87/","headword_ar":"ماهان","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=146591#6132c7","body_html":"ماهان:<br>إن كان عربيّا فهو تثنية الماء الذي يشرب لأن أصله الهاء وإلا فهو فارسيّ، وهو تثنية الماء وهي القصبة كما يذكر في ماه البصرة بعده، والماهان: الدّينور ونهاوند. وماهان: مدينة بكرمان، وبينها وبين السِّيرجان مدينة كرمان مرحلتان، وبينها وبين خبيص خمس مراحل، والعرب تسميها بالجمع فتقول الماهات، قال القعقاع بن عمرو:<br>جدعت على الماهات آنف فارس ... بكل فتى من صلب فارس خادر<br>هتكت بيوت الفرس يوم لقيتها، ... وما كلّ من يلقى الحروب بثائر<br>حبست ركاب الفيرزان وجمعه ... على فتر من جرينا غير فاتر<br>هدمت بها الماهات والدرب بغتة ... إلى غاية أخرى الليالي الغوابر<br>وقال أيضا:<br>هم هدموا الماهات بعد اعتدالها ... بصحن نهاوند التي قد أمرّت<br>بكل قناة لدنة برميّة ... إذا أكرهت لم تنثني واستمرّت<br>وأبيض من ماء الحديد مهنّد، ... وصفراء من نبع إذا هي رنّت"}]}}