ttps://lanelexicon.com/?s=%D9%86%D9%8E%D9%87%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"river"},{"pos":"verb","gloss":"to flow forth upon, to betide"},{"pos":"verb","gloss":"to yell at, to reprimand, to rebuff, to chide","examples":[{"text":"لَا تَنْهَرْ وَالِدَيْكَ!","english":"Don't yell at your parents!"}]},{"pos":"noun","gloss":"verbal noun of نَهَرَ (nahara) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-Semitic *nahar- (“river”).\n\nDenominal from نَهْر (nahr)."},"ipa":["/nahr/","/na.har/","/na.ha.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40631","headword_ar":"نَهَرَ","root":"nhr","body":[{"kind":"text","text":", (S, Msb,) aor."},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"ran upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"along, the ground,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"and made for itself a"},{"kind":"arabic","text_bw":"nahor","text_ar":"نَهْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"channel like that of a river"},{"kind":"text","text":"]. (S.) See also 10. ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything, as in one copy of the S, or anything copious, as in another copy of the S and in the TA)"},{"kind":"italic_en","text":"ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"Astnhr","text_ar":"استنهر","orth_type":"arrow"},{"kind":"text","text":", (S,) or ↓"},{"kind":"arabic","text_bw":"Anthr","text_ar":"انتهر","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(blood)"},{"kind":"italic_en","text":"flowed with force:"},{"kind":"text","text":"(Msb:)"},{"kind":"page_break","n":2858},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^anohara","text_ar":"اَنْهَرَ","orth_type":"arrow"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(blood)"},{"kind":"italic_en","text":"flowed"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"like a river:"},{"kind":"text","text":"(TA:) and the latter also,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a vein)"},{"kind":"italic_en","text":"flowed and would not stop;"},{"kind":"text","text":"(K, TA;) meaning,"},{"kind":"italic_en","text":"it flowed like a river;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Anthr","text_ar":"انتهر","orth_type":"arrow"},{"kind":"text","text":": (Sgh, K, TA:) and ↓"},{"kind":"arabic","text_bw":"Anhr","text_ar":"انهر","orth_type":"arrow"},{"kind":"text","text":"also signifies the same said of the belly; (TA;) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the belly)"},{"kind":"italic_en","text":"became loose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relaxed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it discharged itself;"},{"kind":"text","text":"(JK;) as also ↓"},{"kind":"arabic","text_bw":"Anthr","text_ar":"انتهر","orth_type":"arrow"},{"kind":"text","text":". (JK, K.)       -A2-"},{"kind":"arabic","text_bw":"nahara","text_ar":"نَهَرَ"},{"kind":"text","text":", (S, K.) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"nahorN","text_ar":"نَهْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"dug"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"nahor","text_ar":"نَهْر"},{"kind":"text","text":"[or channel for a river]: (S, TA:)"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"nahor","text_ar":"نَهْر"},{"kind":"text","text":"[or river]"},{"kind":"italic_en","text":"to run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flow."},{"kind":"text","text":"(K, TA.)       -A3-"},{"kind":"arabic","text_bw":"nahra","text_ar":"نَهرَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nahorN","text_ar":"نَهْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made an inroad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incursion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inroads"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incursions, into the territory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"territories of enemies, in the day-time."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"naharahu","text_ar":"نَهَرَهُ"},{"kind":"text","text":", (S, Mgh, Msb, K, &c.,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nahorN","text_ar":"نَهْرٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Anthrhu","text_ar":"انتهرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, Msb, K, &c.;)"},{"kind":"italic_en","text":"He chid him; he checked him, restrained him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forbade him, with rough speech;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zajarahu","text_ar":"زَجَرَهُ"},{"kind":"text","text":", (Mgh, Msb, K, and so in a copy of the S,) or"},{"kind":"arabic","text_bw":"zabarahu","text_ar":"زَبَرَهُ"},{"kind":"text","text":", (as in another copy of the S,)"},{"kind":"arabic","text_bw":"bikalaAmK galiyZK","text_ar":"بِكَلَامٍ غَلِيظٍ"},{"kind":"text","text":": (Mgh:)"},{"kind":"italic_en","text":"be addressed him with chiding speech,"},{"kind":"text","text":"(JK, A,)"},{"kind":"italic_en","text":"forbidding him from doing evil."},{"kind":"text","text":"(JK. [in the TA, citing the last explanation from the T,"},{"kind":"arabic","text_bw":"Eano xayorK","text_ar":"عَنْ خَيْرٍ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Eano $ar~K","text_ar":"عَنْ شَرٍّ"},{"kind":"text","text":".]) It is said in the Kur, [xciii. 10,]"},{"kind":"arabic","text_bw":"waA^am~aA A@ls~aAy^ila falaA tanoharo","text_ar":"وَاَمَّا ا@لسَّايِلَ فَلَا تَنْهَرْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And as for the beggar, thou shalt not chide"},{"kind":"text","text":"him, or"},{"kind":"italic_en","text":"address"},{"kind":"text","text":"him"},{"kind":"italic_en","text":"with rough speech"},{"kind":"text","text":"]. And in a trad.,"},{"kind":"arabic","text_bw":"mani A@notahara","text_ar":"مَنِ ا@نْتَهَرَ"},{"kind":"arabic","text_bw":"SaAHiba bidoEapK malaA^a A@ll~`hu qalobahu A^amonFA wiA_iymaAnFA waA^am~anahu A@ll~`hu","text_ar":"صَاحِبَ بِدْعَةٍ مَلَاَ ا@للّٰهُ قَلْبَهُ اَمْنًا وِاـِيمَانًا وَاَمَّنَهُ ا@للّٰهُ"},{"kind":"arabic","text_bw":"mina AlfazaEi A@loA^akobar","text_ar":"مِنَ الفَزَعِ ا@لْاَكْبَر"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whoso chideth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"checketh with rough speech, the author of an innovation in religion, God will fill his heart with security and faith, and God will preserve him from the greatest terror"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Msb","TA","K","Sgh","Mgh","JK","A"]}]},"classical_definitions":null}