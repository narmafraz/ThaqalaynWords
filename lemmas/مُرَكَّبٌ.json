n", "text": "to whom a horse has been given for him to ride, and who has put his foot into the stirrup."}, {"kind": "text", "text": "(A.) [Also]"}, {"kind": "italic_en", "text": "Weak in the art of horsemanship,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the management of horses, and the riding of them."}, {"kind": "text", "text": "(Ham p. 441.) ―         -b2-  [Also"}, {"kind": "italic_en", "text": "Put,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "set, one part upon another: set,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fixed,"}, {"kind": "text", "text": "in another thing:"}, {"kind": "italic_en", "text": "composed; constituted;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "put together:"}, {"kind": "text", "text": "see its verb, 2.] The stone ["}, {"kind": "italic_en", "text": "set"}, {"kind": "text", "text": "] in the signet-ring is termed"}, {"kind": "arabic", "text_bw": "murak~abN", "text_ar": "مُرَكَّبٌ"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "rakiybN", "text_ar": "رَكِيبٌ", "orth_type": "arrow"}, {"kind": "text", "text": "; and so the arrowhead ["}, {"kind": "italic_en", "text": "fixed"}, {"kind": "text", "text": "] in the shaft: (S:) or"}, {"kind": "arabic", "text_bw": "rakiybN", "text_ar": "رَكِيبٌ"}, {"kind": "text", "text": "signifies, (K, TA,) as a subst., (TA,)"}, {"kind": "italic_en", "text": "a thing set"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "murak~abN", "text_ar": "مُرَكَّبٌ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "in a thing,"}, {"kind": "text", "text": "such as a ring-stone in the bezel, or collet, of the signet-ring. (K, * TA.)       -A2-  Also (tropical:)"}, {"kind": "italic_en", "text": "Origin:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "place of growth"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "germination"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "vegetation."}, {"kind": "text", "text": "(S, K, TA.) You say,"}, {"kind": "arabic", "text_bw": "fulaAnN", "text_ar": "فُلَانٌ"}, {"kind": "arabic", "text_bw": "kariymu Almurak~abi", "text_ar": "كَرِيمُ المُرَكَّبِ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "Such a one is generous,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "noble, in respect of the origin of his rank among his people."}, {"kind": "text", "text": "(S, A. *)"}], "source_refs": ["IAar", "TA", "K", "S"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}