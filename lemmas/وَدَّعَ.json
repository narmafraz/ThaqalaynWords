en":"m","num":"p"},{"role":"present_2mp","form":"تُوَدِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُوَدِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُوَدِّع","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُوَدِّع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُوَدِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُوَدِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوَدِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَدِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَدِّعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَدِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَدِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"وَدَّعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَدَّعْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَدِّع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَدِّع","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":38,"cross_references":{"qac":{"found":true,"lemma_key":"وَدَّعَ","root":"ودع","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n44495"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%AF%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lay down, to place, to leave"},{"pos":"verb","gloss":"to let, to let be, to suffer"},{"pos":"verb","gloss":"to take leave; to say goodbye; to bid farewell"},{"pos":"verb","gloss":"to forsake","examples":[{"text":"وَٱلضُّحَى وَٱللَّيْلِ إِذَا سَجَى مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى","english":"By the forenoon, and the night when it is the stillest, thy Lord hath not forsaken thee nor doth He hate thee."}]},{"pos":"noun","gloss":"seashell, cowry","tags":["collective"],"examples":[{"text":"ويضعن على رؤوسهنّ تمائم من حبّ نبات يسمّى الشوش وهو حبّ صغير أحمر كالجُلَّنار وفي جانب كلّ حبّة منه نكتة سوداء وهذا الحبّ رؤيته مفرحة جدًّا وودع وفول وهذا الفول عندهم ذو ألوان منه ما هو أحمر ناصع الحمرة ومنه ما هو تِبْنيّ اللون ومنه ما هو أسود ومنه عسليّ فيثقبن الشوش والودع والفول وينظمن الشوش وحده تمائم لكن يجعلن في أسفل كلّ تميمة إمّا جلجلًا أو ودعة ويجعلنها عناقيد هكذا لكن يفصلن بين كلّ تعريجة بخرز أزرق.","english":"On their heads, the women place amulets made from the seeds of a plant called šūš—the seeds are small and red, like those of the pomegranate flower; each has a black spot on its side and they are very pleasing to the eye—as well as amulets made of shells and of beans. In their country, these beans are colored, some being bright red, some straw-colored, some black, some honey-colored. They bore a hole in the šūš, the shells, or the beans. They also make the šūš into amulets on their own, though they attach to the bottom of each amulet either a little bell or a shell, and make them into clusters, like this: However, they separate each pedicel from the next with a blue bead."}]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *wadaʕ- attested in every corner of the Semitic language area with the meaning “to know”, apparently with desert-specific meaning specialization in Arabic of a thing being “left” somewhere being equated with remembering and “knowing” where it is. The sea-shell is also so called due to being “left over” by nature or placed on amulets; supposedly دَعَا (daʕā, “to call”) is from the current imperative usage."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44495","headword_ar":"وَدُعَ","root":"wdE","body":[{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"wadoEN","text_ar":"وَدْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daEapN","text_ar":"دَعَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, TA,)"},{"kind":"italic_en","text":"became still, quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at rest;"},{"kind":"text","text":"(S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Ait~adaEa","text_ar":"اِتَّدَعَ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) [quasi-] inf. n."},{"kind":"arabic","text_bw":"tudoEapN","text_ar":"تُدْعَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tudaEapN","text_ar":"تُدَعَةٌ"},{"kind":"text","text":". (TA.) You say to a man, ↓"},{"kind":"arabic","text_bw":"Ain~adaEo","text_ar":"اِنَّدَعْ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tawad~aEo","text_ar":"تَوَدَّعْ","orth_type":"arrow"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"Be thou grave, staid, steady, sedate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm."},{"kind":"text","text":"(TA.) See also 1; and art."},{"kind":"arabic","text_bw":"w*r","text_ar":"وذر"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"waduEa","text_ar":"وَدُعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wadaEa","text_ar":"وَدَعَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wadaAEapN","text_ar":"وَدَاعَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of ease, and ampleness of the means"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances of life."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"daEo","text_ar":"دَعْ"},{"kind":"text","text":": see an ex. voce"},{"kind":"arabic","text_bw":"A=*aY","text_ar":"ا=ذَى"},{"kind":"text","text":": it may be rendered, in different cases,"},{"kind":"italic_en","text":"Leave thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"say nothing of:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"baloha","text_ar":"بَلْهَ"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"daEoniY mino ka*aA","text_ar":"دَعْنِى مِنْ كَذَا"},{"kind":"italic_en","text":"Let me alone and cease from such a thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"exempt thou me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excuse me, from such a thing."},{"kind":"text","text":"―         -b5-"},{"kind":"arabic","text_bw":"daEo Eanoka ka*aA","text_ar":"دَعْ عَنْكَ كَذَا"},{"kind":"italic_en","text":"Dismiss thou from thee such a thing."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"xu*o","text_ar":"خُذْ"},{"kind":"arabic","text_bw":"Eanoka","text_ar":"عَنْكَ"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"daEo maA yariybuka A_ilaY laA yariybuka","text_ar":"دَعْ مَا يَرِيبُكَ اـِلَى لَا يَرِيبُكَ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"ryb","text_ar":"ريب"},{"kind":"text","text":". ―         -b7-"},{"kind":"arabic","text_bw":"daEo maA zayodN","text_ar":"دَعْ مَا زَيْدٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"siY~N","text_ar":"سِىٌّ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"swY","text_ar":"سوى"},{"kind":"text","text":". ―         -b8-"},{"kind":"arabic","text_bw":"wadaEa","text_ar":"وَدَعَ"},{"kind":"text","text":"used as a pret.: see an ex. voce"},{"kind":"arabic","text_bw":"zaAy^ilapN","text_ar":"زَايِلَةٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"zwl","text_ar":"زول"},{"kind":"text","text":"."}],"source_refs":["S","K","TA"]}]}}