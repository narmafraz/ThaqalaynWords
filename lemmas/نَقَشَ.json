:"m","num":"p"},{"role":"present_2mp","form":"تَنْقُشُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْقُشْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْقُش","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْقُش","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْقُشانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْقُشا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْقُشانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْقُشا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْقُشُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْقُشُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْقُشْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَقَشْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَقَشْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْقُش","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْقُش","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n40398"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%82%D9%8E%D8%B4%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to emboss; to variegate, to give different colours, to decorate, to embellish"},{"pos":"verb","gloss":"to emboss; to engrave, to carve, to inscribe, to scratch, to peck, vel sim."},{"pos":"verb","gloss":"to extract, to draw out, to pull out"},{"pos":"verb","gloss":"synonym of نَقَشَ (naqaša)"},{"pos":"noun","gloss":"verbal noun of نَقَشَ (naqaša) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40398","headword_ar":"نَقَشَ","root":"nq$","body":[{"kind":"text","text":", (S, M, Msb,) aor."},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"naqo$N","text_ar":"نَقْشٌ"},{"kind":"text","text":". (S, M, A, Msb, K,)"},{"kind":"italic_en","text":"He variegated"},{"kind":"text","text":"a thing; or"},{"kind":"italic_en","text":"decorated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embellished"},{"kind":"text","text":"it; syn."},{"kind":"arabic","text_bw":"namonama","text_ar":"نَمْنَمَ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"Antq$","text_ar":"انتقش","orth_type":"arrow"},{"kind":"text","text":": (M:) ["},{"kind":"italic_en","text":"he charactered"},{"kind":"text","text":"in any manner a coin &c.:] and"},{"kind":"italic_en","text":"he engraved,"},{"kind":"text","text":"agreeably with modern usage:"},{"kind":"italic_en","text":"he coloured"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with two colours,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"with colours;"},{"kind":"text","text":"(A, K;) and ↓"},{"kind":"arabic","text_bw":"nq~$","text_ar":"نقّش","orth_type":"arrow"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"tanoqiy$u","text_ar":"تَنْقِيشُ"},{"kind":"text","text":", (S, K,) signifies the same. (S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"naqa$a fY xaAtamihi ka*aA","text_ar":"نَقَشَ فى خَاتَمِهِ كَذَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EalaY faS~i xaAtamihi","text_ar":"عَلَى فَصِّ خَاتَمِهِ"},{"kind":"text","text":", (A,) inf. n. as above, (K,) ["},{"kind":"italic_en","text":"He engraved upon his signet-ring such a thing,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"upon the stone of his signet-ring:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"naqa$a","text_ar":"نَقَشَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"he marked with a cutting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pointed instrument: he sculptured"},{"kind":"text","text":"a thing in any manner.] ―         -b3-"},{"kind":"arabic","text_bw":"naqa$a Alr~aHaA","text_ar":"نَقَشَ الرَّحَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He pecked the mill-stone with a"},{"kind":"arabic","text_bw":"minoqaAr","text_ar":"مِنْقَار"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"naqarahaA","text_ar":"نَقَرَهَا"},{"kind":"text","text":". (A, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"naqa$a","text_ar":"نَقَشَ"},{"kind":"text","text":", inf. n. as above, also signifies"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, scratched, lacerated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wounded in the outer skin."},{"kind":"text","text":"(TA.) They said,"},{"kind":"arabic","text_bw":"kaA^an~a wajohahu nuqi$a biqataAdapK","text_ar":"كَاَنَّ وَجْهَهُ نُقِشَ بِقَتَادَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"As though his face were scratched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lacerated, by a tragacanth-bush"},{"kind":"text","text":"]; syn."},{"kind":"arabic","text_bw":"xudi$a","text_ar":"خُدِشَ"},{"kind":"text","text":": relating to hatefulness, and austerity or moroseness of countenance, (M, TA,) and anger. (M.) ―         -b5-"},{"kind":"arabic","text_bw":"naqo$u AlEi*oqi","text_ar":"نَقْشُ العِذْقِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The striking the raceme of dates with thorns, in order that the dates may ripen:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"and their consequently ripening."},{"kind":"text","text":"(AA.) And one says,"},{"kind":"arabic","text_bw":"nuqi$a AlEi*oqu","text_ar":"نُقِشَ العِذْقُ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"The raceme of dates had specks apparent in it, in consequence of ripening."},{"kind":"text","text":"(S.) ―         -b6-  And [hence, perhaps,]"},{"kind":"arabic","text_bw":"naqo$N","text_ar":"نَقْشٌ"},{"kind":"text","text":"is used as (tropical:)"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"jimaAEN","text_ar":"جِمَاعٌ"},{"kind":"text","text":"(S, A, Sgh, K,) accord. to AA, (S,) or IAar; (Sgh;)"},{"kind":"arabic","text_bw":"naqa$a","text_ar":"نَقَشَ"},{"kind":"text","text":"signifying (tropical:)"},{"kind":"italic_en","text":"Inivit"},{"kind":"text","text":"puellam. (T, K.) [This signification is mentioned in the A among those which are proper; but in the TA it is said, to be tropical.]       -A2-  Also"},{"kind":"arabic","text_bw":"naqa$a","text_ar":"نَقَشَ"},{"kind":"text","text":", (S, M, A, Msb,) aor. as above, (M, TA,) and so the inf. n., (S, M, Msb, K,)"},{"kind":"italic_en","text":"He extracted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulled, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"a thorn (S, M, A, Msb, K) from his foot, (S, M,)"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"minoqa$","text_ar":"مِنْقَش"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"minoqaA$","text_ar":"مِنْقَاش"},{"kind":"text","text":"; (Msb, K; *) as also ↓"},{"kind":"arabic","text_bw":"Antq$","text_ar":"انتقش","orth_type":"arrow"},{"kind":"text","text":": (S, M, A, K:) thought by A 'Obeyd to be from"},{"kind":"arabic","text_bw":"AlmunaAqa$apu","text_ar":"المُنَاقَشَةُ"},{"kind":"text","text":"; but others say the reverse: (TA:) and in like manner, bones from a wound in the head: (S, K:) and"},{"kind":"italic_en","text":"he plucked out"},{"kind":"text","text":"(S, A,) hair, (A,)"},{"kind":"italic_en","text":"with the"},{"kind":"arabic","text_bw":"minoqaA$","text_ar":"مِنْقَاش"},{"kind":"text","text":"; (S, A;) as also ↓"},{"kind":"arabic","text_bw":"Antq$","text_ar":"انتقش","orth_type":"arrow"},{"kind":"text","text":". (A.) A certain poet says, (namely, Yezeed Ibn-Maksam [?] EthThakafee, O in art."},{"kind":"arabic","text_bw":"$wk","text_ar":"شوك"},{"kind":"text","text":",)"},{"kind":"quote","text":"laA tanoqu$an~a birijoli gayorika $awokapF\n                      \n                     \n                        fataqiY birijolika rijola mano qado $aAkahaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Do not thou by any means extract from the foot of another a thorn, and so preserve, by"},{"kind":"text","text":"(risking)"},{"kind":"italic_en","text":"thy foot, the foot of him who has pierced himself therewith"},{"kind":"text","text":"]: the [former]"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"is put in the place of"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":": he says, do not thou extract from the foot of another a thorn and put it in thy foot: (TA:) or"},{"kind":"arabic","text_bw":"mano $aAkahaA","text_ar":"مَنْ شَاكَهَا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"who has entered among the thorns."},{"kind":"text","text":"(S and O, in art."},{"kind":"arabic","text_bw":"$wk","text_ar":"شوك"},{"kind":"text","text":".) And it is said in a trad. of Aboo-Hureyreh,"},{"kind":"arabic","text_bw":"Eavara falaA A@notaEa$a wa$iyka falaA A@notaqa$a","text_ar":"عَثَرَ فَلَا ا@نْتَعَشَ وَشِيكَ فَلَا ا@نْتَقَشَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May he stumble, and not rise again; and may he be pierced with a thorn, and not extract the thorn"},{"kind":"text","text":"]: (M, TA: *) the words meaning an imprecation. (TA.) See also 8, below. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"naqa$a","text_ar":"نَقَشَ"},{"kind":"text","text":", aor. as above, (TA,) and so the inf. n., (K,)"},{"kind":"italic_en","text":"He cleared"},{"kind":"text","text":"the nightly resting-place of sheep or goats"},{"kind":"italic_en","text":"from thorns and the like,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"from what might hurt them, of stones and thorns and the like."},{"kind":"text","text":"(TA.) ―         -b3-  Hence also,"},{"kind":"arabic","text_bw":"naqa$a Eani Al$~aYo'i","text_ar":"نَقَشَ عَنِ الشَّىْءِ"},{"kind":"text","text":", (TK,) inf. n. as above, (IDrd, K,)"},{"kind":"italic_en","text":"He explored the thing to the utmost."},{"kind":"text","text":"(IDrd, K, TK.) ―         -b4-  [Hence also,]"},{"kind":"arabic","text_bw":"maA naqa$a minohu $ayoy^FA","text_ar":"مَا نَقَشَ مِنْهُ شَيْيًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He did not obtain from him anything:"},{"kind":"text","text":"but the word commonly known is"},{"kind":"arabic","text_bw":"nata$a","text_ar":"نَتَشَ"},{"kind":"text","text":". (M, TA.) See also 8."}],"source_refs":["S","M","Msb","A","K","TA","Sgh","TK","IDrd"]}]}}