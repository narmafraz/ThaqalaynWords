{"lemma":"بَلَدِ","slug":"بَلَدِ","root":"ب.ل.د","root_slug":"ب-ل-د","root_link":"/words/roots/ب-ل-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بَلَد","root":"بلد","pos":"N","occurrence_count":14},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n3158","n3159","n3163"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%84%D9%8E%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"country, land, homeland"},{"pos":"noun","gloss":"town, city"},{"pos":"noun","gloss":"place, village, community"},{"pos":"verb","gloss":"to acclimatize, to habituate"},{"pos":"verb","gloss":"to be stupid, to be dull-witted"}]},"etymology":{"source":"wiktextract","text":"Compare Ugaritic 𐎁𐎍𐎄 (bld)."},"ipa":["/ba.lad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3158","headword_ar":"بَلَدَ","root":"bld","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"buluwdN","text_ar":"بُلُودٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"remained, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, in the"},{"kind":"arabic","text_bw":"balad","text_ar":"بَلَد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town,"},{"kind":"text","text":"&c.]: (Msb:) or"},{"kind":"arabic","text_bw":"balada biAlmakaAna","text_ar":"بَلَدَ بِالمَكَانَ"},{"kind":"text","text":", (T, S, M, L, K,) aor."},{"kind":"text","text":", (M, L,) inf. n."},{"kind":"arabic","text_bw":"buluwdN","text_ar":"بُلُودٌ"},{"kind":"text","text":", (T, M, L, K,)"},{"kind":"italic_en","text":"he remained, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, in the place,"},{"kind":"text","text":"(AZ, T, S, L, K,)"},{"kind":"italic_en","text":"and kept to it:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he took it as his"},{"kind":"arabic","text_bw":"balad","text_ar":"بَلَد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town,"},{"kind":"text","text":"&c.], (M, L, K,)"},{"kind":"italic_en","text":"and kept to it."},{"kind":"text","text":"(M, L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"baliduwA","text_ar":"بَلِدُوا"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (M, K;) and"},{"kind":"arabic","text_bw":"baladuwA","text_ar":"بَلَدُوا"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) or the latter is correctly ↓"},{"kind":"arabic","text_bw":"bl~dwA","text_ar":"بلّدوا","orth_type":"arrow"},{"kind":"text","text":"; (M, * TA;)"},{"kind":"italic_en","text":"They kept to the ground, fighting upon it:"},{"kind":"text","text":"(M, K:) said to be derived from"},{"kind":"arabic","text_bw":"bilaAdu AlA^aroDi","text_ar":"بِلَادُ الاَرْضِ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"balida","text_ar":"بَلِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"His skin had"},{"kind":"arabic","text_bw":"A^abolaAd","text_ar":"اَبْلَاد"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"marks,"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"baladN","text_ar":"بَلَدٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"remaining upon it."},{"kind":"text","text":"(M, L.) ―         -b2-  Also, (M, K,) inf. n."},{"kind":"arabic","text_bw":"baladN","text_ar":"بَلَدٌ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, M)"},{"kind":"italic_en","text":"had a space clear from hair between his eyebrows:"},{"kind":"text","text":"(S, M, K:) or"},{"kind":"italic_en","text":"had eyebrows not joined."},{"kind":"text","text":"(M.)       -A3-"},{"kind":"arabic","text_bw":"baluda","text_ar":"بَلُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"balaAdapN","text_ar":"بَلَادَةٌ"},{"kind":"text","text":", (T, S, M, A, Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stupid, dull, wanting in intelligence:"},{"kind":"text","text":"(S, A, Msb:)"},{"kind":"italic_en","text":"inert; wanting in vigour; not penetrating, sharp, vigorous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effective, in the performance of affairs;"},{"kind":"text","text":"(T, M, K, * TA;) [or"},{"kind":"italic_en","text":"soft, weak, feeble, wanting in endurance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patience;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"baliydN","text_ar":"بَلِيدٌ"},{"kind":"text","text":";)] as also"},{"kind":"arabic","text_bw":"balida","text_ar":"بَلِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"baladN","text_ar":"بَلَدٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also, inf. n. as above, said of a horse, meaning"},{"kind":"italic_en","text":"He lagged behind those that outstripped in running."},{"kind":"text","text":"(T, TA.) [See also 2.] ―         -b3-"},{"kind":"arabic","text_bw":"balada Als~aHaAbu","text_ar":"بَلَدَ السَّحَابُ"},{"kind":"text","text":": see 2."}],"source_refs":["Msb","T","S","M","L","K","AZ","A","TA"]},{"entry_id":"n3159","headword_ar":"بلّد","root":"bld","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taboliydN","text_ar":"تَبْلِيدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode;"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"balada","text_ar":"بَلَدَ"},{"kind":"text","text":";] or"},{"kind":"italic_en","text":"cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laid, himself down upon the ground;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Daraba binafosihi AlA^aroDa","text_ar":"ضَرَبَ بِنَفْسِهِ الاَرْضَ"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"he did so by reason of fatigue."},{"kind":"text","text":"(TA. [See 5.]) See also"},{"kind":"arabic","text_bw":"baliduwA","text_ar":"بَلِدُوا"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"He became languid, and affected laziness,"},{"kind":"text","text":"after being brisk, lively, or sprightly. (A.) ―         -b3-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was impotent"},{"kind":"text","text":"in work, and"},{"kind":"italic_en","text":"was weak;"},{"kind":"text","text":"(T, L;) and so even in bounty, or liberality, (T,) or in running. (T, * L.) ―         -b4-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"failed to outstrip in running."},{"kind":"text","text":"(M, K.) [See also"},{"kind":"arabic","text_bw":"baluda","text_ar":"بَلُدَ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"italic_en","text":"He was niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious; was not liberal, nor generous."},{"kind":"text","text":"(M, K.) [And hence,]"},{"kind":"arabic","text_bw":"bal~adati Als~aHaAbapu","text_ar":"بَلَّدَتِ السَّحَابَةُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"Als~aHaAbu","text_ar":"السَّحَابُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"balada","text_ar":"بَلَدَ","orth_type":"arrow"},{"kind":"text","text":", (M,) [but the latter is probably imperfectly transcribed,]"},{"kind":"italic_en","text":"The cloud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clouds, gave no rain."},{"kind":"text","text":"(M, K.) ―         -b6-"},{"kind":"italic_en","text":"He did not apply himself rightly to anything."},{"kind":"text","text":"(M, K.)       -A2-"},{"kind":"arabic","text_bw":"bal~adati","text_ar":"بَلَّدَتِ"},{"kind":"arabic","text_bw":"AljibaAli","text_ar":"الجِبَالِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The mountains appeared low to the eye by reason of the darkness of the night:"},{"kind":"text","text":"so in the L, confirmed by a citation from a poet: in the A,"},{"kind":"arabic","text_bw":"AlbilaAdu","text_ar":"البِلَادُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tabal~adati","text_ar":"تَبَلَّدَتِ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The countries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regions,"},{"kind":"page_break","n":247},{"kind":"italic_en","text":"appeared short"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in extent"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the eye by reason of the darkness of the night."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","T","M"]},{"entry_id":"n3163","headword_ar":"بَلَدٌ","root":"bld","body":[{"kind":"text","text":"(which is masc. and fem., Msb) and ↓"},{"kind":"arabic","text_bw":"balodapN","text_ar":"بَلْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"both signify the same; (M, A, Msb, K;) namely, ["},{"kind":"italic_en","text":"A country, land, region, province, district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"territory:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a city, town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"any portion of the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of land, comprehended within certain limits,"},{"kind":"text","text":"[thus I render"},{"kind":"arabic","text_bw":"musotaHiyzap","text_ar":"مُسْتَحِيزَة"},{"kind":"text","text":", and in like manner it is rendered in the TK,]"},{"kind":"italic_en","text":"cultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inhabited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninhabited:"},{"kind":"text","text":"(M, Msb, * K:) or the former signifies"},{"kind":"italic_en","text":"any place of this description;"},{"kind":"text","text":"and the latter,"},{"kind":"italic_en","text":"a portion thereof:"},{"kind":"text","text":"(T:) or the former is a generic name of"},{"kind":"italic_en","text":"a place"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"province"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"such as El-'Irák and Syria;"},{"kind":"text","text":"and the latter signifies"},{"kind":"italic_en","text":"a particular portion thereof such as"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the city"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"El-Basrah and Damascus;"},{"kind":"text","text":"(M, K;) or these are post-classical applications: (TA:) or the former,"},{"kind":"italic_en","text":"a tract of land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district, which is an abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place of resort, of animals,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii, even if containing no building:"},{"kind":"text","text":"(Nh:) or"},{"kind":"italic_en","text":"a land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"absolutely: and also"},{"kind":"italic_en","text":"a town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":": but this latter is a conventional adventitious application: ('Ináyeh, TA:) and the latter,"},{"kind":"italic_en","text":"a land, country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"territory,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"belonging to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inhabited by, a people,"},{"kind":"text","text":"] syn."}],"source_refs":["T","TA","Nh"]}]},"classical_definitions":null}