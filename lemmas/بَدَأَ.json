num":"d"},{"role":"present_3fd","form":"تَبْدَأا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْدَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْدَأُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْدَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْدَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْدَأْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَدَأْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَدَأْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْدَأ","in_corpus":true,"count":253,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْدَأ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":752,"cross_references":{"qac":{"found":true,"lemma_key":"بَدَأَ","root":"بدأ","pos":"V","occurrence_count":12},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n2037","n2044"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%AF%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to appear"},{"pos":"verb","gloss":"to become evident, clear"}]},"etymology":null,"ipa":["/ba.daː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2037","headword_ar":"بَدَا","root":"bdw","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"arabic","text_bw":"yaboduw","text_ar":"يَبْدُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"buduw~N","text_ar":"بُدُوٌّ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"badaA='N","text_ar":"بَدَا=ءٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"badaA='apN","text_ar":"بَدَا=ءَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"badFA","text_ar":"بَدًا"},{"kind":"text","text":", (M, on the authority of Sb,) for which last we find, in [some of] the copies of the K,"},{"kind":"arabic","text_bw":"buduw~N","text_ar":"بُدُوٌّ"},{"kind":"text","text":", a repetition, (TA,) or"},{"kind":"arabic","text_bw":"buduwo'N","text_ar":"بُدُوْءٌ"},{"kind":"text","text":", (so in other copies of the K,)"},{"kind":"italic_en","text":"It appeared; it became apparent, open, manifest, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident:"},{"kind":"text","text":"(T, S, M, Msb, K:) and ↓"},{"kind":"arabic","text_bw":"tbd~Y","text_ar":"تبدّى","orth_type":"arrow"},{"kind":"text","text":"[signifies the same; or"},{"kind":"italic_en","text":"he showed himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it showed itself;"},{"kind":"text","text":"(see an ex. in art."},{"kind":"arabic","text_bw":"jy$","text_ar":"جيش"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"jaA$a","text_ar":"جَاشَ"},{"kind":"text","text":", last sentence;) or]"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came in sight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"within sight."},{"kind":"text","text":"(KL.) ―         -b2-"},{"kind":"arabic","text_bw":"badaA lahu fiY AlA^amori","text_ar":"بَدَا لَهُ فِى الاَمْرِ"},{"kind":"text","text":", (T, M, Msb, K, and Har p. 665,) inf. n."},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"badFA","text_ar":"بَدًا"},{"kind":"text","text":"(M, and so in a copy of the K) and"},{"kind":"arabic","text_bw":"badaA='N","text_ar":"بَدَا=ءٌ"},{"kind":"text","text":", (T, M, and so in the CK,) or"},{"kind":"arabic","text_bw":"badaA='apN","text_ar":"بَدَا=ءَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"badaApN","text_ar":"بَدَاةٌ"},{"kind":"text","text":"; (as in some copies of the K;) or ↓"},{"kind":"arabic","text_bw":"badaA lahu fiY AlA^amori badaA='N","text_ar":"بَدَا لَهُ فِى الاَمْرِ بَدَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (S, IB,) the last word being in the nom. case because it is the agent; (IB, TA;)"},{"kind":"italic_en","text":"An opinion presented itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurred, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arose in his mind,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"na$aA^a","text_ar":"نَشَاَ"},{"kind":"text","text":", (S, K, and Har ubi suprà,) or"},{"kind":"italic_en","text":"appeared to him,"},{"kind":"text","text":"(M,) ["},{"kind":"italic_en","text":"respecting the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"different from his first opinion, so that it turned him therefrom:"},{"kind":"text","text":"(Har ubi suprà:) or"},{"kind":"italic_en","text":"there appeared to him, respecting the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, what did not appear at first:"},{"kind":"text","text":"(Msb:) accord. to Fr, ↓"},{"kind":"arabic","text_bw":"badaA liY badaA='N","text_ar":"بَدَا لِى بَدَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"another opinion appeared to me:"},{"kind":"text","text":"accord. to Az,"},{"kind":"arabic","text_bw":"badaA liY badFA","text_ar":"بَدَا لِى بَدًا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"my opinion changed from what it was."},{"kind":"text","text":"(TA.) Esh-Shemmàkh says,"},{"kind":"quote","text":"laEal~aka wa AlmawoEuwdu Haq~N wafaAw^uhu\n                      \n                     \n                        badaA laka fiY tiloka AlqaluwSi badaA='u"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May-be"},{"kind":"text","text":"("},{"kind":"italic_en","text":"but it is right that the promise be fulfilled"},{"kind":"text","text":")"},{"kind":"italic_en","text":"an opinion different from thy first opinion hath arisen in thy mind respecting that youthful she-camel"},{"kind":"text","text":"]. (M, TA.)"},{"kind":"arabic","text_bw":"vum~a badaA lahumo mino baEodi maA raA^awuA","text_ar":"ثُمَّ بَدَا لَهُمْ مِنْ بَعْدِ مَا رَاَوُا"},{"kind":"arabic","text_bw":"A@loA=yaAti layasojunan~ahu","text_ar":"ا@لْا=يَاتِ لَيَسْجُنَنَّهُ"},{"kind":"text","text":", in the Kur [xii.35], means"},{"kind":"arabic","text_bw":"badaA","text_ar":"بَدَا"},{"kind":"arabic","text_bw":"waqaAluwA layasojunun~ahu","text_ar":"وَقَالُوا لَيَسْجُنُنَّهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"lahumo badaA='N","text_ar":"لَهُمْ بَدَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", [i.e."},{"kind":"italic_en","text":"Then an opinion arose in their minds, after they had seen the signs"},{"kind":"text","text":"of his innocence,"},{"kind":"italic_en","text":"and they said that they should certainly imprison him,"},{"kind":"text","text":"] because"},{"kind":"arabic","text_bw":"lysjnn~h","text_ar":"ليسجننّه"},{"kind":"text","text":", being a proposition, cannot be the agent: so says Sb. (M.)"},{"kind":"arabic","text_bw":"badaA lil~hi A^ano yaqotulahumo","text_ar":"بَدَا لِلّهِ اَنْ يَقْتُلَهُمْ"},{"kind":"text","text":", occurring in a trad., means (tropical:)"},{"kind":"italic_en","text":"God determined that He would slay them:"},{"kind":"text","text":"for, as IAth says,"},{"kind":"arabic","text_bw":"badaA='N","text_ar":"بَدَا=ءٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"deeming to be right a thing that is known after its having been not known;"},{"kind":"text","text":"and this may not be attributed to God: but as is said by Suh, in the R, one may say, [of God,]"},{"kind":"arabic","text_bw":"badaA lahu A^ano yafoEala ka*aA","text_ar":"بَدَا لَهُ اَنْ يَفْعَلَ كَذَا"},{"kind":"text","text":", [properly signifying"},{"kind":"italic_en","text":"It occurred to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appeared to him, that he should do such a thing,"},{"kind":"text","text":"] as meaning (tropical:)"},{"kind":"italic_en","text":"He desired to do such a thing;"},{"kind":"text","text":"[as also"},{"kind":"arabic","text_bw":"badaA lahu fiY fiEoli ka*aA","text_ar":"بَدَا لَهُ فِى فِعْلِ كَذَا"},{"kind":"text","text":";] and thus the phrase in the trad., here mentioned, has been explained. (TA.) [One says also,"},{"kind":"arabic","text_bw":"AifoEalo ka*aA maA badaA laka","text_ar":"اِفْعَلْ كَذَا مَا بَدَا لَكَ"},{"kind":"italic_en","text":"Do thou thus as long as it seems fit to thee:"},{"kind":"text","text":"see, a verse of El-Ahmar cited voce"},{"kind":"arabic","text_bw":"jal~a","text_ar":"جَلَّ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"badaA Alqawomu","text_ar":"بَدَا القَوْمُ"},{"kind":"text","text":", (T, S, M, K,) inf. n."},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"badaA='N","text_ar":"بَدَا=ءٌ"},{"kind":"text","text":"; (M, K;) [the latter of which is said in the TA to be the right;] or"},{"kind":"arabic","text_bw":"badaA A_ilaY AlbaAdiyapi","text_ar":"بَدَا اـِلَى البَادِيَةِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"badaAwapN","text_ar":"بَدَاوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bidaAwapN","text_ar":"بِدَاوَةٌ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"The people, or company of men, went forth to the"},{"kind":"arabic","text_bw":"baAdiyap","text_ar":"بَادِيَة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or desert"},{"kind":"text","text":"]: (M, Msb, K:) or, the former,"},{"kind":"italic_en","text":"went forth to their"},{"kind":"arabic","text_bw":"baAdiyap","text_ar":"بَادِيَة"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"went forth from the region, or district, of towns or villages or of cultivated land, to the pasturingplaces in the deserts:"},{"kind":"text","text":"(T:) [ISd says,]"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":"may be used as meaning"},{"kind":"arabic","text_bw":"bidaAwapN","text_ar":"بِدَاوَةٌ"},{"kind":"text","text":", which is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HiDaArapN","text_ar":"حِضَارَةٌ"},{"kind":"text","text":": (M:) [J says,]"},{"kind":"arabic","text_bw":"badaAwapN","text_ar":"بَدَاوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bidaAwapN","text_ar":"بِدَاوَةٌ"},{"kind":"text","text":"signify the"},{"kind":"italic_en","text":"dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding, in the"},{"kind":"arabic","text_bw":"baAdiyap","text_ar":"بَادِيَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desert"},{"kind":"text","text":"]; the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HiDaArapN","text_ar":"حِضَارَةٌ"},{"kind":"text","text":": but Th says, I know not"},{"kind":"arabic","text_bw":"badaAwapN","text_ar":"بَدَاوَةٌ"},{"kind":"text","text":", with fet-h, except on the authority of AZ alone: (S:) As says that"},{"kind":"arabic","text_bw":"bdAwp","text_ar":"بداوة"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HDArp","text_ar":"حضارة"},{"kind":"text","text":"are with kesr to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"and fet-h to the"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":"; but AZ says the reverse, i. e. with fet-h to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"and kesr to the"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":": (T:) both are also explained as signifying the"},{"kind":"italic_en","text":"going forth to the"},{"kind":"arabic","text_bw":"baAdiyap","text_ar":"بَادِيَة"},{"kind":"text","text":": and some mention"},{"kind":"arabic","text_bw":"budaAwapN","text_ar":"بُدَاوَةٌ"},{"kind":"text","text":", with damm; but this is not known: (TA:) ↓"},{"kind":"arabic","text_bw":"tbd~Y","text_ar":"تبدّى","orth_type":"arrow"},{"kind":"text","text":"like wise signifies"},{"kind":"italic_en","text":"he went forth from the constant sources of water to the places where herbage was to be sought"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the desert"},{"kind":"text","text":"]; (T;) or"},{"kind":"italic_en","text":"he dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the"},{"kind":"arabic","text_bw":"baAdiyap","text_ar":"بَادِيَة"},{"kind":"text","text":". (S, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"mano badaA jafaA","text_ar":"مَنْ بَدَا جَفَا"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He who abides in the desert becomes rude, rough, coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncivil, like the desert-Arabs."},{"kind":"text","text":"(S.) And in another,"},{"kind":"arabic","text_bw":"kaAna yaboduw A_ilaY h`*ihi Alt~ilaAEi","text_ar":"كَانَ يَبْدُو اـِلَى هٰذِهِ التِّلَاعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He used to go forth to these water-courses in the desert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"these high grounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low grounds,"},{"kind":"text","text":"&c.]. (TA.)―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"badaA","text_ar":"بَدَا"},{"kind":"italic_en","text":"He voided his excrement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordure;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"AbdY","text_ar":"ابدى","orth_type":"arrow"},{"kind":"text","text":"(T, K) [and"},{"kind":"arabic","text_bw":"AbdA^","text_ar":"ابدا"},{"kind":"text","text":"]: because he who does so goes forth from the tents or houses into the open country. (T.)       -A2-"},{"kind":"arabic","text_bw":"badaAniY bika*aA","text_ar":"بَدَانِى بِكَذَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaboduw","text_ar":"يَبْدُو"},{"kind":"text","text":", is like"},{"kind":"arabic","text_bw":"badaA^aniY","text_ar":"بَدَاَنِى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He began with me by"},{"kind":"page_break","n":171},{"kind":"text","text":"doing"},{"kind":"italic_en","text":"such a thing"},{"kind":"text","text":"]. (M, TA.)       -A3-"},{"kind":"arabic","text_bw":"badiyati AlA^aroDu","text_ar":"بَدِيَتِ الاَرْضُ"},{"kind":"italic_en","text":"The land produced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abounded with,"},{"kind":"arabic","text_bw":"badaAp","text_ar":"بَدَاة"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"truffles:"},{"kind":"text","text":"(K, * TA:) or"},{"kind":"italic_en","text":"had in it truffles."},{"kind":"text","text":"(TK.) ―         -b2-  And"},{"kind":"italic_en","text":"The land had in it"},{"kind":"arabic","text_bw":"badaAp","text_ar":"بَدَاة"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"dust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth."},{"kind":"text","text":"(K, * TK.)"}],"source_refs":["S","Msb","M","K","TA","T","IB"]},{"entry_id":"n2044","headword_ar":"بَدًا","root":"bdw","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"excrement from the anus"},{"kind":"text","text":"(M, K *) of a man. (M.) [And"},{"kind":"arabic","text_bw":"badaA='N","text_ar":"بَدَا=ءٌ"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"A^abodaA^a","text_ar":"اَبْدَاَ"},{"kind":"text","text":", signifies the same.] ―         -b2-"},{"kind":"italic_en","text":"A joint"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mafoSil","text_ar":"مَفْصِل"},{"kind":"text","text":") of a man; (AA, M, K;) as also"},{"kind":"arabic","text_bw":"bado'N","text_ar":"بَدْءٌ"},{"kind":"text","text":": (AA, M:) pl."},{"kind":"arabic","text_bw":"A^abodaA='N","text_ar":"اَبْدَا=ءٌ"},{"kind":"text","text":". (AA, M, K.)       -A2-"},{"kind":"arabic","text_bw":"badaA","text_ar":"بَدَا"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"badFA","text_ar":"بَدًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":", in two places."}],"source_refs":["AA","M"]}]}}