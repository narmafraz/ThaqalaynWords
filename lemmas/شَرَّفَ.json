{"lemma":"شَرَّفَ","slug":"شَرَّفَ","root":"ش.ر.ف","root_slug":"ش-ر-ف","root_link":"/words/roots/ش-ر-ف","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَرَّفْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَرَّفْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَرَّفْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَرَّفْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَرَّفْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَرَّفَ","in_corpus":true,"count":20,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَرَّفَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَرَّفا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَرَّفَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَرَّفُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَرَّفْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُشَرِّف","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُشَرِّفِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُشَرِّفِي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُشَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشَرِّفا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُشَرِّفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشَرِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشَرِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشَرِّف","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشَرِّف","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشَرِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشَرِّفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشَرِّفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشَرِّفُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشَرِّفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشَرِّفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُشَرِّف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشَرِّف","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"شَرَّفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَرَّفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":46,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n22157","n22165","n22166"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%8E%D9%91%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be noble, to be highborn, to be illustrious, to be eminent, to be distinguished, to be high-ranking"},{"pos":"verb","gloss":"to make noble, to ennoble, to make illustrious, to make eminent, to elevate, to exalt, to honor"},{"pos":"noun","gloss":"verbal noun of شَرُفَ (šarufa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"elevated place"},{"pos":"noun","gloss":"high rank, nobility, distinction, eminence, dignity"},{"pos":"noun","gloss":"honor, glory"},{"pos":"noun","gloss":"plural of شُرْفَة (šurfa)","tags":["form-of","plural"]}]},"etymology":null,"ipa":["/ʃa.ru.fa/","/ʃar.ra.fa/","/ʃa.raf/","/ʃu.ruf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22157","headword_ar":"شَرُفَ","root":"$rf","body":[{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"(S, * O, * Msb, * K, TA) and"},{"kind":"arabic","text_bw":"$araAfapN","text_ar":"شَرَافَةٌ"},{"kind":"text","text":", (TA,) said of a man, (S, O, TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high, elevated, exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eminent,"},{"kind":"text","text":"(S, O, Msb, K, TA,) ["},{"kind":"italic_en","text":"in rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in respect of religion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of worldly things:"},{"kind":"text","text":"(K, TA:) [generally meaning"},{"kind":"italic_en","text":"he was high-born,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noble:"},{"kind":"text","text":"] part. n."},{"kind":"arabic","text_bw":"$ariyfN","text_ar":"شَرِيفٌ"},{"kind":"text","text":"[q. v.]. (S, O, Msb, K, TA.) [See also"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":", below.] ―         -b2-  [Hence one says,]"},{"kind":"arabic","text_bw":"$arufato nafosuhu Eani Al$~aYo'i","text_ar":"شَرُفَتْ نَفْسُهُ عَنِ الشَّىْءِ"},{"kind":"italic_en","text":"His soul was above the thing; disdained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scorned, it."},{"kind":"text","text":"(L in art."},{"kind":"arabic","text_bw":"Anf","text_ar":"انف"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"$arafati Aln~aAqapu","text_ar":"شَرَفَتِ النَّاقَةُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$arufat","text_ar":"شَرُفَت"},{"kind":"text","text":", (O, K,) aor. of each"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$uruwfN","text_ar":"شُرُوفٌ"},{"kind":"text","text":", (K,) reg. as of the former verb, and irreg. as of the latter, (TA,)"},{"kind":"italic_en","text":"The she-camel was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"$aArifN","text_ar":"شَارِفٌ"},{"kind":"text","text":"[q. v.]. (O, K.)       -A2-"},{"kind":"arabic","text_bw":"$arafahu","text_ar":"شَرَفَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (IJ, S, O, K, TA,) inf. n."},{"kind":"arabic","text_bw":"$arofN","text_ar":"شَرْفٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He overcame him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpassed him, in"},{"kind":"arabic","text_bw":"$araf","text_ar":"شَرَف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"highness, elevation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eminence, of rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"]; (IJ, S, O, K, TA;) and so"},{"kind":"arabic","text_bw":"$arufa Ealayohi","text_ar":"شَرُفَ عَلَيْهِ"},{"kind":"text","text":": (Z, TA:) or"},{"kind":"italic_en","text":"he excelled him"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"TaAlahu","text_ar":"طَالَهُ"},{"kind":"text","text":", K, TA, in the CK [erroneously]"},{"kind":"arabic","text_bw":"TAwalahu","text_ar":"طاوَلَهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in the grounds of pretension to respect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honour"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"fiY AlHasabi","text_ar":"فِى الحَسَبِ"},{"kind":"text","text":"). (K, TA.) See 3. ―         -b2-"},{"kind":"arabic","text_bw":"$arafa AlHaAy^iTa","text_ar":"شَرَفَ الحَايِطَ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$arofN","text_ar":"شَرْفٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He put to the wall a"},{"kind":"arabic","text_bw":"$urofap","text_ar":"شُرْفَة"},{"kind":"text","text":"[q. v.]. (K, TA.) [See also 2.]       -A3-"},{"kind":"arabic","text_bw":"$arifati AlA^u*unu","text_ar":"شَرِفَتِ الاُذُنُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$arifa Almanokibu","text_ar":"شَرِفَ المَنْكِبُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The ear,"},{"kind":"text","text":"and in like manner"},{"kind":"italic_en","text":"the shoulder, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, high,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and prominent:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"stood up."},{"kind":"text","text":"(TA.)       -A4-  And"},{"kind":"arabic","text_bw":"$arifa","text_ar":"شَرِفَ"},{"kind":"text","text":", [from"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"signifying the “ hump ” of a camel,] (O, K,) said of a man, (O,)"},{"kind":"italic_en","text":"He kept constantly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continually, to the eating of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"camel's"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hump."},{"kind":"text","text":"(O, K.)"}],"source_refs":["S","O","Msb","K","TA","IJ","Z"]},{"entry_id":"n22165","headword_ar":"شَرْفٌ","root":"$rf","body":[{"kind":"text","text":": see the next paragraph, near the end."}],"source_refs":[]},{"entry_id":"n22166","headword_ar":"شَرَفٌ","root":"$rf","body":[{"kind":"italic_en","text":"Highness, elevation, exaltation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eminence,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation, in respect of religion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of worldly things:"},{"kind":"text","text":"(see the first sentence of this art.:)] (S, O, Msb, K:) [generally meaning"},{"kind":"italic_en","text":"high birth:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"glory, honour, dignity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"majodN","text_ar":"مَجْدٌ"},{"kind":"text","text":": or not unless ["},{"kind":"italic_en","text":"transmitted"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by ancestors:"},{"kind":"text","text":"(K:) [for] accord. to ISk,"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"majodN","text_ar":"مَجْدٌ"},{"kind":"text","text":"may not be unless [transmitted] by ancestors; but"},{"kind":"arabic","text_bw":"HasabN","text_ar":"حَسَبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"karamN","text_ar":"كَرَمٌ"},{"kind":"text","text":"may be in a man though he have not ancestors [endowed therewith]: (O:) or, (K,) accord. to IDrd, (O,) it signifies"},{"kind":"italic_en","text":"highness of"},{"kind":"arabic","text_bw":"Hasab","text_ar":"حَسَب"},{"kind":"text","text":"[which means"},{"kind":"italic_en","text":"grounds of pretension to respect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honour, consisting in any qualities"},{"kind":"text","text":"("},{"kind":"italic_en","text":"either of oneself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of one's ancestors"},{"kind":"text","text":")"},{"kind":"italic_en","text":"which are enumerated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recounted, as causes of glorying"},{"kind":"text","text":"]: (O, K:) and ↓"},{"kind":"arabic","text_bw":"$urofapN","text_ar":"شُرْفَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"; (TA;) or the same as"},{"kind":"arabic","text_bw":"faDolN","text_ar":"فَضْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"a favour"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a glory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an honour"},{"kind":"text","text":"]; as in the saying,"},{"kind":"arabic","text_bw":"A^aEud~u A_itoyaAnakumN","text_ar":"اَعُدُّ اـِتْيَانَكُمٌ"},{"kind":"arabic","text_bw":"$urofapF","text_ar":"شُرْفَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I reckon your coming a favour,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a glory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an honour"},{"kind":"text","text":"]; (O, K;) and"},{"kind":"arabic","text_bw":"A^araY *`lika $urofapF","text_ar":"اَرَى ذٰلِكَ شُرْفَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I regard that as a favour,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a glory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an honour"},{"kind":"text","text":"]: (O:) the pl. of"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^a$oraAfN","text_ar":"اَشْرَافٌ"},{"kind":"text","text":", like as that of"},{"kind":"arabic","text_bw":"sababN","text_ar":"سَبَبٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^asobaAbN","text_ar":"اَسْبَابٌ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"nuhobapN *aAtu $arafK","text_ar":"نُهْبَةٌ ذَاتُ شَرَفٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Spoil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"booty, of high value, at which men raise their eyes, and look,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"which they smite with the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"evil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"eye:"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"Aisota$orafa A_ibilahumo","text_ar":"اِسْتَشْرَفَ اـِبِلَهُمْ"},{"kind":"text","text":":] but the phrase is also related with"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":". (TA. See"},{"kind":"arabic","text_bw":"sarafN","text_ar":"سَرَفٌ"},{"kind":"text","text":".) ―         -b2-  See also"},{"kind":"arabic","text_bw":"$ariyfN","text_ar":"شَرِيفٌ"},{"kind":"text","text":", with which, or with the pls. of which, it is said to be syn. ―         -b3-  Also"},{"kind":"italic_en","text":"An elevated place; an eminence:"},{"kind":"text","text":"(S, Mgh, O, K:) accord. to Sh,"},{"kind":"italic_en","text":"any piece of ground that overtops what is around it, whether extended or not, only about ten cubits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"five, in length, of little or much breadth in its upper surface:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^a$oraAfN","text_ar":"اَشْرَافٌ"},{"kind":"text","text":": (TA voce"},{"kind":"arabic","text_bw":"waTo'N","text_ar":"وَطْءٌ"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"ma$aArifu","text_ar":"مَشَارِفُ"},{"kind":"arabic","text_bw":"AlA^aroDi","text_ar":"الاَرْضِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, places,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, of the earth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground:"},{"kind":"text","text":"(S, Msb, K:) sing. ↓"},{"kind":"arabic","text_bw":"ma$orafN","text_ar":"مَشْرَفٌ","orth_type":"arrow"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":". (Msb. [See also"},{"kind":"arabic","text_bw":"mu$orafN","text_ar":"مُشْرَفٌ"},{"kind":"text","text":".]) A poet says,"},{"kind":"quote","text":"A=tiY Aln~adiY~a falaA yuqar~abu majolisiY\n                      \n                     \n                        waA^aquwdu lil$~arafi Alr~afiyEi HimaAriY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I come to the assembly, and my sitting-place is not made near"},{"kind":"text","text":"to the chief person or persons,"},{"kind":"italic_en","text":"and I lead to the high elevated place my ass"},{"kind":"text","text":"]: he means, I have become unsound in my intellect in consequence of old age, so that no profit is gotten from my opinion, and I am not able to mount my ass from the ground, unless from a high place. (S.) ―         -b4-  [Hence, (tropical:)  The"},{"kind":"italic_en","text":"brink, verge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point,"},{"kind":"text","text":"of some event of great magnitude, or of any importance: not well expl. as meaning] the"},{"kind":"italic_en","text":"being on the brink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the point,"},{"kind":"text","text":"of some event of great importance, good or evil: (O, K:) one says in the case of good,"},{"kind":"arabic","text_bw":"huwa EalaY $arafK mino qaDaA='i","text_ar":"هُوَ عَلَى شَرَفٍ مِنْ قَضَا=ءِ"},{"kind":"arabic","text_bw":"HaAjatihi","text_ar":"حَاجَتِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is at the point of accomplishing the object of his want"},{"kind":"text","text":"]: and in the case of evil,"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"EalaY $arafK mina AlhalaAki","text_ar":"عَلَى شَرَفٍ مِنَ الهَلَاكِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is on the brink,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of destruction"},{"kind":"text","text":"]. (O, TA.) ―         -b5-  And (tropical:)  The"},{"kind":"italic_en","text":"hump"},{"kind":"text","text":"of a camel. (O, K, TA.) ―         -b6-  And app. sing. of"},{"kind":"arabic","text_bw":"A^a$oraAfN","text_ar":"اَشْرَافٌ"},{"kind":"text","text":"in a sense expl. below: see the latter word. (TA.)       -A2-  And"},{"kind":"italic_en","text":"A heat; a single run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a run at once, to a goal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limit:"},{"kind":"text","text":"(O, K:) or, (K,) accord. to Fr,"},{"kind":"italic_en","text":"about a mile:"},{"kind":"text","text":"(O, K:) or"},{"kind":"italic_en","text":"about two miles."},{"kind":"text","text":"(TA as from the K and on the authority of Fr.) One says,"},{"kind":"arabic","text_bw":"EadaA $arafFA A^awo $arafayoni","text_ar":"عَدَا شَرَفًا اَوْ شَرَفَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He ran a heat, or two heats"},{"kind":"text","text":"]: (O:) and [in like manner,]"},{"kind":"arabic","text_bw":"Aisotan~atN","text_ar":"اِسْتَنَّتٌ"},{"kind":"arabic","text_bw":"$arafFA A^awo $arafayoni","text_ar":"شَرَفًا اَوْ شَرَفَيْنِ"},{"kind":"text","text":", (O, K,) occurring in a trad., said of a mare, or of horses. (O.)       -A3-  Also, (O, TA,) accord. to IAar, (O,)"},{"kind":"italic_en","text":"A red clay"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"magorapN","text_ar":"مَغْرَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"red ochre"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"$arofN","text_ar":"شَرْفٌ","orth_type":"arrow"},{"kind":"text","text":": accord. to Lth,"},{"kind":"italic_en","text":"a kind of trees, having a red dye:"},{"kind":"text","text":"and said to be"},{"kind":"italic_en","text":"the same as"},{"kind":"text","text":"[the Pers.]"},{"kind":"arabic","text_bw":"dAr PrnyAn","text_ar":"دار پرنيان"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"daAro ParoniyaAn","text_ar":"دَارْ پَرْنِيَان"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Brazil-wood,"},{"kind":"text","text":"which is commonly called in Arabic"},{"kind":"arabic","text_bw":"baq~am","text_ar":"بَقَّم"},{"kind":"text","text":"]. (O, TA: *  in the former of which, the Pers. word here mentioned is written without the points to the"},{"kind":"arabic","text_bw":"P","text_ar":"پ"},{"kind":"text","text":"; and in the latter,"},{"kind":"arabic","text_bw":"AldAbrnyAn","text_ar":"الدابرنيان"},{"kind":"text","text":".)"}],"source_refs":["S","O","Msb","K","Mgh","TA"]}]}}