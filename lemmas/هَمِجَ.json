l,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41297","headword_ar":"همج","root":"hmj","body":[{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"hamija","text_ar":"هَمِجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He hungered; was hungry."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"hamajati AlA_ibilu","text_ar":"هَمَجَتِ الاـِبِلُ"},{"kind":"arabic","text_bw":"mina AlmaA='i","text_ar":"مِنَ المَا=ءِ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hamojN","text_ar":"هَمْجٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"The camels drank of the water at one draught,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"until they satisfied their thirst."},{"kind":"text","text":"(S.)"}],"source_refs":["S","K"]},{"entry_id":"n41299","headword_ar":"هَمَجٌ","root":"hmj","body":[{"kind":"italic_en","text":"Hunger:"},{"kind":"text","text":"or (in the K, and)"},{"kind":"italic_en","text":"bad management of the means of subsistence."},{"kind":"text","text":"(S, K.) ↓"},{"kind":"arabic","text_bw":"hamajN haAmijN","text_ar":"هَمَجٌ هَامِجٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Severe hunger:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very bad management of the means of subsistence:"},{"kind":"text","text":"] (S, K:) the latter word is added to give intensiveness to the signification; (TA;) or to corroborate; (S, K;) as in the case of"},{"kind":"arabic","text_bw":"layolN laAy^ilN","text_ar":"لَيْلٌ لَايِلٌ"},{"kind":"text","text":". (S.) ―         -b2-"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"italic_en","text":"Small flies, like gnats, that fall upon the faces of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, and asses,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and into their eyes:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"gnats;"},{"kind":"text","text":"so called from"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"text","text":"signifying “ hunger; ” because when they are hungry they live, but when they become satiated they die: or"},{"kind":"arabic","text_bw":"SigaAr Ald~awaAb~i","text_ar":"صِغَار الدَّوَابِّ"},{"kind":"text","text":": (L:) [but this is evidently a mistake for"},{"kind":"arabic","text_bw":"SigaAru","text_ar":"صِغَارُ"},{"kind":"arabic","text_bw":"Al*~ubaAbi","text_ar":"الذُّبَابِ"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"young ones,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"little ones, of flies:"},{"kind":"text","text":"]) or"},{"kind":"italic_en","text":"any grubs that burst forth from flies"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from gnats:"},{"kind":"text","text":"(Lth, A:) pl. of"},{"kind":"arabic","text_bw":"hamajapN","text_ar":"هَمَجَةٌ"},{"kind":"text","text":", (S,) [or rather this is the n. un. of"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"text","text":", which is a coll. gen. n.]. ―         -b3-"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"italic_en","text":"Lean sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats:"},{"kind":"text","text":"(K:) [a coll. gen. n.,] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish, men;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"men of little sense:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish, young men of the meaner sort:"},{"kind":"text","text":"(S:) or simply"},{"kind":"italic_en","text":"young men of the meaner sort:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed and low set of men:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorderly vagabonds:"},{"kind":"text","text":"(TA:) you say also"},{"kind":"arabic","text_bw":"rajulN hamajN","text_ar":"رَجُلٌ هَمَجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hamajapN","text_ar":"هَمَجَةٌ"},{"kind":"italic_en","text":"a stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish, man;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rijaAlN hamajN","text_ar":"رِجَالٌ هَمَجٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^ahomaAjN","text_ar":"اَهْمَاجٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"hamajapN","text_ar":"هَمَجَةٌ"},{"kind":"text","text":"signifies a"},{"kind":"italic_en","text":"stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish,"},{"kind":"text","text":"man,"},{"kind":"italic_en","text":"who has not firm command of himself."},{"kind":"text","text":"(Aboo-Sa'eed.) ―         -b5-"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"italic_en","text":"Old and weak ewes:"},{"kind":"text","text":"(K:) [a coll. gen. n.,] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": which also signifies simply"},{"kind":"italic_en","text":"a ewe."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"qawomN hamajN","text_ar":"قَوْمٌ هَمَجٌ"},{"kind":"italic_en","text":"A people in whom is no good."},{"kind":"text","text":"(TA.) ―         -b7-  ↓"},{"kind":"arabic","text_bw":"hamajN haAmijN","text_ar":"هَمَجٌ هَامِجٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Young men of the meaner sort;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"hamajN","text_ar":"هَمَجٌ"},{"kind":"text","text":"alone: and"},{"kind":"italic_en","text":"a mixed set of men who have no intelligence nor manliness."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","L","Lth","A","TA"]}]}}