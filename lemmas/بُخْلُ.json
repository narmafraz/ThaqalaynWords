{"lemma":"بُخْلُ","slug":"بُخْلُ","root":"ب.خ.ل","root_slug":"ب-خ-ل","root_link":"/words/roots/ب-خ-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بُخْل","root":"بخل","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n1903","n1906","n1907","n1908","n1909","n1910","n1911"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D8%AE%D9%92%D9%84%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be stingy"},{"pos":"verb","gloss":"to withhold","examples":[{"text":"لَا يَبْخَلُ عَلَيْهِ بِأَيَّةِ مَعْلُومَةٍ.","english":"He does not conceal any information from him"}]},{"pos":"noun","gloss":"avarice, stinginess"},{"pos":"noun","gloss":"unlawful or immoral withholding of property"},{"pos":"noun","gloss":"refusal to do what is legally obliged"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1903","headword_ar":"بَخِلَ","root":"bxl","body":[{"kind":"text","text":", (JK, S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baxalN","text_ar":"بَخَلٌ"},{"kind":"text","text":"; (JK, Msb, K;) and"},{"kind":"arabic","text_bw":"baxula","text_ar":"بَخُلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly, tenacious, stingy, penurious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":", below. (K, TA.) You say,"},{"kind":"arabic","text_bw":"baxila bika*aA","text_ar":"بَخِلَ بِكَذَا"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"baxula bihi","text_ar":"بَخُلَ بِهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of such a thing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"baxila Eanohu","text_ar":"بَخِلَ عَنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He withheld, with niggardliness, from him"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"baxila Ealayohi","text_ar":"بَخِلَ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he was niggardly to him"},{"kind":"text","text":"]. (Bd and Jel in xlvii. last verse.)"}],"source_refs":["JK","S","Msb","K","TA"]},{"entry_id":"n1906","headword_ar":"بَخْلٌ","root":"bxl","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n1907","headword_ar":"بُخْلٌ","root":"bxl","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"baxalN","text_ar":"بَخَلٌ","orth_type":"arrow"},{"kind":"text","text":", [both of which are properly inf. ns.,] (JK, S, K,) and ↓"},{"kind":"arabic","text_bw":"baxolN","text_ar":"بَخْلٌ","orth_type":"arrow"},{"kind":"text","text":", (Ks, S, Msb, K,) which is a simple subst., (Msb,) and ↓"},{"kind":"arabic","text_bw":"buxulN","text_ar":"بُخُلٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"baxilN","text_ar":"بَخِلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bixolN","text_ar":"بِخْلٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"buxuwlN","text_ar":"بُخُولٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) of all which, the first is that which commonly obtains, (TA,) are syn., (JK, S,) signifying"},{"kind":"italic_en","text":"Niggardliness, tenaciousness, stinginess, penuriousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avarice;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"karamN","text_ar":"كَرَمٌ"},{"kind":"text","text":"(K, TA) and"},{"kind":"arabic","text_bw":"juwdN","text_ar":"جُودٌ"},{"kind":"text","text":"; and its definition is the"},{"kind":"italic_en","text":"withholding of acquired articles of property from that wherefrom it is not lawful to withhold them:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"debarring the asker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beggar, from what one has that is superabundant:"},{"kind":"text","text":"(Msb:) and in the law, the"},{"kind":"italic_en","text":"refusal of what is incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory."},{"kind":"text","text":"(Msb, TA.)"}],"source_refs":["JK","S","K","Ks","Msb","TA"]},{"entry_id":"n1908","headword_ar":"بِخْلٌ","root":"bxl","body":[{"kind":"text","text":": see what next precedes."}],"source_refs":[]},{"entry_id":"n1909","headword_ar":"بَخَلٌ","root":"bxl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":": ―         -b2-  and see also"},{"kind":"arabic","text_bw":"baxiylN","text_ar":"بَخِيلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1910","headword_ar":"بَخِلٌ","root":"bxl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1911","headword_ar":"بُخُلٌ","root":"bxl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}