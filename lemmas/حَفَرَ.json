:"m","num":"p"},{"role":"present_2mp","form":"تَحْفِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْفِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْفِر","in_corpus":true,"count":17,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْفِر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْفِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْفِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْفِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْفِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْفِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْفِرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْفِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَفَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَفَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْفِر","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْفِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":47,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n8472"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%81%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dig, dig out, hollow"},{"pos":"verb","gloss":"to dig or clean a well"},{"pos":"verb","gloss":"to investigate"},{"pos":"verb","gloss":"to lie with"},{"pos":"verb","gloss":"to emaciate by milking frequently"},{"pos":"noun","gloss":"verbal noun of حَفَرَ (ḥafara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"digging, hollowing"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ḥapar-. Cognate with Biblical Hebrew חָפַר (ḥɔp̄ar, “to dig, search for”).\n\nFrom Proto-Semitic *ḥapr-."},"ipa":["/ħa.fa.ra/","/ħafr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8472","headword_ar":"حَفَرَ","root":"Hfr","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HaforN","text_ar":"حَفْرٌ"},{"kind":"text","text":", (Mgh, Msb,)"},{"kind":"italic_en","text":"He dug, excavated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hollowed out,"},{"kind":"text","text":"the ground, or earth; (KL, PS, &c.;)"},{"kind":"italic_en","text":"he cleared out"},{"kind":"text","text":"a thing, (K,) as one does the ground; (S, Msb, K;) and a well; (the Lexicons passim;) and a river; (A, Mgh;) with a"},{"kind":"arabic","text_bw":"miHofaAr","text_ar":"مِحْفَار"},{"kind":"text","text":"; (A;) or with an iron implement; (K;) and ↓"},{"kind":"arabic","text_bw":"AHtfr","text_ar":"احتفر","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (S, A, K.) And"},{"kind":"arabic","text_bw":"Hafara","text_ar":"حَفَرَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Hafarahu","text_ar":"حَفَرَهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AHtfrhu","text_ar":"احتفرهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He dug for him,"},{"kind":"text","text":"(namely, a lizard of the kind called"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":", or a jerboa,)"},{"kind":"italic_en","text":"to fetch him forth."},{"kind":"text","text":"(A, TA.) ―         -b2-  ["},{"kind":"italic_en","text":"He burrowed."},{"kind":"text","text":"] ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a torrent)"},{"kind":"italic_en","text":"furrowed"},{"kind":"text","text":"a valley. (Msb.) [See also 5.] ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"Inivit"},{"kind":"text","text":"feminam: (IAar, Msb, K:) the action being likened to that of a man digging a river. (IAar.) ―         -b5- .) ―         -b6-"},{"kind":"arabic","text_bw":"h`*aA gayovN laA","text_ar":"هٰذَا غَيْثٌ لَا"},{"kind":"arabic","text_bw":"yaHofiruhu A^aHadN","text_ar":"يَحْفِرُهُ اَحَدٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"This is a rain of which no one knows the utmost extent."},{"kind":"text","text":"(K, * TA.) ―         -b7-"},{"kind":"arabic","text_bw":"Hafara varay zayodK","text_ar":"حَفَرَ ثَرَي زَيْدٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He searched into the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, of Zeyd,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"and became acquainted with it."},{"kind":"text","text":"(K.) ―         -b8-  And"},{"kind":"arabic","text_bw":"Hafara","text_ar":"حَفَرَ"},{"kind":"text","text":", (S, A, K,) aor. as above, (S,) and so the inf. n., (S, A,) (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, emaciated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered lean:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a copious flow of milk, TA)"},{"kind":"italic_en","text":"emaciated"},{"kind":"text","text":"a she-goat: (K, TA:) (tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a young camel)"},{"kind":"italic_en","text":"rendered"},{"kind":"text","text":"his mother"},{"kind":"italic_en","text":"flabby in flesh by much sucking."},{"kind":"text","text":"(A.) There is no pregnant animal that pregnancy does not emaciate, except the camel: (S, A:) she fattens in pregnancy. (S.)       -A2-"},{"kind":"arabic","text_bw":"Hafara","text_ar":"حَفَرَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child)"},{"kind":"italic_en","text":"shed his"},{"kind":"arabic","text_bw":"rawaADiE","text_ar":"رَوَاضِع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"milk-teeth"},{"kind":"text","text":"]. (K, TA.) [See also 4.] ―         -b2-"},{"kind":"arabic","text_bw":"Hafarato","text_ar":"حَفَرَتْ"},{"kind":"arabic","text_bw":"rawaADiEu Almuhori","text_ar":"رَوَاضِعُ المُهْرِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Hufirato","text_ar":"حُفِرَتْ"},{"kind":"text","text":", (accord. to different copies of the A,) (tropical:)"},{"kind":"italic_en","text":"The milk-teeth of the colt became in a wabbling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loose, state, previously to their falling out;"},{"kind":"text","text":"because, when they have fallen out, their sockets become hollow. (A.) [See 4.] ―         -b3-"},{"kind":"arabic","text_bw":"Hafarati AlA^asonaAnu","text_ar":"حَفَرَتِ الاَسْنَانُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HaforN","text_ar":"حَفْرٌ"},{"kind":"text","text":"; (S, Msb;) and"},{"kind":"arabic","text_bw":"Hafirat","text_ar":"حَفِرَت"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HafarN","text_ar":"حَفَرٌ"},{"kind":"text","text":", in the dial. of BenooAsad, (S, Msb,) and this is the worse of these two forms, (S,) and"},{"kind":"arabic","text_bw":"HaforN","text_ar":"حَفْرٌ"},{"kind":"text","text":"; (El-Wá'ee;) and"},{"kind":"arabic","text_bw":"Hufirat","text_ar":"حُفِرَت"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"The teeth became affected with what is termed"},{"kind":"arabic","text_bw":"HaforN","text_ar":"حَفْرٌ"},{"kind":"text","text":"[q. v. infrà] or"},{"kind":"arabic","text_bw":"HafarN","text_ar":"حَفَرٌ"},{"kind":"text","text":": (S, Msb, K:) or"},{"kind":"italic_en","text":"became unsound:"},{"kind":"text","text":"(Mgh:) and"},{"kind":"arabic","text_bw":"Hafara fuwhu","text_ar":"حَفَرَ فُوهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hafira","text_ar":"حَفِرَ"},{"kind":"italic_en","text":"his teeth cankered."},{"kind":"text","text":"(A.) IDrst says, in the Expos. of the Fs, that"},{"kind":"arabic","text_bw":"Hafara","text_ar":"حَفَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Hafora fuwhu","text_ar":"حَفْرَ فُوهُ"},{"kind":"text","text":", is trans.; and that the cause of"},{"kind":"arabic","text_bw":"Hafor","text_ar":"حَفْر"},{"kind":"text","text":"of the teeth, [or the agent of the verb"},{"kind":"arabic","text_bw":"Hafara","text_ar":"حَفَرَ"},{"kind":"text","text":",] is old age, or the continuance of a yellow incrustation, [or tartar,] or some kind of canker that effects them: but that the verb in the phrase"},{"kind":"arabic","text_bw":"Hafirato sin~uhu","text_ar":"حَفِرَتْ سِنُّهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HafarN","text_ar":"حَفَرٌ"},{"kind":"text","text":", is intrans. (MF.) [The truth probably is, that the former verb is both trans. and intrans., and hence"},{"kind":"arabic","text_bw":"Hufirati AlA^asonaAnu","text_ar":"حُفِرَتِ الاَسْنَانُ"},{"kind":"text","text":"; and that the latter is intrans. only.] ―         -b4-  And"},{"kind":"arabic","text_bw":"Hafira","text_ar":"حَفِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound, state."},{"kind":"text","text":"(Az.)"}],"source_refs":["Msb","K","Mgh","IAar","A","S","TA"]}]}}