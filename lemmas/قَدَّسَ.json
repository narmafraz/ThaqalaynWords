,"text":"or"},{"kind":"italic_en","text":"Purity;"},{"kind":"text","text":"] i. e.,"},{"kind":"italic_en","text":"Paradise."},{"kind":"text","text":"(S, A.) ―         -b3-  [Hence, also,]"},{"kind":"arabic","text_bw":"ruwHu","text_ar":"رُوحُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Alqudusi","text_ar":"القُدُسِ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"ruwHu Alqudosi","text_ar":"رُوحُ القُدْسِ"},{"kind":"text","text":", accord. to the reading of Ibn-Ketheer, (Bd, ii. 81,) [The Spirit of Holiness or Purity; properly applied to"},{"kind":"italic_en","text":"The Holy Spirit, The Third Person of the Trinity,"},{"kind":"text","text":"in Christian theology; generally, but incorrectly, called by the Eastern Christians among the Arabs"},{"kind":"arabic","text_bw":"Alr~uwHu Alqudusu","text_ar":"الرُّوحُ القُدُسُ"},{"kind":"text","text":": but accord. to the Muslims,]"},{"kind":"italic_en","text":"Jibreel"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Gabriel, the Archangel"},{"kind":"text","text":"]; (S, A, K; and Bd, ubi supra;) as also"},{"kind":"arabic","text_bw":"Alqudosu","text_ar":"القُدْسُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alqudusu","text_ar":"القُدُسُ"},{"kind":"text","text":": (K, TA:) or"},{"kind":"italic_en","text":"the Spirit of Jesus:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the Gospel:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the most great name of God, by which Jesus used to raise to life the dead:"},{"kind":"text","text":"(Bd, ubi supra:) or"},{"kind":"italic_en","text":"God's protection and direction."},{"kind":"text","text":"(A.) You say,"},{"kind":"arabic","text_bw":"ruwHu","text_ar":"رُوحُ"},{"kind":"arabic","text_bw":"Alqudusi maEaka","text_ar":"القُدُسِ مَعَكَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"muEiynuka","text_ar":"مُعِينُكَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Gabriel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"God's protection and direction, be with thee,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"be thine aider."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"qudosN","text_ar":"قُدْسٌ"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"qudusN","text_ar":"قُدُسٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Blessing."},{"kind":"text","text":"(M, TA.) ―         -b5-  Also,"},{"kind":"arabic","text_bw":"Alqudosu","text_ar":"القُدْسُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Alqudusu","text_ar":"القُدُسُ","orth_type":"arrow"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Albayotu Almuqad~asu","text_ar":"البَيْتُ المُقَدَّسُ"},{"kind":"text","text":", q. v. (K,) or"},{"kind":"arabic","text_bw":"bayotu Almaqodisi","text_ar":"بَيْتُ المَقْدِسِ"},{"kind":"text","text":". (A.) ―         -b6-  And ↓"},{"kind":"arabic","text_bw":"A^aroDu Alqudusi","text_ar":"اَرْضُ القُدُسِ","orth_type":"arrow"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"ArD Alqudosi","text_ar":"ارض القُدْسِ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AlArD Almuqad~asapu","text_ar":"الارض المُقَدَّسَةُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n35307","headword_ar":"قَدَسٌ","root":"qds","body":[{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"vessel of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"saTol","text_ar":"سَطْل"},{"kind":"text","text":"; (S, A, K;) of the dial. of the people of El-Hijáz; so called because one purifies himself in it, (S, TA,) and with it. (TA.)"}],"source_refs":["S","TA"]},{"entry_id":"n35308","headword_ar":"قُدُسٌ","root":"qds","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qudosN","text_ar":"قُدْسٌ"},{"kind":"text","text":", throughout."}],"source_refs":[]}]}}