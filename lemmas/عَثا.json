le":"present_1mp","form":"نَعْثُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْثُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28072"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AB%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause corruption, to act wickedly","tags":["intransitive"]}]},"etymology":null,"ipa":["/ʕa.θaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28072","headword_ar":"عَثَا","root":"Evw and EvY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEovuw","text_ar":"يَعْثُو"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"Euvuw~N","text_ar":"عُثُوٌّ"},{"kind":"text","text":", (K, TA,) [accord. to the CK"},{"kind":"arabic","text_bw":"EavowN","text_ar":"عَثْوٌ"},{"kind":"text","text":", but] like"},{"kind":"arabic","text_bw":"sumuw~N","text_ar":"سُمُوٌّ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"EaviYa","text_ar":"عَثِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEovaY","text_ar":"يَعْثَى"},{"kind":"text","text":", (S, Msb, K,) which is of the dial. of El-Hijáz, and of which the inf. n. is"},{"kind":"arabic","text_bw":"EavFA","text_ar":"عَثًا"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"EavaY","text_ar":"عَثَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEovaY","text_ar":"يَعْثَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaEoviY","text_ar":"يَعْثِى"},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"EuviY~N","text_ar":"عُثِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiviY~N","text_ar":"عِثِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EavayaAnN","text_ar":"عَثَيَانٌ"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"He acted corruptly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did, mischief:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"did so in the utmost degree:"},{"kind":"text","text":"(TA:)"},{"kind":"arabic","text_bw":"fiY AlA^aroDi","text_ar":"فِى الاَرْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the earth"},{"kind":"text","text":"]: (S, TA:) the aor. of one of the dial. vars. occurs in the Kur ii. 57; &c.: some say that"},{"kind":"arabic","text_bw":"EvA","text_ar":"عثا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yEvA","text_ar":"يعثا"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"EivaY","text_ar":"عِثَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEovaY","text_ar":"يَعْثَى"},{"kind":"text","text":",] is formed by transposition from"},{"kind":"arabic","text_bw":"EaAva","text_ar":"عَاثَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEiyvu","text_ar":"يَعِيثُ"},{"kind":"text","text":": (TA:) accord. to Er-Rághib,"},{"kind":"arabic","text_bw":"EayovN","text_ar":"عَيْثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuviY~N","text_ar":"عُثِىٌّ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"EiviY~N","text_ar":"عِثِىٌّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Euvuw~N","text_ar":"عُثُوٌّ"},{"kind":"text","text":"are nearly alike; but"},{"kind":"arabic","text_bw":"EayovN","text_ar":"عَيْثٌ"},{"kind":"text","text":"is mostly used in relation to that which is perceived by sense; and"},{"kind":"arabic","text_bw":"EvY~","text_ar":"عثىّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Evw~","text_ar":"عثوّ"},{"kind":"text","text":", in relation to that which is perceived by the [mind or] judgment: some say that"},{"kind":"arabic","text_bw":"Evw~","text_ar":"عثوّ"},{"kind":"text","text":"[as also"},{"kind":"arabic","text_bw":"EvY~","text_ar":"عثىّ"},{"kind":"text","text":"] is the"},{"kind":"italic_en","text":"acting wrongfully, injuriously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unjustly;"},{"kind":"text","text":"and sometimes does not involve the acting corruptly: (MF and TA in art."},{"kind":"arabic","text_bw":"Eyv","text_ar":"عيث"},{"kind":"text","text":":) Lh says that"},{"kind":"arabic","text_bw":"EaviYa","text_ar":"عَثِىَ"},{"kind":"text","text":"is of the dial. of El-Hijáz, and is the [more] approved form; and"},{"kind":"arabic","text_bw":"EAv","text_ar":"عاث"},{"kind":"text","text":"is of the dial. of the Benoo-Temeem. (TA in that art.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EaviYa","text_ar":"عَثِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEovaY","text_ar":"يَعْثَى"},{"kind":"text","text":", inf.n."},{"kind":"arabic","text_bw":"EavFA","text_ar":"عَثًا"},{"kind":"text","text":", said of the hair of the head,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dry and matted, and was long left uncombed."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}