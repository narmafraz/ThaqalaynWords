{"lemma":"زَرَعَ","slug":"زَرَعَ","root":"ز.ر.ع","root_slug":"ز-ر-ع","root_link":"/words/roots/ز-ر-ع","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"زَرَعْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"زَرَعْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"زَرَعْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"زَرَعْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"زَرَعْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"زَرَعَ","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"زَرَعَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"زَرَعا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"زَرَعَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"زَرَعُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"زَرَعْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَزْرَع","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَزْرَعِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَزْرَعِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَزْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَزْرَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَزْرَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَزْرَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَزْرَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَزْرَع","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَزْرَع","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَزْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَزْرَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَزْرَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَزْرَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَزْرَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَزْرَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَزْرَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"زَرَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زَرَعْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَزْرَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَزْرَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":true,"lemma_key":"زَرَعَ","root":"زرع","pos":"N","occurrence_count":10},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n17658"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%B1%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sow"},{"pos":"verb","gloss":"to spread, to scatter"},{"pos":"verb","gloss":"to plant (place a seed or plant in a substrate in order that it may live and grow; also used for planting of explosive charges, organs etc.)"},{"pos":"verb","gloss":"to till, to cultivate"},{"pos":"noun","gloss":"verbal noun of زَرَعَ (zaraʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"sowing"},{"pos":"noun","gloss":"seed"},{"pos":"noun","gloss":"green crop"},{"pos":"noun","gloss":"plantation"},{"pos":"noun","gloss":"field, fields"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *zarʕ- (“seed”). Cognate with Hebrew זֶרַע (zéra', “seed”), Akkadian 𒆰 (zērum, “seed”), Classical Syriac ܙܪܥܐ and Ugaritic 𐎄𐎗𐎓 (drʿ, “seed”)."},"ipa":["/za.ra.ʕa/","/zarʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17658","headword_ar":"زَرَعَ","root":"zrE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaroEN","text_ar":"زَرْعٌ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"ziraAEapN","text_ar":"زِرَاعَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He sowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast seed;"},{"kind":"text","text":"(S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"AizodaraEa","text_ar":"اِزْدَرَعَ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) originally"},{"kind":"arabic","text_bw":"AizotaraEa","text_ar":"اِزْتَرَعَ"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":"in order that it may agree with the"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":", (S, K,) for"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":"are pronounced with the voice as well as the breath, whereas"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"is pronounced with the breath only: (S, TA:) [or the latter verb, as appears from an explanation of it to be found below, may signify"},{"kind":"italic_en","text":"he sowed for himself."},{"kind":"text","text":"] They say,"},{"kind":"arabic","text_bw":"mano zaraEa HaSada","text_ar":"مَنْ زَرَعَ حَصَدَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who sows reaps"},{"kind":"text","text":"]. (TA.) And [they use this verb transitively, saying,]"},{"kind":"arabic","text_bw":"zaraEotu Albur~a waAl$~aEiyra","text_ar":"زَرَعْتُ البُرَّ وَالشَّعِيرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I sowed wheat and barley"},{"kind":"text","text":"]: and in like manner,"},{"kind":"arabic","text_bw":"zaraEotu Al$~ajara","text_ar":"زَرَعْتُ الشَّجَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I sowed the trees;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sowed the seeds which should produce the trees:"},{"kind":"text","text":"or it may signify"},{"kind":"italic_en","text":"I planted the trees"},{"kind":"text","text":"]. (Ibn-Abi-l-Hadeed.) And"},{"kind":"arabic","text_bw":"zaraEa AlHub~a laka fiY Alquluwbi karamuka waHusonu xuluqika","text_ar":"زَرَعَ الحُبَّ لَكَ فِى القُلُوبِ كَرَمُكَ وَحُسْنُ خُلُقِكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Thy generosity and the goodness of thy disposition have sown love for thee in the hearts"},{"kind":"text","text":"]. (TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"mano kaAnato lahu A^aroDN","text_ar":"مَنْ كَانَتْ لَهُ اَرْضٌ"},{"kind":"arabic","text_bw":"faliyazoraEohaA A^awo liyamonaHohaA A^axaAhu faA_ino A^abaY faliyumosiko A^aroDahu","text_ar":"فَلِيَزْرَعْهَا اَوْ لِيَمْنَحْهَا اَخَاهُ فَاـِنْ اَبَى فَلِيُمْسِكْ اَرْضَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Whoso hath land,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"let him sow it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or let him lend it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"give it, to his brother; and if he refuse, let him retain his land"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"zaraEa AlA^aroDa","text_ar":"زَرَعَ الاَرْضَ"},{"kind":"text","text":", (Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"zaroEN","text_ar":"زَرْعٌ"},{"kind":"text","text":", (Msb,) signifies [also] (tropical:)"},{"kind":"italic_en","text":"He ploughed up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tilled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cultivated, the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, for sowing."},{"kind":"text","text":"(Mgh, Msb.) Hence [the saying in a trad.],"},{"kind":"arabic","text_bw":"A_i*aA zaraEato h`*ihi AlA^um~apu","text_ar":"اـِذَا زَرَعَتْ هٰذِهِ الاُمَّةُ"},{"kind":"arabic","text_bw":"nuziEa minohaA Aln~aSoru","text_ar":"نُزِعَ مِنْهَا النَّصْرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"When this nation shall employ itself"},{"kind":"text","text":"altogether"},{"kind":"italic_en","text":"with agriculture"},{"kind":"text","text":"and the affairs of the present world, and turn away from warring against unbelievers and the like,"},{"kind":"italic_en","text":"aid shall be withdrawn from it."},{"kind":"text","text":"(Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"zaraEahu A@ll~`hu","text_ar":"زَرَعَهُ ا@للّٰهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"God caused it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it, to grow, vegetate,"},{"kind":"text","text":"or"},{"kind":"page_break","n":1226},{"kind":"italic_en","text":"germinate;"},{"kind":"text","text":"(S, Mgh, Msb, K;) and,"},{"kind":"italic_en","text":"to increase;"},{"kind":"text","text":"(Mgh;) namely,"},{"kind":"arabic","text_bw":"AlHarova","text_ar":"الحَرْثَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the seed-produce"},{"kind":"text","text":"]. (Mgh, Msb;) The verb is properly thus used of divine affairs, exclusively of human: (Er-Rághib:) and hence the saying in the Kur [lvi. 63-4],"},{"kind":"arabic","text_bw":"A^afaraA^ayotumo maA","text_ar":"اَفَرَاَيْتُمْ مَا"},{"kind":"arabic","text_bw":"taHoruvuwna A^aA^anotumo tazoraEuwnahu A^amo naHonu Alz~aAriEuwna","text_ar":"تَحْرُثُونَ اَاَنْتُمْ تَزْرَعُونَهُ اَمْ نَحْنُ الزَّارِعُونَ"},{"kind":"text","text":"(S, * Er-Rághib)"},{"kind":"italic_en","text":"Now think ye, what ye sow, do ye cause it to grow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"are We the causers of growth?"},{"kind":"text","text":"(Bd:) or, as some say,"},{"kind":"italic_en","text":"do ye cause it to increase, or are We the causers of"},{"kind":"text","text":"its"},{"kind":"italic_en","text":"increase?"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"Harov","text_ar":"حَرْث"},{"kind":"text","text":"[or sowing] being ascribed to them, and the"},{"kind":"arabic","text_bw":"zaroE","text_ar":"زَرْع"},{"kind":"text","text":"[or causing to grow] exclusively to God: when the latter is ascribed to a man, it is because he is an agent as a means of making to grow; as when you say,"},{"kind":"arabic","text_bw":"A^anobat~u ka*aA","text_ar":"اَنْبَتُّ كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I was a means of causing such a thing to grow."},{"kind":"text","text":"(Er-Rághib.) [In like manner,] you say,"},{"kind":"arabic","text_bw":"zaroEFA","text_ar":"زَرْعًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AizodaraEa","text_ar":"اِزْدَرَعَ","orth_type":"arrow"},{"kind":"text","text":", meaning (tropical:)  ["},{"kind":"italic_en","text":"He raised seed-produce,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"was a means of causing it to grow,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for himself,"},{"kind":"text","text":"in particular. (TA.) ―         -b4-  [Hence,] one says, with respect to a child,"},{"kind":"arabic","text_bw":"zaraEahu A@ll~`hu","text_ar":"زَرَعَهُ ا@للّٰهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"May God render him sound and strong;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jabarahu","text_ar":"جَبَرَهُ"},{"kind":"text","text":": (S, K, TA:) like as one says"},{"kind":"arabic","text_bw":"A^anobatahu A@ll~`hu","text_ar":"اَنْبَتَهُ ا@للّٰهُ"},{"kind":"text","text":": and in like manner,"},{"kind":"arabic","text_bw":"zaraEa A@ll~`hu waladaka liloxayori","text_ar":"زَرَعَ ا@للّٰهُ وَلَدَكَ لِلْخَيْرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"May God render thine offspring sound and strong,"},{"kind":"text","text":"or rather,"},{"kind":"italic_en","text":"cause thine offspring to grow up, for"},{"kind":"text","text":"the doing, or enjoyment, of"},{"kind":"italic_en","text":"what is good"},{"kind":"text","text":"]. (TA.) ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"zuriEa lahu baEodu $aqaAwapK","text_ar":"زُرِعَ لَهُ بَعْدُ شَقَاوَةٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"An increase was made for him after adversity;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he obtained property after want;"},{"kind":"text","text":"for the verb in this instance is like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":". (Ibn-'Abbád, K.)"}],"source_refs":["K","S","TA","Msb","Mgh","Bd"]}]}}