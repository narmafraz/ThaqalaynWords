,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْجُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْجُلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْجُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْجِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْجِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْجُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَحْجِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَجَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَجَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْجُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْجُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْجِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْجِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n7200"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AC%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"partridge","tags":["collective"]},{"pos":"verb","gloss":"to hop, to take leaps, to walk as if with the legs shackled"},{"pos":"verb","gloss":"to bedeck with anklets or shackles"},{"pos":"verb","gloss":"to bring to the curtained canopy حَجَلَة (ḥajala)"},{"pos":"noun","gloss":"verbal noun of حَجَلَ (ḥajala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"an anklet as well as a shackle"}]},"etymology":{"source":"wiktextract","text":"The absence of farther cognates suggests a borrowing of the name for the bird from Classical Syriac ܚܰܓܠܴܐ (ḥaḡlā), ܚܰܓܠܬܴܐ (ḥaḡəlṯā, “partridge”), also appearing early, although by itself the term is unsuspicious and cognacy cannot be excluded. Although there is a potential semantic connection to the verb “to hop”, this would require a synonymous verb to exist in a common ancestor of Arabic and Syriac as the latter is, owing to its age, unlikely to be a borrowing from Arabic, so if the words are related, the verb would have to be denominal. In that case, the word for an anklet could also be denominal, naming a thing on the part of the body used to hop; however there is also a connection to ح ج ر (ḥ j r) and its Semitic matches related to detaining and Aramaic חֲגַל (ḥăḡal) / ܚܓܰܠ (ḥgal, “to draw a circle about, to gird”), possibly the source verb of the name of the partridge due to its going around or due to its bulbous body depending on the species, Ge'ez ሐገለ (ḥägälä, “to tie, to bind”), also Ge'ez ሐግል (ḥägl, “shackle, fetter”), and the surrounding meaning is again found for the root ḥ-g-l in Old South Arabian and Soqotri, which implies together with the consideration of workmanship lacking in the Najd that instead, the word for an anklet or shackle was borrowed into Arabic from a more southern Semitic language, from which the word for hopping was then derived, whereas the word for the partridge is to be seen as borrowed from Aramaic to account for its etymology."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7200","headword_ar":"حَجَلَ","root":"Hjl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajalaAnN","text_ar":"حَجَلَانٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"HajolN","text_ar":"حَجْلٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He walked having his legs shackled:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he raised one leg, and went slowly on the other leg:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he went with short steps, like him who has his legs shackled:"},{"kind":"text","text":"(Ham p. 221:) and"},{"kind":"italic_en","text":"he raised one leg, and hopped on the other:"},{"kind":"text","text":"(TA:) it is said of a bird: (S:) and it means, (S, K,) in like manner, (S,) as also ↓"},{"kind":"arabic","text_bw":"Hj~l","text_ar":"حجّل","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"he leaped in going;"},{"kind":"text","text":"(S, K, TA;) said of a crow, or raven; (K, TA;)"},{"kind":"italic_en","text":"as leaps"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yaHojulu","text_ar":"يَحْجُلُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the camel that is hocked"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in one leg"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon three legs, and the boy upon one leg"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon two."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"arabic","text_bw":"Hajalato Eayonuhu","text_ar":"حَجَلَتْ عَيْنُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HujuwlN","text_ar":"حُجُولٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Hj~lt","text_ar":"حجّلت","orth_type":"arrow"},{"kind":"text","text":", (As, S. K,) inf. n."},{"kind":"arabic","text_bw":"taHojiylN","text_ar":"تَحْجِيلٌ"},{"kind":"text","text":"; (As, S;)"},{"kind":"italic_en","text":"His eye sank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became depressed, in his head;"},{"kind":"text","text":"(As, S, K;) said of a man, and of a camel, and of a horse: (TA:) and ↓"},{"kind":"arabic","text_bw":"Hawojala","text_ar":"حَوْجَلَ","orth_type":"arrow"},{"kind":"text","text":", alone, signifies the same; (Ibn-' Abbád, K;) said of a man. (Ibn-' Abbád, TA.)       -A3-"},{"kind":"arabic","text_bw":"Hujila bayonahu wabayonahu","text_ar":"حُجِلَ بَيْنَهُ وَبَيْنَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajolN","text_ar":"حَجْلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"An obstacle was made to intervene between him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, and him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","M","TA"]}]},"classical_definitions":null}