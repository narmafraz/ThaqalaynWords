TapN","text_ar":"حِيطَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) which latter is originally"},{"kind":"arabic","text_bw":"HiwoTapN","text_ar":"حِوْطَةٌ"},{"kind":"text","text":", (TA,) [and is also an inf. n. of 1,] and ↓"},{"kind":"arabic","text_bw":"HawoTapN","text_ar":"حَوْطَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) Some hold"},{"kind":"arabic","text_bw":"AHtyAT","text_ar":"احتياط"},{"kind":"text","text":"to belong to art."},{"kind":"arabic","text_bw":"HyT","text_ar":"حيط"},{"kind":"text","text":". (Msb.) You say also"},{"kind":"arabic","text_bw":"fiY AlA^umuwri","text_ar":"فِى الاُمُورِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstHAT","text_ar":"استحاط","orth_type":"arrow"},{"kind":"text","text":"[meaning in like manner (assumed tropical:)"},{"kind":"italic_en","text":"He took the course prescribed by prudence,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the affairs:"},{"kind":"text","text":"as is shown below: see"},{"kind":"arabic","text_bw":"muHotaATN","text_ar":"مُحْتَاطٌ"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb","K","TA"]},{"entry_id":"n9756","headword_ar":"احتاط","root":"HyT","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"HwT","text_ar":"حوط"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}