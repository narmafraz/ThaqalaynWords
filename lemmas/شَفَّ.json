"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n22595"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%81%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be seethrough"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22595","headword_ar":"شَفَّ","root":"$f","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ufuwfN","text_ar":"شُفُوفٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and"},{"kind":"arabic","text_bw":"$afiyfN","text_ar":"شَفِيفٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"$afafN","text_ar":"شَفَفٌ"},{"kind":"text","text":", (CK, [but not in my MS. copy of the K nor in the TA,])"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a garment, or piece of cloth,)"},{"kind":"italic_en","text":"was thin, fine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate,"},{"kind":"text","text":"(S, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"so that what was behind it was visible,"},{"kind":"text","text":"(S, * IB, Mgh, [for"},{"kind":"arabic","text_bw":"xalaqahu","text_ar":"خَلَقَهُ"},{"kind":"text","text":"in some copies of the S, and"},{"kind":"arabic","text_bw":"xalofahu","text_ar":"خَلْفَهُ"},{"kind":"text","text":"in others, I read"},{"kind":"arabic","text_bw":"maA xalofahu","text_ar":"مَا خَلْفَهُ"},{"kind":"text","text":", which is the right reading accord. to IB and the TA, agreeably with the reading in the Mgh, which is"},{"kind":"arabic","text_bw":"maA waraA='ahu","text_ar":"مَا وَرَا=ءَهُ"},{"kind":"text","text":",]) or"},{"kind":"italic_en","text":"so as to tell what was beneath it:"},{"kind":"text","text":"(O, K:) [and"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a gem, or the like,)"},{"kind":"italic_en","text":"was translucent:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was transparent."},{"kind":"text","text":"(See"},{"kind":"arabic","text_bw":"$af~aAfN","text_ar":"شَفَّافٌ"},{"kind":"text","text":".)] One says,"},{"kind":"arabic","text_bw":"$af~a Ealayohi vawobuhu","text_ar":"شَفَّ عَلَيْهِ ثَوْبُهُ"},{"kind":"italic_en","text":"His garment was thin,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"upon him."},{"kind":"text","text":"(S.) ―         -b2-  ―         -b3-  And"},{"kind":"arabic","text_bw":"$af~a","text_ar":"شَفَّ"},{"kind":"arabic","text_bw":"jisomuhu","text_ar":"جِسْمُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ufuwfN","text_ar":"شُفُوفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"His body became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated."},{"kind":"text","text":"(S, O, K.)       -A2-"},{"kind":"arabic","text_bw":"$af~a","text_ar":"شَفَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$if~N","text_ar":"شِفٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, O, Msb)"},{"kind":"italic_en","text":"exceeded;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, redundant."},{"kind":"text","text":"(S, O, Msb, K.) Hence, in a trad.,"},{"kind":"arabic","text_bw":"$af~a naHowFA mino daAniqK","text_ar":"شَفَّ نَحْوًا مِنْ دَانِقٍ"},{"kind":"italic_en","text":"It exceeded by about a"},{"kind":"arabic","text_bw":"dAnq","text_ar":"دانق"},{"kind":"text","text":". (Sh, O.) And one says,"},{"kind":"arabic","text_bw":"$af~a","text_ar":"شَفَّ"},{"kind":"arabic","text_bw":"Ealayoh","text_ar":"عَلَيْه"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$uf~u","text_ar":"يَشُفُّ"},{"kind":"text","text":", [so in the L and TA, contr. to rule, probably a mistranscription for"},{"kind":"arabic","text_bw":"ya$if~u","text_ar":"يَشِفُّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"$ufuwfN","text_ar":"شُفُوفٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"$f~f","text_ar":"شفّف","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Ast$f~","text_ar":"استشفّ","orth_type":"arrow"},{"kind":"text","text":"; [app. meaning, as seems to be indicated by the context,"},{"kind":"italic_en","text":"It exceeded it:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"$afifotu fiY Als~iloEapi","text_ar":"شَفِفْتُ فِى السِّلْعَةِ"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"$afafotu","text_ar":"شَفَفْتُ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I gained in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon, the the article of merchandise:"},{"kind":"text","text":"(TA: [and so, app., ↓"},{"kind":"arabic","text_bw":"$af~afotu","text_ar":"شَفَّفْتُ","orth_type":"arrow"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$af~aY","text_ar":"شَفَّى"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"fY tijaAratihi","text_ar":"فى تِجَارَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ast$f~","text_ar":"استشفّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He obtained what is termed"},{"kind":"arabic","text_bw":"$if~N","text_ar":"شِفٌّ"},{"kind":"italic_en","text":"in his traffic;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"he made gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profit, in his traffic;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"rabiHa","text_ar":"رَبِحَ"},{"kind":"text","text":". (S and K in art."},{"kind":"arabic","text_bw":"rbH","text_ar":"ربح"},{"kind":"text","text":".) ―         -b2-  And sometimes (Msb) it signifies also the contr.; i. e."},{"kind":"italic_en","text":"It fell short;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, deficient."},{"kind":"text","text":"(Msb, K.) One says, (O, Msb,) of a dirhem, (O,)"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"arabic","text_bw":"ya$if~u qaliylFA","text_ar":"يَشِفُّ قَلِيلًا"},{"kind":"italic_en","text":"This falls short,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is deficient, a little."},{"kind":"text","text":"(O, Msb.) And"},{"kind":"arabic","text_bw":"$af~a Eanohu Alv~awobu","text_ar":"شَفَّ عَنْهُ الثَّوْبُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"The garment was too short for him."},{"kind":"text","text":"(TA.)       -A3-  Also"},{"kind":"arabic","text_bw":"$af~a","text_ar":"شَفَّ"},{"kind":"text","text":", (O, K,) aor."},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, O)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of motion, commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation."},{"kind":"text","text":"(O, K.)       -A4-  And"},{"kind":"arabic","text_bw":"$af~a laka Al$~aYo'u","text_ar":"شَفَّ لَكَ الشَّىْءُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"The thing belonged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pertained, to thee permanently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may the thing belong,"},{"kind":"text","text":"&c.]. (TA.)       -A5-"},{"kind":"arabic","text_bw":"$af~ahu","text_ar":"شَفَّهُ"},{"kind":"text","text":", (S, M, O, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$af~N","text_ar":"شَفٌّ"},{"kind":"text","text":"(S, M, TA) and"},{"kind":"arabic","text_bw":"$ufuwfN","text_ar":"شُفُوفٌ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anxiety)"},{"kind":"italic_en","text":"rendered him lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"$afo$afahu","text_ar":"شَفْشَفَهُ","orth_type":"arrow"},{"kind":"text","text":"; (S;) both are also expl. as meaning"},{"kind":"italic_en","text":"it rendered him lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lank in the belly, so that he became slender:"},{"kind":"text","text":"(TA:) or, accord. to the M,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(grief, and love,)"},{"kind":"italic_en","text":"pained his heart:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered him lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived him of his reason:"},{"kind":"text","text":"and it is said of grief as meaning"},{"kind":"italic_en","text":"it manifested what he felt of impatience."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"$af~a","text_ar":"شَفَّ"},{"kind":"arabic","text_bw":"Aln~ufuwsa","text_ar":"النُّفُوسَ"},{"kind":"text","text":", as used in a verse of Towbeh Ibn-El- Homeiyir,"},{"kind":"italic_en","text":"It hurt and melted the souls."},{"kind":"text","text":"(Ham p. 594.)       -A6-  See also 8, in two places."}],"source_refs":["S","Mgh","O","Msb","K","M","TA"]}]}}