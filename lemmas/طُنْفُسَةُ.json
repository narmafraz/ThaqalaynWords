"},{"kind":"italic_en","text":"a piece of cloth"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"vawobN","text_ar":"ثَوْبٌ"},{"kind":"text","text":"): or"},{"kind":"italic_en","text":"a kind of carpet called in Persian"},{"kind":"arabic","text_bw":"Tabosaho","text_ar":"طَبْسَهْ"},{"kind":"text","text":"(Har p. 376) ["},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"tanobasaho","text_ar":"تَنْبَسَهْ"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"a carpet having a fine nap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pile:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"what is put beneath the"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"camel's saddle"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"upon the shoulders of the camel:"},{"kind":"text","text":"(Msb:) or the"},{"kind":"arabic","text_bw":"numoruqap","text_ar":"نُمْرُقَة"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"above the"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":": (M:) pl."},{"kind":"arabic","text_bw":"TanaAfisu","text_ar":"طَنَافِسُ"},{"kind":"text","text":". (S, Msb, K.)"}],"source_refs":["M","Msb","K","Kr"]}]},"classical_definitions":null}