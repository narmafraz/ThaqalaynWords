{"lemma":"زَحْمَةٍ","slug":"زَحْمَةٍ","root":"ز.ح.م","root_slug":"ز-ح-م","root_link":"/words/roots/ز-ح-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n17570","n17573","n17574"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%AD%D9%92%D9%85%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of زَحَمَ (zaḥama) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/zaħ.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17570","headword_ar":"زَحَمَهُ","root":"zHm","body":[{"kind":"text","text":", (Mgh, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zaHomN","text_ar":"زَحْمٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"zaHomapN","text_ar":"زَحْمَةٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"ziHaAmN","text_ar":"زِحَامٌ"},{"kind":"text","text":", with kesr; (K; [but see what here follows, and see also"},{"kind":"arabic","text_bw":"zaHomapN","text_ar":"زَحْمَةٌ"},{"kind":"text","text":"below;] and ↓"},{"kind":"arabic","text_bw":"zAHmhu","text_ar":"زاحمهُ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"muzaAHamapN","text_ar":"مُزَاحَمَةٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"ziHaAmN","text_ar":"زِحَامٌ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"DaAyaqahu","text_ar":"ضَايَقَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He straitened him,"},{"kind":"text","text":"meaning, in this instance,"},{"kind":"italic_en","text":"by pressure;"},{"kind":"text","text":"and properly,"},{"kind":"italic_en","text":"being in like manner straitened by him"},{"kind":"text","text":"]: (K in explanation of"},{"kind":"arabic","text_bw":"zaHamahu","text_ar":"زَحَمَهُ"},{"kind":"text","text":", and TA in explanation of"},{"kind":"arabic","text_bw":"zAHmhu","text_ar":"زاحمهُ"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dafaEahu","text_ar":"دَفَعَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he pushed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repelled him"},{"kind":"text","text":"]; generally meaning ["},{"kind":"italic_en","text":"he pushed against him"},{"kind":"text","text":"] in a strait, or narrow, [or crowded,] place: (Msb in explanation of"},{"kind":"arabic","text_bw":"zaHamahu","text_ar":"زَحَمَهُ"},{"kind":"text","text":", and app. in explanation of"},{"kind":"arabic","text_bw":"zAHmhu","text_ar":"زاحمهُ"},{"kind":"text","text":"also:) [or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"daAfaEahu","text_ar":"دَافَعَهُ"},{"kind":"text","text":", which often signifies the same as"},{"kind":"arabic","text_bw":"dafaEahu","text_ar":"دَفَعَهُ"},{"kind":"text","text":"; but more properly,"},{"kind":"italic_en","text":"he pushed him,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"being pushed,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"by him:"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"zaHamaniYa Aln~aAsu","text_ar":"زَحَمَنِىَ النَّاسُ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"daAfaEuwniY","text_ar":"دَافَعُونِى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The people pushed against me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pushed me,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"being pushed,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"by me;"},{"kind":"text","text":"] in a strait, or narrow, [or crowded,] place: (Mgh:) [or"},{"kind":"italic_en","text":"pressed, crowded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thronged, me:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"muzaAHamapN","text_ar":"مُزَاحَمَةٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"mudaAfaEapN","text_ar":"مُدَافَعَةٌ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"dfE","text_ar":"دفع"},{"kind":"text","text":":) ↓"},{"kind":"arabic","text_bw":"AizodaHamahu","text_ar":"اِزْدَحَمَهُ","orth_type":"arrow"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"zaHamahu","text_ar":"زَحَمَهُ"},{"kind":"text","text":"is a mistake. (Mgh.) One says,"},{"kind":"arabic","text_bw":"zaHama Alqawomu baEoDuhumo baEoDFA","text_ar":"زَحَمَ القَوْمُ بَعْضُهُمْ بَعْضًا"},{"kind":"italic_en","text":"The people straitened one another;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taDaAyaquwA","text_ar":"تَضَايَقُوا"},{"kind":"text","text":"; [or"},{"kind":"italic_en","text":"pressed, crowded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thronged, one another;"},{"kind":"text","text":"] in a sitting-place, or place of assembly: (Msb:) as also ↓"},{"kind":"arabic","text_bw":"AzdHmwA","text_ar":"ازدحموا","orth_type":"arrow"},{"kind":"text","text":", (Msb, K, * TA,) in whatever place it be; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tzAHmwA","text_ar":"تزاحموا","orth_type":"arrow"},{"kind":"text","text":". (K, * TA.) One may also use the pass. form of"},{"kind":"arabic","text_bw":"zaHama","text_ar":"زَحَمَ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"zuHima","text_ar":"زُحِمَ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"He was straitened, by pressure;"},{"kind":"text","text":"&c.]; and that of"},{"kind":"arabic","text_bw":"zaAHama","text_ar":"زَاحَمَ"},{"kind":"text","text":", i. e. ↓"},{"kind":"arabic","text_bw":"zuwHima","text_ar":"زُوحِمَ","orth_type":"arrow"},{"kind":"text","text":"[meaning the same]. (Msb.)       -A2-  ↓"},{"kind":"arabic","text_bw":"zaHima zuHomapF","text_ar":"زَحِمَ زُحْمَةً","orth_type":"arrow"},{"kind":"italic_en","text":"He gobbled a gobbet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morsel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mouthful:"},{"kind":"text","text":"so in the “ Nawádir; ” as also"},{"kind":"arabic","text_bw":"zahimahaA","text_ar":"زَهِمَهَا"},{"kind":"text","text":". (TA.) 3: see above, in two places. ―         -b2-  [Hence,] one says,"},{"kind":"arabic","text_bw":"zaAHama EalaY Alr~iy^aAsapi waA^araAdahaA","text_ar":"زَاحَمَ عَلَى الرِّيَاسَةِ وَاَرَادَهَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He strove for headship,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"command, and desired it"},{"kind":"text","text":"]. (IAar, TA in art."},{"kind":"arabic","text_bw":"rA^s","text_ar":"راس"},{"kind":"text","text":".) [And hence the prov."},{"kind":"arabic","text_bw":"zaAHim","text_ar":"زَاحِم"},{"kind":"arabic","text_bw":"biEawodK A^awo daEo","text_ar":"بِعَوْدٍ اَوْ دَعْ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Ewd","text_ar":"عود"},{"kind":"text","text":".] ―         -b3-  [Hence, likewise,]"},{"kind":"arabic","text_bw":"zAHmhu","text_ar":"زاحمهُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He treated him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved towards him, with roughness, rudeness, hardness, harshness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ill-nature."},{"kind":"text","text":"(TA. [I find this explanation noted down by me as taken from the TA, but without any reference to the art. from which I obtained it. It is not in the present art.]) ―         -b4-"},{"kind":"arabic","text_bw":"zAHm Alxamosiyna","text_ar":"زاحم الخَمْسِينَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"approached,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"[age of]"},{"kind":"italic_en","text":"fifty"},{"kind":"text","text":"[years]; (K, TA;) as also"},{"kind":"arabic","text_bw":"zaAhamahaA","text_ar":"زَاهَمَهَا"},{"kind":"text","text":". (TA.)"}],"source_refs":["Mgh","Msb","K","S","TA"]},{"entry_id":"n17573","headword_ar":"زَحْمَةٌ","root":"zHm","body":[{"kind":"text","text":"[an inf. n. of"},{"kind":"arabic","text_bw":"zaHamahu","text_ar":"زَحَمَهُ"},{"kind":"text","text":"accord. to the Msb]"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ziHaAmN","text_ar":"زِحَامٌ","orth_type":"arrow"},{"kind":"text","text":"[likewise an inf. n. of"},{"kind":"arabic","text_bw":"zaHamahu","text_ar":"زَحَمَهُ"},{"kind":"text","text":"accord. to the K, and of"},{"kind":"arabic","text_bw":"zaAHamahu","text_ar":"زَاحَمَهُ"},{"kind":"text","text":"accord. to the Msb: both signify"},{"kind":"italic_en","text":"A straitening, pushing, pressing, crowding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thronging"},{"kind":"text","text":"]. (S.) ―         -b2-"},{"kind":"arabic","text_bw":"zaHomapu AlwilaAdapi","text_ar":"زَحْمَةُ الوِلَادَةِ"},{"kind":"italic_en","text":"The moaning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard breathing,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"zaHorap","text_ar":"زَحْرَة"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"with which the child comes forth;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"zajomap","text_ar":"زَجْمَة"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zakomap","text_ar":"زَكْمَة"},{"kind":"text","text":". (K in the present art. and in art."},{"kind":"arabic","text_bw":"zjm","text_ar":"زجم"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n17574","headword_ar":"زُحْمَةٌ","root":"zHm","body":[{"kind":"italic_en","text":"A gobbet, morsel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mouthful."},{"kind":"text","text":"(TA.) See 1, last sentence."}],"source_refs":[]}]},"classical_definitions":null}