{"lemma":"نَزْرٍ","slug":"نَزْرٍ","root":"ن.ز.ر","root_slug":"ن-ز-ر","root_link":"/words/roots/ن-ز-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n39667","n39671"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B2%D9%92%D8%B1%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be minimal, to be little, to be scarce, to be scant, to be trifling"},{"pos":"verb","gloss":"to deem little, to esteem trifling"},{"pos":"verb","gloss":"to withdraw little by little"},{"pos":"verb","gloss":"to make little, to make small"},{"pos":"adj","gloss":"minimal, little, scarce, scant, trifle"},{"pos":"noun","gloss":"minimal thing, modicum, trace, residue, vestige"}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39667","headword_ar":"نَزُرَ","root":"nzr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nazaArapN","text_ar":"نَزَارَةٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"nuzuwrN","text_ar":"نُزُورٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"nuzuwrapN","text_ar":"نُزُورَةٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"nuzorapN","text_ar":"نُزْرَةٌ"},{"kind":"text","text":", as in the M and L, and perhaps one of these last two forms is a mistake for the other, (TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, in quantity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"number;"},{"kind":"text","text":"(S, A, Msb, K;)"},{"kind":"italic_en","text":"paltry, mean, contemptible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable."},{"kind":"text","text":"(S, TA.) See also 5. ―         -b2-  Also, inf. n."},{"kind":"arabic","text_bw":"nazaArapN","text_ar":"نَزَارَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, possessed of little good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"little wealth."},{"kind":"text","text":"(AZ.) ―         -b3-"},{"kind":"arabic","text_bw":"nazarato","text_ar":"نَزَرَتْ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nazorN","text_ar":"نَزْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had little milk."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"nazarahu","text_ar":"نَزَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"nazorN","text_ar":"نَزْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He despised, and deemed little, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K. * TA.) See also 2. ―         -b2-"},{"kind":"italic_en","text":"He smote him with the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"evil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"eye."},{"kind":"text","text":"(Fr, in TA, art."},{"kind":"arabic","text_bw":"$zr","text_ar":"شزر"},{"kind":"text","text":".)       -A3-"},{"kind":"arabic","text_bw":"nazarahu","text_ar":"نَزَرَهُ"},{"kind":"text","text":", (As, A,) aor."},{"kind":"text","text":", (As,) inf. n."},{"kind":"arabic","text_bw":"nazorN","text_ar":"نَزْرٌ"},{"kind":"text","text":", (As, K,)"},{"kind":"italic_en","text":"He drew forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got out, what he had, by little and little:"},{"kind":"text","text":"(As:)"},{"kind":"italic_en","text":"he importuned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressed him, in asking"},{"kind":"text","text":"(A, K)"},{"kind":"italic_en","text":"a matter of science"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gift."},{"kind":"text","text":"(A.) You say also,"},{"kind":"arabic","text_bw":"fulaAnN laA yuEoTiY Hat~aY yunozara","text_ar":"فُلَانٌ لَا يُعْطِى حَتَّى يُنْزَرَ"},{"kind":"text","text":", (A, K,) or ↓"},{"kind":"arabic","text_bw":"yunaz~ara","text_ar":"يُنَزَّرَ","orth_type":"arrow"},{"kind":"text","text":", (so in two copies of the S,)"},{"kind":"italic_en","text":"Such a one will not give until he is importuned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressed,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"and despised."},{"kind":"text","text":"(S, K, TA.)"}],"source_refs":["S","A","Msb","K","TA","As"]},{"entry_id":"n39671","headword_ar":"نَزْرٌ","root":"nzr","body":[{"kind":"text","text":", applied to anything, (TA,)"},{"kind":"italic_en","text":"little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, in quantity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"number;"},{"kind":"text","text":"(S, A, Msb;)"},{"kind":"italic_en","text":"paltry, mean, contemptible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable:"},{"kind":"text","text":"(S, TA:) as also ↓"},{"kind":"arabic","text_bw":"naziyrN","text_ar":"نَزِيرٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb, K) and ↓"},{"kind":"arabic","text_bw":"nazuwrN","text_ar":"نَزُورٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb) and ↓"},{"kind":"arabic","text_bw":"manozuwrN","text_ar":"مَنْزُورٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the last signifies"},{"kind":"italic_en","text":"little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, in quantity,"},{"kind":"text","text":"applied to a gift, (S, TA,) and to food; (TA;) or a gift"},{"kind":"italic_en","text":"made little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, in quantity:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"nazorN","text_ar":"نَزْرٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"manozuwrN","text_ar":"مَنْزُورٌ","orth_type":"arrow"},{"kind":"text","text":"a gift"},{"kind":"italic_en","text":"obtained by importunity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gayoru manozuwrN","text_ar":"غَيْرُ مَنْزُورٌ","orth_type":"arrow"},{"kind":"text","text":"a gift"},{"kind":"italic_en","text":"given without its being asked for; without importunity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing."},{"kind":"text","text":"(TA.) It is also applied to speech: thus the speech of Mohammad is described as"},{"kind":"arabic","text_bw":"faSolN laA nazorN walaA ha*orN","text_ar":"فَصْلٌ لَا نَزْرٌ وَلَا هَذْرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Distinct;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty,"},{"kind":"text","text":"so as to indicate impotence,"},{"kind":"italic_en","text":"nor much and corrupt:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"not little nor much."},{"kind":"text","text":"(TA, art."},{"kind":"arabic","text_bw":"h*r","text_ar":"هذر"},{"kind":"text","text":".) ―         -b2-  A man"},{"kind":"italic_en","text":"possessing little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no, good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness; little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no, wealth;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"fazorN","text_ar":"فَزْرٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"manozuwrN","text_ar":"مَنْزُورٌ","orth_type":"arrow"},{"kind":"text","text":". (AZ.)       -A2-"},{"kind":"arabic","text_bw":"maA jiy^ota A_il~aA nazorFA","text_ar":"مَا جِيْتَ اـِلَّا نَزْرًا"},{"kind":"italic_en","text":"Thou hast not come otherwise than slowly, tardily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"late."},{"kind":"text","text":"(K.)"}],"source_refs":["TA","S","Msb","K"]}]},"classical_definitions":null}