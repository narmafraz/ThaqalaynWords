{"lemma":"ضَجَرُ","slug":"ضَجَرُ","root":"ض.ج.ر","root_slug":"ض-ج-ر","root_link":"/words/roots/ض-ج-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n25545","n25547","n25548"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%AC%D9%8E%D8%B1%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"bored, weary"}]},"etymology":null,"ipa":["/dˤa.d͡ʒir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25545","headword_ar":"ضَجِرَ","root":"Djr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, A, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"DajarN","text_ar":"ضَجَرٌ"},{"kind":"text","text":"; (S, Mgh, Msb;) and ↓"},{"kind":"arabic","text_bw":"tDj~r","text_ar":"تضجّر","orth_type":"arrow"},{"kind":"text","text":"; (A, Mgh, Msb, K;)"},{"kind":"italic_en","text":"He was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted by grief:"},{"kind":"text","text":"(S:) or, followed by"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":", (A, Mgh, Msb, K,) and by"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"he was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted by grief, at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it, and by distress of mind, and complained:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"he was grieved at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"and distressed in mind,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and complained:"},{"kind":"text","text":"(A, Msb:) or"},{"kind":"italic_en","text":"he was disgusted"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tabar~ama","text_ar":"تَبَرَّمَ"},{"kind":"text","text":", A, K)"},{"kind":"italic_en","text":"at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by it, and was vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"by grief."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Dajira","text_ar":"ضَجِرَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grumbled, much:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"Dajirato","text_ar":"ضَجِرَتْ"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grumbled,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"on being milked,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"being distressed thereby."},{"kind":"text","text":"(A.) In a verse, (of El-Akhtal, TA,)"},{"kind":"arabic","text_bw":"Dajira","text_ar":"ضَجِرَ"},{"kind":"text","text":"is contracted into"},{"kind":"arabic","text_bw":"Dajora","text_ar":"ضَجْرَ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"faxi*N","text_ar":"فَخِذٌ"},{"kind":"text","text":", among nouns, is contracted [into"},{"kind":"arabic","text_bw":"faxo*N","text_ar":"فَخْذٌ"},{"kind":"text","text":"]. (S, TA.)"}],"source_refs":["S","A","Mgh","Msb","K"]},{"entry_id":"n25547","headword_ar":"ضَجْرٌ","root":"Djr","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n25548","headword_ar":"ضَجِرٌ","root":"Djr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted by grief:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"grieved,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"and distressed in mind,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and complaining:"},{"kind":"text","text":"(A, Msb:) or"},{"kind":"italic_en","text":"disgusted,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mutabar~imN","text_ar":"مُتَبَرِّمٌ"},{"kind":"text","text":", A, K,)"},{"kind":"italic_en","text":"and vexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"by grief:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"mutaDaj~irN","text_ar":"مُتَضَجِّرٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (A:) and so, but in an intensive manner, ↓"},{"kind":"arabic","text_bw":"DujarapN","text_ar":"ضُجَرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and ↓"},{"kind":"arabic","text_bw":"DajuwrN","text_ar":"ضَجُورٌ","orth_type":"arrow"},{"kind":"text","text":"is also an epithet [in this last, intensive, sense,] applied to a man: (S, Msb:) accord. to Aboo-Bekr,"},{"kind":"arabic","text_bw":"DajirN","text_ar":"ضَجِرٌ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressed, in mind,"},{"kind":"text","text":"is from the same word in the sense here next following. (TA.) ―         -b2-  A"},{"kind":"italic_en","text":"narrow"},{"kind":"text","text":"place; (Aboo-Bekr, K;) as also ↓"},{"kind":"arabic","text_bw":"DajorN","text_ar":"ضَجْرٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":["S","A","Msb","K","TA"]}]}}