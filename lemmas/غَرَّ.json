us":13,"cross_references":{"qac":{"found":true,"lemma_key":"غَرَّ","root":"غرر","pos":"V","occurrence_count":15},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["n31585","n31586"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to deceive, to delude","examples":[{"text":"لَا يَغُرَّنَّكَ حِلْمِي فَصَبْرِي بَدَأَ يَنْفَدُ.","english":"Let not my forbearance deceive you, for my patience is running out."}]},{"pos":"verb","gloss":"to sink into the ground (of water)"},{"pos":"verb","gloss":"to graze one's camels (of a shepherd)"},{"pos":"verb","gloss":"to feed (one's young) (of a bird)"},{"pos":"verb","gloss":"to be arrogant"},{"pos":"verb","gloss":"to turn white"},{"pos":"verb","gloss":"to be honorable and eminent"},{"pos":"verb","gloss":"to be negligent and gullible"},{"pos":"adj","gloss":"credulous, easily fooled, gullible, naïve"},{"pos":"adj","gloss":"inexperienced; fresh, novice, or raw (to a job or role)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31585","headword_ar":"غَرٌّ","root":"gr","body":[{"kind":"text","text":", (S, O, K, TA,) with fet-h, (S, O, TA, [in the CK erroneously said to be with damm,])"},{"kind":"italic_en","text":"A crease, wrinkle, ply, plait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fold,"},{"kind":"text","text":"(S, O, K, TA,) in skin, (O, * S,) accord. to Lth, from fatness, (TA,) or in a skin, (K,) and in a garment, or piece of cloth; (S, O, K;) syn."},{"kind":"arabic","text_bw":"kasorN","text_ar":"كَسْرٌ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"kasorN matavan~K","text_ar":"كَسْرٌ مَتَثَنٍّ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"makosirN","text_ar":"مَكْسِرٌ"},{"kind":"text","text":": (S, * O:) pl."},{"kind":"arabic","text_bw":"guruwrN","text_ar":"غُرُورٌ"},{"kind":"text","text":". (S, TA.) [Hence,]"},{"kind":"arabic","text_bw":"guruwru Alfaxi*ayoni","text_ar":"غُرُورُ الفَخِذَيْنِ"},{"kind":"italic_en","text":"The furrows"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"creases"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed lines"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between the muscles of the thighs."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"guruwru Al*~iraAEayoni","text_ar":"غُرُورُ الذِّرَاعَيْنِ"},{"kind":"italic_en","text":"The duplicatures"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"creases"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sinew's called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"HibAal","text_ar":"حِباَل"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"HabolN","text_ar":"حَبْلٌ"},{"kind":"text","text":"q. v.]"},{"kind":"italic_en","text":"of the fore arms."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"gar~u AlZ~ahori","text_ar":"غَرُّ الظَّهْرِ"},{"kind":"italic_en","text":"The duplicature"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"crease"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"maton","text_ar":"مَتْن"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flesh and sinew next the backbone"},{"kind":"text","text":"]: or, as ISk says,"},{"kind":"arabic","text_bw":"gar~u Almatoni","text_ar":"غَرُّ المَتْنِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the line of the"},{"kind":"arabic","text_bw":"mtn","text_ar":"متن"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"guruwru Alqadami","text_ar":"غُرُورُ القَدَمِ"},{"kind":"italic_en","text":"The creases of the foot."},{"kind":"text","text":"(TA.) And one says,"},{"kind":"arabic","text_bw":"Tawayotu Alv~awoba","text_ar":"طَوَيْتُ الثَّوْبَ"},{"kind":"arabic","text_bw":"EalaY gar~ihi","text_ar":"عَلَى غَرِّهِ"},{"kind":"italic_en","text":"I folded the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, according to its first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"original, folding."},{"kind":"text","text":"(S, O, TA. [In the TA said to be tropical; but for this I see no reason.]) And hence"},{"kind":"arabic","text_bw":"Tawayotuhu EalaY gar~ihi","text_ar":"طَوَيْتُهُ عَلَى غَرِّهِ"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"I left him as he was, without making known his case:"},{"kind":"text","text":"a saying proverbially used in relation to one who is made to rely upon his own opinion. (Har p. 233. [In Freytag's Arab Prov., ii. 38, it is not well rendered nor well explained.]) Hence also the saying of 'Áïsheh, respecting her father, mentioned in a trad.,"},{"kind":"arabic","text_bw":"farad~a","text_ar":"فَرَدَّ"},{"kind":"arabic","text_bw":"na$ara AlA_isolaAmi EalaY gar~ihi","text_ar":"نَشَرَ الاـِسْلَامِ عَلَى غَرِّهِ"},{"kind":"text","text":"i. e. (assumed tropical:)"},{"kind":"italic_en","text":"And he reduced what was disordered of El-Islám to its"},{"kind":"text","text":"["},{"kind":"italic_en","text":"primitive"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"state"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of order"},{"kind":"text","text":"]: (O:) meaning that he considered the results of the apostacy [that had commenced], and counteracted the disease thereof with its [proper] remedy. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"A fissure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleft, in the earth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"A rivulet:"},{"kind":"text","text":"(IAar, TA:) or"},{"kind":"italic_en","text":"a narrow steam of water in land:"},{"kind":"text","text":"(K, TA:) so called because it cleaves the earth: pl."},{"kind":"arabic","text_bw":"guruwrN","text_ar":"غُرُورٌ"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"guruwrN","text_ar":"غُرُورٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"streaks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lines, of a road."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Algar~aAni","text_ar":"الغَرَّانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Two lines by the two sides of the lower part of the"},{"kind":"arabic","text_bw":"Eayor","text_ar":"عَيْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ridge in the middle of the iron head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blade, of an arrow"},{"kind":"text","text":"&c.]. (AHn, TA.) ―         -b6-  See also"},{"kind":"arabic","text_bw":"giraArN","text_ar":"غِرَارٌ"},{"kind":"text","text":", last sentence. ―         -b7-  Also, the sing., The"},{"kind":"italic_en","text":"extremity"},{"kind":"text","text":"of a tooth: pl. as above. (O.)       -A2-  And The"},{"kind":"italic_en","text":"food wherewith a bird feeds its young one with its bill:"},{"kind":"text","text":"(K, TA:) pl. as above. (TA.) ―         -b2-  Its pl. is used in a verse of 'Owf Ibn-Dhirweh in relation to the journeying of camels, in the phrase"},{"kind":"arabic","text_bw":"AiHotasaY guruwra Eiydiy~aAtihaA","text_ar":"اِحْتَسَى غُرُورَ عِيدِيَّاتِهَا"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He jaded their"},{"kind":"arabic","text_bw":"Eiydy~aAt","text_ar":"عِيديَّات"},{"kind":"text","text":"[an appellation given to certain excellent she-camels]; as though he supped their"},{"kind":"arabic","text_bw":"guruwr","text_ar":"غُرُور"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","O","K","TA","IAar"]},{"entry_id":"n31586","headword_ar":"غِرٌّ","root":"gr","body":[{"kind":"italic_en","text":"Inexperienced in affairs;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"ignorant of affairs; negligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heedless, of them;"},{"kind":"text","text":"(Msb;) applied to a man, (S, Msb,) or to a youth, or young man; (K;) as also ↓"},{"kind":"arabic","text_bw":"gaAr~N","text_ar":"غَارٌّ","orth_type":"arrow"},{"kind":"text","text":"(Msb) and ↓"},{"kind":"arabic","text_bw":"gariyrN","text_ar":"غَرِيرٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) and applied to a young woman; as also"},{"kind":"arabic","text_bw":"gir~apN","text_ar":"غِرَّةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gariyrapN","text_ar":"غَرِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K:) or these three epithets, applied to a girl, signify"},{"kind":"italic_en","text":"young, inexperienced in affairs, and not knowing what woman know of love:"},{"kind":"text","text":"(A'Obeyd:) the pl. of"},{"kind":"arabic","text_bw":"gir~N","text_ar":"غِرٌّ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^agoraArN","text_ar":"اَغْرَارٌ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"giraArN","text_ar":"غِرَارٌ"},{"kind":"text","text":"; (TA;) and of ↓"},{"kind":"arabic","text_bw":"gariyrN","text_ar":"غَرِيرٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"A^agor~aA='u","text_ar":"اَغْرَّا=ءُ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"A^agir~apN","text_ar":"اَغِرَّةٌ"},{"kind":"text","text":"[which is a pl. of pane.] (K.) [And"},{"kind":"arabic","text_bw":"gir~apN","text_ar":"غِرَّةٌ"},{"kind":"text","text":"is also used as a pl.] Paradise says,"},{"kind":"arabic","text_bw":"yado xuloniY gir~apu Aln~aAsi","text_ar":"يَدْ خُلْنِى غِرَّةُ النَّاسِ"},{"kind":"italic_en","text":"The simple, of mankind, who prefer obscurity. and discard the affairs of the present world, and provide themselves for the world to come, enter me."},{"kind":"text","text":"(TA, from a trad.) ―         -b2-  Also"},{"kind":"italic_en","text":"Youthful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"childish, in conduct:"},{"kind":"text","text":"applied to a man, and to a girl, or young woman. (IAar, T.) ―         -b3-  And One"},{"kind":"italic_en","text":"who submits to be deceived."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}