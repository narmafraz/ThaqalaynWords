adj","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n33851","n33858"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%B3%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to spoil, to damage, to ruin","examples":[{"text":"وَإِذَا قِيلَ لَهُمْ لَا تُفْسِدُوا فِي الْأَرْضِ قَالُوا إِنَّمَا نَحْنُ مُصْلِحُونَ. أَلَا إِنَّهُمْ هُمُ الْمُفْسِدُونَ وَلَٰكِن لَّا يَشْعُرُونَ.","english":"When they are told, “Do not spread corruption in the land,” they reply, “We are only peace-makers!”. Indeed, it is they who are the corruptors, but they fail to perceive it."}]},{"pos":"adj","gloss":"elative degree of فَاسِد (fāsid):; more spoiled, more rotten; most spoiled, most rotten"},{"pos":"adj","gloss":"elative degree of فَاسِد (fāsid):; more corrupt; most corrupt"},{"pos":"adj","gloss":"elative degree of فَاسِد (fāsid):; more destructive; most destructive"}]},"etymology":{"source":"wiktextract","text":"Elative of فَاسِد (fāsid, “spoiled, rotten; corrupt; destructive”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33851","headword_ar":"افسد","root":"fsd","body":[{"kind":"text","text":", (S, M, O, L, Msb, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"A_fosaAdN","text_ar":"اـفْسَادٌ"},{"kind":"text","text":"and [quasi-inf.n.]"},{"kind":"arabic","text_bw":"fasaAdN","text_ar":"فَسَادٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"fs~d","text_ar":"فسّد","orth_type":"arrow"},{"kind":"text","text":", (O, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tafosiydN","text_ar":"تَفْسِيدٌ"},{"kind":"text","text":"; (O, K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, bad, evil, corrupt, unsound, wrong, wrongful, improper, unrighteous, wicked, vitious, depraved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishonest; deprived of virtue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efficacy; corrupted, vitiated, perverted, marred, spoiled, injured, impaired, deteriorated, tainted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infected;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"constituted, disposed, arranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"qualified, ill, wrongly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"improperly;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disturbed,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"disorganized,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"destroyed, annihilated, consumed, wasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruined;"},{"kind":"text","text":"(MA, KL, &c.;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"A^SolaHa","text_ar":"اصْلَحَ"},{"kind":"text","text":". (M, L, K.) One says,"},{"kind":"arabic","text_bw":"Afsd AlmaAla","text_ar":"افسد المَالَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He rendered the property in a bad state; marred, impaired, consumed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wasted, it"},{"kind":"text","text":"]. (L.) [And"},{"kind":"arabic","text_bw":"Afsd Ealayohimo","text_ar":"افسد عَلَيْهِمْ"},{"kind":"italic_en","text":"He corrupted, perverted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred, their state, case, affair, scheme, plot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"arabic","text_bw":"A^amorahumo","text_ar":"اَمْرَهُمْ"},{"kind":"text","text":", or the like, being understood. And"},{"kind":"arabic","text_bw":"Afsdhu","text_ar":"افسدهُ"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"italic_en","text":"He corrupted him and rendered him disaffected towards me."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A_ifosaAdu SabiY~K","text_ar":"اـِفْسَادُ صَبِىٍّ"},{"kind":"text","text":", occurring in a trad., means"},{"kind":"italic_en","text":"The injuring a child by rendering its mother pregnant while she is suckling it and so vitiating her milk:"},{"kind":"text","text":"which act is also termed"},{"kind":"arabic","text_bw":"Algiylahu","text_ar":"الغِيلَهُ"},{"kind":"text","text":". (L.) [And"},{"kind":"arabic","text_bw":"Afsd","text_ar":"افسد"},{"kind":"text","text":"as contr. of"},{"kind":"arabic","text_bw":"A^aSolaHa","text_ar":"اَصْلَحَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He acted in a bad, an evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a corrupt, manner; acted ill, corruptly, wrongly, wrongfully, improperly, unrighteously, wickedly, vitiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishonestly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief;"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"italic_en","text":"to him:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he created,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited, disorder, disturbance, disagreement, discord, dissension, strife,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarrel-ling;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did, mischief;"},{"kind":"arabic","text_bw":"bayona Alqawomi","text_ar":"بَيْنَ القَوْمِ"},{"kind":"italic_en","text":"between,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"among, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(See also 10.)]"}],"source_refs":["O","L","Msb","K"]},{"entry_id":"n33858","headword_ar":"اَفْسَدُ","root":"fsd","body":[{"kind":"text","text":"is [a noun denoting the comparative and superlative degrees] from"},{"kind":"arabic","text_bw":"AlfasaAdu","text_ar":"الفَسَادُ"},{"kind":"text","text":"; as in the prov.,"},{"kind":"arabic","text_bw":"A^afosadu mino bayoDapi Albaladi","text_ar":"اَفْسَدُ مِنْ بَيْضَةِ البَلَدِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"More corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"than the egg that the ostrich leaves in the desert, not returning to it,"},{"kind":"text","text":"in consequence of which it becomes corrupt, or unsound, &c.: and, anomalously, from"},{"kind":"arabic","text_bw":"AlA_ifosaAdu","text_ar":"الاـِفْسَادُ"},{"kind":"text","text":"; as in the prov.,"},{"kind":"arabic","text_bw":"A^afosada","text_ar":"اَفْسَدَ"},{"kind":"arabic","text_bw":"mina AljaraAdi","text_ar":"مِنَ الجَرَادِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"More corrupting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marring,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"than the locust"},{"kind":"text","text":"], because it strips the trees and the herbage; and as in other provs. (Meyd.)"}],"source_refs":[]}]},"classical_definitions":null}