text":",]"},{"kind":"italic_en","text":"news,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tidings,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"spreading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming spread."},{"kind":"text","text":"(IAar, O, K.) ―         -b2-  [(assumed tropical:)  A thing"},{"kind":"italic_en","text":"scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of dispersion:"},{"kind":"text","text":"fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": pl. of the latter"},{"kind":"arabic","text_bw":"$awaAy^iEu","text_ar":"شَوَايِعُ"},{"kind":"text","text":"; which may also be pl. of the former applied to a rational being, like"},{"kind":"arabic","text_bw":"fawaArisu","text_ar":"فَوَارِسُ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"faArisN","text_ar":"فَارِسٌ"},{"kind":"text","text":".] One says,"},{"kind":"arabic","text_bw":"jaA='ati Alxayolu $awaAy^iEa","text_ar":"جَا=ءَتِ الخَيْلُ شَوَايِعَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The horsemen came scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of dispersion;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"$awaAEiYa","text_ar":"شَوَاعِىَ"},{"kind":"text","text":", formed by transposition. (TA. [But the latter is also mentioned as belonging to art."},{"kind":"arabic","text_bw":"$Ew","text_ar":"شعو"},{"kind":"text","text":".]) ―         -b3-  Also A lot, share, or portion, ("},{"kind":"arabic","text_bw":"sahomN","text_ar":"سَهْمٌ"},{"kind":"text","text":", S O, Msb, K, and"},{"kind":"arabic","text_bw":"naSiybN","text_ar":"نَصِيبٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"undivided;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"