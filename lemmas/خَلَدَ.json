icon.com/?s=%D8%AE%D9%8E%D9%84%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to last forever, to be everlasting"},{"pos":"verb","gloss":"to be immortal"},{"pos":"verb","gloss":"to abide forever"},{"pos":"verb","gloss":"to remain, to stay"},{"pos":"verb","gloss":"to rest"},{"pos":"verb","gloss":"to make eternal, to make everlasting","examples":[{"text":"يَطُوفُ عَلَيْهِمْ وِلْدَانٌ مُّخَلَّدُونَ","english":"There will circulate among them young boys made eternal."}]},{"pos":"verb","gloss":"to perpetuate, to make immortal"},{"pos":"verb","gloss":"to make ineffaceable, to make unforgettable"},{"pos":"verb","gloss":"to remain, to stay, to abide, to linger"},{"pos":"verb","gloss":"to grow very old, to enjoy a long life, to be long-lived"},{"pos":"noun","gloss":"infinite duration, endless time, perpetuity, eternity"},{"pos":"noun","gloss":"mind, heart, spirit, temper","examples":[{"text":"مَا دَارَ فِي خَلَدِ الْأَيَّامِ لِي فَرَحٌ / أَبَا عُبَادَةَ حَتَّى دُرْتَ فِي خَلَدِي"}]},{"pos":"noun","gloss":"mole-rat"},{"pos":"noun","gloss":"mole","tags":["Arabic","Modern","Standard","proscribed"]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew חלד (khéled, “world, era”) and Ge'ez ኀለደ (ḫälädä, “to last long”).\n\nFrom Aramaic חוּלְדּא / ܚܘܠܕܐ (ḥuldā, “mole”). Compare Hebrew חולד (khóled)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11234","headword_ar":"خَلَدَ","root":"xld","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuluwdN","text_ar":"خُلُودٌ"},{"kind":"text","text":"(S, A, L, Msb, K) and"},{"kind":"arabic","text_bw":"xulodN","text_ar":"خُلْدٌ"},{"kind":"text","text":", (S, * A, L, K, * [but the latter is not said to be an inf. n. in the first nor in the last of these lexicons, and is perhaps a simple subst.,])"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"text","text":": (L, Msb, K:) or"},{"kind":"italic_en","text":"he remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"page_break","n":784},{"kind":"italic_en","text":"abode, long;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aTaAla AlA_iqaAmapa","text_ar":"اَطَالَ الاـِقَامَةَ"},{"kind":"text","text":": (A:)"},{"kind":"arabic","text_bw":"bimakaAnK","text_ar":"بِمَكَانٍ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"A_ilaY makaAnK","text_ar":"اـِلَى مَكَانٍ"},{"kind":"text","text":"(K) ["},{"kind":"italic_en","text":"in a place"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"Axld","text_ar":"اخلد","orth_type":"arrow"},{"kind":"text","text":"(S, A, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"xl~d","text_ar":"خلّد","orth_type":"arrow"},{"kind":"text","text":": (K:) and"},{"kind":"italic_en","text":"he remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, incessantly, always, endlessly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for ever;"},{"kind":"text","text":"(S, A, L, K; *) syn."},{"kind":"arabic","text_bw":"baqiYa","text_ar":"بَقِىَ"},{"kind":"text","text":", (A, L, K,) and"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"daAma baqaAw^uhu","text_ar":"دَامَ بَقَاوُهُ"},{"kind":"text","text":"; (S, L;)"},{"kind":"arabic","text_bw":"fiY daArK","text_ar":"فِى دَارٍ"},{"kind":"italic_en","text":"in a house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abode, not going forth from it:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, for ever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perpetually,"},{"kind":"text","text":"in Paradise, (A, L,) or in Hell. (A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"xalada","text_ar":"خَلَدَ"},{"kind":"text","text":", (L, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (Ham p. 70, and L,) inf. n."},{"kind":"arabic","text_bw":"xalodN","text_ar":"خَلْدٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"xaladN","text_ar":"خَلَدٌ"},{"kind":"text","text":", (thus in the L,) and"},{"kind":"arabic","text_bw":"xuluwdN","text_ar":"خُلُودٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"Axld","text_ar":"اخلد","orth_type":"arrow"},{"kind":"text","text":"; (Ham ubi suprà;) (tropical:)"},{"kind":"italic_en","text":"He was slow in becoming hoary,"},{"kind":"text","text":"(Ham, L, K,)"},{"kind":"italic_en","text":"when advanced in years;"},{"kind":"text","text":"(K;) as though he were created to continue for ever. (L.) ―         -b3-  See also 4, in two places."}],"source_refs":["S","A","L","Msb","K","Ham"]}]},"classical_definitions":null}