{"lemma":"سَخا","slug":"سَخا","root":"س.خ.#","root_slug":"س-خ-_","root_link":"/words/roots/س-خ-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَخَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَخَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَخَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَخَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَخَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَخا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَخَت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَخَوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَخَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَخَوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَخَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْخُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْخ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْخِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْخِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْخُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْخُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْخُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْخُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْخُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْخُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْخُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْخُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْخُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْخُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَسْخُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْخُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَخَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَخَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n19269"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%AE%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19269","headword_ar":"سَخَا","root":"sxw and sxY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxuw","text_ar":"يَسْخُو"},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"saxaY","text_ar":"سَخَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxaY","text_ar":"يَسْخَى"},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"saxiYa","text_ar":"سَخِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxaY","text_ar":"يَسْخَى"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"saxuwa","text_ar":"سَخُوَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxuw","text_ar":"يَسْخُو"},{"kind":"text","text":"; (S, Msb, K;) inf. n."},{"kind":"arabic","text_bw":"saxaA='N","text_ar":"سَخَا=ءٌ"},{"kind":"text","text":", (S, * M, Msb, * K, TA,) of the first verb, (M, Msb, * TA,) and of the second, (TA,) and"},{"kind":"arabic","text_bw":"suxuw~N","text_ar":"سُخُوٌّ"},{"kind":"text","text":", (M, K, TA, [in the CK"},{"kind":"arabic","text_bw":"saxow","text_ar":"سَخْو"},{"kind":"text","text":",]) of the first verb, (M, TA,) or of the last, (TA,) and"},{"kind":"arabic","text_bw":"suxuw~apN","text_ar":"سُخُوَّةٌ"},{"kind":"text","text":", (M, K, TA,) of the first verb, (M, TA,) or of the third, (TA,) and"},{"kind":"arabic","text_bw":"saxFY","text_ar":"سَخًى"},{"kind":"text","text":", (Msb, K, TA,) of the third verb, (Msb, TA,) and"},{"kind":"arabic","text_bw":"saxaAwapN","text_ar":"سَخَاوَةٌ"},{"kind":"text","text":", of the last verb; (S, Msb, TA;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself, to be generous;"},{"kind":"text","text":"(S, * Msb, * K, * TA;) syn."},{"kind":"arabic","text_bw":"jaAda","text_ar":"جَادَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"takar~ama","text_ar":"تَكَرَّمَ"},{"kind":"text","text":"; (TA;) the inf. ns. signifying"},{"kind":"arabic","text_bw":"juwdN","text_ar":"جُودٌ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"karamN","text_ar":"كَرَمٌ"},{"kind":"text","text":"(Msb) [or"},{"kind":"arabic","text_bw":"takar~umN","text_ar":"تَكَرُّمٌ"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"saxato nafosuhu","text_ar":"سَخَتْ نَفْسُهُ"},{"kind":"italic_en","text":"His mind was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, liberal,"},{"kind":"text","text":"&c. (Msb.) [Accord. to J,] the saying of 'Amr Ibn-Kulthoom, [relating to wine,]"},{"kind":"quote","text":"A_i*aA maA AlmaA='u xaAlaTahaA saxiynaA"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"When the water mixes with it,"},{"kind":"text","text":"and we drink it,]"},{"kind":"italic_en","text":"we are,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, liberal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bountiful, with our riches;"},{"kind":"text","text":"and the assertion that"},{"kind":"arabic","text_bw":"sxynA","text_ar":"سخينا"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"Als~uxuwnapu","text_ar":"السُّخُونَةُ"},{"kind":"text","text":", in the accus. case as a denotative of state, is a mistake: (S:) the former is the saying of AA; and the latter, of As: but IB says, on the authority of IKtt, that the right explanation is that which J disallows; and Es- Safadee says the like. (TA.) [See also 5.] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"saxiyato nafosiY Eani Al$~aYo'i","text_ar":"سَخِيَتْ نَفْسِى عَنِ الشَّىْءِ"},{"kind":"italic_en","text":"I left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquished, the thing."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"saxaA binafosihi Eanohu","text_ar":"سَخَا بِنَفْسِهِ عَنْهُ"},{"kind":"italic_en","text":"He left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquished, it;"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he held himself far from it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdrew his heart from it;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"nafosahu Eanohu","text_ar":"نَفْسَهُ عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sax~aY","text_ar":"سَخَّى","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sx~Y binafosihi Eanohu","text_ar":"سخّى بِنَفْسِهِ عَنْهُ"},{"kind":"text","text":": (MA:) or"},{"kind":"arabic","text_bw":"nafosiY Eano h`*aA Al$~aYo'i","text_ar":"نَفْسِى عَنْ هٰذَا الشَّىْءِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sax~ayotu","text_ar":"سَخَّيْتُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sx~yt binafosiY Eanohu","text_ar":"سخّيت بِنَفْسِى عَنْهُ"},{"kind":"italic_en","text":"I left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquished, this thing, and my soul did not strive with me to incline me to it."},{"kind":"text","text":"(JK.) And"},{"kind":"arabic","text_bw":"saxaA qalobiY Ealayoka","text_ar":"سَخَا قَلْبِى عَلَيْكَ"},{"kind":"text","text":"[perhaps a mistranscription for"},{"kind":"arabic","text_bw":"Eanoka","text_ar":"عَنْكَ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I endured with patience the being debarred from thee."},{"kind":"text","text":"(JK.)       -A2-"},{"kind":"arabic","text_bw":"saxaA","text_ar":"سَخَا"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yasoxuw","text_ar":"يَسْخُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxowN","text_ar":"سَخْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"rested from his state of motion:"},{"kind":"text","text":"(K:) from ISd. (TA.)       -A3-"},{"kind":"arabic","text_bw":"saxaA Aln~aAra","text_ar":"سَخَا النَّارَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxuw","text_ar":"يَسْخُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxowN","text_ar":"سَخْوٌ"},{"kind":"text","text":"; (AA, S, K;) and"},{"kind":"arabic","text_bw":"saxiyahaA","text_ar":"سَخِيَهَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxaY","text_ar":"يَسْخَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxoYN","text_ar":"سَخْىٌ"},{"kind":"text","text":"; (AA, S;) and"},{"kind":"arabic","text_bw":"saxaAhaA","text_ar":"سَخَاهَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxaY","text_ar":"يَسْخَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxoYN","text_ar":"سَخْىٌ"},{"kind":"text","text":"; (Sgh, K;)"},{"kind":"italic_en","text":"He made an opening in the live and extinct coals of the fire which had become collected together after it had been kindled:"},{"kind":"text","text":"(T, S:) or"},{"kind":"italic_en","text":"he made a way"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vent"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for the fire, beneath the cooking-pot:"},{"kind":"text","text":"(M, K:) or"},{"kind":"arabic","text_bw":"saxaA Aln~aAra","text_ar":"سَخَا النَّارَ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"fataHa EayonahaA","text_ar":"فَتَحَ عَيْنَهَا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he made an opening in the live coals of the fire, that had become collected together,"},{"kind":"text","text":"(as expl. in the TK in art."},{"kind":"arabic","text_bw":"Sxw","text_ar":"صخو"},{"kind":"text","text":",) i. e.,"},{"kind":"italic_en","text":"that had become compacted; in order that it might burn up well"},{"kind":"text","text":"]; as also"},{"kind":"arabic","text_bw":"SaxaAhaA","text_ar":"صَخَاهَا"},{"kind":"text","text":": or, as some say,"},{"kind":"italic_en","text":"he cleared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swept, away the"},{"kind":"page_break","n":1328},{"kind":"italic_en","text":"live,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burning, coals of the fire;"},{"kind":"text","text":"as also with"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":": (TA: [see"},{"kind":"arabic","text_bw":"saHaA","text_ar":"سَحَا"},{"kind":"text","text":":]) and"},{"kind":"arabic","text_bw":"Aln~aAra","text_ar":"النَّارَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sax~ayotu","text_ar":"سَخَّيْتُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tasoxiyapN","text_ar":"تَسْخِيَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I opened the heart of the place where the fire was kindled, in order that it might burn up well."},{"kind":"text","text":"(JK.) And one says,"},{"kind":"arabic","text_bw":"Aisoxa naAraka","text_ar":"اِسْخَ نَارَكَ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"Make thou a place upon which to kindle thy fire."},{"kind":"text","text":"(S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"saxaA Alqidora","text_ar":"سَخَا القِدْرَ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yasoxuw","text_ar":"يَسْخُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxowN","text_ar":"سَخْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He made a way"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vent"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for the fire beneath the cooking-pot;"},{"kind":"text","text":"(K;) mentioned by ISd, who adds that one says also,"},{"kind":"arabic","text_bw":"saxaA Aljamora mino","text_ar":"سَخَا الجَمْرَ مِنْ"},{"kind":"arabic","text_bw":"taHoti Alqidori","text_ar":"تَحْتِ القِدْرِ"},{"kind":"text","text":": (TA:) or the former phrase, [and app. the latter also,]"},{"kind":"italic_en","text":"he put aside the live coals from beneath the cooking-pot;"},{"kind":"text","text":"(JK, TA;) as also ↓"},{"kind":"arabic","text_bw":"sax~aAhaA","text_ar":"سَخَّاهَا","orth_type":"arrow"},{"kind":"text","text":". (JK.)       -A4-"},{"kind":"arabic","text_bw":"saxiYa","text_ar":"سَخِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yasoxaY","text_ar":"يَسْخَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saxFA","text_ar":"سَخًا"},{"kind":"text","text":", said of a camel, (S, K,) and of a young weaned camel, (S,)"},{"kind":"italic_en","text":"He became affected with a limping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"halting,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"having leaped with a heavy load, in consequence of which a flatus had intervened between the skin and the shoulderblade:"},{"kind":"text","text":"(S:) the epithet applied to the animal in this case is ↓"},{"kind":"arabic","text_bw":"saxK","text_ar":"سَخٍ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) mentioned by Yaakoob, (S,) and ↓"},{"kind":"arabic","text_bw":"saxiY~N","text_ar":"سَخِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (JK, K,) this latter mentioned by Sgh, and anomalous, being of a measure proper to an epithet from a verb of the measure"},{"kind":"arabic","text_bw":"faEula","text_ar":"فَعُلَ"},{"kind":"text","text":", with damm to the medial radical; (TA;) and the pl. of this latter epithet is"},{"kind":"arabic","text_bw":"saxaAyaA","text_ar":"سَخَايَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saxaAwaY","text_ar":"سَخَاوَى"},{"kind":"text","text":". (JK.)"}],"source_refs":["TA","M","K","Msb","S","MA","T","JK"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%AE%D8%A7/","headword_ar":"سخا","entries":[{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=11090#00f112","body_html":"<span class=\"title1\">[سخا]</span><span> السَخاوَةُ والسَخاءُ: الجود. يقال منه: سَخا يَسْخو. وسَخِيَ يَسْخى مثله، قال عمرو بن كلثوم: </span><span>مُشَعْشَعَةً كأنَّ الحُصَّ فيها * إذا ما الماءُ خالطها سَخينا أي جُدْنا بأموالنا. وقول من قال \" سَخينا \" من السُخونَةِ نصب على الحال، فليس بشئ. وسخيت نفسي عن الشئ، إذا تركته. وسخو الرجل يسخو سَخاوَةً، أي صار سَخِيَّاً. وسَخَوْتُ النار أَسْخوها سَخْواً، وذلك إذا أوقدتَ فاجتمع الجمرُ والرماد ففرَّجْتَه. وفيه لغة أخرى حكاهما جميعاً أبو عمرو: سَخيتُ النار أَسْخاها سَخْياً، مثال لبثت ألبث لَبْثاً. يقال: اسْخَ نارَكَ، أي اجعل لها مكاناً تُوقَد عليه. وأنشد: ويرْزِمُ أن يَرى المَعْجونَ يُلْقى * بسَخي النار إِرْزامَ الفصيلِ والسَخا مقصورٌ: ظَلْعٌ يصيب البعيرَ أو الفصيل، بأنْ يثب بالحمل الثقيل فتعترضَ الريحُ بين الجلد والكتِف. يقال: سَخِيَ البعير</span><span> </span><a></a><span>بالكسر يَسْخَى سَخىً، فهو سَخٍ مثل عم، حكاه يعقوب. وفلان يَتَسَخى على أصحابه، أي يتكلَّف السَخاءَ. وأرضٌ سَخاوِيَّةٌ: ليِّنة التُراب، وهي منسوبة. ومكانٌ سَخاوِيٌّ. والسَخواءُ: الأرض السهلة الواسعة، والجمع السخاوى والسخاوى، مثل الصحارى والصحارى.</span>"},{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=11090#8a35c0","body_html":"<span class=\"title1\">س خ ا</span><span>: (السَّخَاءُ) الْجُودُ وَقَدْ (سَخَا) يَسْخُو وَ (سَخِيَ) بِالْكَسْرِ (سَخَاءً) فِيهِمَا. قَالَ عَمْرُو بْنُ كُلْثُومٍ:</span><br><span>مُشَعْشَعَةً كَأَنَّ الْحُصَّ فِيهَا إِذَا مَا الْمَاءُ خَالَطَهَا سَخِينَا أَيْ جُدْنَا بِأَمْوَالِنَا. وَقَوْلُ مَنْ قَالَ: سَخِينًا مِنَ السُّخُونَةِ نُصِبَ عَلَى الْحَالِ لَيْسَ بِشَيْءٍ. قُلْتُ: قَدْ ذَكَرَ رَحِمَهُ اللَّهُ تَعَالَى فِي [س خ ن] ضِدَّ هَذَا. وَ (سَخُوَ) الرَّجُلُ مِنْ بَابِ ظَرُفَ صَارَ (سَخِيًّا) . وَفُلَانٌ (يَتَسَخَّى) عَلَى أَصْحَابِهِ أَيْ يَتَكَلَّفُ السَّخَاءَ. </span>"}]}}