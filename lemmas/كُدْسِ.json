{"lemma":"كُدْسِ","slug":"كُدْسِ","root":"ك.د.س","root_slug":"ك-د-س","root_link":"/words/roots/ك-د-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["","n36762"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8F%D8%AF%D9%92%D8%B3%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to accumulate, to collect together","tags":["transitive"]},{"pos":"verb","gloss":"to pile or heap","tags":["transitive"]},{"pos":"verb","gloss":"to amass, to horde","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of كَدَسَ (kadasa).","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to accumulate","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"From the root ك د س (k d s) meaning to sweep or rake together, to heap or pile, to amass."},"ipa":["/ka.da.sa/","/kads/","/kad.da.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36762","headword_ar":"كُدْسٌ","root":"kds","body":[{"kind":"italic_en","text":"Reaped grain collected together;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a heap thereof;"},{"kind":"text","text":"] (A, K;) as also ↓"},{"kind":"arabic","text_bw":"kud~aAsN","text_ar":"كُدَّاسٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"rum~aAnN","text_ar":"رُمَّانٌ"},{"kind":"text","text":": (Ibn-'Abbád and A, Sgh, K:) or"},{"kind":"italic_en","text":"what is collected together,"},{"kind":"text","text":"of wheat, (S, * Msb,)"},{"kind":"italic_en","text":"in the place where it is trodden out:"},{"kind":"text","text":"(Msb:) when trodden out and thrashed, it is called"},{"kind":"arabic","text_bw":"EaramapN","text_ar":"عَرَمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SuborapN","text_ar":"صُبْرَةٌ"},{"kind":"text","text":": or, as Az says, in one place in the T, on the authority of IAar,"},{"kind":"arabic","text_bw":"kudosN","text_ar":"كُدْسٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bayodarN","text_ar":"بَيْدَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaramapN","text_ar":"عَرَمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$agolapN","text_ar":"شَغْلَةٌ"},{"kind":"text","text":"are all one: and in another place he says, that"},{"kind":"arabic","text_bw":"kudosN","text_ar":"كُدْسٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a collection of wheat:"},{"kind":"text","text":"and in like manner, (assumed tropical:)"},{"kind":"italic_en","text":"what is collected"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"heaped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"together,"},{"kind":"text","text":"of money, and of other things: (Msb:) or (assumed tropical:)  of dates, (TA,) and (tropical:)  of money, (A, TA,) and the like, (TA,) and (tropical:)  of clothes: (A, TA:) also, (assumed tropical:)"},{"kind":"italic_en","text":"a large heap"},{"kind":"text","text":"of sand,"},{"kind":"italic_en","text":"of which one part does not separate from another:"},{"kind":"text","text":"(En-Nadr:) and ↓"},{"kind":"arabic","text_bw":"kudaAsN","text_ar":"كُدَاسٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"guraAbN","text_ar":"غُرَابٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"what is collected together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heaped up, of snow:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"kudaAsapN","text_ar":"كُدَاسَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"what is collected together, and heaped up, one part upon another:"},{"kind":"text","text":"(K:) the pl. of"},{"kind":"arabic","text_bw":"kudosN","text_ar":"كُدْسٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^akodaAsN","text_ar":"اَكْدَاسٌ"},{"kind":"text","text":". (S, A, Msb.)"}],"source_refs":["Msb","TA","A","K"]}]},"classical_definitions":null}