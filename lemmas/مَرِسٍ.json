{"lemma":"مَرِسٍ","slug":"مَرِسٍ","root":"م.ر.س","root_slug":"م-ر-س","root_link":"/words/roots/م-ر-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n38466","n38467","n15543"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B1%D9%90%D8%B3%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to steep, to soak, to macerate"},{"pos":"verb","gloss":"to make slip about the pulley (of a rope)","tags":["obsolete"]},{"pos":"adj","gloss":"of practice, experienced"},{"pos":"adj","gloss":"contorted (of a rope)","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of مَرَسَ (marasa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"al-Andalus form of مَارِس (māris, “March”)","tags":["al-Andalus","alt-of"]},{"pos":"noun","gloss":"alternative form of مَرَسَة (marasa, “rope, hawser”)","tags":["alt-of","alternative","collective"]}]},"etymology":{"source":"wiktextract","text":"Compare Akkadian mersum (“a cake mainly made of dates, sesame and oil”), from marāsu (“to mix, to mash”)."},"ipa":["/mars/","/ma.ras/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38466","headword_ar":"مَرَسٌ","root":"mrs","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"marasapN","text_ar":"مَرَسَةٌ"},{"kind":"text","text":", and 3."}],"source_refs":[]},{"entry_id":"n38467","headword_ar":"مَرِسٌ","root":"mrs","body":[{"kind":"text","text":"A"},{"kind":"italic_en","text":"strong"},{"kind":"text","text":"man: (TA:) or a man (S)"},{"kind":"italic_en","text":"strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, in labour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exertion:"},{"kind":"text","text":"(S, M:) and"},{"kind":"italic_en","text":"strong, experienced in affairs, and who has laboured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exerted himself, in the management,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transaction, thereof:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^amoraAsN","text_ar":"اَمْرَاسٌ"},{"kind":"text","text":". (TA.) You say also,"},{"kind":"arabic","text_bw":"A_in~ahu lamarisN Ha*irN","text_ar":"اـِنَّهُ لَمَرِسٌ حَذِرٌ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"Verily he is strong in the waging of wars."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"humo EalaY marisK waAHidK","text_ar":"هُمْ عَلَى مَرِسٍ وَاحِدٍ"},{"kind":"italic_en","text":"They are alike in dispositions."},{"kind":"text","text":"(S, TA.)"}],"source_refs":["TA","S","M"]},{"entry_id":"n15543","headword_ar":"مُرْسٍ","root":"rsw","body":[{"kind":"text","text":", as an epithet applied to God: see 4, near the end of the paragraph."}],"source_refs":[]}]},"classical_definitions":null}