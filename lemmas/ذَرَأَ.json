per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَذْرَأا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَذْرَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَذْرَأُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَذْرَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَذْرَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَذْرَأْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"ذَرَأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ذَرَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَذْرَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَذْرَأ","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":true,"lemma_key":"ذَرَأَ","root":"ذرأ","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n13742","n13745"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D8%B1%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to create"},{"pos":"verb","gloss":"to become white, to have whiteness intermixed into the saturated colour"},{"pos":"verb","gloss":"to be or become rusty","tags":["Morocco","al-Andalus"]},{"pos":"noun","gloss":"whiteness intermixed into saturated colour"},{"pos":"noun","gloss":"rust","tags":["Morocco","al-Andalus"]}]},"etymology":{"source":"wiktextract","text":"Dialectal variant of ذَرَا (ḏarā) or ذَرَّ (ḏarra) in all senses. How “to sow” or “to strew”, with meaning “offspring” in ذُرِّيَّة (ḏurriyya), can mean “to create”, needs no explanation. For the coloration meaning apparently ذَرَأ (ḏaraʔ) is the original and meant color specks figuratively strewn, ultimately becoming a dead metaphor like Russian сы́паться (sýpatʹsja) which is used for skin rashes and the like."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13742","headword_ar":"ذَرَاَ","root":"*rA^","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"text","text":", (S, M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"*aro'N","text_ar":"ذَرْءٌ"},{"kind":"text","text":", (S, M, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"created,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xalaqa","text_ar":"خَلَقَ"},{"kind":"text","text":", (T, S, M, Msb, K,)"},{"kind":"arabic","text_bw":"Alxaloqa","text_ar":"الخَلْقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the creation;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"the things that are created"},{"kind":"text","text":"]. (T, S, M, Msb.)"},{"kind":"arabic","text_bw":"walaqado *araA^onaA lijahan~ama kaviyrFA mina A@lojin~i wa A@loA_inosi","text_ar":"وَلَقَدْ ذَرَاْنَا لِجَهَنَّمَ كَثِيرًا مِنَ ا@لْجِنِّ وَ ا@لْاـِنْسِ"},{"kind":"text","text":", in the Kur [vii. 178], means ["},{"kind":"italic_en","text":"And verily"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"we have created"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for Hell many of the jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii, and of mankind"},{"kind":"text","text":"]. (T.) ―         -b2-"},{"kind":"italic_en","text":"He multiplied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made numerous."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"ya*oraw^ukumo fiyhi","text_ar":"يَذْرَوُكُمْ فِيهِ"},{"kind":"text","text":", in the Kur [xlii. 9], means"},{"kind":"italic_en","text":"He multiplieth you thereby;"},{"kind":"text","text":"i. e., by making of you, and of the cattle, pairs, males and females: so says Zj; and Fr says the like; and this is a correct explanation. (T.) ―         -b3-  Also, (S, M, K,) and so"},{"kind":"arabic","text_bw":"*araA","text_ar":"ذَرَا"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He sowed"},{"kind":"text","text":"land: (S, M, K, TA:) but the latter verb is said to be the more chaste. (MF.)       -A2-"},{"kind":"arabic","text_bw":"*araA^a fuwhu","text_ar":"ذَرَاَ فُوهُ"},{"kind":"italic_en","text":"His teeth fell out from his mouth;"},{"kind":"text","text":"(K, TA;) as also"},{"kind":"arabic","text_bw":"*araA","text_ar":"ذَرَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*araY","text_ar":"ذَرَى"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (TA:) but the most chaste is said to be without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"*araA^a","text_ar":"ذَرَاَ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", is said to be of weak authority, or a mispronunciation. (MF.) ―         -b2-"},{"kind":"arabic","text_bw":"*ariy^a","text_ar":"ذَرِيَ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"*ariy^a $aEarahu","text_ar":"ذَرِيَ شَعَرَهُ"},{"kind":"text","text":", (S,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"*araA^N","text_ar":"ذَرَاٌ"},{"kind":"text","text":"; (S, * M, O;) and"},{"kind":"arabic","text_bw":"*araA^a","text_ar":"ذَرَاَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"*aruw^a","text_ar":"ذَرُوَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Ktr, TA;)"},{"kind":"italic_en","text":"His hair became white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary, in the fore part of his"},{"kind":"page_break","n":958},{"kind":"italic_en","text":"head:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he had whiteness intermixed with blackness in the hair of his head:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"his hair became white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he began to become white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoary,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"in the fore part of his head,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"in the upper part of each side of the head."},{"kind":"text","text":"(A, TA.) The epithet is ↓"},{"kind":"arabic","text_bw":"A^a*oraA^u","text_ar":"اَذْرَاُ","orth_type":"arrow"},{"kind":"text","text":"; fem."},{"kind":"arabic","text_bw":"*aroA='N","text_ar":"ذَرْا=ءٌ"},{"kind":"text","text":". (S, M, K. [In some copies of the K,"},{"kind":"arabic","text_bw":"*aroA^aY","text_ar":"ذَرْاَى"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"*aroA='u","text_ar":"ذَرْا=ءُ"},{"kind":"text","text":".])"}],"source_refs":["S","M","Msb","K","God","T","TA"]},{"entry_id":"n13745","headword_ar":"ذَرَاٌ","root":"*rA^","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]}]}}