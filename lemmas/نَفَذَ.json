"},{"role":"present_2mp","form":"تَنْفُذُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْفُذْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْفُذ","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْفُذ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْفُذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْفُذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْفُذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفُذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْفُذُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفُذُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْفُذْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْفُذ","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْفُذ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَفَذْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَفَذْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":37,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n40209"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%81%D9%8E%D8%B0%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pierce, to penetrate"},{"pos":"verb","gloss":"to pass through","examples":[{"text":"يَا مَعْشَرَ ٱلْجِنِّ وَٱلْإِنْسِ إِنِ ٱسْتَطَعْتُمْ أَنْ تَنْفُذُوا مِنْ أَقْطَارِ السَّمَاوَاتِ وَٱلْأَرْضِ فَٱنْفُذُوا لَا تَنْفُذُونَ إِلَّا بِسُلْطَانٍ","english":"O assembly of jinn and men! If you can penetrate beyond the realms of the heavens and the earth, then pass. But you cannot pass except with authority."}]},{"pos":"verb","gloss":"to carry out, to execute"},{"pos":"verb","gloss":"to implement"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40209","headword_ar":"نَفَذَ","root":"nf*","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (M, L,) inf. n."},{"kind":"arabic","text_bw":"nafaA*N","text_ar":"نَفَاذٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nufuw*N","text_ar":"نُفُوذٌ"},{"kind":"text","text":", (M, L, K,)"},{"kind":"italic_en","text":"It went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, through:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"it went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, through"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"and became clear of it."},{"kind":"text","text":"(M, L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"nafa*otu","text_ar":"نَفَذْتُ"},{"kind":"italic_en","text":"I went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, through."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"nafa*a Als~ahomu","text_ar":"نَفَذَ السَّهْمُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nufuw*N","text_ar":"نُفُوذٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafaA*N","text_ar":"نَفَاذٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The arrow perforated, transpierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced through,"},{"kind":"text","text":"the animal at which it was shot,"},{"kind":"italic_en","text":"and went forth from"},{"kind":"text","text":"it: (Msb:) or"},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"arabic","text_bw":"Als~ahomu Alr~amiy~apa","text_ar":"السَّهْمُ الرَّمِيَّةَ"},{"kind":"text","text":", (M, L,) and"},{"kind":"arabic","text_bw":"nafa*a minohaA","text_ar":"نَفَذَ مِنْهَا"},{"kind":"text","text":", (S, L,) and"},{"kind":"arabic","text_bw":"fiyhaA","text_ar":"فِيهَا"},{"kind":"text","text":", (M, A, L,) aor."},{"kind":"text","text":", (M, L,) inf. n."},{"kind":"arabic","text_bw":"nafaA*N","text_ar":"نَفَاذٌ"},{"kind":"text","text":"(M, A, L, K) and"},{"kind":"arabic","text_bw":"nufuw*N","text_ar":"نُفُوذٌ"},{"kind":"text","text":"(A) and"},{"kind":"arabic","text_bw":"nafo*N","text_ar":"نَفْذٌ"},{"kind":"text","text":", (M, L, K,)"},{"kind":"italic_en","text":"the arrow penetrated into the inside of the animal at which it was shot, and its extremity went forth from the other side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protruded from it, the rest remaining therein; the extremity of the arrow passed through the animal at which it was shot, the rest remaining therein;"},{"kind":"text","text":"(M, L, K;)"},{"kind":"italic_en","text":"a part of the arrow passed through,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protruded from, the animal at which it was shot."},{"kind":"text","text":"(A, art."},{"kind":"arabic","text_bw":"Srd","text_ar":"صرد"},{"kind":"text","text":".) See"},{"kind":"arabic","text_bw":"shomN naAfi*N","text_ar":"سهْمٌ نَافِذٌ"},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"nafa*ati AlT~aEonapu","text_ar":"نَفَذَتِ الطَّعْنَةُ"},{"kind":"italic_en","text":"The wound made by a spear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like passed through,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beyond, the other side"},{"kind":"text","text":"(T, L.) ―         -b5-"},{"kind":"arabic","text_bw":"Aunofu*o Eanoka","text_ar":"اُنْفُذْ عَنْكَ"},{"kind":"italic_en","text":"Go thou from thy place; pass thou from it."},{"kind":"text","text":"(L.) [See also"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"nafa*a liwajohihi","text_ar":"نَفَذَ لِوَجْهِهِ"},{"kind":"italic_en","text":"He went his way."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"nafad","text_ar":"نَفَد"},{"kind":"arabic","text_bw":"AlT~ariyqu","text_ar":"الطَّرِيقُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The road was"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a thoroughfare"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"naAfi*N","text_ar":"نَافِذٌ"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"pervious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passable, to every one in common."},{"kind":"text","text":"(Msb.) ―         -b8-"},{"kind":"arabic","text_bw":"h`*aA AlT~ariyqu yanofudu A_ilaY makaAni ka*aA","text_ar":"هٰذَا الطَّرِيقُ يَنْفُدُ اـِلَى مَكَانِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This road is a thoroughfare, along which every one may pass, to such a place"},{"kind":"text","text":"]. (T, M, * L.) ―         -b9-"},{"kind":"arabic","text_bw":"nafa*a Alamonzilu A_ilaY AlT~ariyqi","text_ar":"نَفَذَ الَمْنزِلُ اـِلَى الطَّرِيقِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"was a thoroughfare, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"communicated with the road."},{"kind":"text","text":"(Msb.) ―         -b10-"},{"kind":"arabic","text_bw":"nafa*a Alqawoma","text_ar":"نَفَذَ القَوْمَ"},{"kind":"italic_en","text":"He passed through the people, and left them behind him;"},{"kind":"text","text":"(T, M, L, K;) as also ↓"},{"kind":"arabic","text_bw":"A^anofa*ahumo","text_ar":"اَنْفَذَهُمْ","orth_type":"arrow"},{"kind":"text","text":"; (L, K;) or only the former is used in this sense (L.) See also the latter. ―         -b11-"},{"kind":"arabic","text_bw":"naf*ahumu AlbaSaru","text_ar":"نَفذَهُمُ البَصَرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The sight reached them, and extended beyond them:"},{"kind":"text","text":"(Ks, L:) or,"},{"kind":"italic_en","text":"extended over them all:"},{"kind":"text","text":"(A'Obeyd, L:) you say also,"},{"kind":"arabic","text_bw":"AlbaSaru","text_ar":"البَصَرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^anofa*ahumu","text_ar":"اَنْفَذَهُمُ","orth_type":"arrow"},{"kind":"text","text":"in the former sense (L:) [or"},{"kind":"italic_en","text":"The sight penetrated into the midst of them:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^anofa*a Alqawoma","text_ar":"اَنْفَذَ القَوْمَ"},{"kind":"text","text":".] ―         -b12-"},{"kind":"arabic","text_bw":"nafa*a raA^oyuhu","text_ar":"نَفَذَ رَاْيُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His judgment was penetrating;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"vafaba","text_ar":"ثَفَبَ"},{"kind":"text","text":". (K in art"},{"kind":"arabic","text_bw":"vfb","text_ar":"ثفب"},{"kind":"text","text":") ―         -b13-"},{"kind":"arabic","text_bw":"nafa*a fiY AlA^amori","text_ar":"نَفَذَ فِى الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He acted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went on, with penetrative energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with sharpness, vigorousness, and effectiveness, in the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"text","text":"(S, K, art."},{"kind":"arabic","text_bw":"mDY","text_ar":"مضى"},{"kind":"text","text":".) ―         -b14-"},{"kind":"arabic","text_bw":"nafa*a AlkitaAbu A_ilaY fulaAnK","text_ar":"نَفَذَ الكِتَابُ اـِلَى فُلَانٍ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafaA*N","text_ar":"نَفَاذٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nufuw*N","text_ar":"نُفُوذٌ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"The letter passed to, came to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reached, such a one"},{"kind":"text","text":"]: (S, L:) [and in like manner,"},{"kind":"arabic","text_bw":"Alr~asuwlu","text_ar":"الرَّسُولُ"},{"kind":"italic_en","text":"the messenger:"},{"kind":"text","text":"see 4.] ―         -b15-"},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":",and"},{"kind":"arabic","text_bw":"Alqawolu","text_ar":"القَوْلُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The command,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"order,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the saying, was effectual; had effect; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, executed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"text","text":". (Msb.) ―         -b16-"},{"kind":"arabic","text_bw":"nafa*a AlEitoqu","text_ar":"نَفَذَ العِتْقُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The act of emancipation had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took effect; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, executed."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed;"},{"kind":"text","text":"and in like manner, a covenant, contract, sale, &c.: see 4]. App. a met. expression, from"},{"kind":"arabic","text_bw":"nufuw*u Als~ahomi","text_ar":"نُفُوذُ السَّهْمِ"},{"kind":"text","text":"; because there is no retracting it. (Msb.) ―         -b17-"},{"kind":"arabic","text_bw":"yanofudu bayonanaA","text_ar":"يَنْفُدُ بَيْنَنَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He shall judge between us, and make his command"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"order to have effect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"execute"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perform it."},{"kind":"text","text":"(L.) ―         -b18-"},{"kind":"arabic","text_bw":"lahu nafaA*N fiY AlA^umuwri","text_ar":"لَهُ نَفَاذٌ فِى الاُمُورِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He has ability in affairs, to execute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perform"},{"kind":"text","text":"]. (A.)"}],"source_refs":["M","L","K","Msb","S","A","Ks"]}]}}