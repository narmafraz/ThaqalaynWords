ا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَنَفَّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَنَفَّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَنَفَّس","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَنَفَّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَنَفَّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَنَفَّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَنَفَّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَنَفَّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَنَفَّسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَنَفَّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَنَفَّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتَنَفَّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَنَفَّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَنَفَّسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَنَفَّسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":true,"lemma_key":"تَنَفَّسَ","root":"نفس","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40255"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%86%D9%8E%D9%81%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to breathe, to respire, to take a breath, to take a breather, to take a rest"},{"pos":"noun","gloss":"verbal noun of تَنَفَّسَ (tanaffasa) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"breathing"}]},"etymology":null,"ipa":["/ta.naf.fa.sa/","/ta.naf.fus/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40255","headword_ar":"تنفّس","root":"nfs","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He breathed"},{"kind":"text","text":"] is said of a man and of every animal having lungs: (S:) [or it signifies]"},{"kind":"italic_en","text":"he drew"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Aisotamad~a","text_ar":"اِسْتَمَدَّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"breath:"},{"kind":"text","text":"(M:) or ["},{"kind":"italic_en","text":"he respired,"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"he drew breath with the air-passages in his nose; to his inside, and emitted it."},{"kind":"text","text":"(Msb.) You say also,"},{"kind":"arabic","text_bw":"tnf~s AlS~uEadaA='a","text_ar":"تنفّس الصُّعَدَا=ءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sighed:"},{"kind":"text","text":"see also art."},{"kind":"arabic","text_bw":"SEd","text_ar":"صعد"},{"kind":"text","text":"]. (S.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"emitted wind from beneath him."},{"kind":"text","text":"(TA.) ―         -b3-  Also, (TA,) or"},{"kind":"arabic","text_bw":"tnf~s","text_ar":"تنفّس"},{"kind":"arabic","text_bw":"fiY AlA_inaA='i","text_ar":"فِى الاـِنَا=ءِ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"He drank"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"from the vessel"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"with three restings between draughts, and separated the vessel from his mouth at every such resting:"},{"kind":"text","text":"(K, TA.) and, contr., the latter phrase, (assumed tropical:)"},{"kind":"italic_en","text":"he drank"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the vessel"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without separating it from his mouth:"},{"kind":"text","text":"(K, TA:) which latter mode of drinking is disapproved. (TA.) ―         -b4-  Also"},{"kind":"arabic","text_bw":"tnf~s","text_ar":"تنفّس"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He lengthened in speech; he spoke long;"},{"kind":"text","text":"for when a speaker takes breath, it is easy"},{"kind":"page_break","n":2827},{"kind":"text","text":"to him to lengthen his speech; and"},{"kind":"arabic","text_bw":"tnfs fiY","text_ar":"تنفس فِى"},{"kind":"arabic","text_bw":"AlkalaAmi","text_ar":"الكَلَامِ"},{"kind":"text","text":"signifies the same. (TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(said of the day, M, A, and of the dawn, A, and of other things, M)"},{"kind":"italic_en","text":"became extended;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"it became long;"},{"kind":"text","text":"(M, A;) or, said of the day, accord. to Lh,"},{"kind":"italic_en","text":"it advanced so that it became noon:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"it increased:"},{"kind":"text","text":"(S:) and"},{"kind":"italic_en","text":"it extended far:"},{"kind":"text","text":"and hence it is said of life, meaning either"},{"kind":"italic_en","text":"it became protracted, and extended far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became ample:"},{"kind":"text","text":"(M:) and, said of the dawn,"},{"kind":"italic_en","text":"it shone forth,"},{"kind":"text","text":"(Akh, S, K, TA,)"},{"kind":"italic_en","text":"and extended so that it became clear day:"},{"kind":"text","text":"(Fr, TA:) or"},{"kind":"italic_en","text":"it broke, so that things became plain in consequence of it:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"it rose:"},{"kind":"text","text":"(Mujáhid:) or"},{"kind":"italic_en","text":"its dusty hue shone at the approach of a gentle wind."},{"kind":"text","text":"(Bd, lxxxi. 18.) You say also,"},{"kind":"arabic","text_bw":"tnf~s bihi AlEumuru","text_ar":"تنفّس بِهِ العُمُرُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Life became long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protracted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"tnf~st dijolapu","text_ar":"تنفّست دِجْلَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The water of the Tigris increased."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"tnf~s","text_ar":"تنفّس"},{"kind":"arabic","text_bw":"Almawoju","text_ar":"المَوْجُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The waves sprinkled the water."},{"kind":"text","text":"(S, K.) ―         -b7-"},{"kind":"arabic","text_bw":"tnf~st Alqawosu","text_ar":"تنفّست القَوْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The bow cracked."},{"kind":"text","text":"(S, M, K.) It is only the stick that is not split in twain that does so; and this is the best of bows. And"},{"kind":"arabic","text_bw":"tnf~s","text_ar":"تنفّس"},{"kind":"text","text":"in the same sense is said of an arrow. (M.)       -A2-  ["},{"kind":"arabic","text_bw":"tnf~s Ealayohi Al$~aYo'a","text_ar":"تنفّس عَلَيْهِ الشَّىْءَ"},{"kind":"text","text":"app. signifies the same as"},{"kind":"arabic","text_bw":"nafisa","text_ar":"نَفِسَ"},{"kind":"arabic","text_bw":"Elyh Al$Y'","text_ar":"عليه الشىء"},{"kind":"text","text":", q. v.]"}],"source_refs":["S","M","TA","K","Akh","Fr"]}]},"classical_definitions":null}