anes":{"found":true,"entry_ids":["n20193"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B3%D9%92%D9%83%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20193","headword_ar":"اسكت","root":"skt","body":[{"kind":"text","text":"as an intrans. verb: see 1, in nine places. ―         -b2-"},{"kind":"italic_en","text":"He turned away, and spoke not;"},{"kind":"text","text":"occurring in this sense in a trad.: and"},{"kind":"arabic","text_bw":"Askt Eani","text_ar":"اسكت عَنِ"},{"kind":"arabic","text_bw":"Al$~aYo'i","text_ar":"الشَّىْءِ"},{"kind":"italic_en","text":"He turned away from the thing."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Askthu","text_ar":"اسكتهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sk~thu","text_ar":"سكّتهُ","orth_type":"arrow"},{"kind":"text","text":"(S, A, Msb) both signify the same, said of God (S) [and of a man];"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered him, silent, mute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speechless;"},{"kind":"text","text":"(Msb;) ["},{"kind":"italic_en","text":"he silenced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hushed, him;"},{"kind":"text","text":"] namely, a person speaking. (A.) And"},{"kind":"arabic","text_bw":"Askthu EaniY","text_ar":"اسكتهُ عَنِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made him to abstain from speaking of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to, me"},{"kind":"text","text":"]. (As, TA in art."},{"kind":"arabic","text_bw":"nSt","text_ar":"نصت"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Askt AlS~abiY~a bisukotapK","text_ar":"اسكت الصَّبِىَّ بِسُكْتَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He silenced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hushed, the child with a"},{"kind":"arabic","text_bw":"sukotap","text_ar":"سُكْتَة"},{"kind":"text","text":"]. (Lh, S, A, K.) And"},{"kind":"arabic","text_bw":"A^usokita","text_ar":"اُسْكِتَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He was silenced in a dispute"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(A, TA.) ―         -b2-  [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"He stilled, quieted, appeased, tranquillized, calmed, allayed, assuaged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quelled, it."},{"kind":"text","text":"] In the Kur vii. 153, some read, ↓"},{"kind":"arabic","text_bw":"walam~aA sukita","text_ar":"وَلَمَّا سُكِتَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Eano muwsaY AlgaDabu","text_ar":"عَنْ مُوسَى الغَضَبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^usokita","text_ar":"اُسْكِتَ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"And when the anger was stilled so that it was made to depart from Moses"},{"kind":"text","text":"]. (Bd. [For the usual reading see 1, latter part.])"}],"source_refs":["S","A","Msb"]}]},"classical_definitions":null}