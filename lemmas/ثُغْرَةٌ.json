"italic_en","text":"two portions of flesh on the right and left of the breast"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"italic_en","text":"A tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter, of the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of land;"},{"kind":"text","text":"(JK, K;) as also ↓"},{"kind":"arabic","text_bw":"vagorN","text_ar":"ثَغْرٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"maA bitiloka Alv~ugorapi mivoluhu","text_ar":"مَا بِتِلْكَ الثُّغْرَةِ مِثْلُهُ"},{"kind":"italic_en","text":"There is not, in that tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter, of the earth, his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, like."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"italic_en","text":"A plain, level,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"even, road;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"vagorN","text_ar":"ثَغْرٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"any road that people tread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pass along, with ease;"},{"kind":"text","text":"because they furrow its surface: (T, TA:) pl. as above. (A.) [Hence,]"},{"kind":"arabic","text_bw":"vugaru Almasojidi","text_ar":"ثُغَرُ المَسْجِدِ"},{"kind":"italic_en","text":"The ways leading to the mosque:"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"vugorapu Almasojidi","text_ar":"ثُغْرَةُ المَسْجِدِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the upper part of the mosque"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"next to the kibleh"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"huwayaxotariqu","text_ar":"هُوَيَخْتَرِقُ"},{"kind":"arabic","text_bw":"vugara Almajodi","text_ar":"ثُغَرَ المَجْدِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He travels] the ways of glory."},{"kind":"text","text":"(A.)"}],"source_refs":["Msb","K","TA","T"]}]},"classical_definitions":null}