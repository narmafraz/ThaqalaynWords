solete"]}]}, "etymology": {"source": "wiktextract", "text": "Compare Hebrew חרג (ħarág, “deviate”)."}, "ipa": ["/ħa.ri.d͡ʒa/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n7562", "headword_ar": "حَرِجَ", "root": "Hrj", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "HarajN", "text_ar": "حَرَجٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a number of things)"}, {"kind": "italic_en", "text": "became collected together:"}, {"kind": "text", "text": "and, necessarily,"}, {"kind": "italic_en", "text": "became close, strait,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "narrow:"}, {"kind": "text", "text": "(so accord. to an explanation of the inf. n. by Er-Rághib, in the TA:) said of anything,"}, {"kind": "italic_en", "text": "it was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, close, strait,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "narrow."}, {"kind": "text", "text": "(KL.) One says of dust,"}, {"kind": "arabic", "text_bw": "Harija A_ilaY HaAy^iTK", "text_ar": "حَرِجَ اـِلَى حَايِطٍ"}, {"kind": "text", "text": ", or"}, {"kind": "arabic", "text_bw": "sanadK", "text_ar": "سَنَدٍ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "It rose,"}, {"kind": "text", "text": "(Lth, Az, TA,)"}, {"kind": "italic_en", "text": "in a narrow place,"}, {"kind": "text", "text": "(TA,)"}, {"kind": "italic_en", "text": "and became collected"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "against a wall,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an acclivity"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like"}, {"kind": "text", "text": "]. (Lth, Az, TA.) ―         -b2-"}, {"kind": "arabic", "text_bw": "Harija Sadoruhu", "text_ar": "حَرِجَ صَدْرُهُ"}, {"kind": "text", "text": ", aor. and inf. n. as above, (assumed tropical:)"}, {"kind": "italic_en", "text": "His bosom became strait,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "contracted;"}, {"kind": "text", "text": "(S, A, Mgh, Msb, TA;)"}, {"kind": "italic_en", "text": "not expanded,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "dilated, by reason of what was good."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "Harija", "text_ar": "حَرِجَ"}, {"kind": "text", "text": "alone, aor. and inf. n. as above, (assumed tropical:)"}, {"kind": "italic_en", "text": "He became disquieted, and contracted in bosom:"}, {"kind": "text", "text": "and (assumed tropical:)"}, {"kind": "italic_en", "text": "he became in doubt; he doubted;"}, {"kind": "text", "text": "because doubt disquiets the mind. (So accord. to explanations of the inf. n. by Er-Rághib, in the TA.) ―         -b3-  Also"}, {"kind": "arabic", "text_bw": "Harija", "text_ar": "حَرِجَ"}, {"kind": "text", "text": ", aor. and inf. n. as above, [(assumed tropical:)"}, {"kind": "italic_en", "text": "He became straitened,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in difficulty:"}, {"kind": "text", "text": "and particularly,"}, {"kind": "italic_en", "text": "by the commission of a sin,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "crime:"}, {"kind": "text", "text": "(see"}, {"kind": "arabic", "text_bw": "HarajN", "text_ar": "حَرَجٌ"}, {"kind": "text", "text": ", below:) and hence, simply,] (assumed tropical:)"}, {"kind": "italic_en", "text": "he committed a sin, a crime,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an act of disobedience for which he deserved punishment."}, {"kind": "text", "text": "(Msb.) ―         -b4-  Also"}, {"kind": "italic_en", "text": "He looked, and was unable to move from his place by reason of fear and rage."}, {"kind": "text", "text": "(T, TA.) And"}, {"kind": "arabic", "text_bw": "Harijati AlEayonu", "text_ar": "حَرِجَتِ العَيْنُ"}, {"kind": "text", "text": ", (S, A, K,) aor."}, {"kind": "text", "text": ", (K,) inf. n. as above, (TA,) (tropical:)"}, {"kind": "italic_en", "text": "The eye became dazzled,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "HaArat", "text_ar": "حَارَت"}, {"kind": "text", "text": ", S, K, TA,) or"}, {"kind": "italic_en", "text": "sank in its socket,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "gaArat", "text_ar": "غَارَت"}, {"kind": "text", "text": ",)"}, {"kind": "italic_en", "text": "and its vision became straitened:"}, {"kind": "text", "text": "(A, TA:) or"}, {"kind": "italic_en", "text": "it did not turn about,"}, {"kind": "text", "text": "nor"}, {"kind": "italic_en", "text": "wink, by reason of intent gazing."}, {"kind": "text", "text": "(TA.) ―         -b5-  Also, (S, A, K,) aor. as above, (K,) and so the inf. n., (S, K,) (tropical:)"}, {"kind": "italic_en", "text": "It was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, forbidden,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "prohibited,"}, {"kind": "text", "text": "(S, A, K,) and"}, {"kind": "italic_en", "text": "attended with straitness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "difficulty."}, {"kind": "text", "text": "(A.) So in the saying,"}, {"kind": "arabic", "text_bw": "Harija EalaY~a Zulomuka", "text_ar": "حَرِجَ عَلَىَّ ظُلْمُكَ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "The wronging of thee is forbidden,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "prohibited, to me."}, {"kind": "text", "text": "(S, TA.) And"}, {"kind": "arabic", "text_bw": "Harija Ealayohi Als~aHuwru", "text_ar": "حَرِجَ عَلَيْهِ السَّحُورُ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "The meal termed"}, {"kind": "arabic", "text_bw": "sHwr", "text_ar": "سحور"}, {"kind": "italic_en", "text": "became forbidden,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "prohibited, to him,"}, {"kind": "text", "text": "(A, TA,) namely, a man fasting,"}, {"kind": "italic_en", "text": "and attended with difficulty,"}, {"kind": "text", "text": "(A,)"}, {"kind": "italic_en", "text": "by reason of the straitness of the time thereof."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "Harijati AlS~alaApu", "text_ar": "حَرِجَتِ الصَّلَاةُ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "Prayer became forbidden,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "prohibited,"}, {"kind": "text", "text": "(A, and TA as from the K, [but not found by me in the copies of the K,])"}, {"kind": "arabic", "text_bw": "EalayohaA", "text_ar": "عَلَيْهَا"}, {"kind": "italic_en", "text": "to her"}, {"kind": "text", "text": "[by reason of legal impurity, as is shown in the A]. (A, TA.) ―         -b6-"}, {"kind": "arabic", "text_bw": "Harija A_ilayohi", "text_ar": "حَرِجَ اـِلَيْهِ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "He betook himself,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "had recourse, to him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, for protection from a strait,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "difficulty."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "Harija", "text_ar": "حَرِجَ"}, {"kind": "arabic", "text_bw": "A_ilaY ka*aA wa ka*aA", "text_ar": "اـِلَى كَذَا وَ كَذَا"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He betook himself to such and such things."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["Lth", "Az", "TA", "S", "A", "K"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}