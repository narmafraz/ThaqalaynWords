":"text","text":",] in the accus. case"},{"kind":"arabic","text_bw":"juwfiyFA","text_ar":"جُوفِيًا"},{"kind":"text","text":", by poetic license, (S,)"},{"kind":"italic_en","text":"A species of fish;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"juwaAfN","text_ar":"جُوَافٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}