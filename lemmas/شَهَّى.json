ord_ar":"شَهِىٌّ","root":"$hw","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mu$otahFY","text_ar":"مُشْتَهًى","orth_type":"arrow"},{"kind":"text","text":"(S, Msb) [i. e."},{"kind":"italic_en","text":"Desired, longed for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerly desired:"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"pleasant, delicious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sweet:"},{"kind":"text","text":"(Msb, TA:) applied to food, (S,) and to water. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^abuw Al$~ahiY~i","text_ar":"اَبُو الشَّهِىِّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"barobaT","text_ar":"بَرْبَط"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Persian lute"},{"kind":"text","text":"]. (KL.) ―         -b3-  [And Golius adds, as on the authority of a gloss in a copy of the KL, (assumed tropical:)"},{"kind":"italic_en","text":"The water-melon"},{"kind":"text","text":"("},{"kind":"italic_en","text":"anguria"},{"kind":"text","text":").]       -A2-  See also"},{"kind":"arabic","text_bw":"$ahowaAnu","text_ar":"شَهْوَانُ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B4%D9%87%D9%89/","headword_ar":"شهى","entries":[{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=35403#08debc","body_html":"<span class=\"title1\">[شهى]</span><span> نه: فيه: إن أخوف ما أخاف عليكم الرئاء و\"الشهوة\" الخفية، قيل: هو كل شيء من المعاصي يضمره صاحبه ويصر عليه وإن لم يعمله، وقيل: هو أن يرى جارية حسناء فيغض طرفه ثم ينظر بقلبه كما كان ينظر بعينه؛ الأزهري: والقول هو الأول غير أني أستحسن أن أنصب الشهوة وأجعل الواو بمعنى مع بمعنى: إن أخوف ما أخاف عليكم الرئاء مع الشهوة الخفية للمعاصي، فكأنه يرائى الناس بتركه للمعاصي والشهوة في قلبه مخفاة؛ وقيل: الرئاء ما ظهر من العمل، والشهوة حب اطلاع الناس على العمل. غ: الشهوة الخفية أن يكون في طاعة من طاعات الله فيعرض شهوة من شهواته كالأكل والجماع وغيرهما فيرحج جانب النفس على جانب الله فيدخل في زمرة \"وأما من طغى وأثر الحيوة الدنيا\" وسمي خفيًا لخفاء هلاكه. وح: حجبت النار \"بالشهوات\" أي المحرمة، والمكاره الطاعات والصبر عن المعاصي - ومر في حفت. وفي ح رابعة: يا \"شهواني\" رجل شهوان وشهواني أي شديد الشهوة، وجمع شهاوى كسكارى. ك: إذا \"اشتهى\" مريض أحدكم شيئًا فليطعمه، هذا بناء على التوكل وأنه هو الشافي أو أن المريض قد شارف الوفاة. غ: «وحيل بينهم وبين ما \"يشتهون\"» أي الإيمان أو الرجوع إلى الدنيا.</span>"}]}}