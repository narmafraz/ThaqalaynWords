{"lemma":"جَلِيل","slug":"جَلِيل","root":"ج.ل.ل","root_slug":"ج-ل-ل","root_link":"/words/roots/ج-ل-ل","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","name"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n6028"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%90%D9%8A%D9%84"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"great, important"},{"pos":"adj","gloss":"exalted"},{"pos":"adj","gloss":"revered, honorable, venerable"},{"pos":"adj","gloss":"glorious, magnificent"},{"pos":"adj","gloss":"strong, stout, rough"},{"pos":"adj","gloss":"old, experienced"},{"pos":"name","gloss":"a male given name, Jalil"},{"pos":"name","gloss":"a surname, Jalil"}]},"etymology":{"source":"wiktextract","text":"Compare جَلَّ (jalla, “to be great, to be exalted”)."},"ipa":["/d͡ʒa.liːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6028","headword_ar":"جَلِيلٌ","root":"jl","body":[{"kind":"text","text":", in its primary acceptation, signifies"},{"kind":"italic_en","text":"Thick, gross, coarse, rough, rugged, rude, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulky;"},{"kind":"text","text":"applied to a material substance; (Er-Rághib, TA;) opposed to"},{"kind":"arabic","text_bw":"daqiyqN","text_ar":"دَقِيقٌ"},{"kind":"text","text":"; (S, Er-Rághib, TA;) as also ↓"},{"kind":"arabic","text_bw":"jil~N","text_ar":"جِلٌّ","orth_type":"arrow"},{"kind":"text","text":", (S,) opposed to"},{"kind":"arabic","text_bw":"diq~N","text_ar":"دِقٌّ"},{"kind":"text","text":": (S, K:) [and then,]"},{"kind":"italic_en","text":"great;"},{"kind":"text","text":"(Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"jil~N","text_ar":"جِلٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jal~N","text_ar":"جَلٌّ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"julaAlN","text_ar":"جُلَالٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) which is also explained as signifying"},{"kind":"italic_en","text":"large, big, bulky,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large in body,"},{"kind":"text","text":"(K,) and ↓"},{"kind":"arabic","text_bw":"jul~aAlN","text_ar":"جُلَّالٌ","orth_type":"arrow"},{"kind":"text","text":": fem."},{"kind":"arabic","text_bw":"jaliylapN","text_ar":"جَلِيلَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"julaAlapN","text_ar":"جُلَالَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) [also]"},{"kind":"italic_en","text":"great in respect of estimation, rank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity:"},{"kind":"text","text":"(S, TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^ajil~apN","text_ar":"اَجِلَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jil~apN","text_ar":"جِلَّةٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"A^ajil~aA='u","text_ar":"اَجِلَّا=ءُ"},{"kind":"text","text":". (TA.) You say, ↓"},{"kind":"arabic","text_bw":"maA lahu diq~N y^alaA jil~N","text_ar":"مَا لَهُ دِقٌّ يَلَا جِلٌّ","orth_type":"arrow"},{"kind":"text","text":", i. e.,"},{"kind":"arabic","text_bw":"daqiyqN walaA jaliylN","text_ar":"دَقِيقٌ وَلَا جَلِيلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has neither slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, nor thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gross,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"great"},{"kind":"text","text":"]. (S.) And ↓"},{"kind":"arabic","text_bw":"$ajarN jil~N","text_ar":"شَجَرٌ جِلٌّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Large trees;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trees as"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"opposed to"},{"kind":"arabic","text_bw":"$ajarN diq~N","text_ar":"شَجَرٌ دِقٌّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shrubs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bushes"},{"kind":"text","text":"]. (Lth, Mgh in art."},{"kind":"arabic","text_bw":"bql","text_ar":"بقل"},{"kind":"text","text":".) And ↓"},{"kind":"arabic","text_bw":"Hulalu jil~K","text_ar":"حُلَلُ جِلٍّ","orth_type":"arrow"},{"kind":"italic_en","text":"Thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dresses, of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hulal","text_ar":"حُلَل"},{"kind":"text","text":"; opposed to"},{"kind":"arabic","text_bw":"Hulalu diq~N","text_ar":"حُلَلُ دِقٌّ"},{"kind":"text","text":": (Mgh in art."},{"kind":"arabic","text_bw":"dq","text_ar":"دق"},{"kind":"text","text":":) or the things termed"},{"kind":"arabic","text_bw":"jil~N","text_ar":"جِلٌّ"},{"kind":"text","text":", of commodities, are"},{"kind":"italic_en","text":"carpets,"},{"kind":"text","text":"and [the"},{"kind":"italic_en","text":"garments called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akosiyap","text_ar":"اَكْسِيَة"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"kisaA='","text_ar":"كِسَا=ء"},{"kind":"text","text":"], and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"diq~N","text_ar":"دِقٌّ"},{"kind":"text","text":"; such as the ["},{"kind":"italic_en","text":"cloth called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hilos","text_ar":"حِلْس"},{"kind":"text","text":", and the"},{"kind":"italic_en","text":"mat,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"julaAlapN","text_ar":"جُلَالَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A great she-camel;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"big-bodied."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"TaHatapu","text_ar":"طَحَتَةُ"},{"kind":"arabic","text_bw":"TaHonFA jaliylFA","text_ar":"طَحْنًا جَلِيلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He ground it coarsely"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"j$","text_ar":"جش"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"Aljaliylu","text_ar":"الجَلِيلُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The great in dignity,"},{"kind":"text","text":"is not applied peculiarly to God: when it is applied to Him, it is because of his creating the great things that are indicative of Him, or because He is too great to be comprehended within limits or to be perceived by the senses. (Er-Rághib, TA.) And"},{"kind":"arabic","text_bw":"qawomN jil~apN","text_ar":"قَوْمٌ جِلَّةٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A great people; lords, chiefs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people of rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"a good people;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"a people of eminence, nobility, dignity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"high rank."},{"kind":"text","text":"(K.) ―         -b2-  Also"},{"kind":"italic_en","text":"Old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced in age,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, in judgment:"},{"kind":"page_break","n":438},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"jil~apN","text_ar":"جِلَّةٌ"},{"kind":"text","text":": (K:) which pl., as meaning"},{"kind":"italic_en","text":"old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced in age,"},{"kind":"text","text":"is applied to camels, (S, Sgh, K,) as well as to men. (K.) Hence, in a trad.,"},{"kind":"arabic","text_bw":"faA@EotaraDa","text_ar":"فَا@عْتَرَضَ"},{"kind":"arabic","text_bw":"lahumo A_iboliysu fiY Suwarpi $ayoxK jaliylK","text_ar":"لَهُمْ اـِبْلِيسُ فِى صُوَرةِ شَيْخٍ جَلِيلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And Iblees presented himself to them in the form of an old man advanced in age"},{"kind":"text","text":"]. (TA.) ↓"},{"kind":"arabic","text_bw":"jil~apN","text_ar":"جِلَّةٌ","orth_type":"arrow"},{"kind":"text","text":"in the sense last explained above, is also used as a sing., and is applied to the male and the female [of camels]: or signifies"},{"kind":"italic_en","text":"such as is termed"},{"kind":"arabic","text_bw":"vaniy~ap","text_ar":"ثَنِيَّة"},{"kind":"text","text":", [i. e., a she-camel"},{"kind":"italic_en","text":"that has entered her sixth year,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"until she has become a"},{"kind":"arabic","text_bw":"baAzil","text_ar":"بَازِل"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in her ninth year"},{"kind":"text","text":"]: or a male camel"},{"kind":"italic_en","text":"that has become a"},{"kind":"arabic","text_bw":"vaniY~","text_ar":"ثَنِىّ"},{"kind":"text","text":": or it is applied to a she-camel, and ↓"},{"kind":"arabic","text_bw":"jil~N","text_ar":"جِلٌّ","orth_type":"arrow"},{"kind":"text","text":"to a he-camel. (K.) And [the fem.] ↓"},{"kind":"arabic","text_bw":"jaliylapN","text_ar":"جَلِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"[used as a subst.] signifies"},{"kind":"italic_en","text":"A she-camel that has brought forth once:"},{"kind":"text","text":"(S, O, K:) and [simply]"},{"kind":"italic_en","text":"a she-camel;"},{"kind":"text","text":"as in the saying,"},{"kind":"arabic","text_bw":"maA lahu","text_ar":"مَا لَهُ"},{"kind":"arabic","text_bw":"jaliylapN walaA daqiyqapN","text_ar":"جَلِيلَةٌ وَلَا دَقِيقَةٌ"},{"kind":"italic_en","text":"He has neither a she-camel nor a ewe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she-goat:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"camels."},{"kind":"text","text":"(JK and TA in art."},{"kind":"arabic","text_bw":"dq","text_ar":"دق"},{"kind":"text","text":"[q. v., voce"},{"kind":"arabic","text_bw":"daqiyqN","text_ar":"دَقِيقٌ"},{"kind":"text","text":"].) Also (i. e. ↓"},{"kind":"arabic","text_bw":"jlylp","text_ar":"جليلة","orth_type":"arrow"},{"kind":"text","text":")"},{"kind":"italic_en","text":"A great palm-tree having much fruit:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"jaliylN","text_ar":"جَلِيلٌ"},{"kind":"text","text":"; (K;) [or rather this is a coll. gen. n.;] or, accord. to some copies of the K, the pl. is"},{"kind":"arabic","text_bw":"jilaAlN","text_ar":"جِلَالٌ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"vumaAmN","text_ar":"ثُمَامٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Panicum,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"panic grass"},{"kind":"text","text":"]; (S, K;)"},{"kind":"italic_en","text":"a weak plant, with which the interstices of houses are stopped up:"},{"kind":"text","text":"n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S:) or ↓"},{"kind":"arabic","text_bw":"jaliylapN","text_ar":"جَلِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a species of"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"vm","text_ar":"ثم"},{"kind":"text","text":":) pl."},{"kind":"arabic","text_bw":"jalaAy^ilu","text_ar":"جَلَايِلُ"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","K","TA","Sgh","O"]}]},"classical_definitions":null}