ue,"entry_ids":["n5802","n5803","n5804"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B3%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become bulky or massive, to swell, to enlarge","tags":["intransitive"]},{"pos":"verb","gloss":"to make, present, describe, or conceive of as concrete, physical, material, or corporeal, to concretize, to reify, to corporealize","tags":["transitive"]},{"pos":"verb","gloss":"to make, present, describe, or conceive of as concrete, physical, material, or corporeal, to concretize, to reify, to corporealize; to make tangible or perceptible, to incorporate, to embody","tags":["transitive"]},{"pos":"verb","gloss":"to make, present, describe, or conceive of as human, to humanize, to anthropomorphize","tags":["transitive"]},{"pos":"verb","gloss":"to make (an object, a phenomenon, a happening an event, etc.) seem bigger, to magnify","tags":["transitive"]},{"pos":"noun","gloss":"a body"},{"pos":"noun","gloss":"an object"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ج س م (j s m).\n\nCognate with Classical Syriac ܓܘܫܡܐ (gušmā, “body”)."},"ipa":["/d͡ʒa.su.ma/","/d͡ʒas.sa.ma/","/d͡ʒism/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5802","headword_ar":"جَسُمَ","root":"jsm","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jasaAmapN","text_ar":"جَسَامَةٌ"},{"kind":"text","text":", (Msb, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, S,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large:"},{"kind":"text","text":"(S, K:) or so"},{"kind":"arabic","text_bw":"jasima","text_ar":"جَسِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jasamN","text_ar":"جَسَمٌ"},{"kind":"text","text":": and the former,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulky:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large, in body:"},{"kind":"text","text":"(KL:) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, corpulent;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corporeal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bodied;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tjs~m","text_ar":"تجسّم","orth_type":"arrow"},{"kind":"text","text":". (MA, PS.)"}],"source_refs":["K","Msb","TA","S","KL"]},{"entry_id":"n5803","headword_ar":"جسّم","root":"jsm","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajosiymN","text_ar":"تَجْسِيمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, corporeal;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"great, large, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulky."},{"kind":"text","text":"(KL.) ―         -b2-  ["},{"kind":"italic_en","text":"He made to be solid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to have length and breadth and thickness."},{"kind":"text","text":"]"}],"source_refs":[]},{"entry_id":"n5804","headword_ar":"جِسْمٌ","root":"jsm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"body, with the limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jasadN","text_ar":"جَسَدٌ"},{"kind":"text","text":"; (AZ, S, Msb;) as also ↓"},{"kind":"arabic","text_bw":"jusomaAnN","text_ar":"جُسْمَانٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"juvomaAnN","text_ar":"جُثْمَانٌ"},{"kind":"text","text":": (AZ, S, Msb: *) or"},{"kind":"arabic","text_bw":"jisomN","text_ar":"جِسْمٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jusomaAnN","text_ar":"جُسْمَانٌ","orth_type":"arrow"},{"kind":"text","text":"are syn. with"},{"kind":"arabic","text_bw":"jasadN","text_ar":"جَسَدٌ"},{"kind":"text","text":"; (As, S;) or signify the"},{"kind":"italic_en","text":"whole body and limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members"},{"kind":"text","text":"of a man, (K, and T and Msb in explanation of"},{"kind":"arabic","text_bw":"jsm","text_ar":"جسم"},{"kind":"text","text":",) and of a beast, a camel, and the like, (T, Msb,) and of any other species, (K,) of large make; (T, Msb, K;) and"},{"kind":"arabic","text_bw":"juvomaAnN","text_ar":"جُثْمَانٌ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"$axoSN","text_ar":"شَخْصٌ"},{"kind":"text","text":"[app. as meaning “ a person ”]; and ↓"},{"kind":"arabic","text_bw":"jusomaAnN","text_ar":"جُسْمَانٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"whole"},{"kind":"arabic","text_bw":"jisom","text_ar":"جِسْم"},{"kind":"text","text":"of a man: (As, S:) or"},{"kind":"arabic","text_bw":"jisomN","text_ar":"جِسْمٌ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"a body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"material substance; a solid;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing having length and breadth and thickness;"},{"kind":"text","text":"so that, when it is cut and divided, no portion thereof ceases to be a"},{"kind":"arabic","text_bw":"jisom","text_ar":"جِسْم"},{"kind":"text","text":"; whereas a"},{"kind":"arabic","text_bw":"$axoS","text_ar":"شَخْص"},{"kind":"text","text":"[meaning “ a person ”] ceases to be a"},{"kind":"arabic","text_bw":"$axoS","text_ar":"شَخْص"},{"kind":"text","text":"by its being divided: (Er-Rághib, TA:)"},{"kind":"italic_en","text":"a thing that is capable of being divided in length and breadth and thickness"},{"kind":"text","text":"is called"},{"kind":"arabic","text_bw":"jisomN TabiyEiY~N","text_ar":"جِسْمٌ طَبِيعِىٌّ"},{"kind":"text","text":", and also, because it is a subject of investigation, or inquiry, in instruction in the mathematical studies,"},{"kind":"arabic","text_bw":"jisomN","text_ar":"جِسْمٌ"},{"kind":"arabic","text_bw":"taEoliymiY~N","text_ar":"تَعْلِيمِىٌّ"},{"kind":"text","text":": (KT:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^ajosaAmN","text_ar":"اَجْسَامٌ"},{"kind":"text","text":"and [of mult]"},{"kind":"arabic","text_bw":"jusuwmN","text_ar":"جُسُومٌ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"vaAba jisomuhu","text_ar":"ثَابَ جِسْمُهُ"},{"kind":"text","text":", (M, A, K, in art."},{"kind":"arabic","text_bw":"vwb","text_ar":"ثوب"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"A^avaAba jisomuhu","text_ar":"اَثَابَ جِسْمُهُ"},{"kind":"text","text":", (IKt, M, ib.,) and"},{"kind":"arabic","text_bw":"vaAba A_ilayohi jisomuhu","text_ar":"ثَابَ اـِلَيْهِ جِسْمُهُ"},{"kind":"text","text":", (T, M, A, ib.,) (tropical:)"},{"kind":"italic_en","text":"He became fat, after leanness;"},{"kind":"text","text":"(A;)"},{"kind":"italic_en","text":"his good state of body returned to him;"},{"kind":"text","text":"(M, K; *)"},{"kind":"italic_en","text":"his condition of body became good, after extenuation; and health,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundness, thereof returned to him."},{"kind":"text","text":"(T.) And ↓"},{"kind":"arabic","text_bw":"A_in~ahu laHaniyfu AljusomaAni","text_ar":"اـِنَّهُ لَحَنِيفُ الجُسْمَانِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily he is slender, spare,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lean, of body"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AlA^ajosaAmu Almuxotalifapu AlT~abaAy^iEi","text_ar":"الاَجْسَامُ المُخْتَلِفَةُ الطَّبَايِعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The material substances of different natures;"},{"kind":"text","text":"also called"},{"kind":"arabic","text_bw":"AlA^ajosaAmu","text_ar":"الاَجْسَامُ"},{"kind":"arabic","text_bw":"Als~aboEapu","text_ar":"السَّبْعَةُ"},{"kind":"italic_en","text":"the seven material substances,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alfili*aAtu","text_ar":"الفِلِذَاتُ"},{"kind":"text","text":"; namely,]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"EanaASir","text_ar":"عَنَاصِر"},{"kind":"text","text":"[which are the"},{"kind":"italic_en","text":"four elements, fire, air, earth, and water,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the three products composed of these,"},{"kind":"text","text":"(KT,) which are"},{"kind":"italic_en","text":"minerals, vegetables, and animals."},{"kind":"text","text":"(Note in a copy of the KT.)"},{"kind":"arabic","text_bw":"AlA^ajosaAmu AlT~abiyEiy~ahu","text_ar":"الاَجْسَامُ الطَّبِيعِيَّهُ"},{"kind":"text","text":", as used by those who study to discover occult things, signifies"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Earo$","text_ar":"عَرْش"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"kurosiY~","text_ar":"كُرْسِىّ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"AlA^ajosaAmu AlEunoSuriy~apu","text_ar":"الاَجْسَامُ العُنْصُرِيَّةُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"everything beside these two, of the heavens and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"elements termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^usoTuqusaAt","text_ar":"اُسْطُقُسَات"},{"kind":"italic_en","text":"therein."},{"kind":"text","text":"(KT.)"}],"source_refs":["T","Msb","K","As","S","KT"]}]}}