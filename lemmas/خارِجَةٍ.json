{"lemma":"خارِجَةٍ","slug":"خارِجَةٍ","root":"خ.ر.ج","root_slug":"خ-ر-ج","root_link":"/words/roots/خ-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خارِج","root":"خرج","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","prep"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n10293"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%B1%D9%90%D8%AC%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of خَرَجَ (ḵaraja)","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"outside, exterior"},{"pos":"noun","gloss":"foreign country, foreign countries, abroad"},{"pos":"noun","gloss":"quotient"},{"pos":"prep","gloss":"outside, out of"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb خَرَجَ (ḵaraja, “to go out”).\n\nConstruct-state accusative of خَارِج (ḵārij, “outside, exterior”)."},"ipa":["/xaː.rid͡ʒ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10293","headword_ar":"خَارِجَةٌ","root":"xrj","body":[{"kind":"text","text":"[fem. of"},{"kind":"arabic","text_bw":"xaArijN","text_ar":"خَارِجٌ"},{"kind":"text","text":": and sing. of"},{"kind":"arabic","text_bw":"xawaAriju","text_ar":"خَوَارِجُ"},{"kind":"text","text":"used as a subst.]. ―         -b2-"},{"kind":"arabic","text_bw":"AlxawaAriju","text_ar":"الخَوَارِجُ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"Ald~awaAxilu","text_ar":"الدَّوَاخِلُ"},{"kind":"arabic","text_bw":"waAlxawaAriju","text_ar":"وَالخَوَارِجُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The arches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vaults, and niches, in the inner side of a wall;"},{"kind":"arabic","text_bw":"AldwAxl","text_ar":"الدواخل"},{"kind":"text","text":"meaning the figured forms, and inscriptions, upon a wall, executed with gypsum or otherwise: or"},{"kind":"arabic","text_bw":"AldwAxl","text_ar":"الدواخل"},{"kind":"arabic","text_bw":"wAlxwArj","text_ar":"والخوارج"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the ornamental"},{"kind":"text","text":"["},{"kind":"italic_en","text":"depressed and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"projecting forms of a building, differing from the forms adjacent thereto."},{"kind":"text","text":"(Msb, from a saying of Esh-Sháfi'ee.) ―         -b3-"},{"kind":"arabic","text_bw":"xawaAriju AlmaAli","text_ar":"خَوَارِجُ المَالِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The mare and the female slave and the she-ass."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"xarajato","text_ar":"خَرَجَتْ"},{"kind":"arabic","text_bw":"xawaArijuhu","text_ar":"خَوَارِجُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His generosity became apparent, and he applied himself to the sound management of affairs,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"and became intelligent like others of his class, after his youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignorant and youthful conduct."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":null}