{"lemma":"عَطَشُ","slug":"عَطَشُ","root":"ع.ط.ش","root_slug":"ع-ط-ش","root_link":"/words/roots/ع-ط-ش","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n29558","","n29563","n29564"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B7%D9%8E%D8%B4%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be in want of water, to thirst, to require irrigation"},{"pos":"verb","gloss":"to make thirsty"},{"pos":"noun","gloss":"verbal noun of عَطِشَ (ʕaṭiša) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thirst"},{"pos":"adj","gloss":"thirsty"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29558","headword_ar":"عَطِشَ","root":"ET$","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaTa$N","text_ar":"عَطَشٌ"},{"kind":"text","text":", (S, O, Msb, K,) and sometimes"},{"kind":"arabic","text_bw":"maEoTa$N","text_ar":"مَعْطَشٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He thirsted; was thirsty: was in want of drink;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was in want of irrigation:"},{"kind":"arabic","text_bw":"EaTa$N","text_ar":"عَطَشٌ"},{"kind":"text","text":"being the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"riY~N","text_ar":"رِىٌّ"},{"kind":"text","text":". (S, O, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EaTi$a A_ilaY liqaAy^ihi","text_ar":"عَطِشَ اـِلَى لِقَايِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He longed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"thirsted,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to meet with him:"},{"kind":"text","text":"like as they say"},{"kind":"arabic","text_bw":"Zamiy^a","text_ar":"ظَمِيَ"},{"kind":"text","text":". (IDrd, O.) And"},{"kind":"arabic","text_bw":"A^anaA $adiydu","text_ar":"اَنَا شَدِيدُ"},{"kind":"arabic","text_bw":"AlEaTa$i A_ilaY liqaAy^ika","text_ar":"العَطَشِ اـِلَى لِقَايِكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I am vehemently longing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring, to meet with thee"},{"kind":"text","text":"]. (A.) [See also the first paragraph of art."},{"kind":"arabic","text_bw":"EmY","text_ar":"عمى"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"EaATa$ahu faEaTa$ahu","text_ar":"عَاطَشَهُ فَعَطَشَهُ"},{"kind":"text","text":": see 3."}],"source_refs":["S","O","Msb","K","TA"]},{"entry_id":"n29563","headword_ar":"عَطُشٌ","root":"ET$","body":[{"kind":"text","text":"; fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see the next paragraph, in three places."}],"source_refs":[]},{"entry_id":"n29564","headword_ar":"عَطِشٌ","root":"ET$","body":[{"kind":"text","text":"(Mgh, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EaTu$N","text_ar":"عَطُشٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"EaTo$aAn","text_ar":"عَطْشَان","orth_type":"arrow"},{"kind":"text","text":"[without and with tenween, as is shown by the two forms of its fem., which see in what follows,] (S, Mgh, O, Msb) and ↓"},{"kind":"arabic","text_bw":"EaATi$N","text_ar":"عَاطِشٌ","orth_type":"arrow"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"Thirsting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thirsty:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"needing water:"},{"kind":"text","text":"(Mgh:) or you say,"},{"kind":"arabic","text_bw":"A@loA=na","text_ar":"ا@لْا=نَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa EaTo$aAnu","text_ar":"هُوَ عَطْشَانُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is thirsting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thirsty, now"},{"kind":"text","text":"]; (Lh, K;) and"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"gadFA","text_ar":"غَدًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaATi$N","text_ar":"عَاطِشٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He will be thirsting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thirsty, tomorrow"},{"kind":"text","text":"]; (Lh, O, K;) and"},{"kind":"arabic","text_bw":"baEoda","text_ar":"بَعْدَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA huwa biEaATi$K","text_ar":"مَا هُوَ بِعَاطِشٍ","orth_type":"arrow"},{"kind":"arabic","text_bw":"h`*aA Alyawomi","text_ar":"هٰذَا اليَوْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He will not be thirsting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thirsty, after this day"},{"kind":"text","text":"]: (Lh, TA:) fem. [of the first]"},{"kind":"arabic","text_bw":"EaTi$apN","text_ar":"عَطِشَةٌ"},{"kind":"text","text":"(O, Msb, K) and [of the second] ↓"},{"kind":"arabic","text_bw":"EaTu$apN","text_ar":"عَطُشَةٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and [of the third] ↓"},{"kind":"arabic","text_bw":"EaTo$aY","text_ar":"عَطْشَى","orth_type":"arrow"},{"kind":"text","text":", (S, O, Msb, K,) which is also used as a pl., (S, K,) and ↓"},{"kind":"arabic","text_bw":"EaTo$aAnapN","text_ar":"عَطْشَانَةٌ","orth_type":"arrow"},{"kind":"text","text":": (Lth, O, K:) pl. masc. [of the first and third and fourth, and perhaps of the second also,]"},{"kind":"arabic","text_bw":"EiTaA$N","text_ar":"عِطَاشٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"EuTaA$N","text_ar":"عُطَاشٌ"},{"kind":"text","text":"[which is irregular] and"},{"kind":"arabic","text_bw":"EaTi$uwna","text_ar":"عَطِشُونَ"},{"kind":"text","text":"and [of the second]"},{"kind":"arabic","text_bw":"EaTu$uwna","text_ar":"عَطُشُونَ"},{"kind":"text","text":"(TA) and [of the third]"},{"kind":"arabic","text_bw":"EaTaA$aY","text_ar":"عَطَاشَى"},{"kind":"text","text":": (S, O, K:) pl. fem."},{"kind":"arabic","text_bw":"EiTaA$N","text_ar":"عِطَاشٌ"},{"kind":"text","text":", like the masc., (S, O, K,) and [of the first]"},{"kind":"arabic","text_bw":"EaTi$aAtN","text_ar":"عَطِشَاتٌ"},{"kind":"text","text":", (Lth, O, K,) but this was ignored by Aboo-Leylà, (O,) and [of the second]"},{"kind":"arabic","text_bw":"EaTu$aAtN","text_ar":"عَطُشَاتٌ"},{"kind":"text","text":"(TA) and [of the third]"},{"kind":"arabic","text_bw":"EaTo$aAnaAtN","text_ar":"عَطْشَانَاتٌ"},{"kind":"text","text":". (Lth, O, K.) Accord. to Mohammad Ibn-EsSeree, ↓"},{"kind":"arabic","text_bw":"EaTo$aAn","text_ar":"عَطْشَان","orth_type":"arrow"},{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"EaTo$aA='u","text_ar":"عَطْشَا=ءُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"SaHoraA='u","text_ar":"صَحْرَا=ءُ"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"being substituted for the fem."},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", as is shown by its plural's being"},{"kind":"arabic","text_bw":"EaTaA$aY","text_ar":"عَطَاشَى"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"SaHaAraY","text_ar":"صَحَارَى"},{"kind":"text","text":": (S, O:) [but there are many similar pls. of epithets of the measure"},{"kind":"arabic","text_bw":"fuEolaAn","text_ar":"فُعْلَان"},{"kind":"text","text":"; as"},{"kind":"arabic","text_bw":"sakaAraY","text_ar":"سَكَارَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gayaAraY","text_ar":"غَيَارَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nadaAmaY","text_ar":"نَدَامَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kasaAlaY","text_ar":"كَسَالَى"},{"kind":"text","text":"&c.] You say also"},{"kind":"arabic","text_bw":"EaTo$aAnu","text_ar":"عَطْشَانُ"},{"kind":"arabic","text_bw":"naTo$aAnu","text_ar":"نَطْشَانُ"},{"kind":"text","text":"; the latter being an imitative sequent to the former, not used alone. (S, O.) And"},{"kind":"arabic","text_bw":"A_in~aka","text_ar":"اـِنَّكَ"},{"kind":"arabic","text_bw":"kaA^an~aka EaTo$aAnu","text_ar":"كَاَنَّكَ عَطْشَانُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_ilaY Ald~ami EaTo$aAnu","text_ar":"اـِلَى الدَّمِ عَطْشَانُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily thou art thirsting for blood, as though thou wert 'Atshán"},{"kind":"text","text":"]: (A:) this being the name of a sword of 'Abd-ElMuttalib Ibn-Háshim. (A, O, K.) The dim. of"},{"kind":"arabic","text_bw":"EaTi$N","text_ar":"عَطِشٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"EuTayo$aAn","text_ar":"عُطَيْشَان","orth_type":"arrow"},{"kind":"text","text":", as though from"},{"kind":"arabic","text_bw":"EaTo$aAn","text_ar":"عَطْشَان"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"EuTayo$N","text_ar":"عُطَيْشٌ","orth_type":"arrow"},{"kind":"text","text":"also; but the former is the better. (ISk, O.) ―         -b2-  [Hence,] ↓"},{"kind":"arabic","text_bw":"EaTo$aAn","text_ar":"عَطْشَان","orth_type":"arrow"},{"kind":"text","text":"also signifies (tropical:)"},{"kind":"italic_en","text":"Longing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"A_in~iY A_ilayoka","text_ar":"اـِنِّى اـِلَيْكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"laEaTo$aAnu","text_ar":"لَعَطْشَانُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily I am longing for"},{"kind":"text","text":"seeing"},{"kind":"italic_en","text":"thee"},{"kind":"text","text":"]. (IAar, O.) ―         -b3-"},{"kind":"arabic","text_bw":"makaAnN EaTi$N","text_ar":"مَكَانٌ عَطِشٌ"},{"kind":"text","text":"(S, O, Msb) and ↓"},{"kind":"arabic","text_bw":"EaTu$N","text_ar":"عَطُشٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O)"},{"kind":"italic_en","text":"A place in which is little water:"},{"kind":"text","text":"(S, O, Msb:) or"},{"kind":"italic_en","text":"in which is no water."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"Alwi$aAHi","text_ar":"الوِشَاحِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fulaAnapu EaTo$aY","text_ar":"فُلَانَةُ عَطْشَى","orth_type":"arrow"},{"kind":"text","text":"(A) or"},{"kind":"arabic","text_bw":"EaTi$apu Alwi$aAHi","text_ar":"عَطِشَةُ الوِشَاحِ"},{"kind":"text","text":"(TA) (tropical:)  ["},{"kind":"italic_en","text":"Such a woman is slender in the waist;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the belly and flanks;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"garovaY Alwi$aAHi","text_ar":"غَرْثَى الوِشَاحِ"},{"kind":"text","text":"]."}],"source_refs":["Mgh","O","Msb","K","S","TA","Lh","Lth","A"]}]}}