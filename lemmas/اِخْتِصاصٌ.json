{"lemma":"اِخْتِصاصٌ","slug":"اِخْتِصاصٌ","root":"خ.ص.ص","root_slug":"خ-ص-ص","root_link":"/words/roots/خ-ص-ص","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of اِخْتَصَّ (iḵtaṣṣa) (form VIII)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"specialization"},{"pos":"noun","gloss":"specialty, domain, field"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of اِخْتَصَّ (iḵtaṣṣa)."},"ipa":["/ix.ti.sˤaːsˤ/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D8%AE%D8%AA%D8%B5%D8%A7%D8%B5/","headword_ar":"اختصاص الناعت","entries":[{"lexicon_id":"dictionary_22","lexicon_en":"Al-Munāwī, al-Tawqīf ʿalā Muhimmāt al-Taʿārīf (d. 1622 CE)","lexicon_ar":"التوقيف على مهمات التعاريف للمناوي","permalink":"https://arabiclexicon.hawramani.com/?p=22794#4c7cfd","body_html":"<span>اختصاص الناعت: هو التعلق الخاص الذي يصير به أحد المتعلقين ناعتا للاخر والاخر منعوتا به والنعت حالا فيه، والمنعوت محله، كالتعلق بين لون البياض والجسم المقتضي لكون البياض نعتا للجسم والجسم منعوتا بأن يقال جسم أبيض.</span><br>"},{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22794#bf06b8","body_html":"<span>اختصاص الناعت: هو التعلق الخاص الذي يصير به أحد المتعلقين ناعتًا للآخر، والآخر منعوتًا به، والنعت حالٌّ، والمنعوت محل، كالتعلق بين لون البياض والجسم المقتضي لكون البياض نعتًا للجسم، والجسم منعوتًا به، بأن يقال: جسم أبيض.</span>"}]}}