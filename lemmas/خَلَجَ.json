en":"m","num":"p"},{"role":"present_2mp","form":"تَخْلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْلِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْلِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْلِجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْلِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْلِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَلَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَلَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11219"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plural of خَلِيج (ḵalīj)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11219","headword_ar":"خَلَجَ","root":"xlj","body":[{"kind":"text","text":", (S, A, L, Msb, K,) aor."},{"kind":"text","text":", (S, K,) or"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xalojN","text_ar":"خَلْجٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Axtlj","text_ar":"اختلج","orth_type":"arrow"},{"kind":"text","text":"; (S, L, Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"txl~j","text_ar":"تخلّج","orth_type":"arrow"},{"kind":"text","text":"; (L, TA;)"},{"kind":"italic_en","text":"He drew, dragged, pulled, strained, stretched, extended, lengthened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protracted,"},{"kind":"text","text":"(S, L, K,) a thing: (S, * L, TA:) and"},{"kind":"italic_en","text":"he pulled out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"up, displaced, removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took away,"},{"kind":"text","text":"(S, A, Msb, K,) a thing, (S, * A, Msb, TA,) and a person. (A.) Thus in the saying,"},{"kind":"arabic","text_bw":"A^axa*a biyadihi faxalajahu bayoni SaHobihi","text_ar":"اَخَذَ بِيَدِهِ فَخَلَجَهُ بَيْنِ صَحْبِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took his hand, and pulled him out from amid his companions"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"xalaja rumoHahu mina AlmaToEuwni","text_ar":"خَلَجَ رُمْحَهُ مِنَ المَطْعُونِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He pulled out his spear from the person pierced"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"rumoHFA marokuwzFA","text_ar":"رُمْحًا مَرْكُوزًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Axtlj","text_ar":"اختلج","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He pulled out a spear stuck in the ground"},{"kind":"text","text":"]. (A, TA.) [See also an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"maTorabN","text_ar":"مَطْرَبٌ"},{"kind":"text","text":".] El-'Ajjáj says,"},{"kind":"quote","text":"faA_ino yakuno h`*aA Alz~amaAnu xalajaA\n                      \n                     \n                        faqado labisonaA Eayo$ahu AlmuxarofajaA"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"And if this time has taken away,"},{"kind":"text","text":"and exchanged for another, a state [in which we were,"},{"kind":"italic_en","text":"we have long enjoyed its plentiful life"},{"kind":"text","text":"]. (S.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"xulija","text_ar":"خُلِجَ"},{"kind":"text","text":", said of a stallion-camel,"},{"kind":"italic_en","text":"He was taken away from the females that had passed seven or eight months since the period when they last brought forth, before he had become too languid to cover any longer."},{"kind":"text","text":"(Lth, A, L.) And"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He weaned"},{"kind":"text","text":"his offspring, or the offspring"},{"kind":"page_break","n":783},{"kind":"text","text":"of his she-camel: (K:) (tropical:)"},{"kind":"italic_en","text":"he separated"},{"kind":"text","text":"a young camel from the mother. (A.) And"},{"kind":"arabic","text_bw":"xalajato waladahaA","text_ar":"خَلَجَتْ وَلَدَهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a mother)"},{"kind":"italic_en","text":"weaned her offspring:"},{"kind":"text","text":"(M, A:) so accord. to Lh, who does not particularize any kind [of animal]. (M.) And"},{"kind":"arabic","text_bw":"xalaja naAqapF","text_ar":"خَلَجَ نَاقَةً"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He weaned the offspring of a she-camel."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"mino bayonihimo","text_ar":"مِنْ بَيْنِهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Auxotulija","text_ar":"اُخْتُلِجَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He was taken away from among them"},{"kind":"text","text":"]: said of the dead. (A, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xalajaniY ka*aA","text_ar":"خَلَجَنِى كَذَا"},{"kind":"text","text":", (S, K, *) aor."},{"kind":"text","text":", (K,) (assumed tropical:)"},{"kind":"italic_en","text":"Such a thing occupied me; busied me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diverted me, by employing my attention,"},{"kind":"text","text":"from other things. (S, K, * TA.) You say,"},{"kind":"arabic","text_bw":"xalajatohu A^umuwru Ald~unoyaA","text_ar":"خَلَجَتْهُ اُمُورُ الدُّنْيَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The affairs of the world occupied him,"},{"kind":"text","text":"&c.]. (S, TA.) And ↓"},{"kind":"arabic","text_bw":"xalajatohu AlxawaAliju","text_ar":"خَلَجَتْهُ الخَوَالِجُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Busying"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"distracting"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"affairs busied"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"distracted"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"(Lth.) And a poet says,"},{"kind":"quote","text":"wa A^abiytu taxolijuniY Alhumuwmu kaA^an~aniY\n                      \n                     \n                        dalowu Als~uqaApi tumad~u biAlA^a$oTaAni"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I pass the night,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"anxieties busying me"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though I were the bucket of the waterers, drawn from the well by the ropes"},{"kind":"text","text":"]. (IAar.) ―         -b4-"},{"kind":"arabic","text_bw":"taxoliju","text_ar":"تَخْلِجُ"},{"kind":"arabic","text_bw":"Als~ayora","text_ar":"السَّيْرَ"},{"kind":"text","text":", said of a fleet she-camel, (L, K,) (assumed tropical:)"},{"kind":"italic_en","text":"She goes, journeys,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travels, quickly."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ"},{"kind":"arabic","text_bw":"fiY mi$oyatihi","text_ar":"فِى مِشْيَتِهِ"},{"kind":"text","text":": see 5. ―         -b5-"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He put"},{"kind":"text","text":"(a thing, TA)"},{"kind":"italic_en","text":"in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into a state of commotion."},{"kind":"text","text":"(A, K, TA.) You say,"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ"},{"kind":"arabic","text_bw":"HaAjibayohi","text_ar":"حَاجِبَيْهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eayonayohi","text_ar":"عَيْنَيْهِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He put in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into a state of commotion, his eyebrows,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his eyes."},{"kind":"text","text":"(A.) ―         -b6-  And"},{"kind":"arabic","text_bw":"xalaja","text_ar":"خَلَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(L, K) and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xalojN","text_ar":"خَلْجٌ"},{"kind":"text","text":", (L, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He made a sign"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by a motion"},{"kind":"text","text":"] (L, K, TA)"},{"kind":"arabic","text_bw":"biEayonihi","text_ar":"بِعَيْنِهِ"},{"kind":"italic_en","text":"with his eye,"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biHaAjibayohi","text_ar":"بِحَاجِبَيْهِ"},{"kind":"italic_en","text":"with his eyebrows."},{"kind":"text","text":"(L, TA.) And"},{"kind":"arabic","text_bw":"xalajahu biHaAjibihi","text_ar":"خَلَجَهُ بِحَاجِبِهِ"},{"kind":"text","text":", aor. and inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He made a sign to him with his eyebrow."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"xalajahu biEayonihi","text_ar":"خَلَجَهُ بِعَيْنِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made a sign to him with his eye; winked to him."},{"kind":"text","text":"(S, L.) And"},{"kind":"arabic","text_bw":"xalajatoniY biEayonihaA","text_ar":"خَلَجَتْنِى بِعَيْنِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"She made a sign to me with her eye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"winked to me, to indicate a time or place of appointment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something that she desired."},{"kind":"text","text":"(A, TA.) ―         -b7-  See also 8, in two places."}],"source_refs":["S","A","L","Msb","K","M","TA"]}]}}