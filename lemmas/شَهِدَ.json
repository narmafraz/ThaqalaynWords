{"lemma":"شَهِدَ","slug":"شَهِدَ","root":"ش.ه.د","root_slug":"ش-ه-د","root_link":"/words/roots/ش-ه-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَهِدْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَهِدْتِ","in_corpus":true,"count":15,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَهِدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَهِدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَهِدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَهِدَ","in_corpus":true,"count":78,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَهِدَت","in_corpus":true,"count":15,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَهِدا","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَهِدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَهِدُوا","in_corpus":true,"count":36,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَهِدْنَ","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَشْهَد","in_corpus":true,"count":38,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَشْهَدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَشْهَدِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَشْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَشْهَدا","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَشْهَدُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَشْهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْهَدْنَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْهَد","in_corpus":true,"count":90,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْهَد","in_corpus":true,"count":38,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْهَدانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْهَدا","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْهَدُونَ","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْهَدُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَهِدْنا","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَهِدْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْهَد","in_corpus":true,"count":179,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْهَد","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":555,"cross_references":{"qac":{"found":true,"lemma_key":"شَهِدَ","root":"شهد","pos":"V","occurrence_count":44},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n23186"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%87%D9%90%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to witness, to be a witness"},{"pos":"verb","gloss":"to experience personally, to see with one’s own eyes"},{"pos":"verb","gloss":"to be present, to attend, to be around"},{"pos":"verb","gloss":"to see"},{"pos":"verb","gloss":"to testify, to bear witness, to give testimony, to give evidence","examples":[{"text":"شَهِدَ الشَّاهِدُ بِالحَقِّ أَمَامَ القَاضِي.","english":"The witness testified to the truth in front of the judge."}]},{"pos":"verb","gloss":"to attest, to confirm, to certify"},{"pos":"verb","gloss":"to witness (a signature)"},{"pos":"verb","gloss":"to acknowledge, to adjudge"},{"pos":"noun","gloss":"honey especially still in the honeycomb","examples":[{"text":"فَكَمْ تُمَرِّرُ عَيْشِي وَأَنْتَ حامِلُ شَهْدٍ","english":"And how much you make my life bitter and [although] you are a carrier of honey"}]},{"pos":"noun","gloss":"honeycomb"},{"pos":"noun","gloss":"melon, cantaloupe"},{"pos":"noun","gloss":"nectar"},{"pos":"noun","gloss":"anything pleasant","tags":["figuratively"]},{"pos":"noun","gloss":"semen, menstruation","tags":["figuratively"]},{"pos":"adj","gloss":"masculine plural of شَاهِد (šāhid)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"From ش ه د (š h d), uncertain sense, perhaps from likening the honeycombs to the graves of martyrs or the swarming of people at such shrines like bees swarm around a hive; see مشهد. Otherwise from the mucus that covers a fetus at birth; the meaning of birth is extended from the \"being around\" or \"being present\" of verb form I."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23186","headword_ar":"شَهِدَ","root":"$hd","body":[{"kind":"text","text":", (S, A, Mgh, L, Msb, K,) aor."},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"$ahuda","text_ar":"شَهُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) also pronounced and written"},{"kind":"arabic","text_bw":"$ahoda","text_ar":"شَهْدَ"},{"kind":"text","text":", (Akh, S, K,) and"},{"kind":"arabic","text_bw":"$ihoda","text_ar":"شِهْدَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$ihida","text_ar":"شِهِدَ"},{"kind":"text","text":", accord. to a rule applying to all verbs of the measure"},{"kind":"arabic","text_bw":"faEila","text_ar":"فَعِلَ"},{"kind":"text","text":"of which the medial radical letter is a faucial; (MF;) inf. n."},{"kind":"arabic","text_bw":"$ahaAdapN","text_ar":"شَهَادَةٌ"},{"kind":"text","text":"(S, A, Mgh, L, Msb, K) and"},{"kind":"arabic","text_bw":"$hd","text_ar":"شهد"},{"kind":"text","text":"; (TA;) [there written without any syll. sign, and not found by me in any other Lex.;])"},{"kind":"italic_en","text":"He told,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave information of, what he had witnessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seen"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beheld with his eye:"},{"kind":"text","text":"(Mgh, L, Msb:) this is the primary signification: (L:)"},{"kind":"italic_en","text":"he declared what he knew: he gave testimony, attestation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence; he bore witness:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he gave decisive information."},{"kind":"text","text":"(S, A, L, K.) [See also"},{"kind":"arabic","text_bw":"$ahaAdapN","text_ar":"شَهَادَةٌ"},{"kind":"text","text":"below.] You say,"},{"kind":"arabic","text_bw":"$ahida bika*aA","text_ar":"شَهِدَ بِكَذَا"},{"kind":"text","text":", inf. n. as above, (S, A, Mgh, L, Msb, K,)"},{"kind":"italic_en","text":"He told,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave information of, such a thing, as having witnessed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seen"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beheld it with his eye;"},{"kind":"text","text":"(Mgh, Msb;) or"},{"kind":"italic_en","text":"declared such a thing as knowing it;"},{"kind":"text","text":"(L;) or"},{"kind":"italic_en","text":"gave his testimony, attestation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence, respecting it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bore witness of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to it;"},{"kind":"text","text":"(S, A, L, K;)"},{"kind":"arabic","text_bw":"Einoda AlHaAkimi","text_ar":"عِنْدَ الحَاكِمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the presence of the judge"},{"kind":"text","text":"];"},{"kind":"arabic","text_bw":"lifulaAnK","text_ar":"لِفُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in favour of, such a one"},{"kind":"text","text":"], (S, Mgh, L, K,) and"},{"kind":"arabic","text_bw":"EalaY fulaAnK","text_ar":"عَلَى فُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"against,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in opposition to, such a one"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"$ahida EalaY","text_ar":"شَهِدَ عَلَى"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"italic_en","text":"He gave decisive information"},{"kind":"text","text":"["},{"kind":"italic_en","text":"respecting such a thing"},{"kind":"text","text":"(as in the Kur xlvi. 9, and in many other instances);"},{"kind":"italic_en","text":"he testified respecting it"},{"kind":"text","text":"]. (S, L. [See also another meaning of this phrase in what follows.]) [Hence,]"},{"kind":"arabic","text_bw":"$ahida A@ll~`hu A^an~ahu laA A_ilaAha A_il~aA huwa","text_ar":"شَهِدَ ا@للّٰهُ اَنَّهُ لَا اـِلَاهَ اـِلَّا هُوَ"},{"kind":"text","text":", in the Kur [iii. 16], means"},{"kind":"italic_en","text":"God hath given evidence that there is no deity but He:"},{"kind":"text","text":"(Abu-l- 'Abbás, IAmb, Jel:) or"},{"kind":"italic_en","text":"God knoweth"},{"kind":"text","text":"&c.; (Ah- mad Ibn-Yahyà, K;) and so"},{"kind":"arabic","text_bw":"$ahida A@ll~`hu","text_ar":"شَهِدَ ا@للّٰهُ"},{"kind":"text","text":"throughout the Kur-án: (Ahmad Ibn-Yahyà:) or"},{"kind":"italic_en","text":"God saith"},{"kind":"text","text":"&c.: or"},{"kind":"italic_en","text":"God hath written"},{"kind":"text","text":"&c. (K.) And"},{"kind":"arabic","text_bw":"A^a$ohadu","text_ar":"اَشْهَدُ"},{"kind":"arabic","text_bw":"A^ano laA A_ilaAha A_il~aAA@ll~`hu","text_ar":"اَنْ لَا اـِلَاهَ اـِلَّاا@للّٰهُ"},{"kind":"italic_en","text":"I know,"},{"kind":"text","text":"(Msb, K,) [or"},{"kind":"italic_en","text":"acknowledge,"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"I declare,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"testify, that there is no deity but God:"},{"kind":"text","text":"] (K:) [Fei says,] the verb is trans. in this phrase by itself [i. e. without the intervention of a prep.] because it is used in the sense of"},{"kind":"arabic","text_bw":"A^aEolamu","text_ar":"اَعْلَمُ"},{"kind":"text","text":". (Msb.) [And hence,"},{"kind":"arabic","text_bw":"kalimapu Al$~ahaAdapi","text_ar":"كَلِمَةُ الشَّهَادَةِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The sentence declaring that there is no deity but God and that Mohammad is God's apostle."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"$ahida biA@ll~`hi","text_ar":"شَهِدَ بِا@للّٰهِ"},{"kind":"text","text":", (Mgh, * Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ahaAdapN","text_ar":"شَهَادَةٌ"},{"kind":"text","text":", (Mgh,) means"},{"kind":"italic_en","text":"He swore by God:"},{"kind":"text","text":"(Mgh, Msb:) and"},{"kind":"arabic","text_bw":"A^a$ohadu bika*aA","text_ar":"اَشْهَدُ بِكَذَا"},{"kind":"italic_en","text":"I swear by such a thing."},{"kind":"text","text":"(S, K.)"},{"kind":"arabic","text_bw":"A^a$ohadu biA@ll~`hi laqado kaAna ka*aA","text_ar":"اَشْهَدُ بِا@للّٰهِ لَقَدْ كَانَ كَذَا"},{"kind":"italic_en","text":"I swear by God that such a thing happened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took place,"},{"kind":"text","text":"combines the meaning of witnessing with that of swearing and that of informing at the time of"},{"kind":"page_break","n":1610},{"kind":"text","text":"uttering these words; as though the speaker said,"},{"kind":"italic_en","text":"I swear by God that I witnessed such a thing, and now I inform of it."},{"kind":"text","text":"(Msb.) Accord. to some, when one says only"},{"kind":"arabic","text_bw":"A^a$ohadu","text_ar":"اَشْهَدُ"},{"kind":"text","text":", not adding"},{"kind":"arabic","text_bw":"biA@ll~`hi","text_ar":"بِا@للّٰهِ"},{"kind":"text","text":", it is an oath. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"$ahida EalaY ka*aA","text_ar":"شَهِدَ عَلَى كَذَا"},{"kind":"text","text":", a phrase of which one meaning has been expl. above, means also"},{"kind":"italic_en","text":"He became a witness"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$aAhid","text_ar":"شَاهِد"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to, such a thing;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he had knowledge of such a thing, and witnessed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw it"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beheld it with his eye:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"$ahidahu","text_ar":"شَهِدَهُ"},{"kind":"text","text":", (Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"$ahaAdapN","text_ar":"شَهَادَةٌ"},{"kind":"text","text":", (L,) [likewise] signifies"},{"kind":"italic_en","text":"he witnessed it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beheld, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, with his eye;"},{"kind":"text","text":"(Mgh, L;) and (Mgh, L, Msb) so ↓"},{"kind":"arabic","text_bw":"$Ahdhu","text_ar":"شاهدهُ","orth_type":"arrow"},{"kind":"text","text":", (A, Mgh, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"mu$aAhadapN","text_ar":"مُشَاهَدَةٌ"},{"kind":"text","text":". (S, A, L, Msb.) [Hence,] one says,"},{"kind":"arabic","text_bw":"minohu HaAlN jamiylapN","text_ar":"مِنْهُ حَالٌ جَمِيلَةٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$uwhidato","text_ar":"شُوهِدَتْ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A comely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, of him was witnessed"},{"kind":"text","text":"]. (A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"$ahidahu","text_ar":"شَهِدَهُ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", K,) inf. n."},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present at it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in it;"},{"kind":"text","text":"(S, A, Mgh, L, Msb, * K;) namely, a place, (Mgh,) or an assembly. (Msb.) Hence the saying, (Msb,)"},{"kind":"arabic","text_bw":"famano $ahida minokumu A@l$~ahora faloyaSumohu","text_ar":"فَمَنْ شَهِدَ مِنْكُمُ ا@لشَّهْرَ فَلْيَصُمْهُ"},{"kind":"text","text":", in the Kur [ii. 181],"},{"kind":"italic_en","text":"Therefore whosoever of you shall be present in the month, and stationary, not journeying, he shall fast therein"},{"kind":"text","text":"(Mgh, Msb) as long as he shall remain present and stationary: (Msb:)"},{"kind":"arabic","text_bw":"Al$hr","text_ar":"الشهر"},{"kind":"text","text":"being here in the accus. case as an adv. n. of time. (Mgh, Msb.) [And hence,]"},{"kind":"arabic","text_bw":"$ahida AljumoEapa","text_ar":"شَهِدَ الجُمْعَةَ"},{"kind":"italic_en","text":"He attained to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the being present at"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"jumoEap","text_ar":"جُمْعَة"},{"kind":"text","text":"[here meaning, as in many other instances, the"},{"kind":"italic_en","text":"prayer of Friday"},{"kind":"text","text":"]: (Mgh:) and"},{"kind":"arabic","text_bw":"$ahida AlEiyda","text_ar":"شَهِدَ العِيدَ"},{"kind":"italic_en","text":"he attained to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the being present at"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"Eiyd","text_ar":"عِيد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"festival,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the prayer thereof"},{"kind":"text","text":"]. (Msb.) [Hence also,] it is said in a trad.,"},{"kind":"arabic","text_bw":"ya$ohadu bayoEakumu","text_ar":"يَشْهَدُ بَيْعَكُمُ"},{"kind":"arabic","text_bw":"AlHalifu waAll~agowu","text_ar":"الحَلِفُ وَاللَّغْوُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Swearing, and unprofitable speech, attend your selling"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"$wb","text_ar":"شوب"},{"kind":"text","text":": see 1 in that art.)"}],"source_refs":["S","A","Mgh","L","Msb","K","Akh"]}]}}