e,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a sharpness and effectiveness, in his pace."},{"kind":"text","text":"] ―         -b6-"},{"kind":"arabic","text_bw":"maDaYa AlA^amoru","text_ar":"مَضَىَ الاَمْرُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alqawolu","text_ar":"القَوْلُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The command, or order,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the saying, was effectual; had effect; was, or became, executed, or performed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":". (Msb, art"},{"kind":"arabic","text_bw":"nf*","text_ar":"نفذ"},{"kind":"text","text":".) ―         -b7-"},{"kind":"arabic","text_bw":"maDaY fiY","text_ar":"مَضَى فِى"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He acted"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"went on,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"did so"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with penetrative energy, or with sharpness, vigour, and effectiveness, in the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":". (S, M, K.) See"},{"kind":"arabic","text_bw":"maADK fiY AlA^umuwri","text_ar":"مَاضٍ فِى الاُمُورِ"},{"kind":"text","text":", below; and"},{"kind":"arabic","text_bw":"jasara","text_ar":"جَسَرَ"},{"kind":"text","text":". ―         -b8-"},{"kind":"arabic","text_bw":"maDaY EalaY AlA^amori","text_ar":"مَضَى عَلَى الاَمْرِ"},{"kind":"italic_en","text":"He executed, performed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished, the affair;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^amoDaAhu","text_ar":"اَمْضَاهُ","orth_type":"arrow"},{"kind":"text","text":": (S:) and"},{"kind":"italic_en","text":"he kept,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"applied himself, constantly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perseveringly, to it."},{"kind":"text","text":"(Msb.) ―         -b9-"},{"kind":"arabic","text_bw":"maDayotu ElY bayoEiY","text_ar":"مَضَيْتُ على بَيْعِى"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^amoDayotuhu","text_ar":"اَمْضَيْتُهُ","orth_type":"arrow"},{"kind":"italic_en","text":"I effected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"executed, my sale."},{"kind":"text","text":"(K.) ―         -b10-"},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a sword)"},{"kind":"italic_en","text":"cut;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"penetrated; was sharp."}],"source_refs":["S"]}]},"classical_definitions":null}