ntry_ids":["n1835"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D9%8E%D8%AD%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to enlarge oneself, to become ample, to become abundant"},{"pos":"verb","gloss":"to delve into, to get concerned with, to get thoroughly involved","examples":[{"text":"وعندما تبحَّرتُ في دراسات مقارنة النشاط الجيني بمختلف الكروموسومات، أدركت أن أداة تجارية كهذه لن تتماشى مع متطلباتها في معالجة البيانات.","english":"But when I delved into studies comparing the genetic activity of various chromosomes, I realized that a commercial application like this could not keep pace with the requirements of data processing."}]}]},"etymology":null,"ipa":["/ta.baħ.ħa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1835","headword_ar":"تبحّر","root":"bHr","body":[{"kind":"text","text":": see 10. ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a pastor)"},{"kind":"italic_en","text":"took a wide range"},{"kind":"text","text":"in abundant pasturage. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"tbH~r fiY AlmaAli","text_ar":"تبحّر فِى المَالِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He enlarged himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made himself, ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant, in wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(K, * TA;) as also"},{"kind":"arabic","text_bw":"fyh","text_ar":"فيه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstbHr","text_ar":"استبحر"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"tbH~r fiY AlEilomi","text_ar":"تبحّر فِى العِلْمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He went deep into science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge, and enlarged himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took a wide range, therein,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"wide as the sea;"},{"kind":"text","text":"(TA;) and in like manner one says with respect to other things: (S:) and so"},{"kind":"arabic","text_bw":"fyh","text_ar":"فيه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstbHr","text_ar":"استبحر"},{"kind":"text","text":". (A, TA.)"}],"source_refs":["S","A","K"]}]}}