abited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninhabited:"},{"kind":"text","text":"(M, Msb, * K:) or the former signifies"},{"kind":"italic_en","text":"any place of this description;"},{"kind":"text","text":"and the latter,"},{"kind":"italic_en","text":"a portion thereof:"},{"kind":"text","text":"(T:) or the former is a generic name of"},{"kind":"italic_en","text":"a place"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"province"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"such as El-'Irák and Syria;"},{"kind":"text","text":"and the latter signifies"},{"kind":"italic_en","text":"a particular portion thereof such as"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the city"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"El-Basrah and Damascus;"},{"kind":"text","text":"(M, K;) or these are post-classical applications: (TA:) or the former,"},{"kind":"italic_en","text":"a tract of land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district, which is an abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place of resort, of animals,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii, even if containing no building:"},{"kind":"text","text":"(Nh:) or"},{"kind":"italic_en","text":"a land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"absolutely: and also"},{"kind":"italic_en","text":"a town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":": but this latter is a conventional adventitious application: ('Ináyeh, TA:) and the latter,"},{