{"lemma": "خَرٌّ", "slug": "خَرٌّ", "root": "خ.ر.ر", "root_slug": "خ-ر-ر", "root_link": "/words/roots/خ-ر-ر", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": true, "lemma_key": "خَرٌّ", "root": "خرر", "pos": "V", "occurrence_count": 12}, "wiktextract": {"found": true, "entry_count": 3, "pos_tags": ["noun", "verb"], "has_etymology": false, "sense_count": 6}, "lanes": {"found": true, "entry_ids": ["n10213", "n10217"], "search_url": "https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B1%D9%8C%D9%91"}}, "translations": {"en": "murmuring sound", "fa": "صدای غرغر", "ur": "غرغر کی آواز", "tr": "gürültü", "id": "suara gemuruh", "bn": "গুমর শব্দ", "es": "sonido murmurante", "fr": "bruit de murmure", "de": "Murmeln", "ru": "бурление", "zh": "轰鸣声"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to murmur, to bubble, to gurgle"}, {"pos": "verb", "gloss": "to ripple, to trickle"}, {"pos": "verb", "gloss": "to snore"}, {"pos": "verb", "gloss": "to fall, to fall down, to drop", "examples": [{"text": "وَمَنْ يُشْرِكْ بِاللَّهِ فَكَأَنَّمَا خَرَّ مِنَ السَّمَاءِ فَتَخْطَفُهُ الطَّيْرُ", "english": "And he who associates with Allah - it is as though he had fallen from the sky and was snatched by the birds"}, {"text": "قَالَ لَقَدْ ظَلَمَكَ بِسُؤَالِ نَعْجَتِكَ إِلَىٰ نِعَاجِهِ ۖ وَإِنَّ كَثِيرًا مِّنَ الْخُلَطَاءِ لَيَبْغِي بَعْضُهُمْ عَلَىٰ بَعْضٍ إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ وَقَلِيلٌ مَّا هُمْ ۗ وَظَنَّ دَاوُودُ أَنَّمَا فَتَنَّاهُ فَاسْتَغْفَرَ رَبَّهُ وَخَرَّ رَاكِعًا وَأَنَابَ", "english": "[David] said, \"He has certainly wronged you in demanding your ewe [in addition] to his ewes. And indeed, many associates oppress one another, except for those who believe and do righteous deeds - and few are they.\" And David became certain that We had tried him, and he asked forgiveness of his Lord and fell down bowing [in prostration] and turned in repentance [to Allāh]. [Sajdah]"}]}, {"pos": "verb", "gloss": "to sink to the ground, to prostrate oneself"}, {"pos": "noun", "gloss": "verbal noun of خَرَّ (ḵarra) (form I)", "tags": ["form-of", "noun-from-verb"]}]}, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n10213", "headword_ar": "خَرَّ", "root": "xr", "body": [{"kind": "text", "text": ", (S, A, K,) aor."}, {"kind": "text", "text": "(S, M, K) and"}, {"kind": "text", "text": ", (M, K,) [the latter of which is anomalous,] inf. n."}, {"kind": "arabic", "text_bw": "xariyrN", "text_ar": "خَرِيرٌ"}, {"kind": "text", "text": ", (S, A, Msb, K,)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(water)"}, {"kind": "italic_en", "text": "sounded;"}, {"kind": "text", "text": "[i. e.,"}, {"kind": "italic_en", "text": "murmured; rumbled;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "gurgled;"}, {"kind": "text", "text": "] (S, A, Msb, K;) as also ↓"}, {"kind": "arabic", "text_bw": "xaroxara", "text_ar": "خَرْخَرَ", "orth_type": "arrow"}, {"kind": "text", "text": ", (A,) inf. n."}, {"kind": "arabic", "text_bw": "xaroxarapN", "text_ar": "خَرْخَرَةٌ"}, {"kind": "text", "text": ": (TA:) or"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", (IAar, T,) inf. n."}, {"kind": "arabic", "text_bw": "xar~N", "text_ar": "خَرٌّ"}, {"kind": "text", "text": ", (IAar,)"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(water)"}, {"kind": "italic_en", "text": "ran vehemently"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "so as to make a noise:"}, {"kind": "text", "text": "as used in the present day,"}, {"kind": "italic_en", "text": "it ran, flowed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "trickled down;"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "leaked,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "oozed, out:"}, {"kind": "text", "text": "and also"}, {"kind": "italic_en", "text": "it ran so as to make a murmuring,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "similar, sound"}, {"kind": "text", "text": "]: (IAar, T:) and"}, {"kind": "arabic", "text_bw": "xur~a", "text_ar": "خُرَّ"}, {"kind": "italic_en", "text": "it was made to run:"}, {"kind": "text", "text": "(TA: but the subject of this verb is not mentioned.) And"}, {"kind": "arabic", "text_bw": "xar~ato", "text_ar": "خَرَّتْ"}, {"kind": "text", "text": ", (A, K,) aor."}, {"kind": "text", "text": "and"}, {"kind": "text", "text": ", (K,) inf. n."}, {"kind": "arabic", "text_bw": "xariyrN", "text_ar": "خَرِيرٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(the wind,"}, {"kind": "arabic", "text_bw": "Alr~iyHu", "text_ar": "الرِّيحُ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "sounded;"}, {"kind": "text", "text": "[i. e.,"}, {"kind": "italic_en", "text": "murmured; rumbled;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rustled;"}, {"kind": "text", "text": "] (A, K;) among reeds or canes; as also ↓"}, {"kind": "arabic", "text_bw": "xaroxarato", "text_ar": "خَرْخَرَتْ", "orth_type": "arrow"}, {"kind": "text", "text": ", (A,) inf. n. as above: (TA:) or the latter signifies"}, {"kind": "page_break", "n": 715}, {"kind": "italic_en", "text": "it made a quick"}, {"kind": "arabic", "text_bw": "xariyr", "text_ar": "خَرِير"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "rustling"}, {"kind": "text", "text": "] among reeds or canes or the like. (Lth.) Also"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(an eagle,"}, {"kind": "arabic", "text_bw": "EuqaAb", "text_ar": "عُقَاب"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "made a rustling"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "Hafiyf", "text_ar": "حَفِيف"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "with its wings,"}, {"kind": "text", "text": "in flying. (Lth, K.) And"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ", (S,) inf. n."}, {"kind": "arabic", "text_bw": "xariyrN", "text_ar": "خَرِيرٌ"}, {"kind": "text", "text": ", (K,)"}, {"kind": "italic_en", "text": "He"}, {"kind": "text", "text": "(a man sleeping)"}, {"kind": "italic_en", "text": "snored,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "made a sound in breathing;"}, {"kind": "text", "text": "(S, K, * TA;) as also ↓"}, {"kind": "arabic", "text_bw": "xaroxara", "text_ar": "خَرْخَرَ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S,) inf. n."}, {"kind": "arabic", "text_bw": "xaroxarapN", "text_ar": "خَرْخَرَةٌ"}, {"kind": "text", "text": ": (S, K:) and the latter, (TA,) inf. n. as above, (K,) has the same signification when said of a leopard (K, * TA) in his sleep; (TA;) as also the former, inf. n. as above; (TA;) and when said of a cat; (K, * TA;) as also the former, (TA,) inf. n."}, {"kind": "arabic", "text_bw": "xuruwrN", "text_ar": "خُرُورٌ"}, {"kind": "text", "text": "(so in the CK and in a MS. copy of the K, but in the text of the K in the TA,"}, {"kind": "arabic", "text_bw": "xaruwrN", "text_ar": "خَرُورٌ"}, {"kind": "text", "text": ",) and"}, {"kind": "arabic", "text_bw": "xariyrN", "text_ar": "خَرِيرٌ"}, {"kind": "text", "text": "; (TA;) [i. e."}, {"kind": "italic_en", "text": "he made a loud purring in his sleep;"}, {"kind": "text", "text": "] and it is likewise significant of the sound, or sounds, made by a person suffering strangulation. (S, TA: but of the verb applied in this last manner, only the inf. n.,"}, {"kind": "arabic", "text_bw": "xaroxarapN", "text_ar": "خَرْخَرَةٌ"}, {"kind": "text", "text": ", is mentioned.) And"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a stone)"}, {"kind": "italic_en", "text": "made a sound in its descent."}, {"kind": "text", "text": "(TA.) ―         -b2-  [Hence,]"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": "(S, A, Msb, K) and"}, {"kind": "text", "text": ", (K,) the latter of which is anomalous, (TA,) inf. n."}, {"kind": "arabic", "text_bw": "xuruwrN", "text_ar": "خُرُورٌ"}, {"kind": "text", "text": "(S, K) and"}, {"kind": "arabic", "text_bw": "xar~N", "text_ar": "خَرٌّ"}, {"kind": "text", "text": ", (K,)"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, fell,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fell down:"}, {"kind": "text", "text": "(S, A, Msb, K:) originally,"}, {"kind": "italic_en", "text": "he,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, fell, making a sound to be heard at the same time:"}, {"kind": "text", "text": "afterwards used in the sense of falling absolutely: you say"}, {"kind": "arabic", "text_bw": "xar~a AlbinaA='u", "text_ar": "خَرَّ البِنَا=ءُ"}, {"kind": "italic_en", "text": "The building fell down:"}, {"kind": "text", "text": "(TA:) and"}, {"kind": "arabic", "text_bw": "xar~a lil~`hi saAjidFA", "text_ar": "خَرَّ لِلّٰهِ سَاجِدًا"}, {"kind": "italic_en", "text": "He fell down prostrating himself to God:"}, {"kind": "text", "text": "(S, A, * TA:) or"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": "signifies"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, fell from a high to a low place:"}, {"kind": "text", "text": "(K, TA:) so in the Kur [xxii. 32],"}, {"kind": "arabic", "text_bw": "fakaA^an~amaA", "text_ar": "فَكَاَنَّمَا"}, {"kind": "arabic", "text_bw": "xar~amina Als~amaA='i", "text_ar": "خَرَّمِنَ السَّمَا=ءِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He is as though he fell from the shy"}, {"kind": "text", "text": "]. (A, * TA.) And"}, {"kind": "arabic", "text_bw": "xar~uwA liA^a*oqaAnihimo", "text_ar": "خَرُّوا لِاَذْقَانِهِمْ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "xuruwrN", "text_ar": "خُرُورٌ"}, {"kind": "text", "text": ", ["}, {"kind": "italic_en", "text": "They fell down prostrate, with their chins to the ground:"}, {"kind": "text", "text": "see the Kur xvii. 108 and 109:] (A:) [whence the saying,]"}, {"kind": "arabic", "text_bw": "EaSafato riyHu faxar~ati AlA^a$ojaAru", "text_ar": "عَصَفَتْ رِيحُ فَخَرَّتِ الاَشْجَارُ"}, {"kind": "arabic", "text_bw": "liloA^a*oqaAni", "text_ar": "لِلْاَذْقَانِ"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "A wind blew violently, so that the trees fell,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "bent themselves, down to the ground"}, {"kind": "text", "text": "]. (A.) ―         -b3-  You say also,"}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ", (TA,) inf. n."}, {"kind": "arabic", "text_bw": "xar~N", "text_ar": "خَرٌّ"}, {"kind": "text", "text": ", (K,) meaning (assumed tropical:)"}, {"kind": "italic_en", "text": "He died:"}, {"kind": "text", "text": "(K, TA:) because a man, when he dies, falls down. (TA.) In the Kur xxxiv. 13, it may mean (assumed tropical:)"}, {"kind": "italic_en", "text": "He died,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "he fell down."}, {"kind": "text", "text": "(TA.) ―         -b4-  Also ("}, {"kind": "arabic", "text_bw": "xar~a", "text_ar": "خَرَّ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "He stumbled after going right."}, {"kind": "text", "text": "(TA.) ―         -b5-  And"}, {"kind": "arabic", "text_bw": "xar~ato xaTaAyaAhu", "text_ar": "خَرَّتْ خَطَايَاهُ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "His sins fell;"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "fell from him;"}, {"kind": "text", "text": "q. d."}, {"kind": "italic_en", "text": "fell to the ground;"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "went away;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "departed."}, {"kind": "text", "text": "(TA, from a trad.) ―         -b6-  And"}, {"kind": "arabic", "text_bw": "xar~a mina Aljabali", "text_ar": "خَرَّ مِنَ الجَبَلِ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "xuruwrN", "text_ar": "خُرُورٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "(a man,) and"}, {"kind": "italic_en", "text": "it,"}, {"kind": "text", "text": "(a stone, &c.,)"}, {"kind": "italic_en", "text": "rolled down from the mountain."}, {"kind": "text", "text": "(TA.) ―         -b7-  And"}, {"kind": "arabic", "text_bw": "AlA^aEoraAbu", "text_ar": "الاَعْرَابُ"}, {"kind": "arabic", "text_bw": "yaxir~uwna mina AlbawaAdiY AlquraY", "text_ar": "يَخِرُّونَ مِنَ البَوَادِى القُرَى"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "The Arabs of the desert come down,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "descend, from the deserts to the towns or villages."}, {"kind": "text", "text": "(A.) ―         -b8-  And"}, {"kind": "arabic", "text_bw": "xar~uwA EalayonaA", "text_ar": "خَرُّوا عَلَيْنَا"}, {"kind": "text", "text": ", (TA,) inf. n."}, {"kind": "arabic", "text_bw": "xar~N", "text_ar": "خَرٌّ"}, {"kind": "text", "text": ", (K,) (assumed tropical:)"}, {"kind": "italic_en", "text": "They came upon us suddenly, or unawares, from a place unknown."}, {"kind": "text", "text": "(K, * TA.) ―         -b9-  And"}, {"kind": "arabic", "text_bw": "xar~uwA", "text_ar": "خَرُّوا"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "They came from one town,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "country,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like, to another."}, {"kind": "text", "text": "(TA.) ―         -b10-  And (assumed tropical:)"}, {"kind": "italic_en", "text": "They passed along, or away, or by."}, {"kind": "text", "text": "(TA.) ―         -b11-"}, {"kind": "arabic", "text_bw": "xararota Eano yadayoka", "text_ar": "خَرَرْتَ عَنْ يَدَيْكَ"}, {"kind": "text", "text": ", or"}, {"kind": "arabic", "text_bw": "mino yadayoki", "text_ar": "مِنْ يَدَيْكِ"}, {"kind": "text", "text": ", is a metonymical phrase, well known, meaning (tropical:)"}, {"kind": "italic_en", "text": "Mayest thou be confounded and stupified by shame; or, so as to be speechless and motionless:"}, {"kind": "arabic", "text_bw": "xrrt", "text_ar": "خررت"}, {"kind": "text", "text": "[properly] signifying"}, {"kind": "arabic", "text_bw": "saqaTota", "text_ar": "سَقَطْتَ"}, {"kind": "text", "text": ". (TA in the present art. and in art."}, {"kind": "arabic", "text_bw": "Arb", "text_ar": "ارب"}, {"kind": "text", "text": ".)"}], "source_refs": ["S", "A", "K", "M", "Msb", "TA", "IAar", "T"]}, {"entry_id": "n10217", "headword_ar": "خُرٌّ", "root": "xr", "body": [{"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "xur~iY~N", "text_ar": "خُرِّىٌّ", "orth_type": "arrow"}, {"kind": "text", "text": "The"}, {"kind": "arabic", "text_bw": "luhowap", "text_ar": "لُهْوَة"}, {"kind": "text", "text": "of a mill or mill-stone; i. e. the"}, {"kind": "italic_en", "text": "place into which the wheat is thrown with the hand;"}, {"kind": "text", "text": "(S;) the"}, {"kind": "italic_en", "text": "mouth"}, {"kind": "text", "text": "of a mill or millstone. (K.)"}], "source_refs": []}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}