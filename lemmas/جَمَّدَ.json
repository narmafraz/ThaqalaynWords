"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%85%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to freeze, stiffen, coagulate (intransitive)"},{"pos":"verb","gloss":"to harden (intransitive)"},{"pos":"verb","gloss":"to grow tranquil, calm down"},{"pos":"verb","gloss":"to remain stationary"},{"pos":"verb","gloss":"to be or become lifeless"},{"pos":"verb","gloss":"to be or become dull, stupid, inert"},{"pos":"verb","gloss":"to be hard, be miserly, be stingy"},{"pos":"verb","gloss":"to insist on one's right"},{"pos":"verb","gloss":"to cut, cut off"},{"pos":"verb","gloss":"to freeze, to frost","tags":["transitive"],"examples":[{"text":"جَمَّدَتِ الثَّلَّاجَةُ المَاءَ","english":"The refrigerator froze the water."}]},{"pos":"noun","gloss":"verbal noun of جَمَدَ (jamada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of جَمُدَ (jamuda) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"freezing"},{"pos":"noun","gloss":"condensation, coagulation, congelation"},{"pos":"noun","gloss":"ice"},{"pos":"noun","gloss":"ice"},{"pos":"noun","gloss":"snow"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6247","headword_ar":"جَمَدَ","root":"jmd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jamodN","text_ar":"جَمْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":", said of water, (S, M, L, Msb, K,) &c., (Msb,) [i. e.,] of anything fluid, or liquid, (K,)"},{"kind":"italic_en","text":"It congealed; concreted; became solid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contr. of fluid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liquid; froze;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":"; (S, M;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"*aAba","text_ar":"ذَابَ"},{"kind":"text","text":"; (Msb, K;) as also"},{"kind":"arabic","text_bw":"jamuda","text_ar":"جَمُدَ"},{"kind":"text","text":". (L, K.) And said of blood, &c., (S, M,)"},{"kind":"italic_en","text":"It congealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concreted;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qAm","text_ar":"قام"},{"kind":"text","text":": (M:) or"},{"kind":"italic_en","text":"became dry; dried."},{"kind":"text","text":"(S.) See also 2. ―         -b2-  Also, inf. n."},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, remained fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary."},{"kind":"text","text":"(KL.) You say,"},{"kind":"arabic","text_bw":"maA zilotu A^aDoribuhu Hat~aY jamada","text_ar":"مَا زِلْتُ اَضْرِبُهُ حَتَّى جَمَدَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I ceased not to beat him until he became motionless"},{"kind":"text","text":"]. (A.) ―         -b3-  (assumed tropical:)  ["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, incapable of growth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"increase; lifeless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dead:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":". ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stupid, dull, wanting in intelligence; inert; not sharp, penetrating, vigorous, or effective, in the performing of affairs;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, without strength"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sturdiness, and without endurance:"},{"kind":"text","text":"see, again,"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":".] ―         -b5-  Also, inf. n."},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":", (tropical:)  said of a man's state or condition [as meaning,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stagnant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unimproving"},{"kind":"text","text":"]. (A.) ―         -b6-  Also"},{"kind":"arabic","text_bw":"jamadato","text_ar":"جَمَدَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"[a camel, &c.,]"},{"kind":"italic_en","text":"had little milk."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"jamadato Eayonuhu","text_ar":"جَمَدَتْ عَيْنُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His eye shed few tears:"},{"kind":"text","text":"a phrase alluding to hardness of the heart. (Msb.) ―         -b7-  Also"},{"kind":"arabic","text_bw":"jamada","text_ar":"جَمَدَ"},{"kind":"text","text":", (L, K,) aor."},{"kind":"text","text":", (L,) [inf. n."},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":";] and ↓"},{"kind":"arabic","text_bw":"A^ajomada","text_ar":"اَجْمَدَ","orth_type":"arrow"},{"kind":"text","text":"; (A, TA; [in a copy of the A,"},{"kind":"arabic","text_bw":"Anjmd","text_ar":"انجمد"},{"kind":"text","text":", but this is doubtless a mistranscription; see"},{"kind":"arabic","text_bw":"mujomidN","text_ar":"مُجْمِدٌ"},{"kind":"text","text":";]) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly, penurious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious;"},{"kind":"text","text":"(L, A, K;) as also"},{"kind":"arabic","text_bw":"jamada","text_ar":"جَمَدَ"},{"kind":"arabic","text_bw":"kaf~uhu","text_ar":"كَفُّهُ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"jamadato","text_ar":"جَمَدَتْ"},{"kind":"text","text":"]; (Msb;) or"},{"kind":"arabic","text_bw":"jamadato yaduhu","text_ar":"جَمَدَتْ يَدُهُ"},{"kind":"text","text":": (A:) and ↓"},{"kind":"arabic","text_bw":"Ajmd","text_ar":"اجمد","orth_type":"arrow"},{"kind":"italic_en","text":"he possessed little good:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"refraining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"holding back, from beneficence."},{"kind":"text","text":"(Har p. 149.) ―         -b8-"},{"kind":"arabic","text_bw":"jamada liY Ealayohi Haq~iY","text_ar":"جَمَدَ لِى عَلَيْهِ حَقِّى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"My right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established against him;"},{"kind":"text","text":"(A, K, * TA;) as also"},{"kind":"arabic","text_bw":"*aAba","text_ar":"ذَابَ"},{"kind":"text","text":". (A, TA.)       -A2-"},{"kind":"arabic","text_bw":"jamadahu","text_ar":"جَمَدَهُ"},{"kind":"italic_en","text":"He cut it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut it off."},{"kind":"text","text":"(K.)"}],"source_refs":["S","M","L","Msb","K","A","TA"]},{"entry_id":"n6248","headword_ar":"جمّد","root":"jmd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajomiydN","text_ar":"تَجْمِيدٌ"},{"kind":"text","text":"; (K;) or ↓"},{"kind":"arabic","text_bw":"jamada","text_ar":"جَمَدَ","orth_type":"arrow"},{"kind":"text","text":"; (so in the L;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water, and expressed juice, L)"},{"kind":"italic_en","text":"was about to congeal, concrete, become solid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freeze; was at the point of congealing,"},{"kind":"text","text":"&c.; expl. by"},{"kind":"arabic","text_bw":"HaAwala A^ano yajomuda","text_ar":"حَاوَلَ اَنْ يَجْمُدَ"},{"kind":"text","text":". (L, K.)       -A2-  [And the former,"},{"kind":"italic_en","text":"It caused"},{"kind":"text","text":"water &c."},{"kind":"italic_en","text":"to congeal."},{"kind":"text","text":"]"}],"source_refs":[]},{"entry_id":"n6250","headword_ar":"جَمْدٌ","root":"jmd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n6251","headword_ar":"جُمْدٌ","root":"jmd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jumudN","text_ar":"جُمُدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n6252","headword_ar":"جَمَدٌ","root":"jmd","body":[{"kind":"text","text":"pl. [or rather quasi-pl. n.] of"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":", q. v. (S, Msb, K.) ―         -b2-  Also"},{"kind":"italic_en","text":"Congealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frozen, water; ice:"},{"kind":"text","text":"[see also"},{"kind":"arabic","text_bw":"jamodN","text_ar":"جَمْدٌ"},{"kind":"text","text":", mentioned with"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":":] and"},{"kind":"italic_en","text":"snow."},{"kind":"text","text":"(K.) ―         -b3-  See also what next follows."}],"source_refs":[]},{"entry_id":"n6253","headword_ar":"جُمُدٌ","root":"jmd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jumodN","text_ar":"جُمْدٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Elevated"},{"kind":"text","text":"ground; as also ↓"},{"kind":"arabic","text_bw":"jamadN","text_ar":"جَمَدٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) or a"},{"kind":"italic_en","text":"hard, elevated"},{"kind":"text","text":"place: (S, TA:) or"},{"kind":"arabic","text_bw":"jumudN","text_ar":"جُمُدٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"rugged"},{"kind":"text","text":"ground: (TA:) or"},{"kind":"italic_en","text":"an elevated, rugged"},{"kind":"text","text":"place: (As, TA:) or"},{"kind":"italic_en","text":"a small isolated mountain, not high, sometimes rugged and sometimes soft, and producing trees, only found in rugged land;"},{"kind":"text","text":"so called because of its dryness; it is the"},{"kind":"italic_en","text":"smallest kind of"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"round and small, not extending along the ground, rugged at the top, and producing herbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leguminous plants, as well as trees;"},{"kind":"text","text":"differing from"},{"kind":"arabic","text_bw":"jumuwdN","text_ar":"جُمُودٌ"},{"kind":"text","text":"[q. v.]: (ISh, L, TA:) pl. [of mult.]"},{"kind":"arabic","text_bw":"jimaAdN","text_ar":"جِمَادٌ"},{"kind":"text","text":"(ISh, S, M, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^ajomaAdN","text_ar":"اَجْمَادٌ"},{"kind":"text","text":". (S, M, K.) ―         -b2-  Also, the first,"},{"kind":"italic_en","text":"A stone:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"jimaAdN","text_ar":"جِمَادٌ"},{"kind":"text","text":". (Fr, TA.)"}],"source_refs":["M","K","S","TA","As","ISh","L"]}]}}