{"lemma":"خُشافٌ","slug":"خُشافٌ","root":"خ.ش.ف","root_slug":"خ-ش-ف","root_link":"/words/roots/خ-ش-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n10693"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D8%B4%D8%A7%D9%81%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10693","headword_ar":"خُشَّافٌ","root":"x$f","body":[{"kind":"italic_en","text":"A certain nocturnal flying thing;"},{"kind":"text","text":"(Msb;) the"},{"kind":"arabic","text_bw":"xuf~aA$","text_ar":"خُفَّاش"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bat"},{"kind":"text","text":"], (S, K, Msb,)"},{"kind":"italic_en","text":"that flies by night:"},{"kind":"text","text":"so says El-Fárábee, in section"},{"kind":"arabic","text_bw":"$","text_ar":"ش"},{"kind":"text","text":": (Msb:) formed by transposition from the latter word, which is the more chaste: (Sgh, Msb, TA:) or rather so called because of its"},{"kind":"arabic","text_bw":"xafa$aAn","text_ar":"خَفَشَان"},{"kind":"text","text":", i. e. its going about, or round about, by"},{"kind":"page_break","n":744},{"kind":"text","text":"night: (Lth, TA:) or"},{"kind":"italic_en","text":"a certain flying thing, having two small eyes:"},{"kind":"text","text":"(TA:) as some say, (S,) and thus also says El-Fárábee, (Msb,) the"},{"kind":"arabic","text_bw":"xuT~aAf","text_ar":"خُطَّاف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"swallow"},{"kind":"text","text":"]: (S, Msb, TA:) he who says"},{"kind":"arabic","text_bw":"xuf~aA$N","text_ar":"خُفَّاشٌ"},{"kind":"text","text":"derives its name from the smallness of its eyes. (Lth, TA.)"}],"source_refs":["S","K","Msb","Sgh","TA","Lth"]}]},"classical_definitions":null}