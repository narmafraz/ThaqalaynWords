{"lemma":"قَطّانِي","slug":"قَطّانِي","root":"ق.ط.ط","root_slug":"ق-ط-ط","root_link":"/words/roots/ق-ط-ط","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"قَطَطْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"قَطَطْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"قَطَطْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"قَطَطْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"قَطَطْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"قَطَّ","in_corpus":true,"count":113,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"قَطَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"قَطّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"قَطَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"قَطُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"قَطَطْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَقُطّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَقْطُط","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَقُطِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَقُطِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَقُطّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَقُطّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَقُطُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَقُطُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَقْطُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَقُطّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَقْطُط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَقُطّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَقْطُط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقُطّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقُطّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقُطّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقُطّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقُطُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقُطُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقْطُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَقُطّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقُطّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"قَطَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَطَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":116,"cross_references":{"qac":{"found":true,"lemma_key":"قَطّ","root":"قطط","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","adv","noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["","n35844","n35845","n35846","n35847","n35848","n35849","n35850","n35851","n35852","n35853","n35855"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B7%D9%91%D8%A7%D9%86%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adv","gloss":"ever, never"},{"pos":"verb","gloss":"to carve"},{"pos":"verb","gloss":"to cut, to trim, to clip, to pare"},{"pos":"verb","gloss":"to sharpen a nib, pencil"},{"pos":"adj","gloss":"short and curly (of hair)"},{"pos":"noun","gloss":"cat, tomcat","examples":[{"text":"القِطُّ يَلْعَبُ بِكُرَةٍ.","english":"The cat is playing with a ball."}]},{"pos":"noun","gloss":"verbal noun of قَطَّ (qaṭṭa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Most likely to be onomatopoeic. See قَتَّ (qatta).\n\nCognate with Classical Syriac ܩܛܘ (qaṭṭu)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35844","headword_ar":"قَطْ","root":"qT","body":[{"kind":"text","text":", signifying"},{"kind":"arabic","text_bw":"Hasobu","text_ar":"حَسْبُ"},{"kind":"text","text":", [explained in exs. here following,] (Lth, S, M, Msb, Mughnee, K,) i. e., (S,) denoting the being satisfied, or content, (Sb, S, M, Msb,) with a thing, (Msb,) is thus written, with fet-h to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", and with the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"quiescent, (Sb, S, M, Msb, * Mughnee,) like"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"; (K;) and also, (Sb, M, K,) sometimes, (Sb, M,) ↓"},{"kind":"arabic","text_bw":"qaTK","text_ar":"قَطٍ","orth_type":"arrow"},{"kind":"text","text":", (Sb, M, K,) with tenween, mejroor; (K;) and ↓"},{"kind":"arabic","text_bw":"qaTiY","text_ar":"قَطِى","orth_type":"arrow"},{"kind":"text","text":"[distinguished from"},{"kind":"arabic","text_bw":"qaTiY","text_ar":"قَطِى"},{"kind":"text","text":"in the next sentence]; (Sb, M, K;) but the term “ mejroor ” is here used contr. to the rules of grammar, as it denotes that"},{"kind":"arabic","text_bw":"qT","text_ar":"قط"},{"kind":"text","text":"is decl., whereas it is not. (MF.) It is used as a prefixed noun: you say,"},{"kind":"arabic","text_bw":"qaToka h`*aA Al$~aYo'u","text_ar":"قَطْكَ هٰذَا الشَّىْءُ"},{"kind":"italic_en","text":"Thy sufficiency"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"sufficient for thee"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is this thing;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Hasobuka","text_ar":"حَسْبُكَ"},{"kind":"text","text":"; (Lth, S, Mughnee; *) and like it is"},{"kind":"arabic","text_bw":"qado","text_ar":"قَدْ"},{"kind":"text","text":": (Lth:) and you also say, using it as a prefixed n.,"},{"kind":"arabic","text_bw":"qaToniY","text_ar":"قَطْنِى"},{"kind":"italic_en","text":"My sufficiency;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HasobiY","text_ar":"حَسْبِى"},{"kind":"text","text":"; (Lth, S, * Mughnee;) like"},{"kind":"arabic","text_bw":"qadoniY","text_ar":"قَدْنِى"},{"kind":"text","text":"; introducing"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":", (Lth, S, TA,) as in"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"min~iY","text_ar":"مِنِّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ladun~iY","text_ar":"لَدُنِّى"},{"kind":"text","text":", contr. to rule, for the reason which has been explained in treating of"},{"kind":"arabic","text_bw":"qado","text_ar":"قَدْ"},{"kind":"text","text":", (S, TA,) to preserve the original quiescence of the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"; (Mughnee;) and"},{"kind":"arabic","text_bw":"qaTiY","text_ar":"قَطِى"},{"kind":"text","text":"; (S, Msb, Mughnee;) and ↓"},{"kind":"arabic","text_bw":"qaTi","text_ar":"قَطِ","orth_type":"arrow"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"qaTaATi","text_ar":"قَطَاطِ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) like"},{"kind":"arabic","text_bw":"qaTaAmi","text_ar":"قَطَامِ"},{"kind":"text","text":", (S, K,) indecl.; (M;) as signifying"},{"kind":"arabic","text_bw":"HasobiY","text_ar":"حَسْبِى"},{"kind":"text","text":": (S, M, Msb, Mughnee, K:) and, as is said in the Moo'ab,"},{"kind":"arabic","text_bw":"qaTo Eabodi All~`hi dirohamN","text_ar":"قَطْ عَبْدِ اللّٰهِ دِرْهَمٌ"},{"kind":"italic_en","text":"The sufficiency of 'Abd-Allah is a dirhem;"},{"kind":"text","text":"[and the like is said by Lth and in the Mughnee;] pausing upon the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":", and making"},{"kind":"arabic","text_bw":"qT","text_ar":"قط"},{"kind":"text","text":"to govern a gen. case [as it does virtually in the preceding instances]; and the Basrees say, that this is the right mode, as meaning the like of"},{"kind":"arabic","text_bw":"Hasobu zayodK","text_ar":"حَسْبُ زَيْدٍ"},{"kind":"arabic","text_bw":"dirohamN","text_ar":"دِرْهَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kafoYa zayodK dirohamN","text_ar":"كَفْىَ زَيْدٍ دِرْهَمٌ"},{"kind":"text","text":": (K:) or some say"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":", with jezm; and some say ↓"},{"kind":"arabic","text_bw":"qaTu","text_ar":"قَطُ","orth_type":"arrow"},{"kind":"text","text":", making it inded. with damm for its termination; each governing what follows it in the gen. case. (M.) ―         -b2-  It is also a verbal noun, signifying"},{"kind":"arabic","text_bw":"yakofiY","text_ar":"يَكْفِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It suffices,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will suffice;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will be, sufficient"},{"kind":"text","text":"]; and when this is the case, you say,"},{"kind":"arabic","text_bw":"qaToniY","text_ar":"قَطْنِى"},{"kind":"text","text":", (Mughnee, K,) like as you say,"},{"kind":"arabic","text_bw":"yakofiyniY","text_ar":"يَكْفِينِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It suffices me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will suffice me"},{"kind":"text","text":"]; (Mughnee;) or"},{"kind":"arabic","text_bw":"kafaAniY","text_ar":"كَفَانِى"},{"kind":"text","text":"[which means, emphatically,"},{"kind":"italic_en","text":"it suffices me"},{"kind":"text","text":"], accord. to the Koofees; (Lth;) which is also allowable when"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":"is equivalent to"},{"kind":"arabic","text_bw":"Hasobu","text_ar":"حَسْبُ"},{"kind":"text","text":"[as we have observed above]: (Mughnee:) and you say also,"},{"kind":"arabic","text_bw":"qaToka","text_ar":"قَطْكَ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"kafaAka","text_ar":"كَفَاكَ"},{"kind":"text","text":"[emphatically"},{"kind":"italic_en","text":"It suffices thee"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"qaTiY","text_ar":"قَطِى"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"kafaAniY","text_ar":"كَفَانِى"},{"kind":"text","text":"[emphatically"},{"kind":"italic_en","text":"It suffices me"},{"kind":"text","text":"]: (K:) so in the copies of the K; [in the CK, erroneously,"},{"kind":"arabic","text_bw":"qaT~aniY","text_ar":"قَطَّنِى"},{"kind":"text","text":";] but [it seems that it should be"},{"kind":"arabic","text_bw":"qaToniY","text_ar":"قَطْنِى"},{"kind":"text","text":"; for] it is said in the Mughnee and its Expositions, that in this last case the addition of the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"is indispensable: (MF:) and some say,"},{"kind":"arabic","text_bw":"qaTo Eaboda All~`hi dirohamN","text_ar":"قَطْ عَبْدَ اللّٰهِ دِرْهَمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A dirhem suffices,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will suffice, 'Abd-Allah"},{"kind":"text","text":"(in the CK, erroneously,"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":")]; making it to govern the accus. case [as it does virtually in preceding instances]: and some add"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":", saying,"},{"kind":"arabic","text_bw":"Eaboda All~`hi dirohamN","text_ar":"عَبْدَ اللّٰهِ دِرْهَمٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qaTonu","text_ar":"قَطْنُ","orth_type":"arrow"},{"kind":"text","text":"[meaning the same]: (Lth, K:) [hence,] some say, that ["},{"kind":"arabic","text_bw":"qaTon","text_ar":"قَطْن"},{"kind":"text","text":"in]"},{"kind":"arabic","text_bw":"qaToniY","text_ar":"قَطْنِى"},{"kind":"text","text":"is a word originally thus formed without any augmentation, like ["},{"kind":"arabic","text_bw":"Hasob","text_ar":"حَسْب"},{"kind":"text","text":"in]"},{"kind":"arabic","text_bw":"HasobiY","text_ar":"حَسْبِى"},{"kind":"text","text":"; (M;) [but J says,] if the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"qaToniY","text_ar":"قَطْنِى"},{"kind":"text","text":"belonged to the root of the word, they had said"},{"kind":"arabic","text_bw":"qaTonuka","text_ar":"قَطْنُكَ"},{"kind":"text","text":", which is not known. (S.) ―         -b3-  It is also syn. with"},{"kind":"arabic","text_bw":"Hasobu","text_ar":"حَسْبُ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"maA raA^ayotuhu A_il~aA mar~apF waAHidapF faqaTN","text_ar":"مَا رَاَيْتُهُ اـِلَّا مَرَّةً وَاحِدَةً فَقَطٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have not seen him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, save once, and that was a thing sufficient"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that was enough"},{"kind":"text","text":"]: (S, Msb: *) or, as is said in the Mutowwel,"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"faqaTo","text_ar":"فَقَطْ"},{"kind":"text","text":"is a verbal noun, meaning"},{"kind":"italic_en","text":"abstain thou"},{"kind":"text","text":"[from further questioning, or the like], as though it were the complement of a condition suppressed [such as “ the case being so ”]: or, as is said in the Mesáïl of Ibn-Es-Seed, the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"is properly prefixed because the meaning is"},{"kind":"italic_en","text":"and I was satisfied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"content,"},{"kind":"text","text":"therewith; so that the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"is a conjunction: (from a marginal note in a copy of the Mughnee:) [it therefore virtually signifies"},{"kind":"italic_en","text":"and no more;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"only;"},{"kind":"text","text":"and thus it may often be rendered: and this explains what here follows:] when"},{"kind":"arabic","text_bw":"qaT","text_ar":"قَط"},{"kind":"text","text":"is used to denote paucity, (M, K,) which is said by El-Hareeree, in the Durrah, to be only in negative phrases, (MF,) it is [written"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":",] with jezm, (M, K,) and without teshdeed: (M:) you say,"},{"kind":"arabic","text_bw":"maA Einodaka A_il~aA h`*aA qaTo","text_ar":"مَا عِنْدَكَ اـِلَّا هٰذَا قَطْ"},{"kind":"text","text":"[which may be rendered"},{"kind":"italic_en","text":"Thou hast not save this only"},{"kind":"text","text":"]: but when it is followed by a conjunctive"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", it is with kesr; [as in the saying,]"},{"kind":"arabic","text_bw":"maA Ealimotu A_il~aA h`*aA qaTi Alyawoma","text_ar":"مَا عَلِمْتُ اـِلَّا هٰذَا قَطِ اليَوْمَ"},{"kind":"text","text":"[virtually mean-"},{"kind":"page_break","n":2540},{"kind":"text","text":"ing"},{"kind":"italic_en","text":"I knew not,"},{"kind":"text","text":"or, emphatically,"},{"kind":"italic_en","text":"know not, save this only, to-day"},{"kind":"text","text":"]: (K:) and also, (K,) when thus using it, (M,) you say,"},{"kind":"arabic","text_bw":"maA lahu A_il~aA Ea$arapN qaTo","text_ar":"مَا لَهُ اـِلَّا عَشَرَةٌ قَطْ"},{"kind":"arabic","text_bw":"yaAfataY","text_ar":"يَافَتَى"},{"kind":"text","text":"[likewise virtually meaning"},{"kind":"italic_en","text":"He has not save ten only, O young man"},{"kind":"text","text":"], without teshdeed, and with jezm; and ↓"},{"kind":"arabic","text_bw":"qaT~i","text_ar":"قَطِّ","orth_type":"arrow"},{"kind":"text","text":", with teshdeed and khafd; (Lh, M, K;) the kesreh of the latter, in a case of this kind, being to distinguish the"},{"kind":"arabic","text_bw":"qaT~","text_ar":"قَطّ"},{"kind":"text","text":"which denotes [paucity of] number from"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":", which denotes time. (Lth.)       -A2-  See also"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":", first sentence."}],"source_refs":["S","Sb","M","Msb","K","Lth","TA","MF"]},{"entry_id":"n35845","headword_ar":"قُطْ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35846","headword_ar":"قَطُ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35847","headword_ar":"قَطِ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35848","headword_ar":"قُطُ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35849","headword_ar":"قَطٍ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35850","headword_ar":"قَطَّ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35851","headword_ar":"قَطُّ","root":"qT","body":[{"kind":"text","text":"is an adv. noun, (Mughnee,) [generally] denoting time, (S, M, Mughnee,) or past time, (Msb, K,) used to include all past time; (Lth, Mughnee;) as also ↓"},{"kind":"arabic","text_bw":"quT~u","text_ar":"قُطُّ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Mughnee, K,) the former vowel being assimilated to the latter; (S, Mughnee;) and ↓"},{"kind":"arabic","text_bw":"qaTu","text_ar":"قَطُ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Mughnee, K,) and ↓"},{"kind":"arabic","text_bw":"quTu","text_ar":"قُطُ","orth_type":"arrow"},{"kind":"text","text":"; (S, Mughnee, * K;) and some say ↓"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ","orth_type":"arrow"},{"kind":"text","text":", (S, Mughnee,) whence"},{"kind":"arabic","text_bw":"qaTu","text_ar":"قَطُ"},{"kind":"text","text":"is formed, by making its termination similar to that of the primary form"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":", to show its origin; (S, M;) or this would be better than"},{"kind":"arabic","text_bw":"qaTu","text_ar":"قَطُ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"quTo","text_ar":"قُطْ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Mughnee, *) like"},{"kind":"arabic","text_bw":"mu*o","text_ar":"مُذْ"},{"kind":"text","text":", which is rare: (S, M:) of all these, the first is the most chaste: (Mughnee:) when time is meant by it, it is always with refa, without tenween: (K:) or one says also ↓"},{"kind":"arabic","text_bw":"qaT~i","text_ar":"قَطِّ","orth_type":"arrow"},{"kind":"text","text":", (M, Mughnee, K,) with kesr and teshdeed to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":", (M, K,) accord. to IAar; (M;) and ↓"},{"kind":"arabic","text_bw":"qaT~a","text_ar":"قَطَّ","orth_type":"arrow"},{"kind":"text","text":", with fet-h and teshdeed to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"; (M, * K;) as well as with damm to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"without teshdeed. (K [in some copies of which is here added, “ and with refa to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":"; ” to which is further added in the CK, “ without teshdeed: ” but I find two copies without any addition of this redundant kind: for by “ refa ” is here meant, as in a former instance, “ damm; ” though improperly, as the word is indecl.]) You say,"},{"kind":"arabic","text_bw":"maA raA^ayotuhu qaT~u","text_ar":"مَا رَاَيْتُهُ قَطُّ"},{"kind":"text","text":"&c. ["},{"kind":"italic_en","text":"I have not seen him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, ever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hitherto"},{"kind":"text","text":"]; (S, M, K;) and"},{"kind":"arabic","text_bw":"maA faEalotuhu qaT~a","text_ar":"مَا فَعَلْتُهُ قَطَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have not done it ever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hitherto"},{"kind":"text","text":"]; (Msb, Mughnee;) i. e.,"},{"kind":"italic_en","text":"in the time that is past;"},{"kind":"text","text":"(Msb, K;) or"},{"kind":"italic_en","text":"in what has been cut off of my life;"},{"kind":"text","text":"(Mughnee, K;) its derivation being from"},{"kind":"arabic","text_bw":"qaTaTotu","text_ar":"قَطَطْتُ"},{"kind":"text","text":"meaning “ I cut; ” for the past is cut off from the present and the future; and it is indecl. because it implies the meaning of"},{"kind":"arabic","text_bw":"mu*o","text_ar":"مُذْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"; its meaning being"},{"kind":"arabic","text_bw":"mu*o A^ano xuliqotu A_ilaY AlA=na","text_ar":"مُذْ اَنْ خُلِقْتُ اـِلَى الا=نَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"since my being created until now"},{"kind":"text","text":"]; and with a vowel for its termination to prevent the occurrence of two quiescent letters together; (Mughnee;) and it is with refa [meaning damm for its termination] because it is like"},{"kind":"arabic","text_bw":"qabolu","text_ar":"قَبْلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEodu","text_ar":"بَعْدُ"},{"kind":"text","text":": (Lth:) accord. to Ks, (S,)"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"is a contraction of"},{"kind":"arabic","text_bw":"qaTaTu","text_ar":"قَطَطُ"},{"kind":"text","text":": (S, M:) Sb says, that it denotes"},{"kind":"arabic","text_bw":"AlA_inotihaA='","text_ar":"الاـِنْتِهَا=ء"},{"kind":"text","text":"; [app. meaning that it signifies"},{"kind":"italic_en","text":"abstain thou"},{"kind":"text","text":"from further questioning, or the like; for El-Hareeree says, in the Durrah, that"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":"both signify the same as"},{"kind":"arabic","text_bw":"Hasobu","text_ar":"حَسْبُ"},{"kind":"text","text":";] and that it is indecl., with damm for its termination, like"},{"kind":"arabic","text_bw":"Hasobu","text_ar":"حَسْبُ"},{"kind":"text","text":". (M.) You say also,"},{"kind":"arabic","text_bw":"maA faEalotu","text_ar":"مَا فَعَلْتُ"},{"kind":"arabic","text_bw":"h`*aA qaTo walaA qaT~u","text_ar":"هٰذَا قَطْ وَلَا قَطُّ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"I have not done this alone, nor ever"},{"kind":"text","text":"]: (K, TA: [in the CK"},{"kind":"arabic","text_bw":"qaT~u wlA quTu","text_ar":"قَطُّ ولا قُطُ"},{"kind":"text","text":", but]) the former"},{"kind":"arabic","text_bw":"qT","text_ar":"قط"},{"kind":"text","text":"is with jezm to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":", and the latter is with teshdeed and damm to the"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"yaA fataY","text_ar":"يَا فَتَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA zaAla EalaY h`*aA mu*o quT~a","text_ar":"مَا زَالَ عَلَى هٰذَا مُذْ قُطَّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, has not ceased to be after this manner during all past time, O young man"},{"kind":"text","text":"]; with damm to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", and with teshdeed. (Lh, M.) It is used only in negative phrases relating to past time; the saying of the vulgar"},{"kind":"arabic","text_bw":"laA A^afoEaluhu qaT~u","text_ar":"لَا اَفْعَلُهُ قَطُّ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"I will not do it ever"},{"kind":"text","text":"] being incorrect; (Mughnee, K; [in the CK"},{"kind":"arabic","text_bw":"qaTu","text_ar":"قَطُ"},{"kind":"text","text":"]) for with respect to the future you say"},{"kind":"arabic","text_bw":"EawoDu","text_ar":"عَوْضُ"},{"kind":"text","text":"(TA) [or"},{"kind":"arabic","text_bw":"A^abadFA","text_ar":"اَبَدًا"},{"kind":"text","text":"]: or it is mostly so used, accord. to Ibn-Málik: (MF:) but it occurs after an affirmative phrase in places in El-Bukháree, (K,) in his Saheeh; (TA;) for ex.,"},{"kind":"arabic","text_bw":"A^aTowalu SalaApK Sal~ayotuhaA qaT~u","text_ar":"اَطْوَلُ صَلَاةٍ صَلَّيْتُهَا قَطُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The longest prayer which I have prayed ever"},{"kind":"text","text":"]: and in the Sunan of Aboo-Dawood;"},{"kind":"arabic","text_bw":"tawaD~aA^a valaAvFA qaT~u","text_ar":"تَوَضَّاَ ثَلَاثًا قَطُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He performed the"},{"kind":"arabic","text_bw":"wuDuwo'","text_ar":"وُضُوْء"},{"kind":"italic_en","text":"three times ever"},{"kind":"text","text":"]: and Ibn-Málik asserts it to be right, and says that it is one of the things which have been unperceived by many of the grammarians: (K:) El-Karmánee, however, interprets these instances as though they were negative. (TA.)"}],"source_refs":["Msb","K","S","M","Lth","TA","MF"]},{"entry_id":"n35852","headword_ar":"قَطِّ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaTo","text_ar":"قَطْ"},{"kind":"text","text":", near the end of the paragraph:       -A2-  and see also"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":", in the first sentence."}],"source_refs":[]},{"entry_id":"n35853","headword_ar":"قُطُّ","root":"qT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaT~u","text_ar":"قَطُّ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n35855","headword_ar":"قِطٌّ","root":"qT","body":[{"kind":"italic_en","text":"A slice cut off"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$aqiyqapN","text_ar":"شَقِيقَةٌ"},{"kind":"text","text":"), of a melon or other thing. (A, TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"A portion, share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lot,"},{"kind":"text","text":"(M, A, Msb, K,) of gifts, (A, TA,) &c. (TA.) Hence the saying in the Kur, [xxxviii. 15,]"},{"kind":"arabic","text_bw":"rab~anaA Eaj~ilo lanaA qiT~anaA qabola yawomi AlHisaAbi","text_ar":"رَبَّنَا عَجِّلْ لَنَا قِطَّنَا قَبْلَ يَوْمِ الحِسَابِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"O our Lord, hasten to us our portion before the day of reckoning"},{"kind":"text","text":"]: accord. to some,"},{"kind":"italic_en","text":"our portion of punishment:"},{"kind":"text","text":"but accord. to Sa'eed Ibn-Jubeyr, it means,"},{"kind":"italic_en","text":"of Paradise."},{"kind":"text","text":"(TA.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"A writing;"},{"kind":"text","text":"(Fr, S, Msb;) [such as that of a man's works;] and hence, accord. to Fr, the words of the Kur cited above; those words being said in derision: (TA:) or"},{"kind":"italic_en","text":"a writing of reckoning:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"a written obligation:"},{"kind":"text","text":"(M:) or it signifies also"},{"kind":"italic_en","text":"a written obligation binding one to give a gift"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"present;"},{"kind":"text","text":"(S, K, TA;) and hence the saying in the Kur cited above: (S:) pl."},{"kind":"arabic","text_bw":"quTuwTN","text_ar":"قُطُوطٌ"},{"kind":"text","text":": (S, M, Msb, K:) which Az explains as meaning"},{"kind":"italic_en","text":"gifts,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"stipends;"},{"kind":"text","text":"so called because they were issued written in the form of notes and statements of obligation upon cut pieces of paper or the like. (TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a portion,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEap","text_ar":"سَاعَة"},{"kind":"text","text":",) of the night. (M, K.) You say"},{"kind":"arabic","text_bw":"maDaY qiT~N mina All~ayoli","text_ar":"مَضَى قِطٌّ مِنَ اللَّيْلِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a portion, of the night passed"},{"kind":"text","text":"]. (Th, M.)       -A2-"},{"kind":"italic_en","text":"A male cat:"},{"kind":"text","text":"(S, M, Msb, K:) the female is called"},{"kind":"arabic","text_bw":"qiT~apN","text_ar":"قِطَّةٌ"},{"kind":"text","text":": (Lth, S, M, Msb:) Kr disallowed this latter; and IDrd says, I do not think it to be genuine Arabic; (M;) but to this it is objected that it occurs in traditions: (MF:) the pl. is"},{"kind":"arabic","text_bw":"qiTaATN","text_ar":"قِطَاطٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"qiTaTapN","text_ar":"قِطَطَةٌ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"qiTaTN","text_ar":"قِطَطٌ"},{"kind":"text","text":". (Msb.)"}],"source_refs":["M","A","Msb","K","TA","S","Lth","MF"]}]},"classical_definitions":null}