 twisting termed"}, {"kind": "arabic", "text_bw": "jaraEN", "text_ar": "جَرَعٌ"}, {"kind": "italic_en", "text": "in one of its"}, {"kind": "page_break", "n": 411}, {"kind": "italic_en", "text": "strands;"}, {"kind": "text", "text": "as also ↓"}, {"kind": "arabic", "text_bw": "mujar~aEN", "text_ar": "مُجَرَّعٌ", "orth_type": "arrow"}, {"kind": "text", "text": ": (K:) or, accord. to IAar, a bow-string that is"}, {"kind": "italic_en", "text": "even, except that there is a prominence in one part of it, wherefore it is rubbed and pulled with a piece of a"}, {"kind": "arabic", "text_bw": "kisaA='", "text_ar": "كِسَا=ء"}, {"kind": "text", "text": "[q. v.]"}, {"kind": "italic_en", "text": "until that prominence disappears:"}, {"kind": "text", "text": "and ↓ the latter, accord. to ISh, a bow-string"}, {"kind": "italic_en", "text": "not uniformly nor well twisted, having in it prominences, so that one of its strands appears above the others,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "some appear above others."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["K", "TA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}