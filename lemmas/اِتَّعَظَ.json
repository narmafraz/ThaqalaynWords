m/?s=%D8%A7%D9%90%D8%AA%D9%8E%D9%91%D8%B9%D9%8E%D8%B8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to learn a lesson, take a warning, take heed, or be admonished"}]},"etymology":null,"ipa":["/it.ta.ʕa.ðˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42135","headword_ar":"اـِتَّعَظَ","root":"wEZ","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He became exhorted, admonished, warned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in fear:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he obeyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conformed to,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"an exhortation to obedience,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"a command, and restrained himself:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"he accepted good advice,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the being reminded of the results of affairs:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"he became reminded of that which should soften his heart, by the mention of reward and punishment."},{"kind":"text","text":"(K.) It is said,"},{"kind":"arabic","text_bw":"Als~aEiydu mano wuEiZa yigayorihi waAl$~aqiY~u mano A@t~aEaZa bihi","text_ar":"السَّعِيدُ مَنْ وُعِظَ يِغَيْرِهِ وَالشَّقِىُّ مَنْ ا@تَّعَظَ بِهِ"},{"kind":"arabic","text_bw":"gayoruhu","text_ar":"غَيْرُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The happy is he who is exhorted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admonished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warned, by"},{"kind":"text","text":"the example of"},{"kind":"italic_en","text":"another, and the unhappy is he by"},{"kind":"text","text":"the example of"},{"kind":"italic_en","text":"whom another becomes exhorted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admonished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warned"},{"kind":"text","text":"]. (S, L.)"}],"source_refs":["Msb","S"]}]},"classical_definitions":null}