{"lemma":"صافِيَةٌ","slug":"صافِيَةٌ","root":"ص.ف.#","root_slug":"ص-ف-_","root_link":"/words/roots/ص-ف-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n24551"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D8%A7%D9%81%D9%90%D9%8A%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24551","headword_ar":"صَافِيَةٌ","root":"Sfw","body":[{"kind":"text","text":"[fem. of"},{"kind":"arabic","text_bw":"SaAfK","text_ar":"صَافٍ"},{"kind":"text","text":", q. v. ―         -b2-  And also, as a subst.,] (tropical:)"},{"kind":"italic_en","text":"One of what are termed"},{"kind":"arabic","text_bw":"SawaAfiY AlA_imaAmi","text_ar":"صَوَافِى الاـِمَامِ"},{"kind":"text","text":", which means"},{"kind":"italic_en","text":"the towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages, of those who have rebelled against him, which the Imám"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Khaleefeh"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"chooses for himself"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as his peculiar property"},{"kind":"text","text":"]: (A, TA:) or, as in the T,"},{"kind":"arabic","text_bw":"AlS~awaAfiY","text_ar":"الصَّوَافِى"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"what the Sultán appropriates exclusively to those persons whom he specially favours:"},{"kind":"text","text":"or, as some say, it means"},{"kind":"italic_en","text":"the possessions and lands which their owners have abandoned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of which the owners have died leaving no heirs thereof."},{"kind":"text","text":"(TA.)"}],"source_refs":["A","TA"]}]},"classical_definitions":null}