"in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْتَنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْتَنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْتَنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْتَنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْتَنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْتَنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْتَنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْتَنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْتَنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْتَنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْتَنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"اِسْتَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِسْتَنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَسْتَنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْتَنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n20843"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20843","headword_ar":"استنّ","root":"sn","body":[{"kind":"italic_en","text":"He rubbed and cleaned his teeth with the"},{"kind":"arabic","text_bw":"siwaAk","text_ar":"سِوَاك"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"piece of stick used for that purpose"},{"kind":"text","text":"];"},{"kind":"page_break","n":1437},{"kind":"text","text":"(S, M, L, K;)"},{"kind":"italic_en","text":"he made use of the"},{"kind":"arabic","text_bw":"siwaAk","text_ar":"سِوَاك"},{"kind":"text","text":","},{"kind":"italic_en","text":"passing it over his teeth."},{"kind":"text","text":"(L.) ―         -b2-  And"},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seized, with the teeth."},{"kind":"text","text":"(KL.)       -A2-"},{"kind":"arabic","text_bw":"Astn~t AlEayonu","text_ar":"استنّت العَيْنُ"},{"kind":"italic_en","text":"The eye poured forth its tears."},{"kind":"text","text":"(M, L.) ―         -b2-"},{"kind":"arabic","text_bw":"Astn~","text_ar":"استنّ"},{"kind":"text","text":"said of the blood of a wound made with a spear or the like,"},{"kind":"italic_en","text":"It issued in a gush."},{"kind":"text","text":"(AZ, L.) ―         -b3-  Said of the"},{"kind":"arabic","text_bw":"saraAb","text_ar":"سَرَاب"},{"kind":"text","text":"[or mirage],"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of commotion, went to and fro,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quivered."},{"kind":"text","text":"(M, L, K.) ―         -b4-  Said of a horse,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qamaSa","text_ar":"قَمَصَ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"He pranced, leaped, sprang,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounded"},{"kind":"text","text":"]: (S, K:)"},{"kind":"italic_en","text":"he frisked;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was brisk, lively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly: he ran, in his friskiness, briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness, in one direction: he ran, by reason of his friskiness, briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness, a heat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two heats, without a rider upon him:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he ran to and fro, by reason of briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"san~a","text_ar":"سَنَّ"},{"kind":"text","text":"as signifying “ he poured forth ” water, and as signifying “ he sharpened ” iron upon a whetstone. (Har p. 47.) It is said in a prov.,"},{"kind":"arabic","text_bw":"Aisotan~ati AlfiSaAlu Hat~aY AlqaroEaY","text_ar":"اِسْتَنَّتِ الفِصَالُ حَتَّى القَرْعَى"},{"kind":"text","text":", (S, Meyd, L,) or"},{"kind":"arabic","text_bw":"AlfuSolaAnu","text_ar":"الفُصْلَانُ"},{"kind":"text","text":", (Meyd,) i. e."},{"kind":"italic_en","text":"The young weaned camels leaped, sprang,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounded;"},{"kind":"text","text":"(S * L;)"},{"kind":"italic_en","text":"even those affected with the small pustules called"},{"kind":"arabic","text_bw":"qaraE","text_ar":"قَرَع"},{"kind":"text","text":"; (Meyd, L;) which are small white pustules, the remedy for which is salt, and the butter ("},{"kind":"arabic","text_bw":"jubaAb","text_ar":"جُبَاب"},{"kind":"text","text":") of camels' milk: (Meyd:) when the healthy young weaned camels do thus, those affected with such pustules do the like in imitation, but become disabled from doing it by weakness: the prov. is applied to the man who introduces himself among a people, or party, to whom he does not belong: (L:) or to him who speaks with one before whom he should not speak by reason of the greatness of his rank: and some related it differently, saying,"},{"kind":"arabic","text_bw":"AlqurayoEaY","text_ar":"القُرَيْعَى"},{"kind":"text","text":"[which is the dim. of"},{"kind":"arabic","text_bw":"AlqaroEaY","text_ar":"القَرْعَى"},{"kind":"text","text":"]; (Meyd;) and"},{"kind":"arabic","text_bw":"AlquroEu","text_ar":"القُرْعُ"},{"kind":"text","text":"[which is pl. of"},{"kind":"arabic","text_bw":"AlA^aqoraEu","text_ar":"الاَقْرَعُ"},{"kind":"text","text":", q. v.]: and some say that"},{"kind":"arabic","text_bw":"Astn~t AlfiSaAlu","text_ar":"استنّت الفِصَالُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the young weaned camels became fat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plump, and their skins became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sleek"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like"},{"kind":"arabic","text_bw":"masaAn~","text_ar":"مَسَانّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"whetstones"},{"kind":"text","text":"]. (L.) And it is said in a trad. of 'Omar,"},{"kind":"arabic","text_bw":"raA^ayotu","text_ar":"رَاَيْتُ"},{"kind":"arabic","text_bw":"A^abaAhu yasotan~u bisayofihi kamaA yasotan~u Aljamalu","text_ar":"اَبَاهُ يَسْتَنُّ بِسَيْفِهِ كَمَا يَسْتَنُّ الجَمَلُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I saw his father"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"exulting with briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness, and brandishing his sword,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"like as the camel exults with briskness, and lashes with his tail."},{"kind":"text","text":"] (L.) See also 5. ―         -b5-  [Also"},{"kind":"italic_en","text":"He took, held,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"followed, the"},{"kind":"arabic","text_bw":"sanan","text_ar":"سَنَن"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"main and middle part thereof:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lay, in the way."},{"kind":"text","text":"Hence,] one says,"},{"kind":"arabic","text_bw":"xu*o maA A@sotan~a","text_ar":"خُذْ مَا ا@سْتَنَّ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Take thou what lies in the way;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what is easily attainable; what offers itself without difficulty."},{"kind":"text","text":"(AA, TA voce"},{"kind":"arabic","text_bw":"Ainotadaba","text_ar":"اِنْتَدَبَ"},{"kind":"text","text":".) ―         -b6-  See also 1, near the end of the paragragh, in two places."}],"source_refs":["S","K","L","Meyd"]}]},"classical_definitions":null}