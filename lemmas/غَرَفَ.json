num":"p"},{"role":"present_2mp","form":"تَغْرِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَغْرِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَغْرِف","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَغْرِف","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَغْرِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَغْرِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَغْرِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَغْرِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَغْرِفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَغْرِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَغْرِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"غَرَفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غَرَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَغْرِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَغْرِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n31697","n31698"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B1%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lade out, to scoop"},{"pos":"noun","gloss":"verbal noun of غَرَفَ (ḡarafa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of غُرْفَة (ḡurfa)","tags":["form-of","plural"]}]},"etymology":null,"ipa":["/ɣu.raf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31697","headword_ar":"غَرْفٌ","root":"grf","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"garafN","text_ar":"غَرَفٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) the latter mentioned by Yaakoob, (S,)"},{"kind":"italic_en","text":"A species of trees,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$ajarN","text_ar":"شَجَرٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"with which one tans;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"when dry,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"said to be"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what are termed"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":": (TA: [but perhaps this statement applies particularly to"},{"kind":"arabic","text_bw":"garafN","text_ar":"غَرَفٌ"},{"kind":"text","text":", which see below: and see also"},{"kind":"arabic","text_bw":"vumaAmN","text_ar":"ثُمَامٌ"},{"kind":"text","text":":]) accord. to A'Obeyd, called"},{"kind":"arabic","text_bw":"garofN","text_ar":"غَرْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"galofN","text_ar":"غَلْفٌ"},{"kind":"text","text":"[q. v.]: AHn says, the"},{"kind":"arabic","text_bw":"grf","text_ar":"غرف"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"a species of trees from which bows are made;"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"EiDaAhN","text_ar":"عِضَاهٌ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"and no one tans with it;"},{"kind":"text","text":"but Kz says that"},{"kind":"italic_en","text":"its leaves may be used for tanning therewith, though bows be made of its branches:"},{"kind":"text","text":"and Aboo-Mohammad mentions, on the authority of As, that"},{"kind":"italic_en","text":"one tans with the leaves of the"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"garaf","text_ar":"غَرَف","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"and not with its branches:"},{"kind":"text","text":"El-Báhilee says that"},{"kind":"arabic","text_bw":"garofN","text_ar":"غَرْفٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"certain skins, not such as are termed"},{"kind":"arabic","text_bw":"qaraZiy~ap","text_ar":"قَرَظِيَّة"},{"kind":"text","text":", [i. e."},{"kind":"italic_en","text":"not tanned with"},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":","},{"kind":"italic_en","text":"but"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"tanned, in Hejer, in the following manner: one takes for them sprigs"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"hadab","text_ar":"هَدَب"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"A^aroTaY","text_ar":"اَرْطَى"},{"kind":"text","text":","},{"kind":"italic_en","text":"and puts them in a mortar, and pounds them, then throws upon them dates, whereupon there comes forth from them an altered odour, after which a certain quantity is laded out for each skin, which is then tanned therewith; and the term"},{"kind":"arabic","text_bw":"garof","text_ar":"غَرْف"},{"kind":"italic_en","text":"is applied to that which is laded out, and to every quantity of skin from that mash, to one and to all alike:"},{"kind":"text","text":"but Az says,"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"garof","text_ar":"غَرْف"},{"kind":"italic_en","text":"with which skins are tanned is well known, of the trees of the desert"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlbaAdiyap","text_ar":"البَادِيَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and,"},{"kind":"text","text":"he says,"},{"kind":"italic_en","text":"I have seen it;"},{"kind":"text","text":"and what I hold is this, that"},{"kind":"italic_en","text":"the skins termed"},{"kind":"arabic","text_bw":"garofiy~ap","text_ar":"غَرْفِيَّة"},{"kind":"italic_en","text":"are thus termed in relation to the species of trees called the"},{"kind":"arabic","text_bw":"garof","text_ar":"غَرْف"},{"kind":"text","text":","},{"kind":"italic_en","text":"not to what is laded out:"},{"kind":"text","text":"As says that"},{"kind":"arabic","text_bw":"Algarofu","text_ar":"الغَرْفُ"},{"kind":"text","text":", with the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"quiescent, signifies"},{"kind":"italic_en","text":"certain skins that are brought from El-Bahreyn."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K"]},{"entry_id":"n31698","headword_ar":"غَرَفٌ","root":"grf","body":[{"kind":"text","text":", (O, K, TA,) accord. to AA, (O,) or IAar, (T, TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"vumaAmN","text_ar":"ثُمَامٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Panic grass"},{"kind":"text","text":"]; (O, K, TA;)"},{"kind":"italic_en","text":"not used for tanning therewith;"},{"kind":"text","text":"and accord. to Az, this that IAar says is correct: AHn says that"},{"kind":"italic_en","text":"when it becomes dry, and one chews it, its odour is likened to that of camphor:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"italic_en","text":"while green:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"one of the species of"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":","},{"kind":"italic_en","text":"which resembles rushes"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^asal","text_ar":"اَسَل"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of which brooms are made, and with which water-bags of leather are covered to protect them from the sun so that the water becomes cool:"},{"kind":"text","text":"(A 'Obeyd, TA:) the n. un. is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (AHn, O.) And, (O, K,) accord. to Skr, (O,) The"},{"kind":"arabic","text_bw":"$av~","text_ar":"شَثّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Tub~aAq","text_ar":"طُبَّاق"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"na$am","text_ar":"نَشَم"},{"kind":"text","text":"[thus (correctly) in the O, but in the K"},{"kind":"arabic","text_bw":"ba$am","text_ar":"بَشَم"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"EafaAr","text_ar":"عَفَار"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"gafAr","text_ar":"غَفار"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Eutom","text_ar":"عُتْم"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Sawom","text_ar":"صَوْم"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Habaj","text_ar":"حَبَج"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$adon","text_ar":"شَدْن"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Hay~ahal","text_ar":"حَيَّهَل"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"Hay~ahol","text_ar":"حَيَّهْل"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"hayo$ar","text_ar":"هَيْشَر"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Durom","text_ar":"ضُرْم"},{"kind":"text","text":"[thus in the O and in some copies of the K] or"},{"kind":"arabic","text_bw":"Dirom","text_ar":"ضِرْم"},{"kind":"text","text":"[thus in other copies of the K]: every one of these is called"},{"kind":"arabic","text_bw":"garaf","text_ar":"غَرَف"},{"kind":"text","text":". (O, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"garofN","text_ar":"غَرْفٌ"},{"kind":"text","text":", in two places. ―         -b3-  Also The"},{"kind":"italic_en","text":"leaves of trees"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"with which tanning is performed."},{"kind":"text","text":"(TA.)"}],"source_refs":["O","K","TA","T"]}]},"classical_definitions":null}