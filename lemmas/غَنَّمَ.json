r":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُغَنِّمُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُغَنِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُغَنِّم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُغَنِّم","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُغَنِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُغَنِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغَنِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَنِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغَنِّمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغَنِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغَنِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"غَنَّمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَنَّمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُغَنِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغَنِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":39,"cross_references":{"qac":{"found":true,"lemma_key":"غَنَّمَ","root":"غنم","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n32525","n32529","n32530"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%86%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make booty","tags":["intransitive"],"examples":[{"text":"إِنْ كَانَ أَحَدُنَا فِي زَمَنِ رَسُولِ اللّٰهِ صَلَّى اللّٰهُ عَلَيْهِ وَسَلَّمَ لَيَأْخُذُ نِضْوَ أَخِيهِ عَلَى أَنَّ لَهُ النِّصْفَ مِمَّا يَغْنَمُ وَلَنَا النِّصْفُ وَإِنْ كَانَ أَحَدُنَا لَيَطِيرُ لَهُ النَّصْلُ وَٱلرِّيشُ وَلِلْآخَرِ الْقَدَحُ.","english":"Any one of us would borrow an arrow-shaft during the lifetime of the Prophet (ﷺ) from the other, on condition that he would give him half the booty, and the other half he would retain himself. Further, one of us received, so it flies, an arrowhead and a feather, and the other the arrow-shaft."}]},{"pos":"verb","gloss":"to take as booty","tags":["transitive"]},{"pos":"verb","gloss":"to pillage, to foray, to plunder","tags":["transitive"]},{"pos":"verb","gloss":"to give away altruistically, to dole out, to deal out, to share out"},{"pos":"noun","gloss":"sheep","tags":["collective"],"examples":[{"text":"إنما يأكل الذئب من الغنم القاصية.","english":"The wolf eats up a solitary sheep that stays far from the flock."}]},{"pos":"noun","gloss":"small cattle","tags":["collective"]},{"pos":"noun","gloss":"verbal noun of غَنِمَ (ḡanima) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32525","headword_ar":"غَنِمَ","root":"gnm","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"gunomN","text_ar":"غُنْمٌ"},{"kind":"text","text":"(S, MA, Msb, * K, KL) and"},{"kind":"arabic","text_bw":"ganomN","text_ar":"غَنْمٌ"},{"kind":"text","text":", (K,) or, as some say, the former is a simple subst. and the latter is an inf. n., (TA,) and"},{"kind":"arabic","text_bw":"ganamN","text_ar":"غَنَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ganiymapN","text_ar":"غَنِيمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gunomaAnN","text_ar":"غُنْمَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they,"},{"kind":"text","text":"(i. e. a man, Msb, or a party of men, S,)"},{"kind":"italic_en","text":"obtained, got,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took,"},{"kind":"text","text":"(Msb, K, * TK,)"},{"kind":"italic_en","text":"spoil,"},{"kind":"text","text":"(K, * TK,) or a thing ["},{"kind":"italic_en","text":"as spoil"},{"kind":"text","text":"]. (Msb, TA.) [And"},{"kind":"italic_en","text":"He acquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained,"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"without difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconvenience:"},{"kind":"text","text":"or in this sense the inf. n. is"},{"kind":"arabic","text_bw":"gunomN","text_ar":"غُنْمٌ"},{"kind":"text","text":","},{"kind":"page_break","n":2301},{"kind":"text","text":"which see below, voce"},{"kind":"arabic","text_bw":"ganiymapN","text_ar":"غَنِيمَةٌ"},{"kind":"text","text":".]"},{"kind":"arabic","text_bw":"maA ganimotumo","text_ar":"مَا غَنِمْتُمْ"},{"kind":"text","text":"in the Kur viii. 42 means"},{"kind":"italic_en","text":"What ye take by force"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in war"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the unbelievers."},{"kind":"text","text":"(Bd, Jel.) [See also 8.]"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n32529","headword_ar":"غُنْمٌ","root":"gnm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ganiymapN","text_ar":"غَنِيمَةٌ"},{"kind":"text","text":", in three places. ―         -b2-  It signifies also [The"},{"kind":"italic_en","text":"regaining"},{"kind":"text","text":"(as is shown by an explanation of A 'Obeyd cited in the first paragraph of art."},{"kind":"arabic","text_bw":"glq","text_ar":"غلق"},{"kind":"text","text":"), and] the"},{"kind":"italic_en","text":"increase, and growth, and excess in value,"},{"kind":"text","text":"of a pledge. (O in art."},{"kind":"arabic","text_bw":"glq","text_ar":"غلق"},{"kind":"text","text":", and TA in the present art.) Thus in a trad., in which it is said,"},{"kind":"arabic","text_bw":"Alr~ahonu limano rahanahu lahu gunomuhu waEalayohi guromuhu","text_ar":"الرَّهْنُ لِمَنْ رَهَنَهُ لَهُ غُنْمُهُ وَعَلَيْهِ غُرْمُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The pledge pertains to him who pledged it; to him pertains the regaining of it, and its increase, and growth, and excess in value, if such there be, and upon him lies the obligation to pay the debt for it, without requiring any abatement thereof if the pledge have unavoidably suffered damage or total loss:"},{"kind":"text","text":"see the explanation of A 'Obeyd mentioned above]. (TA.)"},{"kind":"arabic","text_bw":"Algunomu biAlguromi","text_ar":"الغُنْمُ بِالغُرْمِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"gunom","text_ar":"غُنْم"},{"kind":"italic_en","text":"is compensated"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muqaAbalN","text_ar":"مُقَابَلٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by the"},{"kind":"arabic","text_bw":"gurom","text_ar":"غُرْم"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the regaining"},{"kind":"text","text":"of the pledge,"},{"kind":"italic_en","text":"with the increase and the growth and the excess in value"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"if such there be, is compensated by the payment of the debt"},{"kind":"text","text":"for it]; for like as the owner [of the pledge] is exclusively entitled to the"},{"kind":"arabic","text_bw":"gunom","text_ar":"غُنْم"},{"kind":"text","text":", no one sharing it with him, so he bears the"},{"kind":"arabic","text_bw":"gurom","text_ar":"غُرْم"},{"kind":"text","text":", no one bearing it with him: and this is the meaning of their saying,"},{"kind":"arabic","text_bw":"Alguromu","text_ar":"الغُرْمُ"},{"kind":"arabic","text_bw":"majobuwrN biAlgunomi","text_ar":"مَجْبُورٌ بِالغُنْمِ"},{"kind":"text","text":"[which may therefore be rendered"},{"kind":"italic_en","text":"The loss suffered by the payment of the debt is repaired by the regaining"},{"kind":"text","text":"of the pledge; app. a phrase of the lawyers, implying that such is to be considered as the case whatever be the state of the pledge at the time of its being restored unless it have suffered damage through the fault of the pledgee]. (Msb.) [See more in the first paragraph of art."},{"kind":"arabic","text_bw":"glq","text_ar":"غلق"},{"kind":"text","text":".] ―         -b3-  See also"},{"kind":"arabic","text_bw":"gunaAmaAka","text_ar":"غُنَامَاكَ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"gnm","text_ar":"غنم"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"gunomN","text_ar":"غُنْمٌ"},{"kind":"text","text":"] is mentioned by Suh as the name of"},{"kind":"italic_en","text":"A certain idol."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n32530","headword_ar":"غَنَمٌ","root":"gnm","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$aA='N","text_ar":"شَا=ءٌ"},{"kind":"text","text":", (T, Msb, K,) meaning"},{"kind":"italic_en","text":"Sheep"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"goats;"},{"kind":"text","text":"(Msb;) [and"},{"kind":"italic_en","text":"both together;"},{"kind":"text","text":"] a gen. n., (S, Msb, K,) of the fem. gender, (S, K,) applied to the"},{"kind":"italic_en","text":"males"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"females,"},{"kind":"text","text":"and to"},{"kind":"italic_en","text":"both together:"},{"kind":"text","text":"(S, Msb, K:) it has no sing. from which it is derived, the sing. being"},{"kind":"arabic","text_bw":"$Ap","text_ar":"شاة"},{"kind":"text","text":": the dual"},{"kind":"arabic","text_bw":"ganamaAni","text_ar":"غَنَمَانِ"},{"kind":"text","text":"is used as meaning"},{"kind":"italic_en","text":"two flocks"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herds"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of goats"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of both together"},{"kind":"text","text":"]; (Msb, K;) each flock or herd having its distinct place of pasture and its pastor: (Msb, TA: *) and hence it is said in a trad. that the poor-rate [meaning a portion thereof] is to be given to him to whom the year of drought has left a"},{"kind":"arabic","text_bw":"ganam","text_ar":"غَنَم"},{"kind":"text","text":", but not to him to whom it has left"},{"kind":"arabic","text_bw":"ganamayoni","text_ar":"غَنَمَيْنِ"},{"kind":"text","text":": (TA:) the pl. is"},{"kind":"arabic","text_bw":"A^agonaAmN","text_ar":"اَغْنَامٌ"},{"kind":"text","text":", (Msb, K,) [properly a pl. of pauc.,] sometimes used, (Msb,) meaning flocks or herds of"},{"kind":"arabic","text_bw":"ganam","text_ar":"غَنَم"},{"kind":"text","text":", (Msb and TA in art."},{"kind":"arabic","text_bw":"Abl","text_ar":"ابل"},{"kind":"text","text":",) and also"},{"kind":"arabic","text_bw":"gunuwmN","text_ar":"غُنُومٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^agaAnimu","text_ar":"اَغَانِمُ"},{"kind":"text","text":", (K,) the last used in an ode of Aboo-Jundab El-Hudhalee: (TA:) the dim. is ↓"},{"kind":"arabic","text_bw":"gunayomapN","text_ar":"غُنَيْمَةٌ","orth_type":"arrow"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", because quasi-pl. ns. of the class having no sing. from which they are derived, when applied to what are not human beings, are constantly fem.; so one says"},{"kind":"arabic","text_bw":"xamosN mina Alganami *ukuwrN","text_ar":"خَمْسٌ مِنَ الغَنَمِ ذُكُورٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"five of sheep, males"},{"kind":"text","text":"], making the n. of number fem., though one means"},{"kind":"italic_en","text":"rams,"},{"kind":"text","text":"when it is followed by"},{"kind":"arabic","text_bw":"mina Alganami","text_ar":"مِنَ الغَنَمِ"},{"kind":"text","text":", for the n. of number is masc. and fem. accord. to the word, not accord. to the meaning. (S.) ―         -b2-  In the saying"},{"kind":"arabic","text_bw":"laA A=tiyka ganama Alfizori","text_ar":"لَا ا=تِيكَ غَنَمَ الفِزْرِ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"Hat~aY tajotamiEa ganamu Alfizori","text_ar":"حَتَّى تَجْتَمِعَ غَنَمُ الفِزْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will not come to thee until the sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, of El-Fizr congregate"},{"kind":"text","text":"],"},{"kind":"arabic","text_bw":"gnm","text_ar":"غنم"},{"kind":"text","text":"[with its complement] is made to stand in the place of"},{"kind":"arabic","text_bw":"Ald~ahor","text_ar":"الدَّهْر"},{"kind":"text","text":", [the meaning being,"},{"kind":"italic_en","text":"I will not come to thee ever,"},{"kind":"text","text":"] and is [therefore] put in the accus. case as though it were an adv. n. [of time]. (TA. [This saying with"},{"kind":"arabic","text_bw":"miEozaY","text_ar":"مِعْزَى"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"ganama","text_ar":"غَنَمَ"},{"kind":"text","text":"is mentioned by El-Meydánee in his “ Proverbs, ” and thus in the S and K in art."},{"kind":"arabic","text_bw":"fzr","text_ar":"فزر"},{"kind":"text","text":". For an explanation of its origin see Freytag's Arab. Prov. ii. 484.]) ―         -b3-"},{"kind":"arabic","text_bw":"AlA^agonaAmu","text_ar":"الاَغْنَامُ"},{"kind":"text","text":"is the name of (assumed tropical:)"},{"kind":"italic_en","text":"Certain small stars between the legs of Cepheus and the star"},{"kind":"arabic","text_bw":"AljadoYu","text_ar":"الجَدْىُ"},{"kind":"text","text":". (Kzw, in his descr. of Cepheus.) [See"},{"kind":"arabic","text_bw":"$aApN","text_ar":"شَاةٌ"},{"kind":"text","text":"(in art."},{"kind":"arabic","text_bw":"$wh","text_ar":"شوه"},{"kind":"text","text":"), last sentence.]"}],"source_refs":["T","Msb","K","S","TA"]}]}}