ext","text":"and ↓"},{"kind":"arabic","text_bw":"EinofN","text_ar":"عِنْفٌ","orth_type":"arrow"},{"kind":"text","text":"[the first of which is an inf. n.]"},{"kind":"italic_en","text":"Ungentleness, roughness, harshness, rigorousness, severity, violence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemence;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"rifoqN","text_ar":"رِفْقٌ"},{"kind":"text","text":". (S, Mgh, O, K, TA.) It is said of God, in a trad.,"},{"kind":"arabic","text_bw":"yuEoTiY EalaY Alr~ifoqi maA laA yuEoTiY EalaY AlEunofi","text_ar":"يُعْطِى عَلَى الرِّفْقِ مَا لَا يُعْطِى عَلَى العُنْفِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He gives on account of gentleness"},{"kind":"text","text":"in the petitioner,"},{"kind":"italic_en","text":"what He will not give on account of ungentleness"},{"kind":"text","text":"]. (O.)"}],"source_refs":[]},{"entry_id":"n30769","headword_ar":"عِنْفٌ","root":"Enf","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]},{"entry_id":"n30770","headword_ar":"عَنِفٌ","root":"Enf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaniyfN","text_ar":"عَنِيفٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n30771","headword_ar":"عُنُفٌ","root":"Enf","body":[{"kind":"text","text":", with two dammehs,"},{"kind":"italic_en","text":"Roughness, and hardness:"},{"kind":"text","text":"so expl. by Lh as used in the saying,"},{"kind":"quote","text":"faqa*afato bibayoDapK fiyhaA Eunufo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And she cast forth an egg in which were roughness and hardness"},{"kind":"text","text":"]. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}