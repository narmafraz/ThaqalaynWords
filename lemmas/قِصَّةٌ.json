row"},{"kind":"text","text":": (A:) the pl. of"},{"kind":"arabic","text_bw":"qiS~apN","text_ar":"قِصَّةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"qiSaSN","text_ar":"قِصَصٌ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"A^aqaA SiySu","text_ar":"اَقَا صِيصُ"},{"kind":"text","text":"is a pl. pl.: (A, * TA:) and the pl. of ↓"},{"kind":"arabic","text_bw":"qaSiySapN","text_ar":"قَصِيصَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"qaSaAy^iSu","text_ar":"قَصَايِصُ"},{"kind":"text","text":". (A, * TA.) You say,"},{"kind":"arabic","text_bw":"lahu qiS~apN EajiybapN","text_ar":"لَهُ قِصَّةٌ عَجِيبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaSaSN","text_ar":"قَصَصٌ"},{"kind":"text","text":"&c. ["},{"kind":"italic_en","text":"He has,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, relates, a wonderful story"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"fiY raA^osihi qiS~apN","text_ar":"فِى رَاْسِهِ قِصَّةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"In his head is a speech;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA qiS~atuka","text_ar":"مَا قِصَّتُكَ"},{"kind":"italic_en","text":"What is thine affair?"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy case?"},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"rafaEa qiS~apF A_ilaY","text_ar":"رَفَعَ قِصَّةً اـِلَى"},{"kind":"arabic","text_bw":"Als~uloTaAni","text_ar":"السُّلْطَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He referred an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a case, to the Sultán"},{"kind":"text","text":"]. (A.)       -A2-  See also"},{"kind":"arabic","text_bw":"qaS~N","text_ar":"قَصٌّ"},{"kind":"text","text":", last signification."}],"source_refs":["S","M","TA","K","Msb","A"]}]},"classical_definitions":null}