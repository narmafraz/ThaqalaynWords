{"lemma":"سَفِيرَةٍ","slug":"سَفِيرَةٍ","root":"س.ف.ر","root_slug":"س-ف-ر","root_link":"/words/roots/س-ف-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n19942"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%81%D9%90%D9%8A%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"ambassador or mediator"}]},"etymology":null,"ipa":["/sa.fiːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19942","headword_ar":"سَفِيرٌ","root":"sfr","body":[{"kind":"italic_en","text":"Leaves which the wind sweeps away;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"leaves which fall from trees"},{"kind":"text","text":"(S, A, K)"},{"kind":"italic_en","text":"and which the wind sweeps away,"},{"kind":"text","text":"(A,) or because the wind sweeps them away: (S:) or"},{"kind":"italic_en","text":"leaves of herbs;"},{"kind":"text","text":"because the wind sweeps them away: (T, TA:) or"},{"kind":"italic_en","text":"what have fallen of the leaves of trees and of the lower portions of seed-produce."},{"kind":"text","text":"(JM.)       -A2-  Also"},{"kind":"italic_en","text":"A messenger:"},{"kind":"text","text":"(S:) and (assumed tropical:)"},{"kind":"italic_en","text":"a mediator;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a man who makes peace, effects a reconciliation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adjusts a difference, between a people;"},{"kind":"text","text":"(S, M, Msb;) as also ↓"},{"kind":"arabic","text_bw":"saAfirN","text_ar":"سَافِرٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"a messenger who makes peace,"},{"kind":"text","text":"&c.: (T, Mgh, TA:) [see 1:] pl. of the former"},{"kind":"arabic","text_bw":"sufaraA='u","text_ar":"سُفَرَا=ءُ"},{"kind":"text","text":", (S, M, Mgh,) and of the latter"},{"kind":"arabic","text_bw":"safarapN","text_ar":"سَفَرَةٌ"},{"kind":"text","text":". (Har p. 255. [See also"},{"kind":"arabic","text_bw":"sifaArapN","text_ar":"سِفَارَةٌ"},{"kind":"text","text":", below.]) ―         -b2-  And (assumed tropical:)"},{"kind":"italic_en","text":"A commissioned agent, a factor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a deputy;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"pl. as above: app. so called because he discovers, and makes manifest, the affair in which he acts as a substitute for another person. (Msb.)       -A3-  See also"},{"kind":"arabic","text_bw":"safarN","text_ar":"سَفَرٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","K","T","TA","Msb","Mgh","M"]}]},"classical_definitions":null}