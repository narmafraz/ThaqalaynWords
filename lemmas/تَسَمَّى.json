Alqawomi","text_ar":"بِالقَوْمِ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"A_ilayohimo","text_ar":"اـِلَيْهِمْ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He asserted his relationship to the sons of such a one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by the assumption of a name of relationship to them"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"to the people."},{"kind":"text","text":"(M, K.)"}],"source_refs":["M","K"]}]},"classical_definitions":null}