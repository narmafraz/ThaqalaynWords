{"lemma":"عِباراتٌ","slug":"عِباراتٌ","root":"ع.ب.ر","root_slug":"ع-ب-ر","root_link":"/words/roots/ع-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27841","n27842"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%90%D8%A8%D8%A7%D8%B1%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of عَبَرَ (ʕabara) (form I)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"expression"},{"pos":"noun","gloss":"ferry"}]},"etymology":{"source":"wiktextract","text":"Tool noun."},"ipa":["/ʕi.baː.ra/","/ʕab.baː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27841","headword_ar":"عَبَارَةٌ","root":"Ebr","body":[{"kind":"text","text":": see the next paragraph, in two places."}],"source_refs":[]},{"entry_id":"n27842","headword_ar":"عِبَارَةٌ","root":"Ebr","body":[{"kind":"italic_en","text":"Speech that passes from the tongue of the speaker to the ear of the hearer."},{"kind":"text","text":"(TA.) ―         -b2-  [And hence,"},{"kind":"italic_en","text":"A passage in a book"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"writing."},{"kind":"text","text":"] ―         -b3-  [Hence also,]"},{"kind":"italic_en","text":"A word, an expression,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a phrase."},{"kind":"text","text":"(Kull p. 60.) ―         -b4-  And ["},{"kind":"italic_en","text":"An explanation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interpretation;"},{"kind":"text","text":"] a subst. from"},{"kind":"arabic","text_bw":"Eab~ara Eanohu","text_ar":"عَبَّرَ عَنْهُ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"EabaArapN","text_ar":"عَبَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K, TA, [the former only in the CK,]) and ↓"},{"kind":"arabic","text_bw":"EaborapN","text_ar":"عَبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"EiborapN","text_ar":"عِبْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to different copies of the K. (TA.) You say,"},{"kind":"arabic","text_bw":"huwa Hasanu","text_ar":"هُوَ حَسَنُ"},{"kind":"arabic","text_bw":"AlEibaArapi","text_ar":"العِبَارَةِ"},{"kind":"text","text":", and, accord. to the M, ↓"},{"kind":"arabic","text_bw":"AlEabaArapi","text_ar":"العَبَارَةِ","orth_type":"arrow"},{"kind":"text","text":"also, i. e."},{"kind":"italic_en","text":"He has a good faculty of explaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of diction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of speaking perspicuously."},{"kind":"text","text":"(Msb.) [And"},{"kind":"arabic","text_bw":"h`*aA EibaArapN Eano ka*aA","text_ar":"هٰذَا عِبَارَةٌ عَنْ كَذَا"},{"kind":"italic_en","text":"This is a word,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an expression,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a phrase, for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denoting, such a thing;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"an explanation of such a thing."},{"kind":"text","text":"]       -A2-  Also"},{"kind":"italic_en","text":"A thing that is made a condition:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thing that is made account of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"esteemed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regarded as being of importance."},{"kind":"text","text":"(Msb.)"}],"source_refs":[]}]}}