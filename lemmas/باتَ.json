{"lemma":"باتَ","slug":"باتَ","root":"ب.#.ت","root_slug":"ب-_-ت","root_link":"/words/roots/ب-_-ت","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بِتَّ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بِتِّ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بِتُّما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بِتُّم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بِتُّنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"باتَ","in_corpus":true,"count":16,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"باتَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"باتا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"باتَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"باتُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بِتْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبِت","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَبِيت","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبِيتِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبِيتِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبِيتا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبِيتانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبِيتُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبِيتُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبِتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبِت","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَبِيت","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبِت","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَبِيت","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبِيتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبِيتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبِيتا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبِيتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبِيتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبِيتُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبِتْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"بِتُّ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بِتْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبِيت","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبِيت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":78,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n1699","n3598"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D8%A7%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"definite, definitive","tags":["definite","definitive"]},{"pos":"adj","gloss":"categorical","examples":[{"text":"مَنْع بَاتّ","english":"categorical interdiction"}]},{"pos":"verb","gloss":"to spend the night, to stay overnight","examples":[{"text":"\" إِنْ كَانَ عِنْدَكَ مَاءٌ بَاتَ فِي شَنٍّ فَٱسْقِنَا وَإِلَّا كَرَعْنَا \" . قَالَ عِنْدِي مَاءٌ بَاتَ فِي شَنٍّ . فَٱنْطَلَقَ وَٱنْطَلَقْنَا مَعَهُ إِلَى ٱلْعَرِيشِ فَحَلَبَ لَهُ شَاةً عَلَى مَاءٍ بَاتَ فِي شَنٍّ فَشَرِبَ ثُمَّ فَعَلَ مِثْلَ ذَٰلِكَ بِصَاحِبِهِ ٱلَّذِي مَعَهُ .","english":"‘If you have any water that has been kept overnight in a water skin, then give us some to drink, otherwise we will drink by putting out mouths in the basin.’ He said: ‘I have water that has been kept in a water skin. So he went and we went with him, to the shelter, where he milked a sheep for him and (mixed it with) the water that had been kept overnight in a water skin. He drank from it, then he did likewise for his Companion who was with him.”"}]},{"pos":"verb","gloss":"to become, to have gotten into","tags":["copulative"],"examples":[{"text":"رَمَضَانُ بَاتَ عَلَى الْأَبْوَابِ وَيَفْصِلُنَا عَنْهُ أَيّامٌ مَعْدُودَةٌ","english":"Ramadan is about to happen and what separates us from it are a few days."}]},{"pos":"verb","gloss":"to continue doing, keep doing, stick to"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of بَتَّ (batta, “to fix, to determine, to decide”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1699","headword_ar":"بَاتٌّ","root":"bt","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bat~N","text_ar":"بَتٌّ"},{"kind":"text","text":", in three places. ―         -b2-"},{"kind":"italic_en","text":"Cut off from [the possession of] reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect, by drunkenness:"},{"kind":"text","text":"(AHn, M:) or"},{"kind":"italic_en","text":"drunken:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"stupid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish:"},{"kind":"text","text":"(S, K:) and"},{"kind":"arabic","text_bw":"A^aHomaqu baAt~N","text_ar":"اَحْمَقُ بَاتٌّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"very stupid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish,"},{"kind":"text","text":"(T, M,) accord. to Lth; but [Az adds,] what we remember to have heard from those deserving of confidence is"},{"kind":"arabic","text_bw":"taAb~N","text_ar":"تَابٌّ"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"Alt~abaAbu","text_ar":"التَّبَابُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"AlxasaAru","text_ar":"الخَسَارُ"},{"kind":"text","text":"; like as one says,"},{"kind":"arabic","text_bw":"A^aHomaqu","text_ar":"اَحْمَقُ"},{"kind":"page_break","n":149},{"kind":"arabic","text_bw":"xaAsirN daAbirN daAmirN","text_ar":"خَاسِرٌ دَابِرٌ دَامِرٌ"},{"kind":"text","text":"[explained in art."},{"kind":"arabic","text_bw":"xsr","text_ar":"خسر"},{"kind":"text","text":"]. (T.) [See also 1, near the end of the paragraph.] ―         -b3-  Also"},{"kind":"italic_en","text":"Lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meagre,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"and unable to rise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stand."},{"kind":"text","text":"(TA.)"}],"source_refs":["AHn","M","K","S","T"]},{"entry_id":"n3598","headword_ar":"بَاتَ","root":"byt","body":[{"kind":"text","text":", (T, S M, &c.,) aor."},{"kind":"arabic","text_bw":"yabiytu","text_ar":"يَبِيتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yabaAtu","text_ar":"يَبَاتُ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"bayotuwtapN","text_ar":"بَيْتُوتَةٌ"},{"kind":"text","text":"(Lth, T, S A, Msb, K) and"},{"kind":"arabic","text_bw":"mabiytN","text_ar":"مَبِيتٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"mabaAtN","text_ar":"مَبَاتٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"bayotN","text_ar":"بَيْتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bayaAtN","text_ar":"بَيَاتٌ"},{"kind":"text","text":", (K,) has two meanings: in that which more commonly obtains, the action is restricted to the night: (Msb:) it is by night, or in night; not in sleep: (M:) you say,"},{"kind":"arabic","text_bw":"baAta yafoEalu ka*aA","text_ar":"بَاتَ يَفْعَلُ كَذَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He did such a thing by night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at night:"},{"kind":"text","text":"(S, Msb, K:) [or"},{"kind":"italic_en","text":"he was in the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"during the night, doing such a thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spent, the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a night,"},{"kind":"text","text":"or a"},{"kind":"italic_en","text":"part"},{"kind":"italic_en","text":"thereof,"},{"kind":"text","text":"or, as will be seen below,"},{"kind":"italic_en","text":"he entered upon the night, doing such a thing:"},{"kind":"text","text":"] like as one says,"},{"kind":"arabic","text_bw":"Zal~a yafoEalu ka*aA","text_ar":"ظَلَّ يَفْعَلُ كَذَا"},{"kind":"text","text":"as meaning “ he did such a thing by day, ” or “ at day-time: ” (S, Msb;*) IKoot and Es-Sarakustee and IKtt say that it has this meaning, and not “ he slept: ” (Msb:) [F adds,]"},{"kind":"arabic","text_bw":"wa layosa mina Aln~awomi","text_ar":"وَ لَيْسَ مِنَ النَّوْمِ"},{"kind":"text","text":", (K,) which is said to mean, “ and the action is not one of sleep; ” so that when one sleeps by night, or at night, it is not correct to say,"},{"kind":"arabic","text_bw":"baAta yanaAmu","text_ar":"بَاتَ يَنَامُ"},{"kind":"text","text":": or, accord. to some, “ its meaning is not that of sleeping; ” so that one may say,"},{"kind":"arabic","text_bw":"baAta zayodN naAy^imFA","text_ar":"بَاتَ زَيْدٌ نَايِمًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Zeyd was in the night,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spent, the night,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"sleeping"},{"kind":"text","text":"]: (MF:) [Fei says,] it is only when one remains awake in the night: and hence the saying in the Kur [xxv. 65],"},{"kind":"arabic","text_bw":"waA@l~a*iyna yabiytuwna lir~abihimo suj~adFA waqiyAmFA","text_ar":"وَا@لَّذِينَ يَبِيتُونَ لِرَّبِهِمْ سُجَّدًا وَقِيامًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And those who pass the night prostrating themselves to their Lord and standing up"},{"kind":"text","text":"in prayer]: (Msb:) Fr says that"},{"kind":"arabic","text_bw":"baAta Alr~ajulu","text_ar":"بَاتَ الرَّجُلُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The man remained awake all the night,"},{"kind":"text","text":"engaged in acts of obedience or of disobedience: (T, Msb:) [or it means"},{"kind":"italic_en","text":"the man entered upon the night;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was in the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"during the night,"},{"kind":"text","text":"in any state, or engaged in any action; for] Zj says, (M,)"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"text","text":"is said of any one whom the night has overtaken, (M, K, *) whether he have slept or not slept: (M:) and Lth says,"},{"kind":"arabic","text_bw":"Albayotuwtapu","text_ar":"البَيْتُوتَةُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the entering upon the night:"},{"kind":"text","text":"one says,"},{"kind":"arabic","text_bw":"bit~u A^aSonaEu ka*aA wa ka*aA","text_ar":"بِتُّ اَصْنَعُ كَذَا وَ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I entered upon the night doing such and such things"},{"kind":"text","text":"]: and he adds, (T,) he who says"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"he slept"},{"kind":"text","text":"commits an error; for you say,"},{"kind":"arabic","text_bw":"bit~u A^uraAEiY","text_ar":"بِتُّ اُرَاعِى"},{"kind":"arabic","text_bw":"Aln~ujuwma","text_ar":"النُّجُومَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I entered upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, the night"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"looking at the stars:"},{"kind":"text","text":"and how can he be sleeping who is looking at them? (T, Msb:) but Mullà 'Abd-El-Hakeem, in his Commentaries on the Mutowwal, says that"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"text","text":"sometimes means"},{"kind":"italic_en","text":"he remained, continued, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he alighted and abode, by night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at night,"},{"kind":"text","text":"whether he slept or not: (MF:) and Ibn-Keysán says that it may be used in the same manner as"},{"kind":"arabic","text_bw":"naAma","text_ar":"نَامَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he slept"},{"kind":"text","text":"]; and also, [as will be explained below,] in the same manner as"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"arabic","text_bw":"bayotuwtapF SaAliHapF","text_ar":"بَيْتُوتَةً صَالِحَةً"},{"kind":"text","text":"(T) or"},{"kind":"arabic","text_bw":"Tay~ibapF","text_ar":"طَيِّبَةً"},{"kind":"text","text":"(A) ["},{"kind":"italic_en","text":"He passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon, the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a night, in a good manner"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"bit~u Alqawoma","text_ar":"بِتُّ القَوْمَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bit~u bihimo","text_ar":"بِتُّ بِهِمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bit~u","text_ar":"بِتُّ"},{"kind":"arabic","text_bw":"Einodahumo","text_ar":"عِنْدَهُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon, the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a night, with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the abode of, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men:"},{"kind":"text","text":"the last of these phrases is the most common]. (A 'Obeyd, M, K.) ―         -b2-  Secondly, it is used in the sense of"},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He became"},{"kind":"text","text":"]; (Msb;) or in the same manner as"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he was"},{"kind":"text","text":"]. (Ibn-Keysán, TA.) One says,"},{"kind":"arabic","text_bw":"baAta bimawoDiEi ka*aA","text_ar":"بَاتَ بِمَوْضِعِ كَذَا"},{"kind":"italic_en","text":"He became"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"was"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in such a place;"},{"kind":"text","text":"whether in night-time or in day-time. (Msb.) And hence the saying of the lawyers,"},{"kind":"arabic","text_bw":"baAta Einoda A@moraA^atihi layolapF","text_ar":"بَاتَ عِنْدَ ا@مْرَاَتِهِ لَيْلَةً"},{"kind":"italic_en","text":"He became"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"was"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his wife one night;"},{"kind":"text","text":"[which is the same as"},{"kind":"italic_en","text":"he passed a night"},{"kind":"text","text":"&c.; though this, it will be observed, is not in this instance the signification of the verb alone;] whether sleeping or not. (Msb.) ―         -b3-  [Thus it is used both as a “ complete, ” i. e. an attributive, verb, and also as an “ incomplete, ” i. e. a non-attributive, verb.] ―         -b4-"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yabiytu","text_ar":"يَبِيتُ"},{"kind":"text","text":", (T, A,) inf. n."},{"kind":"arabic","text_bw":"bayotN","text_ar":"بَيْتٌ"},{"kind":"text","text":", (T, M, K,) also signifies (tropical:)"},{"kind":"italic_en","text":"He married,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took a wife:"},{"kind":"text","text":"(T, A:) [see"},{"kind":"arabic","text_bw":"bayotN","text_ar":"بَيْتٌ"},{"kind":"text","text":"below:] or (assumed tropical:)"},{"kind":"italic_en","text":"he gave in marriage;"},{"kind":"text","text":"syn. of the inf. n."},{"kind":"arabic","text_bw":"tazowiyjN","text_ar":"تَزْوِيجٌ"},{"kind":"text","text":". (Kr, M, K.)"}],"source_refs":["S","Msb","K","M","MF","T","A"]}]},"classical_definitions":null}