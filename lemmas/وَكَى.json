esent_3ms","form":"يُوكَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكِي","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُوكَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fp","form":"يَكِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكِي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"وَكَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَكَيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُوكَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوكَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":false}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%88%D9%83%D9%89/","headword_ar":"وكى","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=10136#0623c6","body_html":"وكى:<br>وكى: انظر توكأ واتكأ في (وكا)."},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10136#7493a0","body_html":"<h3>وك</h3>ى<br><br>وِكَآءٌ A tie: see an <abbr title=\"example\">ex.</abbr> <abbr title=\"under the heading\">voce</abbr> اِسْتٌ, in art. سته. <span class=\"sub-sense\">b2:</span> The tie, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) which is a cord, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) of the head (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>) of the قِرْبة, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) &amp;c. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.)"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=10136#6a8cfc","body_html":"<span class=\"title1\">[وكى]</span><span> الوِكاءُ: الذي يشدُّ به رأس القِربة. وفي الحديث: \" احْفَظْ عفاصها ووكاءها \". يقال: أؤكى على ما في سِقائِهِ، إذا شدَّه بالوِكاءِ. وإنَّ فلاناً لوِكاءٌ: ما يبض بشئ. وسألناه فأوكى علينا، أي بَخِلَ. وفي الحديث أنَّه \" كان يوكي بين الصفا والمروة \"، أي يملأ ما بينهما سعياً كما يوكى السِقاءُ بعد الملءِ. ويقال معناه أنَّه كان يسكت فلا يتكلَّم، كأنَّه يوكي فمه. وهو من قولهم: أَوْكِ حَلْقَكَ، أي اسكت. أبو زيد: استوكت الناقة، إذا امتلات شحما.</span>"},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=10136#45782c","body_html":"<span class=\"title1\">وكى</span><span> بن وَقَالَ [أَبُو عبيد -] : فِي حَدِيث الزبير [رَحمَه الله -] أَنه كَانَ يُوكي بَين الصَّفَا والمروة. فَذهب بعض النَّاس فِي هَذَا إِلَى أَنه كَانَ يستريح فِي طَوَافه بَينهمَا. حَتَّى يُوكي الشَّيْء يشده وَإِنَّمَا هُوَ عِنْدِي من إمْسَاك الْكَلَام أَنه يوكي فَاه فَلَا يتَكَلَّم ويحكى عَن أَعْرَابِي أَنه سمع رجلا يتَكَلَّم فَقَالَ: أوك حلقك 7 / الف أَي سُدّ فمك واسكت فَلَا تكلم. وَإِنَّمَا كره الزبير الْكَلَام / فِي السَّعْي بَينهمَا كَمَا كره كثير من الْفُقَهَاء الْكَلَام فِي الطّواف بِالْبَيْتِ فَشبه هَذَا </span><span>بذلك. وَفِيه تَفْسِير آخر أَنه يرْوى عَنهُ قَالَ: كَانَ يُوكي [مَا -] بَين الصَّفَا والمروة سعيا فَإِن كَانَ هَذَا هُوَ الْمَحْفُوظ فَإِن وَجهه أَن يمْلَأ مَا بَينهمَا سعيا لَا يمشي على هينته فِي شَيْء من ذَلِك وَهَذَا شَبيه بالسقاء أَو غَيره يُملأ مَاء ثمَّ يَوكى عَلَيْهِ حَيْثُ انْتهى الامتلاء.</span><br><br><span>أَحَادِيث طَلْحَة عبيد الله رَضِي الله عَنهُ</span>"}]}}