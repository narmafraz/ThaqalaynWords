":"text","text":": (K:) fem."},{"kind":"arabic","text_bw":"sulakapN","text_ar":"سُلَكَةٌ"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"silokaAnapN","text_ar":"سِلْكَانَةٌ","orth_type":"arrow"},{"kind":"text","text":", but the latter is rare: (K:) pl."},{"kind":"arabic","text_bw":"silokaAnN","text_ar":"سِلْكَانٌ"},{"kind":"text","text":", (S, K,) like"},{"kind":"arabic","text_bw":"SirodaAnN","text_ar":"صِرْدَانٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"SuradN","text_ar":"صُرَدٌ"},{"kind":"text","text":"(S) [and"},{"kind":"arabic","text_bw":"siloHaAnN","text_ar":"سِلْحَانٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"sulaHN","text_ar":"سُلَحٌ"},{"kind":"text","text":"]."}],"source_refs":["K","S"]}]}}