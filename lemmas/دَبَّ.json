uency_in_corpus":33,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":13},"lanes":{"found":true,"entry_ids":["n11944"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%A8%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to creep, to crawl"},{"pos":"verb","gloss":"to proceed, to advance, to move slowly"},{"pos":"verb","gloss":"to go on all fours"},{"pos":"verb","gloss":"to enter"},{"pos":"verb","gloss":"to steal, to creep"},{"pos":"verb","gloss":"to spread, to fill, to pervade, to invade"},{"pos":"verb","gloss":"to gain ground"},{"pos":"noun","gloss":"bear","examples":[{"text":"(astronomy) الدُّبّ الْأَصْغَر (ad-dubb al-ʔaṣḡar, “Ursa Minor”)"},{"text":"(astronomy) الدُّبّ الْأَكْبَر (ad-dubb al-ʔakbar, “Ursa Major”)"}]},{"pos":"noun","gloss":"verbal noun of دَبَّ (dabba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"walking along slowly"},{"pos":"noun","gloss":"creeping, crawling"},{"pos":"noun","gloss":"slow walk"},{"pos":"noun","gloss":"creeping, crawling"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *dubb- (“bear”), from Proto-Afroasiatic *dab- (“big animal”). Compare Aramaic דבא (debbā), Hebrew דוב (dov) and Akkadian dabûm."},"ipa":["/dab.ba/","/dubb/","/dabb/","/dibb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11944","headword_ar":"دَبَّ","root":"db","body":[{"kind":"text","text":"aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dabiybN","text_ar":"دَبِيبٌ"},{"kind":"text","text":"(T, S, M, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"dab~N","text_ar":"دَبٌّ"},{"kind":"text","text":"(M, K,) and"},{"kind":"arabic","text_bw":"madab~N","text_ar":"مَدَبٌّ"},{"kind":"text","text":", (S, K,) [and perhaps"},{"kind":"arabic","text_bw":"dababN","text_ar":"دَبَبٌ"},{"kind":"text","text":"also, q. v.,]"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(the ant, T, M, and any animal, M, and in like manner a party moving towards the enemy, T, or an army, and a child, Msb,) ["},{"kind":"italic_en","text":"crept; crawled;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walked, leisurely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gently,"},{"kind":"text","text":"(T, M, Msb, K,)"},{"kind":"italic_en","text":"without haste,"},{"kind":"text","text":"(T,)"},{"kind":"arabic","text_bw":"EalaY AlA^aroDi","text_ar":"عَلَى الاَرْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon the ground"},{"kind":"text","text":"]: (S:) and [simply]"},{"kind":"italic_en","text":"he walked:"},{"kind":"text","text":"(IAar, T:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(an old man) ["},{"kind":"italic_en","text":"crept along;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"walked leisurely, softly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gently:"},{"kind":"text","text":"(S:) and ↓"},{"kind":"arabic","text_bw":"db~b","text_ar":"دبّب","orth_type":"arrow"},{"kind":"text","text":", also,"},{"kind":"italic_en","text":"he walked leisurely, by slow degrees."},{"kind":"text","text":"(TA.) Hence,"},{"kind":"arabic","text_bw":"A^ako*abu","text_ar":"اَكْذَبُ"},{"kind":"arabic","text_bw":"mano dab~a wadaraja","text_ar":"مَنْ دَبَّ وَدَرَجَ"},{"kind":"italic_en","text":"The most lying of those who have walked and died,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished:"},{"kind":"text","text":"(T:) i. e.,"},{"kind":"italic_en","text":"of the living and the dead."},{"kind":"text","text":"(T, S, K.) And"},{"kind":"arabic","text_bw":"yadib~u maEa AlquraAdi","text_ar":"يَدِبُّ مَعَ القُرَادِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He creeps about with ticks"},{"kind":"text","text":"]; said of a man who brings a small worn-out skin containing ticks, and ties it to the tail of a camel; in consequence of which, when one of the ticks bites it, the camel runs away, and the other camels run away with it; and thereupon he steals one of them: whence it is said of a thief, or stealer of cattle &c. (TA.) And"},{"kind":"arabic","text_bw":"huwa yadib~u bayonanaA biAln~amaAy^imi","text_ar":"هُوَ يَدِبُّ بَيْنَنَا بِالنَّمَايِمِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He creeps among us with calumnies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slanders"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"dab~ato EaqaArabuhu","text_ar":"دَبَّتْ عَقَارَبُهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His scorpions crept along"},{"kind":"text","text":"]; meaning (tropical:)"},{"kind":"italic_en","text":"his calumnies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slanders,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"mischief,"},{"kind":"text","text":"(M, A, K,)"},{"kind":"italic_en","text":"crept along;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sarato","text_ar":"سَرَتْ"},{"kind":"text","text":". (M, K [See also art."},{"kind":"arabic","text_bw":"Eqrb","text_ar":"عقرب"},{"kind":"text","text":".]) And the same phrase is also used to signify (tropical:)"},{"kind":"italic_en","text":"His downy hair crept"},{"kind":"text","text":"["},{"kind":"italic_en","text":"along his cheeks"},{"kind":"text","text":"]. (MF in art."},{"kind":"arabic","text_bw":"Eqrb","text_ar":"عقرب"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"dab~a qamoluhu","text_ar":"دَبَّ قَمْلُهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His lice crept"},{"kind":"text","text":"]; meaning (tropical:)"},{"kind":"italic_en","text":"he became fat:"},{"kind":"text","text":"said of a man. (Ham. p. 633.) And"},{"kind":"arabic","text_bw":"dab~a Aljadowalu","text_ar":"دَبَّ الجَدْوَلُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The rivulet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streamlet for irrigation, crept along"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"dab~a fiyhi","text_ar":"دَبَّ فِيهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It crept in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"saraY","text_ar":"سَرَى"},{"kind":"text","text":"; (M, A, K;) namely, wine, or beverage, (T, M, A, K,) in, or into, the body, (M, K,) or in, or into, a man, (T,) and into a vessel; (M;) and a disease, or malady, (M, A, K,) in, or into, the body, (M, K,) or"},{"kind":"arabic","text_bw":"fiY Euruwqihi","text_ar":"فِى عُرُوقِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his veins"},{"kind":"text","text":"]; (A;) and wear in a garment, or piece of cloth; (M, K;) and the dawn in the darkness of the latter part of the night. (M.) ―         -b2-"},{"kind":"arabic","text_bw":"dib~iY Hajalo","text_ar":"دِبِّى حَجَلْ"},{"kind":"text","text":"(in the CK"},{"kind":"arabic","text_bw":"Hajalu","text_ar":"حَجَلُ"},{"kind":"text","text":") is the name of"},{"kind":"italic_en","text":"A certain game of the Arabs:"},{"kind":"text","text":"(K, TA:) the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is quiescent. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"dub~a","text_ar":"دُبَّ"},{"kind":"text","text":"used as a noun: see below.       -A2-"},{"kind":"arabic","text_bw":"dab~a","text_ar":"دَبَّ"},{"kind":"text","text":"[second pers."},{"kind":"arabic","text_bw":"dabibota","text_ar":"دَبِبْتَ"},{"kind":"text","text":",] aor."},{"kind":"arabic","text_bw":"yadab~u","text_ar":"يَدَبُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dababN","text_ar":"دَبَبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"A^adab~u","text_ar":"اَدَبُّ"},{"kind":"text","text":"; (IAar, T, TA;) i. e.,"},{"kind":"italic_en","text":"had much hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much fur"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"wabar","text_ar":"وَبَر"},{"kind":"text","text":"), or"},{"kind":"italic_en","text":"much fur upon the face."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","K","S","T","Msb","IAar","A","TA"]}]}}