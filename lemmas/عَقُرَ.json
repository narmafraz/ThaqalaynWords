{"lemma":"عَقُرَ","slug":"عَقُرَ","root":"ع.ق.ر","root_slug":"ع-ق-ر","root_link":"/words/roots/ع-ق-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَقُرْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَقُرْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَقُرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَقُرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَقُرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَقُرَ","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَقُرَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَقُرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَقُرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَقُرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَقُرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْقُر","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْقُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْقُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْقُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْقُرُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْقُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْقُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْقُر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْقُر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْقُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْقُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْقُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْقُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْقُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَعْقُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْقُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"عَقُرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَقُرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":true,"lemma_key":"عَقُرَ","root":"عقر","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n29906","n29907","n29908","n29909","n29910"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%82%D9%8F%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hamstring"},{"pos":"verb","gloss":"to be infertile"},{"pos":"noun","gloss":"verbal noun of عَقَرَ (ʕaqara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَقُرَ (ʕaqura) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَقُرَ (ʕaqura) (form I); sterility, barrenness"},{"pos":"noun","gloss":"the midst of the house"}]},"etymology":{"source":"wiktextract","text":"Cognate to Hebrew עָקַר (ʿāqár, “to pluck, to hamstring”).\n\nFrom Aramaic אַקְרָא / חַקְרָא / עַקְרָא (ʿaqrā, ḥaqrā, ʾaqrā), from Ancient Greek ἄκρᾱ (ákrā, “farthest point, heart, end, extremity”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29906","headword_ar":"عَقْرٌ","root":"Eqr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"act of wounding; &c.:"},{"kind":"text","text":"[see 1:]"},{"kind":"italic_en","text":"a mark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wound,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^avarN","text_ar":"اَثَرٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"like a notch,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"kAlHaz~i","text_ar":"كالحَزِّ"},{"kind":"text","text":", K, TA, [in the CK,"},{"kind":"arabic","text_bw":"kAlxar~i","text_ar":"كالخَرِّ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"in the legs of a horse,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a camel."},{"kind":"text","text":"(K.) [Hence,"},{"kind":"arabic","text_bw":"EaqorFA HaloqFA","text_ar":"عَقْرًا حَلْقًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EaqoraY HaloqaY","text_ar":"عَقْرَى حَلْقَى"},{"kind":"text","text":": see 1.]       -A2-  See also"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ"},{"kind":"text","text":", first sentence:       -A3-  and again in the last quarter.       -A4-  Also"},{"kind":"italic_en","text":"What is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constitutes, the most essential part,"},{"kind":"text","text":"of anything; or the"},{"kind":"italic_en","text":"prime,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"principal part,"},{"kind":"text","text":"thereof; syn."},{"kind":"arabic","text_bw":"A^aSolN","text_ar":"اَصْلٌ"},{"kind":"text","text":": [such appears to me to be the meaning of"},{"kind":"arabic","text_bw":"ASl","text_ar":"اصل"},{"kind":"text","text":"as here used, from what follows.] (S, IF, Msb.) ―         -b2-  The"},{"kind":"italic_en","text":"principal part"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aSol","text_ar":"اَصْل"},{"kind":"text","text":") of a"},{"kind":"arabic","text_bw":"daAr","text_ar":"دَار"},{"kind":"text","text":"[i. e., a country]; (As, S, Msb, K;) which is the"},{"kind":"italic_en","text":"place where the people dwell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abide;"},{"kind":"text","text":"(As, S;) as also ↓"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ","orth_type":"arrow"},{"kind":"text","text":": (As, S, Msb, K:) the former of the dial. of Nejd; (As, TA;) and the latter of the dial. of the people of El-Medeeneh, (As, S,) or of the dial. of El-Hijáz; (TA;) or both of the dial. of the people of El-Hijáz; and the latter, in the dial. of others, signifies the"},{"kind":"italic_en","text":"chief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"main, part"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"dAr","text_ar":"دار"},{"kind":"text","text":"; (Msb;) and the latter also signifies the"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"heart"},{"kind":"text","text":"] of a"},{"kind":"arabic","text_bw":"dAr","text_ar":"دار"},{"kind":"text","text":": (K:) or"},{"kind":"arabic","text_bw":"Eaqoru Ald~aAri","text_ar":"عَقْرُ الدَّارِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuqoruhaA","text_ar":"عُقْرُهَا","orth_type":"arrow"},{"kind":"text","text":"both signify"},{"kind":"italic_en","text":"the principal part"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ASl","text_ar":"اصل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the place of abode of a people, upon which they rest their confidence."},{"kind":"text","text":"(Mgh, O.) This last signification is exemplified by the trad. of 'Alee,"},{"kind":"arabic","text_bw":"maA guziYa qawomN fiY Eaqori daArihimo A_il~aA","text_ar":"مَا غُزِىَ قَوْمٌ فِى عَقْرِ دَارِهِمْ اـِلَّا"},{"kind":"arabic","text_bw":"*al~uwA","text_ar":"ذَلُّوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"No people have had war waged against them in the principal part of their country, upon which they rest their confidence, but they have become abased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought into subjection"},{"kind":"text","text":"]: (Mgh, O:) or the meaning here is,"},{"kind":"italic_en","text":"in the midst"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"heart"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of their country,"},{"kind":"text","text":"&c.; i. e.,"},{"kind":"italic_en","text":"in the place where they abide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lodge."},{"kind":"text","text":"(L.) It is said in another trad.,"},{"kind":"arabic","text_bw":"Eaqoru daAri A@loA_isolaAmi Al$~aA^omu","text_ar":"عَقْرُ دَارِ ا@لْاـِسْلَامِ الشَّاْمُ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"The principal part"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ASl","text_ar":"اصل"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and the place, of the country of El-Islám is Syria:"},{"kind":"text","text":"apparently pointing to a time of conflicts and factions, or seditions, when Syria should be free from them, and the Muslims should there be more secure. (TA.) Lth has confounded in explaining what is the"},{"kind":"arabic","text_bw":"Euqor","text_ar":"عُقْر"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"dAr","text_ar":"دار"},{"kind":"text","text":"and what is the"},{"kind":"arabic","text_bw":"Euqor","text_ar":"عُقْر"},{"kind":"text","text":"of a tank or trough for watering beasts &c. (Az.)"}],"source_refs":["As","S","Msb","K","Mgh","O"]},{"entry_id":"n29907","headword_ar":"عُقْرٌ","root":"Eqr","body":[{"kind":"text","text":"(S, M, &c.) and ↓"},{"kind":"arabic","text_bw":"EaqorN","text_ar":"عَقْرٌ","orth_type":"arrow"},{"kind":"text","text":", (M,) or ↓"},{"kind":"arabic","text_bw":"EaqorapN","text_ar":"عَقْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuqorapN","text_ar":"عُقْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"Barrenness,"},{"kind":"text","text":"in a woman, (S, K, &c.,) and in a man. (S, TA.) You say also"},{"kind":"arabic","text_bw":"laqiHati Aln~aAqapu Eano EuqorK","text_ar":"لَقِحَتِ النَّاقَةُ عَنْ عُقْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The she-camel conceived after having been barren"},{"kind":"text","text":"]. (S, O.) And"},{"kind":"arabic","text_bw":"laqiHa","text_ar":"لَقِحَ"},{"kind":"arabic","text_bw":"liqaAw^uka Eano EuqorK","text_ar":"لِقَاوُكَ عَنْ عُقْرٍ"},{"kind":"text","text":"[app., (assumed tropical:)"},{"kind":"italic_en","text":"The meeting thee hath been productive of good after barrenness thereof"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"laqiHona A_ilaY EuqorK","text_ar":"لَقِحْنَ اـِلَى عُقْرٍ"},{"kind":"text","text":", a phrase used by Dhu-r-Rummeh, referring to wars; i. e. (assumed tropical:)"},{"kind":"italic_en","text":"They returned to stillness."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"rajaEati AlHarobu","text_ar":"رَجَعَتِ الحَرْبُ"},{"kind":"arabic","text_bw":"A_ilaY EuqorK","text_ar":"اـِلَى عُقْرٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The war became languid."},{"kind":"text","text":"(A, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ"},{"kind":"text","text":"in a palm-tree means ["},{"kind":"italic_en","text":"Barrenness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a drying up, and perishing, occasioned by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fibrous substance called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"liyf","text_ar":"لِيف"},{"kind":"italic_en","text":"stripped off"},{"kind":"text","text":"(O, K, TA)"},{"kind":"italic_en","text":"from the heart,"},{"kind":"text","text":"(O, TA,)"},{"kind":"italic_en","text":"and the heart itself taken away;"},{"kind":"text","text":"(O, K, TA;) which being done, it dries up and perishes. (Az, O, TA.)       -A2-  Also, or ↓"},{"kind":"arabic","text_bw":"EuqurN","text_ar":"عُقُرٌ","orth_type":"arrow"},{"kind":"text","text":", or the latter is used only by poetic license,"},{"kind":"italic_en","text":"Anything which a man drinks, and in consequence thereof has no offspring born to him."},{"kind":"text","text":"(O, TA.)       -A3-  Also,"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"A kind of dowry,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"compensation,"},{"kind":"text","text":"(IAth,)"},{"kind":"italic_en","text":"which is given to a woman when connection has been had with her in consequence of dubiousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a likeness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"on her part to the man's wife"},{"kind":"text","text":"]: ("},{"kind":"arabic","text_bw":"A_i*aA wuTiy^ato Eano $ubohapK","text_ar":"اـِذَا وُطِيَتْ عَنْ شُبْهَةٍ"},{"kind":"text","text":", S; or"},{"kind":"arabic","text_bw":"bi$ubohapK","text_ar":"بِشُبْهَةٍ"},{"kind":"text","text":", Mgh; or"},{"kind":"arabic","text_bw":"EalaY waTo'i Al$~ubohapi","text_ar":"عَلَى وَطْءِ الشُّبْهَةِ"},{"kind":"text","text":", IAth:) or"},{"kind":"italic_en","text":"a recompense which is given to a woman for connection with her:"},{"kind":"text","text":"(AO:) or"},{"kind":"italic_en","text":"a mulct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine, which is paid to a woman for ravishing her:"},{"kind":"text","text":"(Lth, Msb, K:) or"},{"kind":"italic_en","text":"what is given to a female slave who has been ravished, like a dowry in the like case to a free woman:"},{"kind":"text","text":"(Ahmad Ibn-Hambal:) so called because devirgination wounds the object of it: pl."},{"kind":"arabic","text_bw":"A^aEoqaArN","text_ar":"اَعْقَارٌ"},{"kind":"text","text":". (IAth, TA.) ―         -b2-  Hence, in consequence of frequency of usage, (Msb,) A woman's"},{"kind":"italic_en","text":"dowry;"},{"kind":"text","text":"(Msb, K;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"buDoEuhaA","text_ar":"بُضْعُهَا"},{"kind":"text","text":". (O.) ―         -b3-  Also The"},{"kind":"italic_en","text":"exploration of a woman to see if she be a virgin or not:"},{"kind":"text","text":"(Kh, O, K, TA:) but Az says that this is unknown. (TA.) [Perhaps it is a meaning inferred from what here follows.] ―         -b4-"},{"kind":"arabic","text_bw":"bayoDapu AlEuqori","text_ar":"بَيْضَةُ العُقْرِ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"That"},{"kind":"text","text":"["},{"kind":"italic_en","text":"egg"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with which a woman is tested on the occasion of devirgination:"},{"kind":"text","text":"(K: [but what is meant by this, I have not been able to learn:]) or"},{"kind":"italic_en","text":"the first egg of the hen;"},{"kind":"text","text":"(K, TA;) because it wounds her: (TA:) or"},{"kind":"italic_en","text":"the last egg of the hen;"},{"kind":"text","text":"(O, K, TA;)"},{"kind":"italic_en","text":"when she is old and weak:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"the egg of the cock, which"},{"kind":"text","text":"["},{"kind":"italic_en","text":"they say"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he lays once in the year,"},{"kind":"text","text":"(O, K,) [or"},{"kind":"italic_en","text":"once in his life,"},{"kind":"text","text":"for] they assert that it is"},{"kind":"italic_en","text":"the egg of the cock, because he lays, in his life, one egg, somewhat inclining to length; so called because the virginity of the girl,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young woman, is tested with it:"},{"kind":"text","text":"hence, they say of a thing given one time [only],"},{"kind":"arabic","text_bw":"kaAnato bayoDapa","text_ar":"كَانَتْ بَيْضَةَ"},{"kind":"arabic","text_bw":"AlEuqori","text_ar":"العُقْرِ"},{"kind":"text","text":": or, as some say, it is like the phrases"},{"kind":"arabic","text_bw":"bayoDu","text_ar":"بَيْضُ"},{"kind":"arabic","text_bw":"AlA^anuwqi","text_ar":"الاَنُوقِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA^abolaqu AlEaquwqu","text_ar":"الاَبْلَقُ العَقُوقُ"},{"kind":"text","text":"; so that it is a phrase proverbially used as applied to a thing that never is: (S, O:) accord. to A'Obeyd, when a niggard gives once, and not again, one says [of the gift],"},{"kind":"arabic","text_bw":"kaAnato bayoDapa Ald~iyki","text_ar":"كَانَتْ بَيْضَةَ الدِّيكِ"},{"kind":"text","text":"; and when he gives a thing, and then stops doing so, one says of the last time [of his giving],"},{"kind":"arabic","text_bw":"kaAnato bayoDapa AlEuqori","text_ar":"كَانَتْ بَيْضَةَ العُقْرِ"},{"kind":"text","text":". (TA.) One says also,"},{"kind":"arabic","text_bw":"kaAna *`lika bayoDapa AlEuqori","text_ar":"كَانَ ذٰلِكَ بَيْضَةَ العُقْرِ"},{"kind":"italic_en","text":"meaning"},{"kind":"text","text":"*"},{"kind":"italic_en","text":"That happened once, not a second time."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"bayoDapu AlEuqori","text_ar":"بَيْضَةُ العُقْرِ"},{"kind":"text","text":"means also (tropical:)"},{"kind":"italic_en","text":"He who has no offspring."},{"kind":"text","text":"(K, TA. [See also"},{"kind":"arabic","text_bw":"EaAqirN","text_ar":"عَاقِرٌ"},{"kind":"text","text":".]) And (assumed tropical:)"},{"kind":"italic_en","text":"He who stands another in no stead."},{"kind":"text","text":"(TA.)       -A4-  Also"},{"kind":"italic_en","text":"A grant of land;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TuEomapN","text_ar":"طُعْمَةٌ"},{"kind":"text","text":"; (O, K;) and so ↓"},{"kind":"arabic","text_bw":"EuqorapN","text_ar":"عُقْرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K. [See 4.]) ―         -b2-  And"},{"kind":"italic_en","text":"A place where people alight"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maHal~apu qawomK","text_ar":"مَحَلَّةُ قَوْمٍ"},{"kind":"text","text":", K, TA)"},{"kind":"italic_en","text":"between the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, and the trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank, for watering beasts &c.;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"EaqorN","text_ar":"عَقْرٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) or (TA, but in the K “ and ”) the"},{"kind":"italic_en","text":"hinder part"},{"kind":"text","text":"of a trough, or tank, for watering beasts &c., (S, K, TA,)"},{"kind":"italic_en","text":"where the camels stand when they come to water;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EuqurN","text_ar":"عُقُرٌ","orth_type":"arrow"},{"kind":"text","text":": (S:) or the"},{"kind":"italic_en","text":"station of the drinker;"},{"kind":"text","text":"(K;) as in all the copies of the K; but accord. to the T and Nh, the"},{"kind":"italic_en","text":"station of the animals drinking:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"place where the bucket is emptied, at the hinder part"},{"kind":"text","text":"of the trough, or tank; the place at the fore part being called its"},{"kind":"arabic","text_bw":"A_izaA='","text_ar":"اـِزَا=ء"},{"kind":"text","text":": (IAar:) pl."},{"kind":"arabic","text_bw":"A^aEoqaArN","text_ar":"اَعْقَارٌ"},{"kind":"text","text":". (S, O.) It is said in a prov.,"},{"kind":"arabic","text_bw":"A_in~amaA yuhodamu AlHawoDu mino Euqorihi","text_ar":"اـِنَّمَا يُهْدَمُ الحَوْضُ مِنْ عُقْرِهِ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"The trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank, for watering beasts &c. is demolished only"},{"kind":"text","text":"by commencing"},{"kind":"italic_en","text":"from its hinder part"},{"kind":"text","text":"]; meaning,"},{"kind":"italic_en","text":"an affair is performed only by setting about it in the proper way."},{"kind":"text","text":"(TA.) ―         -b3-  Also The"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of a well"},{"kind":"italic_en","text":"where the fore feet of the animals watering stand when they drink."},{"kind":"text","text":"(TA.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"EaqorN","text_ar":"عَقْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":["M","A","K","O","TA","S","IAth","AO","Lth","Msb","Kh","IAar"]},{"entry_id":"n29908","headword_ar":"عَقِرٌ","root":"Eqr","body":[{"kind":"text","text":": fem."},{"kind":"arabic","text_bw":"EaqirapN","text_ar":"عَقِرَةٌ"},{"kind":"text","text":": see the latter voce"},{"kind":"arabic","text_bw":"EaqiyrN","text_ar":"عَقِيرٌ"},{"kind":"text","text":":       -A2-  and see"},{"kind":"arabic","text_bw":"EaAqirN","text_ar":"عَاقِرٌ"},{"kind":"text","text":".       -A3-"},{"kind":"arabic","text_bw":"naAqapN EaqirapN","text_ar":"نَاقَةٌ عَقِرَةٌ"},{"kind":"text","text":", accord. to the K,"},{"kind":"italic_en","text":"A she-camel that will not drink save from fear:"},{"kind":"text","text":"but accord. to IAar [and the S and O],"},{"kind":"italic_en","text":"that will not drink save from the"},{"kind":"arabic","text_bw":"Euqor","text_ar":"عُقْر"},{"kind":"italic_en","text":"of the trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aziyapN","text_ar":"اَزِيَةٌ"},{"kind":"text","text":"signifies one “ that will not drink save from its"},{"kind":"arabic","text_bw":"A_izaA='","text_ar":"اـِزَا=ء"},{"kind":"text","text":", ” i. e. “ from its fore part. ” (TA.)"}],"source_refs":[]},{"entry_id":"n29909","headword_ar":"عُقَرٌ","root":"Eqr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"miEoqarN","text_ar":"مِعْقَرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n29910","headword_ar":"عُقُرٌ","root":"Eqr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}