},{"role":"present_2mp","form":"تَحْصُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْصُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْصُل","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْصُل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْصُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْصُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْصُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْصُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْصُلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْصُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْصُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَصَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَصَلْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْصُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْصُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":true,"lemma_key":"حَصَلَ","root":"حصل","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n8244"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B5%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be educed, to be taken forth, to be extracted","tags":["archaic"]},{"pos":"verb","gloss":"to happen, to come to existence, to befall"},{"pos":"verb","gloss":"to remain, to stay","tags":["archaic"]},{"pos":"verb","gloss":"to originate (مِن (min) from)"},{"pos":"verb","gloss":"to obtain, to get, to acquire; to receive; to collect (a debt)"},{"pos":"verb","gloss":"to produce, to educe, to fetch out, to extract, to take forth, to raise, to levy, to gather, vel sim."},{"pos":"noun","gloss":"dates before they have become hard","tags":["collective"]}]},"etymology":null,"ipa":["/ħa.sˤa.la/","/ħasˤ.sˤa.la/","/ħa.sˤal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8244","headword_ar":"حَصَلَ","root":"HSl","body":[{"kind":"text","text":", (Msb, K, &c.,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"HuSuwlN","text_ar":"حُصُولٌ"},{"kind":"text","text":"(Msb, K, &c.) and"},{"kind":"arabic","text_bw":"maHoSuwlN","text_ar":"مَحْصُولٌ"},{"kind":"text","text":", (K,) like"},{"kind":"arabic","text_bw":"maEoqurlN","text_ar":"مَعْقُرلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, produced, educed, extracted, taken forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fetched out;"},{"kind":"text","text":"as gold or silver from the stone of the mine, and the kernel from the shell, and wheat from the straw: (see 2:)]"},{"kind":"italic_en","text":"it came out, it became apparent:"},{"kind":"text","text":"(KL:)"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came into being"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existence; it became realized; syn. with the complete"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"attributive"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":": (Msb in art."},{"kind":"arabic","text_bw":"kwn","text_ar":"كون"},{"kind":"text","text":":) ["},{"kind":"italic_en","text":"it presented itself: it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prepared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready: it became attained, obtained, gotten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it came, came to pass, happened, took place, betided, befell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurred;"},{"kind":"text","text":"said of an event;"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"waqaEa","text_ar":"وَقَعَ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"wqE","text_ar":"وقع"},{"kind":"text","text":",) which is also"},{"kind":"italic_en","text":"syn. with the complete"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"attributive"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":"; (Msb in art."},{"kind":"arabic","text_bw":"kwn","text_ar":"كون"},{"kind":"text","text":";) likewise"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"jaA='a","text_ar":"جَا=ءَ"},{"kind":"text","text":": (Er-Rághib, TA in art."},{"kind":"arabic","text_bw":"jyA^","text_ar":"جيا"},{"kind":"text","text":":) ["},{"kind":"italic_en","text":"it resulted;"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"as a sum;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"as a product;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"as a quotient: it ensued: it arose, originated, proceeded, came, supervened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accrued:"},{"kind":"text","text":"in which senses, also, it is"},{"kind":"italic_en","text":"syn. with the attributive"},{"kind":"arabic","text_bw":"kaAna","text_ar":"كَانَ"},{"kind":"text","text":", and"},{"kind":"italic_en","text":"with"},{"kind":"arabic","text_bw":"jaA='a","text_ar":"جَا=ءَ"},{"kind":"text","text":", followed by"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":":]"},{"kind":"italic_en","text":"it remained, and continued, when the rest had gone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed away;"},{"kind":"text","text":"(K, TA;) relating to a reckoning, and to an action, and the like: (TA:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":"; as in the saying,"},{"kind":"arabic","text_bw":"HaSala liY Ealayohi ka*aA","text_ar":"حَصَلَ لِى عَلَيْهِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sum, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent, on him to render as a debt to me"},{"kind":"text","text":"]. (Msb.)       -A2-"},{"kind":"arabic","text_bw":"HaSila","text_ar":"حَصِلَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"HaSalN","text_ar":"حَصَلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"had a complaint of his belly from eating the earth of the herbage:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"HaSilati Ald~aAb~apu","text_ar":"حَصِلَتِ الدَّابَّةُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (M, K,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"the beast ate earth,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"pebbles,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and they remained in its inside,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"fixed:"},{"kind":"text","text":"(M:) or"},{"kind":"arabic","text_bw":"HaSalN","text_ar":"حَصَلٌ"},{"kind":"text","text":"signifies a horse's"},{"kind":"italic_en","text":"taking into the mouth earth from the herbs, some of which earth, collecting in his belly, kills him:"},{"kind":"text","text":"and the horse so killed is said to be ↓"},{"kind":"arabic","text_bw":"HaSilN","text_ar":"حَصِلٌ","orth_type":"arrow"},{"kind":"text","text":": (T, TA:) or a camel's"},{"kind":"italic_en","text":"having pebbles"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which he has swallowed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"remaining in the omasum, so as not to come forth in the cud when he ruminates;"},{"kind":"text","text":"and when this is the case, they sometimes kill: or a young camel's"},{"kind":"italic_en","text":"eating earth, and in consequence not ejecting the cud;"},{"kind":"text","text":"which sometimes kills it. (TA.) ―         -b2-  Said of a boy, it signifies"},{"kind":"arabic","text_bw":"waqaEa AlHaSaY","text_ar":"وَقَعَ الحَصَى"},{"kind":"text","text":"(K) or"},{"kind":"arabic","text_bw":"waqaEati AlHaSaApu","text_ar":"وَقَعَتِ الحَصَاةُ"},{"kind":"text","text":"(O)"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"arabic","text_bw":"A^unovayayohi","text_ar":"اُنْثَيَيْهِ"},{"kind":"text","text":"(O, K) [app. meaning"},{"kind":"italic_en","text":"The stones,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the stone, fell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"descended, in his scrotum:"},{"kind":"text","text":"Freytag, following the TK, in which"},{"kind":"arabic","text_bw":"fY Anvyyh","text_ar":"فى انثييه"},{"kind":"text","text":"is considered (I know not on what authority) as meaning"},{"kind":"arabic","text_bw":"fY mavaAnatihi","text_ar":"فى مَثَانَتِهِ"},{"kind":"text","text":", renders it “ laboravit lapidibus in vesica urinæ orientibus ”]."}],"source_refs":["TA","K","KL","S","M","T","O"]}]}}