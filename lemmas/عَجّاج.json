{"lemma":"عَجّاج","slug":"عَجّاج","root":"ع.ج.ج","root_slug":"ع-ج-ج","root_link":"/words/roots/ع-ج-ج","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28085","n28087"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%91%D8%A7%D8%AC"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"haze"}]},"etymology":null,"ipa":["/ʕa.d͡ʒaːd͡ʒ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28085","headword_ar":"عَجَاجٌ","root":"Ej","body":[{"kind":"italic_en","text":"Dust:"},{"kind":"text","text":"(S, A, O, K:) or"},{"kind":"italic_en","text":"dust raised by the wind:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"smoke:"},{"kind":"text","text":"(S, A, O, K:) ↓"},{"kind":"arabic","text_bw":"EajaAjapN","text_ar":"عَجَاجَةٌ","orth_type":"arrow"},{"kind":"text","text":"is a more special term [signifying"},{"kind":"italic_en","text":"a portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloud, of dust:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of smoke"},{"kind":"text","text":"]: (S, O:) and this latter signifies [also]"},{"kind":"italic_en","text":"a dust that buries in it everything;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"hajaAjapN","text_ar":"هَجَاجَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Low, vile, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble, people;"},{"kind":"text","text":"(Sh, O, K, TA;)"},{"kind":"italic_en","text":"lacking intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"(Sh, O;)"},{"kind":"italic_en","text":"in whom is no good:"},{"kind":"text","text":"[a coll. gen. n.; for] ↓"},{"kind":"arabic","text_bw":"EajaAjapN","text_ar":"عَجَاجَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"one of such persons"},{"kind":"text","text":"[as is indicated in the O]. (TA.) And, applied to a single person,"},{"kind":"italic_en","text":"Foolish; stupid; unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient, in intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding."},{"kind":"text","text":"(K.)"}],"source_refs":["S","A","O","K","TA"]},{"entry_id":"n28087","headword_ar":"عَجَّاجٌ","root":"Ej","body":[{"kind":"italic_en","text":"Vociferous, clamorous, sounding much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noisy;"},{"kind":"text","text":"an epithet applied to anything that has a voice, or sound, or noise, (S, O, K,) as a bow and the wind [&c.]; (S, O;) as also ↓"},{"kind":"arabic","text_bw":"EajoEaAjN","text_ar":"عَجْعَاجٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) this latter mentioned by Lh as applied in this sense to a man: (S:) and the former, applied to a stallion [camel],"},{"kind":"italic_en","text":"vociferous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noisy,"},{"kind":"text","text":"in his braying: and, applied to a river,"},{"kind":"italic_en","text":"sounding:"},{"kind":"text","text":"(S, O:) or, thus applied,"},{"kind":"italic_en","text":"containing much water;"},{"kind":"text","text":"as though it vociferated by reason of the abundance thereof and of the sound of its copious pouring. (IDrd, TA.) [See a tropical ex. of it voce"},{"kind":"arabic","text_bw":"vaj~aAjN","text_ar":"ثَجَّاجٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"yawomN Eaj~aAjN","text_ar":"يَوْمٌ عَجَّاجٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEij~N","text_ar":"مُعِجٌّ","orth_type":"arrow"},{"kind":"italic_en","text":"A day of violent wind that raises the dust."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["S","O","K"]}]}}