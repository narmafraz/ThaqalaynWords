um":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n15348","n15349"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"rice","examples":[{"text":"والوجه الآخر إن يقطع له الأرض أمشارا أمشارا ويدخل فيها الماء ويقام فيها مقدار شبرة ثم ينثر الحب عليه نثرا وإذا شربت الأرض ذلك الماء غطي الرز برقيق التراب ينثر علبه بالأيادي حتى إذا مضت ساعات وتندى التراب الذي غطي به فليقام الماء في تلك المشارات فياما دائما متّصلا","english":"And the other way [of transplanting rice] is when the earth is cut into divisions and water is introduced into it to stand a handspan high, then the seeds are strewn onto it, and when the earth is soaked by this water the rice is covered with sprinkled soil strewn onto it by the hands until some hours have passed and the soil which has been strewn on it is damp too, and the water shall stand in these beds continuously and without intermission."}]},{"pos":"verb","gloss":"to insert, to drive in"},{"pos":"noun","gloss":"verbal noun of رَزَّ (razza) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"inserting, driving in"},{"pos":"noun","gloss":"a faint sound, like that which you can hear from a distance"}]},"etymology":{"source":"wiktextract","text":"Etymology tree\nProto-Indo-Iranian *wriHǰʰíš\nProto-Iranian *wriHǰíš\nProto-Iranian *wrinǰišder.\nAncient Greek ὄρυζα (óruza)bor.\nArabic رز\nBorrowed from Aramaic אֲרוּזָא (ʔăruzzā) / ܐܘܪܘܙܐ (ʔuruzzā), ܪܘܙܐ (rūzā). Doublet of بِرِنْج (birinj).\n\nbears resemblance to Aramaic רָזָ֥א (rāzā)."},"ipa":["/ruzz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15348","headword_ar":"رُزٌّ","root":"rz","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aruz~N","text_ar":"اَرُزٌّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Rice:"},{"kind":"text","text":"see the latter word, in art."},{"kind":"arabic","text_bw":"Arz","text_ar":"ارز"},{"kind":"text","text":"]. (S, K.)"}],"source_refs":[]},{"entry_id":"n15349","headword_ar":"رِزٌّ","root":"rz","body":[{"kind":"italic_en","text":"A piercing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"pain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and rumbling"},{"kind":"text","text":"in the belly: (A:) or"},{"kind":"italic_en","text":"pain"},{"kind":"text","text":"in the belly; as also ↓"},{"kind":"arabic","text_bw":"riz~iyzaY","text_ar":"رِزِّيزَى","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"pain, and pressure of the feces:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"pressure and motion of the feces"},{"kind":"text","text":"in the belly, (Kt, Mgh, TA,)"},{"kind":"italic_en","text":"in the effort to pass forth, so that the person who feels it wants to enter the privy; whether it be with a rumbling or without:"},{"kind":"text","text":"(Kt, TA:) or"},{"kind":"italic_en","text":"a sound of rumbling or the like"},{"kind":"text","text":"in the belly. (As, Mgh, * TA.) You say,"},{"kind":"arabic","text_bw":"wajadotu","text_ar":"وَجَدْتُ"},{"kind":"arabic","text_bw":"fiY baToniY riz~FA","text_ar":"فِى بَطْنِى رِزًّا"},{"kind":"text","text":"(As, S, A)"},{"kind":"italic_en","text":"I felt in my belly a piercing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"pain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and rumbling:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"a pain:"},{"kind":"text","text":"(As, S: expl. in the KL by the Pers. word"},{"kind":"arabic","text_bw":"darod","text_ar":"دَرْد"},{"kind":"text","text":":) as also ↓"},{"kind":"arabic","text_bw":"riz~iyzaY","text_ar":"رِزِّيزَى","orth_type":"arrow"},{"kind":"text","text":": (As, S:) or"},{"kind":"italic_en","text":"pain, and pressure of the feces;"},{"kind":"text","text":"&c. (TA.) ―         -b2-  [Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"A vehement burning in the mouth"},{"kind":"text","text":"of a camel,"},{"kind":"italic_en","text":"arising from thirst, with pain."},{"kind":"text","text":"(TA.) ―         -b3-  Also"},{"kind":"italic_en","text":"A low sound:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"any sound that is not vehement:"},{"kind":"text","text":"(A 'Obeyd, TA:) or"},{"kind":"italic_en","text":"a sound that one hears from afar;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"riz~iyzaY","text_ar":"رِزِّيزَى","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"a sound that one hears but knows not what it is:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a sound in a more common sense;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"vehement or slight:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a sound;"},{"kind":"text","text":"as of thunder &c.: (S:) or the"},{"kind":"italic_en","text":"sound of thunder;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"raziyzN","text_ar":"رَزِيزٌ","orth_type":"arrow"},{"kind":"text","text":", [in measure] like"},{"kind":"arabic","text_bw":"A^amiyrN","text_ar":"اَمِيرٌ"},{"kind":"text","text":": or the former has a more general application: and ↓"},{"kind":"arabic","text_bw":"A_iroziyzN","text_ar":"اـِرْزِيزٌ","orth_type":"arrow"},{"kind":"text","text":"[in like manner] signifies"},{"kind":"italic_en","text":"a sound:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"thunder:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"riz~N","text_ar":"رِزٌّ"},{"kind":"text","text":"also signifies the"},{"kind":"italic_en","text":"braying"},{"kind":"text","text":"of a stallion-camel. (K, * TA.)"}],"source_refs":["A","S","TA","Kt","Mgh","As","K"]}]},"classical_definitions":null}