{"lemma":"شَقا","slug":"شَقا","root":"ش.ق.#","root_slug":"ش-ق-_","root_link":"/words/roots/ش-ق-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَقَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَقَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَقَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَقَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَقَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَقا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَقَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَقَوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَقَوْا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَقَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَشْق","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَشْقُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُشْقَى","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَشْقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَشْقِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَشْقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","fo