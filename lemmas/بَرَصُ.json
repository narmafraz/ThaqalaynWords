nt species thereof termed “leuce;”"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain disease,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"well known,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"which is a whiteness;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"a whiteness incident in the skin;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"a whiteness which appears upon the exterior of the body, by reason of a corrupt state of constitution."},{"kind":"text","text":"(A, K.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"What has become white, in a beast, in consequence of his being bitten."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","TA"]}]}}