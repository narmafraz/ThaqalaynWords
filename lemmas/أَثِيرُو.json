{"lemma":"أَثِيرُو","slug":"أَثِيرُو","root":"#.ث.ر","root_slug":"_-ث-ر","root_link":"/words/roots/_-ث-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n206"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AB%D9%90%D9%8A%D8%B1%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"air, ether"}]},"etymology":{"source":"wiktextract","text":"Phono-semantic matching of Ancient Greek αἰθήρ (aithḗr, “upper air”)."},"ipa":["/ʔa.θiːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n206","headword_ar":"اَثِيرٌ","root":"Avr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^avarapN","text_ar":"اَثَرَةٌ"},{"kind":"text","text":". ―         -b2-  ["},{"kind":"italic_en","text":"That makes a large footprint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"daAb~apN A^aviyarpN","text_ar":"دَابَّةٌ اَثِيَرةٌ"},{"kind":"italic_en","text":"A beast that makes a large footprint upon the ground with its hoof,"},{"kind":"text","text":"(AZ, S, M, K,) or"},{"kind":"italic_en","text":"with its soft foot, such as that of the camel."},{"kind":"text","text":"(AZ, S.) ―         -b3-  A man"},{"kind":"italic_en","text":"possessing power and authority; honoured:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^uvaraA='u","text_ar":"اُثَرَا=ءُ"},{"kind":"text","text":": fem."},{"kind":"arabic","text_bw":"A^aviyrapN","text_ar":"اَثِيرَةٌ"},{"kind":"text","text":". (M.) ―         -b4-"},{"kind":"arabic","text_bw":"fulaAnN A^aviyriY","text_ar":"فُلَانٌ اَثِيرِى"},{"kind":"italic_en","text":"Such a one is my particular friend:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"is the person wh