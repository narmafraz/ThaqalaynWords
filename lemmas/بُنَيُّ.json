;) [the"},{"kind":"italic_en","text":"cyprinus Bynni"},{"kind":"text","text":"of Forskål; described by him in his Descr. Anim. p. 71;] it is"},{"kind":"italic_en","text":"white,"},{"kind":"text","text":"and is"},{"kind":"italic_en","text":"the best kind"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of fish"},{"kind":"text","text":"], and"},{"kind":"italic_en","text":"abundant in the Nile."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n3350","headword_ar":"بُنًى","root":"bnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"binaA='N","text_ar":"بِنَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n3351","headword_ar":"بِنًى","root":"bnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"binaA='N","text_ar":"بِنَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n3361","headword_ar":"بُنَىٌّ","root":"bnY","body":[{"kind":"text","text":", [said to be] originally"},{"kind":"arabic","text_bw":"bunayowN","text_ar":"بُنَيْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"A little son;"},{"kind":"text","text":"[used as a term of endearment;] (Msb;) dim. of"},{"kind":"arabic","text_bw":"AibonN","text_ar":"اِبْنٌ"},{"kind":"text","text":". (S, Mgh, Msb.) You say,"},{"kind":"arabic","text_bw":"yaA bunaY~i","text_ar":"يَا بُنَىِّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaA bunaY~a","text_ar":"يَا بُنَىَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O my little son,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"O my child"},{"kind":"text","text":"], with kesr to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and with fet-h also; like as you say,"},{"kind":"arabic","text_bw":"yaA A^abati","text_ar":"يَا اَبَتِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaA A^abata","text_ar":"يَا اَبَتَ"},{"kind":"text","text":"[which see in art."},{"kind":"arabic","text_bw":"Abw","text_ar":"ابو"},{"kind":