":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْتَشِيط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n23511"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%B4%D8%A7%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to boil with rage, to be seething","examples":[{"text":"رَأَيْتُهُ يَسْتَشْطُ غَضَبًا عِنْدَمَا أُخْبِرُوهُ بِفَشَل الْمَشْرُوع الَّذِي عَمِلَ عَلَيْهِ لِأَشْهُر.","english":"I saw him raging when they informed him about the failure of the project he had worked on for months."}]},{"pos":"verb","gloss":"to become angry"},{"pos":"verb","gloss":"to fight"},{"pos":"verb","gloss":"to fly briskly, to flutter (of a bird)"},{"pos":"verb","gloss":"to overdo"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23511","headword_ar":"استشاط","root":"$yT","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became inflamed by anger;"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"against him:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"he became as though he were inflamed in his anger;"},{"kind":"text","text":"accord. to As, from"},{"kind":"arabic","text_bw":"mi$oyaATN","text_ar":"مِشْيَاطٌ"},{"kind":"text","text":"as applied to a she-camel: (S, TA:) [or]"},{"kind":"italic_en","text":"he burned, and became inflamed, by vehement anger."},{"kind":"text","text":"(TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"became brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharp;"},{"kind":"text","text":"(K, * TA;)"},{"kind":"italic_en","text":"he burned;"},{"kind":"text","text":"(TA;)"},{"kind":"arabic","text_bw":"mina AlA^amori","text_ar":"مِنَ الاَمْرِ"},{"kind":"italic_en","text":"by reason of the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(K, TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a pigeon)"},{"kind":"italic_en","text":"flew briskly."},{"kind":"text","text":"(K, TA.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"He sought to be slain"},{"kind":"text","text":"in war or fight. (TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"He became at the point of destruction."},{"kind":"text","text":"(TA.) ―         -b6-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"became fat:"},{"kind":"text","text":"(S, TA:) [as though he desired, or demanded, that he should be slaughtered, and that his flesh should be distributed:] or"},{"kind":"italic_en","text":"fatness spread in him."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","S"]}]},"classical_definitions":null}