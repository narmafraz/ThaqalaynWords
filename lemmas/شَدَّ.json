fs","form":"تَشْدِد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَشْدُد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشِدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشِدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشُدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشُدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشِدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشِدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشُدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشُدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشِدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشِدُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشُدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشُدُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْدِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَشْدُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَشِدّ","in_corpus":true,"count":121,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِدّ","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشُدّ","in_corpus":true,"count":121,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشُدّ","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شَدَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَدَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":327,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n21907"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become firm, solid, hard, strong","tags":["intransitive"]},{"pos":"verb","gloss":"to make firm, solid, hard, strong; to strengthen, solidify, harden","tags":["transitive"],"examples":[{"text":"شَدَّ قَبْضَتَيْهِ","english":"to clench one's fists"}]},{"pos":"verb","gloss":"to tighten, draw taut","tags":["transitive"]},{"pos":"verb","gloss":"to tense (muscles)","tags":["transitive"]},{"pos":"verb","gloss":"to fasten, tie, bind","tags":["transitive"]},{"pos":"verb","gloss":"to press","tags":["transitive"]}]},"etymology":null,"ipa":["/ʃad.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21907","headword_ar":"شَدَّ","root":"$d","body":[{"kind":"text","text":", as an intrans. verb, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$id~apN","text_ar":"شِدَّةٌ"},{"kind":"text","text":": see 8; and see also"},{"kind":"arabic","text_bw":"$id~apN","text_ar":"شِدَّةٌ"},{"kind":"text","text":". ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"la$ad~a maA","text_ar":"لَشَدَّ مَا"},{"kind":"text","text":"is an expression used in the same sense as"},{"kind":"arabic","text_bw":"laEaz~a maA","text_ar":"لَعَزَّ مَا"},{"kind":"text","text":"(A and K in art."},{"kind":"arabic","text_bw":"Ez","text_ar":"عز"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"laHaq~a maA","text_ar":"لَحَقَّ مَا"},{"kind":"text","text":": (A and TA in that art.:) [and in like manner without the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":": thus] one says,"},{"kind":"arabic","text_bw":"$ad~a maA A^an~aka *aAhibN","text_ar":"شَدَّ مَا اَنَّكَ ذَاهِبٌ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Haq~a A^an~aka *aAhibN","text_ar":"حَقَّ اَنَّكَ ذَاهِبٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"It is distressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it distresses"},{"kind":"text","text":"me,"},{"kind":"italic_en","text":"that thou art going away"},{"kind":"text","text":"]: and if you please, you may consider"},{"kind":"arabic","text_bw":"$ad~a","text_ar":"شَدَّ"},{"kind":"text","text":"as similar to"},{"kind":"arabic","text_bw":"niEoma","text_ar":"نِعْمَ"},{"kind":"text","text":"; as when you say,"},{"kind":"arabic","text_bw":"niEoma AlEamalu A^an~aka taquwlu AlHaq~a","text_ar":"نِعْمَ العَمَلُ اَنَّكَ تَقُولُ الحَقَّ"},{"kind":"text","text":"[Excellent, or most excellent, is the deed, thy saying the truth]. (Sb, TA.) [And it is also used to render intensive a verb following it; as in the saying,"},{"kind":"arabic","text_bw":"la$ad~a maA","text_ar":"لَشَدَّ مَا"},{"kind":"arabic","text_bw":"A^abogaDaniY","text_ar":"اَبْغَضَنِى"},{"kind":"italic_en","text":"Much indeed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greatly indeed, did he hate me."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"$ad~a Ealayohi","text_ar":"شَدَّ عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(S, L) and"},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":"(S, L) and"},{"kind":"arabic","text_bw":"$uduwdN","text_ar":"شُدُودٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He charged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made an assault"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attack, upon him,"},{"kind":"text","text":"in war, or battle. (S, L.) You say,"},{"kind":"arabic","text_bw":"$ad~a EalaY AlEaduw~i $ad~apF","text_ar":"شَدَّ عَلَى العَدُوِّ شَدَّةً"},{"kind":"arabic","text_bw":"waAHidapF","text_ar":"وَاحِدَةً"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$ad~aAtK kaviyrapF","text_ar":"شَدَّاتٍ كَثِيرَةً"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made one charge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attack, upon the enemy,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"many charges,"},{"kind":"text","text":"&c. (L.) And"},{"kind":"arabic","text_bw":"$ad~a EalaY qironihi bisik~iynK","text_ar":"شَدَّ عَلَى قِرْنِهِ بِسِكِّينٍ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"biEaSFA","text_ar":"بِعَصًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made an assault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attack, upon his adversary, with a knife,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with a staff;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A$td~","text_ar":"اشتدّ","orth_type":"arrow"},{"kind":"text","text":". (Mgh.) And"},{"kind":"arabic","text_bw":"$ad~a Al*~iy^obu EalaY Alganami","text_ar":"شَدَّ الذِّيْبُ عَلَى الغَنَمِ"},{"kind":"italic_en","text":"The wolf asaulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attacked, the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats."},{"kind":"text","text":"(L.) In the phrase,"},{"kind":"arabic","text_bw":"$ad~uwA AlA_igaArapa","text_ar":"شَدُّوا الاـِغَارَةَ"},{"kind":"text","text":", the meaning is"},{"kind":"arabic","text_bw":"$ad~uwA liloA_igaArapi","text_ar":"شَدُّوا لِلْاـِغَارَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They made a charge for the purpose of a sudden attack"},{"kind":"text","text":"upon an enemy, or"},{"kind":"italic_en","text":"a predatory incursion"},{"kind":"text","text":"]; and therefore"},{"kind":"arabic","text_bw":"AlAgArp","text_ar":"الاغارة"},{"kind":"text","text":"is put in the accus. case, not as an objective complement. (Ham p. 8.) ―         -b4-"},{"kind":"arabic","text_bw":"$ad~a","text_ar":"شَدَّ"},{"kind":"text","text":", (S,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":", (S, L, K,) also signifies"},{"kind":"italic_en","text":"He ran;"},{"kind":"text","text":"(S, L, * K; *) and so ↓"},{"kind":"arabic","text_bw":"A$td~","text_ar":"اشتدّ","orth_type":"arrow"},{"kind":"text","text":". (S, L, K.)"},{"kind":"arabic","text_bw":"rub~a $ad~K fiY","text_ar":"رُبَّ شَدٍّ فِى"},{"kind":"arabic","text_bw":"Alkurozi","text_ar":"الكُرْزِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Many a run is in the sack"},{"kind":"text","text":"] is a prov., originating from the fact that a man riding a pregnant mare was pursued by an enemy, and she cast her foal, which ran with its mother, whereupon the horseman alighted, and carried it off in a sack; and the enemy overtook him, and said to him, “Throw to me the foal;” and he replied in these words, meaning that the foal was of generous race: it is applied to him whose internal, or intrinsic, qualities are commended. (Meyd.) And one says,"},{"kind":"arabic","text_bw":"$ad~a fiY AlEadowi","text_ar":"شَدَّ فِى العَدْوِ"},{"kind":"text","text":", (A, Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"A$td~","text_ar":"اشتدّ","orth_type":"arrow"},{"kind":"text","text":"; (A, Mgh, L;)"},{"kind":"italic_en","text":"He hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick, in running:"},{"kind":"text","text":"(Mgh, L:) and"},{"kind":"arabic","text_bw":"$ad~a AlA_iHoDaAra","text_ar":"شَدَّ الاـِحْضَارَ"},{"kind":"text","text":"[meaning the same]. (S in art."},{"kind":"arabic","text_bw":"Afr","text_ar":"افر"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"$ad~a Aln~ahaAru","text_ar":"شَدَّ النَّهَارُ"},{"kind":"text","text":", (S, L,) and"},{"kind":"arabic","text_bw":"AlD~uHaY","text_ar":"الضُّحَى"},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":"; (L, K; but in the latter,"},{"kind":"arabic","text_bw":"Aln~aAr","text_ar":"النَّار"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Aln~ahaAr","text_ar":"النَّهَار"},{"kind":"text","text":"; TA;) and ↓"},{"kind":"arabic","text_bw":"A$td~","text_ar":"اشتدّ","orth_type":"arrow"},{"kind":"text","text":"; (L;)"},{"kind":"italic_en","text":"The day,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the morning, became advanced, the sun being high."},{"kind":"text","text":"(S, * L, K. *) [See also"},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":"below.]       -A2-"},{"kind":"arabic","text_bw":"$ad~ahu","text_ar":"شَدَّهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, L, Msb) and"},{"kind":"text","text":", the latter anomalous, for the aor. of a trans. verb of this class, of the measure"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":", should be"},{"kind":"text","text":"only, and that of an intrans. verb of the same class and measure should be"},{"kind":"text","text":", and this is the only instance, or almost the only one, of its kind, with both of these forms of aor., except"},{"kind":"arabic","text_bw":"Eal~a","text_ar":"عَلَّ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"bat~a","text_ar":"بَتَّ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"nam~a","text_ar":"نَمَّ"},{"kind":"arabic","text_bw":"AlHadiyva","text_ar":"الحَدِيثَ"},{"kind":"text","text":", but there is one trans. verb of the same class having the latter form of aor. only, namely,"},{"kind":"arabic","text_bw":"Hab~a","text_ar":"حَبَّ"},{"kind":"text","text":", (Fr, S, L,) inf. n."},{"kind":"arabic","text_bw":"$ad~N","text_ar":"شَدٌّ"},{"kind":"text","text":", (L, Msb, K,)"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it, hard;"},{"kind":"text","text":"used in relation to substances and attributes: (L:)"},{"kind":"italic_en","text":"he made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, firm, compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"strong, powerful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forcible; vigorous, robust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sturdy;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aHokamahu","text_ar":"اَحْكَمَهُ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"qaw~aAhu","text_ar":"قَوَّاهُ"},{"kind":"text","text":"; (S, A, L, K; *) as also ↓"},{"kind":"arabic","text_bw":"$d~dhu","text_ar":"شدّدهُ","orth_type":"arrow"},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"ta$odiydN","text_ar":"تَشْدِيدٌ"},{"kind":"text","text":",] i. e. as syn. with"},{"kind":"arabic","text_bw":"AHkmhu","text_ar":"احكمهُ"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"qw~Ahu","text_ar":"قوّاهُ"},{"kind":"text","text":": (S, A, L:)"},{"kind":"italic_en","text":"he bound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tied, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, firmly, fast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^awovaqahu","text_ar":"اَوْثَقَهُ"},{"kind":"text","text":": [which may also be meant to convey the signification immediately preceding this last:] (S, L, Msb, K:) and [simply]"},{"kind":"italic_en","text":"he tied, bound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made fast, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"rabaTahu","text_ar":"رَبَطَهُ"},{"kind":"text","text":". (S and Msb and K &c. in art."},{"kind":"arabic","text_bw":"rbT","text_ar":"ربط"},{"kind":"text","text":".) One says,"},{"kind":"arabic","text_bw":"$ad~a EaDudahu","text_ar":"شَدَّ عَضُدَهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"He"},{"kind":"page_break","n":1518},{"kind":"italic_en","text":"strengthened"},{"kind":"text","text":"["},{"kind":"italic_en","text":"his fore arm,"},{"kind":"text","text":"or perhaps"},{"kind":"italic_en","text":"his upper arm,"},{"kind":"text","text":"but the former is app. here meant]. (S, L.) And"},{"kind":"arabic","text_bw":"$ad~a EalaY yadihi","text_ar":"شَدَّ عَلَى يَدِهِ"},{"kind":"italic_en","text":"He strengthened him,"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"his arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and aided him."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"$ad~a","text_ar":"شَدَّ"},{"kind":"arabic","text_bw":"A@ll~`hu mulokahu","text_ar":"ا@للّٰهُ مُلْكَهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"$ad~adahu","text_ar":"شَدَّدَهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"God strengthened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may God strengthen, his dominion."},{"kind":"text","text":"(S, L. [See also a similar ex. voce"},{"kind":"arabic","text_bw":"A^azorN","text_ar":"اَزْرٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"$ad~a AlEuqodapa","text_ar":"شَدَّ العُقْدَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He tied firmly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he pulled tight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tightened, the knot"},{"kind":"text","text":"], (A, Mgh, Msb,) and"},{"kind":"arabic","text_bw":"AlwavaAqa","text_ar":"الوَثَاقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the bond"},{"kind":"text","text":"]. (Kur xlvii. 4.) [And"},{"kind":"arabic","text_bw":"$ad~a Ald~aAb~apa","text_ar":"شَدَّ الدَّابَّةَ"},{"kind":"italic_en","text":"He bound the saddle on the beast:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"daliylN","text_ar":"دَلِيلٌ"},{"kind":"text","text":".]"},{"kind":"arabic","text_bw":"$ad~u Alr~iHaAli","text_ar":"شَدُّ الرِّحَالِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"The binding of the camels' saddles"},{"kind":"text","text":"upon their backs] is a metonymical phrase for (tropical:)"},{"kind":"italic_en","text":"the going a journey."},{"kind":"text","text":"(Mgh, Msb.) And"},{"kind":"arabic","text_bw":"$ad~u Almiy^ozari","text_ar":"شَدُّ المِيْزَرِ"},{"kind":"text","text":", occurring in a trad., [lit."},{"kind":"italic_en","text":"The binding of the waist-wrapper"},{"kind":"text","text":"upon the waist] is a metonymical phrase for (tropical:)"},{"kind":"italic_en","text":"the avoiding of women:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the exerting oneself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employing oneself vigorously"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laboriously, in work:"},{"kind":"text","text":"or for both of these together. (L.)"},{"kind":"arabic","text_bw":"maA A^amoliku $ad~FA walaA A_iroxaA='F","text_ar":"مَا اَمْلِكُ شَدًّا وَلَا اـِرْخَا=ءً"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"I possess not power to tighten nor to slacken"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"I am not able to do anything."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"$ad~ahu","text_ar":"شَدَّهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He pressed, compressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"squeezed, it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he pulled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strained, it."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"waA@$odudo EalaY","text_ar":"وَا@شْدُدْ عَلَى"},{"kind":"arabic","text_bw":"quluwbihimo","text_ar":"قُلُوبِهِمْ"},{"kind":"text","text":", in the Kur [x. 88], means"},{"kind":"italic_en","text":"And put Thou a seal upon their hearts,"},{"kind":"text","text":"so that they may not heed admonition, nor be disposed, or directed, to that which is good. (L.)       -A3-"},{"kind":"arabic","text_bw":"A^a$ad~u laqado kaAna ka*aA","text_ar":"اَشَدُّ لَقَدْ كَانَ كَذَا"},{"kind":"text","text":", as also"},{"kind":"arabic","text_bw":"A^a$adu","text_ar":"اَشَدُ"},{"kind":"text","text":"without teshdeed, means"},{"kind":"arabic","text_bw":"A^a$ohadu","text_ar":"اَشْهَدُ"},{"kind":"text","text":"[q. v.]: (K:) a strange saying. (TA.)"}],"source_refs":["S","L","TK","K","A","Mgh","Msb","Fr"]}]}}