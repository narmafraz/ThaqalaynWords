{"role":"present_2mp","form":"تُفارِقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفارِقْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفارِق","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفارِق","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفارِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفارِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفارِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفارِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفارِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفارِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفارِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فارَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فارَقْتُ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفارِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفارِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":40,"cross_references":{"qac":{"found":true,"lemma_key":"فارَقَ","root":"فرق","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n33680"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D8%B1%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to separate oneself from","tags":["transitive"]},{"pos":"verb","gloss":"to withdraw from, to depart from","tags":["transitive"]},{"pos":"verb","gloss":"to leave, to forsake, to abandon","tags":["transitive"]},{"pos":"noun","gloss":"a difference","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Compare فَرَقَ (faraqa, “to separate”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33680","headword_ar":"فَارِقٌ","root":"frq","body":[{"kind":"text","text":"[act. part. n. of"},{"kind":"arabic","text_bw":"faraqa","text_ar":"فَرَقَ"},{"kind":"text","text":", q. v.]."},{"kind":"arabic","text_bw":"AlfaAriqaAtu","text_ar":"الفَارِقَاتُ"},{"kind":"text","text":", mentioned in the Kur lxxvii. 4, means"},{"kind":"italic_en","text":"Those"},{"kind":"text","text":"angels"},{"kind":"italic_en","text":"that descend with what makes a distinction between truth and falsity:"},{"kind":"text","text":"(Fr, O, K:) or"},{"kind":"italic_en","text":"that distinguish between that which is allowable and that which is forbidden:"},{"kind":"text","text":"(Th, TA:) or"},{"kind":"italic_en","text":"that make a distinction between things according as God has commanded them."},{"kind":"text","text":"(Er-Rághib, TA.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"faAriqN","text_ar":"فَارِقٌ"},{"kind":"text","text":", A she-camel, and a she-ass,"},{"kind":"italic_en","text":"in consequence of her being taken with the pains of parturition, going away at random in the land;"},{"kind":"text","text":"(S, O, K;) and so"},{"kind":"arabic","text_bw":"faAriqapN","text_ar":"فَارِقَةٌ"},{"kind":"text","text":", as in the “ Mufradát: ” or a she-camel"},{"kind":"italic_en","text":"that separates herself from her mate, and brings forth alone:"},{"kind":"text","text":"or a she-camel"},{"kind":"italic_en","text":"that runs"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ta$otad~u","text_ar":"تَشْتَدُّ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and then casts her young one by reason of the pain that befalls her;"},{"kind":"text","text":"thus expl. by IAar: (TA:) pl."},{"kind":"arabic","text_bw":"fawaAriqu","text_ar":"فَوَارِقُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fur~aqN","text_ar":"فُرَّقٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"furuqN","text_ar":"فُرُقٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"fur~aAqN","text_ar":"فُرَّاقٌ"},{"kind":"text","text":", which is thus used by El-Aashà, applied to she-camels, and ↓"},{"kind":"arabic","text_bw":"mafaAriyqu","text_ar":"مَفَارِيقُ","orth_type":"arrow"},{"kind":"text","text":"is [an irreg. pl.] likewise applied to she-camels as syn. with"},{"kind":"arabic","text_bw":"fawaAriqu","text_ar":"فَوَارِقُ"},{"kind":"text","text":". (TA.) ―         -b3-  And hence, as being likened to such a she-camel, applied to a cloud ("},{"kind":"arabic","text_bw":"saHaAbapN","text_ar":"سَحَابَةٌ"},{"kind":"text","text":") as meaning (tropical:)"},{"kind":"italic_en","text":"Apart from the other clouds;"},{"kind":"text","text":"(S, O, K;)"},{"kind":"italic_en","text":"cut off from the main aggregate of the clouds:"},{"kind":"text","text":"(ISd, TA:) or an"},{"kind":"italic_en","text":"isolated"},{"kind":"text","text":"cloud,"},{"kind":"italic_en","text":"that will not break its promise"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of giving rain"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and sometimes preceded by thunder and lighting:"},{"kind":"text","text":"(TA:) thus applied, also, having for pl."},{"kind":"arabic","text_bw":"fawaAriqu","text_ar":"فَوَارِقُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fur~aqN","text_ar":"فُرَّقٌ"},{"kind":"text","text":"[&c.]. (O.)"}],"source_refs":["Fr","O","K","Th","TA","S","ISd"]}]}}