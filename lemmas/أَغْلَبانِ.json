{"lemma":"أَغْلَبانِ","slug":"أَغْلَبانِ","root":"غ.ل.ب","root_slug":"غ-ل-ب","root_link":"/words/roots/غ-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n32203"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%BA%D9%92%D9%84%D9%8E%D8%A8%D8%A7%D9%86%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32203","headword_ar":"اَغَْلَبُ","root":"glb","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, overcoming"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conquering"},{"kind":"text","text":"&c.: fem."},{"kind":"arabic","text_bw":"galobaA='u","text_ar":"غَلْبَا=ءُ"},{"kind":"text","text":": and pl."},{"kind":"arabic","text_bw":"gulobN","text_ar":"غُلْبٌ"},{"kind":"text","text":"]. One says"},{"kind":"arabic","text_bw":"qabiylapN galobaA='u","text_ar":"قَبِيلَةٌ غَلْبَا=ءُ"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"most overcoming"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"mighty, resistive, tribe."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eiz~apN galobaA='u","text_ar":"عِزَّةٌ غَلْبَا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Most overpowering might"},{"kind":"text","text":"]. (S.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"gaAlibN","text_ar":"غَالِبٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"Thick-necked,"},{"kind":"text","text":"(S, TA,) applied to a man: (S:) [or"},{"kind":"italic_en","text":"thick and short in the neck:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thick and inclining in the neck:"},{"kind":"text","text":"(see 1, last sentence:)] fem."},{"kind":"arabic","text_bw":"galobaA='u","text_ar":"غَلْبَا=ءُ"},{"kind":"text","text":", applied to a she-camel: and pl."},{"kind":"arabic","text_bw":"gulobN","text_ar":"غُلْبٌ"},{"kind":"text","text":". (TA.) And"},{"kind":"italic_en","text":"Thick,"},{"kind":"text","text":"applied to a neck. (Lh, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HadiyqapN galobaA='u","text_ar":"حَدِيقَةٌ غَلْبَا=ءُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"A garden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walled garden,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"of tangled and luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant and dense, trees:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"of compact and dense trees;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mugolawolibapN","text_ar":"مُغْلَوْلِبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) In the phrase"},{"kind":"arabic","text_bw":"HadaAy^iqa gulobFA","text_ar":"حَدَايِقَ غُلْبًا"},{"kind":"text","text":"in the Kur [lxxx. 30], the epithet is expl by Bd as meaning (tropical:)"},{"kind":"italic_en","text":"Large."},{"kind":"text","text":"(TA.) And the fem. is applied to a [mountain, or hill, such as is termed]"},{"kind":"arabic","text_bw":"haDobap","text_ar":"هَضْبَة"},{"kind":"text","text":", (S, TA,) meaning (tropical:)"},{"kind":"italic_en","text":"Lofty and great."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlA^agolabu","text_ar":"الاَغْلَبُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The lion"},{"kind":"text","text":"[app. because of the thickness of his neck]. (K.)"}],"source_refs":["S","TA"]}]},"classical_definitions":null}