"مَتَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mat~N","text_ar":"مَتٌّ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"matomata","text_ar":"مَتْمَتَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"matomatapN","text_ar":"مَتْمَتَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He sought to bring himself near"},{"kind":"text","text":"[to another], or"},{"kind":"italic_en","text":"to approach"},{"kind":"text","text":"[to him], or"},{"kind":"italic_en","text":"to gain access"},{"kind":"text","text":"[to him], or"},{"kind":"italic_en","text":"to advance himself in"},{"kind":"text","text":"[his]"},{"kind":"italic_en","text":"favour,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tawas~ala","text_ar":"تَوَسَّلَ"},{"kind":"text","text":",) by relationship, (S, K,) or by what is termed"},{"kind":"arabic","text_bw":"Huromap","text_ar":"حُرْمَة"},{"kind":"text","text":", [see"},{"kind":"arabic","text_bw":"maAt~apN","text_ar":"مَاتَّةٌ"},{"kind":"text","text":", below,] or by other means: (TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"tawaS~al","text_ar":"تَوَصَّل"},{"kind":"text","text":"[which seems here to signify nearly or exactly the same as"},{"kind":"arabic","text_bw":"tws~l","text_ar":"توسّل"},{"kind":"text","text":"] by relationship, or by what is termed"},{"kind":"arabic","text_bw":"daAl~ap","text_ar":"دَالَّة"},{"kind":"text","text":"[or blandishment, &c.] (L.) ―         -b5-"},{"kind":"arabic","text_bw":"mat~a A_ilayohi biAl$~aYo'i","text_ar":"مَتَّ اـِلَيْهِ بِالشَّىْءِ"},{"kind":"italic_en","text":"He sought to bring himself near to him, &c.,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tws~l Alyh","text_ar":"توسّل اليه"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"by the thing."},{"kind":"text","text":"(M.) ―         -b6-  ↓"},{"kind":"arabic","text_bw":"matomata","text_ar":"مَتْمَتَ","orth_type":"arrow"},{"kind":"italic_en","text":"He sought to bring himself near, &c.,"},{"kind":"text","text":"[to another,] by affection, or love, or by relationship. (IAar.) ―         -b7-"},{"kind":"arabic","text_bw":"laA tamut~aAoni","text_ar":"لَا تَمُتَّاْنِ"},{"kind":"arabic","text_bw":"A_ilaY All~`hi biHabolK walaA tamud~aAni A_ilayohi bisababK","text_ar":"اـِلَى اللّٰهِ بِحَبْلٍ وَلَا تَمُدَّانِ اـِلَيْهِ بِسَبَبٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Ye two shall not approach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtain access, to God by means of any friend, nor shall ye do so by means of any relation"},{"kind":"text","text":"]. A trad. (TA.) ―         -b8-"},{"kind":"arabic","text_bw":"mat~ahu","text_ar":"مَتَّهُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Talaba A_ilayohi AlmataAta","text_ar":"طَلَبَ اـِلَيْهِ المَتَاتَ"},{"kind":"text","text":", q. v. infra. (L.)"}],"source_refs":["S","K","TA"]}]}}