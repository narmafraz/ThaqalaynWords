: false, "count": null, "asp": "i", "per": "3", "gen": "f", "num": "p"}, {"role": "present_1ms", "form": "أَمُتّ", "in_corpus": true, "count": 1, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَمُتّ", "in_corpus": true, "count": 2, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "مَتَتُّ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}, {"role": "past_1mp", "form": "مَتَتْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 144, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["verb"], "has_etymology": true, "sense_count": 1}, "lanes": {"found": true, "entry_ids": ["n38191"], "search_url": "https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AA%D9%8E%D9%91"}}, "translations": {"en": "to extend", "fa": "گسترش دادن", "ur": "پھیلانا", "tr": "uzatmak", "id": "memanjangkan", "bn": "বিস্তার করা", "es": "extender", "fr": "étendre", "de": "erstrecken", "ru": "растягивать", "zh": "延伸"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to spread; extend; stretch"}]}, "etymology": {"source": "wiktextract", "text": "Compare مَدَّ (madda), مَطَّ (maṭṭa)."}, "ipa": ["/mat.ta/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n38191", "headword_ar": "مَتَّ", "root": "mt", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "mat~N", "text_ar": "مَتٌّ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He extended,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stretched out,"}, {"kind": "text", "text": "(S, K,) a rope, &c. (TA);"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "mad~a", "text_ar": "مَدَّ"}, {"kind": "text", "text": "(S, K) and"}, {"kind": "arabic", "text_bw": "maT~a", "text_ar": "مَطَّ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "magaTa", "text_ar": "مَغَطَ"}, {"kind": "text", "text": ". (TA.) ―         -b2-"}, {"kind": "arabic", "text_bw": "mat~a", "text_ar": "مَتَّ"}, {"kind": "arabic", "text_bw": "fiY Als~ayori", "text_ar": "فِى السَّيْرِ"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "mad~a", "text_ar": "مَدَّ"}, {"kind": "text", "text": ". (TA.) ―         -b3-"}, {"kind": "arabic", "text_bw": "mat~a", "text_ar": "مَتَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "mat~N", "text_ar": "مَتٌّ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He drew"}, {"kind": "text", "text": "[water], or"}, {"kind": "italic_en", "text": "drew up"}, {"kind": "text", "text": "[a bucket],"}, {"kind": "italic_en", "text": "without a pulley."}, {"kind": "text", "text": "(S, K.) ―         -b4-"}, {"kind": "arabic", "text_bw": "mat~a", "text_ar": "مَتَّ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "mat~N", "text_ar": "مَتٌّ"}, {"kind": "text", "text": "; (S, K;) and ↓"}, {"kind": "arabic", "text_bw": "matomata", "text_ar": "مَتْمَتَ", "orth_type": "arrow"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "matomatapN", "text_ar": "مَتْمَتَةٌ"}, {"kind": "text", "text": "; (K;)"}, {"kind": "italic_en", "text": "He sought to bring himself near"}, {"kind": "text", "text": "[to another], or"}, {"kind": "italic_en", "text": "to approach"}, {"kind": "text", "text": "[to him], or"}, {"kind": "italic_en", "text": "to gain access"}, {"kind": "text", "text": "[to him], or"}, {"kind": "italic_en", "text": "to advance himself in"}, {"kind": "text", "text": "[his]"}, {"kind": "italic_en", "text": "favour,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "tawas~ala", "text_ar": "تَوَسَّلَ"}, {"kind": "text", "text": ",) by relationship, (S, K,) or by what is termed"}, {"kind": "arabic", "text_bw": "Huromap", "text_ar": "حُرْمَة"}, {"kind": "text", "text": ", [see"}, {"kind": "arabic", "text_bw": "maAt~apN", "text_ar": "مَاتَّةٌ"}, {"kind": "text", "text": ", below,] or by other means: (TA:) or"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "tawaS~al", "text_ar": "تَوَصَّل"}, {"kind": "text", "text": "[which seems here to signify nearly or exactly the same as"}, {"kind": "arabic", "text_bw": "tws~l", "text_ar": "توسّل"}, {"kind": "text", "text": "] by relationship, or by what is termed"}, {"kind": "arabic", "text_bw": "daAl~ap", "text_ar": "دَالَّة"}, {"kind": "text", "text": "[or blandishment, &c.] (L.) ―         -b5-"}, {"kind": "arabic", "text_bw": "mat~a A_ilayohi biAl$~aYo'i", "text_ar": "مَتَّ اـِلَيْهِ بِالشَّىْءِ"}, {"kind": "italic_en", "text": "He sought to bring himself near to him, &c.,"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "tws~l Alyh", "text_ar": "توسّل اليه"}, {"kind": "text", "text": ",)"}, {"kind": "italic_en", "text": "by the thing."}, {"kind": "text", "text": "(M.) ―         -b6-  ↓"}, {"kind": "arabic", "text_bw": "matomata", "text_ar": "مَتْمَتَ", "orth_type": "arrow"}, {"kind": "italic_en", "text": "He sought to bring himself near, &c.,"}, {"kind": "text", "text": "[to another,] by affection, or love, or by relationship. (IAar.) ―         -b7-"}, {"kind": "arabic", "text_bw": "laA tamut~aAoni", "text_ar": "لَا تَمُتَّاْنِ"}, {"kind": "arabic", "text_bw": "A_ilaY All~`hi biHabolK walaA tamud~aAni A_ilayohi bisababK", "text_ar": "اـِلَى اللّٰهِ بِحَبْلٍ وَلَا تَمُدَّانِ اـِلَيْهِ بِسَبَبٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Ye two shall not approach,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "obtain access, to God by means of any friend, nor shall ye do so by means of any relation"}, {"kind": "text", "text": "]. A trad. (TA.) ―         -b8-"}, {"kind": "arabic", "text_bw": "mat~ahu", "text_ar": "مَتَّهُ"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "Talaba A_ilayohi AlmataAta", "text_ar": "طَلَبَ اـِلَيْهِ المَتَاتَ"}, {"kind": "text", "text": ", q. v. infra. (L.)"}], "source_refs": ["S", "K", "TA"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D9%85%D8%AA/", "headword_ar": "مت", "entries": [{"lexicon_id": "dictionary_32", "lexicon_en": "Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)", "lexicon_ar": "تكملة المعاجم العربية لرينهارت دوزي", "permalink": "https://arabiclexicon.hawramani.com/?p=53703#58b5e6", "body_html": "مت: مت: (ينبغي أن تحذف الفقرة الثالثة من فريناج ويحل محلها ما يأتي): مت: مد، ومت الحبل نزعه على غير بكرة، ومت إلى فلان بقرابة وصل إليه وتوسل (م. المحيط، فليشر على المقري 2: 632 وبريشت 157 وبدرون 245: 9 وابن خلكان 1: 384 وسلان 17)."}, {"lexicon_id": "dictionary_36", "lexicon_en": "Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)", "lexicon_ar": "المحيط في اللغة للصاحب بن عباد", "permalink": "https://arabiclexicon.hawramani.com/?p=53703#8147de", "body_html": "<span class=\"title1\">مت</span><br><span>مَتُّ: اسْمٌ أعْجَمِي. والمَتُ: المَدُّ. وتَوَصُّلٌ بقَرَابَةٍ أو دالَّةٍ يَمتُّ بها الرَّجُلُ. وماتَتُ فلاناً، أمَاتُه مُمَاتَّةً: أي أشَادُّه. وماتَتّه بالرحِمَ: سَألْته بها. والمَتُّ في القَدَحِ: مِثْلُ الفَتْلِ، وفي الغَزْلِ: سُرْعَةُ تَتَابُعِه.</span><br><span>ومتى: اسْمُ والِدِ يُوْنُسَ عليه السَّلامُ.</span><br><span>ومَتّى: لُغَةٌ في مَتَى.</span><br><span>والمَتّوْتُ من السَّمَكِ: الحَسّاس.</span>"}, {"lexicon_id": "dictionary_49", "lexicon_en": "Arabic-English Lexicon by Edward William Lane (d. 1876)", "lexicon_ar": "المعجم العربي الإنجليزي لإدوارد وليام لين", "permalink": "https://arabiclexicon.hawramani.com/?p=53703#d340d6", "body_html": "<div>مت</div><div><br></div><div>1 مَتَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَتٌّ, He extended, or stretched out, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) a rope, &amp;c. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>); <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> مَدَّ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and مَطَّ and مَغَطَ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b2:</span> مَتَّ</div><div><br></div><div>فِى السَّيْرِ <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> مَدَّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b3:</span> مَتَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَتٌّ, He drew [water], or drew up [a bucket], without a pulley. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b4:</span> مَتَّ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَتٌّ; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and ↓ مَتْمَتَ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَتْمَتَةٌ; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) He sought to bring himself near [to another], or to approach [to him], or to gain access [to him], or to advance himself in [his] favour, (تَوَسَّلَ,) by relationship, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or by what is termed حُرْمَة, [see مَاتَّةٌ, below,] or by other means: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> تَوَصَّل [which seems here to signify nearly or exactly the same as توسّل] by relationship, or by what is termed دَالَّة [or blandishment, &amp;c.] (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b5:</span> مَتَّ إِلَيْهِ بِالشَّىْءِ He sought to bring himself near to him, &amp;c., (توسّل اليه,) by the thing. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b6:</span> ↓ مَتْمَتَ He sought to bring himself near, &amp;c., [to another,] by affection, or love, or by relationship. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b7:</span> لَا تَمُتَّاْنِ</div><div><br></div><div>إِلَى اللّٰهِ بِحَبْلٍ وَلَا تَمُدَّانِ إِلَيْهِ بِسَبَبٍ [Ye two shall not approach, or obtain access, to God by means of any friend, nor shall ye do so by means of any relation]. A <abbr title=\"tradition (hadith), حَدِيْثٌ\">trad.</abbr> (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b8:</span> مَتَّهُ <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> طَلَبَ إِلَيْهِ المَتَاتَ, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr> infra. (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.)</div><div><br></div><div>3 ماتّ فُلَانًا He reminded such a one of what are termed مَوَاتّ [<abbr title=\"plural, جَمْعٌ\">pl.</abbr> of مَاتَّةٌ, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.)</div><div><br></div><div>5 تَمَتَّى, originally تَمَتَّتَ, which has not been heard, (like تَظَنَّى for تَظَنَّنَ, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> تَمَطَّى. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b2:</span> تَمَتَّى فِى الحَبْلِ He bore upon the rope in order to break it, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or to stretch it out. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See also art. متو.</div><div><br></div><div>R. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1 متمت: see 1, in two places.</div><div><br></div><div>مَتَّى <abbr title=\"dialect, لُغَةٌ\">dial.</abbr> form of مَتَى, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr> (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) It occurs in the following instances: أَلَمْ تَسْأَلِ الأَطَلَالَ مَتَّى عُهُودُهَا</div><div><br></div><div>[Didst thou not ask the remains of the dwelling, when were their times?] <abbr title=\"Abū Ḥatim al-Sijistāniī\">AHát</abbr> asked <abbr title=\"al-Aṣmaʿī\">As</abbr> respecting متّى in this hemistich, and he answered, I know not. <abbr title=\"Abū Ḥatim al-Sijistāniī\">AHát</abbr> thinks that it is for مَتَى: or that it may be for مَتًّا, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of مَتَّ; and that the meaning may be [Didst thou not ask the remains of the dwelling,] whereof the times when men were present there are (or were) long past, or distant, or remote? but he confesses that he does not know. (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.) <abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr> remarks upon it, that it is very extraordinary. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)</div><div><br></div><div>مَتَاتٌ signifies مَا يُمَتّ بِهِ; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) i. e., That whereby one seeks to bring himself near [to another], or, to approach [to him], or, to advance himself in [his] favour; or to gain access [to him]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) طَلَبَ إِلَيْهِ الَمَتاتَ [He sought the means of drawing near to him, or, of advancing himself in his favour, &amp;c.: or he sought access to him]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [See also ↓ مَاتَّة, which signifies the same.]</div><div><br></div><div>مَاتَّةٌ <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> حُرْمَةٌ and وَسِيلَةٌ: [the former signifies, Anything that is sacred or inviolable; and here, such a bond, or tie, or the like; or a quality &amp;c. to be regarded as sacred, or inviolable; or that which renders one entitled to respect and reverence: so says IbrD: the latter, a thing whereby one seeks to bring himself near, or to approach, to another, or to advance himself in his favour:] (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> مَوَاتُّ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) [See also مَتَاتٌ, which signifies the same.] </div><div><br></div><div><span class=\"sub-sense\">b2:</span> بَيْنَنَا رَحِمٌ</div><div><br></div><div>مَاتَّةٌ, i. e. قَرِيبَةٌ, Between us is a near relationship. (<abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>.)</div>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}