{"lemma":"بَعُدَ","slug":"بَعُدَ","root":"ب.ع.د","root_slug":"ب-ع-د","root_link":"/words/roots/ب-ع-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَعُدْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَعُدْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَعُدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَعُدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَعُدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَعُدَ","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَعُدَت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَعُدا","in_corpus":true,"count":14,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَعُدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَعُدُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَعُدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْعُد","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْعُدِينَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْعُدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْعُدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْعُدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْعُدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْعُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْعُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْعُد","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْعُد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْعُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْعُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْعُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْعُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْعُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْعُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْعُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَعُدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَعُدْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْعُد","in_corpus":true,"count":14,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْعُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":50,"cross_references":{"qac":{"found":true,"lemma_key":"بَعُدَ","root":"بعد","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adv","noun","prep","verb"],"has_etymology":false,"sense_count":14},"lanes":{"found":true,"entry_ids":["n2861"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B9%D9%8F%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be distant, afar, to become distant, go away (مِنْ (min) or عَنْ (ʕan) from)"},{"pos":"verb","gloss":"to die, to perish"},{"pos":"noun","gloss":"verbal noun of بَعُدَ (baʕuda) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"distance"},{"pos":"noun","gloss":"dimension"},{"pos":"noun","gloss":"absence"},{"pos":"noun","gloss":"death"},{"pos":"noun","gloss":"interval"},{"pos":"noun","gloss":"verbal noun of بَعَدَ (baʕada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of بَعِدَ (baʕida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"distance, going to a distance"},{"pos":"noun","gloss":"death"},{"pos":"prep","gloss":"after"},{"pos":"adv","gloss":"after that","examples":[{"text":"فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّينِ","english":"So what will make you deny the religion after that?"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2861","headword_ar":"بَعُدَ","root":"bEd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":"; (S, L, Msb, K;) and"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baEadN","text_ar":"بَعَدٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iboEaAdN","text_ar":"اـِبْعَادٌ"},{"kind":"text","text":", which is also trans.; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AstbEd","text_ar":"استبعد","orth_type":"arrow"},{"kind":"text","text":"; (S, K, &c.;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distant, remote, far off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aloof: he went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdrew himself, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off: he alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, himself: he stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept, aloof: contr. of"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":": (S, L:) [but"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"generally has the first of these significations; and ↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", the others, as also ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstbEd","text_ar":"استبعد","orth_type":"arrow"},{"kind":"text","text":":] it is the general opinion of the leading lexicologists that"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":", is thus used; but some deny this; and some assert that they may be employed alike, but that"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is more chaste than"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":"thus used. (TA.) [You say also, of a desert, and a tract of country, and the like,"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It extended far."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"zayodN Eani Almanozili","text_ar":"زَيْدٌ عَنِ المَنْزِلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", meaning ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Zeyd went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far, from the place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode"},{"kind":"text","text":"]. (IKt, Msb.) And"},{"kind":"arabic","text_bw":"min~iY","text_ar":"مِنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AbtEd","text_ar":"ابتعد","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tbE~d","text_ar":"تبعّد","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far, from me; he alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, himself from me; he shunned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided, me;"},{"kind":"text","text":"] (A;) and"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"arabic","text_bw":"En~Y","text_ar":"عنّى"},{"kind":"text","text":"signify the same]. (Msb in art."},{"kind":"arabic","text_bw":"k$H","text_ar":"كشح"},{"kind":"text","text":".) And ↓"},{"kind":"arabic","text_bw":"A_i*aA A^araA*a A^aHadukumo AlHaAjapi A^aboEada","text_ar":"اـِذَا اَرَاذَ اَحَدُكُمْ الحَاجَةِ اَبْعَدَ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb,) a trad., (Msb,) meaning"},{"kind":"italic_en","text":"When one of you desires to accomplish that which is needful,"},{"kind":"text","text":"(i. e. to ease nature,)"},{"kind":"italic_en","text":"he goes far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a great distance."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"fiY Alma*ohabi","text_ar":"فِى المَذْهَبِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aboEadotu","text_ar":"اَبْعَدْتُ","orth_type":"arrow"},{"kind":"text","text":", meaning ↓"},{"kind":"arabic","text_bw":"tabaAEadotu","text_ar":"تَبَاعَدْتُ","orth_type":"arrow"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"I went far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a great distance, to the place of ease,"},{"kind":"text","text":"i. e., to ease nature. (L.) ―         -b2-  ["},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"referring to a saying or the like, and an event, means"},{"kind":"italic_en","text":"It was far from being probable"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correct; it was improbable, extraordinary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strange:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"baEiydN","text_ar":"بَعِيدٌ"},{"kind":"text","text":", and see also 10:) often occurring in these senses.] And"},{"kind":"arabic","text_bw":"fiY nawoEihi","text_ar":"فِى نَوْعِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"italic_en","text":"It reached the utmost point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree, in its kind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species."},{"kind":"text","text":"(IAth.) And"},{"kind":"arabic","text_bw":"AbEd fiY Als~awomi","text_ar":"ابعد فِى السَّوْمِ"},{"kind":"italic_en","text":"He exceeded the due bounds in offering a thing for sale and demanding a price for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in bargaining for a thing."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"arabic","text_bw":"A^axa*ahu maA qaruba wa maA baEuda","text_ar":"اَخَذَهُ مَا قَرُبَ وَ مَا بَعُدَ"},{"kind":"italic_en","text":"Recent and old griefs took hold upon him:"},{"kind":"text","text":"a saying similar to"},{"kind":"arabic","text_bw":"A^axa*ahu maA qaduma wa maA Haduva","text_ar":"اَخَذَهُ مَا قَدُمَ وَ مَا حَدُثَ"},{"kind":"text","text":". (Mgh in art."},{"kind":"arabic","text_bw":"qdm","text_ar":"قدم"},{"kind":"text","text":".) ―         -b4-  ["},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is often used, agreeably with a general rule, in the manner of a verb of praise or dispraise; and in this case is commonly contracted into"},{"kind":"arabic","text_bw":"buEoda","text_ar":"بُعْدَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Husona","text_ar":"حُسْنَ"},{"kind":"text","text":"; as in the phrase, in a verse of Imrael-Keys,"},{"kind":"arabic","text_bw":"buEoda maA mutaA^am~alY","text_ar":"بُعْدَ مَا مُتَاَمَّلى"},{"kind":"text","text":"(in which"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"is redundant)"},{"kind":"italic_en","text":"Distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far distant, was the object of my contemplation!"},{"kind":"text","text":"or (as explained in the EM p. 52)"},{"kind":"italic_en","text":"how distant,"},{"kind":"text","text":"&c.!] ―         -b5-"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baEadN","text_ar":"بَعَدٌ"},{"kind":"text","text":"; (S, L, Msb, K;) and"},{"kind":"arabic","text_bw":"baEoda","text_ar":"بَعْدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":"; (L, K;) also signify"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, perished:"},{"kind":"text","text":"(S L, Msb:)"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(K:) it is the general opinion of the leading lexicologists that both these verbs are used as signifying “he perished,” and both occur in different readings of v. 98 of ch. xi. of the Kur: the former is said to be used in this sense by some of the Arabs; and the latter, by others; but some disallow the latter in this sense; and some say that the"},{"kind":"italic_en","text":"former is more"},{"kind":"text","text":"chaste than the latter thus used: (TA:) or both signify"},{"kind":"italic_en","text":"he became far distant from his home"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"native country; became a stranger,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, therefrom:"},{"kind":"text","text":"(L, TA:) or the Arabs say,"},{"kind":"arabic","text_bw":"baEida Alr~ajulu","text_ar":"بَعِدَ الرَّجُلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد"},{"kind":"text","text":", when not reviling; but when reviling, they say,"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", only. (Yoo, TA.) You say,"},{"kind":"arabic","text_bw":"laA taboEadN","text_ar":"لَا تَبْعَدٌ"},{"kind":"arabic","text_bw":"wa A_ino baEudota Ean~aY","text_ar":"وَ اـِنْ بَعُدْتَ عَنَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Mayest thou not perish though thou be distant from me!"},{"kind":"text","text":"] (A.) [And as an imprecation against a man, you say,"},{"kind":"arabic","text_bw":"baEidota","text_ar":"بَعِدْتَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Mayest thou perish!"},{"kind":"text","text":"(See the printed edition of the Ham, pp. 89 and 90, where"},{"kind":"arabic","text_bw":"baEidotaAYa hlkt","text_ar":"بَعِدْتَاىَ هلكت"},{"kind":"text","text":"is an evident mistake for"},{"kind":"arabic","text_bw":"aEidota A^aY halakota","text_ar":"َعِدْتَ اَى هَلَكْتَ"},{"kind":"text","text":".)] And"},{"kind":"arabic","text_bw":"buEodFA lahu","text_ar":"بُعْدًا لَهُ"},{"kind":"italic_en","text":"May God alienate him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estrange him, from good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity!"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"curse him!"},{"kind":"text","text":"(A, * K, TA;) i. e. may he not be pitied with respect to that which has befallen him! like"},{"kind":"arabic","text_bw":"suHoqFA lahu","text_ar":"سُحْقًا لَهُ"},{"kind":"text","text":": the most approved way being to put"},{"kind":"arabic","text_bw":"bEd","text_ar":"بعد"},{"kind":"text","text":"thus in the accus. case as an inf. n.; but the tribe of Temeem say,"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"suHoqN","text_ar":"سُحْقٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"gulaAmN lahu","text_ar":"غُلَامٌ لَهُ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is made trans. by means of [the preposition]"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":": see 4. (Msb.)"}],"source_refs":["S","L","Msb","K","TA"]}]}}