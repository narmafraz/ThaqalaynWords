%D8%A8%D9%8E%D8%B1%D9%8E%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to come forth, to appear"},{"pos":"verb","gloss":"to go out, to step out"},{"pos":"verb","gloss":"to jut out, to be prominent","tags":["also","figuratively"]},{"pos":"verb","gloss":"to stand out against, to contrast with"},{"pos":"verb","gloss":"to surpass, to excel against"},{"pos":"verb","gloss":"to accentuate, to set off, to highlight"},{"pos":"verb","gloss":"to emboss, to raise in relief"},{"pos":"verb","gloss":"to emphasize, to highlight (an issue, a theme, etc.)","tags":["figuratively"]},{"pos":"verb","gloss":"to excel, to surpass"}]},"etymology":null,"ipa":["/ba.ra.za/","/bar.ra.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2251","headword_ar":"بَرَزَ","root":"brz","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"buruwzN","text_ar":"بُرُوزٌ"},{"kind":"text","text":", (S, Msb, TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth; he issued."},{"kind":"text","text":"(S, A.)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, into the field, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open tract or country:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"did so to satisfy a want of nature:"},{"kind":"text","text":"(TS, TA:) as also, in the former sense, (K,) or in the latter, (S,) ↓"},{"kind":"arabic","text_bw":"tbr~z","text_ar":"تبرّز","orth_type":"arrow"},{"kind":"text","text":"; (S, K, TA;) and"},{"kind":"arabic","text_bw":"bariza","text_ar":"بَرِزَ"},{"kind":"text","text":"; (Sgh, TA;) and so, in the former sense, ↓"},{"kind":"arabic","text_bw":"br~z","text_ar":"برّز","orth_type":"arrow"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"taboriyzN","text_ar":"تَبْرِيزٌ"},{"kind":"text","text":"; (Har p. 510;) [and in the latter sense, ↓"},{"kind":"arabic","text_bw":"bArz","text_ar":"بارز","orth_type":"arrow"},{"kind":"text","text":"accord. to an explanation of its part. n."},{"kind":"arabic","text_bw":"mubaArizN","text_ar":"مُبَارِزٌ"},{"kind":"text","text":"in Har p. 566:] or ↓"},{"kind":"arabic","text_bw":"tbr~z","text_ar":"تبرّز","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he voided his excrement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordure."},{"kind":"text","text":"(Mgh, Msb.) You say,"},{"kind":"arabic","text_bw":"barazaA_ilaY Alqironi fiY AlHarobi","text_ar":"بَرَزَاـِلَى القِرْنِ فِى الحَرْبِ"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, into the field to his adversary in battle or war."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a man, TA, or thing, Msb, or anything, Fr,)"},{"kind":"italic_en","text":"appeared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became apparent,"},{"kind":"text","text":"(Fr, Sgh, Msb, K,)"},{"kind":"italic_en","text":"after concealment,"},{"kind":"text","text":"(Fr, K,) or"},{"kind":"italic_en","text":"after obscurity;"},{"kind":"text","text":"(Sgh;) as also"},{"kind":"arabic","text_bw":"bariza","text_ar":"بَرِزَ"},{"kind":"text","text":"(Sgh, K.) ―         -b3-  ["},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"projecting:"},{"kind":"text","text":"often used in this sense.]       -A2-"},{"kind":"arabic","text_bw":"baruza","text_ar":"بَرُزَ"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"baraAzapN","text_ar":"بَرَازَةٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"barozN","text_ar":"بَرْزٌ"},{"kind":"text","text":"q. v.: (Msb, K:) and in like manner,"},{"kind":"arabic","text_bw":"baruzato","text_ar":"بَرُزَتْ"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"barozapN","text_ar":"بَرْزَةٌ"},{"kind":"text","text":"(A.)"}],"source_refs":["S","A","Msb","K","TA","TS","Fr","Sgh"]}]}}