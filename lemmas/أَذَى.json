{"lemma":"أَذَى","slug":"أَذَى","root":"#.ذ.#","root_slug":"_-ذ-_","root_link":"/words/roots/_-ذ-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَذَى","root":"أذي","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n505","n507","n511"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B0%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to harm, to hurt, to abuse","examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا لَا تَكُونُوا كَٱلَّذِينَ آذَوْا مُوسَى فَبَرَّأَهُ ٱللَّهُ مِمَّا قَالُوا"}]}]},"etymology":null,"ipa":["/ʔaː.ðaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n505","headword_ar":"اَذِىَ","root":"A*Y","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^a*FY","text_ar":"اَذًى"},{"kind":"text","text":", (T, M, Msb, K,) in [some of] the copies of the K written"},{"kind":"arabic","text_bw":"A^a*FA","text_ar":"اَذًا"},{"kind":"text","text":", and so by IB, (TA,) and"},{"kind":"arabic","text_bw":"A^a*aA='N","text_ar":"اَذَا=ءٌ"},{"kind":"text","text":", (CK, [but not found by me in any MS. copy of the K nor in any other lexicon,]) and, accord. to IB,"},{"kind":"arabic","text_bw":"A^a*aApN","text_ar":"اَذَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^a*iy~apN","text_ar":"اَذِيَّةٌ"},{"kind":"text","text":", (TA,) or these two are simple substs.; (M, K;) and ↓"},{"kind":"arabic","text_bw":"tA^*~Y","text_ar":"تاذّى","orth_type":"arrow"},{"kind":"text","text":"; (T, S, M, Msb, K;) ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, annoyed, molested, harmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he experienced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffered, slight evil,"},{"kind":"text","text":"[i. e.,"},{"kind":"italic_en","text":"annoyance, molestation, harm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"less than what is termed"},{"kind":"arabic","text_bw":"Darar","text_ar":"ضَرَر"},{"kind":"text","text":"; (El-Khattábee;) or"},{"kind":"italic_en","text":"he experienced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffered, what was disagreeable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hateful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"in a small degree;"},{"kind":"text","text":"(K;)"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; (T, S, M, K;) [and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"italic_en","text":"from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"] ↓"},{"kind":"arabic","text_bw":"Alt~aA^a*~iY","text_ar":"التَّاَذِّى","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the being affected by what is termed"},{"kind":"arabic","text_bw":"AlA^a*aY","text_ar":"الاَذَى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"what annoys, molests, harms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurts, one"},{"kind":"text","text":"]: and also"},{"kind":"italic_en","text":"the showing the effect thereof;"},{"kind":"text","text":"which is forbidden by the saying of 'Omar,"},{"kind":"arabic","text_bw":"biAln~aAsi","text_ar":"بِالنَّاسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_iy~aAka waAlt~aA^a*~iY","text_ar":"اـِيَّاكَ وَالتَّاَذِّى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Avoid thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beware thou of, showing the being annoyed, molested, harmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, by men"},{"kind":"text","text":"]; for this is what is within one's power. (Mgh.) ―         -b2-  Also, aor. and inf. n. as above,"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was unclean, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"text","text":"(Msb.)"}],"source_refs":["T","M","Msb","K","TA"]},{"entry_id":"n507","headword_ar":"اَذَّى","root":"A*Y","body":[{"kind":"text","text":"inf. n. of 1. (T, M, Msb, K.) [As a simple subst.,"},{"kind":"italic_en","text":"A state of annoyance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"molestation."},{"kind":"text","text":"] ―         -b2-  And ["},{"kind":"italic_en","text":"Annoyance, molestation, harm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt:"},{"kind":"text","text":"quasi-] inf. n. of"},{"kind":"arabic","text_bw":"A=*aAhu","text_ar":"ا=ذَاهُ"},{"kind":"text","text":". (S, K.) ―         -b3-  It signifies also, [like ↓"},{"kind":"arabic","text_bw":"A^a*iy~apN","text_ar":"اَذِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^a*aApN","text_ar":"اَذَاةٌ","orth_type":"arrow"},{"kind":"text","text":",]"},{"kind":"arabic","text_bw":"kul~u maA taA^o*~ayota","text_ar":"كُلُّ مَا تَاْذَّيْتَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Anything by which thou art annoyed, molested, harmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt"},{"kind":"text","text":"]; (T;) or"},{"kind":"arabic","text_bw":"maA yuw^o*iyka","text_ar":"مَا يُوْذِيكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a thing that annoys, molests, harms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurts thee"},{"kind":"text","text":"]: (Mgh:) or"},{"kind":"italic_en","text":"a slight evil; less than what is termed"},{"kind":"arabic","text_bw":"Darar","text_ar":"ضَرَر"},{"kind":"text","text":". (El-Khattábee.) You say,"},{"kind":"arabic","text_bw":"A^amaATa AlA^a*aY Eani","text_ar":"اَمَاطَ الاَذَى عَنِ"},{"kind":"arabic","text_bw":"AlT~ariyqi","text_ar":"الطَّرِيقِ"},{"kind":"italic_en","text":"He removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put at a distance, what was hurtful from the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way."},{"kind":"text","text":"(Mgh and TA in art."},{"kind":"arabic","text_bw":"myT","text_ar":"ميط"},{"kind":"text","text":".) ―         -b4-  Also"},{"kind":"italic_en","text":"A thing held to be unclean, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy:"},{"kind":"text","text":"so in the Kur ii. 222. (Mgh, Msb.) ["},{"kind":"italic_en","text":"Filth; impurity:"},{"kind":"text","text":"often used in this sense in books on practical law.]"}],"source_refs":["Mgh"]},{"entry_id":"n511","headword_ar":"اَذِيٌّ","root":"A*Y","body":[{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^a*iy~apN","text_ar":"اَذِيَّةٌ"},{"kind":"text","text":"as its fem.: see"},{"kind":"arabic","text_bw":"A^a*K","text_ar":"اَذٍ"},{"kind":"text","text":", in three places."}],"source_refs":[]}]}}