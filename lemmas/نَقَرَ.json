{"lemma":"نَقَرَ","slug":"نَقَرَ","root":"ن.ق.ر","root_slug":"ن-ق-ر","root_link":"/words/roots/ن-ق-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"نَقَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"نَقَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"نَقَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"نَقَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"نَقَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"نَقَرَ","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"نَقَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"نَقَرا","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"نَقَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"نَقَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"نَقَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَنْقُر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَنْقُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَنْقُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَنْقُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَنْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَنْقُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَنْقُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْقُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْقُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْقُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْقُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْقُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْقُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْقُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْقُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْقُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَنْقُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْقُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"نَقَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَقَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":true,"lemma_key":"نَقَرَ","root":"نقر","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n40376"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%82%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to strike, to knock, to hack, to dig into, to tap, to peck; literally"},{"pos":"verb","gloss":"to strike, to knock, to hack, to dig into, to tap, to peck; so as investigating, to dig into, to tap"},{"pos":"verb","gloss":"to strike, to knock, to hack, to dig into, to tap, to peck; so as making a certain sound, to click (also on the computer), to knock, to thump, pluck (a drum as well as a string instrument)","examples":[{"text":"جِلَّوْز عَيْن الثَّوْر\nشَيْئًا مَلْهَوِيّ\nيَنْقُر لَك فَالْبَاب\nنَقْرً مُسْتَوِيّ\nيَصَّدَّع رَأْسَك\nفَذَاك الدَوِيّ\nوَرِزْق الْجِلَّوْز\nفَذَاك الصُّدَاع","english":"Filberts and prunes\nare frolic forsooth!\nYour door is pinged\nto have them slinged,\nstopless din and ballyhoo!\nEach cobnut wreaks you grue!"}]},{"pos":"verb","gloss":"to strike, to knock, to hack, to dig into, to tap, to peck; so as offending a person, to injure, to bully"},{"pos":"verb","gloss":"to dig into, to peck, to stipple, to pit"},{"pos":"noun","gloss":"verbal noun of نَقَرَ (naqara) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Latin fodere for semantical development. Cognate to the Hebrew root ניקר / נִקֵּר (nikér, “to bore, gouge out”)"},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40376","headword_ar":"نَقَرَ","root":"nqr","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bird)"},{"kind":"italic_en","text":"pecked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"picked up,"},{"kind":"text","text":"(S, A, Msb, K,) a grain, (S,) or grains, (A, Msb,)"},{"kind":"italic_en","text":"from this place and that,"},{"kind":"text","text":"(A, K,)"},{"kind":"arabic","text_bw":"biminoqaArihi","text_ar":"بِمِنْقَارِهِ"},{"kind":"italic_en","text":"with his beak."},{"kind":"text","text":"(A.) [Accord. to the TA, the addition “ from this place and that, ” which is found in the K and A, and in one place in the S, seems to be unnecessary. And ↓"},{"kind":"arabic","text_bw":"Antqr","text_ar":"انتقر","orth_type":"arrow"},{"kind":"text","text":"signifies the same: see 8, in art."},{"kind":"arabic","text_bw":"qb","text_ar":"قب"},{"kind":"text","text":".] ―         -b2-  [Hence, because of the sure aim with which a bird pecks a thing,] the same verb, having the same [aor. and] inf. n. signifies, (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an arrow)"},{"kind":"italic_en","text":"hit"},{"kind":"text","text":"the butt. (Msb.) And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an archer)"},{"kind":"italic_en","text":"hit"},{"kind":"text","text":"the butt,"},{"kind":"italic_en","text":"without making his arrow to pass through, partly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wholly."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence also,] (assumed tropical:)"},{"kind":"italic_en","text":"He took"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"picked"},{"kind":"text","text":"] a thing, as, for instance, food,"},{"kind":"italic_en","text":"with the finger."},{"kind":"text","text":"(TA.) ―         -b4-  Also, (M, K,) aor. and inf. n. as above, (M, TA,)"},{"kind":"italic_en","text":"He struck"},{"kind":"text","text":"a thing (IKtt, K, * TA,) with a thing: (IKtt, TA:) [generally,"},{"kind":"italic_en","text":"he struck, knocked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pecked,"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with a pointed instrument,"},{"kind":"text","text":"like as a bird strikes a thing with its beak:]"},{"kind":"italic_en","text":"he struck"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pecked"},{"kind":"text","text":"] a mill-stone, or a stone, &c., with a"},{"kind":"arabic","text_bw":"minoqaAr","text_ar":"مِنْقَار"},{"kind":"text","text":"[which is a"},{"kind":"italic_en","text":"pick,"},{"kind":"text","text":"or a"},{"kind":"italic_en","text":"kind of pickaxe;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"he wrought it into shape, and roughened it in its surface, with a pick"},{"kind":"text","text":"]. (M, TA.) ―         -b5-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"He wrote"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"engraved writing"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"fiY HajarK","text_ar":"فِى حَجَرٍ"},{"kind":"italic_en","text":"upon a stone."},{"kind":"text","text":"(A, K.) Whence the saying,"},{"kind":"arabic","text_bw":"Alt~aEoliymu","text_ar":"التَّعْلِيمُ"},{"kind":"arabic","text_bw":"fiY AlS~igari kaAln~aqori EalaY AlHajari","text_ar":"فِى الصِّغَرِ كَالنَّقْرِ عَلَى الحَجَرِ"},{"kind":"text","text":"[or, as in a verse of Niftaweyh,"},{"kind":"arabic","text_bw":"fiY AlHajari","text_ar":"فِى الحَجَرِ"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"Teaching in infancy is like engraving writing upon stone"},{"kind":"text","text":"]. (TA.) ―         -b6-"},{"kind":"italic_en","text":"He struck"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fillipped"},{"kind":"text","text":"] a man's head, and in like manner a lute, and a tambourine, with his finger. (TA.) You say also"},{"kind":"arabic","text_bw":"A^u*unahu","text_ar":"اُذُنَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^anoqara","text_ar":"اَنْقَرَ","orth_type":"arrow"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"He struck"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fillipped"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his ear with his finger."},{"kind":"text","text":"(AA, in TA, art."},{"kind":"arabic","text_bw":"nTb","text_ar":"نطب"},{"kind":"text","text":".) ―         -b7-  [Hence,]"},{"kind":"arabic","text_bw":"naqara","text_ar":"نَقَرَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":", as appears from what follows;] and ↓"},{"kind":"arabic","text_bw":"A^anoqara","text_ar":"اَنْقَرَ","orth_type":"arrow"},{"kind":"text","text":"; (tropical:)  ["},{"kind":"italic_en","text":"He made a snapping with his thumb and middle finger;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he struck his thumb against the end of the middle finger and made a sound with them."},{"kind":"text","text":"(A.) [And in like manner the former verb used transitively; as in the following instance:]"},{"kind":"arabic","text_bw":"waDaEa","text_ar":"وَضَعَ"},{"kind":"arabic","text_bw":"Tarafa A_ibohaAmihi EalaY baATini sab~aAbatihi vum~a naqarahaA","text_ar":"طَرَفَ اـِبْهَامِهِ عَلَى بَاطِنِ سَبَّابَتِهِ ثُمَّ نَقَرَهَا"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"He put the end of his thumb against the inner side of his first finger, then made a snapping with it"},{"kind":"text","text":"]. (TA.) See also"},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":", below. ―         -b8-  [Hence also,]"},{"kind":"arabic","text_bw":"naqara biAld~aAb~api","text_ar":"نَقَرَ بِالدَّابَّةِ"},{"kind":"text","text":", (T, A, TS,) or"},{"kind":"arabic","text_bw":"biAlfarasi","text_ar":"بِالفَرَسِ"},{"kind":"text","text":", (S,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":"; (T, S, TS;) and ↓"},{"kind":"arabic","text_bw":"A^anoqara","text_ar":"اَنْقَرَ","orth_type":"arrow"},{"kind":"text","text":", (A, TS,) inf. n."},{"kind":"arabic","text_bw":"A_inoqaArN","text_ar":"اـِنْقَارٌ"},{"kind":"text","text":"; (TS;) (tropical:)"},{"kind":"italic_en","text":"He made a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"smacking"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"slight sound, to put in motion the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"beast"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"horse, by making his tongue adhere to his palate and then opening"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"suddenly drawing it away"},{"kind":"text","text":"]: (S:) or"},{"kind":"italic_en","text":"he struck with his tongue the place of utterance of the letter"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"italic_en","text":"and made a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"smacking"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by suddenly withdrawing his tongue"},{"kind":"text","text":"]: (A:)"},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"making the end of the tongue to adhere to the palate, then making a sound"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by suddenly withdrawing it"},{"kind":"text","text":"]: (M, K:) or one's"},{"kind":"italic_en","text":"putting his tongue above his central incisors, at the part next the palate, then making a smacking sound"},{"kind":"text","text":"[so I render"},{"kind":"arabic","text_bw":"vum~a yanoqur","text_ar":"ثُمَّ يَنْقُر"},{"kind":"text","text":"]: (TA:) [the sounds thus described, which are nearly the same, are commonly made by the Arabs in the present day, in urging beasts of carriage:] or"},{"kind":"italic_en","text":"an agitation of the tongue"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in the mouth, upwards and downwards:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a sound,"},{"kind":"text","text":"(so in some copies of the K and in the TA,) or"},{"kind":"italic_en","text":"slight sound,"},{"kind":"text","text":"(so in the TS [as mentioned in the TA] and in some copies of the K)"},{"kind":"italic_en","text":"by which a horse is put in motion:"},{"kind":"text","text":"(TS, K:) or"},{"kind":"arabic","text_bw":"naqara bilisaAnihi","text_ar":"نَقَرَ بِلِسَانِهِ"},{"kind":"text","text":", accord. to IKtt, signifies"},{"kind":"italic_en","text":"he struck his palate with his tongue"},{"kind":"text","text":"to quiet the horse: but this is at variance with what is said by Az, J, and ISd, and requires consideration. (TA.) A poet, (S,) Fedekee El-Minkaree, (K,) i. e., 'Obeyd"},{"kind":"page_break","n":2838},{"kind":"text","text":"Ibn-Máweeyeh, of the tribe of Teiyi, (TA,) uses"},{"kind":"arabic","text_bw":"Aln~aquro","text_ar":"النَّقُرْ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"Aln~aqoro","text_ar":"النَّقْرْ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Aln~aqoru biA@loxayoli","text_ar":"النَّقْرُ بِا@لْخَيْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The smacking with the tongue to urge the horses"},{"kind":"text","text":"]: pausing after the word, at the end of a hemistich, he transfers the vowel of the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", (S, K,) agreeably with the dial. of certain of the Arabs, (TA,) that the hearer may know it to be the vowel of the [final] letter when there is no pause; (S;) like as you say,"},{"kind":"arabic","text_bw":"h`*aA bakoru","text_ar":"هٰذَا بَكْرُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mararotu bibakiro","text_ar":"مَرَرْتُ بِبَكِرْ"},{"kind":"text","text":": but this is not done when the word is in the accus. case (S, K:) and if you choose, you may make the final letter quiescent in pausing, though it is preceded by a quiescent letter. (S.) ―         -b9-  Hence also,"},{"kind":"arabic","text_bw":"faA_i*aA nuqira fiY Aln~aAquwri","text_ar":"فَاـِذَا نُقِرَ فِى النَّاقُورِ"},{"kind":"text","text":"[Kur, lxxiv. 8,] (tropical:)"},{"kind":"italic_en","text":"For when the horn shall be blown:"},{"kind":"text","text":"(S, * A, * Bd, K:) from"},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":"signifying (tropical:)  the"},{"kind":"italic_en","text":"making a sound:"},{"kind":"text","text":"originally,"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"which is the cause of sound. (Bd.) See also"},{"kind":"arabic","text_bw":"naAquwrN","text_ar":"نَاقُورٌ"},{"kind":"text","text":", below. ―         -b10-  Also,"},{"kind":"arabic","text_bw":"naqara","text_ar":"نَقَرَ"},{"kind":"italic_en","text":"He bored, perforated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a hole through"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into,"},{"kind":"text","text":"a thing: (TA:) or"},{"kind":"italic_en","text":"he did so with a"},{"kind":"arabic","text_bw":"minoqaAr","text_ar":"مِنْقَار"},{"kind":"text","text":": (S:) and, inf. n."},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he hollowed out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excavated,"},{"kind":"text","text":"a piece of wood. (Mgh, Msb.)"},{"kind":"arabic","text_bw":"nuqirN","text_ar":"نُقِرٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ainotaqara","text_ar":"اِنْتَقَرَ","orth_type":"arrow"},{"kind":"text","text":", (so in some copies of the K,) or ↓"},{"kind":"arabic","text_bw":"A^unotuqira","text_ar":"اُنْتُقِرَ","orth_type":"arrow"},{"kind":"text","text":", (so in other copies of the K and in the TA,) both in the pass. form, (TA,) said of stone and of wood and the like, signify alike, (K,)"},{"kind":"italic_en","text":"It was bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it had a hole made through"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into it:"},{"kind":"text","text":"(TA:) [and"},{"kind":"italic_en","text":"it was hollowed out."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"naqara AlbayoDapa Eani Alfaroxi","text_ar":"نَقَرَ البَيْضَةَ عَنِ الفَرْخِ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":", (TA.)"},{"kind":"italic_en","text":"He made a hole in the egg"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to disclose the young bird"},{"kind":"text","text":"]. (K.) And"},{"kind":"arabic","text_bw":"naqarat Alxayolu","text_ar":"نَقَرَت الخَيْلُ"},{"kind":"text","text":", (A,) and"},{"kind":"arabic","text_bw":"bHwAfrhA nuqarFA","text_ar":"بحوافرها نُقَرًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Antqrt","text_ar":"انتقرت","orth_type":"arrow"},{"kind":"text","text":", (Lth, K,)"},{"kind":"italic_en","text":"The horses made hollows in the ground with their hoofs."},{"kind":"text","text":"(Lth, A, K.) And in like manner, ↓"},{"kind":"arabic","text_bw":"Antqrt","text_ar":"انتقرت","orth_type":"arrow"},{"kind":"arabic","text_bw":"Als~uyuwlu nuqarFA","text_ar":"السُّيُولُ نُقَرًا"},{"kind":"italic_en","text":"The torrents left hollows in the ground, in which water was retained."},{"kind":"text","text":"(TA.) ―         -b11-  Hence,"},{"kind":"arabic","text_bw":"naqara Eani AlA^amori","text_ar":"نَقَرَ عَنِ الاَمْرِ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nq~r","text_ar":"نقّر","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"tanoqiyrN","text_ar":"تَنْقِيرٌ"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"nq~rhu","text_ar":"نقّرهُ","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tnq~rhu","text_ar":"تنقّرهُ","orth_type":"arrow"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"Antqrhu","text_ar":"انتقرهُ","orth_type":"arrow"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"He searched"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquired into the thing; investigated, scrutinized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined, it;"},{"kind":"text","text":"(S, Msb, K, TA;)"},{"kind":"italic_en","text":"and endeavoured to know it:"},{"kind":"text","text":"(TA;) and so"},{"kind":"arabic","text_bw":"naqara Eani lxabari","text_ar":"نَقَرَ عَنِ لخَبَرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he investigated the news, and endeavoured to know it."},{"kind":"text","text":"(A.) [And hence,]"},{"kind":"arabic","text_bw":"Als~ahoma bayona A_iSobaEayohi","text_ar":"السَّهْمَ بَيْنَ اـِصْبَعَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nq~r","text_ar":"نقّر","orth_type":"arrow"},{"kind":"text","text":". (K, in art."},{"kind":"arabic","text_bw":"Hn","text_ar":"حن"},{"kind":"text","text":",) or"},{"kind":"arabic","text_bw":"EalaY AlA_ibohaAmi","text_ar":"عَلَى الاـِبْهَامِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tanoqiyrN","text_ar":"تَنْقِيرٌ"},{"kind":"text","text":", (K, in art."},{"kind":"arabic","text_bw":"dwm","text_ar":"دوم"},{"kind":"text","text":",) ["},{"kind":"italic_en","text":"He tried the sonorific quality of the arrow by turning it round between his fingers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon his thumb:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"Han~aAnN","text_ar":"حَنَّانٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"dar~a Als~ahomu","text_ar":"دَرَّ السَّهْمُ"},{"kind":"text","text":", and see also 4, in art."},{"kind":"arabic","text_bw":"dwm","text_ar":"دوم"},{"kind":"text","text":": or]"},{"kind":"arabic","text_bw":"nq~r Als~ahoma","text_ar":"نقّر السَّهْمَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he made the arrow to produce a sharp sound"},{"kind":"text","text":"[by turning it round between his fingers, or] upon his thumb. (TK, in art."},{"kind":"arabic","text_bw":"dwm","text_ar":"دوم"},{"kind":"text","text":".)"}],"source_refs":["S","A","Msb","K","M","TA","IKtt","T","TS","Lth"]}]},"classical_definitions":null}