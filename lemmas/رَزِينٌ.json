{"lemma":"رَزِينٌ","slug":"رَزِينٌ","root":"ر.ز.ن","root_slug":"ر-ز-ن","root_link":"/words/roots/ر-ز-ن","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","name"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15434"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B2%D9%90%D9%8A%D9%86%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"composed, serene, stoic, wise"},{"pos":"name","gloss":"a male given name"}]},"etymology":{"source":"wiktextract","text":"فَعِيل (faʕīl)-type stative-verb derived from the active participle from the verb رَزُنَ (razuna)."},"ipa":["/ra.ziːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15434","headword_ar":"رَزِينٌ","root":"rzn","body":[{"kind":"italic_en","text":"Heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weighty;"},{"kind":"text","text":"(S, K;) applied to a thing (S, TA) of any kind. (TA.) ―         -b2-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"Grave, staid, steady, sedate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm;"},{"kind":"text","text":"(S, MA, K, TA;) and"},{"kind":"italic_en","text":"forbearing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless:"},{"kind":"text","text":"(S, * K, * TA:) or"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, of judgment:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"wise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sensible:"},{"kind":"text","text":"(MA:) or a man"},{"kind":"italic_en","text":"having much gravity, staidness,"},{"kind":"text","text":"&c.: (Har p. 227:) and ↓"},{"kind":"arabic","text_bw":"razaAnN","text_ar":"رَزَانٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, applied to a woman; (MA, K;) or, thus applied,"},{"kind":"italic_en","text":"grave, staid,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in her sitting-place:"},{"kind":"text","text":"(S:) the epithet"},{"kind":"arabic","text_bw":"raziynapN","text_ar":"رَزِينَةٌ"},{"kind":"text","text":"is not applied to her unless she be"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant; and grave, staid,"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"and continent, chaste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"modest; grave, staid,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in her sitting-place."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^abuw raziynK","text_ar":"اَبُو رَزِينٍ"},{"kind":"text","text":"is a name given to"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of sweet food commonly called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xabiyS","text_ar":"خَبِيص"},{"kind":"text","text":"[q. v.]; because of its excellence among eatables, and its high estimation, and its surpassing cost, and its being put the last thing to be eaten. (Har p. 227.)"}],"source_refs":["S","TA","MA"]}]},"classical_definitions":null}