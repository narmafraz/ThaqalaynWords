{"lemma":"عَنْبَرٌ","slug":"عَنْبَرٌ","root":"ع.ن.ب.ر","root_slug":"ع-ن-ب-ر","root_link":"/words/roots/ع-ن-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27845","n30691"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%86%D9%92%D8%A8%D9%8E%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"ambergris"},{"pos":"noun","gloss":"ellipsis of حُوت الْعَنْبَر (ḥūt al-ʕanbar, “sperm whale, cachalot”)","tags":["abbreviation","alt-of","ellipsis"]},{"pos":"noun","gloss":"storeroom, stowage; depot; hangar"}]},"etymology":{"source":"wiktextract","text":"From Middle Persian ʾmbl (ambar, “ambergris”).\n\nFrom Persian انبار (anbâr)."},"ipa":["/ʕan.bar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27845","headword_ar":"عَنْبَرٌ","root":"Ebr","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Enbr","text_ar":"عنبر"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n30691","headword_ar":"عَنْبَرٌ","root":"Enbr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Ambergris;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain odoriferous substance,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"well known;"},{"kind":"text","text":"(O, Msb;)"},{"kind":"italic_en","text":"an excrement found in the belly of a certain great fish,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the spermaceti-whale,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which is called by the same name;"},{"kind":"text","text":"(Towsheeh, TA;) or"},{"kind":"italic_en","text":"an excrement of a certain marine beast;"},{"kind":"text","text":"(K;) or, accord. to Ks,"},{"kind":"italic_en","text":"a vegetable"},{"kind":"text","text":"["},{"kind":"italic_en","text":"substance found"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the bottom of the sea and driven by the waves to the shores thereof, whence it is taken;"},{"kind":"text","text":"(O;) or, (O, K,) as the physicians say, (O,)"},{"kind":"italic_en","text":"it issues from a source in the sea;"},{"kind":"text","text":"(O, * K;) [and there are other opinions respecting its origin, mentioned in the TA; but these I do not add, as it is well known to be an excrement of the spermaceti-whale;]"},{"kind":"italic_en","text":"the best kind is the white,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the whitish; next, the blue"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"gray"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"and the worst, the black:"},{"kind":"text","text":"(TA:) the word is masc. and fem., (AA, IAmb, O, Msb,) like"},{"kind":"arabic","text_bw":"misokN","text_ar":"مِسْكٌ"},{"kind":"text","text":": (IAmb, TA voce"},{"kind":"arabic","text_bw":"*akiY~N","text_ar":"ذَكِىٌّ"},{"kind":"text","text":":) MF says that most hold the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"to be augmentative, the measure being"},{"kind":"arabic","text_bw":"fanoEalN","text_ar":"فَنْعَلٌ"},{"kind":"text","text":", as it is said to be in the Msb. (TA.) ―         -b2-  [As mentioned above, it signifies also The"},{"kind":"italic_en","text":"spermaceti-whale;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain great fish;"},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"Ebr","text_ar":"عبر"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"a certain marine fish,"},{"kind":"text","text":"(Az, O, K,)"},{"kind":"italic_en","text":"the length of which reaches to fifty cubits, called in Pers."},{"kind":"arabic","text_bw":"PAlh","text_ar":"پاله"},{"kind":"text","text":"[app. a mistranscription for"},{"kind":"arabic","text_bw":"waAlo","text_ar":"وَالْ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"baAlN","text_ar":"بَالٌ"},{"kind":"text","text":"]: (Az, TA:)"},{"kind":"italic_en","text":"shields are made of its skin;"},{"kind":"text","text":"(Mgh, O, TA;)"},{"kind":"italic_en","text":"and the people of Juddeh have sandals,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shoes, made thereof."},{"kind":"text","text":"(O, TA.) ―         -b3-  And hence, (O,)"},{"kind":"italic_en","text":"A shield"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"made of the skin of the fish above-mentioned:"},{"kind":"text","text":"(O, K:) and some say,"},{"kind":"italic_en","text":"coats of defence"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"duruwE","text_ar":"دُرُوع"},{"kind":"text","text":"). (O.)       -A2-  Also"},{"kind":"italic_en","text":"Saffron."},{"kind":"text","text":"(K.) ―         -b2-  And (as some say, TA) [The"},{"kind":"italic_en","text":"plant called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"waros","text_ar":"وَرْس"},{"kind":"text","text":". (K.) ―         -b3-  [Accord. to Forskål (Flora Aegypt. Arab. p. lxiv.) now applied to"},{"kind":"italic_en","text":"Gomphrena globosa."},{"kind":"text","text":"]       -A3-  See also the next paragraph, in two places."}],"source_refs":["S","O","Msb","K","TA","AA","IAmb","Az"]}]},"classical_definitions":null}