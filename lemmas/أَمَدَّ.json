um":"d"},{"role":"present_3md","form":"يُمَدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُمَدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُمِدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمِدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمَدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمَدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُمِدُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمِدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمَدُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمَدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُمْدِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُمِدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمِدّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُمَدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمَدّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَمْدَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَمْدَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":59,"cross_references":{"qac":{"found":true,"lemma_key":"أَمَدَّ","root":"مدد","pos":"V","occurrence_count":10},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n1201","n1202","","n38321"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1201","headword_ar":"امّد","root":"Amd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taA^omiydN","text_ar":"تَاْمِيدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He declared the time, considered with regard to its end;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the utmost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extreme, extent, term, limit, point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reach;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"bay~ana AlA^amada","text_ar":"بَيَّنَ الاَمَدَ"},{"kind":"text","text":". (K.)"}],"source_refs":[]},{"entry_id":"n1202","headword_ar":"اَمَدٌ","root":"Amd","body":[{"kind":"italic_en","text":"Time, considered with regard to its end:"},{"kind":"arabic","text_bw":"zamaAnN","text_ar":"زَمَانٌ"},{"kind":"text","text":"being time considered with regard to its end and its beginning: (Er-Rághib:) [but sometimes it is interchangeable with"},{"kind":"arabic","text_bw":"zamaAnN","text_ar":"زَمَانٌ"},{"kind":"text","text":", as will be seen in what follows:] or the"},{"kind":"italic_en","text":"utmost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extreme, extent, term, limit, point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reach."},{"kind":"text","text":"(S, M, A, Msb, K.) You say,"},{"kind":"arabic","text_bw":"balaga A^amadahu","text_ar":"بَلَغَ اَمَدَهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, utmost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extreme, extent, term,"},{"kind":"text","text":"&c. (Msb.) And"},{"kind":"arabic","text_bw":"Daraba lahu A^amadFA","text_ar":"ضَرَبَ لَهُ اَمَدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He assigned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, a term,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limit"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"huwa baEiydu AlA=maAdi","text_ar":"هُوَ بَعِيدُ الا=مَادِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is one whose limits are remote:"},{"kind":"arabic","text_bw":"A=maAdN","text_ar":"ا=مَادٌ"},{"kind":"text","text":"being the pl.]. (A.) ―         -b2-  The"},{"kind":"italic_en","text":"period of life which one has reached;"},{"kind":"text","text":"as in the saying,"},{"kind":"arabic","text_bw":"maA A^amaduka","text_ar":"مَا اَمَدُكَ"},{"kind":"italic_en","text":"What is thy period of life which thou hast reached?"},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"italic_en","text":"Each of the two terms of the life"},{"kind":"text","text":"of a man; i. e. the"},{"kind":"italic_en","text":"time of"},{"kind":"text","text":"his"},{"kind":"italic_en","text":"birth,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"time of"},{"kind":"text","text":"his"},{"kind":"italic_en","text":"death."},{"kind":"text","text":"(Sh, T.) El-Hasan [El-Basree], being asked by El-Hajjáj,"},{"kind":"arabic","text_bw":"maA A^amaduka","text_ar":"مَا اَمَدُكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"What was the time of thy birth?"},{"kind":"text","text":"answered by saying that it was two years before the expiration of 'Omar's reign as Khaleefeh. (T, L, from a trad.) ―         -b4-  The"},{"kind":"italic_en","text":"startingplace,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"goal,"},{"kind":"text","text":"of horses in a race. (Sh, T, L.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"Any space of time:"},{"kind":"text","text":"(Er-Rághib:)"},{"kind":"italic_en","text":"a space of time of unknown limit."},{"kind":"text","text":"(Kull pp. 9 and 10.) ―         -b6-  Sometimes, (assumed tropical:)"},{"kind":"italic_en","text":"A particular time;"},{"kind":"text","text":"as in the phrase"},{"kind":"arabic","text_bw":"A^amadu ka*aA","text_ar":"اَمَدُ كَذَا"},{"kind":"italic_en","text":"The time of such a thing;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"zamaAnu A^amadN","text_ar":"زَمَانُ اَمَدٌ"},{"kind":"text","text":". (Kull p. 10.) ―         -b7-  [It is also used for"},{"kind":"arabic","text_bw":"*w A^amadN","text_ar":"ذو اَمَدٌ"},{"kind":"text","text":", and (applied to a fem. n.)"},{"kind":"arabic","text_bw":"*aAt A^amadK","text_ar":"ذَات اَمَدٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Having a term,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limit; limited in duration;"},{"kind":"text","text":"as in the saying,]"},{"kind":"arabic","text_bw":"Ald~unoyaA A^amadN wAlA=xirpu A^abadN","text_ar":"الدُّنْيَا اَمَدٌ والا=خِرةُ اَبَدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The present state of existence is limited in duration, but the final state of existence is everlasting"},{"kind":"text","text":"]. (Obeyd Ibn-'Omeyr, L in art."},{"kind":"arabic","text_bw":"Abd","text_ar":"ابد"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n38321","headword_ar":"اَمَدُّ","root":"md","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most tall, high, long,"},{"kind":"text","text":"&c.] ―         -b2-"},{"kind":"arabic","text_bw":"huwa mino A^amad~i Aln~aAsi qaAmapF","text_ar":"هُوَ مِنْ اَمَدِّ النَّاسِ قَامَةً"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is of the tallest of men in stature."},{"kind":"text","text":"(A) ―         -b3-"},{"kind":"arabic","text_bw":"naEamo waA^a$ad~ahu waA^amad~ahu","text_ar":"نَعَمْ وَاَشَدَّهُ وَاَمَدَّهُ"},{"kind":"italic_en","text":"Yes: even the utmost thereof, and the most that could be thereof."},{"kind":"text","text":"Said in reply to the question “ Hast thou done it? ” (A.) ―         -b4-"},{"kind":"arabic","text_bw":"A^amad~u SawotFA","text_ar":"اَمَدُّ صَوْتًا"},{"kind":"italic_en","text":"Higher"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"louder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loudest, of voice."},{"kind":"text","text":"(Mgh, art."},{"kind":"arabic","text_bw":"lqY","text_ar":"لقى"},{"kind":"text","text":".)"}],"source_refs":["A"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%85%D8%AF/","headword_ar":"أمد","entries":[{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=78#35cfdb","body_html":"<span class=\"title1\">[أمد]</span><span> الأَمَدُ: الغاية كالمدى. يقال: ما أَمَدُكَ؟ أي منتهى عمرك. والأَمَدُ أيضاً: الغضب. وقد أَمِدَ عليه بالكسر، وأَبِدَ عليه، أي غضب. وآمد: بلد في الثغور.</span>"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=78#1fe8ce","body_html":"أمد: أمَّد (بالتضعيف): أجَّل، جعل له مدة (فوك)."},{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=78#580192","body_html":"<span class=\"title1\">أ م د</span><br><br><span>ضرب له أمداً، وهو بعيد الآماد.</span>"},{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=78#c3156a","body_html":"<span class=\"title1\">أ م د</span><span>: (الْأَمَدُ) بِفَتْحَتَيْنِ الْغَايَةُ كَالْمَدَى. </span>"},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=78#574ed8","body_html":"<span class=\"title1\">أمد</span><br><span>الأمَدُ: مُنْتَهى كُل شَيْءٍ وآخِرُه. ولَيْسَ لهذا الأمْرِ أمَدٌ مَأمُوْد: أي مُنْتَهى إليه. وأصْبَحَ سِقَاؤكَ مُؤَمداً: أي لَيْسَ فيه جُرْعَةٌ من ماءٍ. والبَقِيَّةُ: الأمْدَةُ.</span><br><span>والأمِدُ: المَمْلُوء من خَيْرٍ وشَر، وبه سُمِّيَ البَلَدُ وأمِدَ عليه: أي غَضِبَ عليه.</span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=78#57f148","body_html":"<span>: [أم د] الأَمَدُ: الغايَةُ. وأَمْدَ عليه: غَضِبَ. وآمِدُ: مَوْضِعٌ، قالَ:</span><br><br><span>(بآمَدَ مَرَّةً وبِرَأْسِ عَيْنٍ </span><span class=\"red\">...</span><span> وأَحْيانَا بمَيَّا فارِقِينَا)</span><br><br><span>ذَهَب إِلى الأَرْضِ أو البُقْعَةِ فلم يَصْرِفْ، وقد تَقَدَّمَ. والإمِدّانُ: الماءَُ عَلَى وَجْهِ الأَرْضِ، عن كُراع، ولَسْتُ منه عَلَى ثِقَةِ.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=78#e40d79","body_html":"<p>أمد: الأَمَدُ: الغاية كالمَدَى؛ يقال: ما أَمدُك؟ أَي منتهى عمرك. وفي</p><p>التنزيل العزيز: ولا تكونوا كالذين أُوتو الكتاب من قبل فطال عليهم</p><p>الأَمدُ فَقَسَتْ قلوبهم؛ قال شمر: الأَمَدُ منتهى الأَجل، قال: وللإِنسان</p><p>أَمَدانِ: أَحدهما ابتداء خلقه الذي يظهر عند مولده، والأَمد الثاني الموت؛</p><p>ومن الأَول حديث الحجاج حين سأَل الحسن فقال له: ما أَمَدُكَ؟ قال: سنتان</p><p>من خلافة عمر؛ أَراد أَنه ولد لسنتين بقيتا من خلافة عمر، رضي الله عنه.</p><p>والأَمَدُ: الغضب؛ أَمِدَ عليه وأَبِدَ إِذا غضب عليه. وآمِدُ: بلد </p><p>(*</p><p>قوله «وآمد بلد إلخ» عبارة شرح القاموس وآمد بلد بالثغور في ديار بكر</p><p>مجاورة لبلاد الروم ثم قال: ونقل شيخنا عن بعض ضبطه بضم الميم، قلت وهو</p><p>المشهور على الألسنة.) معروف في الثغور؛ قال:</p><p>بآمِدَ مرَّةً وبرأْسِ عينٍ،</p><p>وأَحياناً بِمَيَّا فارِقينا</p><p>ذهب إِلى الأَرض أَو البقعة فلم يصرف.</p><p>والإِمِّدانُ: الماءُ على وجه الأَرض؛ عن كراع. قال ابن سيده: ولست منه</p><p>على ثقة.</p><p>وأَمَدُ الخيل في الرهان: مَدافِعُها في السباق ومنتهى غاياتها الذي</p><p>تسبق إِليه؛ ومنه قول النابغة:</p><p>سَبْقَ الجوادِ، إِذا استولى على الأَمَدِ</p><p>أَي غلب على منتهاه حين سبق وسيلة إِليه. أَبو عمرو: يقال للسفينة إِذا</p><p>كانت مشحونة عامِدٌ وآمِدٌ وعامدة وآمِدَة، وقال: السامدُ العاقل،</p><p>والآمِدُ: المملوء من خير أَو شرّ.</p>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=78#2be639","body_html":"<span class=\"title1\">أمد</span><br><span>قال تعالى: تَوَدُّ لَوْ أَنَّ بَيْنَها وَبَيْنَهُ أَمَداً بَعِيداً [آل عمران/ 30] . والأَمَد والأبد يتقاربان، لكن الأبد عبارة عن مدّة الزمان التي ليس لها حدّ محدود، ولا يتقيد، لا يقال: أبد كذا.</span><br><span>والأَمَدُ: مدّة لها حدّ مجهول إذا أطلق، وقد ينحصر نحو أن يقال: أمد كذا، كما يقال: زمان كذا، والفرق بين الزمان والأمد أنّ الأمد يقال باعتبار الغاية، والزمان عامّ في المبدأ والغاية، ولذلك قال بعضهم: المدى والأمد يتقاربان.</span>"},{"lexicon_id":"dictionary_4","lexicon_en":"Abū ʿUbayd al-Qāsim bin Salām al-Harawī, Gharīb al-Ḥadīth (d. 838 CE)","lexicon_ar":"غريب الحديث لأبي عبيد القاسم بن سلام","permalink":"https://arabiclexicon.hawramani.com/?p=78#466ef9","body_html":"<span class=\"title1\">أمد</span><span> أمد عين [وَقَالَ أَبُو عبيد: فِي حَدِيث الحجّاج حِين سَأَلَ الْحسن رَحمَه الله: مَا أمَدُكَ يَا حسن قَالَ: سنتَانِ من خلَافَة عمر رَضِي الله عَنهُ فقالك وَالله لَعَيْنُك أكبر من أمَدِك حدّثنَاهُ ابْن علية عَن يُونُس عَن الْحسن. </span><span>قَوْله: أمَدك يَعْنِي مُنْتَهى عمره وأمَدُ كل شَيْء منتهاه. وَإِنَّمَا أَرَادَ المولد. وَقَوله: وَالله لَعَيْنُك يَقُول: شاهدُك ومَنْظرُك أكبر من أمَدِك وَعين كل شَيْء شَاهده وحاضره وَمِنْه قَول الشَّاعِر: [الرجز]</span><br><br><span>وعينه كالكالىء الضِّمارِ</span><br><br><span>يَقُول: مَا أَرَادَ أَن يعطيك حَاضرا فَهُوَ مثل الْغَائِب الَّذِي لَا يُرْجَى.</span><br><br><span>بن قَالَ أَبُو عبيد: لم يرد الْحسن بقوله سنتَانِ مضتا إِنَّمَا أَرَادَ بَقِيَتَا] .</span><br><br><span>أَحَادِيث عبيد الله زِيَاد</span>"}]}}