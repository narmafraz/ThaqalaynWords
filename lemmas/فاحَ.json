oss_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n34919"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to spread, to emanate (of perfume, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to be fragrant (of spring, the land, etc.)","tags":["intransitive"]},{"pos":"verb","gloss":"to spread, to reek (of a bad smell)","tags":["intransitive"]},{"pos":"verb","gloss":"to boil (of a pot)","tags":["intransitive"]},{"pos":"verb","gloss":"to bleed (of a wound)","tags":["intransitive"]},{"pos":"verb","gloss":"to blaze, to become intense (of heat)","tags":["intransitive"]},{"pos":"verb","gloss":"to spread, to expand","tags":["intransitive"]},{"pos":"verb","gloss":"to become spacious","tags":["intransitive"]}]},"etymology":{"source":"wiktextract","text":"From the root ف و ح (f w ḥ). Also compare فَاخَ (fāḵa), نَفَحَ (nafaḥa), نَفَخَ (nafaḵa), فَحَّ (faḥḥa), Aramaic פּוּחַ / ܦܘܚ (fūḥa, “to exhale, to give out odour”)."},"ipa":["/faː.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34919","headword_ar":"فَاحَ","root":"fyH","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafiyHu","text_ar":"يَفِيحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayoHN","text_ar":"فَيْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fayaHaAnN","text_ar":"فَيَحَانٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"fwH","text_ar":"فوح"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"fAH Ald~amu","text_ar":"فاح الدَّمُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayoHN","text_ar":"فَيْحٌ"},{"kind":"text","text":"(L, Msb) and"},{"kind":"arabic","text_bw":"fayaHaAnN","text_ar":"فَيَحَانٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"It poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"it flowed;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AfAH","text_ar":"افاح","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ifaAHapN","text_ar":"اـِفَاحَةٌ"},{"kind":"text","text":": or, accord. to AZ, the latter is trans., and signifies as expl. below in relation to blood. (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faAHati","text_ar":"فَاحَتِ"},{"kind":"arabic","text_bw":"Al$~aj~apu","text_ar":"الشَّجَّةُ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"arabic","text_bw":"tafiyHu","text_ar":"تَفِيحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayoHN","text_ar":"فَيْحٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The wound upon the head spirted forth blood;"},{"kind":"text","text":"(S, Msb, K;) or"},{"kind":"italic_en","text":"poured forth much blood."},{"kind":"text","text":"(A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"fAH AlHur~u","text_ar":"فاح الحُرُّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafiyHu","text_ar":"يَفِيحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fayoHN","text_ar":"فَيْحٌ"},{"kind":"text","text":"; and aor."},{"kind":"arabic","text_bw":"yafwHu","text_ar":"يَفوحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fawoHN","text_ar":"فَوْحٌ"},{"kind":"text","text":"; (assumed tropical:)"},{"kind":"italic_en","text":"The heat rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diffused itself, and raged vehemently."},{"kind":"text","text":"(L.) It is said in a trad.,"},{"kind":"arabic","text_bw":"$id~apu AlqayoZi mino fayoHi jahan~ama","text_ar":"شِدَّةُ القَيْظِ مِنْ فَيْحِ جَهَنَّمَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The intenseness of the heat of summer is from the vehement raging of the heat of Hell"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"AlHum~aY mino fayoHi jahan~ama","text_ar":"الحُمَّى مِنْ فَيْحِ جَهَنَّمَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The fever is from the vehemence of the heat of Hell."},{"kind":"text","text":"(A.) ―         -b5-  And"},{"kind":"arabic","text_bw":"faAHati Alqidoru","text_ar":"فَاحَتِ القِدْرُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"arabic","text_bw":"tafiyHu","text_ar":"تَفِيحُ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"tafuwHu","text_ar":"تَفُوحُ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The cooking-pot boiled;"},{"kind":"text","text":"(S, K, TA;) as though it were the fire of Hell, in its heat. (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"faAHati Aln~aAru","text_ar":"فَاحَتِ النَّارُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The fire spread."},{"kind":"text","text":"(Msb.) And [hence, app.,]"},{"kind":"arabic","text_bw":"faAHati AlgaArapu","text_ar":"فَاحَتِ الغَارَةُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tafiyHu","text_ar":"تَفِيحُ"},{"kind":"text","text":", i. e. (tropical:)  ["},{"kind":"italic_en","text":"The troop of horsemen making an attack,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incursion, upon a people"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"spread themselves."},{"kind":"text","text":"(S, TA.) See"},{"kind":"arabic","text_bw":"fayaAHi","text_ar":"فَيَاحِ"},{"kind":"text","text":". ―         -b7-  And"},{"kind":"arabic","text_bw":"fAH","text_ar":"فاح"},{"kind":"text","text":", (L, Msb, TA,) aor."},{"kind":"arabic","text_bw":"yafaAHu","text_ar":"يَفَاحُ"},{"kind":"text","text":", (L, TA,) [inf. n., app."},{"kind":"arabic","text_bw":"fayaHN","text_ar":"فَيَحٌ"},{"kind":"text","text":", which signifies “ width ” accord. to the S and K, and is agreeable with general analogy in this case, as the aor. of the verb is originally"},{"kind":"arabic","text_bw":"yafoyaHu","text_ar":"يَفْيَحُ"},{"kind":"text","text":", though it seems to be implied in the Msb that the aor. is not"},{"kind":"arabic","text_bw":"yafaAHu","text_ar":"يَفَاحُ"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"yafiyHu","text_ar":"يَفِيحُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a sea, S, * L, K, * TA, and a place, L, or a valley, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, wide."},{"kind":"text","text":"(S, * L, Msb, K, * TA.)"}],"source_refs":["L","Msb","S","A","K","TA"]}]}}