ic_en","text":"pleasing."},{"kind":"text","text":"Hence, app.,] one says,"},{"kind":"arabic","text_bw":"AlEumuri","text_ar":"العُمُرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kaAna liqaAw^uka zubodapa","text_ar":"كَانَ لِقَاوُكَ زُبْدَةَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The meeting with thee was"},{"kind":"text","text":"emphatically"},{"kind":"italic_en","text":"the event of life;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"the most relishable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing, event of life"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["Mgh","Msb","K","S","M","L"]}]},"classical_definitions":null}