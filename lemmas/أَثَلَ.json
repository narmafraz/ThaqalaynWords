","gen":"m","num":"p"},{"role":"present_2mp","form":"تَأْثِلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَأْثِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَأْثِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَأْثِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَأْثِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَأْثِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْثِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْثِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْثِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْثِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْثِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَأْثِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَثَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَثَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَثَلَ","root":"أثل","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n224","n227","n4594"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AB%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"tamarisk (Tamarix spp., particularly Tamarix aphylla)","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"From the root ء ث ل (ʔ ṯ l) meaning to be strong rooted, well-founded, deeply and firmly connected, tied with many roots; cognates with Aramaic אַתְלָא, Sabaean 𐩱𐩻𐩡 (ʾṯl), Hebrew אֵשֶׁל. Theoretically from Proto-Afroasiatic *ʔčl (“tamarisk, strong rooted tree”) with correspondence to Egyptian jzr (“tamarisk”). Alternatively, if not rooted in a common ancestor, one may be a loan derived from the other."},"ipa":["/ʔaθl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n224","headword_ar":"اَثَلَ","root":"Avl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^uvuwlN","text_ar":"اُثُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything, M)"},{"kind":"italic_en","text":"had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to have, root,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a foundation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"firmly rooted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"founded;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tA^v~l","text_ar":"تاثّل","orth_type":"arrow"},{"kind":"text","text":". (M, K.) ―         -b2-  Also, inf. n. as above,"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(dominion)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, great;"},{"kind":"text","text":"(TA;) and so ↓ the latter verb. (M, K. *) ―         -b3-  And"},{"kind":"arabic","text_bw":"A^avula","text_ar":"اَثُلَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^avaAlapN","text_ar":"اَثَالَةٌ"},{"kind":"text","text":", said of high rank, or nobility,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, old, of ancient origin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of long standing."},{"kind":"text","text":"(TA.)       -A2-  See also 5."}],"source_refs":[]},{"entry_id":"n227","headword_ar":"اَثْلٌ","root":"Avl","body":[{"kind":"italic_en","text":"A kind of trees;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"a species of the"},{"kind":"arabic","text_bw":"TarofaA='","text_ar":"طَرْفَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tamarisk;"},{"kind":"text","text":"so applied in the present day; termed by Forskål (Flora Aeg. Arab. p. lxiv.)"},{"kind":"italic_en","text":"tamarix orientalis"},{"kind":"text","text":"]; (S, TA;) or"},{"kind":"italic_en","text":"a kind of trees,"},{"kind":"text","text":"(T, M,) or"},{"kind":"italic_en","text":"a certain tree,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"resembling the"},{"kind":"arabic","text_bw":"TrfA='","text_ar":"طرفا=ء"},{"kind":"text","text":", (T, M, Mgh,)"},{"kind":"italic_en","text":"except that it is of a better kind,"},{"kind":"text","text":"(T,) or"},{"kind":"italic_en","text":"except that it is larger, and better in its wood,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"of which are made yellow and excellent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"vessels of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^aqodaAH","text_ar":"اَقْدَاح"},{"kind":"text","text":","},{"kind":"italic_en","text":"and of which was made the Prophet's pulpit; it has thick stems, of which are made doors and other things; and its leaves are of the kind called"},{"kind":"arabic","text_bw":"Eabal","text_ar":"عَبَل"},{"kind":"text","text":","},{"kind":"italic_en","text":"like those of the"},{"kind":"arabic","text_bw":"TrfA='","text_ar":"طرفا=ء"},{"kind":"text","text":": (TA:) AHn says, on the authority of Aboo-Ziyád, that"},{"kind":"italic_en","text":"it is of the kind termed"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":","},{"kind":"italic_en","text":"tail, and long in its wood, which is excellent, and is carried to the towns and villages, and the clay houses of these are built upon it;"},{"kind":"text","text":"[app. meaning that its wood is used in forming the foundations of the walls;]"},{"kind":"italic_en","text":"its leaves are of the kind called"},{"kind":"arabic","text_bw":"hadab","text_ar":"هَدَب"},{"kind":"text","text":", [syn. with"},{"kind":"arabic","text_bw":"Eabal","text_ar":"عَبَل"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"long and slender, and it has no thorns; of it are made [bowls of the kinds called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qiSaAE","text_ar":"قِصَاع"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"jifaAn","text_ar":"جِفَان"},{"kind":"text","text":";"},{"kind":"italic_en","text":"and it has a red fruit, like a knot of a rope:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"a kind of large trees, having no fruit:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"TrfA='","text_ar":"طرفا=ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"having no fruit:"},{"kind":"text","text":"(Bd in xxxiv. 15:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (S, M, Msb, K;) explained in the A as the"},{"kind":"arabic","text_bw":"samurap","text_ar":"سَمُرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"gum-acacia tree"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"a tall, straight"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tree such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EiDaAhap","text_ar":"عِضَاهَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"of which are made the like of"},{"kind":"arabic","text_bw":"A^aqodaAH","text_ar":"اَقْدَاح"},{"kind":"text","text":": (TA:) the pl. [of"},{"kind":"arabic","text_bw":"A^avolN","text_ar":"اَثْلٌ"},{"kind":"text","text":"] is"},{"kind":"arabic","text_bw":"A^uvuwlN","text_ar":"اُثُولٌ"},{"kind":"text","text":"(M, K) and [of"},{"kind":"arabic","text_bw":"A^avolapN","text_ar":"اَثْلَةٌ"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^avalaAvN","text_ar":"اَثَلَاثٌ"},{"kind":"text","text":". (S, K, TA (in the CK"},{"kind":"arabic","text_bw":"AavolAtN","text_ar":"اَثْلاتٌ"},{"kind":"text","text":"].) ―         -b2-  [See also"},{"kind":"arabic","text_bw":"A^avolapN","text_ar":"اَثْلَةٌ"},{"kind":"text","text":", below.]       -A2-"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"A^avolu maAlK","text_ar":"اَثْلُ مَالٍ"},{"kind":"italic_en","text":"Such a one is a collector of wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property."},{"kind":"text","text":"(Ibn-'Abbád.)"}],"source_refs":["T","M","Mgh","TA","Msb","K"]},{"entry_id":"n4594","headword_ar":"اثلّ","root":"vl","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"abounded in what is termed"},{"kind":"arabic","text_bw":"val~ap","text_ar":"ثَلَّة"},{"kind":"text","text":", (S, K,) which may mean either"},{"kind":"italic_en","text":"wool"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a flock of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats:"},{"kind":"text","text":"both these meanings are assigned to it in this case by Z. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Avl~hu","text_ar":"اثلّهُ"},{"kind":"italic_en","text":"He ordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commanded, the repairing of it;"},{"kind":"text","text":"(M;) or"},{"kind":"italic_en","text":"the repairing of what had been thrown down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demolished, of it."},{"kind":"text","text":"(IAar, S, K.)"}],"source_refs":["S","K"]}]}}