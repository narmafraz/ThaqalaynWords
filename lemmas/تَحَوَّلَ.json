s":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَحَوَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَحَوَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَحَوَّل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَحَوَّل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَحَوَّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَحَوَّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَحَوَّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَحَوَّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَحَوَّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَحَوَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَحَوَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتَحَوَّل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَحَوَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَحَوَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَحَوَّلْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n9576"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AD%D9%8E%D9%88%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to shift, to change, to become different","examples":[{"text":"اَلطَّبَقَاتُ ٱلْخَارِجِيَّةُ لِلشَّمْسِ سَوْفَ تَتَوَسَّعُ وَيَتَحَوَّلُ لَوْنُهَا.","english":"The sun's outer layers will expand and its colour will shift."}]},{"pos":"verb","gloss":"to become, to transform","examples":[{"text":"إِنَّهَا أُسْطُورَةٌ عِنْدَ ٱلْأَمْرِيكِيِّينَ ٱلْأَصْلِيِّينَ يَتَحَوَّلُ فِيهَا ٱلْبَشَرُ إِلَى حَيَوَانَاتٍ.","english":"It's a Native American myth where the humans transform into animals."}]},{"pos":"verb","gloss":"to deviate, to digress, to go away","examples":[{"text":"تَحَوَّلَ عَنِ ٱلطَّرِيقِ.","english":"to stray from the way"}]}]},"etymology":null,"ipa":["/ta.ħaw.wa.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9576","headword_ar":"تحوّل","root":"Hwl","body":[{"kind":"text","text":": see 1, first sentence, in three places. [Hence,]"},{"kind":"arabic","text_bw":"tHw~l mubotadiEFA","text_ar":"تحوّل مُبْتَدِعًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He turned innovator"},{"kind":"text","text":"]. (O and K in art."},{"kind":"arabic","text_bw":"bdE","text_ar":"بدع"},{"kind":"text","text":".) ―         -b2-"},{"kind":"italic_en","text":"It shifted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed,"},{"kind":"page_break","n":675},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became shifted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transferred,"},{"kind":"text","text":"(S, Msb, K,) from one place to another, (S,) or from its place; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"Hw~l","text_ar":"حوّل","orth_type":"arrow"},{"kind":"text","text":"(S, * Msb, K *) [and"},{"kind":"arabic","text_bw":"HAl","text_ar":"حال"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AstHAl","text_ar":"استحال"},{"kind":"text","text":", as shown above: see 1, near the beginning.] You say,"},{"kind":"arabic","text_bw":"tHw~l mino makaAnihi","text_ar":"تحوّل مِنْ مَكَانِهِ"},{"kind":"italic_en","text":"It shifted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from its place."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"tHw~l","text_ar":"تحوّل"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"italic_en","text":"It shifted from it to another."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"tHw~l A_ilaY makaAnK A=xara","text_ar":"تحوّل اـِلَى مَكَانٍ ا=خَرَ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"HaAla","text_ar":"حَالَ"},{"kind":"text","text":", q. v. (S.) And"},{"kind":"arabic","text_bw":"Almajar~apu","text_ar":"المَجَرَّةُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Haw~alati","text_ar":"حَوَّلَتِ","orth_type":"arrow"},{"kind":"italic_en","text":"The Milky Way became in the midst of the sky;"},{"kind":"text","text":"which it does in the summer, (Sh, K, TA,) when the season of heat comes on. (Sh, TA.) ―         -b3-  See also 8, in two places.       -A2-  Also, (S, K,) or"},{"kind":"arabic","text_bw":"tHw~l HaAlFA","text_ar":"تحوّل حَالًا"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He carried a bundle upon his back."},{"kind":"text","text":"(S, K, TA.) And"},{"kind":"arabic","text_bw":"tHw~l","text_ar":"تحوّل"},{"kind":"arabic","text_bw":"AlkisaA='i","text_ar":"الكِسَا=ءِ"},{"kind":"italic_en","text":"He put a thing in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"ksA'","text_ar":"كساء"},{"kind":"text","text":","},{"kind":"italic_en","text":"and then carried it on his back."},{"kind":"text","text":"(M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"tHw~lhu biAlmawoEiZapi","text_ar":"تحوّلهُ بِالمَوْعِظَةِ"},{"kind":"italic_en","text":"He sought to avail himself of the state in which he might be rendered prompt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"willing, to accept admonition."},{"kind":"text","text":"(AA, K.)"}],"source_refs":["S","Msb","K","Sh","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%AD%D9%88%D9%84/","headword_ar":"تَحَوُّل","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=114927#ef8474","body_html":"تَحَوُّل<br>من (ح و ل) الغيير والانتقال من مكان إلى آخر."}]}}