{"lemma":"خَزَرُ","slug":"خَزَرُ","root":"خ.ز.ر","root_slug":"خ-ز-ر","root_link":"/words/roots/خ-ز-ر","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n10484","n10487"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B2%D9%8E%D8%B1%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10484","headword_ar":"خزّر","root":"xzr","body":[{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"taxoziyrN","text_ar":"تَخْزِيرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He made narrow."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"xz~r Eayonayohi","text_ar":"خزّر عَيْنَيْهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an old man)"},{"kind":"italic_en","text":"narrowed his eyes; contracted his eyelids as though they were sewed together; to collect the light:"},{"kind":"text","text":"when a young man does so,"},{"kind":"arabic","text_bw":"yatadaAhaY","text_ar":"يَتَدَاهَى"},{"kind":"arabic","text_bw":"bi*`lika","text_ar":"بِذٰلِكَ"},{"kind":"text","text":"[i. e. he affects, or pretends, thereby, to be cunning; i. e. intelligent, or sagacious; or intelligent with a mixture of craft and forecast]. (IAar. [See also"},{"kind":"arabic","text_bw":"xazara","text_ar":"خَزَرَ"},{"kind":"text","text":": and see 6.])"}],"source_refs":["TA","K"]},{"entry_id":"n10487","headword_ar":"خَزَرٌ","root":"xzr","body":[{"kind":"text","text":"[commonly known only as inf. n. of"},{"kind":"arabic","text_bw":"xazira","text_ar":"خَزِرَ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"xazirati AlEayonu","text_ar":"خَزِرَتِ العَيْنُ"},{"kind":"text","text":"]: see"},{"kind":"arabic","text_bw":"xaziyrN","text_ar":"خَزِيرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}