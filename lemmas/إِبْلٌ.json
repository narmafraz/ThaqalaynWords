{"lemma":"إِبْلٌ","slug":"إِبْلٌ","root":"#.ب.ل","root_slug":"_-ب-ل","root_link":"/words/roots/_-ب-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"إِبْلٌ","root":"أبل","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n62","n63","n65","n66","n67","n68","n69","n3102","n3140"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D8%A8%D9%92%D9%84%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n62","headword_ar":"اَبِلَ","root":"Abl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, M, K;) and"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n."},{"kind":"arabic","text_bw":"A^abaAlapN","text_ar":"اَبَالَةٌ"},{"kind":"text","text":", (S, M, K,) of the former verb, (S, M, TA,) or, accord. to Sb,"},{"kind":"arabic","text_bw":"A_ibaAlapN","text_ar":"اـِبَالَةٌ"},{"kind":"text","text":", because it denotes an office, and, if so, of the latter verb, (TA,) and"},{"kind":"arabic","text_bw":"A^abalN","text_ar":"اَبَلٌ"},{"kind":"text","text":", (M, K,) which is of the former verb, (M, TA,) and"},{"kind":"arabic","text_bw":"A^abalapN","text_ar":"اَبَلَةٌ"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"galabapN","text_ar":"غَلَبَةٌ"},{"kind":"text","text":"]; (T;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, skilled in the good management of camels"},{"kind":"text","text":"(S, M, K) and"},{"kind":"italic_en","text":"of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats."},{"kind":"text","text":"(M, K.)"},{"kind":"arabic","text_bw":"A_ibaAlapN","text_ar":"اـِبَالَةٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"kitaAbapN","text_ar":"كِتَابَةٌ"},{"kind":"text","text":"[in measure], signifies The"},{"kind":"italic_en","text":"management,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tending,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"maAl","text_ar":"مَال"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other beasts"},{"kind":"text","text":"]. (A, TA.) You say,"},{"kind":"arabic","text_bw":"huwa Hasanu AlA_ibaAlapi","text_ar":"هُوَ حَسَنُ الاـِبَالَةِ"},{"kind":"italic_en","text":"He is good in the management,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tending, of his"},{"kind":"arabic","text_bw":"mAl","text_ar":"مال"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"camels, &c."},{"kind":"text","text":"]. (A, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":": see 2, second signification. ―         -b3-"},{"kind":"arabic","text_bw":"A^ubilati AlA_ibilu","text_ar":"اُبِلَتِ الاـِبِلُ"},{"kind":"italic_en","text":"The camels were gotten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired, as permanent property."},{"kind":"text","text":"(S, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"A^abilati AlA_ibilu","text_ar":"اَبِلَتِ الاـِبِلُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"A^abalat","text_ar":"اَبَلَت"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) inf. n. [of the former]"},{"kind":"arabic","text_bw":"A^abalN","text_ar":"اَبَلٌ"},{"kind":"text","text":"and [of the latter]"},{"kind":"arabic","text_bw":"A^ubuwlN","text_ar":"اُبُولٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"The camels became many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"numerous."},{"kind":"text","text":"(K.) ―         -b5-  Also"},{"kind":"arabic","text_bw":"A^ubalati AlA_ibilu","text_ar":"اُبَلَتِ الاـِبِلُ"},{"kind":"text","text":", (S, M, K,) and the like is said of wild animals, (S, M,) or others, (K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^ubuwlN","text_ar":"اُبُولٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"A^abolN","text_ar":"اَبْلٌ"},{"kind":"text","text":"; (M, K;) and"},{"kind":"arabic","text_bw":"A^abilat","text_ar":"اَبِلَت"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tA^bl~t","text_ar":"تابلّت","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"The camels were content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied, with green pasture, so as to be in no need of water:"},{"kind":"text","text":"(S, M, K:) the last verb is mentioned by Z, and he says that it is tropical, and hence"},{"kind":"arabic","text_bw":"A^abiylN","text_ar":"اَبِيلٌ"},{"kind":"text","text":"applied to “a monk.“ (TA.) ―         -b6-  [Hence,]"},{"kind":"arabic","text_bw":"A^abala Alr~ajulu","text_ar":"اَبَلَ الرَّجُلُ"},{"kind":"arabic","text_bw":"Eani A@moraA^atihi","text_ar":"عَنِ ا@مْرَاَتِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tA^b~l","text_ar":"تابّل","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,)"},{"kind":"italic_en","text":"The man was content to abstain from conjugal intercourse with his wife;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AijotazaA^aEanohaA","text_ar":"اِجْتَزَاَعَنْهَا"},{"kind":"text","text":"; (M;)"},{"kind":"italic_en","text":"the man abstained from conjugal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carnal, intercourse with his wife."},{"kind":"text","text":"(S, K, TA.) ―         -b7-  [Hence also]"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ"},{"kind":"text","text":", (K,)"},{"kind":"page_break","n":8},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"A^abolN","text_ar":"اَبْلٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He devoted himself to religious exercises;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became a devotee;"},{"kind":"text","text":"(K, TA;) as also"},{"kind":"arabic","text_bw":"A^abula","text_ar":"اَبُلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"faquha","text_ar":"فَقُهَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^abaAlapN","text_ar":"اَبَالَةٌ"},{"kind":"text","text":": or this signifies"},{"kind":"italic_en","text":"he became a monk."},{"kind":"text","text":"(TA.) ―         -b8-  And"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Kr, M, K,) inf. n."},{"kind":"arabic","text_bw":"A^abolN","text_ar":"اَبْلٌ"},{"kind":"text","text":", (Kr, M,) (assumed tropical:)"},{"kind":"italic_en","text":"He overcame,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"resisted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withstood;"},{"kind":"text","text":"(Kr, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^b~l","text_ar":"ابّل","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taA^obiylN","text_ar":"تَاْبِيلٌ"},{"kind":"text","text":"; (TA;) but the word commonly known is"},{"kind":"arabic","text_bw":"A^abal~a","text_ar":"اَبَلَّ"},{"kind":"text","text":". (M, TA.) ―         -b9-  Also (K, TA, but in the CK “ or ”)"},{"kind":"arabic","text_bw":"A^abalati AlA_ibilu","text_ar":"اَبَلَتِ الاـِبِلُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The camels were left to pasture at liberty, and went away, having with them no pastor:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"they became wild,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shy."},{"kind":"text","text":"(K, * TA.) ―         -b10-  And"},{"kind":"italic_en","text":"The camels sought by degrees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"step by step,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bit by bit, after the"},{"kind":"arabic","text_bw":"A^ubul","text_ar":"اُبُل"},{"kind":"text","text":"[q. v.], i. e."},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"xilofap","text_ar":"خِلْفَة"},{"kind":"italic_en","text":"of the herbage"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasture."},{"kind":"text","text":"(TA.) ―         -b11-  And, inf. n."},{"kind":"arabic","text_bw":"A^ubuwlN","text_ar":"اُبُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The camels remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"in the place: (M, K:) or"},{"kind":"italic_en","text":"remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, long"},{"kind":"text","text":"in the pasturage, and in the place. (El-Moheet, TA.) ―         -b12-"},{"kind":"arabic","text_bw":"A^abala AlEu$obN","text_ar":"اَبَلَ العُشْبٌ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^ubuwlN","text_ar":"اُبُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The herbage became tall, so that the camels were able to feed upon it."},{"kind":"text","text":"(K.) ―         -b13-"},{"kind":"arabic","text_bw":"A^abala Al$~ajaru","text_ar":"اَبَلَ الشَّجَرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^ubuwlN","text_ar":"اُبُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The trees had green"},{"kind":"text","text":"["},{"kind":"italic_en","text":"such,"},{"kind":"text","text":"app.,"},{"kind":"italic_en","text":"as is termed"},{"kind":"arabic","text_bw":"A^ubulN","text_ar":"اُبُلٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"growing in its dried parts, mixing therewith, upon which camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, fatten."},{"kind":"text","text":"(Ibn- 'Abbád.)       -A2-"},{"kind":"arabic","text_bw":"A^abalahu","text_ar":"اَبَلَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^abolN","text_ar":"اَبْلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He assigned to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave him,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"jaEala lahu","text_ar":"جَعَلَ لَهُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"pasturing camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels pasturing by themselves."},{"kind":"text","text":"(K.)"}],"source_refs":["S","M","K","TA","A","Kr"]},{"entry_id":"n63","headword_ar":"ابّل","root":"Abl","body":[{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"taA^obiylN","text_ar":"تَاْبِيلٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He took for himself, got, gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired, camels; he acquired them as permanent property."},{"kind":"text","text":"(S, K.) [See also 5.] ―         -b2-"},{"kind":"italic_en","text":"He was one whose camels had become numerous;"},{"kind":"text","text":"(T, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A=bl","text_ar":"ا=بل","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"A_iybaAlN","text_ar":"اـِيبَالٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A^abolN","text_ar":"اَبْلٌ"},{"kind":"text","text":". (TK.) ―         -b3-"},{"kind":"arabic","text_bw":"taA^obiylN AlA_ibili","text_ar":"تَاْبِيلٌ الاـِبِلِ"},{"kind":"italic_en","text":"The managing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"taking good care, of camels;"},{"kind":"text","text":"(M;) and"},{"kind":"italic_en","text":"the fattening of them:"},{"kind":"text","text":"(M, K:) mentioned by AHn, on the authority of Aboo—Ziyád ElKilábee. (M.)       -A2-  See also 1."}],"source_refs":["S","K","M"]},{"entry_id":"n65","headword_ar":"اـِبْلٌ","root":"Abl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A_ibilN","text_ar":"اـِبِلٌ"},{"kind":"text","text":": ―         -b2-  and"},{"kind":"arabic","text_bw":"A^abilN","text_ar":"اَبِلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n66","headword_ar":"اَبَلٌ","root":"Abl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^abalapN","text_ar":"اَبَلَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n67","headword_ar":"اَبِلٌ","root":"Abl","body":[{"kind":"italic_en","text":"Skilled in the good management of camels"},{"kind":"text","text":"(S, M, K) and"},{"kind":"italic_en","text":"of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"A=bilN","text_ar":"ا=بِلٌ","orth_type":"arrow"},{"kind":"text","text":": (S, M, K:) and"},{"kind":"arabic","text_bw":"A^abilN biAlA_ibili","text_ar":"اَبِلٌ بِالاـِبِلِ"},{"kind":"text","text":", and in poetry ↓"},{"kind":"arabic","text_bw":"A_ibolN","text_ar":"اـِبْلٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"skilled in the management,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"care, of camels."},{"kind":"text","text":"(T.) ―         -b2-  A man"},{"kind":"italic_en","text":"possessing camels;"},{"kind":"text","text":"(Fr, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A=bilN","text_ar":"ا=بِلٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) similar to"},{"kind":"arabic","text_bw":"taAmirN","text_ar":"تَامِرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"laAbinN","text_ar":"لَابِنٌ"},{"kind":"text","text":", (Ham p. 714,) but this is disapproved by Fr; (TA;) and ↓"},{"kind":"arabic","text_bw":"A_ibaliY~N","text_ar":"اـِبَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (S, M, O,) with fet-h to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"(S, O,) because several kesrehs together are deemed uncouth; (O;) in the K, erroneously, ↓"},{"kind":"arabic","text_bw":"A^abaliY~N","text_ar":"اَبَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", with two fet-hahs; (TA;) and ↓"},{"kind":"arabic","text_bw":"A_ibiliY~N","text_ar":"اـِبِلِىٌّ","orth_type":"arrow"},{"kind":"text","text":"also, (M, K,) with two kesrehs. (K.) ―         -b3-"},{"kind":"arabic","text_bw":"baEiyrN A^abilN","text_ar":"بَعِيرٌ اَبِلٌ"},{"kind":"italic_en","text":"A fleshy he-camel."},{"kind":"text","text":"(Ibn- 'Abbád, K.) ―         -b4-"},{"kind":"arabic","text_bw":"naAqapN A^bilapN","text_ar":"نَاقَةٌ ابِلَةٌ"},{"kind":"italic_en","text":"A she-camel blessed, prospered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to have increase, in respect of offspring."},{"kind":"text","text":"(Ibn-'Abbád, K.) In one place in the K,"},{"kind":"arabic","text_bw":"mina Alwaladi","text_ar":"مِنَ الوَلَدِ"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"fiY Alwaladi","text_ar":"فِى الوَلَدِ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","M","K","O"]},{"entry_id":"n68","headword_ar":"اُبُلٌ","root":"Abl","body":[{"kind":"text","text":"[mentioned in two places in the latter part of the first paragraph,] The"},{"kind":"arabic","text_bw":"xilofap","text_ar":"خِلْفَة"},{"kind":"italic_en","text":"of herbage,"},{"kind":"text","text":"(K,) i. e.,"},{"kind":"italic_en","text":"of dry herbage;"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"what grows in the season called"},{"kind":"arabic","text_bw":"AlS~ayof","text_ar":"الصَّيْف"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"summer, among herbage that has dried up;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"growing after a year; upon which camels, or the like, fatten."},{"kind":"text","text":"(TA.)"}],"source_refs":["K"]},{"entry_id":"n69","headword_ar":"اـِبِلٌ","root":"Abl","body":[{"kind":"text","text":"(T, S, M, Msb, K, &c.,) said by Sb to be the only subst. of this form except"},{"kind":"arabic","text_bw":"HibirN","text_ar":"حِبِرٌ"},{"kind":"text","text":", and to have none like it among epithets except"},{"kind":"arabic","text_bw":"bilizN","text_ar":"بِلِزٌ"},{"kind":"text","text":"; for though other instances are mentioned, they are not of established authority; (Msb;) but IJ mentions, with these,"},{"kind":"arabic","text_bw":"HibikN","text_ar":"حِبِكٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_iTilN","text_ar":"اـِطِلٌ"},{"kind":"text","text":"[which may be of established authority]; (TA;) [and to these may be added"},{"kind":"arabic","text_bw":"A_ibiTN","text_ar":"اـِبِطٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ibidN","text_ar":"اـِبِدٌ"},{"kind":"text","text":", and perhaps"},{"kind":"arabic","text_bw":"nikiHN","text_ar":"نِكِحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiTibN","text_ar":"خِطِبٌ"},{"kind":"text","text":"; respecting which see"},{"kind":"arabic","text_bw":"A_ibidN","text_ar":"اـِبِدٌ"},{"kind":"text","text":";] and for"},{"kind":"arabic","text_bw":"A_ibilN","text_ar":"اـِبِلٌ"},{"kind":"text","text":"one says also ↓"},{"kind":"arabic","text_bw":"A_iblN","text_ar":"اـِبلٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K, &c.,) sometimes, by way of contraction; (S, Msb;) or this may be a dial. var. of the former; (Kr, MF;) ["},{"kind":"italic_en","text":"Camels:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a herd of camels:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"at the least,"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"Siromap","text_ar":"صِرْمَة"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"a number"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of camels"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"more than a"},{"kind":"arabic","text_bw":"*awod","text_ar":"ذَوْد"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which is at least nine,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"up to thirty;"},{"kind":"text","text":"after which is the"},{"kind":"arabic","text_bw":"hajomap","text_ar":"هَجْمَة"},{"kind":"text","text":", i. e. forty and upwards; and then,"},{"kind":"arabic","text_bw":"hunayodapu","text_ar":"هُنَيْدَةُ"},{"kind":"text","text":", which is a hundred of"},{"kind":"arabic","text_bw":"A_ibil","text_ar":"اـِبِل"},{"kind":"text","text":": (T:) or, accord. to Ibn-'Abbád,"},{"kind":"italic_en","text":"a hundred of"},{"kind":"arabic","text_bw":"A_ibil","text_ar":"اـِبِل"},{"kind":"text","text":": (TA:) it is a quasi-pl. n.; (Az, S, ISd, Z, O, Msb, &c.;) a word having no proper sing.; (S, M, O, Msb;) and is of the fem. gender, because the quasi-pl. n. that has no proper sing. is necessarily fem. (S, O, Msb) when not applied to human beings, (S, O,) or when applied to irrational beings, (Msb,) and has"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"added in the dim.; (S, Msb;) the dim. of"},{"kind":"arabic","text_bw":"A_ibilN","text_ar":"اـِبِلٌ"},{"kind":"text","text":"being ↓"},{"kind":"arabic","text_bw":"A^ubayolapN","text_ar":"اُبَيْلَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, Msb, K:) it is said in the K that it is a sing. applied to a pl. number, and is not a pl., nor a quasi-pl. n.; but in this assertion together with the saying that the dim. is as above is a kind of contradiction; for if it be a sing., and not a quasi-pl. n., what is the reason of its being fem.? (TA:) the pl. is"},{"kind":"arabic","text_bw":"A=baAlN","text_ar":"ا=بَالٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^abiylN","text_ar":"اَبِيلٌ"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"EabiydN","text_ar":"عَبِيدٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"EabodN","text_ar":"عَبْدٌ"},{"kind":"text","text":", q. v.]; (Msb, TA;) the pl. meaning"},{"kind":"italic_en","text":"herds"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of camels"},{"kind":"text","text":"]; and in like manner"},{"kind":"arabic","text_bw":"A^agonaAmN","text_ar":"اَغْنَامٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aboqaArN","text_ar":"اَبْقَارٌ"},{"kind":"text","text":"mean flocks of sheep or goats and herds of bulls or cows: (Msb, TA:) and the dual,"},{"kind":"arabic","text_bw":"A_iblaAni","text_ar":"اـِبلَانِ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"two herds"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of camels"},{"kind":"text","text":"], (Sb, T, S, M, Msb,) each with its pastor; (T;) like as"},{"kind":"arabic","text_bw":"ganamaAni","text_ar":"غَنَمَانِ"},{"kind":"text","text":"means two flocks of sheep or goats: (S:) or, accord. to Ibn-'Abbád, the dual means"},{"kind":"italic_en","text":"two hundreds of"},{"kind":"arabic","text_bw":"A_ibil","text_ar":"اـِبِل"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AlA_ibilu AlS~ugoraY","text_ar":"الاـِبِلُ الصُّغْرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The smaller camels"},{"kind":"text","text":"] is an appellation applied to"},{"kind":"italic_en","text":"sheep;"},{"kind":"text","text":"because they eat more than goats. (IAar in TA art."},{"kind":"arabic","text_bw":"DbT","text_ar":"ضبط"},{"kind":"text","text":".) ―         -b3-  It is said in the Kur [lxxxviii. 17],"},{"kind":"arabic","text_bw":"A^afalaA yanoZuruwna A_ilaY A@loA_ibili kayofa","text_ar":"اَفَلَا يَنْظُرُونَ اـِلَى ا@لْاـِبِلِ كَيْفَ"},{"kind":"arabic","text_bw":"xuliqato","text_ar":"خُلِقَتْ"},{"kind":"text","text":", meaning, accord. to 'Aboo-Amr Ibn-El- 'Alà, (T, TA,) (tropical:)  ["},{"kind":"italic_en","text":"Will they not then consider"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the clouds that bear the water for rain, [how they are created?"},{"kind":"text","text":"] (T, K, TA:) but accord. to him who reads"},{"kind":"arabic","text_bw":"AlA_iboli","text_ar":"الاـِبْلِ"},{"kind":"text","text":", the meaning is,"},{"kind":"italic_en","text":"the camels."},{"kind":"text","text":"(T, TA.)"}],"source_refs":["T","TA","S","O","Msb","K","M","Sb"]},{"entry_id":"n3102","headword_ar":"ابلّ","root":"bl","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(wood, or a branch or twig,)"},{"kind":"italic_en","text":"had the sap,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlmaA='","text_ar":"المَا=ء"},{"kind":"text","text":", K,) or"},{"kind":"italic_en","text":"the produce of the rain,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"flowing in it."},{"kind":"text","text":"(O, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"bal~a","text_ar":"بَلَّ"},{"kind":"text","text":", in four places.       -A2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"resisted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withstood, and overcame."},{"kind":"text","text":"(As, T, S. [See also"},{"kind":"arabic","text_bw":"A^abala","text_ar":"اَبَلَ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Abl~","text_ar":"ابلّ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"He overcame him."},{"kind":"text","text":"(M, K.) [See an ex. in a verse of Sá'ideh, cited voce"},{"kind":"arabic","text_bw":"xasofN","text_ar":"خَسْفٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"He wearied by badness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wickedness:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he wearied another in aiding him to accomplish his desire."},{"kind":"text","text":"(TA. [See"},{"kind":"arabic","text_bw":"mubil~N","text_ar":"مُبِلٌّ"},{"kind":"text","text":".])       -A3-"},{"kind":"arabic","text_bw":"A^abolalotuhu","text_ar":"اَبْلَلْتُهُ"},{"kind":"italic_en","text":"I made him to go away."},{"kind":"text","text":"(Msb.)"}],"source_refs":["O","M","K"]},{"entry_id":"n3140","headword_ar":"اَبَلٌّ","root":"bl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, moist:"},{"kind":"text","text":"fem."},{"kind":"arabic","text_bw":"bal~aA='u","text_ar":"بَلَّا=ءُ"},{"kind":"text","text":": and pl."},{"kind":"arabic","text_bw":"bul~N","text_ar":"بُلٌّ"},{"kind":"text","text":". Hence,]"},{"kind":"arabic","text_bw":"Aljanuwbu A^abal~u Alr~iyaAHi","text_ar":"الجَنُوبُ اَبَلُّ الرِّيَاحِ"},{"kind":"italic_en","text":"The south is the most moist of the winds."},{"kind":"text","text":"(S.) ―         -b2-  [Hence, also,]"},{"kind":"arabic","text_bw":"maA $aYo'N A^abal~a lilojisomi m$na All~ahowi","text_ar":"مَا شَىْءٌ اَبَلَّ لِلْجِسْمِ مشنَ اللَّهْوِ"},{"kind":"italic_en","text":"Nothing is more healthful and suitable to the body than sport."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"SafaApN bal~aA='N","text_ar":"صَفَاةٌ بَلَّا=ءٌ"},{"kind":"italic_en","text":"A smooth stone"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rock."},{"kind":"text","text":"(S.) ―         -b4-  And"},{"kind":"arabic","text_bw":"A^abal~u","text_ar":"اَبَلُّ"},{"kind":"text","text":", applied to a man, (T, S, &c.,)"},{"kind":"italic_en","text":"Violent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, in contention, altercation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispute;"},{"kind":"text","text":"(T, M, K;) as also ↓"},{"kind":"arabic","text_bw":"bal~N","text_ar":"بَلٌّ","orth_type":"arrow"},{"kind":"text","text":": (K:) or (M) one"},{"kind":"italic_en","text":"who has no sense of shame:"},{"kind":"text","text":"(M, K:) or (TA) one"},{"kind":"italic_en","text":"who resists,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withstands,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and overcomes:"},{"kind":"text","text":"(TA:) or (M)"},{"kind":"italic_en","text":"very mean,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"from whom that which he possesses cannot be obtained,"},{"kind":"text","text":"(Ks, T, S, M, K,)"},{"kind":"italic_en","text":"by reason of his meanness;"},{"kind":"text","text":"(Ks, T, S;) and so"},{"kind":"arabic","text_bw":"bal~aA='u","text_ar":"بَلَّا=ءُ"},{"kind":"text","text":"applied to a woman: (Ks, S:) or"},{"kind":"italic_en","text":"mean,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"much given to the deferring of payment to his creditors,"},{"kind":"text","text":"(IAar, M, K,)"},{"kind":"italic_en","text":"much given to swearing"},{"kind":"text","text":"(T, S, K)"},{"kind":"italic_en","text":"and to wronging,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"withholding the rightful property of others;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"bal~N","text_ar":"بَلٌّ","orth_type":"arrow"},{"kind":"text","text":"[q. v.]: (IAar, M, [but referring only to what is given above on the authority of the former,] K, [referring to the same and to what follows except the addition in the TA,] and TA:) or, (S, M,) accord. to AO, (S,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"faAjiru","text_ar":"فَاجِرُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"vicious, immoral, unrighteous,"},{"kind":"text","text":"&c.]: (S, M, K:) fem."},{"kind":"arabic","text_bw":"bal~aA='u","text_ar":"بَلَّا=ءُ"},{"kind":"text","text":": (M, K:) and pl."},{"kind":"arabic","text_bw":"bul~u","text_ar":"بُلُّ"},{"kind":"text","text":": (K:) or it signifies one"},{"kind":"italic_en","text":"who pursues his course at random, not caring for what he meets."},{"kind":"text","text":"(Ham p. 383.)"}],"source_refs":["K","M","TA","Ks","T","S","IAar"]}]},"classical_definitions":null}