{"lemma":"تَنْجِيسِ","slug":"تَنْجِيسِ","root":"ن.ج.س","root_slug":"ن-ج-س","root_link":"/words/roots/ن-ج-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n39445"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%86%D9%92%D8%AC%D9%90%D9%8A%D8%B3%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39445","headword_ar":"تَنْجِيسٌ","root":"njs","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"name of a thing, either something unclean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bones of the dead,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a menstruous rag, which used to be hung upon him for whom there was a fear of the jinn's,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii's, being attached to him:"},{"kind":"text","text":"(K:) or the"},{"kind":"italic_en","text":"hanging of some such thing upon such a person, as a child"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any other; for they used to say that the jinn would not approach those things:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a thing which the Arabs used to do, as an amulet, to drive away thereby the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"evil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"eye:"},{"kind":"text","text":"(S:) ↓"},{"kind":"arabic","text_bw":"munaj~isapN","text_ar":"مُنَجِّسَةٌ","orth_type":"arrow"},{"kind":"text","text":"also is the name of"},{"kind":"italic_en","text":"a kind of amulet:"},{"kind":"text","text":"(IAar:) and ↓"},{"kind":"arabic","text_bw":"nijaAsN","text_ar":"نِجَاسٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"taEowiy*N","text_ar":"تَعْوِيذٌ"},{"kind":"text","text":"; [by which may be meant either that it signifies"},{"kind":"italic_en","text":"an amulet,"},{"kind":"text","text":"or that it is a quasi-inf. n. of 2; for it is said that] it is app. a subst. from"},{"kind":"arabic","text_bw":"naj~asa lahu","text_ar":"نَجَّسَ لَهُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"naj~asahu","text_ar":"نَجَّسَهُ"},{"kind":"text","text":", as signifying"},{"kind":"arabic","text_bw":"Eaw~a*ahu","text_ar":"عَوَّذَهُ"},{"kind":"text","text":". (IAar.) See also 2."}],"source_refs":["K","TA","S","IAar"]}]},"classical_definitions":null}