{"lemma":"مُصابُو","slug":"مُصابُو","root":"ص.#.ب","root_slug":"ص-_-ب","root_link":"/words/roots/ص-_-ب","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23592","n25131","n25132"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B5%D8%A7%D8%A8%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"wounded, injured, infected","examples":[{"text":"شَارَكَ فِي ٱلْمُبَارَاةِ بَيْدَ أَنَّهُ مُصَابٌ.","english":"He participated in the match although he was injured."}]},{"pos":"noun","gloss":"plural of مَصَبّ (maṣabb)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of the verb أَصَابَ (ʔaṣāba)."},"ipa":["/mu.sˤaːb/","/ma.sˤaːbb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23592","headword_ar":"مِصْاَبٌ","root":"SA^b","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who drinks much water:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"who satisfies and fills himself with drink."},{"kind":"text","text":"(K.)"}],"source_refs":["S"]},{"entry_id":"n25131","headword_ar":"مَصَابٌ","root":"Swb","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A place of pouring forth:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"maSaAwibu","text_ar":"مَصَاوِبُ"},{"kind":"text","text":"]. One says,"},{"kind":"arabic","text_bw":"huwa maSaAbu Alwadoqi","text_ar":"هُوَ مَصَابُ الوَدْقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It is the place of the pouring of rain"},{"kind":"text","text":"in the clouds]: and"},{"kind":"arabic","text_bw":"$imotu maSaAwiba","text_ar":"شِمْتُ مَصَاوِبَ"},{"kind":"arabic","text_bw":"AlmaTari","text_ar":"المَطَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I watched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"watched for, the places of the pouring of rain"},{"kind":"text","text":"in the clouds]: and"},{"kind":"arabic","text_bw":"saqaAhumo","text_ar":"سَقَاهُمْ"},{"kind":"arabic","text_bw":"maSaAwibu Als~amaA='a","text_ar":"مَصَاوِبُ السَّمَا=ءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The places of the pouring of the rain watered them;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may the places"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"water them"},{"kind":"text","text":"]. (A.)"}],"source_refs":[]},{"entry_id":"n25132","headword_ar":"مُصَابٌ","root":"Swb","body":[{"kind":"text","text":"pass. part. n. of 4 [meaning"},{"kind":"italic_en","text":"Hit, struck, smitten, wounded, hurt, affected, assailed, afflicted,"},{"kind":"text","text":"&c.]. (S, Msb, TA.) ―         -b2-"},{"kind":"italic_en","text":"Affected with weakness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feebleness, in the intellect;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"with somewhat of insanity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"madness produced by diabolical possession:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"mad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possessed."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"SaAbapN","text_ar":"صَابَةٌ"},{"kind":"text","text":"; and see also 4, last sentence; and"},{"kind":"arabic","text_bw":"A^aSowabu","text_ar":"اَصْوَبُ"},{"kind":"text","text":".]       -A2-  Also"},{"kind":"italic_en","text":"Syn. with"},{"kind":"arabic","text_bw":"A_iSaAbapN","text_ar":"اـِصَابَةٌ"},{"kind":"text","text":": (S, TA:) see 4, latter half, in two places. ―         -b2-  And"},{"kind":"italic_en","text":"Syn. with"},{"kind":"arabic","text_bw":"muSiybapN","text_ar":"مُصِيبَةٌ"},{"kind":"text","text":", q. v. (A, Msb.)       -A3-  Also The"},{"kind":"italic_en","text":"sugar-cane."},{"kind":"text","text":"(L, TA, and so in a copy of the S.)"}],"source_refs":["S","TA"]}]},"classical_definitions":null}