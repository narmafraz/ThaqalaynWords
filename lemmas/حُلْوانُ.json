{"lemma":"حُلْوانُ","slug":"حُلْوانُ","root":"ح.ل.#","root_slug":"ح-ل-_","root_link":"/words/roots/ح-ل-_","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n8958"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D9%84%D9%92%D9%88%D8%A7%D9%86%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8958","headword_ar":"حُلْوَانٌ","root":"Hlw","body":[{"kind":"text","text":"is a subst. [as well as an inf. n.], signifying"},{"kind":"italic_en","text":"A gift:"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"a gratuity:"},{"kind":"text","text":"so in the present day:] the"},{"kind":"italic_en","text":"hire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pay,"},{"kind":"text","text":"of a broker; (Lh, K;) and of a diviner, (As, S, * Msb, * K,) for divination, (As,) which is forbidden in a trad.: (S, Msb:) and"},{"kind":"italic_en","text":"a requital;"},{"kind":"text","text":"see 1. (IAar, K.) Also The"},{"kind":"italic_en","text":"dowry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nuptial gift,"},{"kind":"text","text":"of a woman: (Msb, K:) [or"},{"kind":"italic_en","text":"a portion thereof which the father"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guardian of the bride used, in some cases, to take for himself;"},{"kind":"text","text":"see 1:] or"},{"kind":"italic_en","text":"a gift to a woman in consideration of having her as a wife during a certain fixed period;"},{"kind":"text","text":"(K;) according to a practice obtaining in Mekkeh: (TA:) or"},{"kind":"italic_en","text":"a gift of the nature of a bride."},{"kind":"text","text":"(K.)"}],"source_refs":["Msb","As","S","K","TA"]}]}}