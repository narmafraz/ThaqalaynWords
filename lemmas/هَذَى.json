um":"s"},{"role":"present_1mp","form":"نَهْذ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَهْذ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":136,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n44272"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%B0%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to trip, to rave, to be delirious, to hallucinate, to dote"},{"pos":"verb","gloss":"to blather, to smatter, to maunder"}]},"etymology":null,"ipa":["/ha.ðaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44272","headword_ar":"هَذَى","root":"h*Y","body":[{"kind":"italic_en","text":"He talked nonsense; he raved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talked irrationally, foolishly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deliriously;"},{"kind":"text","text":"(JK, K;)"},{"kind":"italic_en","text":"by reason of disease or some other cause."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"ha*aYbihi","text_ar":"هَذَىبِهِ"},{"kind":"italic_en","text":"He talked irrationally,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"italic_en","text":"He mentioned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in his irrational,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"talk."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%87%D8%B0%D9%89/","headword_ar":"هذى","entries":[{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=11177#2a9e5a","body_html":"<span class=\"title1\">[هذى]</span><span> هَذَى في منطقة يَهْذي ويَهْذو هَذْواً وهَذَياناً. وهَذَوْتُ بالسيف مثل هذذت.</span>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=11177#15a58a","body_html":"<span class=\"title1\">(هذى)</span><span> - في حديث علَىّ - رضي الله عنه -: \"في السَّكران إذا سَكِر</span><span> </span><span>هَذَى، وإذا هَذَى افترى\"</span><br><span>يقال: هَذَى يَهذِى ويَهذُو هَذْياً وهَذَياناً؛ إذا جَاء بالكَلاَم المُثَبَّج علَى غَير وَجهِ الصَّوابِ.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=11177#172526","body_html":"<h3>هذ</h3>ى<span class=\"sense\">1</span> هَذَى He talked nonsense; he raved, or talked irrationally, foolishly, or deliriously; (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) by reason of disease or some other cause. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> هَذَىبِهِ He talked irrationally, &amp;c., with him. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> And He mentioned him, or it, in his irrational, &amp;c., talk. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 3 غَعَدَ يُهَاذِىأَصْحَابَهُ [He sat talking irrationally, &amp;c., with his companions]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> سَمِعْتُهُمْ يَتَهَاذُونَ [I heard them talking together irrationally, &amp;c.] (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) شَرَابٌ هَاذٍ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [Beverage causing delirious, or irrational, talk.] (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"}]}}