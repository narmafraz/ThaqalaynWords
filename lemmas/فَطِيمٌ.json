{"lemma":"فَطِيمٌ","slug":"فَطِيمٌ","root":"ف.ط.م","root_slug":"ف-ط-م","root_link":"/words/roots/ف-ط-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n34166"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B7%D9%90%D9%8A%D9%85%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34166","headword_ar":"فَطِيمٌ","root":"fTm","body":[{"kind":"text","text":"A child"},{"kind":"italic_en","text":"weaned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ablactated;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"mafoTuwmN","text_ar":"مَفْطُومٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) pl. of the former"},{"kind":"arabic","text_bw":"fuTumN","text_ar":"فُطُمٌ"},{"kind":"text","text":", (S, Msb, K,) which is of a rare form as pl. of an epithet of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":", and more particularly of such as is used in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":". (IAth, TA.) And"},{"kind":"arabic","text_bw":"saxolapN faTiymN","text_ar":"سَخْلَةٌ فَطِيمٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"faTiymapN","text_ar":"فَطِيمَةٌ"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"faATimN","text_ar":"فَاطِمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mafoTuwmapN","text_ar":"مَفْطُومَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A lamb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kid, weaned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ablactated,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"which is the case two months from its birth, and it ceases not to be thus termed until it becomes a"},{"kind":"arabic","text_bw":"jafor","text_ar":"جَفْر"},{"kind":"text","text":"[q. v.]. (TA.)"}],"source_refs":["K","S","Msb","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%B7%D9%8A%D9%85/","headword_ar":"فطيمي","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=103806#ad0432","body_html":"فطيمي<br>عن العبرية بمعنى سمين بدين مسمن والياء للنسب."}]}}