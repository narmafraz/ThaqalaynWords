n":"m","num":"p"},{"role":"present_2mp","form":"تُعاقِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعاقِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعاقِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعاقِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعاقِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعاقِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعاقِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعاقِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعاقِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعاقِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعاقِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"عاقَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عاقَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعاقِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعاقِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"عاقَرَ","root":"عقر","pos":"N","occurrence_count":3},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n29924"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%82%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29924","headword_ar":"عَاقِرٌ","root":"Eqr","body":[{"kind":"text","text":"; see"},{"kind":"arabic","text_bw":"miEoqarN","text_ar":"مِعْقَرٌ"},{"kind":"text","text":".       -A2-  Also, applied to a woman,"},{"kind":"italic_en","text":"Barren:"},{"kind":"text","text":"(O, K, TA:)"},{"kind":"italic_en","text":"that does not conceive:"},{"kind":"text","text":"(S, O:) or"},{"kind":"italic_en","text":"that has ceased to conceive:"},{"kind":"text","text":"(Msb:) as being from"},{"kind":"arabic","text_bw":"Eaqurato","text_ar":"عَقُرَتْ"},{"kind":"text","text":", it is an instance of the confusion of dialects; [being properly from"},{"kind":"arabic","text_bw":"Eaqarato","text_ar":"عَقَرَتْ"},{"kind":"text","text":";] or it is a possessive epithet [meaning"},{"kind":"italic_en","text":"having the quality of barrenness"},{"kind":"text","text":"]: (IJ:) pl."},{"kind":"arabic","text_bw":"Euq~arN","text_ar":"عُقَّرٌ"},{"kind":"text","text":", (K, TA,) which is applied to women and to she-camels, (TA,) or"},{"kind":"arabic","text_bw":"EawaAqiru","text_ar":"عَوَاقِرُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAqiraAtN","text_ar":"عَاقِرَاتٌ"},{"kind":"text","text":": (Msb:) and ↓"},{"kind":"arabic","text_bw":"EuqarapN","text_ar":"عُقَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"is in like manner applied to a woman, signifying,"},{"kind":"italic_en","text":"having a disease in her womb,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"in consequence of which she does not conceive."},{"kind":"text","text":"(TA.) ―         -b2-  Applied to a man,"},{"kind":"italic_en","text":"Barren; that has no offspring born to him;"},{"kind":"text","text":"(S, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"EaqiyrN","text_ar":"عَقِيرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) the former anomalous; [if regarded as from"},{"kind":"arabic","text_bw":"Eaqura","text_ar":"عَقُرَ"},{"kind":"text","text":", not from"},{"kind":"arabic","text_bw":"Eaqara","text_ar":"عَقَرَ"},{"kind":"text","text":"; but"},{"kind":"arabic","text_bw":"Eaqura","text_ar":"عَقُرَ"},{"kind":"text","text":"said of a man, I do not find;] the latter regular; [if from"},{"kind":"arabic","text_bw":"Eaqura","text_ar":"عَقُرَ"},{"kind":"text","text":";] and the latter has not been heard applied to a woman: (TA:) pl."},{"kind":"arabic","text_bw":"Euq~arN","text_ar":"عُقَّرٌ"},{"kind":"text","text":": (Msb, TA:) and ↓"},{"kind":"arabic","text_bw":"EuqarapN","text_ar":"عُقَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"is also applied to a man, and signifies, one"},{"kind":"italic_en","text":"who comes to women, and feels them, and indulges himself with them in mutual embracing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing to the bosom,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yuHaADinuhun~a","text_ar":"يُحَاضِنُهُنَّ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"but has no offspring born to him."},{"kind":"text","text":"(IAar, TA.) ―         -b3-  (tropical:)  A tree ("},{"kind":"arabic","text_bw":"$ajarapN","text_ar":"شَجَرَةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"that does not bear; barren:"},{"kind":"text","text":"and in like manner ↓"},{"kind":"arabic","text_bw":"EaqirapN","text_ar":"عَقِرَةٌ","orth_type":"arrow"},{"kind":"text","text":", occurring in a trad., as the name of a certain tract of land ("},{"kind":"arabic","text_bw":"A^aroDN","text_ar":"اَرْضٌ"},{"kind":"text","text":"), which name Mohammad changed to"},{"kind":"arabic","text_bw":"xaDirapN","text_ar":"خَضِرَةٌ"},{"kind":"text","text":"; or this may be from the same epithet applied to a palm-tree. (TA.) [See also"},{"kind":"arabic","text_bw":"EaqiyrN","text_ar":"عَقِيرٌ"},{"kind":"text","text":".] ―         -b4-  Applied to a tract of sand ("},{"kind":"arabic","text_bw":"ramolapN","text_ar":"رَمْلَةٌ"},{"kind":"text","text":"), (tropical:)"},{"kind":"italic_en","text":"That produces no plants"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage;"},{"kind":"text","text":"(O, K, TA;) likened to a [barren] woman: (TA:) or"},{"kind":"italic_en","text":"of which the sides produce plants"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, but the middle does not produce:"},{"kind":"text","text":"(TA:) or such as is"},{"kind":"italic_en","text":"large:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"large and producing no plants"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(S.)"}],"source_refs":["O","K","TA","S","Msb","IJ"]}]},"classical_definitions":null}