":"m","num":"p"},{"role":"present_1ms","form":"أَطْم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْمِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطْمِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُطْمَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُطْمَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"طَمَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَمَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become high and flood over, to inundate, to overflow"}]},"etymology":null,"ipa":["/tˤa.maː/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D9%85%D9%89/","headword_ar":"طمى","entries":[{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10788#6f9503","body_html":"<span class=\"title1\">باب الطاء والميم و (وا يء) معهما ط م ا، م ط ا، ء ط م، وط م، م ي ط مستعملات</span><br><br><span>طمى: طَمَى الماء يطمي طَمياً، ويَطمُوا طُمُوّاً وطُمِيّاً فهو طامٍ وذلك إذا امتلأ البَحْرُ أو النَّهْرُ أو البِئْرُ، قال:</span><br><br><span>إذا رجزت قَحْطانُ يومَ عَظيمةٍ </span><span class=\"red\">...</span><span> رأيتَ بُحُوراً من بحورهم تطمو </span><span> </span><span>مطا: مُطِيَ في الشَّمْس: مُدَّ، وكلّ شَيءٍ مَدَدْتَهُ فقد مَطَوْته، ومنه: المَطوُ في السَّير، ومنه يقال: يَتَمَطَّى، إنّما هو تمديد جسده. والمُطَيطاءُ: التَّبَخْتُرُ، ومنه قوله جلّ وعزّ: ذَهَبَ إِلى أَهْلِهِ يَتَمَطَّى</span><br><br><span> ، أي: يَتَبَخْتَرُ.</span><br><br><span>أطم: الأُطُم: حِصْنٌ بناه أهلُ المدينة من حجارة. وتأطَّمَ السَّيْلُ إذا ارتفع في وجهه طَحَماتٌ كالأمواج، ثمَّ يُكْسَرُ بعضه على بعض، قال رؤبة: </span><br><br><span>إذا ارتمى في وَأْدِهِ تَأَطَّمُهْ</span><br><br><span>وتَأَطَّمَتِ الحِيطانُ، إذا هَمَّتْ بالسُّقُوط. والأَطُومُ: السُّلَحْفاةُ البحريّ الذي يُجعَلُ من جلده (الزيَل ) ، ورُبَّما شبِّهَ جِلدُ البَعير الأملس به. والأَطُومُ: سَمَكَةٌ في البَحر قد رأيت جلدها، وكان أصحابنا يقولون: إنّها بقرة، حتّى رأيت جِلْدَها يُتَّخَذُ منه الخِفاف للجمّالين، قال الشماخ: </span><span> </span><a></a><span>وجلدها من أطوم ما يُؤَيِّسُهُ </span><span class=\"red\">...</span><span> طِلحٌ كضاحية الصَّحْراء مَهزولُ</span><br><br><span>وطم : وطمت الشّيء أَطِمُهُ: أرخيته.</span><br><br><span>ميط : قولهم: ما زِلنا بالهياط والمِياط: الهِياطُ: المُزاوَلةُ، والمِياطُ: المَيْلُ. ويُقال: أماط الله عنك الأَذَى، أي: نحّاه. ويقال: أرادوا بالهِياطِ الجَلَبة والصَّخَب، وبالمياط التَّباعُدُ والتَّنَحِّي والميل.</span>"}]}}