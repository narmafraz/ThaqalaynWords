","headword_ar":"مُدَّخِرٌ","root":"dxr","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"*xr","text_ar":"ذخر"},{"kind":"text","text":"."}],"source_refs":[]}]}}