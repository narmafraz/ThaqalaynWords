present_2mp","form":"تَطْمَئِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطْمَئِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطْمَأْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطْمَئِنّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطْمَئِنّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطْمَئِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطْمَئِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطْمَئِنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْمَئِنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطْمَئِنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْمَئِنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْمَأْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَطْمَئِنّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْمَئِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"اِطْمَأْنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِطْمَأْنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":true,"lemma_key":"اِطْمَأَنَّ","root":"طمأن","pos":"V","occurrence_count":9},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n27127"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B7%D9%92%D9%85%D9%8E%D8%A3%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to remain quietly"},{"pos":"verb","gloss":"to come to rest"},{"pos":"verb","gloss":"to be calm, to be confident"},{"pos":"verb","gloss":"to be certain"},{"pos":"verb","gloss":"to have confidence (in), to trust (in), to depend (on)"},{"pos":"verb","gloss":"to make sure (of), to reassure oneself"},{"pos":"verb","gloss":"to find reassurance (in)"},{"pos":"verb","gloss":"to ascertain"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27127","headword_ar":"اِطْمَاَنَّ","root":"Tmn","body":[{"kind":"text","text":"is said by some to be originally ["},{"kind":"arabic","text_bw":"AiTomaAn~a","text_ar":"اِطْمَانَّ"},{"kind":"text","text":"] like"},{"kind":"arabic","text_bw":"AiHomaAr~a","text_ar":"اِحْمَارَّ"},{"kind":"text","text":", (Msb,) as Esh-Shiháb states in the Expos. of the Shifè, (TA,) and to be pronounced with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"for the purpose of avoiding [the combination of] the two quiescent letters, (Msb, TA,) anomalously: (Msb:) and some say that it is originally"},{"kind":"arabic","text_bw":"AiToA^aman~a","text_ar":"اِطْاَمَنَّ"},{"kind":"text","text":", (Msb, TA,) because you say"},{"kind":"arabic","text_bw":"TaA^omana Alr~ajulu Zahorahu","text_ar":"طَاْمَنَ الرَّجُلُ ظَهْرَهُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (Msb,) or, as Suh says, in the R, because it is from"},{"kind":"arabic","text_bw":"taTA^omana","text_ar":"تَطاْمَنَ"},{"kind":"text","text":", the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"being put before the"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"in order to render the word more easy of pronunciation, (TA,) therefore it is anomalous; (Msb;) Sb [likewise] held it to be formed by transposition, and derived from"},{"kind":"arabic","text_bw":"TaA^omana","text_ar":"طَاْمَنَ"},{"kind":"text","text":"; but AA held the contrary to be the case. (TA.) ―         -b2-  You say,"},{"kind":"arabic","text_bw":"AiTomaA^an~ati AlA^aroDu","text_ar":"اِطْمَاَنَّتِ الاَرْضُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"taTaAmanat","text_ar":"تَطَامَنَت","orth_type":"arrow"},{"kind":"text","text":"[or ↓"},{"kind":"arabic","text_bw":"taTaA^omanat","text_ar":"تَطَاْمَنَت","orth_type":"arrow"},{"kind":"text","text":"], meaning"},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed."},{"kind":"text","text":"(TA.) ―         -b3-  See also Q. Q. 2. ―         -b4-"},{"kind":"arabic","text_bw":"ATmA^n~","text_ar":"اطمانّ"},{"kind":"text","text":", (S, Mgh, K,) inf. n."},{"kind":"arabic","text_bw":"AiTomiy^onaAnN","text_ar":"اِطْمِيْنَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TumaA^oniynapN","text_ar":"طُمَاْنِينَةٌ"},{"kind":"text","text":", (S, K,) or the latter is a simple subst., (Mgh, Msb,) signifies [also]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still, in a state of rest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease, quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":"; (S, Mgh;) as also"},{"kind":"arabic","text_bw":"AiTobaA^an~a","text_ar":"اِطْبَاَنَّ"},{"kind":"text","text":", which is formed by permutation. (S.) And thus it signifies as said of the heart, i. e."},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still, in a state of rest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease, quiet, calm, tranquil, unruffled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from disquietude."},{"kind":"text","text":"(Msb.) Thus too in the saying,"},{"kind":"arabic","text_bw":"ATmA^n A_ilaY ka*aA","text_ar":"اطمان اـِلَى كَذَا"},{"kind":"text","text":", i. e. (tropical:)"},{"kind":"italic_en","text":"He trusted to such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relied upon it, so as to become at rest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quiet, in mind."},{"kind":"text","text":"(K, * TA.) And one says also,"},{"kind":"arabic","text_bw":"ATmA^n~ jaAlisFA","text_ar":"اطمانّ جَالِسًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He became still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at ease, sitting"},{"kind":"text","text":"]: (TA:) and"},{"kind":"arabic","text_bw":"ATmA^n~ binaA","text_ar":"اطمانّ بِنَا"},{"kind":"arabic","text_bw":"Aljuluwsu","text_ar":"الجُلُوسُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"The sitting became still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from disquiet, with us"},{"kind":"text","text":"]; meaning"},{"kind":"arabic","text_bw":"AisotaqoraronaA wasakan~aA fiY","text_ar":"اِسْتَقْرَرْنَا وَسَكَنَّا فِى"},{"kind":"arabic","text_bw":"Aljuluwsi","text_ar":"الجُلُوسِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"we became settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at rest"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease, and still, in the sitting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became seated at ease"},{"kind":"text","text":"]. (Har p. 280.) And"},{"kind":"arabic","text_bw":"ATmA^n~ biAlmawoDiEi","text_ar":"اطمانّ بِالمَوْضِعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He settled in the place;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"he remained, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt, in the place, and took it as his home."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"ATmA^n~ Eam~aA kaAna yafoEaluhu","text_ar":"اطمانّ عَمَّا كَانَ يَفْعَلُهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He became at rest from that which he was doing;"},{"kind":"text","text":"] i. e."},{"kind":"italic_en","text":"he desisted from that which he was doing."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"fiyhi taTaAmunN","text_ar":"فِيهِ تَطَامُنٌ","orth_type":"arrow"},{"kind":"text","text":"[or ↓"},{"kind":"arabic","text_bw":"taTaA^omunN","text_ar":"تَطَاْمُنٌ","orth_type":"arrow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"In him is quietness, calmness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sedateness."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","TA","S","Mgh","K"]}]},"classical_definitions":null}