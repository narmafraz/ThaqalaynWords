{"lemma":"عالِيَةُ","slug":"عالِيَةُ","root":"ع.ل.#","root_slug":"ع-ل-_","root_link":"/words/roots/ع-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"عالِيَة","root":"علو","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30432"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%84%D9%90%D9%8A%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"feminine singular of عَالٍ (ʕālin)","tags":["feminine","form-of","singular"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30432","headword_ar":"عَالِيَةٌ","root":"Elw","body":[{"kind":"text","text":"[a subst. from"},{"kind":"arabic","text_bw":"EaAlK","text_ar":"عَالٍ"},{"kind":"text","text":", rendered such by the affix"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"]: see"},{"kind":"arabic","text_bw":"EulowN","text_ar":"عُلْوٌ"},{"kind":"text","text":". ―         -b2-  Also [particularly] The"},{"kind":"italic_en","text":"upper portion"},{"kind":"text","text":"of the spear-shaft; (K, TA;)"},{"kind":"arabic","text_bw":"saAfilapN","text_ar":"سَافِلَةٌ"},{"kind":"text","text":"signifying the “ lower portion ” thereof: (TA:) or the"},{"kind":"italic_en","text":"head"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"rA^s","text_ar":"راس"},{"kind":"text","text":") thereof: or the"},{"kind":"italic_en","text":"half that is next to the iron head:"},{"kind":"text","text":"(K, TA:) or the"},{"kind":"italic_en","text":"part,"},{"kind":"text","text":"of the spear,"},{"kind":"italic_en","text":"that is below the iron head:"},{"kind":"text","text":"(Er-Rághib, TA:) or the"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"of the spear,"},{"kind":"italic_en","text":"that enters the iron head, extending to the third part thereof"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"of the shaft;"},{"kind":"text","text":"so that it signifies the"},{"kind":"italic_en","text":"uppermost of the three equal portions of the shaft"},{"kind":"text","text":"]: (S, TA:) pl."},{"kind":"arabic","text_bw":"EawaAlK","text_ar":"عَوَالٍ"},{"kind":"text","text":", which some explain as meaning the"},{"kind":"italic_en","text":"iron heads"},{"kind":"text","text":"of spears. (TA. [See an ex. of the pl. in a verse cited voce"},{"kind":"arabic","text_bw":"zuj~N","text_ar":"زُجٌّ"},{"kind":"text","text":".]) Also"},{"kind":"italic_en","text":"A straight spear-shaft."},{"kind":"text","text":"(TA.) ―         -b3-  And The ["},{"kind":"italic_en","text":"upper"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"part,"},{"kind":"text","text":"of a valley,"},{"kind":"italic_en","text":"whence the water thereof descends."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"AlEaAliyapu","text_ar":"العَالِيَةُ"},{"kind":"text","text":", also, is"},{"kind":"italic_en","text":"The region above Nejd, extending to the land of Tihámeh,"},{"kind":"text","text":"(S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"and to the part behind Mekkeh,"},{"kind":"text","text":"(S, K,) i. e. ["},{"kind":"italic_en","text":"to"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"El- Hijáz and what is next to it:"},{"kind":"text","text":"(S:) and it is said that the"},{"kind":"arabic","text_bw":"EaAliyap","text_ar":"عَالِيَة"},{"kind":"text","text":"of El-Hijáz is the"},{"kind":"italic_en","text":"higher and more elevated part thereof, forming a wide extent of country."},{"kind":"text","text":"(TA.) And [its pl.]"},{"kind":"arabic","text_bw":"AlEawaAliY","text_ar":"العَوَالِى"},{"kind":"text","text":", (K, TA,) as also"},{"kind":"arabic","text_bw":"AlEaAliyapu","text_ar":"العَالِيَةُ"},{"kind":"text","text":", (TA,) is applied to"},{"kind":"italic_en","text":"Certain towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages, in the exterior of El-Medeeneh,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"the nearest four miles distant from it, and the most distant, in the direction of Nejd, eight."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","K","S","Mgh","Msb"]}]},"classical_definitions":null}