2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْتَمِعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْتَمِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْتَمِع","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْتَمِع","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْتَمِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْتَمِعانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْتَمِعا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْتَمِعانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْتَمِعُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْتَمِعُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْتَمِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"اِجْتَمَعْتُ","in_corpus":true,"count":23,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِجْتَمَعْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَجْتَمِع","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْتَمِع","in_corpus":true,"count":37,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":241,"cross_references":{"qac":{"found":true,"lemma_key":"اِجْتَمَعَ","root":"جمع","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n6309"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AC%D9%92%D8%AA%D9%8E%D9%85%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6309","headword_ar":"اجتمع","root":"jmE","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing in a scattered or dispersed state, S, and a number of men, Msb, [and a number of things,])"},{"kind":"italic_en","text":"became collected, brought together, gathered together, gathered up, assembled, congregated, mustered, drawn together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it collected, collected itself together, gathered itself together, came together, assembled, congregated, drew itself together, contracted itself; coalesced; combined;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"so that the several parts or portions became near"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"close"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"together;"},{"kind":"text","text":"(TA;) as also"},{"kind":"arabic","text_bw":"AijodamaEa","text_ar":"اِجْدَمَعَ"},{"kind":"text","text":", (K,) with"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":"[substituted for the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"]; (TA;) and ↓"},{"kind":"arabic","text_bw":"tjm~E","text_ar":"تجمّع","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstjmE","text_ar":"استجمع","orth_type":"arrow"},{"kind":"text","text":"signify the same: (Msb, K:) and ↓"},{"kind":"arabic","text_bw":"tjm~EwA","text_ar":"تجمّعوا","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"they became collected,"},{"kind":"text","text":"&c., ["},{"kind":"italic_en","text":"from several places,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"hence and thence."},{"kind":"text","text":"(S, K:) [See also 10.] You say also,"},{"kind":"arabic","text_bw":"AjtmE maEahu","text_ar":"اجتمع مَعَهُ"},{"kind":"text","text":"(Mgh) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"(Msb) [meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in company with him; came together with him; met with him; met him; had a meeting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an interview, with him"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"AjtmE maEahu EalaY A^amori ka*aA","text_ar":"اجتمع مَعَهُ عَلَى اَمْرِ كَذَا"},{"kind":"text","text":": (S, K:) see 3, first sentence: and see the sentence there next following. And in like manner,"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjm~EwA","text_ar":"تجمّعوا","orth_type":"arrow"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"italic_en","text":"They combined, conspired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leagued, together against such a one."},{"kind":"text","text":"(Ibn-Buzurj, TA in art."},{"kind":"arabic","text_bw":"Dfr","text_ar":"ضفر"},{"kind":"text","text":".) [See also"},{"kind":"arabic","text_bw":"AjtmEwA EalaY AlA^amori","text_ar":"اجتمعوا عَلَى الاَمْرِ"},{"kind":"text","text":"in 4, latter half.] You also say,"},{"kind":"arabic","text_bw":"AijotamaEati A=raAw^uhumo EalaY AlA^amori","text_ar":"اِجْتَمَعَتِ ا=رَاوُهُمْ عَلَى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Their opinions agreed together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"were in unison, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting, the affair"},{"kind":"text","text":"]. (Er-Rághib.) And"},{"kind":"arabic","text_bw":"AijotamaEato $araAy^iTu AlA_imaAmapi","text_ar":"اِجْتَمَعَتْ شَرَايِطُ الاـِمَامَةِ"},{"kind":"italic_en","text":"The conditions of the office of Imám occurred together"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"were combined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they coexisted,"},{"kind":"text","text":"in such a case]; as also ↓"},{"kind":"arabic","text_bw":"AisotajomaEato","text_ar":"اِسْتَجْمَعَتْ","orth_type":"arrow"},{"kind":"text","text":". (Msb: [but it is implied in the Mgh that the latter verb in this sense is not of established authority.]) [See a similar ex. voce"},{"kind":"arabic","text_bw":"ArtfE","text_ar":"ارتفع"},{"kind":"text","text":".] ―         -b2-  ["},{"kind":"italic_en","text":"He"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, compact"},{"kind":"text","text":"in make or frame,"},{"kind":"italic_en","text":"compressed, contracted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"―         -b3-  And hence,]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"attained to his full state of manly vigour, and his beard became fullgrown."},{"kind":"text","text":"(K, TA.) The verb is not thus used in speaking of a woman. (S, TA.) ―         -b4-  [Hence also,]"},{"kind":"arabic","text_bw":"AjtmE fiY AlHaAjapi","text_ar":"اجتمع فِى الحَاجَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was quick and vigorous in executing the needful affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in"},{"kind":"text","text":"accomplishing"},{"kind":"italic_en","text":"that which was wanted;"},{"kind":"text","text":"as though he compacted his frame, and collected all his energy: see"},{"kind":"arabic","text_bw":"ma$aY mujotamiEFA","text_ar":"مَشَى مُجْتَمِعًا"},{"kind":"text","text":", below: and see also 10]. (TA in art."},{"kind":"arabic","text_bw":"km$","text_ar":"كمش"},{"kind":"text","text":".) ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"AijotamaEati Alqidoru","text_ar":"اِجْتَمَعَتِ القِدْرُ"},{"kind":"italic_en","text":"The cooking-pot boiled."},{"kind":"text","text":"(Z, TA.) ―         -b6-  [Hence also,"},{"kind":"arabic","text_bw":"AjtmE","text_ar":"اجتمع"},{"kind":"text","text":"said of a thing, or an affair,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, composed, arranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled."},{"kind":"text","text":"]"}],"source_refs":["K","Msb","S","Mgh"]}]},"classical_definitions":null}