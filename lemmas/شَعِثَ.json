num":"p"},{"role":"present_2mp","form":"تَشْعَثُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْعَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْعَث","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْعَث","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْعَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْعَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْعَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْعَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْعَثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْعَثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْعَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَعِثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَعِثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْعَث","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْعَث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n22450"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B9%D9%90%D8%AB%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22450","headword_ar":"شَعِثَ","root":"$Ev","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"$aEavN","text_ar":"شَعَثٌ"},{"kind":"text","text":", (A, Mgh, Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(hair)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, shaggy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishevelled,"},{"kind":"text","text":"(A, Mgh,)"},{"kind":"italic_en","text":"and frouzy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altered in odour,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"in consequence of its being seldom dressed:"},{"kind":"text","text":"(A, Mgh:) or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, defiled with dust, and matted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compacted, in consequence of its being seldom anointed:"},{"kind":"text","text":"(Msb:) or, accord. to El-Ghooree,"},{"kind":"italic_en","text":"it wanted oil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ointment:"},{"kind":"text","text":"(Har p. 50:) and ↓"},{"kind":"arabic","text_bw":"t$E~t","text_ar":"تشعّت","orth_type":"arrow"},{"kind":"text","text":"signifies [the same: or]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, matted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compacted,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and dusty."},{"kind":"text","text":"(TA.) And the former verb, [and app. ↓ the latter also,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the head)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dusty, not being renovated"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by dressing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anointing"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"nor cleansed."},{"kind":"text","text":"(Msb.) Also the former verb, aor. as above, (L, K, and Ham p. 469,) inf. n."},{"kind":"arabic","text_bw":"$aEavN","text_ar":"شَعَثٌ"},{"kind":"text","text":"(S, L, K, and Ham) and"},{"kind":"arabic","text_bw":"$uEuwvapN","text_ar":"شُعُوثَةٌ"},{"kind":"text","text":", (L and Ham,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, shaggy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishevelled, in the hair,"},{"kind":"text","text":"(JM, PS,)"},{"kind":"italic_en","text":"and frouzy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altered in odour, in consequence of its being seldom dressed:"},{"kind":"text","text":"(JM:) or it signifies (or signifies also, JM)"},{"kind":"italic_en","text":"he had a dusty head,"},{"kind":"text","text":"(S, L, K, JM,)"},{"kind":"italic_en","text":"and plucked hair, unanointed;"},{"kind":"text","text":"(L;) or"},{"kind":"italic_en","text":"he had matted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compacted, and dusty, hair:"},{"kind":"text","text":"(L, and Ham p. 469:) and in like manner ↓"},{"kind":"arabic","text_bw":"t$E~v","text_ar":"تشعّث","orth_type":"arrow"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"$aEavN","text_ar":"شَعَثٌ"},{"kind":"text","text":", (Msb,) or ↓"},{"kind":"arabic","text_bw":"ta$aE~uvN","text_ar":"تَشَعُّثٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) [or each,] also signifies (tropical:)  The"},{"kind":"italic_en","text":"being separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunited,"},{"kind":"text","text":"(S, Msb, K, TA,) and"},{"kind":"italic_en","text":"spread out,"},{"kind":"text","text":"(Msb,) and"},{"kind":"italic_en","text":"uncompacted,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"like as is the head of the"},{"kind":"arabic","text_bw":"siwaAk","text_ar":"سِوَاك"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tooth-stick, by its being bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mangled by blows"},{"kind":"text","text":"]. (Msb, TA.) You say,"},{"kind":"arabic","text_bw":"raA^osu Als~iwaAki","text_ar":"رَاْسُ السِّوَاكِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"t$E~v","text_ar":"تشعّث","orth_type":"arrow"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"Alwatidi","text_ar":"الوَتِدِ"},{"kind":"text","text":", (A, TA,) (tropical:)"},{"kind":"italic_en","text":"The head of the tooth-stick,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the wooden peg"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake, became disintegrated;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated, disunited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncompacted, in its component parts"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"its fibres;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered brushy; by its being bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mangled by blows"},{"kind":"text","text":"]. (TA.) And ↓"},{"kind":"arabic","text_bw":"t$E~vwA","text_ar":"تشعّثوا","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They"},{"kind":"text","text":"[meaning men]"},{"kind":"italic_en","text":"became separated, disunited, dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattered."},{"kind":"text","text":"(A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$aEiva","text_ar":"شَعِثَ"},{"kind":"text","text":", aor. as above, (TK,) inf. n."},{"kind":"arabic","text_bw":"$aEavN","text_ar":"شَعَثٌ"},{"kind":"text","text":", said of the state of affairs, (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dissolved, broken up, discomposed, deranged, disorganized, disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled."},{"kind":"text","text":"(S, * A, * K, * TA, TK. [In the S and A and K, this is placed as the first of all the meanings in this art.; and in the A, it is mentioned among the meanings that are proper, not tropical; but in my opinion it is tropical. See also"},{"kind":"arabic","text_bw":"$aEavN","text_ar":"شَعَثٌ"},{"kind":"text","text":"below.])"}],"source_refs":["Msb","A","Mgh","K","TA","JM","PS","S","L","TK"]}]}}