kind":"text","text":"] or"},{"kind":"italic_en","text":"what God bestows upon one:"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"naEiymN","text_ar":"نَعِيمٌ","orth_type":"arrow"},{"kind":"text","text":": (S:) ["},{"kind":"italic_en","text":"grace"},{"kind":"text","text":"of God:] and ↓"},{"kind":"arabic","text_bw":"naEiymN","text_ar":"نَعِيمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"naEomapN","text_ar":"نَعْمَةٌ","orth_type":"arrow"},{"kind":"text","text":", with fet-h, [and ↓"},{"kind":"arabic","text_bw":"nuEomaY","text_ar":"نُعْمَى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"naEomaA='u","text_ar":"نَعْمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nuEomN","text_ar":"نُعْمٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"ease and plenty,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"enjoyment;"},{"kind":"text","text":"(Msb;) ["},{"kind":"italic_en","text":"welfare; well being; weal:"},{"kind":"text","text":"] ↓"},{"kind":"arabic","text_bw":"nuEomaY","text_ar":"نُعْمَى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"naEomaA='u","text_ar":"نَعْمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"are the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"buw^osaY","text_ar":"بُوْسَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baA^osaA='u","text_ar":"بَاْسَا=ءُ"},{"kind":"text","text":": (TA, art."},{"kind":"arabic","text_bw":"bA^s","text_ar":"باس"},{"kind":"text","text":":)"},{"kind":"arabic","text_bw":"baEoda Dar~aA='a","text_ar":"بَعْدَ ضَرَّا=ءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"naEomaA='u","text_ar":"نَعْمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", in the Kur [xi. 13,] is like health after sickness; and richness, or competence, after want. (Bd.) ―         -b2-"},{"kind":"arabic","text_bw":"niEomapN","text_ar":"نِعْمَةٌ"},{"kind":"italic_en","text":"A blessing;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"a cause of happiness."},{"kind":"text","text":"(K.)"},{"kind":"italic_en","text":"A favour: a benefit; and the like."},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"arabic","text_bw":"niEomapN","text_ar":"نِعْمَةٌ"},{"kind":"italic_en","text":"Wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property."},{"kind":"text","text":"(K.) The first explanations given to it above are assigned in the K, not to this word, but to ↓"},{"kind":"arabic","text_bw":"naEiymN","text_ar":"نَعِيمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nuEomaY","text_ar":"نُعْمَى","orth_type":"arrow"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"niEomapN","text_ar":"نِعْمَةٌ"},{"kind":"text","text":"with the article seems generally to signify"},{"kind":"italic_en","text":"Wealth:"},{"kind":"text","text":"and without the article,"},{"kind":"italic_en","text":"A benefit, benefaction, favour, boon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blessing."}],"source_refs":["S","Msb"]},{"entry_id":"n44053","headword_ar":"نُعْمَةٌ","root":"nEm","body":[{"kind":"text","text":"The act of"},{"kind":"italic_en","text":"rejoicing by a thing:"},{"kind":"text","text":"and the state of"},{"kind":"italic_en","text":"rejoicing in a thing."},{"kind":"text","text":"(KL.)"}],"source_refs":[]}]},"classical_definitions":null}