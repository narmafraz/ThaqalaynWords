{"lemma":"سَخْفِ","slug":"سَخْفِ","root":"س.خ.ف","root_slug":"س-خ-ف","root_link":"/words/roots/س-خ-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n19211","n19216","n19217"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%AE%D9%92%D9%81%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ridicule, belittle,"}]},"etymology":null,"ipa":["/sax.xa.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19211","headword_ar":"سَخُفَ","root":"sxf","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":"(Mgh, Msb, TA) and"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", or, accord. to Kh, the former only, (Msb,) said of a garment, or piece of cloth, (Mgh, Msb, TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thin, flimsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsubstantial;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"scanty in the yarn;"},{"kind":"text","text":"(Mgh, Msb;) or"},{"kind":"italic_en","text":"thin in texture."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", said of anything,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thin, slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsubstantial."},{"kind":"text","text":"(Msb, * TA. [See"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":"below, voce"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", (K,) or rather"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", accord. to what is said below of a distinction between these two ns., (TA,) said of a skin for water or milk,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unsound,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"altered for the worse, old, and worn out."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", q. v. infrà,] is also said of a man, meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shallow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weak, in intellect."},{"kind":"text","text":"(S, K. *) And it is also said of the intellect, meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slender,"},{"kind":"text","text":"&c. (K, * TK.)"}],"source_refs":["Mgh","Msb","TA","K"]},{"entry_id":"n19216","headword_ar":"سَخْفٌ","root":"sxf","body":[{"kind":"italic_en","text":"Slenderness of the means of subsistence."},{"kind":"text","text":"(AA, K.) ―         -b2-  See also the next paragraph."}],"source_refs":[]},{"entry_id":"n19217","headword_ar":"سُخْفٌ","root":"sxf","body":[{"kind":"text","text":"(AA, JK, S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"saxofN","text_ar":"سَخْفٌ","orth_type":"arrow"},{"kind":"text","text":"(JK, K) and ↓"},{"kind":"arabic","text_bw":"suxofapN","text_ar":"سُخْفَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Slenderness, shallowness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weakness, of intellect,"},{"kind":"text","text":"(AA, JK, S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"&c.:"},{"kind":"text","text":"(K:) or, as some say,"},{"kind":"italic_en","text":"a lightness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of body"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"incident to a man when he is hungry:"},{"kind":"text","text":"[but it is not clearly shown whether this refer to all of the foregoing words or only to the last, or last two, of them: (see"},{"kind":"arabic","text_bw":"saxofap","text_ar":"سَخْفَة"},{"kind":"text","text":", below:)] and some say that ↓"},{"kind":"arabic","text_bw":"suxofapN","text_ar":"سُخْفَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"weakness of intellect;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficiency thereof:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":"is in the intellect; and ↓"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ","orth_type":"arrow"},{"kind":"text","text":"is ["},{"kind":"italic_en","text":"thinness,"},{"kind":"text","text":"&c., (see 1,)] in everything; (Kh, Msb, K, TA;) as, for instance, in clouds, and in a skin for water or milk, and in herbage, and in a garment, or piece of cloth, &c. (TA.)"}],"source_refs":["AA","JK","S","Mgh","Msb","K","TA"]}]},"classical_definitions":null}