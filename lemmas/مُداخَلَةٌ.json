{"lemma":"مُداخَلَةٌ","slug":"مُداخَلَةٌ","root":"د.خ.ل","root_slug":"د-خ-ل","root_link":"/words/roots/د-خ-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n12248"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AF%D8%A7%D8%AE%D9%8E%D9%84%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of دَاخَلَ (dāḵala) (form III)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"intervention"},{"pos":"noun","gloss":"participation","examples":[{"text":"مُدَاخَلَةٌ هَاتِفِيَّةٌ"}]}]},"etymology":null,"ipa":["/mu.daː.xa.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12248","headword_ar":"مُدَاخَلَةٌ","root":"dxl","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"dAxl","text_ar":"داخل"},{"kind":"text","text":"] signifies The"},{"kind":"italic_en","text":"entering"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with another"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"into a place:"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"into an affair."},{"kind":"text","text":"(KL.) You say,"},{"kind":"arabic","text_bw":"dAxlhu fiY A^umuwrihi","text_ar":"داخلهُ فِى اُمُورِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He entered with him into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed with him in, his affairs"},{"kind":"text","text":"]. (JK, S.) And"},{"kind":"arabic","text_bw":"daAxalahumo","text_ar":"دَاخَلَهُمْ"},{"kind":"text","text":"[alone (assumed tropical:)"},{"kind":"italic_en","text":"He entered with them into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed with them in, their affairs: he mixed with them in familiar,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"social, intercourse: he conversed with them;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, intimate with them"},{"kind":"text","text":"]. (Lh, TA in the present art. and in art."},{"kind":"arabic","text_bw":"xlT","text_ar":"خلط"},{"kind":"text","text":". [See 3 in art."},{"kind":"arabic","text_bw":"xlT","text_ar":"خلط"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"daAxalahu fasaAdN fiY EaqolK A^awo jisomK","text_ar":"دَاخَلَهُ فَسَادٌ فِى عَقْلٍ اَوْ جِسْمٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Unsoundness in intellect, or body, infected him, as though commingling with him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"xaAlaTahu","text_ar":"خَالَطَهُ"},{"kind":"text","text":"]. (K.)"},{"kind":"arabic","text_bw":"dixaAlN","text_ar":"دِخَالٌ"},{"kind":"text","text":"[also is an inf. n. of"},{"kind":"arabic","text_bw":"dAxl","text_ar":"داخل"},{"kind":"text","text":"]: see 6, in two places. ―         -b2-  [See also"},{"kind":"arabic","text_bw":"dixaAlN","text_ar":"دِخَالٌ"},{"kind":"text","text":"below.]"}],"source_refs":[]}]},"classical_definitions":null}