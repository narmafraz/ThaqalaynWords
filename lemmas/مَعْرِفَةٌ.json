{"lemma":"مَعْرِفَةٌ","slug":"مَعْرِفَةٌ","root":"ع.ر.ف","root_slug":"ع-ر-ف","root_link":"/words/roots/ع-ر-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n28756"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B9%D9%92%D8%B1%D9%90%D9%81%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of عَرَفَ (ʕarafa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"knowledge"},{"pos":"noun","gloss":"definite","tags":["definite"]}]},"etymology":null,"ipa":["/maʕ.ri.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28756","headword_ar":"مَعْرِفَةٌ","root":"Erf","body":[{"kind":"text","text":"a subst. [signifying"},{"kind":"italic_en","text":"Knowledge, cognition, cognizance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquaintance;"},{"kind":"text","text":"&c.: as such having for its pl."},{"kind":"arabic","text_bw":"maEaArifu","text_ar":"مَعَارِفُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"sorts of knowledge:"},{"kind":"text","text":"] from"},{"kind":"arabic","text_bw":"Earafahu","text_ar":"عَرَفَهُ"},{"kind":"text","text":"signifying as expl. in the beginning of this art.: (Msb:) or an inf. n. therefrom. (S, O, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"maEorafN","text_ar":"مَعْرَفٌ"},{"kind":"text","text":", last sentence but one. ―         -b3-  [In grammar,"},{"kind":"italic_en","text":"A determinate noun;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"nakirapN","text_ar":"نَكِرَةٌ"},{"kind":"text","text":".]"}],"source_refs":["Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%B9%D8%B1%D9%81%D8%A9/","headword_ar":"معرفة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23697#d5ecd8","body_html":"<span>المعرفة: ما وضع ليدل على شيء بعينه، وهي المضمرات، والأعلام، والمبهمات، وما عرف باللام، والمضاف إلى أحدهما، والمعرفة أيضًا: إدراك الشيء على ما هو عليه، وهي مسبوقة بجهل بخلاف العلم، ولذلك يسمى الحق تعالى بالعالم دون العارف.</span>"}]}}