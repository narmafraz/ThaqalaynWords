{"lemma":"تامٌّ","slug":"تامٌّ","root":"ت.م.م","root_slug":"ت-م-م","root_link":"/words/roots/ت-م-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n4100","n4253"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D8%A7%D9%85%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"whole, complete, perfect"},{"pos":"adj","gloss":"self-contained, needing no completion"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of تَمَّ (tamma, “to be complete”)."},"ipa":["/taːmm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4100","headword_ar":"تَامٌّ","root":"tm","body":[{"kind":"text","text":"[part. n. of 1 in the first of the senses explained above]: (T, M, K, &c.:)"},{"kind":"italic_en","text":"Complete, entire, whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"full; without,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from, deficiency:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"consummate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfect:"},{"kind":"text","text":"(MF, TA:) as also ↓"},{"kind":"arabic","text_bw":"tamaAmN","text_ar":"تَمَامٌ","orth_type":"arrow"},{"kind":"text","text":", [which see above,] (M, * KL,) [and ↓"},{"kind":"arabic","text_bw":"timaAmN","text_ar":"تِمَامٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"page_break","n":317},{"kind":"text","text":"of which see three exs. voce"},{"kind":"arabic","text_bw":"tamaAmN","text_ar":"تَمَامٌ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"tim~N","text_ar":"تِمٌّ","orth_type":"arrow"},{"kind":"text","text":", (Kh, T, Har p. 82,) and ↓"},{"kind":"arabic","text_bw":"tamamN","text_ar":"تَمَمٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) Thus"},{"kind":"arabic","text_bw":"taAm~u Alxaloqi","text_ar":"تَامُّ الخَلْقِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Complete,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfect, in make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"formation; without any deficiency in his members;"},{"kind":"text","text":"applied to a man; (MF, TA;) [and, thus applied, signifying also"},{"kind":"italic_en","text":"full-grown,"},{"kind":"text","text":"as does, sometimes,"},{"kind":"arabic","text_bw":"taAm~N","text_ar":"تَامٌّ"},{"kind":"text","text":"alone: and likewise applied to a new-born child, meaning"},{"kind":"italic_en","text":"fully formed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"developed:"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"tamiymN","text_ar":"تَمِيمٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, (M, K,) applied to a man and to a horse, (M,) and ↓"},{"kind":"arabic","text_bw":"tamamN","text_ar":"تَمَمٌ","orth_type":"arrow"},{"kind":"text","text":"also; and in like manner is used the phrase ↓"},{"kind":"arabic","text_bw":"xaloqN tamamN","text_ar":"خَلْقٌ تَمَمٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a complete,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfect, make"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"formation"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["MF","TA","M","K"]},{"entry_id":"n4253","headword_ar":"تَامَ","root":"tym","body":[{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yatiymN","text_ar":"يَتِيمٌ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tayomN","text_ar":"تَيْمٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He loved excessively:"},{"kind":"text","text":"(T:) [or"},{"kind":"italic_en","text":"he became enslaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought into subjection, by love;"},{"kind":"text","text":"(see 2;) and so ↓"},{"kind":"arabic","text_bw":"tty~m","text_ar":"تتيّم","orth_type":"arrow"},{"kind":"text","text":", as explained in Kull p. 165: (see"},{"kind":"arabic","text_bw":"Hub~u","text_ar":"حُبُّ"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"his reason departed,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"became disordered, in consequence of love and desire;"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"tayomN","text_ar":"تَيْمٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"departing of reason,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"its becoming disordered,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"in consequence of love and desire."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"He became alone, apart from others."},{"kind":"text","text":"(T, TA.)       -A2-"},{"kind":"arabic","text_bw":"taAmatohu","text_ar":"تَامَتْهُ"},{"kind":"text","text":", (T, S, M, K,) aor."},{"kind":"arabic","text_bw":"tatiymuhu","text_ar":"تَتِيمُهُ"},{"kind":"text","text":", (T,) inf. n."},{"kind":"arabic","text_bw":"tayomN","text_ar":"تَيْمٌ"},{"kind":"text","text":"; (T, M, K;) and ↓"},{"kind":"arabic","text_bw":"tay~amatohu","text_ar":"تَيَّمَتْهُ","orth_type":"arrow"},{"kind":"text","text":", (T, M, K,) [which is the more common,] inf. n."},{"kind":"arabic","text_bw":"tatoyiymN","text_ar":"تَتْيِيمٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"enslaved him"},{"kind":"text","text":"(S, M, K)"},{"kind":"italic_en","text":"by love of her,"},{"kind":"text","text":"(M,) and"},{"kind":"italic_en","text":"brought him into subjection:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"she enslaved it, and brought it into subjection;"},{"kind":"text","text":"namely, his heart: (S:) or"},{"kind":"italic_en","text":"she deprived him of his reason; disordered his reason."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"taAmahu","text_ar":"تَامَهُ"},{"kind":"text","text":", (K,) inf. n. as above; (M, K;) and ↓"},{"kind":"arabic","text_bw":"ty~mhu","text_ar":"تيّمهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(love, S, K, or love and desire, M, and excessive love, K)"},{"kind":"italic_en","text":"enslaved him,"},{"kind":"text","text":"(S, M, K,) and"},{"kind":"italic_en","text":"brought him into subjection."},{"kind":"text","text":"(S, K.)"}],"source_refs":["T","TA","S","M","K"]}]},"classical_definitions":null}