m","num":"p"},{"role":"present_2mp","form":"تُحَمِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَمِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَمِّد","in_corpus":true,"count":12,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَمِّد","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَمِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَمِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَمِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَمِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَمِّدُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَمِّدُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَمِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَمَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَمَّدْتُ","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَمِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَمِّد","in_corpus":true,"count":4987,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5052,"cross_references":{"qac":{"found":true,"lemma_key":"حَمَّدَ","root":"حمد","pos":"N","occurrence_count":43},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n9033","n9039"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%85%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to praise, to commend","examples":[{"text":"حَمِدَهُ عَلَى صَنِيعِهِ وَسُمُوِّ خُلُقِهِ","english":"He praised him for his actions and his noble character."},{"text":"لَا تَحۡسَبَنَّ ٱلَّذِينَ يَفۡرَحُونَ بِمَاۤ أَتَوا۟ وَّيُحِبُّونَ أَن يُحۡمَدُوا۟ بِمَا لَمۡ يَفۡعَلُوا۟ فَلَا تَحۡسَبَنَّهُم بِمَفَازَةࣲ مِّنَ الْعَذَابِ ۖ وَلَهُمۡ عَذَابٌ أَلِيمࣱ","english":"Do not think that those who joy in what they carry out and love to be praised for what they do not do will escape torment. Theirs is [indeed] an agonizing torment."}]},{"pos":"verb","gloss":"to praise, to commend; to praise or exalt (a deity)","examples":[{"text":"حَمِدَ اللهَ وَأَثْنَى عَلَيْهِ","english":"He exalted and praised Allah."}]},{"pos":"verb","gloss":"to praise, to commend; to praise (someone) as a sign of gratitude; to thank"},{"pos":"verb","gloss":"to praise, to commend; to find (something or someone) pleasant or agreeable; to approve; to admire","examples":[{"text":"حَمِدَ فِعْلَهُ وَمَذْهَبَهُ","english":"He approved of his deeds and beliefs."}]},{"pos":"noun","gloss":"verbal noun of حَمِدَ (ḥamida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"praise, eulogy, commendation","examples":[{"text":"الْحَمْدُ لِلّٰهِ","english":"praise be to God"}]},{"pos":"noun","gloss":"kindness, favor, grace"},{"pos":"noun","gloss":"reward, thanks"},{"pos":"noun","gloss":"verbal noun of حَمِدَ (ḥamida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to praise highly or much, to extol, to exalt"},{"pos":"verb","gloss":"to be angry","tags":["obsolete","rare"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9033","headword_ar":"حمّد","root":"Hmd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHomiydN","text_ar":"تَحْمِيدٌ"},{"kind":"text","text":", has a more intensive signification than"},{"kind":"arabic","text_bw":"Hamda","text_ar":"حَمدَ"},{"kind":"text","text":"; (S;) ["},{"kind":"italic_en","text":"He declared the praises of"},{"kind":"text","text":"God: or]"},{"kind":"italic_en","text":"he praised"},{"kind":"text","text":"God"},{"kind":"italic_en","text":"much, with good forms of praise"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"biAlmaHaAmidi AlHasanapi","text_ar":"بِالمَحَامِدِ الحَسَنَةِ"},{"kind":"text","text":"): (T, L:) or"},{"kind":"italic_en","text":"repeatedly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time after time."},{"kind":"text","text":"(L, K.)"},{"kind":"arabic","text_bw":"tHmyd","text_ar":"تحميد"},{"kind":"text","text":"[used as a simple subst.] has a pl., namely,"},{"kind":"arabic","text_bw":"taHaAmiydu","text_ar":"تَحَامِيدُ"},{"kind":"text","text":". (A.) [See an ex. voce"},{"kind":"arabic","text_bw":"xaAtamN","text_ar":"خَاتَمٌ"},{"kind":"text","text":", in the latter part of the paragraph.]"}],"source_refs":["T","L"]},{"entry_id":"n9039","headword_ar":"حَمْدٌ","root":"Hmd","body":[{"kind":"italic_en","text":"Praise, eulogy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commendation;"},{"kind":"text","text":"&c. (S, &c. [For further explanations of this word, and respecting the phrase"},{"kind":"arabic","text_bw":"AlHamodu lil~`hi","text_ar":"الحَمْدُ لِلّٰهِ"},{"kind":"text","text":"and its variations, see 1: and see also"},{"kind":"arabic","text_bw":"$akara","text_ar":"شَكَرَ"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"suboHaAnaka A@ll~`hum~a","text_ar":"سُبْحَانَكَ ا@للّٰهُمَّ"},{"kind":"arabic","text_bw":"wabiHamodika","text_ar":"وَبِحَمْدِكَ"},{"kind":"text","text":", said by a person praying, means ["},{"kind":"italic_en","text":"I extol,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"celebrate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declare, thy remoteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freedom, from every impurity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"O God,"},{"kind":"text","text":"(see art."},{"kind":"arabic","text_bw":"sbH","text_ar":"سبح"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"and I begin with praising Thee;"},{"kind":"arabic","text_bw":"A^abotadiy^u","text_ar":"اَبْتَدِيُ"},{"kind":"text","text":"being understood: (Az, L, Msb:) or by"},{"kind":"arabic","text_bw":"bHmdk","text_ar":"بحمدك"},{"kind":"text","text":"is meant"},{"kind":"arabic","text_bw":"AlHamodu laka","text_ar":"الحَمْدُ لَكَ"},{"kind":"italic_en","text":"praise be to Thee:"},{"kind":"text","text":"and nearly the same is said in explanation of the phrase in the Kur [ii. 28],"},{"kind":"arabic","text_bw":"nusab~iHu biHamodika","text_ar":"نُسَبِّحُ بِحَمْدِكَ"},{"kind":"text","text":", that by"},{"kind":"arabic","text_bw":"bHmdk","text_ar":"بحمدك"},{"kind":"text","text":"is meant"},{"kind":"arabic","text_bw":"HaAmidiyna","text_ar":"حَامِدِينَ"},{"kind":"arabic","text_bw":"laka","text_ar":"لَكَ"},{"kind":"text","text":": [see, again, art."},{"kind":"arabic","text_bw":"sbH","text_ar":"سبح"},{"kind":"text","text":":] or by the expression"},{"kind":"arabic","text_bw":"wbHmdk","text_ar":"وبحمدك"},{"kind":"text","text":"is meant, accord. to Aboo-'Othmán ElMázinee,"},{"kind":"italic_en","text":"and by praising Thee I extol thy remoteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freedom, from every impurity,"},{"kind":"text","text":"&c.;"},{"kind":"arabic","text_bw":"sab~aHotuka","text_ar":"سَبَّحْتُكَ"},{"kind":"text","text":"being understood: or the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is redundant, as it is in the phrase,"},{"kind":"arabic","text_bw":"rab~anaAwalaka AlHamodu","text_ar":"رَبَّنَاوَلَكَ الحَمْدُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O our Lord, praise be to Thee"},{"kind":"text","text":"], in which the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is sometimes omitted: or, accord. to Aboo-'Amr Ibn-El-'Alà, the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is corroborative, as in the phrase,"},{"kind":"arabic","text_bw":"wahuwa laka","text_ar":"وَهُوَ لَكَ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"huwa laka","text_ar":"هُوَ لَكَ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"liwaA='u AlHamodi","text_ar":"لِوَا=ءُ الحَمْدِ"},{"kind":"arabic","text_bw":"biyadiY yawoma AlqiyaAmapi","text_ar":"بِيَدِى يَوْمَ القِيَامَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The standard of praise shall be in my hand on the day of resurrection"},{"kind":"text","text":"(said by Mohammad)] means that he shall be singularly distinguished by praise, or praising, on that day. (L.) ―         -b2-  See"},{"kind":"arabic","text_bw":"HamaAdi","text_ar":"حَمَادِ"},{"kind":"text","text":": ―         -b3-  and"},{"kind":"arabic","text_bw":"HumaAdaAka","text_ar":"حُمَادَاكَ"},{"kind":"text","text":".       -A2-  See also"},{"kind":"arabic","text_bw":"HamiydN","text_ar":"حَمِيدٌ"},{"kind":"text","text":".       -A3-  It is also said to signify The"},{"kind":"italic_en","text":"young one of the kind of bird called"},{"kind":"arabic","text_bw":"qaTFA","text_ar":"قَطًا"},{"kind":"text","text":": so in the prov.,"},{"kind":"quote","text":"Hmodu qaTaApK yasotamiY AlA^araAniba"},{"kind":"italic_en","text":"A young one of a katà desires to make the hares its prey:"},{"kind":"text","text":"applied to a weak man who desires to insnare a strong one. (Meyd, TA.)       -A4-  See also what next follows."}],"source_refs":["Az","L","Msb"]}]}}