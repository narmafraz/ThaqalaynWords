,"gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْعُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْعُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْعُل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْعُل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْعُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْعُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْعُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْعُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْعُلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْعُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْعُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَعَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَعَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْعُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْعُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n19849"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%B9%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cough"}]},"etymology":null,"ipa":["/sa.ʕa.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19849","headword_ar":"سَعَلَ","root":"sEl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"suEaAlN","text_ar":"سُعَالٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"suEolapN","text_ar":"سُعْلَةٌ"},{"kind":"text","text":", (K,) or the latter of these is the inf. n., and the former is a simple subst., (Msb,) ["},{"kind":"italic_en","text":"He coughed:"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"suEolapN","text_ar":"سُعْلَةٌ"},{"kind":"text","text":"signifies [the"},{"kind":"italic_en","text":"having"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a motion whereby nature expels somewhat hurtful from the lungs and the organs connected therewith:"},{"kind":"text","text":"(Ibn-Seenà, K, TA:) wherefore the ducts of the lungs are called"},{"kind":"arabic","text_bw":"qaSabu Als~uEaAli","text_ar":"قَصَبُ السُّعَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the tubes of coughing,"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"the bronchial tubes,"},{"kind":"text","text":"] because it [i. e. what is hurtful in the lungs] has its exit by them. (TA.) One says,"},{"kind":"arabic","text_bw":"A_in~ahu yasoEulu suEolapF","text_ar":"اـِنَّهُ يَسْعُلُ سُعْلَةً"},{"kind":"arabic","text_bw":"munokarapF","text_ar":"مُنْكَرَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily he coughs with an abominable coughing"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"bihi suEolapN","text_ar":"بِهِ سُعْلَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In him is a coughing;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he has a coughing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cough"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"A^agoS~aka Als~uw^aAlu faA^axa*aka Als~uEaAlu","text_ar":"اَغْصَّكَ السُّوَالُ فَاَخَذَكَ السُّعَالُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The question,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petition, has choked thee, and consequently coughing has seized thee"},{"kind":"text","text":"]. (TA.) ―         -b2-  Hence the saying,"},{"kind":"arabic","text_bw":"ramaAhu fasaEala Ald~ama","text_ar":"رَمَاهُ فَسَعَلَ الدَّمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He shot him, and he consequently coughed up blood"},{"kind":"text","text":"]; i. e.,"},{"kind":"italic_en","text":"he threw"},{"kind":"text","text":"["},{"kind":"italic_en","text":"up"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"blood from his chest."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"saEila","text_ar":"سَعِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saEalN","text_ar":"سَعَلٌ"},{"kind":"text","text":"; accord. to the K, app.,"},{"kind":"arabic","text_bw":"saEala","text_ar":"سَعَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saEolN","text_ar":"سَعْلٌ"},{"kind":"text","text":"; [and thus the pret. and inf. n. are written in the copies of the K;] but the former is the right; (TA;) (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly;"},{"kind":"text","text":"(K, TA;) like"},{"kind":"arabic","text_bw":"zaEila","text_ar":"زَعِلَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zaEalN","text_ar":"زَعَلٌ"},{"kind":"text","text":". (TA. [See the part. n.,"},{"kind":"arabic","text_bw":"saEilN","text_ar":"سَعِلٌ"},{"kind":"text","text":", below.])"}],"source_refs":["S","O","Msb","K"]}]},"classical_definitions":null}