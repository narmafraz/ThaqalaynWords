nt":14},"lanes":{"found":true,"entry_ids":["n17604"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%AE%D9%92%D8%B1%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to adorn, ornament, decorate, embellish"},{"pos":"noun","gloss":"gold"},{"pos":"noun","gloss":"ornament, decoration, embellishment"},{"pos":"noun","gloss":"anything varnished or with false coloring"},{"pos":"noun","gloss":"false gold, false ornaments or jewelry"},{"pos":"noun","gloss":"gilding, gloss"},{"pos":"noun","gloss":"tinsel"},{"pos":"noun","gloss":"ornateness of speech, tinsel of speech"},{"pos":"noun","gloss":"varnished falsehood"},{"pos":"noun","gloss":"worldly pomp"},{"pos":"noun","gloss":"line or streak seen in the water"},{"pos":"noun","gloss":"ornamented ship"},{"pos":"noun","gloss":"a small water fly with four legs"},{"pos":"noun","gloss":"mermaid"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17604","headword_ar":"زُخْرُفٌ","root":"zxrf","body":[{"kind":"italic_en","text":"Gold:"},{"kind":"text","text":"(Fr, S, M, K:) so in the Kur xvii. 95: and this, accord. to ISd, is the primary meaning. (TA.) ―         -b2-  Then applied to"},{"kind":"italic_en","text":"Any orna-"},{"kind":"page_break","n":1223},{"kind":"italic_en","text":"ment, decoration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embellishment:"},{"kind":"text","text":"(ISd, TA:)"},{"kind":"italic_en","text":"anything adorned, ornamented, decorated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embellished:"},{"kind":"text","text":"(Ham p. 784:) and particularly applied to the"},{"kind":"italic_en","text":"decorations, and pictured works, in gold, with which the Kaabeh was ornamented in Pagan times."},{"kind":"text","text":"(TA.) The"},{"kind":"italic_en","text":"colours of the plants"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage,"},{"kind":"text","text":"of land, (K, TA,)"},{"kind":"italic_en","text":"red and yellow and white:"},{"kind":"text","text":"its"},{"kind":"italic_en","text":"ornature, consisting in blossoms and flowers:"},{"kind":"text","text":"or its"},{"kind":"italic_en","text":"perfection:"},{"kind":"text","text":"so in the Kur x. 25. (TA.) And The"},{"kind":"italic_en","text":"furniture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utensils, of a house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"italic_en","text":"Anything varnished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embellished with a false colouring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falsified,"},{"kind":"text","text":"is likened thereto [and so termed]. (S, TA.) [Hence,]"},{"kind":"arabic","text_bw":"zuxorufu Alqawoli","text_ar":"زُخْرُفُ القَوْلِ"},{"kind":"italic_en","text":"The ornature of speech;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"the fair appearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comeliness, of speech, produced by the embellishing with lies:"},{"kind":"text","text":"(K, TA:) so in the Kur vi. 112: (TA:) or it there means"},{"kind":"italic_en","text":"varnished falsehoods."},{"kind":"text","text":"(Bd.) ―         -b4-  [Its pl.]"},{"kind":"arabic","text_bw":"zaxaArifu","text_ar":"زَخَارِفُ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"lines,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"streaks,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that are seen on the surface"},{"kind":"text","text":"] of water. (S, K.) ―         -b5-  And"},{"kind":"italic_en","text":"Ships:"},{"kind":"text","text":"(T, K:) or"},{"kind":"italic_en","text":"ornamented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decorated, ships:"},{"kind":"text","text":"(M, TA:) or the"},{"kind":"italic_en","text":"ornature of ships, with which they are decorated."},{"kind":"text","text":"('Eyn, TA.) ―         -b6-  Also"},{"kind":"italic_en","text":"Certain insects that fly upon the water,"},{"kind":"text","text":"(T, O, K,)"},{"kind":"italic_en","text":"having four legs, resembling the common fly;"},{"kind":"text","text":"(O, K;)"},{"kind":"italic_en","text":"small flies, having four legs, that fly upon the water:"},{"kind":"text","text":"(M, TA:) the sing.,"},{"kind":"arabic","text_bw":"zuxorufN","text_ar":"زُخْرُفٌ"},{"kind":"text","text":", is expl. by Kr [in the Munjid] as meaning"},{"kind":"italic_en","text":"a kind of flying thing."},{"kind":"text","text":"(TA.)"}],"source_refs":["Fr","S","M","K","ISd","TA","T","O"]}]},"classical_definitions":null}