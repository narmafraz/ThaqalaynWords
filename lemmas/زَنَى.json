:"زَنَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زَنَيْتُ","in_corpus":true,"count":22,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":160,"cross_references":{"qac":{"found":true,"lemma_key":"زَنَى","root":"زني","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n18277"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D9%86%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18277","headword_ar":"زَنَى","root":"znY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazoniY","text_ar":"يَزْنِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zinFY","text_ar":"زِنًى"},{"kind":"text","text":"[often written"},{"kind":"arabic","text_bw":"zinFA","text_ar":"زِنًا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"zinaA='N","text_ar":"زِنَا=ءٌ"},{"kind":"text","text":", (S, Mgh, * Msb, K,) the latter an inf. n. of 3 (S, Mgh, Msb, K) also, (S, Mgh, K,) but said by some to be a dial. var. of the former, (Msb,) the former being of the dial. of the people of El-Hijáz, (Lh, S, Msb, TA,) and the latter of the dial. of Benoo-Temeem, (Lh, TA,) or of the people of Nejd, (S, Msb, TA,)"},{"kind":"italic_en","text":"He committed fornication"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adultery;"},{"kind":"text","text":"(El-Munáwee, Er-Rághib, TA;)"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"italic_en","text":"with her:"},{"kind":"text","text":"(MA:) but accord. to El-Munáwee, [it seems to be properly a dial. var. of"},{"kind":"arabic","text_bw":"zanaA^a","text_ar":"زَنَاَ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"he mounted;"},{"kind":"text","text":"for he says that,] in the proper language of the Arabs,"},{"kind":"arabic","text_bw":"Alz~inaA","text_ar":"الزِّنَا"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the mounting upon a thing;"},{"kind":"text","text":"and in the language of the law it signifies the commission of the act first mentioned above: it is [thus]"},{"kind":"italic_en","text":"syn."},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"text","text":": and in like manner one says of a woman ["},{"kind":"arabic","text_bw":"zanato","text_ar":"زَنَتْ"},{"kind":"text","text":"]: (TA:) ↓"},{"kind":"arabic","text_bw":"zn~Y","text_ar":"زنّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tazoniyapN","text_ar":"تَزْنِيَةٌ"},{"kind":"text","text":", also signifies the same: (TA:) and so does ↓"},{"kind":"arabic","text_bw":"zAnY","text_ar":"زانى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muzaAnaApN","text_ar":"مُزَانَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zinaA='N","text_ar":"زِنَا=ءٌ"},{"kind":"text","text":": (K:) one says of a woman, ↓"},{"kind":"arabic","text_bw":"tuzaAniY","text_ar":"تُزَانِى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muzaAnaApN","text_ar":"مُزَانَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zinaA='N","text_ar":"زِنَا=ءٌ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"tubaAgiY","text_ar":"تُبَاغِى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"She commits fornication"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adultery;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prostitutes herself"},{"kind":"text","text":"]. (S.) It is said in a prov.,"},{"kind":"arabic","text_bw":"laA HuSonuhaA HuSonN walaA Alz~inaA='u zinaA='N","text_ar":"لَا حُصْنُهَا حُصْنٌ وَلَا الزِّنَا=ءُ زِنَا=ءٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Her continence is not continence, nor the fornication,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adultery,"},{"kind":"text","text":"that she commits,"},{"kind":"italic_en","text":"fornication,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adultery"},{"kind":"text","text":"]: applied to him who does not remain in one state, or condition; neither in good nor in evil: (Meyd:) or to him who refrains from doing good and then is excessive [therein], or from evil and then is excessive therein; not continuing to pursue one way. (TA.) [See also"},{"kind":"arabic","text_bw":"zanoyapN","text_ar":"زَنْيَةٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","Msb","K","Lh","TA","MA","Meyd"]}]}}