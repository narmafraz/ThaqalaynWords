sp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْزُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْزُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْزِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْزِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْزُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْزُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْزِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْزِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْزُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَعْزِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَزَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَزَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْزُب","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْزُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْزِب","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْزِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":30,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28937"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B2%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be far, distant"},{"pos":"verb","gloss":"to escape, to slip out"},{"pos":"verb","gloss":"to be single, to be unmarried"},{"pos":"adj","gloss":"celibate, single, unmarried"},{"pos":"noun","gloss":"bachelor"},{"pos":"noun","gloss":"plural of عِزْبَة (ʕizba, “country estate”)","tags":["Egypt","form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ʕazab-. Compare Akkadian 𒋺 (ezēbum, “to leave”) and Hebrew עָזַב (“to leave, forsake”)."},"ipa":["/ʕa.za.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28937","headword_ar":"عَزَبَ","root":"Ezb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"text","text":", (S, O,) inf. n."},{"kind":"arabic","text_bw":"EuzuwbN","text_ar":"عُزُوبٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, S, O,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, Msb,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote;"},{"kind":"text","text":"(S, O, Msb;) and"},{"kind":"italic_en","text":"absent;"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"italic_en","text":"from me:"},{"kind":"text","text":"(S, O:) or ↓"},{"kind":"arabic","text_bw":"AEzb","text_ar":"اعزب","orth_type":"arrow"},{"kind":"text","text":"has the former meaning: (K:) and"},{"kind":"arabic","text_bw":"Eazaba","text_ar":"عَزَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (Msb, K,) inf. n. as above, (K,) signifies"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, absent,"},{"kind":"text","text":"(Msb, K,) and"},{"kind":"italic_en","text":"concealed:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"Eazaba bihaA","text_ar":"عَزَبَ بِهَا"},{"kind":"text","text":", referring to sheep or goats,"},{"kind":"italic_en","text":"He went to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off, with them:"},{"kind":"text","text":"so in a trad.: or, as some relate it,"},{"kind":"arabic","text_bw":"bhA","text_ar":"بها"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ez~b","text_ar":"عزّب","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he went with them to a remote pasturage:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he pastured them"},{"kind":"text","text":"(namely, camels,)"},{"kind":"italic_en","text":"at a distance from the place of abode of the tribe, not repairing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returning, to them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the evening"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"tEz~b","text_ar":"تعزّب","orth_type":"arrow"},{"kind":"text","text":", and thus the verb is written in copies of the K in a place where some copies have"},{"kind":"arabic","text_bw":"yaEozubu","text_ar":"يَعْزُبُ"},{"kind":"text","text":", occurs in the phrase"},{"kind":"arabic","text_bw":"tEz~b Eano A^aholihi wamaAlihi","text_ar":"تعزّب عَنْ اَهْلِهِ وَمَالِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went away to a distance from his family and his cattle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels"},{"kind":"text","text":"&c.]. (TA.) And"},{"kind":"arabic","text_bw":"Eazabati AlA_ibilu","text_ar":"عَزَبَتِ الاـِبِلُ"},{"kind":"italic_en","text":"The camels went away to a distance in the pasturage, not returning in the evening:"},{"kind":"text","text":"(S, O:) and in like manner one says of sheep or goats. (O.) And"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"yaEozubu Eano Eilomihi $aYo'N","text_ar":"يَعْزُبُ عَنْ عِلْمِهِ شَىْءٌ"},{"kind":"italic_en","text":"Nothing is absent from his"},{"kind":"text","text":"(God's)"},{"kind":"italic_en","text":"knowledge."},{"kind":"text","text":"(TA. [See Kur x.62 and xxxiv. 3.]) And"},{"kind":"arabic","text_bw":"Eazaba Tuhoru AlmuroA^api","text_ar":"عَزَبَ طُهْرُ المُرْاَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The woman's state of pureness from the menstrual discharge was a remote thing"},{"kind":"text","text":"] means (assumed tropical:)"},{"kind":"italic_en","text":"the woman's husband was absent from her:"},{"kind":"text","text":"(K:) or [rather] is said of the woman when her husband is absent from her. (S, O.) And"},{"kind":"arabic","text_bw":"Eazaba Eano fulaAnK Hilomuhu","text_ar":"عَزَبَ عَنْ فُلَانٍ حِلْمُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one's forbearance quitted him"},{"kind":"text","text":"]; (S, O;) as also ↓"},{"kind":"arabic","text_bw":"AEzb","text_ar":"اعزب","orth_type":"arrow"},{"kind":"text","text":". (O.) ―         -b2-  Also, aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EuzobapN","text_ar":"عُزْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuzuwbapN","text_ar":"عُزُوبَةٌ"},{"kind":"text","text":", (Msb, MF, TA,) or these are simple substs., (S, K,) (assumed tropical:)"},{"kind":"italic_en","text":"He was without a wife;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of celibacy."},{"kind":"text","text":"(Msb, K.) [And app."},{"kind":"arabic","text_bw":"Eazabato","text_ar":"عَزَبَتْ"},{"kind":"text","text":"is said in like manner of a woman, meaning (assumed tropical:)"},{"kind":"italic_en","text":"She was without a husband."},{"kind":"text","text":"See also 5.] ―         -b3-  And"},{"kind":"arabic","text_bw":"Eazabati AlA^aroDu","text_ar":"عَزَبَتِ الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"whether fruitful or unfruitful,"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, destitute of inhabitants; had in it no one."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["S","O","Msb","K","MF","TA"]}]}}