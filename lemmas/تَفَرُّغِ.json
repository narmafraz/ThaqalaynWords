{"lemma":"تَفَرُّغِ","slug":"تَفَرُّغِ","root":"ف.ر.غ","root_slug":"ف-ر-غ","root_link":"/words/roots/ف-ر-غ","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n33637"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%81%D9%8E%D8%B1%D9%8F%D9%91%D8%BA%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be unoccupied (to be not employed on a task)","tags":["intransitive"]},{"pos":"verb","gloss":"to devote oneself","tags":["intransitive"],"examples":[{"text":"تَفَرَّغَ هُوَ لِدُرُوسِهِ","english":"He devoted himself to his studies."}]},{"pos":"noun","gloss":"verbal noun of تَفَرَّغَ (tafarraḡa).","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"devotion, dedication"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ف ر غ (f r ḡ)."},"ipa":["/ta.far.ra.ɣa/","/ta.far.ruɣ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33637","headword_ar":"تفرّغ","root":"frg","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he made himself to be, vacant from, devoid of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from, business, occupation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employment; unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taxal~aY mina Al$~ugoli","text_ar":"تَخَلَّى مِنَ الشُّغْلِ"},{"kind":"text","text":". (O, K.) [See also"},{"kind":"arabic","text_bw":"faraga mina Al$~ugoli","text_ar":"فَرَغَ مِنَ الشُّغْلِ"},{"kind":"text","text":".] Hence the trad. of the Prophet,"},{"kind":"arabic","text_bw":"tafar~aguwA mino humuwmi Ald~unoyaA maA","text_ar":"تَفَرَّغُوا مِنْ هُمُومِ الدُّنْيَا مَا"},{"kind":"arabic","text_bw":"A@sotaTaEotumo","text_ar":"ا@سْتَطَعْتُمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Be ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"make yourselves to be, vacant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, from the anxieties of the present state of existence as much as ye are able"},{"kind":"text","text":"]. (O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"tafar~agotu lika*aA","text_ar":"تَفَرَّغْتُ لِكَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I made myself to be, vacant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, from business, occupation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employment;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure; for such a thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I applied myself exclusively to such a thing"},{"kind":"text","text":"]: (S: [these meanings are there indicated, but not expressed; and are well known:]) one says,"},{"kind":"arabic","text_bw":"tfr~g liloEibaAdapi","text_ar":"تفرّغ لِلْعِبَادَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He applied himself exclusively to religious service"},{"kind":"text","text":"]: (Msb in art."},{"kind":"arabic","text_bw":"btl","text_ar":"بتل"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"tafar~agotu liloA^amori","text_ar":"تَفَرَّغْتُ لِلْاَمْرِ"},{"kind":"text","text":"means [also, simply,]"},{"kind":"arabic","text_bw":"taSad~ayotu lahu","text_ar":"تَصَدَّيْتُ لَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I addressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"applied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"directed, myself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"my regard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, to the affair"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"Sd","text_ar":"صد"},{"kind":"text","text":".) [See also"},{"kind":"arabic","text_bw":"faraga lahu","text_ar":"فَرَغَ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":".] ―         -b3-  And"},{"kind":"arabic","text_bw":"tfr~g bihi","text_ar":"تفرّغ بِهِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"taxal~aY","text_ar":"تَخَلَّى"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"He confined himself exclusively to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented himself with it exclusively of other things"},{"kind":"text","text":"]. (K and TA in art."},{"kind":"arabic","text_bw":"xlw","text_ar":"خلو"},{"kind":"text","text":".)"}],"source_refs":[]}]},"classical_definitions":null}