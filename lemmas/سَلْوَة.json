{"lemma":"سَلْوَة","slug":"سَلْوَة","root":"س.ل.#","root_slug":"س-ل-_","root_link":"/words/roots/س-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n20574","n20575"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%92%D9%88%D9%8E%D8%A9"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20574","headword_ar":"سَلْوَةٌ","root":"slw","body":[{"kind":"text","text":", (M, Msb, K,) as also ↓"},{"kind":"arabic","text_bw":"sulowapN","text_ar":"سُلْوَةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) a subst. from"},{"kind":"arabic","text_bw":"salaA Eanohu","text_ar":"سَلَا عَنْهُ"},{"kind":"text","text":"(M, Msb, K) [as such signifying"},{"kind":"italic_en","text":"A state of forgetfulness, unmindfulness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglectfulness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of diversion from remembrance,"},{"kind":"text","text":"of a person or thing:"},{"kind":"italic_en","text":"patient endurance of a loss"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want: content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happiness, in a case of privation:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comfort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consolation, for a loss"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want:"},{"kind":"text","text":"accord. to the MA, the former is an inf. n.]. One says,"},{"kind":"arabic","text_bw":"saqayotaniY minoka salowapF","text_ar":"سَقَيْتَنِى مِنْكَ سَلْوَةً"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sulowaAnFA","text_ar":"سُلْوَانًا","orth_type":"arrow"},{"kind":"italic_en","text":"Thou hast made me content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hast infused into me content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happiness,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without thee"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"in thine absence"},{"kind":"text","text":"]. (As, S.) And"},{"kind":"arabic","text_bw":"huwa fiY salowapK mina AlEayo$i","text_ar":"هُوَ فِى سَلْوَةٍ مِنَ العَيْشِ"},{"kind":"italic_en","text":"He is in a state of life ample in its means"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances, unstraitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plentiful, and pleasant."},{"kind":"text","text":"(AZ, S.)"}],"source_refs":["M","Msb","K"]},{"entry_id":"n20575","headword_ar":"سُلْوَةٌ","root":"slw","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]}}