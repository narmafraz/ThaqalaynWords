text_bw":"Aq$Er~t Als~anapu","text_ar":"اقشعرّت السَّنَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The year became one of drought."},{"kind":"text","text":"(K, * TA:)"}],"source_refs":["S","K"]}]}}