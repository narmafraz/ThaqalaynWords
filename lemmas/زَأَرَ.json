 hadiyrahi","text_ar":"زَاَرَ فِى هَدِيرَهِ"},{"kind":"text","text":", (A,) (tropical:)"},{"kind":"italic_en","text":"He reiterated his voice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry, in his chest, and then prolonged it,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"in his braying:"},{"kind":"text","text":"(A:) or"},{"kind":"arabic","text_bw":"zaA^ara","text_ar":"زَاَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"he threatened"},{"kind":"text","text":"in his braying. (TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"samiEa zay^iyra AlHarobi faTaAra A_ilayohaA","text_ar":"سَمِعَ زَيِيرَ الحَرْبِ فَطَارَ اـِلَيْهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He heard the roaring of the war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"battle, and flew to it"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","A","K","TA"]},{"entry_id":"n18384","headword_ar":"زَارٌ","root":"zwr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zaArapN","text_ar":"زَارَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}