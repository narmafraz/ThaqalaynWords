{"lemma":"فَرَطَ","slug":"فَرَطَ","root":"ف.ر.ط","root_slug":"ف-ر-ط","root_link":"/words/roots/ف-ر-ط","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فَرَطْتَ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فَرَطْتِ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فَرَطْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فَرَطْتُم","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فَرَطْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فَرَطَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فَرَطَت","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فَرَطا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فَرَطَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فَرَطُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فَرَطْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفْرُط","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفْرُطِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفْرُطِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفْرُطانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفْرُطا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفْرُطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفْرُطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْرُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْرُط","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْرُط","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْرُطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْرُطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْرُطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْرُطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْرُطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْرُطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْرُطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَفْرُط","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْرُط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"فَرَطْنا","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرَطْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":48,"cross_references":{"qac":{"found":true,"lemma_key":"فَرَطَ","root":"فرط","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n33589"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to precede, to pass, to outgo, to slip, to shed, to strip","tags":["ambitransitive"],"examples":[{"text":"قَالَا رَبَّنَا إِنَّنَا نَخَافُ أَن يَفْرُطَ عَلَيْنَا أَوْ أَن يَطْغَىٰ","english":"They said: Our Lord, indeed we fear that they hasten against us or transgress!"}]},{"pos":"verb","gloss":"to send before; to hand over, to make go before"},{"pos":"verb","gloss":"to forgo, to abandon, to let slide, to slight, to relinquish, to let go away, to dump","examples":[{"text":"ينبغي أن نكون صارميم والا انتهينا, إن قوتنا تكمن في مواقفنا الشجاعة التي لايمكن أن نفرط بها.","english":"The vital thing is that we stay rugged and have not quitted. For our power hides in our dauntless positions which to relinquish is unworkable for us."}]},{"pos":"verb","gloss":"to dissipate, to squander, to splurge"},{"pos":"noun","gloss":"verbal noun of فَرَطَ (faraṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"excess, exorbitance, over-","examples":[{"text":"فَرْطُ ٱلتَّعَرُّقِ","english":"hyperhidrosis"}]},{"pos":"noun","gloss":"erect waymark, sign set up to show the right way"},{"pos":"noun","gloss":"one who goes forth, or precedes, preceder, foregoer"},{"pos":"noun","gloss":"reward, recompense prepared beforehand"},{"pos":"noun","gloss":"swift horse"},{"pos":"noun","gloss":"a case or affair in which the due limits are exceeded","examples":[{"text":"وَلَا تُطِعْ مَنْ أَغْفَلْنَا قَلْبَهُ عَن ذِكْرِنَا وَاتَّبَعَ هَوَاهُ وَكَانَ أَمْرُهُ فُرُطًا","english":"And do not obey whose heart we have made heedless of our remembrance and who follows his lust and whose affair is in excess of limits!"}]},{"pos":"noun","gloss":"a hill or eminence resembling a mountain"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33589","headword_ar":"فَرَطَ","root":"frT","body":[{"kind":"text","text":", (O, K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"furuwTN","text_ar":"فُرُوطٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"preceded; went before; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, before, beforehand, first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foremost; had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, priority,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"precedence;"},{"kind":"text","text":"(O, K, TA;) as also"},{"kind":"arabic","text_bw":"fariTa","text_ar":"فَرِطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"faraTN","text_ar":"فَرَطٌ"},{"kind":"text","text":"; which is therefore used as an epithet applied to one and to more;] (O, TA;) and so ↓"},{"kind":"arabic","text_bw":"AftrT","text_ar":"افترط","orth_type":"arrow"},{"kind":"text","text":", in the phrase"},{"kind":"arabic","text_bw":"AftrT A_ilayohi","text_ar":"افترط اـِلَيْهِ"},{"kind":"arabic","text_bw":"fiY h`*aA AlA^amori","text_ar":"فِى هٰذَا الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was foremost in attaining to him in this affair"},{"kind":"text","text":"]. (TA.) [See"},{"kind":"arabic","text_bw":"mufotariTN","text_ar":"مُفْتَرِطٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"faraTa","text_ar":"فَرَطَ"},{"kind":"arabic","text_bw":"Alqawoma","text_ar":"القَوْمَ"},{"kind":"text","text":", (S, O, Msb, K, &c.,) aor."},{"kind":"text","text":", (S, Msb,) or"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"faroTN","text_ar":"فَرْطٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"furuwTN","text_ar":"فُرُوطٌ"},{"kind":"text","text":", (Msb,) or both, (O,) or the former and"},{"kind":"arabic","text_bw":"faraATapN","text_ar":"فَرَاطَةٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He preceded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went before, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men,"},{"kind":"text","text":"(S, M, O, Msb, K,)"},{"kind":"italic_en","text":"to the water,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"in search of water,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"to come to water,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"for the purpose of preparing the buckets and ropes,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"for the purpose of putting into a right state the watering-trough"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"and ropes"},{"kind":"text","text":"(M, O)"},{"kind":"italic_en","text":"and buckets,"},{"kind":"text","text":"(M, O, K,) i. e."},{"kind":"italic_en","text":"to prepare these for them."},{"kind":"text","text":"(TA.) [See also 5.] ―         -b3-  An Arab of the desert said to El-Hasan,"},{"kind":"arabic","text_bw":"Eal~imoniY diynFA","text_ar":"عَلِّمْنِى دِينًا"},{"kind":"arabic","text_bw":"wasuwTFA laA *aAhibFA furuwTFA walaA saAqiTFA suquwTFA","text_ar":"وَسُوطًا لَا ذَاهِبًا فُرُوطًا وَلَا سَاقِطًا سُقُوطًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Teach thou me a religion of the middle sort, not passing beyond the due mean, nor falling short of it."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"faraTa minohu","text_ar":"فَرَطَ مِنْهُ"},{"kind":"italic_en","text":"It proceeded from him hastily, before reflection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without premeditation;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as thought it preceded his judgment;"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"badara","text_ar":"بَدَرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"text","text":". (TA.) [See 3.] You say,"},{"kind":"arabic","text_bw":"faraTa minohu kalaAmN","text_ar":"فَرَطَ مِنْهُ كَلَامٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"Speech proceeded from him hastily, before reflection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without premeditation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"faraTa","text_ar":"فَرَطَ"},{"kind":"arabic","text_bw":"A_ilayohi min~iY qawolN","text_ar":"اـِلَيْهِ مِنِّى قَوْلٌ"},{"kind":"italic_en","text":"A saying proceeded to him from me hastily, before reflection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without premeditation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":". (S.) And in like manner you say of an evil action. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"faraTa Ealayohi","text_ar":"فَرَطَ عَلَيْهِ"},{"kind":"italic_en","text":"He hasted to do him an evil action:"},{"kind":"text","text":"(O, TA:)"},{"kind":"italic_en","text":"he acted hastily and unjustly towards him."},{"kind":"text","text":"(S, O,"},{"kind":"page_break","n":2376},{"kind":"text","text":"TA.) Hence, in the Kur [xx. 47],"},{"kind":"arabic","text_bw":"A_in~aA naxaAfu A^ano","text_ar":"اـِنَّا نَخَافُ اَنْ"},{"kind":"arabic","text_bw":"yaforuTa EalayonaA","text_ar":"يَفْرُطَ عَلَيْنَا"},{"kind":"italic_en","text":"Verily we fear that he may act hastily and unjustly towards us:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"that he may hastily do to us an evil action:"},{"kind":"text","text":"(Ibn-'Arafeh, O:) or"},{"kind":"italic_en","text":"that he may hasten to punish us."},{"kind":"text","text":"(Fr, Bd, O, Jel.) [See also 4.]"},{"kind":"arabic","text_bw":"faraTa Ealayohi","text_ar":"فَرَطَ عَلَيْهِ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He did to him what was disagreeable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hateful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil; he annoyed him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"faraTa","text_ar":"فَرَطَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"furuwTN","text_ar":"فُرُوطٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He reviled."},{"kind":"text","text":"(IKtt.) You say also"},{"kind":"arabic","text_bw":"faraTa Ealayohi fiY","text_ar":"فَرَطَ عَلَيْهِ فِى"},{"kind":"arabic","text_bw":"Alqawoli","text_ar":"القَوْلِ"},{"kind":"text","text":": see 4, latter half. ―         -b6-"},{"kind":"arabic","text_bw":"faraTa fiyhi","text_ar":"فَرَطَ فِيهِ"},{"kind":"text","text":": see 2, near the middle. ―         -b7-"},{"kind":"arabic","text_bw":"faraTa fiY HawoDihi","text_ar":"فَرَطَ فِى حَوْضِهِ"},{"kind":"text","text":": see 4, last sentence but one. ―         -b8-"},{"kind":"arabic","text_bw":"faraTati Aln~axolapu","text_ar":"فَرَطَتِ النَّخْلَةُ"},{"kind":"italic_en","text":"The palm-tree was left without being fecundated until its spadix became dry and hard"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EasaA","text_ar":"عَسَا"},{"kind":"text","text":", in the CK"},{"kind":"arabic","text_bw":"Ea$A","text_ar":"عَشا"},{"kind":"text","text":", and in the O"},{"kind":"arabic","text_bw":"yaEosuw","text_ar":"يَعْسُو"},{"kind":"text","text":"). (O, K, * TA.) ―         -b9-  And"},{"kind":"arabic","text_bw":"faraTati","text_ar":"فَرَطَتِ"},{"kind":"arabic","text_bw":"Albiy^oru","text_ar":"البِيْرُ"},{"kind":"italic_en","text":"The well was left until its water had collected again."},{"kind":"text","text":"(Sh, TA.)       -A2-"},{"kind":"arabic","text_bw":"faraTa A_ilayohi rasuwlahu","text_ar":"فَرَطَ اـِلَيْهِ رَسُولَهُ"},{"kind":"text","text":": see 2. ―         -b2-"},{"kind":"arabic","text_bw":"faraTa wulodFA","text_ar":"فَرَطَ وُلْدًا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"waladFA","text_ar":"وَلَدًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"faraTa waladahu","text_ar":"فَرَطَ وَلَدَهُ"},{"kind":"text","text":": see 4."}],"source_refs":["O","K","TA","S","Msb","M"]}]}}