in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصِيحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصِح","in_corpus":true,"count":28,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَصِيح","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصِح","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَصِيح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصِيحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصِيحانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصِيحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصِيحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصِيحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصِيحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صِحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صِحْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":64,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n23846","n25299"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to yell, to shout"},{"pos":"adj","gloss":"awake"},{"pos":"adj","gloss":"sober","examples":[{"text":"الْحُسَيْن بن عَليّ النميري\nوَإِذَا تَقَابَلَتِ النَّدَامَى وَسْطَهُ // سَكِرَ الصُّحَاةُ كَمَا صَحَا سَكْرَاهَا\nwaʔiḏā taqābalati n-nadāmā wasṭahu // sakira aṣ-ṣuḥātu kamā ṣaḥā sakrāhā","english":"(please add an English translation of this quotation)"}]},{"pos":"noun","gloss":"clipping of صَاحِبِي (ṣāḥibī)","tags":["abbreviation","alt-of","clipping","vocative"],"examples":[{"text":"Umar Al-Khayyām\nاِشْرَبْ فَكَمْ سَتَنَامُ فِي قَعْرِ الثَّرَى / يَا صَاحِ دُوْنَ حَلِيلَةٍ وَخَلِيلِ\nišrab fakam satanāmu fī qaʕri ṯ-ṯarā / yā ṣāḥi duwna ḥalīlatin waḵalīli","english":"(please add an English translation of this quotation)"}]}]},"etymology":null,"ipa":["/sˤaːħ/","/sˤaː.ħin/","/sˤaː.ħi/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23846","headword_ar":"صَاحٍ","root":"SHw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":". ―         -b2-  It is also said of one intoxicated [as meaning"},{"kind":"italic_en","text":"Recovering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming free,"},{"kind":"page_break","n":1657},{"kind":"italic_en","text":"from his intoxication;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceasing to be intoxicated:"},{"kind":"text","text":"see 1]. (S, TA.)"}],"source_refs":[]},{"entry_id":"n25299","headword_ar":"صَاحَ","root":"SyH","body":[{"kind":"text","text":", (S, A, O, Msb, &c.,) aor."},{"kind":"arabic","text_bw":"yaSiyHu","text_ar":"يَصِيحُ"},{"kind":"text","text":", (S, O, Msb,) inf. n."},{"kind":"arabic","text_bw":"SiyaAHN","text_ar":"صِيَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SayoHapN","text_ar":"صَيْحَةٌ"},{"kind":"text","text":"(S, A, *  O, Msb, K *) and"},{"kind":"arabic","text_bw":"SayoHN","text_ar":"صَيْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SuyaAHN","text_ar":"صُيَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SayaHaAnN","text_ar":"صَيَحَانٌ"},{"kind":"text","text":", (S, O, K, *)"},{"kind":"italic_en","text":"He raised his voice, voiced, called"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"called out, cried"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried out:"},{"kind":"text","text":"(S, A, O, Msb, K:) or"},{"kind":"italic_en","text":"did so vehemently, cried aloud, uttered a loud cry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying, shouted, exclaimed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vociferated:"},{"kind":"text","text":"(T, S, * A, * O, * Msb, * TA:) or"},{"kind":"italic_en","text":"did so with his utmost force"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Sy~H","text_ar":"صيّح","orth_type":"arrow"},{"kind":"text","text":": (A, *  TA:) it is said of a man, and of other things: (TA:) or of anything: (T, TA:) originally, of an animal, and often of a bird of the crow-kind, but rarely of a bird unrestrictedly, and sometimes of a spear as being likened to an animal. (Ham p. 187.) One says,"},{"kind":"arabic","text_bw":"SaAHa SayoHapF $adiydapF","text_ar":"صَاحَ صَيْحَةً شَدِيدَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He called,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with a vehement calling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"with a vehement call"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry"},{"kind":"text","text":"&c.]. (A.) And"},{"kind":"arabic","text_bw":"SAj bihi","text_ar":"صاج بِهِ"},{"kind":"italic_en","text":"He called"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"called out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried out, to it"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"to him"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"SiHo","text_ar":"صِحْ"},{"kind":"arabic","text_bw":"liY bifulaAnK","text_ar":"لِى بِفُلَانٍ"},{"kind":"italic_en","text":"Call thou to me such a one."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaAyaHa","text_ar":"صَايَحَ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SaAyaHahu","text_ar":"صَايَحَهُ"},{"kind":"text","text":", (A, TA,) and ↓"},{"kind":"arabic","text_bw":"Say~aHa","text_ar":"صَيَّحَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Say~aHahu","text_ar":"صَيَّحَهُ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He called, hailed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"summoned, him; called out, cried out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouted, to him."},{"kind":"text","text":"(A, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"SiyHa bihimo","text_ar":"صِيحَ بِهِمْ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They were"},{"kind":"page_break","n":1752},{"kind":"italic_en","text":"frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"SiyHa fiyhimo","text_ar":"صِيحَ فِيهِمْ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They perished."},{"kind":"text","text":"(K.) ―         -b3-  One says also,"},{"kind":"arabic","text_bw":"laqiytuhu","text_ar":"لَقِيتُهُ"},{"kind":"arabic","text_bw":"qabola kul~i SayoHK wanaforK","text_ar":"قَبْلَ كُلِّ صَيْحٍ وَنَفْرٍ"},{"kind":"italic_en","text":"I met him before every calling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying, and dispersing;"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"I met him before daybreak:"},{"kind":"text","text":"(S, TA:) so in the Proverbs of Meyd. (TA.) Or"},{"kind":"arabic","text_bw":"A^atayotuhu qabola SayoHK wanaforK","text_ar":"اَتَيْتُهُ قَبْلَ صَيْحٍ وَنَفْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I came to him before everything."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"gaDiba mino gayori SayoHK walaA naforK","text_ar":"غَضِبَ مِنْ غَيْرِ صَيْحٍ وَلَا نَفْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was angry for neither little nor much:"},{"kind":"text","text":"(ISk, S, K:) or"},{"kind":"italic_en","text":"for nothing."},{"kind":"text","text":"(A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"SaAHati Al$~ajarapu","text_ar":"صَاحَتِ الشَّجَرَةُ"},{"kind":"text","text":", (A, Msb,) or"},{"kind":"arabic","text_bw":"Aln~axolapu","text_ar":"النَّخْلَةُ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The tree,"},{"kind":"text","text":"(A, Msb,) or"},{"kind":"italic_en","text":"the palm-tree,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"became tall."},{"kind":"text","text":"(A, Msb, K.) And"},{"kind":"arabic","text_bw":"SAH AlEunoquwdu","text_ar":"صاح العُنْقُودُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The raceme came forth completely from its envelope, and became long, and in a fresh and tender state."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"SAH AlkaAfuwru","text_ar":"صاح الكَافُورُ"},{"kind":"text","text":"(tropical:)  [app. meaning"},{"kind":"italic_en","text":"The spathe of the palm-tree put forth its spadix,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its raceme, to its full length"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","O","Msb","A","K","TA","T","ISk"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B5%D8%A7%D8%AD/","headword_ar":"صاح","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=61780#205f09","body_html":"صاح<br>عن اللاتينية بمعنى صحيح وسليم وعاقل وحكيم وعارف وعالم."},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61780#6ab4e6","body_html":"<span class=\"title1\">صاح</span><br><span>الصَّيْحَةُ: رفع الصّوت. قال تعالى: إِنْ كانَتْ إِلَّا صَيْحَةً واحِدَةً</span><br><span>[يس/ 29] ، يَوْمَ يَسْمَعُونَ الصَّيْحَةَ بِالْحَقِ</span><br><span>[ق/ 42] ، أي:</span><br><span><div>النّفخ في الصّور، وأصله: تشقيق الصّوت، من قولهم: انْصَاحَ الخشبُ، أو الثّوب، إذا انشقّ، فسمع منه صوت، وصِيحَ الثّوبُ إذا انشقّ، كذلك، ويقال: بأرض فلان شجر قد صَاحَ: إذا طال فتبيّن للنّاظر لطوله، ودلّ على نفسه دلالة الصَّائِحِ على نفسه بصوته، ولمّا كانت الصَّيْحَةُ قد تفزع عبّر بها عن الفزع في قوله: فَأَخَذَتْهُمُ الصَّيْحَةُ مُشْرِقِينَ</div>[الحجر/ 73] ، والصَّائِحَةُ:</span><br><span>صَيْحَةُ المناحة، ويقال: ما ينتظرون إلّا مثل صَيْحَةِ الحبلى ، أي: شرّا يعاجلهم، والصَّيْحَانِيُّ: ضربٌ من التّمر.</span>"}]}}