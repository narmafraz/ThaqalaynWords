_ids":["n34055"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%81%D9%92%D8%AA%D9%8E%D8%B6%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become exposed, to come to light"}]},"etymology":null,"ipa":["/if.ta.dˤa.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34055","headword_ar":"افتضح","root":"fDH","body":[{"kind":"italic_en","text":"His vices, faults,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"actions, became exposed; he became disgraced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put to shame:"},{"kind":"text","text":"(S, L, K:)"},{"kind":"italic_en","text":"he did evil, and became disgraced thereby."},{"kind":"text","text":"(L.) ―         -b2-  And [hence]"},{"kind":"arabic","text_bw":"AifotaDaHonaA","text_ar":"اِفْتَضَحْنَا"},{"kind":"arabic","text_bw":"fiyka","text_ar":"فِيكَ"},{"kind":"italic_en","text":"We have been negligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have failed of our duty, in respect of visiting thee, and seeking for thee."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["S","L","K"]}]},"classical_definitions":null}