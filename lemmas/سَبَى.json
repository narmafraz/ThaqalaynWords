count":9,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُسْبَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسْبَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْبِي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْبِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَبَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَبَيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":43,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n18835","n18840"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%A8%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to captivate, to captive"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew שבה (šaváh, “captivate”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18835","headword_ar":"سَبْىٌ","root":"sbY","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"masobiY~N","text_ar":"مَسْبِىٌّ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Made captive"},{"kind":"text","text":"]; (M;) or"},{"kind":"arabic","text_bw":"Als~aboYu","text_ar":"السَّبْىُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"maA yusobaY","text_ar":"مَا يُسْبَى"},{"kind":"text","text":"[i.e."},{"kind":"italic_en","text":"what is made captive;"},{"kind":"text","text":"but I rather think that the right explanation is"},{"kind":"arabic","text_bw":"mano yusobaY","text_ar":"مَنْ يُسْبَى"},{"kind":"text","text":"i. e"},{"kind":"italic_en","text":"the person who is made captive;"},{"kind":"text","text":"agreeably with what follows]: pl."},{"kind":"arabic","text_bw":"subiY~N","text_ar":"سُبِىٌّ"},{"kind":"text","text":": (M, K:) one says"},{"kind":"arabic","text_bw":"qawomN saboYN","text_ar":"قَوْمٌ سَبْىٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, of men made captive"},{"kind":"text","text":"]; the latter word in this case being an inf. n. used as an epithet; [therefore, as such, it is applicable to a single person, male or female, as well as to a pl. number;] and accord. to As, one says not otherwise than thus in speaking of a company, or party, of men: (Msb, TA:) [but] ↓"},{"kind":"arabic","text_bw":"sabiY~N","text_ar":"سَبِىٌّ","orth_type":"arrow"},{"kind":"text","text":"is [also] applied to a single person, to the male and the female, (M, K,) i. e. to the latter, as to the former, without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", (M,) as meaning"},{"kind":"italic_en","text":"made captive:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"sabiY~N","text_ar":"سَبِىٌّ"},{"kind":"text","text":"is applied to a boy, or young man, or male slave, as also ↓"},{"kind":"arabic","text_bw":"masobiY~N","text_ar":"مَسْبِىٌّ","orth_type":"arrow"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"sabiy~apN","text_ar":"سَبِيَّةٌ"},{"kind":"text","text":"to a girl, or young woman, or female slave, as also ↓"},{"kind":"arabic","text_bw":"masobiy~apN","text_ar":"مَسْبِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) or to a woman, in this sense: (S:) and the pl. of ↓"},{"kind":"arabic","text_bw":"sabiY~N","text_ar":"سَبِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) or of"},{"kind":"arabic","text_bw":"sabiy~apN","text_ar":"سَبِيَّةٌ"},{"kind":"text","text":", (Msb,) is"},{"kind":"arabic","text_bw":"sabaAyaA","text_ar":"سَبَايَا"},{"kind":"text","text":", (M, Msb, K,) applied to women. (M.) ―         -b2-  Also"},{"kind":"italic_en","text":"Women,"},{"kind":"text","text":"(IAar, M, K,) universally; (IAar, M;) because they captivate the hearts; or because they are made captive, and possessed as property. (M, K.)"}],"source_refs":["M","K","Msb","TA","S","IAar"]},{"entry_id":"n18840","headword_ar":"سَبِىٌّ","root":"sbY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saboYN","text_ar":"سَبْىٌ"},{"kind":"text","text":", in two places. ―         -b2-  Also, (K,) or"},{"kind":"arabic","text_bw":"EuwdN sabiY~N","text_ar":"عُودٌ سَبِىٌّ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"A branch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of stick"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wood, brought by a torrent from one tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region, to another,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"from a distant place;"},{"kind":"text","text":"(M;) and ↓"},{"kind":"arabic","text_bw":"sabaA='N","text_ar":"سَبَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sabFA","text_ar":"سَبًا","orth_type":"arrow"},{"kind":"text","text":"signify the same. (K.) ―         -b3-"},{"kind":"arabic","text_bw":"sabiY~u AlHay~api","text_ar":"سَبِىُّ الحَيَّةِ"},{"kind":"italic_en","text":"The slough of the serpent;"},{"kind":"text","text":"(M, * K;) as also"},{"kind":"arabic","text_bw":"sabiyw^uhaA","text_ar":"سَبِيوُهَا"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"sbA^","text_ar":"سبا"},{"kind":"text","text":". [Accord. to different copies of the K in the present art.,"},{"kind":"arabic","text_bw":"sabo'N","text_ar":"سَبْءٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"sibo'N","text_ar":"سِبْءٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"saboYN","text_ar":"سَبْىٌ"},{"kind":"text","text":", all of which are wrong.]) ―         -b4-"},{"kind":"arabic","text_bw":"sabiy~apN","text_ar":"سَبِيَّةٌ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"dur~apN sabiy~apN","text_ar":"دُرَّةٌ سَبِيَّةٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"A pearl,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large pearl, brought out by the diver"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"from the sea."},{"kind":"text","text":"(TA.) ―         -b5-  Also, [or"},{"kind":"arabic","text_bw":"xamorN sabiy~apN","text_ar":"خَمْرٌ سَبِيَّةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"Wine brought from one town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country, to another:"},{"kind":"text","text":"(S, M, K:) if bought to be drunk, it is termed"},{"kind":"arabic","text_bw":"sabiyoy^apN","text_ar":"سَبِيْيَةٌ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (S, M:) or, perhaps, the former may be an instance of the alleviation of"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":". (M. [See also"},{"kind":"arabic","text_bw":"sabiyoy^apN","text_ar":"سَبِيْيَةٌ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"sbA^","text_ar":"سبا"},{"kind":"text","text":".])"}],"source_refs":["K","M","TA","S"]}]}}