m":"أَرْتَدّ","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":36,"cross_references":{"qac":{"found":true,"lemma_key":"اِرْتَدَّ","root":"ردد","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n15186"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B1%D9%92%D8%AA%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15186","headword_ar":"ارتدّ","root":"rd","body":[{"kind":"text","text":"quasi-pass. of 1 as expl. in the first sentence of this art.; (Msb;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, returned, went back, came back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reverted;"},{"kind":"text","text":"&c.; (S, L, Msb, * K;) ["},{"kind":"arabic","text_bw":"Eano wajohihi","text_ar":"عَنْ وَجْهِهِ"},{"kind":"italic_en","text":"from his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, course;"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"Eano saEodihi wadiynihi","text_ar":"عَنْ سَعْدِهِ وَدِينِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from his state of prosperity and his religion"},{"kind":"text","text":"]; (A;) and"},{"kind":"arabic","text_bw":"A_ilaY manozilihi","text_ar":"اـِلَى مَنْزِلِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to his abode"},{"kind":"text","text":"]: (Msb:) or"},{"kind":"italic_en","text":"he turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shifted;"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from it"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"Eano diynihi","text_ar":"عَنْ دِينِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from his religion"},{"kind":"text","text":"]. (M.) [Hence,"},{"kind":"italic_en","text":"He apostatized;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revolted from his religion:"},{"kind":"text","text":"and particularly]"},{"kind":"italic_en","text":"he returned from El-Islám to disbelief;"},{"kind":"text","text":"(Msb;) or so"},{"kind":"arabic","text_bw":"Artd~ Eini","text_ar":"ارتدّ عِنِ"},{"kind":"arabic","text_bw":"AlA_isolaAmi","text_ar":"الاـِسْلَامِ"},{"kind":"text","text":". (L.) And"},{"kind":"arabic","text_bw":"yarotad~u AlbaSaru Eanohu mino quboHihi","text_ar":"يَرْتَدُّ البَصَرُ عَنْهُ مِنْ قُبْحِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The eye reverts from him by reason of his unseemliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugliness"},{"kind":"text","text":"]. (TA.) See also 6. ―         -b2-  [Hence also,]"},{"kind":"arabic","text_bw":"Airotad~ato nafosiY A_ilaY waqoti A@notihaA='i mud~atiY","text_ar":"اِرْتَدَّتْ نَفْسِى اـِلَى وَقْتِ ا@نْتِهَا=ءِ مُدَّتِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My soul was brought, or came, to the time of the end of my duration"},{"kind":"text","text":"]. (IB, TA in art."},{"kind":"arabic","text_bw":"Amr","text_ar":"امر"},{"kind":"text","text":". [See a verse of El-'Ajjáj cited voce"},{"kind":"arabic","text_bw":"A^amaArN","text_ar":"اَمَارٌ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"arabic","text_bw":"Airotad~ato EalaY fulaAnK bigoyatuhu","text_ar":"اِرْتَدَّتْ عَلَى فُلَانٍ بِغْيَتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing that he sought was refused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denied, to such a one"},{"kind":"text","text":"]: said of one who finds not what he seeks. (TA in art."},{"kind":"arabic","text_bw":"bgY","text_ar":"بغى"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"Artd~hu","text_ar":"ارتدّهُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"rad~ahu","text_ar":"رَدَّهُ"},{"kind":"text","text":"as expl. in the first sentence of this art., q. v. (M, L.) ―         -b2-  See also 10, (with which it is likewise syn.,) in two places."}],"source_refs":["Msb"]}]},"classical_definitions":null}