,"num":"p"},{"role":"present_3mp","form":"يُسَلِّمُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسَلَّمْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُسَلِّمْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَلَّمْنا","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَلَّمْتُ","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سُلِّمْنا","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سُلِّمْتُ","in_corpus":true,"count":31,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسَلَّم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَلَّم","in_corpus":true,"count":66,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسَلِّم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَلِّم","in_corpus":true,"count":66,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":690,"cross_references":{"qac":{"found":true,"lemma_key":"سَلَّمَ","root":"سلم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":11,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":17},"lanes":{"found":true,"entry_ids":["n20529","n20536","n20537","n20538","n20539","n20553"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"peace","tags":["uncountable"],"examples":[{"text":"إِنْ أَرَدْتَ السِّلْمَ فَتَأَهَّبْ لِلْحَرْبِ.","english":"If you want peace, then prepare for war."},{"text":"وَإِن جَنَحُوا لِلسَّلْمِ فَٱجْنَحْ لَهَا","english":"And if they incline to peace, incline to it too."}]},{"pos":"adj","gloss":"peaceful","examples":[{"text":"أَنَا سِلْمٌ لِمَنْ سَالَمَنِي.","english":"I am peaceful to him who keeps peace to me."}]},{"pos":"noun","gloss":"submission, surrender","examples":[{"text":"وَأَلْقَوْا إِلَى ٱللَّٰهِ يَوْمَئِذٍ ٱلسَّلَمَ ۖ وَضَلَّ عَنْهُم مَّا كَانُوا يَفْتَرُونَ","english":"And they proffer unto God on that day submission, and the idols they fell for failed them."}]},{"pos":"adj","gloss":"in peace","examples":[{"text":"ضَرَبَ ٱللّٰهُ مَثَلًا رَّجُلًا فِيهِ شُرَكَاءُ مُتَشَاكِسُونَ وَرَجُلًا سَلَمًا لِّرَجُلٍ هَلْ يَسْتَوِيَانِ مَثَلًا ۚ ٱلْحَمْدُ لِلَّٰهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","english":"God coined a simile: A man with various partners disputing and a man in peace. Are the two equal in the simile? Praise be to God! But most of them know not."}]},{"pos":"noun","gloss":"ladder, stairs","examples":[{"text":"وَإِن كَانَ كَبُرَ عَلَيْكَ إِعْرَاضُهُمْ فَإِنِ ٱسْتَطَعْتَ أَن تَبْتَغِيَ نَفَقًا فِي ٱلْأَرْضِ أَوْ سُلَّمًا فِي ٱلسَّمَاءِ فَتَأْتِيَهُم بِآيَةٍ","english":"And if their aversion is grievous unto thee, then, if thou canst, seek a way down into the earth or a ladder unto the sky that thou mayst bring unto them a portent (to convince them all)!"}]},{"pos":"verb","gloss":"to be safe, to be well"},{"pos":"verb","gloss":"to be free (from); to become free (from), to escape (from)","examples":[{"text":"High honor is not spared from harm until blood has been shed at its sides."}]},{"pos":"verb","gloss":"to surrender","tags":["transitive"]},{"pos":"verb","gloss":"to submit to, to be submissive to; to succumb, to yield or to surrender to","examples":[{"text":"فَلَا وَرَبِّكَ لَا يُؤْمِنُونَ حَتَّى يُحَكِّمُوكَ فِيمَا شَجَرَ بَيْنَهُمْ ثُمَّ لَا يَجِدُوا فِي أَنْفُسِهِمْ حَرَجًا مِمَّا قَضَيْتَ وَيُسَلِّمُوا تَسْلِيمًا","english":"But nay, by thy Lord, they will not believe until they make thee judge about the dispute arising between them and find between themselves no trammel from what thou rulest and submit with whole submission."}]},{"pos":"verb","gloss":"to greet (with عَلَى (ʕalā))"},{"pos":"verb","gloss":"to make safe, to keep safe, to protect","examples":[{"text":"اللّٰهُ يُسَلِّمُكَ","english":"you're welcome; may God protect you; get well soon; goodbye (as an answer)"},{"text":"إِذْ يُرِيكَهُمُ ٱللَّٰهُ فِي مَنَامِكَ قَلِيلًا ۖ وَلَوْ أَرَاكَهُمْ كَثِيرًا لَّفَشِلْتُمْ وَلَتَنَازَعْتُمْ فِي ٱلْأَمْرِ وَلَٰكِنَّ ٱللَّٰهَ سَلَّمَ ۗ إِنَّهُ عَلِيمٌ بِذَاتِ ٱلصُّدُورِ","english":"When God showed them unto thee in thy dream as few, and if he had shown them to thee as many, ye would have dithered and would have made a fuss of the matter, but God kept you safe of it, for he knows how the breasts of the people go."}]},{"pos":"verb","gloss":"to hand over, to deliver","examples":[{"text":"فقالَ لِأتباعِهِ أكثَرَ مِن مَرَّةٍ إنَّهُ سيُسَلَّمُ.","english":"He told his followers more than once that he would be handed over."}]},{"pos":"verb","gloss":"to admit, to concede, to grant"},{"pos":"noun","gloss":"stones","tags":["collective"],"examples":[{"text":"١ عَفَتِ الدِّيارُ مَحَلُّهَا فَمُقَامُهَا * بمنًى تأبَّدَ غَوْلُها فَرِجَامُهَا\n٢ فمَدافعُ الرَّيَّانِ عُرِّيَ رَسْمُهَا * خَلَقًا كما ضَمِنَ الوُحِيَّ سِلاَمُها\n٣ دِمَنٌ تَجَرَّمَ بَعدَ عَهْدِ أنِيسِهَا * حِجَجٌ خَلَوْنَ حَلالُهَا وحَرَامُهَا\n٤ رُزِقَتْ مَرابيعَ النُّجُومِ وَصَابَهَا * وَدْقُ الرَّوَاعِدِ جَوْدُهَا فَرِهَامُها\n٥ مِنْ كلِّ سَارِيَةٍ وغادٍ مُدْجِنٍ * وَعَشِيَّةٍ مُتجاوبٍ إرْزَامُهَا\n٦ فَعَلا فُرُوعُ الأيْهُقَانِ وَأطْفَلَتْ * بالجَلهَتين ظِبَاؤهَا ونَعَامُهَا","english":"Effaced are her resting-places where she stayed and settled in Mina: deserted are her camps in Ḡawl and ar-Rijām\nand the torrents of ar-Rayyān: the traces thereof are laid bare and are torn, as inscribed rocks.\nCampsites have already passed after their period of use; years of war and peace overcome.\nCast off there fell upon them the rains of spring signs, and there swept sated thunder clouds and drizzling rains\nfrom every cloud of night, every full one of morn, and those of eve, answering like a hoting squawk,\nand there sprung shoots of arugula, and in the brinks of a valley the goats and antelopes have youngs."}]},{"pos":"noun","gloss":"Vachellia flava syn. Acacia ehrenbergiana (species of drought-resistant trees in the genus Vachellia)","tags":["collective"]},{"pos":"noun","gloss":"captives","tags":["collective"]},{"pos":"noun","gloss":"futures contract, time bargain, forward transaction"}]},"etymology":{"source":"wiktextract","text":"From Aramaic סוּלַם (sulam), with influence from Hebrew סֻלָּם (sullām) – compare against Classical Syriac ܣܒܠܬܐ (sebbelṯā) and Classical Mandaic ࡎࡅࡌࡁࡉࡋࡕࡀ (sumbiltā) – from Akkadian 𒄑𒄿𒇻 (simmiltum, “stair; stairs; ladder”).\n\nCognates include Hebrew שלם and Aramaic שלם."},"ipa":["/silm/","/sul.lam/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20529","headword_ar":"سَلِمَ","root":"slm","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"salaAmapN","text_ar":"سَلَامَةٌ"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":", (Bd in xxxix. 30,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he escaped;"},{"kind":"text","text":"(M, TA;) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free;"},{"kind":"text","text":"(TA;)"},{"kind":"arabic","text_bw":"mina AlA=faAti","text_ar":"مِنَ الا=فَاتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from evils of any kind"},{"kind":"text","text":"], (S, Mgh,) or"},{"kind":"arabic","text_bw":"mina AlA=fapi","text_ar":"مِنَ الا=فَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from evil of any kind"},{"kind":"text","text":"], (K,) or"},{"kind":"arabic","text_bw":"mina AlbalaA='i","text_ar":"مِنَ البَلَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction"},{"kind":"text","text":"], (A, TA,) or"},{"kind":"arabic","text_bw":"mina AlA^amori","text_ar":"مِنَ الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the affair"},{"kind":"text","text":"]: (M:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a traveller)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, safe, secure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free, from evils of any kind:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"salima mina AlEayobi","text_ar":"سَلِمَ مِنَ العَيْبِ"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from fault, defect, imperfection, blemish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vice;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"bariy^a","text_ar":"بَرِيَ"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"brA^","text_ar":"برا"},{"kind":"text","text":".) [Hence,] one says,"},{"kind":"arabic","text_bw":"laA bi*iY tasolamu maA kaAna","text_ar":"لَا بِذِى تَسْلَمُ مَا كَانَ"},{"kind":"arabic","text_bw":"Ga*aA waka*aA","text_ar":"گَذَا وَكَذَا"},{"kind":"text","text":", (ISk, S, K, *) meaning"},{"kind":"italic_en","text":"No, by God"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who maketh thee to be in safety,"},{"kind":"text","text":"(ISk, S, K,) ["},{"kind":"italic_en","text":"such and such things were not;"},{"kind":"text","text":"] and to two persons"},{"kind":"arabic","text_bw":"lA b*Y tasolamaAni","text_ar":"لا بذى تَسْلَمَانِ"},{"kind":"text","text":", and to a pl. number"},{"kind":"arabic","text_bw":"lA b*Y tasolamuwna","text_ar":"لا بذى تَسْلَمُونَ"},{"kind":"text","text":", and to a female"},{"kind":"arabic","text_bw":"lA b*Y tasolamiyna","text_ar":"لا بذى تَسْلَمِينَ"},{"kind":"text","text":", and to a pl. number [of females]"},{"kind":"arabic","text_bw":"lA b*Y tasolamona","text_ar":"لا بذى تَسْلَمْنَ"},{"kind":"text","text":". (ISk, S, K. *) And"},{"kind":"arabic","text_bw":"laA A^afoEalu *`lika bi*iY tasolamu","text_ar":"لَا اَفْعَلُ ذٰلِكَ بِذِى تَسْلَمُ"},{"kind":"text","text":", meaning,"},{"kind":"arabic","text_bw":"bi*iY salaAmatiki","text_ar":"بِذِى سَلَامَتِكِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I will not do that, by the Author"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"Lord"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Master"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of thy safety"},{"kind":"text","text":"]; and in like manner,"},{"kind":"arabic","text_bw":"b*Y tasolamaAni","text_ar":"بذى تَسْلَمَانِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"b*Y tasolamuwna","text_ar":"بذى تَسْلَمُونَ"},{"kind":"text","text":". (Sb, M. [See also"},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Ai*ohabo bi*iY tasolamu","text_ar":"اِذْهَبْ بِذِى تَسْلَمُ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"Ai*ohabo bisalaAmatika","text_ar":"اِذْهَبْ بِسَلَامَتِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Go thou with thy safety;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"with the Author of thy safety"},{"kind":"text","text":"to protect thee; meaning"},{"kind":"italic_en","text":"go thou in safety"},{"kind":"text","text":"]; and [to two persons]"},{"kind":"arabic","text_bw":"Ai*ohabaA bi*iY tasolamaAni","text_ar":"اِذْهَبَا بِذِى تَسْلَمَانِ"},{"kind":"text","text":". (S, K.)"},{"kind":"arabic","text_bw":"*Y","text_ar":"ذى"},{"kind":"text","text":"is thus prefixed to a verb [as virtually governing it in the gen. case] like as"},{"kind":"arabic","text_bw":"A=yap","text_ar":"ا=يَة"},{"kind":"text","text":"is in an instance mentioned under this latter word; but these are two extr. instances; for only a noun significant of time is [regularly] prefixed to a verb, as in the phrase"},{"kind":"arabic","text_bw":"h`*aA yawomu yufoEalu","text_ar":"هٰذَا يَوْمُ يُفْعَلُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"yufoEalu fiyhi","text_ar":"يُفْعَلُ فِيهِ"},{"kind":"text","text":": (Akh, S:) it is not prefixed to any but this verb"},{"kind":"arabic","text_bw":"tasolamu","text_ar":"تَسْلَمُ"},{"kind":"text","text":"[and its variations as above mentioned]. (Sb, M, K.) ―         -b2-  And hence, (Mgh,) one says also,"},{"kind":"arabic","text_bw":"salimato lahu AlD~ayoEapu","text_ar":"سَلِمَتْ لَهُ الضَّيْعَةُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"The landed estate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from participation to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xalaSat","text_ar":"خَلَصَت"},{"kind":"text","text":". (Mgh, TA.)       -A2-"},{"kind":"arabic","text_bw":"slmhu","text_ar":"سلمهُ"},{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"salamahu","text_ar":"سَلَمَهُ"},{"kind":"text","text":", or perhaps"},{"kind":"arabic","text_bw":"salimahu","text_ar":"سَلِمَهُ"},{"kind":"text","text":", for some verbs of this measure are trans., as"},{"kind":"arabic","text_bw":"Hasiba","text_ar":"حَسِبَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wariva","text_ar":"وَرِثَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"slm","text_ar":"سلم"},{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":", q. v. infrà,]"},{"kind":"italic_en","text":"He made him a captive."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"salamatohu AlHay~apu","text_ar":"سَلَمَتْهُ الحَيَّةُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (M, K, TA,)"},{"kind":"italic_en","text":"The serpent bit him:"},{"kind":"text","text":"(M, * K, * TA:) mentioned by Az, but he adds that no one but Lth has said this. (TA.)       -A4-"},{"kind":"arabic","text_bw":"salama Aljiloda","text_ar":"سَلَمَ الجِلْدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He tanned the skin with"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"leaves of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mimosa flava"},{"kind":"text","text":"]. (S, K, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"salama","text_ar":"سَلَمَ"},{"kind":"arabic","text_bw":"Ald~alowa","text_ar":"الدَّلْوَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He finished making the leathern bucket;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"made it firm, strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it firmly, strongly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundly."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","M","A","Mgh","Msb","K","TA","ISk","Akh"]},{"entry_id":"n20536","headword_ar":"سَلْمٌ","root":"slm","body":[{"kind":"text","text":": see the next paragraph, in six places.       -A2-  Also"},{"kind":"italic_en","text":"A leathern bucket"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dalowN","text_ar":"دَلْوٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"having one"},{"kind":"arabic","text_bw":"Eurowap","text_ar":"عُرْوَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"loop-shaped handle"},{"kind":"text","text":"], (T, S, M, K,)"},{"kind":"italic_en","text":"with which the waterer walks, like the buckets"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dilaA='","text_ar":"دِلَا=ء"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the attendants of the camels or other beasts upon which water is drawn or which carry water,"},{"kind":"text","text":"(T, TA,) or"},{"kind":"italic_en","text":"like the dalow of the water-carriers:"},{"kind":"text","text":"(S, K:) expl. in the S as above as on the authority of AA; but IB says that the correct explanation is,"},{"kind":"italic_en","text":"having one"},{"kind":"arabic","text_bw":"Earoquwap","text_ar":"عَرْقُوَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stick fixed across from one part of the brim to the to the opposite part, serving as a handle as well as to keep it from collapsing"},{"kind":"text","text":"]: (TA:) of the masc. gender [whereas"},{"kind":"arabic","text_bw":"dalowN","text_ar":"دَلْوٌ"},{"kind":"text","text":"is fem.]: (M:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^asolumN","text_ar":"اَسْلُمٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"silaAmN","text_ar":"سِلَامٌ"},{"kind":"text","text":", (M, K,) and Lh mentions as its pl."},{"kind":"arabic","text_bw":"A^asaAlimu","text_ar":"اَسَالِمُ"},{"kind":"text","text":", which is extr. [unless as a pl. pl., i. e. pl. of"},{"kind":"arabic","text_bw":"A^asolumN","text_ar":"اَسْلُمٌ"},{"kind":"text","text":"]. (M.)"}],"source_refs":["T","S","M","K","TA"]},{"entry_id":"n20537","headword_ar":"سِلْمٌ","root":"slm","body":[{"kind":"italic_en","text":"Peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reconciliation;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, M, Msb, K;) masc. and fem.; (S, Msb, K; *) and ↓"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ","orth_type":"arrow"},{"kind":"text","text":"are like"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":"[in signification]: (M: [the context there shows that the signification mentioned above is what is meant in this instance:]) or"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"making peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming at peace"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reconciled,"},{"kind":"text","text":"with another or others; (Ham p. 80;) as also ↓"},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ","orth_type":"arrow"},{"kind":"text","text":"; and both are sometimes fem. as being syn. with"},{"kind":"arabic","text_bw":"muSaAlaHapN","text_ar":"مُصَالَحَةٌ"},{"kind":"text","text":". (L voce"},{"kind":"arabic","text_bw":"janaHa","text_ar":"جَنَحَ"},{"kind":"text","text":", q. v.) In the saying of El-Aashà,"},{"kind":"quote","text":"A^a*aAqatohumu AlHarobu A^anofaAsahaA\n                      \n                     ↓ \n      waqado tukorahu AlHarobu baEoda Als~ilimo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"War made them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has made them, to taste its draughts, and verily war is disliked after peace"},{"kind":"text","text":"], he has transferred the vowel of the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"to the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":", in pausing; or it may be that he has inserted a kesreh in imitation of the preceding kesreh: it is not an instance like"},{"kind":"arabic","text_bw":"A_ibil","text_ar":"اـِبِل"},{"kind":"text","text":", in the opinion of Sb; for in his opinion the latter is the only instance of its kind. (M.) It is said in a trad., respecting El-Hodeybiyeh,"},{"kind":"arabic","text_bw":"A^axa*a vamaAniyna mino A^aholi mak~apa silomFA","text_ar":"اَخَذَ ثَمَانِينَ مِنْ اَهْلِ مَكَّةَ سِلْمًا"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"salomFA","text_ar":"سَلْمًا","orth_type":"arrow"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"salamFA","text_ar":"سَلَمًا","orth_type":"arrow"},{"kind":"text","text":", accord. to different relations, meaning ["},{"kind":"italic_en","text":"He took forty of the people of Mekkeh"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"peaceably:"},{"kind":"text","text":"thus expl. by El-Homeydee, in his “ Ghareeb. ” (TA. [See also"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":"below.]) ―         -b2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) as signifying"},{"kind":"italic_en","text":"Selfresignation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submission;"},{"kind":"text","text":"(TA; [and thus the latter is expl. in one place in the S;]) which is also a signification of ↓"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ","orth_type":"arrow"},{"kind":"text","text":": (S, M, K, TA:) and this is meant in the Kur [iv. 96], where it is said,"},{"kind":"arabic","text_bw":"lasota muw^ominFA","text_ar":"لَسْتَ مُوْمِنًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"walaA taquwluwA limano A^aloqaY A_ilayokumu A@ls~alaAma","text_ar":"وَلَا تَقُولُوا لِمَنْ اَلْقَى اـِلَيْكُمُ ا@لسَّلَامَ","orth_type":"arrow"},{"kind":"text","text":", (Bd, TA,) or ↓"},{"kind":"arabic","text_bw":"Als~alama","text_ar":"السَّلَمَ","orth_type":"arrow"},{"kind":"text","text":", as some read, (Bd,) [i. e."},{"kind":"italic_en","text":"And say not ye to him who offers to you submission, Thou art not a believer:"},{"kind":"text","text":"] or ↓"},{"kind":"arabic","text_bw":"Als~alaAma","text_ar":"السَّلَامَ","orth_type":"arrow"},{"kind":"text","text":"here means"},{"kind":"italic_en","text":"the salutation of"},{"kind":"arabic","text_bw":"AlA_isolaAm","text_ar":"الاـِسْلَام"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by saying"},{"kind":"arabic","text_bw":"salaAmN Ealayokumo","text_ar":"سَلَامٌ عَلَيْكُمْ"},{"kind":"text","text":"]: (Bd, TA: *) or"},{"kind":"italic_en","text":"salutation, and submission by uttering the profession of"},{"kind":"arabic","text_bw":"AlA_isolaAm","text_ar":"الاـِسْلَام"},{"kind":"text","text":"; and so ↓"},{"kind":"arabic","text_bw":"Als~alama","text_ar":"السَّلَمَ","orth_type":"arrow"},{"kind":"text","text":": (Jel:) [or the latter here means, simply,"},{"kind":"italic_en","text":"salutation;"},{"kind":"text","text":"and this is app. what is meant by its being said that]"},{"kind":"arabic","text_bw":"Als~alamu","text_ar":"السَّلَمُ"},{"kind":"text","text":"is the subst. from"},{"kind":"arabic","text_bw":"Alt~asoliymu","text_ar":"التَّسْلِيمُ"},{"kind":"text","text":"; (K;) [but accord. to SM,] this means"},{"kind":"italic_en","text":"the unreserved approval of what is decreed;"},{"kind":"text","text":"and this is said to be meant by the reading"},{"kind":"arabic","text_bw":"Als~alama","text_ar":"السَّلَمَ"},{"kind":"text","text":"mentioned above. (TA.) ―         -b3-  And [hence]"},{"kind":"arabic","text_bw":"Als~ilomu","text_ar":"السِّلْمُ"},{"kind":"text","text":"signifies also"},{"kind":"arabic","text_bw":"AlA_isolaAmu","text_ar":"الاـِسْلَامُ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"The religion of the Muslims;"},{"kind":"text","text":"because it is a religion of self-resignation, or submission]: (S, K:) this is meant in the Kur [ii. 204], where it is said,"},{"kind":"arabic","text_bw":"AudoxuluwA fiY Als~ilomi kaAf~apF","text_ar":"اُدْخُلُوا فِى السِّلْمِ كَافَّةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Enter ye into the religion of El-Islám wholly"},{"kind":"text","text":"]; (S, Bd, Jel;) and so ↓"},{"kind":"arabic","text_bw":"Als~alomi","text_ar":"السَّلْمِ","orth_type":"arrow"},{"kind":"text","text":", as some there read; (Bd, Jel;) or both there mean"},{"kind":"italic_en","text":"submission and obedience"},{"kind":"text","text":"to God: (Bd:) [and] ↓"},{"kind":"arabic","text_bw":"Als~alamu","text_ar":"السَّلَمُ","orth_type":"arrow"},{"kind":"text","text":"[also] has the former meaning. (M.)       -A2-  Also, (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"salomN","text_ar":"سَلْمٌ","orth_type":"arrow"},{"kind":"text","text":", (M,) A man, (S, K, TA,) [and] a woman, (M,)"},{"kind":"italic_en","text":"who makes peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is at peace,"},{"kind":"text","text":"with another; (S, M, K;) and in like manner, a company of men ("},{"kind":"arabic","text_bw":"qawomN","text_ar":"قَوْمٌ"},{"kind":"text","text":"). (M.) This is said to be meant in the Kur [xxxix. 30], where it is said,"},{"kind":"arabic","text_bw":"warajolFA silomFA lirajulK","text_ar":"وَرَجْلًا سِلْمًا لِرَجُلٍ"},{"kind":"text","text":", as some read, i. e."},{"kind":"italic_en","text":"And a man who is at peace with respect to a man:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"silomFA","text_ar":"سِلْمًا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"salomFA","text_ar":"سَلْمًا","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"salamFA","text_ar":"سَلَمًا","orth_type":"arrow"},{"kind":"text","text":", three different readings, in the place of [the more common reading]"},{"kind":"arabic","text_bw":"saAlimFA","text_ar":"سَالِمًا"},{"kind":"text","text":", are all inf. ns. of"},{"kind":"arabic","text_bw":"salima","text_ar":"سَلِمَ"},{"kind":"text","text":", used as epithets [syn. with"},{"kind":"arabic","text_bw":"saAlimFA","text_ar":"سَالِمًا"},{"kind":"text","text":"], or"},{"kind":"arabic","text_bw":"*aA","text_ar":"ذَا"},{"kind":"text","text":"is suppressed before them. (Bd.) You say,"},{"kind":"arabic","text_bw":"A^anaA silomN limano saAlamaniY","text_ar":"اَنَا سِلْمٌ لِمَنْ سَالَمَنِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I am one who is at peace with respect to him who is at peace with me"},{"kind":"text","text":"]. (S, TA.) And a poet says, [using this word in two different senses, the latter of which has been mentioned above,]"},{"kind":"quote","text":"liA^aholiki faA@qobaliY silomiY \n                      \n                     \n                        A^anaAy^ilu A_in~aniY silomN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O Náïleh,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"naAy^ilu","text_ar":"نَايِلُ"},{"kind":"text","text":"being for"},{"kind":"arabic","text_bw":"naAy^ilapN","text_ar":"نَايِلَةٌ"},{"kind":"text","text":", a woman's name, apocopated,)"},{"kind":"italic_en","text":"verily I am one who is at peace with respect to thy family, therefore accept thou my submission"},{"kind":"text","text":"]. (TA. [It seems to be there indicated by the context that"},{"kind":"arabic","text_bw":"slmY","text_ar":"سلمى"},{"kind":"text","text":"here means"},{"kind":"italic_en","text":"my peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reconciliation;"},{"kind":"text","text":"which is less appropriate than the meaning that I have assigned to it.])"}],"source_refs":["S","K","TA","M","Bd","Jel"]},{"entry_id":"n20538","headword_ar":"سَلَمٌ","root":"slm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":": and see also"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":", in seven places. ―         -b2-  Also, in buying or selling, (Msb,) the subst. from"},{"kind":"arabic","text_bw":"A^asolama fiY Al$~aYo'i","text_ar":"اَسْلَمَ فِى الشَّىْءِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sal~ama","text_ar":"سَلَّمَ"},{"kind":"text","text":"signifying"},{"kind":"arabic","text_bw":"A^asolafa","text_ar":"اَسْلَفَ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"salafN","text_ar":"سَلَفٌ"},{"kind":"text","text":"; (S, Msb, K;) i. e."},{"kind":"italic_en","text":"Any money,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property, paid in advance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beforehand, as the price of a commodity for which the seller has become responsible and which one has bought on description:"},{"kind":"text","text":"(T and TA in art."},{"kind":"arabic","text_bw":"slf","text_ar":"سلف"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"payment for a commodity to be delivered at a certain"},{"kind":"text","text":"["},{"kind":"italic_en","text":"future"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"period with something additional to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the equivalent of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the current price at the time of such payment;"},{"kind":"text","text":"this [transaction] being a cause of profit to him who makes such payment: (TA in that art.:) or"},{"kind":"italic_en","text":"a sort of sale in which the price is paid in advance, and the commodity is withheld, on the condition of description, to a certain"},{"kind":"text","text":"["},{"kind":"italic_en","text":"future"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"period:"},{"kind":"text","text":"(S and O in that art., in explanation of"},{"kind":"arabic","text_bw":"salafN","text_ar":"سَلَفٌ"},{"kind":"text","text":":) but it is said in a trad. that the term"},{"kind":"arabic","text_bw":"salamN","text_ar":"سَلَمٌ"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"salafN","text_ar":"سَلَفٌ"},{"kind":"text","text":"was disliked; app. because the former is applied to obedience, and self-resignation, or submission, to God. (TA.)       -A2-  And The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"[one]"},{"kind":"italic_en","text":"captive."},{"kind":"text","text":"(K. [See 1, in the latter part of the paragraph.])       -A3-  And"},{"kind":"italic_en","text":"A captive;"},{"kind":"text","text":"(K;) because he submits himself. (TA.) One says,"},{"kind":"arabic","text_bw":"A^axa*ahu salamFA","text_ar":"اَخَذَهُ سَلَمًا"},{"kind":"text","text":", (M, TA, [in the TK"},{"kind":"arabic","text_bw":"biAls~alami","text_ar":"بِالسَّلَمِ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"He took him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a captive"},{"kind":"text","text":"], (TA,) or"},{"kind":"italic_en","text":"made him captive,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"without war:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"he brought him in a state of submission, not resisting;"},{"kind":"text","text":"and so,"},{"kind":"italic_en","text":"if wounded:"},{"kind":"text","text":"(IAar, M, TA:) and thus El-Khattábee has expl. the phrase in the trad. respecting El-Hodeybiyeh cited above, voce"},{"kind":"arabic","text_bw":"silomN","text_ar":"سِلْمٌ"},{"kind":"text","text":". (TA.)       -A4-  Also"},{"kind":"italic_en","text":"A sort of tree,"},{"kind":"text","text":"(S, M, Msb, K,) [the"},{"kind":"italic_en","text":"mimosa flava"},{"kind":"text","text":"of Forskål, who writes its Arabic name in Italic characters"},{"kind":"italic_en","text":"syllæm,"},{"kind":"text","text":"and in Arabic characters"},{"kind":"arabic","text_bw":"slym","text_ar":"سليم"},{"kind":"text","text":", (Flora Aegypt. Arab., p. cxxiii.,)]"},{"kind":"italic_en","text":"a species"},{"kind":"text","text":"(M)"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of thorny trees called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":", (S, M, Mgh, Msb, TA, [not"},{"kind":"arabic","text_bw":"gaDaAp","text_ar":"غَضَاة"},{"kind":"text","text":", as in the Lexicons of Golius and Freytag,])"},{"kind":"italic_en","text":"the leaves whereof are the"},{"kind":"arabic","text_bw":"qaraZ","text_ar":"قَرَظ"},{"kind":"text","text":","},{"kind":"italic_en","text":"with which skin is tanned:"},{"kind":"text","text":"(TA:) AHn says,"},{"kind":"italic_en","text":"its branches are long, like rods; and it has no wood such as is used in carpentry, even if it grows large: it has slender, long thorns, grievous when they wound the foot of a man; and a yellow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fruit such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"baramap","text_ar":"بَرَمَة"},{"kind":"text","text":"[n. un. of"},{"kind":"arabic","text_bw":"baramN","text_ar":"بَرَمٌ"},{"kind":"text","text":", see this word, and see also"},{"kind":"arabic","text_bw":"HubolapN","text_ar":"حُبْلَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"which is the sweetest of the"},{"kind":"arabic","text_bw":"baram","text_ar":"بَرَم"},{"kind":"italic_en","text":"in odour; and they tan with its leaves:"},{"kind":"text","text":"and it is said, on the authority of the Arabs of the desert, that"},{"kind":"italic_en","text":"it has a yellow flower, containing a green grain"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Hab~ap xaDoraA='","text_ar":"حَبَّة خَضْرَا=ء"},{"kind":"text","text":"[or this may mean"},{"kind":"italic_en","text":"a grain of a dark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ashy, dustcolour"},{"kind":"text","text":"]),"},{"kind":"italic_en","text":"of sweet odour, in which is somewhat of bitterness, and of which the gazelles are very fond:"},{"kind":"text","text":"(M:) the n. un. is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, M, Mgh, Msb, K:) and pl."},{"kind":"arabic","text_bw":"A^asolaAmN","text_ar":"اَسْلَامٌ"},{"kind":"text","text":", (M,) and"},{"kind":"arabic","text_bw":"silaAmN","text_ar":"سِلَامٌ"},{"kind":"text","text":"is said by IB to be pl. of the n. un., like as"},{"kind":"arabic","text_bw":"A_ikaAmN","text_ar":"اـِكَامٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"A^akamapN","text_ar":"اَكَمَةٌ"},{"kind":"text","text":". (TA.) [Hence,]"},{"kind":"arabic","text_bw":"*aAtu A^asolaAmK","text_ar":"ذَاتُ اَسْلَامٍ"},{"kind":"italic_en","text":"A land"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aroD","text_ar":"اَرْض"},{"kind":"text","text":")"},{"kind":"italic_en","text":"that gives growth to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"trees called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"text","text":". (K.) See also"},{"kind":"arabic","text_bw":"slamaAn","text_ar":"سلَمَان"},{"kind":"text","text":"."}],"source_refs":["Msb","M","TA","IAar","S","K","Mgh"]},{"entry_id":"n20539","headword_ar":"سَلِمٌ","root":"slm","body":[{"kind":"italic_en","text":"Stones;"},{"kind":"text","text":"(S, M;) as also ↓"},{"kind":"arabic","text_bw":"silaAmN","text_ar":"سِلَامٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) and ↓"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ","orth_type":"arrow"},{"kind":"text","text":"[as n. un. of the former and sing. of the latter, (incorrectly written by Freytag, in one place,"},{"kind":"arabic","text_bw":"salamapN","text_ar":"سَلَمَةٌ"},{"kind":"text","text":", and incorrectly said by him to be of the dial. of the people of Himyer,)] signifies"},{"kind":"italic_en","text":"a stone:"},{"kind":"text","text":"(S, M, Mgh, Msb:) [or] the pl. [or quasipl. n.] of"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ"},{"kind":"text","text":"in this sense is ↓"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"kalaAmN","text_ar":"كَلَامٌ"},{"kind":"text","text":"in measure: (Msb:) or ↓"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"stones;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"hard stones;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"silaAmN","text_ar":"سِلَامٌ","orth_type":"arrow"},{"kind":"text","text":"is its pl.: (K:) [said to be] so called because of their freedom ("},{"kind":"arabic","text_bw":"slaAmap","text_ar":"سلَامَة"},{"kind":"text","text":") from softness: (TA:) or this last signifies"},{"kind":"italic_en","text":"stones,"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"small"},{"kind":"text","text":"thereof and the"},{"kind":"italic_en","text":"large;"},{"kind":"text","text":"and they assign to it no sing.: (ISh, TA:) or"},{"kind":"arabic","text_bw":"slAm","text_ar":"سلام"},{"kind":"text","text":"[probably meaning ↓"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ","orth_type":"arrow"},{"kind":"text","text":"] is a quasi-pl. n.: (Aboo-Kheyreh, TA:) and it is also said to be a name for"},{"kind":"italic_en","text":"any broad stone."},{"kind":"text","text":"(TA.) See also"},{"kind":"arabic","text_bw":"salamaAn","text_ar":"سَلَمَان"},{"kind":"text","text":". A poet says, (namely, Bujeyr Ibn- 'Anameh, IB, TA,)"},{"kind":"quote","text":"yaromiY waraAy^iY biA@mosahoki waA@mosahomi waA@mosalimaho"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He casts"},{"kind":"text","text":"from"},{"kind":"italic_en","text":"behind me"},{"kind":"text","text":"(i. e."},{"kind":"italic_en","text":"defends me"},{"kind":"text","text":")"},{"kind":"italic_en","text":"with the arrow and the stone"},{"kind":"text","text":"]: this [usage of"},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"] is of the dial. of [Teiyi and] Himyer. (S, TA.)"}],"source_refs":["M","S","Mgh","Msb","K","TA","ISh"]},{"entry_id":"n20553","headword_ar":"سُلَّمٌ","root":"slm","body":[{"kind":"italic_en","text":"A ladder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a series of stairs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steps,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"miroqaApN","text_ar":"مِرْقَاةٌ"},{"kind":"text","text":", (M, K,) and"},{"kind":"arabic","text_bw":"darajapN","text_ar":"دَرَجَةٌ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"miEoraAjN","text_ar":"مِعْرَاجٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"upon which one ascends;"},{"kind":"text","text":"(S, Mgh;) either"},{"kind":"italic_en","text":"of wood"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of clay"},{"kind":"text","text":"["},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"]: (Mgh:) said by Zj to be so called because it delivers thee ("},{"kind":"arabic","text_bw":"yusal~imuka","text_ar":"يُسَلِّمُكَ"},{"kind":"text","text":") to the place to which thou desirest to go, (Mgh, TA,) i. e., to some high place, and thou hopest for safety ("},{"kind":"arabic","text_bw":"Als~alaAmap","text_ar":"السَّلَامَة"},{"kind":"text","text":") by means of it: (Er-Rághib, TA:) masc. and fem.; (Lth, M, Mgh;) [app., accord. to Lth and F, generally fem.; for] accord. to Lth, one says,"},{"kind":"arabic","text_bw":"hiYa Als~ul~amu","text_ar":"هِىَ السُّلَّمُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"huwa Als~ul~amu","text_ar":"هُوَ السُّلَّمُ"},{"kind":"text","text":"; (Mgh;) [and F says,] it is sometimes made masc.: (K:) pl."},{"kind":"arabic","text_bw":"salaAliymu","text_ar":"سَلَالِيمُ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"salaAlimu","text_ar":"سَلَالِمُ"},{"kind":"text","text":", (K,) [which latter is the original, for] the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"salaAliymu","text_ar":"سَلَالِيمُ"},{"kind":"text","text":"is added by poetic license. (M, TA.) [Hence,]"},{"kind":"arabic","text_bw":"Als~ul~amu","text_ar":"السُّلَّمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Certain stars, below"},{"kind":"text","text":"["},{"kind":"italic_en","text":"those called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AlEaAnapu","text_ar":"العَانَةُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"on the right of them;"},{"kind":"text","text":"(K;) as being likened to the"},{"kind":"arabic","text_bw":"sul~am","text_ar":"سُلَّم"},{"kind":"text","text":"[above-mentioned]. (TA.) ―         -b2-  And The"},{"kind":"arabic","text_bw":"garoz","text_ar":"غَرْز"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stirrup of the camel's saddle"},{"kind":"text","text":"] (S, K) is sometimes thus called [as being a means of mounting]. (S.) ―         -b3-  And (tropical:)"},{"kind":"italic_en","text":"A means to a thing;"},{"kind":"text","text":"(K, TA;) because it leads to another thing like as does the"},{"kind":"arabic","text_bw":"sul~am","text_ar":"سُلَّم"},{"kind":"text","text":"upon which one ascends. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Als~ul~amu","text_ar":"السُّلَّمُ"},{"kind":"text","text":"is the name of"},{"kind":"italic_en","text":"The horse of Zebbán"},{"kind":"text","text":"(in the CK"},{"kind":"italic_en","text":"Zeiyán"},{"kind":"text","text":")"},{"kind":"italic_en","text":"Ibn-Seiyár."},{"kind":"text","text":"(K.)"}],"source_refs":["M","K","Msb","Mgh","TA","S"]}]}}