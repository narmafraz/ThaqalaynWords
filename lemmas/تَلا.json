{"lemma":"تَلا","slug":"تَلا","root":"ت.ل.#","root_slug":"ت-ل-_","root_link":"/words/roots/ت-ل-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"تَلَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"تَلَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"تَلَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"تَلَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"تَلَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"تَلا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"تَلَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"تَلَوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"تَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"تَلَوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"تَلَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَتْل","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَتْلُو","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُتْلَى","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَتْلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَتْلِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَتْلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَتْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُتْلَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُتْلَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَتْلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتْلُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتْلُوْنَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُتْلَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتْل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَتْلُو","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُتْلَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتْل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَتْلُو","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُتْلَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتْلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُتْلَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُتْلَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتْلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتْلَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتْلَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتْلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتْلُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتْلُوْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُتْلَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتْل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتْل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَلَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَلَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتْلُو","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتْلُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُتْلَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُتْلَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":27,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n4056","n4062"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%84%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to follow, walk behind another"},{"pos":"verb","gloss":"to abandon, to leave someone in the lurch"},{"pos":"verb","gloss":"to despise"},{"pos":"verb","gloss":"to read"},{"pos":"verb","gloss":"to recite"},{"pos":"verb","gloss":"to meditate"}]},"etymology":null,"ipa":["/ta.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4056","headword_ar":"تَلَا","root":"tlw","body":[{"kind":"italic_en","text":"He followed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walked, behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after."},{"kind":"text","text":"(IAar, T.) You say,"},{"kind":"arabic","text_bw":"talawotuhu","text_ar":"تَلَوْتُهُ"},{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tuluw~N","text_ar":"تُلُوٌّ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"talowN","text_ar":"تَلْوٌ"},{"kind":"text","text":", (Er-Rághib, MF,)"},{"kind":"italic_en","text":"I followed him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walked, behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(S, M, Msb, K;) namely, a man [&c.]; (S, Msb;)"},{"kind":"italic_en","text":"immediately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without intervention;"},{"kind":"text","text":"and sometimes it means"},{"kind":"italic_en","text":"bodily"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"in reality"},{"kind":"text","text":"]; and sometimes,"},{"kind":"italic_en","text":"virtually,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in effect:"},{"kind":"text","text":"(Er-Rághib:) and so"},{"kind":"arabic","text_bw":"talayotuhu","text_ar":"تَلَيْتُهُ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"tal~ayotuhu","text_ar":"تَلَّيْتُهُ","orth_type":"arrow"},{"kind":"text","text":", (As, * T, * K,) inf. n."},{"kind":"arabic","text_bw":"tatoliyapN","text_ar":"تَتْلِيَةٌ"},{"kind":"text","text":". (K.) The phrase, in the Kur xci. 2,"},{"kind":"arabic","text_bw":"waAlqamari A_i*aA talaAhaA","text_ar":"وَالقَمَرِ اـِذَا تَلَاهَا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"By the moon when its rising follows the rising thereof;"},{"kind":"text","text":"i. e., the rising of the sun; at the beginning of the lunar month: (Bd:) or,"},{"kind":"italic_en","text":"when it follows in rising the setting thereof,"},{"kind":"text","text":"(Bd, Jel,) on the night of the full moon: (Bd:) or,"},{"kind":"italic_en","text":"when it follows it in becoming round, and in fullness of light;"},{"kind":"text","text":"(M, * Bd;) i. e.,"},{"kind":"italic_en","text":"when it follows it in the way of imitation, and in respect of rank;"},{"kind":"text","text":"for the moon borrows its light of the sun, and is to it in the place of a successor. (Er-Rághib.) Here, Ks pronounced"},{"kind":"arabic","text_bw":"tlAhA","text_ar":"تلاها"},{"kind":"text","text":"with imáleh, [either because"},{"kind":"arabic","text_bw":"talayotu","text_ar":"تَلَيْتُ"},{"kind":"text","text":"is a dial. var. of"},{"kind":"arabic","text_bw":"talawotu","text_ar":"تَلَوْتُ"},{"kind":"text","text":", or] because, although it has"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"for its last radical letter, it occurs with words that may be so pronounced, namely,"},{"kind":"arabic","text_bw":"yago$aAhaA","text_ar":"يَغْشَاهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"banaAhaA","text_ar":"بَنَاهَا"},{"kind":"text","text":". (M.) ―         -b2-"},{"kind":"arabic","text_bw":"talawotu AlA^ibila","text_ar":"تَلَوْتُ الاِبِلَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I drove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gathered, the camels together, from their several quarters:"},{"kind":"text","text":"because the driver follows the driven. (A, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"yatoluw fulaAnFA","text_ar":"يَتْلُو فُلَانًا"},{"kind":"italic_en","text":"He imitates such a one, and follows what he does; he follows him in action."},{"kind":"text","text":"(T.) ―         -b4-"},{"kind":"arabic","text_bw":"talaA","text_ar":"تَلَا"},{"kind":"text","text":", (T,) first pers."},{"kind":"arabic","text_bw":"talawotu","text_ar":"تَلَوْتُ"},{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (T,) inf. n."},{"kind":"arabic","text_bw":"tilaAwapN","text_ar":"تِلَاوَةٌ"},{"kind":"text","text":", (T, S, M, Msb, K,)"},{"kind":"italic_en","text":"He read,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he recited,"},{"kind":"text","text":"(T, M, K,) the Kur-án, (S, M, Msb, K,) or any discourse, or piece of language: (M, K:) or"},{"kind":"italic_en","text":"he followed"},{"kind":"text","text":"it, (I'Ab, T, S, * M,)"},{"kind":"italic_en","text":"and did according to it;"},{"kind":"text","text":"(I'Ab, Mujáhid, T;) namely, the Scripture: (I'Ab, Mujáhid, T, M:) or the inf. n. specially signifies the"},{"kind":"italic_en","text":"following"},{"kind":"text","text":"God's revealed Scriptures, sometimes"},{"kind":"italic_en","text":"by reading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perusing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reciting,"},{"kind":"text","text":"and sometimes"},{"kind":"italic_en","text":"by conforming therewith"},{"kind":"text","text":"[as well as by reading, &c., but not otherwise, for] every"},{"kind":"arabic","text_bw":"tilaAwap","text_ar":"تِلَاوَة"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"qiraA='ap","text_ar":"قِرَا=ءَة"},{"kind":"text","text":", but the reverse is not the case. (Er-Rághib, TA.) [You say also,"},{"kind":"arabic","text_bw":"talaA Ealayohi","text_ar":"تَلَا عَلَيْهِ"},{"kind":"italic_en","text":"He recited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"related, to him"},{"kind":"text","text":"a narrative &c.: see Kur v. 30, &c.] And"},{"kind":"arabic","text_bw":"fulaAnN yatoluw EalaY fulaAnK","text_ar":"فُلَانٌ يَتْلُو عَلَى فُلَانٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"yaquwlu Ealayohi","text_ar":"يَقُولُ عَلَيْهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a one lies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"says what is false, against such a one."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"waA@t~abaEuwA maA tatoluwAl$~ayaATiynu","text_ar":"وَا@تَّبَعُوا مَا تَتْلُوالشَّيَاطِينُ"},{"kind":"text","text":", in the Kur ii. 96, means ["},{"kind":"italic_en","text":"And they followed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what the devils related,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rehearsed,"},{"kind":"text","text":"('Atà, T,) or"},{"kind":"italic_en","text":"spoke;"},{"kind":"text","text":"(A'Obeyd, T;) or,"},{"kind":"italic_en","text":"what the devils"},{"kind":"text","text":"of the Jinn, or of mankind, or of both,"},{"kind":"italic_en","text":"read,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recited,"},{"kind":"text","text":"or what they"},{"kind":"italic_en","text":"followed,"},{"kind":"text","text":"of the writings of enchantment: (Bd:) some here read ↓"},{"kind":"arabic","text_bw":"tutal~iY","text_ar":"تُتَلِّى","orth_type":"arrow"},{"kind":"text","text":". (T.) Hence the saying,"},{"kind":"arabic","text_bw":"laA darayota walaA talayota","text_ar":"لَا دَرَيْتَ وَلَا تَلَيْتَ"},{"kind":"text","text":": (T:) or, accord. to Yoo, it is ↓"},{"kind":"arabic","text_bw":"wlA A^atolayota","text_ar":"ولا اَتْلَيْتَ","orth_type":"arrow"},{"kind":"text","text":": (T, S:) and others say that it is"},{"kind":"arabic","text_bw":"wlA A@y^otalayota","text_ar":"ولا ا@يْتَلَيْتَ"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"A^alawotu","text_ar":"اَلَوْتُ"},{"kind":"text","text":". (T. [See these three readings explained in the latter part of the first paragraph of art."},{"kind":"arabic","text_bw":"Alw","text_ar":"الو"},{"kind":"text","text":".])       -A2-"},{"kind":"italic_en","text":"He remained behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back."},{"kind":"text","text":"(IAar, ISk, T.) You say,"},{"kind":"arabic","text_bw":"talaA baEoda qawomihi","text_ar":"تَلَا بَعْدَ قَوْمِهِ"},{"kind":"italic_en","text":"He held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lagged behind, after his people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company, and remained."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"talawotuhu","text_ar":"تَلَوْتُهُ"},{"kind":"text","text":", (AZ, A'Obeyd, T, S, M, K,) and"},{"kind":"arabic","text_bw":"talawotu","text_ar":"تَلَوْتُ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", (AZ, T, M, K,) aor."},{"kind":"text","text":", (AZ, T,) inf. n."},{"kind":"arabic","text_bw":"tuluw~N","text_ar":"تُلُوٌّ"},{"kind":"text","text":", (AZ, T, M,)"},{"kind":"italic_en","text":"I left him, and held back from going with him:"},{"kind":"text","text":"(AZ, T:)"},{"kind":"italic_en","text":"I held back from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from aiding him, and left him:"},{"kind":"text","text":"(AZ, A'Obeyd, T, S, M, K:) thus the verb bears two contr. significations. (K.)       -A3-"},{"kind":"italic_en","text":"He bought a"},{"kind":"arabic","text_bw":"tilow","text_ar":"تِلْو"},{"kind":"text","text":", meaning the"},{"kind":"italic_en","text":"young one of a mule."},{"kind":"text","text":"(IAar, T, K.)       -A4-"},{"kind":"arabic","text_bw":"taliyato","text_ar":"تَلِيَتْ"},{"kind":"arabic","text_bw":"liY mino Haq~iY taliy~apN","text_ar":"لِى مِنْ حَقِّى تَلِيَّةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"tulaAwapN","text_ar":"تُلَاوَةٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (ISk, S,) inf. n."},{"kind":"arabic","text_bw":"talFA","text_ar":"تَلًا"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"There remained to me, of my right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, a remainder."},{"kind":"text","text":"(ISk, S.) And"},{"kind":"arabic","text_bw":"taliyato","text_ar":"تَلِيَتْ"},{"kind":"arabic","text_bw":"liY Einodahu taliy~apN","text_ar":"لِى عِنْدَهُ تَلِيَّةٌ"},{"kind":"italic_en","text":"There remained to me, with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"there remained owing to me by him, a remainder."},{"kind":"text","text":"(As, T.) And"},{"kind":"arabic","text_bw":"taliYa mina Al$~ahori ka*aA","text_ar":"تَلِىَ مِنَ الشَّهْرِ كَذَا"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"talFA","text_ar":"تَلًا"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"There remained, of the month, such a portion."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","M","Msb","K","Bd","Jel","T","AZ","ISk","TA"]},{"entry_id":"n4062","headword_ar":"تَلًا","root":"tlw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"taliy~apN","text_ar":"تَلِيَّةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}