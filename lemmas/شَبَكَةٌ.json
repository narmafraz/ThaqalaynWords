{"lemma":"شَبَكَةٌ","slug":"شَبَكَةٌ","root":"ش.ب.ك","root_slug":"ش-ب-ك","root_link":"/words/roots/ش-ب-ك","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n21609"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%A8%D9%8E%D9%83%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"net, fishing net"},{"pos":"noun","gloss":"network"},{"pos":"noun","gloss":"grid"},{"pos":"noun","gloss":"knit veil"},{"pos":"noun","gloss":"trellis, trelliswork"},{"pos":"noun","gloss":"noose"},{"pos":"noun","gloss":"complication, intricacy, confusion"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew שְׂבָכָה (səḇāḵā), Classical Syriac ܣܒܟܐ."},"ipa":["/ʃa.ba.ka/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21609","headword_ar":"شَبَكَةٌ","root":"$bk","body":[{"kind":"text","text":"The"},{"kind":"arabic","text_bw":"$arakap","text_ar":"شَرَكَة"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"net"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"Say~aAd","text_ar":"صَيَّاد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"fisherman,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"fowler"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sportsman"},{"kind":"text","text":"]; (K;) the"},{"kind":"arabic","text_bw":"miSoyadap","text_ar":"مِصْيَدَة"},{"kind":"text","text":", (Lth, O, TA,) or"},{"kind":"italic_en","text":"instrument of"},{"kind":"arabic","text_bw":"AlS~ayod","text_ar":"الصَّيْد"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"that is used in the water"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"for catching fish"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"on the land"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"for catching fowls"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wild animals"},{"kind":"text","text":"]; (Lth, O, * TA;) applied by some peculiarly to the"},{"kind":"arabic","text_bw":"miSoyadap","text_ar":"مِصْيَدَة"},{"kind":"italic_en","text":"of the water;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"$ub~aAkN","text_ar":"شُبَّاكٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) pl. of the former"},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"$abakaAtN","text_ar":"شَبَكَاتٌ"},{"kind":"text","text":"(Msb) and [coll. gen. n.] ↓"},{"kind":"arabic","text_bw":"$abakN","text_ar":"شَبَكٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb, K:) and the pl. of ↓"},{"kind":"arabic","text_bw":"$ub~aAkN","text_ar":"شُبَّاكٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"$abaAbiyku","text_ar":"شَبَابِيكُ"},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"italic_en","text":"A certain thing for the head;"},{"kind":"text","text":"(Lth, O;) ["},{"kind":"italic_en","text":"a small net, for the head, a veil of net-work, in order that the face may not be known."},{"kind":"text","text":"(Golius, on the authority of Meyd.)]       -A2-  Also"},{"kind":"italic_en","text":"Wells near together,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"of which the water is near"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the mouths"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"communicating"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"by filtration"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one with another:"},{"kind":"text","text":"so accord. to El-Kutabee: (TA:) or"},{"kind":"italic_en","text":"wells separate, one from another:"},{"kind":"text","text":"(M and L in art."},{"kind":"arabic","text_bw":"mA^d","text_ar":"ماد"},{"kind":"text","text":":) and, (K,) or as some say, (TA,)"},{"kind":"italic_en","text":"wells"},{"kind":"text","text":"(O, K, TA)"},{"kind":"italic_en","text":"that are open to view,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"dug in a rugged place, of the depth of the stature of a man,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"twice"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"thrice that measure, in which the rain-water becomes retained:"},{"kind":"text","text":"so called because of their mutual proximity, and confusedness: a single one of them is not called"},{"kind":"arabic","text_bw":"$abakapN","text_ar":"شَبَكَةٌ"},{"kind":"text","text":"; for this is only a name for a plural number; but the pl."},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":"is applied to"},{"kind":"italic_en","text":"aggregates thereof in sundry places:"},{"kind":"text","text":"(O, TA:) or"},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"$abakapN","text_ar":"شَبَكَةٌ"},{"kind":"text","text":", (Msb,) signifies"},{"kind":"italic_en","text":"wells that are numerous and near together in a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tract of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"land;"},{"kind":"text","text":"(S, Msb;) form"},{"kind":"arabic","text_bw":"Ai$otibaAku","text_ar":"اِشْتِبَاكُ"},{"kind":"arabic","text_bw":"Aln~ujuwmi","text_ar":"النُّجُومِ"},{"kind":"text","text":": (Msb:) or, accord. to As,"},{"kind":"arabic","text_bw":"$abakapN","text_ar":"شَبَكَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"wells,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other pits"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hollows dug in the ground, that are numerous;"},{"kind":"text","text":"and the pl. is"},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":". (IDrd, O.) ―         -b2-  And"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tract of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"land in which are many wells,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"not tracts that exude water and produce salt, nor such as give growth to plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"(TA:) or [the pl.]"},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"places,"},{"kind":"text","text":"of the earth,"},{"kind":"italic_en","text":"that are not such as exude water and produce salt, nor such as give growth to plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage; such as the"},{"kind":"arabic","text_bw":"$ibaAk","text_ar":"شِبَاك"},{"kind":"italic_en","text":"of El-Basrah."},{"kind":"text","text":"(Lth, O.) ―         -b3-  And The"},{"kind":"italic_en","text":"burrow"},{"kind":"text","text":"of the [field-rat called]"},{"kind":"arabic","text_bw":"jura*","text_ar":"جُرَذ"},{"kind":"text","text":": (K, TA:) or the"},{"kind":"italic_en","text":"burrows"},{"kind":"text","text":"thereof, which are near together: pl."},{"kind":"arabic","text_bw":"$ibaAkN","text_ar":"شِبَاكٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["Lth","O","TA","S","K","Msb"]}]},"classical_definitions":null}