ies":[{"entry_id":"n21670","headword_ar":"شَتِرَ","root":"$tr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"$atarN","text_ar":"شَتَرٌ"},{"kind":"text","text":"; (T, S, A, Msb, K, &c.;) and"},{"kind":"arabic","text_bw":"$utira","text_ar":"شُتِرَ"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a"},{"kind":"page_break","n":1503},{"kind":"text","text":"man)"},{"kind":"italic_en","text":"had an inversion in the eyelid;"},{"kind":"text","text":"(T, S;)"},{"kind":"italic_en","text":"seldom natural:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"an inversion of,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"the lower eyelid:"},{"kind":"text","text":"(A, Mgh, Msb:) or"},{"kind":"italic_en","text":"an inversion of the eyelid above and below,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"above"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"below,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"and a contraction thereof:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"a cracking thereof,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so that the edge"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"AlxitaAr","text_ar":"الخِتَار"},{"kind":"text","text":", in the TA, I read"},{"kind":"arabic","text_bw":"AlHitaAr","text_ar":"الحِتَار"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"became separate:"},{"kind":"text","text":"(Mgh, TA:) or"},{"kind":"italic_en","text":"a flaccidity of its lower part."},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"$atirati AlEayonu","text_ar":"شَتِرَتِ العَيْنُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$utirat","text_ar":"شُتِرَت"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"An$trt","text_ar":"انشترت","orth_type":"arrow"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"The eye had an inversion in the lid:"},{"kind":"text","text":"(S:) [or"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of, the lower lid:"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"an inversion of the lid above and below,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and a contraction thereof:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a cracking thereof,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so that the edge became separate:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a flaccidity of its lower part."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$atira","text_ar":"شَتِرَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"$atarN","text_ar":"شَتَرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had his lower lip cracked."},{"kind":"text","text":"(K, * TA.)       -A2-"},{"kind":"arabic","text_bw":"$atarahu","text_ar":"شَتَرَهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A$trhu","text_ar":"اشترهُ","orth_type":"arrow"},{"kind":"text","text":", (S,) or the latter but not the former, (Sh, TA,)"},{"kind":"italic_en","text":"He caused him to have an inversion in the eyelid."},{"kind":"text","text":"(S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"$atara AlEayona","text_ar":"شَتَرَ العَيْنَ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$atorN","text_ar":"شَتْرٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"A$trhA","text_ar":"اشترها","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"$t~rhA","text_ar":"شتّرها","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He caused the eye to have an inversion of the lid above and below,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and a contraction thereof:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a cracking thereof,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so that the edge became separate:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a flaccidity of its lower part."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"$atorN","text_ar":"شَتْرٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"cutting off of the lower eyelid:"},{"kind":"text","text":"for which a quarter of the whole price of blood must be paid. (TA.)       -A3-"},{"kind":"arabic","text_bw":"$atira bihi","text_ar":"شَتِرَ بِهِ"},{"kind":"italic_en","text":"He reviled him;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"found fault with him; blamed him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"censured him; in verse or in prose:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$t~r","text_ar":"شتّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ta$otiyrN","text_ar":"تَشْتِيرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he detracted from his reputation; found fault with him; blamed him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"censured him;"},{"kind":"text","text":"(S, TA;)"},{"kind":"italic_en","text":"made him to hear what was bad, evil, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul:"},{"kind":"text","text":"(TA:) Sh says that it is"},{"kind":"arabic","text_bw":"$n~r","text_ar":"شنّر"},{"kind":"text","text":", and he disallows ↓"},{"kind":"arabic","text_bw":"$t~r","text_ar":"شتّر","orth_type":"arrow"},{"kind":"text","text":": but IAar and AA say"},{"kind":"arabic","text_bw":"$t~r","text_ar":"شتّر"},{"kind":"text","text":"; and AM holds this to be correct. (TA.) [See also"},{"kind":"arabic","text_bw":"$*~r bh","text_ar":"شذّر به"},{"kind":"text","text":".]"}],"source_refs":["T","A","Msb","Mgh","M","K","TA","S","TK","Sh"]}]}}