cut off his tail:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amputated, his tail in any place."},{"kind":"text","text":"(M, L.) ―         -b3-"},{"kind":"arabic","text_bw":"batara raHimahu","text_ar":"بَتَرَ رَحِمَهُ"},{"kind":"text","text":", (M,) aor. as above, (M, K,) and so the inf. n., (M,) (assumed tropical:)"},{"kind":"italic_en","text":"He cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severed, the ties,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bonds, of his relationship; he disunited himself from his relations."},{"kind":"text","text":"(M, K. *)       -A2-"},{"kind":"arabic","text_bw":"batira","text_ar":"بَتِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"batarN","text_ar":"بَتَرٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(any beast, M)"},{"kind":"italic_en","text":"had his tail cut off:"},{"kind":"text","text":"(S, Msb, K:) or ["},{"kind":"italic_en","text":"had either the whole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of his tail cut off;] had his tail cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amputated, in any place."},{"kind":"text","text":"(M.)"}],"source_refs":["M","Mgh","Msb","S","A","L","K"]}]}}