},{"role":"present_2mp","form":"تَرْفُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْفُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْفُق","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْفُق","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْفُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْفُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْفُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْفُقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْفُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْفُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رَفَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَفَقْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْفُق","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْفُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":26,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["n16192"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be kind, to be nice, to be gentle"},{"pos":"verb","gloss":"to be a companion, to be a friend"},{"pos":"noun","gloss":"verbal noun of رَفَقَ (rafaqa, “to be kind, to be nice”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of رَفُقَ (rafuqa, “to be kind, to be nice”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of رَفِقَ (rafiqa, “to be kind, to be nice”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of رِفْقَة (rifqa)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of رُفْقَة (rufqa)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to strike (someone's) elbow"},{"pos":"verb","gloss":"to bind (a camel's) arm (to prevent it from moving quickly)"},{"pos":"verb","gloss":"to have one's elbow twisted or distorted (of a camel)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16192","headword_ar":"رَفَقَ","root":"rfq","body":[{"kind":"text","text":", (S, O, Mgh, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"rifoqN","text_ar":"رِفْقٌ"},{"kind":"text","text":"(S, * O, Mgh, * Msb, * K) and"},{"kind":"arabic","text_bw":"marofiqN","text_ar":"مَرْفِقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mirofaqN","text_ar":"مِرْفَقٌ"},{"kind":"text","text":"(AZ, O, K,) and"},{"kind":"arabic","text_bw":"marofaqN","text_ar":"مَرْفَقٌ"},{"kind":"text","text":"; (O, K;) and"},{"kind":"arabic","text_bw":"rafiqa","text_ar":"رَفِقَ"},{"kind":"text","text":", (JK, O, K,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"rafaqN","text_ar":"رَفَقٌ"},{"kind":"text","text":"; (JK;) and"},{"kind":"arabic","text_bw":"rafuqa","text_ar":"رَفُقَ"},{"kind":"text","text":"; (JK, O, K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gentle, soft, tender, gracious, courteous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"civil;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he be haved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acted, gently, softly,"},{"kind":"text","text":"&c. (JK, S, O, Mgh, Msb, K.) You say,"},{"kind":"arabic","text_bw":"rafaqa bihi","text_ar":"رَفَقَ بِهِ"},{"kind":"text","text":", (AZ, S, O, Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (AZ, O, K,) inf. ns. as above; (O, K;) and"},{"kind":"arabic","text_bw":"rafiqa","text_ar":"رَفِقَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rafuqa","text_ar":"رَفُقَ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gentle,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"he behaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acted, gently,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him,"},{"kind":"text","text":"(AZ, S, O, Mgh, Msb, K,) and"},{"kind":"italic_en","text":"to him;"},{"kind":"text","text":"(AZ, O, K;) and in like manner,"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"trf~q","text_ar":"ترفّق","orth_type":"arrow"},{"kind":"text","text":", (S, O, Mgh, K,) and ↓"},{"kind":"arabic","text_bw":"Arfqhu","text_ar":"ارفقهُ","orth_type":"arrow"},{"kind":"text","text":". (AZ, O, K.) Hence the saying of the Prophet,"},{"kind":"arabic","text_bw":"mano rafaqa biA^um~atiY rafaqa A@ll~`hu bihi","text_ar":"مَنْ رَفَقَ بِاُمَّتِى رَفَقَ ا@للّٰهُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who is gentle,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with my people, God will be gentle,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him"},{"kind":"text","text":"]. (O.) [Hence, also,] one says, ↓"},{"kind":"arabic","text_bw":"trf~q","text_ar":"ترفّق","orth_type":"arrow"},{"kind":"arabic","text_bw":"fiY A^amorihi","text_ar":"فِى اَمْرِهِ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"rafaqa fiyhi","text_ar":"رَفَقَ فِيهِ"},{"kind":"text","text":"as is indicated in the O]"},{"kind":"italic_en","text":"He used gentleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acted gently, in his affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taA^at~aY","text_ar":"تَاَتَّى"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"AtY","text_ar":"اتى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"liHaAjatihi","text_ar":"لِحَاجَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"trf~q","text_ar":"ترفّق","orth_type":"arrow"},{"kind":"italic_en","text":"He applied himself with gentleness to his needful affair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"business;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taA^at~aY","text_ar":"تَاَتَّى"},{"kind":"text","text":". (T in art."},{"kind":"arabic","text_bw":"AtY","text_ar":"اتى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"liloA^amori","text_ar":"لِلْاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"trf~q","text_ar":"ترفّق","orth_type":"arrow"},{"kind":"italic_en","text":"He applied himself with gentle ness to the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"talaT~afa","text_ar":"تَلَطَّفَ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"lTf","text_ar":"لطف"},{"kind":"text","text":".) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"rafuqa","text_ar":"رَفُقَ"},{"kind":"text","text":", in form like"},{"kind":"arabic","text_bw":"faruba","text_ar":"فَرُبَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gentle, delicate, nice, neat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful, in work"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"operation; the contr. of such as is termed"},{"kind":"arabic","text_bw":"A^axoraq","text_ar":"اَخْرَق"},{"kind":"text","text":". (Msb.) ―         -b3-  And"},{"kind":"arabic","text_bw":"rafaqotu AlEamala","text_ar":"رَفَقْتُ العَمَلَ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"I did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made, the deed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"work, soundly, thoroughly, skilfully, judiciously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"well."},{"kind":"text","text":"(Msb.) ―         -b4-  And"},{"kind":"arabic","text_bw":"rafaqotu fiY Als~ayori","text_ar":"رَفَقْتُ فِى السَّيْرِ"},{"kind":"italic_en","text":"I pro ceeded in a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a moderate, manner in journeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in pace."},{"kind":"text","text":"(Msb.)       -A2-  See also 4.       -A3-"},{"kind":"arabic","text_bw":"rafaAqapN","text_ar":"رَفَاقَةٌ"},{"kind":"text","text":"is an inf. n. signifying The"},{"kind":"italic_en","text":"being a"},{"kind":"arabic","text_bw":"rafayq","text_ar":"رَفَيق"},{"kind":"text","text":". (O, K.) Fr says, I heard a man at 'Arafát saying [to the pilgrims there assembled],"},{"kind":"arabic","text_bw":"jaEalakumu","text_ar":"جَعَلَكُمُ"},{"kind":"arabic","text_bw":"A@ll~`hN fiY rafaAqapi muHam~adK Sal~aY A@ll~`hu Ealayohi wasal~ama","text_ar":"ا@للّٰهٌ فِى رَفَاقَةِ مُحَمَّدٍ صَلَّى ا@للّٰهُ عَلَيْهِ وَسَلَّمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God make you to be in the companionship of Mohammad: may God bless and save him"},{"kind":"text","text":"]. (O.) [And accord. to the TK, one says,"},{"kind":"arabic","text_bw":"rafuqa bihi","text_ar":"رَفُقَ بِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rafaAqapN","text_ar":"رَفَاقَةٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He became a"},{"kind":"arabic","text_bw":"rafiyq","text_ar":"رَفِيق"},{"kind":"italic_en","text":"with him:"},{"kind":"text","text":"but what is commonly said in this sense is"},{"kind":"arabic","text_bw":"raAfqahu","text_ar":"رَافقَهُ"},{"kind":"text","text":", q. v.]       -A4-"},{"kind":"arabic","text_bw":"rafaqa fulaAnFA","text_ar":"رَفَقَ فُلَانًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"He struck the"},{"kind":"arabic","text_bw":"mirofaq","text_ar":"مِرْفَق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"elbow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of such a one."},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"rafaqa Aln~aAqapa","text_ar":"رَفَقَ النَّاقَةَ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rafoqN","text_ar":"رَفْقٌ"},{"kind":"text","text":", (S, O,)"},{"kind":"italic_en","text":"He bound the she-camel's arm"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"together with the shank"},{"kind":"text","text":"(for such is the common practice)], (S, O, K,)"},{"kind":"italic_en","text":"to prevent her going quickly,"},{"kind":"text","text":"(S, O,) when fearing her yearning towards, or longing for, her home, or accustomed place: (S, O, K:) [or]"},{"kind":"arabic","text_bw":"rafaqa AlbaEiyra","text_ar":"رَفَقَ البَعِيرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rafoqN","text_ar":"رَفْقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he bound the camel's neck"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eunuq","text_ar":"عُنُق"},{"kind":"text","text":"[probably, I think, a mistranscription for"},{"kind":"arabic","text_bw":"EaDud","text_ar":"عَضُد"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"arm,"},{"kind":"text","text":"])"},{"kind":"italic_en","text":"to his pastern,"},{"kind":"text","text":"because of a slight lameness therein. (JK.)       -A5-"},{"kind":"arabic","text_bw":"rafiqa","text_ar":"رَفِقَ"},{"kind":"text","text":"said of a camel, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rafaqN","text_ar":"رَفَقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He had his elbow dis torted from his side."},{"kind":"text","text":"(TA and TK. [See"},{"kind":"arabic","text_bw":"rafaqN","text_ar":"رَفَقٌ"},{"kind":"text","text":"below, and"},{"kind":"arabic","text_bw":"A^arofaqu","text_ar":"اَرْفَقُ"},{"kind":"text","text":": and see also"},{"kind":"arabic","text_bw":"dafiqa","text_ar":"دَفِقَ"},{"kind":"text","text":".]) ―         -b2-  [And"},{"kind":"arabic","text_bw":"rafiqato","text_ar":"رَفِقَتْ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rafaqN","text_ar":"رَفَقٌ"},{"kind":"text","text":", is probably said of a she-camel, as meaning"},{"kind":"italic_en","text":"She had, in her teat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"teats, what is termed"},{"kind":"arabic","text_bw":"rafaqN","text_ar":"رَفَقٌ"},{"kind":"text","text":": see, again, this word below.]"}],"source_refs":["S","O","Mgh","Msb","K","AZ","JK"]}]}}