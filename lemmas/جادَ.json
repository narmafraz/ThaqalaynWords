{"lemma":"جادَ","slug":"جادَ","root":"ج.#.د","root_slug":"ج-_-د","root_link":"/words/roots/ج-_-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جُدْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جُدْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جُدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جُدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جُدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جادَ","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جادَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جادا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جادَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جادُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جُدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجُد","in_corpus":true,"count":62,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَجُود","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجُودِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجُودِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجُودا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجُودانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجُودُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجُودُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجُدْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجُد","in_corpus":true,"count":163,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجُود","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجُد","in_corpus":true,"count":62,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجُود","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجُودُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجُودُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جُدْنا","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جُدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجُود","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجُود","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":307,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n5178","n5272","n5283","n6646"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"serious"},{"pos":"adj","gloss":"earnest"},{"pos":"verb","gloss":"to be or become good, excellent"},{"pos":"verb","gloss":"to be bountiful, generous, munificent"},{"pos":"verb","gloss":"to be or become copious, abundant"},{"pos":"verb","gloss":"to be fleet, swift, nimble (of a horse)"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of جَدَّ (jadda, “to be serious”).\n\nCompare جَيِّد (jayyid, “good, excellent”)."},"ipa":["/d͡ʒaː.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5178","headword_ar":"جَادٌّ","root":"jd","body":[{"kind":"text","text":"act. part. n. of"},{"kind":"arabic","text_bw":"jad~a","text_ar":"جَدَّ"},{"kind":"text","text":"; (Mgh, L;)"},{"kind":"italic_en","text":"Cutting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cutting off."},{"kind":"text","text":"(Mgh.)       -A2-"},{"kind":"arabic","text_bw":"A^ajaAd~u A^anota A^amo haAzilN","text_ar":"اَجَادُّ اَنْتَ اَمْ هَازِلٌ"},{"kind":"italic_en","text":"Art thou serious or jesting?"},{"kind":"text","text":"(A.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA yaA^oxu*an~a A^aHadukumo mataAEa A^axiyhi laAEibFA jaAd~FA","text_ar":"لَا يَاْخُذَنَّ اَحَدُكُمْ مَتَاعَ اَخِيهِ لَاعِبًا جَادًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By no means shall any one of you take the property of his brother in play"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in earnest"},{"kind":"text","text":"]; by which is meant taking a thing without meaning to steal it, but meaning to vex and anger the owner, so that the taker is in play with respect to theft, but in earnest in annoying. (TA in art."},{"kind":"arabic","text_bw":"lEb","text_ar":"لعب"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"fulaAnN jaAd~N","text_ar":"فُلَانٌ جَادٌّ"},{"kind":"italic_en","text":"Such a one is striving, labouring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toiling; exerting himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability;"},{"kind":"text","text":"&c. (TA.) And ↓"},{"kind":"arabic","text_bw":"fulaAnN jaAd~N mujid~N","text_ar":"فُلَانٌ جَادٌّ مُجِدٌّ","orth_type":"arrow"},{"kind":"text","text":", thus with the two similar words together, (As, S, L,) signifies the same [in an intensive degree]. (L, TA.)       -A3-"},{"kind":"arabic","text_bw":"jaAd~u miAy^api wasoqK","text_ar":"جَادُّ مِايَةِ وَسْقٍ"},{"kind":"text","text":"Land, or palm-trees,"},{"kind":"italic_en","text":"of which the produce, cut therefrom, is a hundred camel-loads:"},{"kind":"arabic","text_bw":"jaAd~N","text_ar":"جَادٌّ"},{"kind":"text","text":"being here used in the sense of ↓"},{"kind":"arabic","text_bw":"majoduwdN","text_ar":"مَجْدُودٌ","orth_type":"arrow"},{"kind":"text","text":". (L.) It is said in a trad. of Aboo-Bekr,"},{"kind":"arabic","text_bw":"Ei$oriyna wasoqFA","text_ar":"عِشْرِينَ وَسْقًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nahala EaAy^i$apa jidaAda","text_ar":"نَهَلَ عَايِشَةَ جِدَادَ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He gave to 'Áïsheh palm-trees of which the quantity of the dates cut therefrom was a hundred camel-loads;"},{"kind":"text","text":"but the phrase heard from the Arabs is"},{"kind":"arabic","text_bw":"jaAd~a Ei$oriyna","text_ar":"جَادَّ عِشْرِينَ"},{"kind":"text","text":": the former is like the saying"},{"kind":"arabic","text_bw":"h`*ihi","text_ar":"هٰذِهِ"},{"kind":"arabic","text_bw":"Ald~araAhimu Darobu AlA^amiyri","text_ar":"الدَّرَاهِمُ ضَرْبُ الاَمِيرِ"},{"kind":"text","text":"; and the latter, like"},{"kind":"arabic","text_bw":"Eiy$apN","text_ar":"عِيشَةٌ"},{"kind":"arabic","text_bw":"raADiyapN","text_ar":"رَاضِيَةٌ"},{"kind":"text","text":". (Mgh.)"}],"source_refs":["As","S","L"]},{"entry_id":"n5272","headword_ar":"جَادٍ","root":"jdw","body":[{"kind":"italic_en","text":"Asking, seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"a bounty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"gift:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"judaApN","text_ar":"جُدَاةٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K"]},{"entry_id":"n5283","headword_ar":"جَادٍ","root":"jdY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"locust;"},{"kind":"text","text":"because it eats ("},{"kind":"arabic","text_bw":"yajodiY","text_ar":"يَجْدِى"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"yaA^okulu","text_ar":"يَاْكُلُ"},{"kind":"text","text":") everything: but the appellation [more] commonly known is"},{"kind":"arabic","text_bw":"jaAbiy^u","text_ar":"جَابِيُ"},{"kind":"text","text":". (TA.)"},{"kind":"page_break","n":394}],"source_refs":[]},{"entry_id":"n6646","headword_ar":"جَادَ","root":"jwd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajuwdu","text_ar":"يَجُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"juwdapN","text_ar":"جُودَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jawodapN","text_ar":"جَوْدَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, or a commodity, an article of household-goods, or the like, Msb, and a work, or performance, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"jay~id","text_ar":"جَيِّد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"good, goodly, approvable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent;"},{"kind":"text","text":"the verb being the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"raduw^a","text_ar":"رَدُوَ"},{"kind":"text","text":", as is implied in the A and K]: (S, A, Msb, K:) in this sense, accord. to some, of the class of"},{"kind":"arabic","text_bw":"qaAla","text_ar":"قَالَ"},{"kind":"text","text":"; accord. to others, of the class of"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":". (Msb.) [Also said of a man, meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, excellent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"egregious,"},{"kind":"text","text":"in some quality; sometimes, though very rarely, in a quality that is disapproved.] ―         -b2-  And"},{"kind":"arabic","text_bw":"jAd","text_ar":"جاد"},{"kind":"text","text":", (S, A, Msb, K,) of the class of"},{"kind":"arabic","text_bw":"qAl","text_ar":"قال"},{"kind":"text","text":", (Msb,) aor. as above, (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"juwdN","text_ar":"جُودٌ"},{"kind":"text","text":", (S, A, Msb, K,) with damm, (S, Msb,)"},{"kind":"italic_en","text":"He was liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself, to be generous:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he gave without being asked, to preserve the receiver from the ignominy of asking:"},{"kind":"text","text":"(MF:) or"},{"kind":"italic_en","text":"he gave what was meet to him to whom it was meet:"},{"kind":"text","text":"(El-Karmánee, TA:) or"},{"kind":"italic_en","text":"he gave what was meet to him to whom it was meet, not for a compensation;"},{"kind":"text","text":"so that it has a more special signification than"},{"kind":"arabic","text_bw":"A^aHosana","text_ar":"اَحْسَنَ"},{"kind":"text","text":". (MF.) You say,"},{"kind":"arabic","text_bw":"jAd bimaAlihi","text_ar":"جاد بِمَالِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was liberal,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with his property"},{"kind":"text","text":"]: (S:) or"},{"kind":"arabic","text_bw":"jAd biAlmaAli","text_ar":"جاد بِالمَالِ"},{"kind":"italic_en","text":"he affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself, to be generous with the property."},{"kind":"text","text":"(Msb.) ―         -b3-  Hence, (Msb,)"},{"kind":"arabic","text_bw":"jAd binafosihi","text_ar":"جاد بِنَفْسِهِ"},{"kind":"text","text":", (S, Msb, K,) aor. as above, (S, A,) inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"juw^uwdN","text_ar":"جُوُودٌ"},{"kind":"text","text":", (S, TA,) (tropical:)"},{"kind":"italic_en","text":"He gave up his spirit,"},{"kind":"text","text":"(A, Msb, TA,) at death; (S, Msb;) like as one gives away his property; said of one in the agony of death: (TA:) and (tropical:)"},{"kind":"italic_en","text":"he gave away his life,"},{"kind":"text","text":"in war. (Msb.) And you say also,"},{"kind":"arabic","text_bw":"jaAdato nafosuhu","text_ar":"جَادَتْ نَفْسُهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirit, resigned itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"jAd AlmaTaru","text_ar":"جاد المَطَرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The rain was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"jaAdati Als~amaA='u","text_ar":"جَادَتِ السَّمَا=ءُ"},{"kind":"text","text":", (A, Msb,) inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":", with fet-h,"},{"kind":"italic_en","text":"The sky rained."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jaAdati","text_ar":"جَادَتِ"},{"kind":"arabic","text_bw":"AlEayonu","text_ar":"العَيْنُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"juw^uwdN","text_ar":"جُوُودٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The eye shed many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant, tears."},{"kind":"text","text":"(Lh, K.) ―         -b5-"},{"kind":"arabic","text_bw":"jAd","text_ar":"جاد"},{"kind":"text","text":"said of a horse, (S, A, L, Msb, K,) aor. as above, (S,) inf. n."},{"kind":"arabic","text_bw":"juwdapN","text_ar":"جُودَةٌ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"jawodapN","text_ar":"جَوْدَةٌ"},{"kind":"text","text":"; (Msb, and some copies of the K;) and ↓"},{"kind":"arabic","text_bw":"jwd","text_ar":"جود","orth_type":"arrow"},{"kind":"text","text":", (A, L, K,) inf. n."},{"kind":"arabic","text_bw":"tajowiydN","text_ar":"تَجْوِيدٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AjAd","text_ar":"اجاد","orth_type":"arrow"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"A^ajowada","text_ar":"اَجْوَدَ","orth_type":"arrow"},{"kind":"text","text":"; (L, K;)"},{"kind":"italic_en","text":"He became fleet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, and excellent,"},{"kind":"text","text":"(L,)"},{"kind":"arabic","text_bw":"SaAra raAy^iEFA","text_ar":"صَارَ رَايِعًا"},{"kind":"text","text":", (S, L, K, *)"},{"kind":"arabic","text_bw":"fiY Eadowihi","text_ar":"فِى عَدْوِهِ"},{"kind":"italic_en","text":"in his running."},{"kind":"text","text":"(A, L, K.) [See an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"dwm","text_ar":"دوم"},{"kind":"text","text":".] ―         -b6-  See also 4, in two places. ―         -b7-"},{"kind":"arabic","text_bw":"jAd","text_ar":"جاد"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"italic_en","text":"He inclined to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"jAdhu","text_ar":"جادهُ"},{"kind":"italic_en","text":"He overcame him in liberality, bounty, munificence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generosity."},{"kind":"text","text":"(K.) See 3. ―         -b2-"},{"kind":"arabic","text_bw":"jaAdahumo","text_ar":"جَادَهُمْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajuwdu","text_ar":"يَجُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(rain)"},{"kind":"italic_en","text":"rained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"descended, upon them copiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundantly."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"jiyduwA","text_ar":"جِيدُوا"},{"kind":"italic_en","text":"They were rained upon with a copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abundant, rain."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"jiydati AlA^aroDu","text_ar":"جِيدَتِ الاَرْضُ"},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"jawodN","text_ar":"جَوْدٌ"},{"kind":"text","text":"; (As, TA;) and ↓"},{"kind":"arabic","text_bw":"A^ujiydat","text_ar":"اُجِيدَت","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"The earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land, was rained upon with a copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abundant, rain:"},{"kind":"text","text":"(S, L, K:) or,"},{"kind":"italic_en","text":"so that the moisture of the rain met that of the soil."},{"kind":"text","text":"(As, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"jiyda","text_ar":"جِيدَ"},{"kind":"text","text":", (S, A, K,) aor."},{"kind":"arabic","text_bw":"yujaAdu","text_ar":"يُجَادُ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"juwaAdN","text_ar":"جُوَادٌ"},{"kind":"text","text":", (S, * K, * TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, A)"},{"kind":"italic_en","text":"thirsted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became affected by thirst:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"thirsted vehemently:"},{"kind":"text","text":"(accord. to an explanation of"},{"kind":"arabic","text_bw":"juwaAdN","text_ar":"جُوَادٌ"},{"kind":"text","text":"in the K:) or"},{"kind":"italic_en","text":"was at the point of death,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destruction;"},{"kind":"text","text":"(K;) as though destruction rained upon him. (TA.) ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"A_in~iY A^ujaAdu A_ilaYliqaAy^ika","text_ar":"اـِنِّى اُجَادُ اـِلَىلِقَايِكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Verily I am affected with a longing desire to meet thee:"},{"kind":"text","text":"(A:) or"},{"kind":"arabic","text_bw":"A_in~iY laA^ujaAdu A_ilayoka","text_ar":"اـِنِّى لَاُجَادُ اـِلَيْكَ"},{"kind":"text","text":"(K, TA [in the CK, erroneously,"},{"kind":"arabic","text_bw":"laAajAdu","text_ar":"لَاَجادُ"},{"kind":"text","text":"] (tropical:)"},{"kind":"italic_en","text":"Verily I am affected with a longing desire for thee,"},{"kind":"text","text":"(K, TA,) i. e.,"},{"kind":"italic_en","text":"to meet thee,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and am impelled towards thee:"},{"kind":"text","text":"(K:) and"},{"kind":"arabic","text_bw":"yujaAduA_ilaY fulaAnapa","text_ar":"يُجَادُاـِلَى فُلَانَةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is affected with longing desire for such a female;"},{"kind":"text","text":"like as you say"},{"kind":"arabic","text_bw":"yaZomaA^u","text_ar":"يَظْمَاُ"},{"kind":"text","text":". (A.) One says also,"},{"kind":"arabic","text_bw":"jAdhu AlahawY","text_ar":"جادهُ الَهَوى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Love affected him with longing desire,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$aAqahu","text_ar":"شَاقَهُ"},{"kind":"text","text":", L, K, in the CK"},{"kind":"arabic","text_bw":"$Aq~ahu","text_ar":"شاقَّهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and overcame him."},{"kind":"text","text":"(K.) ―         -b5-  [Also, app.,"},{"kind":"arabic","text_bw":"jyda","text_ar":"جيدَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yujaAdu","text_ar":"يُجَادُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"juwaAdN","text_ar":"جُوَادٌ"},{"kind":"text","text":", (as in a sense explained above,) (assumed tropical:)"},{"kind":"italic_en","text":"He became affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overcome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressed,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"majuwdN","text_ar":"مَجُودٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"by drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slumber:"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"juwaAdN","text_ar":"جُوَادٌ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"nuEaAsN","text_ar":"نُعَاسٌ"},{"kind":"text","text":": (L, TA:) and you say,"},{"kind":"arabic","text_bw":"jAdhu Aln~uEaAsu","text_ar":"جادهُ النُّعَاسُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Drowsiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slumber, overcame him;"},{"kind":"text","text":"(L;) as though sleep rained upon him. (TA.)"}],"source_refs":["S","A","Msb","K","MF","TA","L"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AC%D8%A7%D8%AF/","headword_ar":"جَادّ","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=127740#cdd968","body_html":"جَادّ<br>من (ج د د) المجتهد المثابر والمبتعد عن الهزل."}]}}