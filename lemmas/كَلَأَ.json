{"lemma":"كَلَأَ","slug":"كَلَأَ","root":"ك.ل.#","root_slug":"ك-ل-_","root_link":"/words/roots/ك-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"كَلَأَ","root":"كلو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n37123","n37127","n43106"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D9%84%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to guard, to protect"},{"pos":"verb","gloss":"to be postponed, to be delayed, to be long","examples":[{"text":"كَلَأَ ٱلدَّيْنُ","english":"The paying of the debt was postponed."},{"text":"كَلَأَ عُمْرُهَا","english":"Her life came to an end."}]},{"pos":"verb","gloss":"to fix repeatedly one's look at","examples":[{"text":"كَلَأَ بَصَرَهُ فِي شَيْءٍ","english":"He repeatedly turned his eye to a thing."}]},{"pos":"verb","gloss":"to beat, to whip"}]},"etymology":null,"ipa":["/ka.la.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37123","headword_ar":"كلّا","root":"klA^","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takoliYo'N","text_ar":"تَكْلِىْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"takoliy^apN","text_ar":"تَكْلِيَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He brought a ship near to the bank of the river,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and moored it."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"kl~A^","text_ar":"كلّا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He retained, detained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confined,"},{"kind":"text","text":"a person: (K:) app. from the verb as used with reference to a ship; and therefore tropical. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"kl~A^","text_ar":"كلّا"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"takoliYo'N","text_ar":"تَكْلِىْءٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He came"},{"kind":"text","text":"to a place,"},{"kind":"italic_en","text":"and stopped"},{"kind":"text","text":"there. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"kl~A^","text_ar":"كلّا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takoliy^apN","text_ar":"تَكْلِيَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He came to a place sheltered from the wind."},{"kind":"text","text":"(S) ―         -b5-"},{"kind":"arabic","text_bw":"kl~A^","text_ar":"كلّا"},{"kind":"italic_en","text":"He came"},{"kind":"text","text":"to a person (K) on an affair. (TA.)       -A2-"},{"kind":"arabic","text_bw":"kl~A^ fiY A^amorK","text_ar":"كلّا فِى اَمْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He looked into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"considered attentively, a thing."},{"kind":"text","text":"(K.) See 4. ―         -b2-"},{"kind":"arabic","text_bw":"kl~A^fiyhi","text_ar":"كلّافِيهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He regarded him attentively, and was pleased with"},{"kind":"page_break","n":2624},{"kind":"italic_en","text":"him."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"kl~A^ fiY AlT~aEaAmi wagayorihi","text_ar":"كلّا فِى الطَّعَامِ وَغَيْرِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"takoliYo'N","text_ar":"تَكْلِىْءٌ"},{"kind":"text","text":"; (S, * TA;) and ↓"},{"kind":"arabic","text_bw":"AklA^","text_ar":"اكلا","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"A_ikolaA='N","text_ar":"اـِكْلَا=ءٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He paid in advance"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^asolama","text_ar":"اَسْلَمَ"},{"kind":"text","text":", K, and"},{"kind":"arabic","text_bw":"A^asolafa","text_ar":"اَسْلَفَ"},{"kind":"text","text":", S, K)"},{"kind":"italic_en","text":"for corn"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other food, &c."},{"kind":"text","text":"(S, K, TA.) [Here the original signification of postponement or delay is involved: for he who pays in advance for a thing grants a delay in the delivery thereof.] IAar cites the following verse:"},{"kind":"quote","text":"famano yuHosino A_ilayohimo laA yukal~iay^o\n                      \n                     \n                        A_ilaY jaAzK bi*aAka walaA kariymi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"So that he who does a good action to them does not pay in advance to one who will recompence for that"},{"kind":"text","text":"("},{"kind":"italic_en","text":"action"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"nor to him who is generous"},{"kind":"text","text":"]. (TA.) See 1 and 5."}],"source_refs":["K","TA","S"]},{"entry_id":"n37127","headword_ar":"كَلَاٌ","root":"klA^","body":[{"kind":"italic_en","text":"Fresh herbage;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Eu$obN","text_ar":"عُشْبٌ"},{"kind":"text","text":": (S, K:) applied to the"},{"kind":"arabic","text_bw":"Eurowap","text_ar":"عُرْوَة"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"nSiY~","text_ar":"نصِىّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Sil~iyaAn","text_ar":"صِلِّيَان"},{"kind":"text","text":": (Az:) or"},{"kind":"italic_en","text":"pasture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what cattle &c. feed upon:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"herbage. whether fresh"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dry"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"fresh pasture"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fodder:"},{"kind":"text","text":"(S, K:) or it comprises the"},{"kind":"arabic","text_bw":"Sil~ayaAn naSiY~","text_ar":"صِلَّيَان نَصِىّ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"Halamap","text_ar":"حَلَمَة"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"$iyH","text_ar":"شِيح"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"Earofaj","text_ar":"عَرْفَج"},{"kind":"text","text":","},{"kind":"italic_en","text":"the various kinds of"},{"kind":"arabic","text_bw":"Eurowap","text_ar":"عُرْوَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"and what are termed"},{"kind":"arabic","text_bw":"Eu$ob","text_ar":"عُشْب"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"baqol","text_ar":"بَقْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"and the like:"},{"kind":"text","text":"or it is"},{"kind":"italic_en","text":"applied to the herbs called"},{"kind":"arabic","text_bw":"bql","text_ar":"بقل"},{"kind":"text","text":","},{"kind":"italic_en","text":"and to trees:"},{"kind":"text","text":"a gen. n., having no sing.; or its sing. is"},{"kind":"arabic","text_bw":"kalaA='N","text_ar":"كَلَا=ءٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","Az","TA"]},{"entry_id":"n43106","headword_ar":"كَلَا","root":"klw","body":[{"kind":"text","text":", first pers."},{"kind":"arabic","text_bw":"kalaAtu","text_ar":"كَلَاتُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakoluw","text_ar":"يَكْلُو"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"kalaA","text_ar":"كَلَا"},{"kind":"text","text":", first pers."},{"kind":"arabic","text_bw":"kalayotu","text_ar":"كَلَيْتُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakolaA","text_ar":"يَكْلَا"},{"kind":"text","text":"; inf. n.,"},{"kind":"arabic","text_bw":"kilaAyapN","text_ar":"كِلَايَةٌ"},{"kind":"text","text":"; see"},{"kind":"arabic","text_bw":"kalaA^a","text_ar":"كَلَاَ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}