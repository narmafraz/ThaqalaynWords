{"lemma":"رَحَلَ","slug":"رَحَلَ","root":"ر.ح.ل","root_slug":"ر-ح-ل","root_link":"/words/roots/ر-ح-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"رَحَلْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"رَحَلْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"رَحَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"رَحَلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"رَحَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"رَحَلَ","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"رَحَلَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"رَحَلا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"رَحَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"رَحَلُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"رَحَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَرْحَل","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَرْحَلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَرْحَلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَرْحَلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَرْحَلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَرْحَلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْحَلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْحَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْحَل","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْحَل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْحَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْحَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْحَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْحَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْحَلُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْحَلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْحَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرْحَل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْحَل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَحَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَحَلْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":24,"cross_references":{"qac":{"found":true,"lemma_key":"رَحَلَ","root":"رحل","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n15052"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AD%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to saddle, to mount"},{"pos":"verb","gloss":"to set out"},{"pos":"verb","gloss":"to leave, depart","examples":[{"text":"ثُمَّ رَحَلْنَا وَنَزَلْنَا قَرْيَةً تُعْرَفُ بِالْمُوَيْلِحَةِ. ثُمَّ رَحَلْنَا مِنْهَا وَنَزَلْنَا جَزِيرَةَ ٱبْنِ عُمَرَ، وَهِيَ مَدِينَةٌ كَبِيرَةٌ حَسَنَةٌ، مُحِيطٌ بِهَا الْوَادِي، وَلِذٰلِكَ سُمِّيَتْ جَزِيرَةً، وَأَكْثَرُهَا خَرَابٌ.","english":"Journeying on, we halted at a village called al-Muwailiha, and from there alighted at Jazirat Ibn ‘Omar, a large and beautiful city surrounded by the river [Tigris], which is the reason why it is called Jazira [‘island’]. The greater part of it is in ruins."}]},{"pos":"verb","gloss":"to emigrate"},{"pos":"verb","gloss":"to die","tags":["euphemistic"]},{"pos":"verb","gloss":"to make depart; to send out, to dispatch, to urge"},{"pos":"verb","gloss":"to make depart; to transport, to deport, to relocate, to carry over"},{"pos":"verb","gloss":"to make depart; to carry over, to convey"},{"pos":"noun","gloss":"verbal noun of رَحَلَ (raḥala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"camel saddle"},{"pos":"noun","gloss":"saddlebags"},{"pos":"noun","gloss":"camel","tags":["metonymically"]},{"pos":"noun","gloss":"baggage, luggage"},{"pos":"noun","gloss":"stopping place","tags":["in-plural"]}]},"etymology":{"source":"wiktextract","text":"Form I verb from the root ر ح ل (r ḥ l).\n\nForm II verb from the root ر ح ل (r ḥ l)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15052","headword_ar":"رَحْلٌ","root":"rHl","body":[{"kind":"italic_en","text":"A saddle for a camel;"},{"kind":"text","text":"(S, * K;) as also ↓"},{"kind":"arabic","text_bw":"raAHuwlN","text_ar":"رَاحُولٌ","orth_type":"arrow"},{"kind":"text","text":"; (O, L, K;)"},{"kind":"italic_en","text":"for a he-camel and a she-camel;"},{"kind":"text","text":"(TA;) the"},{"kind":"italic_en","text":"thing for the camel that is like the"},{"kind":"arabic","text_bw":"saroj","text_ar":"سَرْج"},{"kind":"italic_en","text":"for the horse or similar beast;"},{"kind":"text","text":"(Mgh;) the"},{"kind":"italic_en","text":"thing that is put upon the camel for the purpose of riding thereon;"},{"kind":"text","text":"(Er-Rághib, TA;)"},{"kind":"italic_en","text":"smaller than the"},{"kind":"arabic","text_bw":"qatab","text_ar":"قَتَب"},{"kind":"text","text":"; (S, TA;)"},{"kind":"italic_en","text":"one of the vehicles of men, exclusively of women:"},{"kind":"text","text":"(TA:) [this seems to be regarded as the primary signification by the authors of the Mgh and the K and by Er-Rághib: but see what follows:] or it signifies the"},{"kind":"italic_en","text":"camel's saddle together with his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"girths called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabaD","text_ar":"رَبَض"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"Haqab","text_ar":"حَقَب"},{"kind":"italic_en","text":"and his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cloth called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hilos","text_ar":"حِلْس"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that is put beneath the saddle"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and all its other appertenances:"},{"kind":"text","text":"and is applied also to the"},{"kind":"italic_en","text":"pieces of wood of the"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"without any apparatus:"},{"kind":"text","text":"(AO, Sh, TA:) or it signifies"},{"kind":"italic_en","text":"anything,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"everything, that a man prepares for removing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeying; such as a bag,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receptacle, for goods"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utensils"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparatus, and a camel's saddle, and a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cloth such as is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Hilos","text_ar":"حِلْس"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that is put beneath the saddle"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and a"},{"kind":"arabic","text_bw":"rasan","text_ar":"رَسَن"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rope for leading his camel"},{"kind":"text","text":"]: (Msb:) or it signifies as first explained above, and also the"},{"kind":"italic_en","text":"goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utensils,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparatus, which a man takes with him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"during a journey"},{"kind":"text","text":"]: (S, K, TA:) [but accord. to the Msb, this signification is from another, mentioned below; and the same seems to be indicated in the S, which reverses the order in which I have mentioned the three significations that I quote from it:] this last signification is disapproved by El-Hareeree, in the “ Durrat el-Ghowwás: ” [but see two exs. voce"},{"kind":"arabic","text_bw":"Hu*aAfapN","text_ar":"حُذَافَةٌ"},{"kind":"text","text":":] the pl. is"},{"kind":"arabic","text_bw":"A^aroHulN","text_ar":"اَرْحُلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riHaAlN","text_ar":"رِحَالٌ"},{"kind":"text","text":"; (S, Mgh, Msb, K;) the former a pl. of pauc.; (S, TA;) the latter, of mult. (TA.) One says,"},{"kind":"arabic","text_bw":"HaT~a raHolahu","text_ar":"حَطَّ رَحْلَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aloqaY raHolahu","text_ar":"اَلْقَى رَحْلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He put down his camel's saddle"},{"kind":"text","text":"]; meaning"},{"kind":"italic_en","text":"he stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"h`*aA maHaT~u Alr~iHaAli","text_ar":"هٰذَا مَحَطُّ الرِّحَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is the place where the camels' saddles are put down"},{"kind":"text","text":"]. (TA.) And in reviling, one says,"},{"kind":"arabic","text_bw":"yaA A@bona muloqaYA^aroHuli Alr~ukobaAni","text_ar":"يَا ا@بْنَ مُلْقَىاَرْحُلِ الرُّكْبَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O son of the place in which are thrown down the camels' saddles of the riders;"},{"kind":"text","text":"as though the person thus addressed were there begotten]; (S, O, TA;) meaning"},{"kind":"page_break","n":1054},{"kind":"arabic","text_bw":"yaA A@bona AlfaAjirapi","text_ar":"يَا ا@بْنَ الفَاجِرَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O son of the adulteress"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornicatress"},{"kind":"text","text":"]: (TA in art."},{"kind":"arabic","text_bw":"lqY","text_ar":"لقى"},{"kind":"text","text":":) or"},{"kind":"arabic","text_bw":"huwa Abn mlqY ArHl","text_ar":"هُوَ ابن ملقى ارحل"},{"kind":"arabic","text_bw":"AlrkbAn","text_ar":"الركبان"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is the son"},{"kind":"text","text":"&c.]. (Msb.) ―         -b2-  Er-Rághib, after giving the explanation mentioned as on his authority above, says that it is then sometimes applied to The"},{"kind":"italic_en","text":"camel"},{"kind":"text","text":"[itself]: and is sometimes used in the sense next following; i. e. ―         -b3-"},{"kind":"italic_en","text":"A part, of a place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, upon which on sits:"},{"kind":"text","text":"(TA:) or a man's"},{"kind":"italic_en","text":"dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habitation;"},{"kind":"text","text":"(S, K, TA;) [in the first of which, this commences the art., app. showing that the author held this to be the primary signification;]) his"},{"kind":"italic_en","text":"house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent;"},{"kind":"text","text":"and his"},{"kind":"italic_en","text":"place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"a place to which a man betakes himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repairs, for lodging, covert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refuge; a"},{"kind":"text","text":"man's"},{"kind":"italic_en","text":"place of resort;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"italic_en","text":"in a region, district,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract, of cities, towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages, and of cultivated land:"},{"kind":"text","text":"and then applied to the"},{"kind":"italic_en","text":"goods, utensils,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparatus, of a traveller;"},{"kind":"text","text":"because they are, in travelling, the things to which he betakes himself: (Msb:) pl."},{"kind":"arabic","text_bw":"A^aroHulN","text_ar":"اَرْحُلٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"riHaAlN","text_ar":"رِحَالٌ"},{"kind":"text","text":"[as above]. (Mgh, TA.) One says,"},{"kind":"arabic","text_bw":"daxalotu EalaY Alr~ajuli raHolahu","text_ar":"دَخَلْتُ عَلَى الرَّجُلِ رَحْلَهُ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"I went in to the man in"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of abode."},{"kind":"text","text":"(TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A_i*aA A@botal~ati Aln~iEaAlu faSal~uwA","text_ar":"اـِذَا ا@بْتَلَّتِ النِّعَالُ فَصَلُّوا"},{"kind":"arabic","text_bw":"fiY Alr~iHaAli","text_ar":"فِى الرِّحَالِ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"fiYlS~alaApu fiY Alr~iHaAli","text_ar":"فِىلصَّلَاةُ فِى الرِّحَالِ"},{"kind":"text","text":", (Mgh, and so in the TA in art."},{"kind":"arabic","text_bw":"nEl","text_ar":"نعل"},{"kind":"text","text":",) i. e. ["},{"kind":"italic_en","text":"When the"},{"kind":"arabic","text_bw":"niEaAl","text_ar":"نِعَال"},{"kind":"italic_en","text":"are moistened"},{"kind":"text","text":"by rain,"},{"kind":"italic_en","text":"then pray ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"then prayer"},{"kind":"text","text":"shall be performed,]"},{"kind":"italic_en","text":"in the houses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habitations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"places of abode;"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"nEAl","text_ar":"نعال"},{"kind":"text","text":"meaning here"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"HiraAr","text_ar":"حِرَار"},{"kind":"text","text":"; (IAth, TA in the present art.;) or"},{"kind":"italic_en","text":"rugged and hard tracts of ground;"},{"kind":"text","text":"which are here particularized because the least wet moistens them, whereas the soft tracts dry up the water: (IAth, TA in art."},{"kind":"arabic","text_bw":"nEl","text_ar":"نعل"},{"kind":"text","text":":) Az says that the meaning is, when the hard grounds are rained upon, they become slippery to him who walks upon them; therefore pray ye in your abodes, and there shall not be anything brought against you for your not being present at the prayer in the mosques of the congregations: (TA in that art.:) or the trad. may mean,"},{"kind":"italic_en","text":"then pray ye"},{"kind":"text","text":"["},{"kind":"italic_en","text":"on the camels' saddles,"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"riding."},{"kind":"text","text":"(TA in the present art.) ―         -b4-  In another trad., it is related that 'Omar said to the Prophet,"},{"kind":"arabic","text_bw":"Haw~alotu raHoliYa AlbaAriHapa","text_ar":"حَوَّلْتُ رَحْلِىَ البَارِحَةَ"},{"kind":"text","text":"; by the word"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":", as signifying [properly] either the “ place of abode and resort ” or the “ saddle upon which camels are ridden, ” alluding to his"},{"kind":"italic_en","text":"wife;"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"gi$oyaAnuhaA fiY qubulihaA mino jihapi ZahorihaA","text_ar":"غِشْيَانُهَا فِى قُبُلِهَا مِنْ جِهَةِ ظَهْرِهَا"},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"raHolu AlmuSoHafi","text_ar":"رَحْلُ المُصْحَفِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desk"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon which the"},{"kind":"arabic","text_bw":"mSHf","text_ar":"مصحف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"copy of the Kur-án"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is put, in shape"},{"kind":"text","text":"["},{"kind":"italic_en","text":"somewhat"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like the saddle."},{"kind":"text","text":"(TA.) [It is generally a small desk of which the front and back have the form of the letter X; commonly made of palm-sticks.]       -A2-  [The pl.]"},{"kind":"arabic","text_bw":"raHaAlN","text_ar":"رَحَالٌ"},{"kind":"text","text":"also signifies ["},{"kind":"italic_en","text":"Carpets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloths,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, such as are called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TanaAfis","text_ar":"طَنَافِس"},{"kind":"text","text":","},{"kind":"italic_en","text":"of the fabric of El-Heereh."},{"kind":"text","text":"(S, K.)"}],"source_refs":["TA","AO","Sh","Msb","S","K"]}]}}