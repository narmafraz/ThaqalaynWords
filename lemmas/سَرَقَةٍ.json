ding,"},{"kind":"arabic","text_bw":"A_in~a A@bonaka sur~iqa","text_ar":"اـِنَّ ا@بْنَكَ سُرِّقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily thy son has been accused of theft"},{"kind":"text","text":"]. (S.)"}],"source_refs":["S","K"]},{"entry_id":"n19623","headword_ar":"سَرْقَةٌ","root":"srq","body":[{"kind":"text","text":": see what next precedes."}],"source_refs":[]},{"entry_id":"n19624","headword_ar":"سِرْقَةٌ","root":"srq","body":[{"kind":"text","text":": see what next precedes."}],"source_refs":[]},{"entry_id":"n19625","headword_ar":"سَرِقَةٌ","root":"srq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sariqN","text_ar":"سَرِقٌ"},{"kind":"text","text":". ―         -b2-  Also, (Msb,)"},{"kind":"italic_en","text":"A thing stolen;"},{"kind":"text","text":"(Mgh, Msb;) and so ↓"},{"kind":"arabic","text_bw":"suraAqapN","text_ar":"سُرَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":"; [pl. of the latter"},{"kind":"arabic","text_bw":"suraAqaAtN","text_ar":"سُرَاقَاتٌ"},{"kind":"text","text":";] whence the saying"},{"kind":"arabic","text_bw":"Einodahu suraAqaAtu Al$~iEori","text_ar":"عِنْدَهُ سُرَاقَاتُ الشِّعْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has stolen things of poetry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verse"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb"]}]},"classical_definitions":null}