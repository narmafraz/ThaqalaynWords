,{"kind":"text","text":"(JK, TA:) or"},{"kind":"arabic","text_bw":"xaDomN","text_ar":"خَضْمٌ"},{"kind":"text","text":"referring to a man is like"},{"kind":"arabic","text_bw":"qaDomN","text_ar":"قَضْمٌ"},{"kind":"text","text":"referring to a beast. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xaDamahu","text_ar":"خَضَمَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, K,) inf. n. as above; (TA;) and ↓"},{"kind":"arabic","text_bw":"AxtDmhu","text_ar":"اختضمهُ","orth_type":"arrow"},{"kind":"text","text":"; (JK, K;)"},{"kind":"italic_en","text":"He cut it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut it off:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he cut it in pieces."},{"kind":"text","text":"(JK.) ―         -b3-"},{"kind":"arabic","text_bw":"xaDama lahu","text_ar":"خَضَمَ لَهُ"},{"kind":"arabic","text_bw":"mino maAlihi","text_ar":"مِنْ مَالِهِ"},{"kind":"text","text":", (K,) accord. to IAar, (TA,) signifies"},{"kind":"italic_en","text":"He gave him of his property;"},{"kind":"text","text":"(K;) [as though he cut off for him a portion thereof;] but Th rejects this, and says that it is"},{"kind":"arabic","text_bw":"haDama","text_ar":"هَضَمَ"},{"kind":"text","text":". (TA.)"}],"source_refs":["As","S","K","TA","JK"]},{"entry_id":"n10931","headword_ar":"خُضْمٌ","root":"xDm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xuSomN","text_ar":"خُصْمٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}