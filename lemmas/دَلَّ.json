sent_2mp","form":"تَدُلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَدُلُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدْلُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدُلّ","in_corpus":true,"count":498,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَدْلُل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدُلّ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَدْلُل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدُلّانِ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدُلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدُلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدُلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدُلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدُلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْلُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَدُلّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدُلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"دَلَلْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":538,"cross_references":{"qac":{"found":true,"lemma_key":"دَلَّ","root":"دلل","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n12874"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to show, to indicate, to direct","examples":[{"text":"الكتاب المقدس يدلُّنا على الطريق الصحيح.","english":"The Bible shows/directs us to the right path."}]},{"pos":"verb","gloss":"[+ على] to be evidence of, to be proof of, to attest to, to demonstrate, to establish, to substantiate"},{"pos":"verb","gloss":"[+ على] to denote, to designate, to signify, to suggest","examples":[{"text":"لا شكلي ولا كلامي يَدُلّان على أنّي من الطبقة العُلْيا.","english":"Neither my way nor my speech show that I am from the upper class."}]}]},"etymology":null,"ipa":["/dal.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12874","headword_ar":"دَلَّ","root":"dl","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yadul~u","text_ar":"يَدُلُّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, directed; directed aright; guided;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused to take,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"follow, a right way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"direction."},{"kind":"text","text":"(IAar, T.) And"},{"kind":"arabic","text_bw":"dul~a","text_ar":"دُلَّ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was directed, directed aright, guided,"},{"kind":"text","text":"&c. (IAar, T.) You say,"},{"kind":"arabic","text_bw":"dal~ahu Ealayohi","text_ar":"دَلَّهُ عَلَيْهِ"},{"kind":"text","text":", (S, M, K,) aor. as above, (S, M,) inf. n."},{"kind":"arabic","text_bw":"dal~N","text_ar":"دَلٌّ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"duluwlapN","text_ar":"دُلُولَةٌ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"dilaAlapN","text_ar":"دِلَالَةٌ"},{"kind":"text","text":", (S, M, K,) [but this is afterwards said in the M to be a simple subst., as it is also in the Msb, and so is"},{"kind":"arabic","text_bw":"duluwlapN","text_ar":"دُلُولَةٌ"},{"kind":"text","text":"in the M,] and"},{"kind":"arabic","text_bw":"dalaAlapN","text_ar":"دَلَالَةٌ"},{"kind":"text","text":", (S, K,) which is of higher authority than"},{"kind":"arabic","text_bw":"dilaAlapN","text_ar":"دِلَالَةٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"dulaAlapN","text_ar":"دُلَالَةٌ"},{"kind":"text","text":", (K,) and [perhaps]"},{"kind":"arabic","text_bw":"dal~iylaY","text_ar":"دَلِّيلَى"},{"kind":"text","text":", [which see below, voce"},{"kind":"arabic","text_bw":"dilaAlapN","text_ar":"دِلَالَةٌ"},{"kind":"text","text":",] (K,) or this is a simple subst., (M,)"},{"kind":"italic_en","text":"He directed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly directed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guided him, to it;"},{"kind":"text","text":"(S, * M, K;) namely, the way, (S,) or a thing: (M:) or"},{"kind":"italic_en","text":"he showed him it;"},{"kind":"text","text":"namely, the way. (TA.) And"},{"kind":"arabic","text_bw":"dal~ahu AlT~ariyqa","text_ar":"دَلَّهُ الطَّرِيقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He directed him to the way;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed him the way"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"dal~a Al$~aYo'a","text_ar":"دَلَّ الشَّىْءَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"], aor. as above, inf. n."},{"kind":"arabic","text_bw":"duluwlapN","text_ar":"دُلُولَةٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He indicated the thing,"},{"kind":"text","text":"by a word &c.,] said of a man; as also ↓"},{"kind":"arabic","text_bw":"Adl~","text_ar":"ادلّ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"Adl~ Al$~aYo'a","text_ar":"ادلّ الشَّىْءَ"},{"kind":"text","text":", &c.]. (Msb.) You say also, of a word,"},{"kind":"arabic","text_bw":"yadul~u EalaY ka*aA","text_ar":"يَدُلُّ عَلَى كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It denotes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"signifies, such a thing"},{"kind":"text","text":"]. (The lexicons passim.)       -A2-  Accord. to Sh, you say,"},{"kind":"arabic","text_bw":"dalilotu bih`*aA AlT~ariyqi","text_ar":"دَلِلْتُ بِهٰذَا الطَّرِيقِ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"A^adal~u","text_ar":"اَدَلُّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"dalaAlapN","text_ar":"دَلَالَةٌ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"I knew this way;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dalalotu bihi","text_ar":"دَلَلْتُ بِهِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^adil~u","text_ar":"اَدِلُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dalaAlapN","text_ar":"دَلَالَةٌ"},{"kind":"text","text":": accord. to AZ, you say,"},{"kind":"arabic","text_bw":"biAlT~ariyqi","text_ar":"بِالطَّرِيقِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aid~alalotu","text_ar":"اِدَّلَلْتُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Aid~ilaAlN","text_ar":"اِدِّلَالٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, directed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly directed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guided, in the way:"},{"kind":"text","text":"] and [Az says,] I heard an Arab of the desert say to another,"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^amaA tanodal~u","text_ar":"اَمَا تَنْدَلُّ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlT~ariyqi","text_ar":"الطَّرِيقِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Wilt thou not be directed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly directed, to the way?"},{"kind":"text","text":"]: (T:) [for] ↓"},{"kind":"arabic","text_bw":"Andl~","text_ar":"اندلّ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, directed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly directed,"},{"kind":"text","text":"(M, K, TA,) to the way: (TA:) and IAar cites as an ex., (T,)"},{"kind":"quote","text":"maA laka yaA A^aHomaqu laAtanodal~u\n                      \n                     \n                        wakayofa yanodal~u A@moruw^N Eivowal~u"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What aileth thee, O stupid, that thou wilt not be rightly directed? but how shall the dull and slack be rightly directed?"},{"kind":"text","text":"]. (T, M, TA: but in the M,"},{"kind":"arabic","text_bw":"yA fulaAnu","text_ar":"يا فُلَانُ"},{"kind":"text","text":"; and in the TA,"},{"kind":"arabic","text_bw":"yA A^aEowaru","text_ar":"يا اَعْوَرُ"},{"kind":"text","text":".) And sometimes ↓"},{"kind":"arabic","text_bw":"Astdl~","text_ar":"استدلّ","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"dal~ahu AlT~ariyqa","text_ar":"دَلَّهُ الطَّرِيقَ"},{"kind":"text","text":"[explained above: see 10 below]. (TA.)       -A3-"},{"kind":"arabic","text_bw":"dal~ato","text_ar":"دَلَّتْ"},{"kind":"text","text":", [sec. pers."},{"kind":"arabic","text_bw":"dalaloti","text_ar":"دَلَلْتِ"},{"kind":"text","text":",] aor."},{"kind":"arabic","text_bw":"tadil~u","text_ar":"تَدِلُّ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"dal~N","text_ar":"دَلٌّ"},{"kind":"text","text":"; (S, * M, * Msb, K; *) and"},{"kind":"arabic","text_bw":"dal~ato","text_ar":"دَلَّتْ"},{"kind":"text","text":"of the class of"},{"kind":"arabic","text_bw":"taEiba","text_ar":"تَعِبَ"},{"kind":"text","text":", [sec. pers."},{"kind":"arabic","text_bw":"daliloti","text_ar":"دَلِلْتِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tadal~u","text_ar":"تَدَلُّ"},{"kind":"text","text":",] (Msb, MF, TA,) inf. n."},{"kind":"arabic","text_bw":"dalalN","text_ar":"دَلَلٌ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tdl~lt","text_ar":"تدلّلت","orth_type":"arrow"},{"kind":"text","text":"; (S, M, Msb, K;)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"behaved in an amorous manner,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"used amorous gesture"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaviour, with coquettish boldness, and feigned coyness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opposition;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"she behaved with boldness"},{"kind":"text","text":"(M, Msb, K)"},{"kind":"italic_en","text":"towards her husband,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"and with amorous gesture"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaviour, and coquettishness, feigning opposition:"},{"kind":"text","text":"(M, Msb, K:) [and"},{"kind":"arabic","text_bw":"dal~ato","text_ar":"دَلَّتْ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"she talked and jested in a pleasing manner, displaying a pleasant mien"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guise:"},{"kind":"text","text":"and in like manner"},{"kind":"arabic","text_bw":"dal~a","text_ar":"دَلَّ"},{"kind":"text","text":"is said of a man with his wife: see"},{"kind":"arabic","text_bw":"dal~N","text_ar":"دَلٌّ"},{"kind":"text","text":", below. See also 4.] ―         -b2-"},{"kind":"arabic","text_bw":"dal~a","text_ar":"دَلَّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He gloried in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted of, certain properties,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peculiar qualities."},{"kind":"text","text":"(IAar, T.) ―         -b3-  Also, aor."},{"kind":"arabic","text_bw":"yadil~u","text_ar":"يَدِلُّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He favoured with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conferred, a gift."},{"kind":"text","text":"(IAar, T.)       -A4-  And"},{"kind":"arabic","text_bw":"dal~a","text_ar":"دَلَّ"},{"kind":"text","text":", [aor., accord. to rule,"},{"kind":"arabic","text_bw":"yadul~u","text_ar":"يَدُلُّ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He emboldened:"},{"kind":"text","text":"so in the phrase,"},{"kind":"arabic","text_bw":"maA dal~aka EalaY~a","text_ar":"مَا دَلَّكَ عَلَىَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What emboldened thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hath emboldened thee, against me?"},{"kind":"text","text":"]: and in the saying of Keys Ibn-Zoheyr,"},{"kind":"quote","text":"A^aZun~u AlHiloma dal~a EalaY~a qawomiY\n                      \n                     \n                        waqado yusotajohalu Alr~ajulu AlHaliymu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I think that forbearance hath emboldened against me my people: for sometimes the forbearing man is reckoned ignorant"},{"kind":"text","text":"]: (T:) and ↓"},{"kind":"arabic","text_bw":"dl~l","text_ar":"دلّل","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (T and TA in art."},{"kind":"arabic","text_bw":"dlw","text_ar":"دلو"},{"kind":"text","text":".)"}],"source_refs":["S","M","K","T","TA","Msb","MF"]}]}}