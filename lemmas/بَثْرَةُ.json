"text","text":"or"},{"kind":"italic_en","text":"vesicated."},{"kind":"text","text":"(S, Msb.)"}],"source_refs":["S","M","A","Msb","K"]},{"entry_id":"n1751","headword_ar":"بثّر","root":"bavira","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(tar) ["},{"kind":"italic_en","text":"made"},{"kind":"text","text":"a camel"},{"kind":"italic_en","text":"to break out with small pustules;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"excoriated"},{"kind":"text","text":"a camel,"},{"kind":"italic_en","text":"and made"},{"kind":"text","text":"him"},{"kind":"italic_en","text":"to bleed."},{"kind":"text","text":"(Ibn-'Abbád, TA in art."},{"kind":"arabic","text_bw":"Hr$","text_ar":"حرش"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n1752","headword_ar":"بَثْرٌ","root":"bavira","body":[{"kind":"text","text":"(S, M, Msb, K) and ↓"},{"kind":"arabic","text_bw":"bavarN","text_ar":"بَثَرٌ","orth_type":"arrow"},{"kind":"text","text":", (M, Msb, K,) coll. gen. ns., (Msb, * MF,) originally inf. ns., (Msb,)"},{"kind":"italic_en","text":"Pimples,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small pustules;"},{"kind":"text","text":"(S, M, Msb, K;) accord. to some, specially upon the face; (M, TA;) as also"},{"kind":"arabic","text_bw":"buvuwrN","text_ar":"بُثُورٌ"},{"kind":"text","text":"; (S, Msb;) which is the pl. of"},{"kind":"arabic","text_bw":"bavorF","text_ar":"بَثْرً"},{"kind":"text","text":": (Msb:) ns. un."},{"kind":"arabic","text_bw":"bavaraAtN","text_ar":"بَثَرَاتٌ"},{"kind":"text","text":"(S, M, Msb) and"},{"kind":"arabic","text_bw":"bavarapN","text_ar":"بَثَرَةٌ"},{"kind":"text","text":": (M, Msb:) and pl. of this last"},{"kind":"arabic","text_bw":"bavaraAtN","text_ar":"بَثَرَاتٌ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"buvuwrN","text_ar":"بُثُورٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"bavorN","text_ar":"بَثْرٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"purulent pustules like the small-pox, upon the face and other parts of the person of a man."},{"kind":"text","text":"(T.) You say,"},{"kind":"arabic","text_bw":"xarajato bihi bavorapN faEaSarahaA","text_ar":"خَرَجَتْ بِهِ بَثْرَةٌ فَعَصَرَهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A pimple,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small pustule,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purulent pustule, came forth on him, and he squeezed it"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"bijilodihi bavorN $at~aY","text_ar":"بِجِلْدِهِ بَثْرٌ شَتَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In his skin are scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sundry, pimples,"},{"kind":"text","text":"&c.]. (A.)"}],"source_refs":["S","M","Msb","K"]},{"entry_id":"n1753","headword_ar":"بَثَرٌ","root":"bavira","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bavorN","text_ar":"بَثْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}