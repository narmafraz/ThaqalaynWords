(K, * TA,) aor. and inf. n. as above; and ↓"},{"kind":"arabic","text_bw":"Ajzlhu","text_ar":"اجزلهُ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The saddle cut it;"},{"kind":"text","text":"namely, the withers of a camel. (K, * TA.)       -A2-"},{"kind":"arabic","text_bw":"jazila","text_ar":"جَزِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K.) inf. n."},{"kind":"arabic","text_bw":"jazalN","text_ar":"جَزَلٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had a gall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sore, in the withers, in consequence of which a bone came forth from it, and the place thereof became depressed:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"he had his withers cut by the saddle:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he had a gall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sore, in the withers, penetrating into the interior, and killing him."},{"kind":"text","text":"(TA.) The epithet applied to a camel in this case is ↓"},{"kind":"arabic","text_bw":"A^ajozlu","text_ar":"اَجْزلُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) fem."},{"kind":"arabic","text_bw":"jazolaA='u","text_ar":"جَزْلَا=ءُ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"juzolN","text_ar":"جُزْلٌ"},{"kind":"text","text":"(K.) See also"},{"kind":"arabic","text_bw":"A^axozalu","text_ar":"اَخْزَلُ"},{"kind":"text","text":"-A3-"},{"kind":"arabic","text_bw":"jazula","text_ar":"جَزُلَ"},{"kind":"text","text":","},{"kind":"page_break","n":421},{"kind":"text","text":"aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jazaAlapN","text_ar":"جَزَالَةٌ"},{"kind":"text","text":", (Msb,) said of firewood, (Msb, TA,) &c., (TA,)"},{"kind":"italic_en","text":"It was thick and large."},{"kind":"text","text":"(Msb, K.) ―         -b2-  Also, (K,) inf. n. as above, (S,) (tropical:)"},{"kind":"italic_en","text":"He possessed good,"},{"kind":"text","text":"(S, * K, TA,)"},{"kind":"italic_en","text":"strong, firm,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"(S * K, TA,) [and"},{"kind":"italic_en","text":"natural disposition,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"intelligence;"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"jazaAlapN","text_ar":"جَزَالَةٌ"},{"kind":"text","text":"is used in relation to judgment and natural disposition and intelligence: (Ham p. 770:) and"},{"kind":"arabic","text_bw":"jazaAlapu Alr~aA^oY","text_ar":"جَزَالَةُ الرَّاْى"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"firmness of judgment:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"AljazaAlapu fiY AlmanoTiqi","text_ar":"الجَزَالَةُ فِى المَنْطِقِ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"chasteness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clearness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eloquence,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"firmness, in speech."},{"kind":"text","text":"(Har p. 8.)"}],"source_refs":["K","S","Msb","TA"]},{"entry_id":"n5741","headword_ar":"جِزْلَةٌ","root":"jzl","body":[{"kind":"italic_en","text":"A piece,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion cut off."},{"kind":"text","text":"(S, K.*) ―         -b2-"},{"kind":"italic_en","text":"A large portion of dates;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"jizolN","text_ar":"جِزْلٌ"},{"kind":"text","text":"(K)"}],"source_refs":["K"]}]},"classical_definitions":null}