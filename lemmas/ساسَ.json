s":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n21223"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to direct, to govern, to rule, to manipulate, to groom, to manage, to cox, to steer","examples":[{"text":"الرَّاعِي يَسُوسُ الدَّوَابَّ.","english":"The shepherd directs the animals."},{"text":"سَاسَ أُمُورَ النَّاسِ بِالحَقِّ","english":"He managed the affairs of people by justice."}]}]},"etymology":null,"ipa":["/saː.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21223","headword_ar":"سَاسٌ","root":"sws","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"suwsN","text_ar":"سُوسٌ"},{"kind":"text","text":". ―         -b2-  Also"},{"kind":"italic_en","text":"A canker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrosion,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qaAdiHN","text_ar":"قَادِحٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in a tooth:"},{"kind":"text","text":"(AZ, K:) without and without teshdeed. (AZ.)       -A2-  And A tooth"},{"kind":"italic_en","text":"that has been eaten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corroded:"},{"kind":"text","text":"(L, K, * TA:) originally"},{"kind":"arabic","text_bw":"saAy^isN","text_ar":"سَايِسٌ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"haArN","text_ar":"هَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"haAy^irN","text_ar":"هَايِرٌ"},{"kind":"text","text":". (K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"masuwsN","text_ar":"مَسُوسٌ"},{"kind":"text","text":", in two places."}],"source_refs":["AZ","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D8%B3/","headword_ar":"ساس","entries":[{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10652#55b0e8","body_html":"<span>ساس: السُّوس والسّاسُ. العُثَّةُ التي تقع في الثّياب والطّعام. تقول: سِيسَ الطَّعامُ فهو مسوس.</span><span> </span><span>والسُّوسُ : حَشيشةُ تُشبه القَتَّ. والسِّياسة: فعل السائس الذي يسوس الدّوابَّ سياسهً، يقوم عليها ويروضها. والوالي يَسُوس الرعية وأمرهم. والسّوس: داءٌ يكون بعجز الدّابّة بين الفَخِذِ والوَرِك، يورثه ضعف الرِّجل. والنّعت: أسوس. والسَّواسُ: شجر، الواحدة بالهاء، من أفضل ما يُتَّخَذ منه زند، لأنّه قلّما يصلِد، قال الطّرمّاح: </span><br><br><span>وأخرج، أُمُّه، لسَواسِ سَلْمى </span><span class=\"red\">...</span><span> لمعفور الضَّرا ضَرِم الجَنينِ</span><br><br><span>أبو ساسان: كنية كِسْرى، والحُصَين بن المنذر </span><span class=\"red\">...</span><span> ومن جعل: ساسان: فعلان، فتصغيره: سُوَيْسان. والسِّيساء: منسج الحمار والبغل، وجعله الرّاجز مُجتَمع داياتِ البَعير، قال :</span><br><br><span>قُفّاً كِسيساء البعير قافلا</span>"},{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=10652#859463","body_html":"ساس<br>عن الفارسية بمعنى حشرة، وأم الزوجة، أو من ساس بمعنى فقير ومسكين. يستخدم للذكور."}]}}