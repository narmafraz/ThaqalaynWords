"},{"role":"present_1ms","form":"أَفْدِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْدَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفْدَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"فَدَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَدَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَفْد","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفْد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":true,"lemma_key":"فَدَى","root":"فدي","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n33286","n33287"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AF%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to free (someone) from captivity or from danger by paying a sum of money or by giving away something to buy him back; to ransom (someone)","tags":["transitive"],"examples":[{"text":"تُحَيِّي بِالسَّلَامَةِ أُمُّ عَمْرٍو * وَهَلْ لَكِ بَعْدَ رَهْطِكِ مِنْ سَلَامِ\nذَرِينِي أَصْطَبِحُ بِكْرًا فَإِنِّي * رَأَيْتُ الْمَوْتَ نَقَّبَ عَنْ هِشَامِ\nوَوَدَّ بَنُو الْمُغِيرَةِ لَوْ فَدَوْهُ * بِأَلْفٍ مِنْ رِجَالٍ أَوْ سَوَامِ","english":"ʾUmm Amr wishes us well!\nHave you, without your kin, ever been well?\nLet me drink, for I have seen Death\nRooting about, hunting Hišām.\nThe clansmen of Muḡīrah wish\nThey could have ransomed him\nFor even a thousand head\nOf grazers or of men."},{"text":"يَا غُصْنَ نَقَا مُكَلَّلًا بِٱلذَّهَبِ – أَفْدِيكَ مِنَ ٱلرَّدَى بِأُمِّي وَأَبِي","english":"Oh gold-wreathed sand dune branch – I would ransom you from death with my mother and father!"}]}]},"etymology":null,"ipa":["/fa.daː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33286","headword_ar":"فَدًى","root":"fdY","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fidFY","text_ar":"فِدًى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fidaA='N","text_ar":"فِدَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fidoyapN","text_ar":"فِدْيَةٌ","orth_type":"arrow"},{"kind":"text","text":"all signify the same, (S, K,) i. e. ["},{"kind":"italic_en","text":"A ransom;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing,"},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"a captive,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"that is given for a man, who is therewith liberated:"},{"kind":"text","text":"(K, TA:) [the first three are also inf. ns. (and have been mentioned as such in the first paragraph); therefore when you say"},{"kind":"arabic","text_bw":"fadFY laka A^abiY","text_ar":"فَدًى لَكَ اَبِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fidFY lk AbY","text_ar":"فِدًى لك ابى"},{"kind":"text","text":", the words"},{"kind":"arabic","text_bw":"fadFY","text_ar":"فَدًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fidFY","text_ar":"فِدًى"},{"kind":"text","text":"may be either inf. ns. or substs.: as substs., the second and third are more common than the first:]"},{"kind":"arabic","text_bw":"fidoyapF","text_ar":"فِدْيَةً"},{"kind":"text","text":"[is also sometimes expl. as an inf. n., but accord. to general usage] signifies as above; (K, TA;) or"},{"kind":"italic_en","text":"property given as a substitute"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a ransom"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for a captive:"},{"kind":"text","text":"(Mgh, Msb, TA:) and"},{"kind":"italic_en","text":"property by the giving of which one preserves himself from evil in the case of a religious act in which he has fallen short of what was incumbent, like the expiation for the breaking of an oath"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a fast;"},{"kind":"text","text":"and thus it is used in the Kur ii. 180 and 192: (Er-Rághib, TA:) and its pl. is"},{"kind":"arabic","text_bw":"fidFY","text_ar":"فِدًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fidayaAtN","text_ar":"فِدَيَاتٌ"},{"kind":"text","text":". (Mgh, Msb, TA.)"}],"source_refs":["S","K","TA","Mgh","Msb"]},{"entry_id":"n33287","headword_ar":"فِدًى","root":"fdY","body":[{"kind":"text","text":": see the next preceding paragraph. [Hence the phrase]"},{"kind":"arabic","text_bw":"juEilotu fidaAka","text_ar":"جُعِلْتُ فِدَاكَ"},{"kind":"text","text":": see 2. It is also a pl. of its syn."},{"kind":"arabic","text_bw":"fidoyapF","text_ar":"فِدْيَةً"},{"kind":"text","text":". (Mgh, Msb, TA.)"}],"source_refs":[]}]},"classical_definitions":null}