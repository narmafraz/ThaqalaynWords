resent_1ms","form":"أَغِلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغِلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"غَلَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":37,"cross_references":{"qac":{"found":true,"lemma_key":"غَلَّ","root":"غلل","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":14},"lanes":{"found":true,"entry_ids":["n32166","n32167"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to insert, to join together"},{"pos":"verb","gloss":"to be put into"},{"pos":"verb","gloss":"to be admitted, to enter"},{"pos":"verb","gloss":"to put on the undergarment غِلَالَة (ḡilāla)"},{"pos":"verb","gloss":"to yield crops or revenue"},{"pos":"verb","gloss":"to embezzle","examples":[{"text":"وَمَا كَانَ لِنَبِيٍّ أَن يَغُلَّۚ وَمَن يَغۡلُلۡ يَأۡتِ بِمَا غَلَّ يَوۡمَ ٱلۡقِيَٰمَةِۚ ثُمَّ تُوَفَّىٰ كُلُّ نَفۡسٖ مَّا كَسَبَتۡ وَهُمۡ لَا يُظۡلَمُونَ.","english":"It is not for any prophet to embezzle. Whoso embezzleth will bring what he embezzled with him on the Day of Resurrection. Then every soul will be paid in full what it hath earned; and they will not be wronged."}]},{"pos":"verb","gloss":"to turn from what is right"},{"pos":"verb","gloss":"to bind, to fetter, to chain, to shackle"},{"pos":"verb","gloss":"to thirst for revenge, be full of hatred"},{"pos":"verb","gloss":"to suffer from violent thirst"},{"pos":"noun","gloss":"verbal noun of غَلَّ (ḡalla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of غَلَّ (ḡalla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of غُلَّ (ḡulla, “to be thirsty”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"shackle, fetter"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32166","headword_ar":"غُلٌّ","root":"gl","body":[{"kind":"italic_en","text":"A ring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collar, of iron, which is put upon the neck:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"a shackle for the neck"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for the hand:"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a ring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collar, for the neck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pinion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manacle for the hand:"},{"kind":"text","text":"] (MA:) or"},{"kind":"italic_en","text":"a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shackle of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jaAmiEap","text_ar":"جَامِعَة"},{"kind":"text","text":", (TA, and so in the S and K in art."},{"kind":"arabic","text_bw":"jmE","text_ar":"جمع"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of iron,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"collecting together the two hands to the neck:"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"jmE","text_ar":"جمع"},{"kind":"text","text":"; and Jel * in xxxvi. 7:) [sometimes,"},{"kind":"italic_en","text":"a shackle for the neck and hands, consisting of two rings, one for the neck and the other for the hands, connected by a bar of iron:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"zam~aArapN","text_ar":"زَمَّارَةٌ"},{"kind":"text","text":":)] and"},{"kind":"italic_en","text":"a shackle with which the Arabs used to confine a captive when they took him, made of thongs, upon which was hair, so that sometimes, when it dried, it became infested with lice upon his neck:"},{"kind":"text","text":"(TA:) the pl. is"},{"kind":"arabic","text_bw":"A^agolaAlN","text_ar":"اَغْلَالٌ"},{"kind":"text","text":": (S, O, Msb, K:) which repeatedly occurs in the Kur-án and the Sunneh as meaning (assumed tropical:)"},{"kind":"italic_en","text":"difficult tasks"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"fatiguing works"},{"kind":"text","text":"[as being likened to shackles upon the necks]. (TA.) ―         -b2-  [Hence] the Arabs apply it metonymically to denote (tropical:)"},{"kind":"italic_en","text":"A wife."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"gul~N qamilN","text_ar":"غُلٌّ قَمِلٌ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"A lousy shackle for the neck"},{"kind":"text","text":"&c.] is an appellation of (assumed tropical:)"},{"kind":"italic_en","text":"a woman of evil disposition;"},{"kind":"text","text":"originating from the fact that the"},{"kind":"arabic","text_bw":"gul~","text_ar":"غُلّ"},{"kind":"text","text":"used to be of thongs, upon which was hair, so that it became infested with lice. (S.)       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"gul~apN","text_ar":"غُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) and ↓"},{"kind":"arabic","text_bw":"galalN","text_ar":"غَلَلٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or this is the inf. n. of"},{"kind":"arabic","text_bw":"gul~a","text_ar":"غُلَّ"},{"kind":"text","text":", (S,) [and accord. to analogy of"},{"kind":"arabic","text_bw":"gal~a","text_ar":"غَلَّ"},{"kind":"text","text":"as originally"},{"kind":"arabic","text_bw":"galila","text_ar":"غَلِلَ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"galiylN","text_ar":"غَلِيلٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,)"},{"kind":"italic_en","text":"Thirst:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement thirst:"},{"kind":"text","text":"(K, TA:) or the"},{"kind":"italic_en","text":"burning of thirst;"},{"kind":"text","text":"(S, O, TA;)"},{"kind":"italic_en","text":"little"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"burning of the inside,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"from thirst,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from anger and vexation"},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","MA","TA","S","O","K"]},{"entry_id":"n32167","headword_ar":"غِلٌّ","root":"gl","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"galiylN","text_ar":"غَلِيلٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite:"},{"kind":"text","text":"(S, O, Msb, K, TA:) or"},{"kind":"italic_en","text":"latent rancour"},{"kind":"text","text":"&c.: (JK in explanation of the former:) and"},{"kind":"italic_en","text":"envy;"},{"kind":"text","text":"so each signifies; (TA;) [and so the former in the Kur vii. 41 and xv. 47:] and"},{"kind":"italic_en","text":"enmity:"},{"kind":"text","text":"(TA in explanation of the latter:) and the former signifies also"},{"kind":"italic_en","text":"dishonesty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insincerity."},{"kind":"text","text":"(S, O.)"}],"source_refs":["S","O","Msb","K","TA"]}]}}