"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AC%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to surpass in courage and bravery"},{"pos":"verb","gloss":"to be brave, courageous, bold"},{"pos":"noun","gloss":"verbal noun of شَجَعَ (šajaʕa, “to surpass in bravery”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"surpassing in courage and bravery"},{"pos":"verb","gloss":"to encourage, to embolden","examples":[{"text":"شَجَّعَهُمْ نَجَاحُهُمْ.","english":"They were emboldened by their success."}]},{"pos":"verb","gloss":"to support, to further"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21753","headword_ar":"شَجُعَ","root":"$jE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$ajaAEapN","text_ar":"شَجَاعَةٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, courageous, brave, valiant, bold, daring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stronghearted"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"on the occasion of war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fight,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"making light of wars, by reason of his boldness."},{"kind":"text","text":"(Msb.) AZ says that"},{"kind":"arabic","text_bw":"sajaAEapN","text_ar":"سَجَاعَةٌ"},{"kind":"text","text":"sometimes denotes a comparative quality in relation to him who is weaker than the person to whom it is ascribed. (Msb.)       -A2-"},{"kind":"arabic","text_bw":"$ajaEahu","text_ar":"شَجَعَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [which in this case is contr. to the general rule, notwithstanding the guttural letter, for by rule it should be"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He overcame him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpassed him, in"},{"kind":"arabic","text_bw":"$ajaAEap","text_ar":"شَجَاعَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"courage,"},{"kind":"text","text":"&c.]. (K.) [See 3.]       -A3-"},{"kind":"arabic","text_bw":"$ajiEa","text_ar":"شَجِعَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"$ajaEN","text_ar":"شَجَعٌ"},{"kind":"text","text":", (IDrd, Msb, K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tall."},{"kind":"text","text":"(IDrd, Msb, K.)"}],"source_refs":["S","Msb","K","IDrd"]},{"entry_id":"n21758","headword_ar":"شَجَعٌ","root":"$jE","body":[{"kind":"italic_en","text":"Penetrating energy; boldness."},{"kind":"text","text":"(As.) ―         -b2-"},{"kind":"italic_en","text":"Quickness of the shifting of the legs,"},{"kind":"text","text":"in camels, (S, K,) or, accord. to IB, in horses. (TA.)"}],"source_refs":["S","K"]},{"entry_id":"n21759","headword_ar":"شَجِعٌ","root":"$jE","body":[{"kind":"text","text":"; fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$ujaAEN","text_ar":"شُجَاعٌ"},{"kind":"text","text":", in three places. ―         -b2-"},{"kind":"arabic","text_bw":"$ajiEu AlqawaAy^imi","text_ar":"شَجِعُ القَوَايِمِ"},{"kind":"italic_en","text":"Quick in the shifting of the legs,"},{"kind":"text","text":"applied to a he-camel; and so"},{"kind":"arabic","text_bw":"$ajiEapN","text_ar":"شَجِعَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$ajoEaA='u","text_ar":"شَجْعَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", applied to a she-camel. (S, K.) And"},{"kind":"arabic","text_bw":"qawaAy^imu $ajiEaAtN","text_ar":"قَوَايِمُ شَجِعَاتٌ"},{"kind":"italic_en","text":"Quick, and light, active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nimble, legs."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"italic_en","text":"Mad,"},{"kind":"text","text":"applied to a camel. (Ibn-'Abbád, K.)"}],"source_refs":[]},{"entry_id":"n21760","headword_ar":"شِجَعٌ","root":"$jE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$ujaAEN","text_ar":"شُجَاعٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}