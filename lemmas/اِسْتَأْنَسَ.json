role":"present_2mp","form":"تَسْتَأْنِسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْتَأْنِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْتَأْنِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْتَأْنِس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْتَأْنِس","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْتَأْنِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْتَأْنِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْتَأْنِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْتَأْنِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْتَأْنِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْتَأْنِسُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْتَأْنِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"اِسْتَأْنَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِسْتَأْنَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَسْتَأْنِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْتَأْنِس","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["n1334"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%A3%D9%92%D9%86%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be friendly to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to accustom oneself, to settle down"},{"pos":"verb","gloss":"to familiarize oneself, to acquaint oneself"},{"pos":"verb","gloss":"to gather information"},{"pos":"verb","gloss":"to take into account or consideration"},{"pos":"verb","gloss":"to heed"},{"pos":"verb","gloss":"to listen"},{"pos":"verb","gloss":"to ask for permission"},{"pos":"verb","gloss":"to become tame, to be domesticated (of an animal)"},{"pos":"verb","gloss":"to become aware [with بِ (bi) or إِلَى (ʔilā) ‘of a human’] (of an animal)"}]},"etymology":null,"ipa":["/is.taʔ.na.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1334","headword_ar":"استانس","root":"Ans","body":[{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AstA^ns bihi","text_ar":"استانس بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":": see 1.       -A2-"},{"kind":"arabic","text_bw":"AstA^ns","text_ar":"استانس"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a wild animal)"},{"kind":"italic_en","text":"became sensible of the presence or nearness of a human being."},{"kind":"text","text":"(S, K.)       -A3-"},{"kind":"italic_en","text":"He looked;"},{"kind":"text","text":"as in the phrase"},{"kind":"arabic","text_bw":"Ai*ohabo faA@sotaA^oniso halo taraY A^aHadFA","text_ar":"اِذْهَبْ فَا@سْتَاْنِسْ هَلْ تَرَى اَحَدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Go thou and look if thou see any one"},{"kind":"text","text":"]: (Fr, TA:)"},{"kind":"italic_en","text":"he considered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined, endeavouring to obtain a clear knowledge of a thing;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"and looked aside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, to ascertain if he could see any one:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asked for, knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"information; he inquired:"},{"kind":"text","text":"(M, TA:) and hence, (Bd in xxiv. 27,)"},{"kind":"italic_en","text":"he asked permission."},{"kind":"text","text":"(Fr, Zj, K, TA, and Bd ubi suprà.) It is said in the Kur [xxiv. 27],"},{"kind":"arabic","text_bw":"laA tadoxuluwA buyuwtFA gayora buyuwtikumo Hat~ay tasotaA^onisuwA","text_ar":"لَا تَدْخُلُوا بُيُوتًا غَيْرَ بُيُوتِكُمْ حَتَّي تَسْتَاْنِسُوا"},{"kind":"arabic","text_bw":"watusal~imuwA","text_ar":"وَتُسَلِّمُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Enter ye not houses other than your own houses"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"until ye inquire"},{"kind":"text","text":"whether its inhabitants desire that ye should enter or not; ["},{"kind":"italic_en","text":"and salute:"},{"kind":"text","text":"] (M:) or (which is essentially the same, M)"},{"kind":"italic_en","text":"until ye ask permission:"},{"kind":"text","text":"(Fr, Zj, M, TA:) but Fr says that the sentence presents an inversion, and that the meaning is,"},{"kind":"italic_en","text":"until ye salute, and ask if ye shall enter or not:"},{"kind":"text","text":"(TA:) I'Ab says that"},{"kind":"arabic","text_bw":"tastA^nswA","text_ar":"تَستانسوا"},{"kind":"text","text":"is a mistranscription; and he and Ubeí and Ibn-Mes'ood read"},{"kind":"arabic","text_bw":"tasotaA^o*inuwA","text_ar":"تَسْتَاْذِنُوا"},{"kind":"text","text":", which signifies the same: (Az, TA:) [it is said that]"},{"kind":"arabic","text_bw":"AstA^ns","text_ar":"استانس"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"he made a reiterated hemming, like a slight coughing;"},{"kind":"text","text":"[as a man does to notify his nearness;] syn."},{"kind":"arabic","text_bw":"tanaHonaHa","text_ar":"تَنَحْنَحَ"},{"kind":"text","text":": and so some explain it in the text of the Kur quoted above. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AstA^ns lahu","text_ar":"استانس لَهُ"},{"kind":"italic_en","text":"He listened to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to hear, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tA^n~s","text_ar":"تانّس","orth_type":"arrow"},{"kind":"text","text":". (A.) [See the Kur xxxiii. 53.]       -A4-"},{"kind":"arabic","text_bw":"AstA^nshu","text_ar":"استانسهُ"},{"kind":"text","text":": see 4."}],"source_refs":["Fr","TA","M","Zj","Az"]}]},"classical_definitions":null}