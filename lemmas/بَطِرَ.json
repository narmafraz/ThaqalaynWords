num":"p"},{"role":"present_2mp","form":"تَبْطَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْطَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْطَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْطَر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْطَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْطَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْطَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْطَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْطَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْطَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْطَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَطِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَطِرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْطَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْطَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"بَطِرَ","root":"بطر","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n2752"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B7%D9%90%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2752","headword_ar":"بَطِرَ","root":"bTr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baTarN","text_ar":"بَطَرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He exulted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulted greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively; and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he exulted by reason of wealth, and behaved with pride and self-conceitedness, and boastfulness, and want of thankfulness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he behaved with the utmost exultation,"},{"kind":"text","text":"&c.: or"},{"kind":"italic_en","text":"he rejoiced, and rested his mind upon things agreeable with natural desire:"},{"kind":"text","text":"syn. of the inf. n."},{"kind":"arabic","text_bw":"A^a$arN","text_ar":"اَشَرٌ"},{"kind":"text","text":", (S, A, L, Msb, TA,) and"},{"kind":"arabic","text_bw":"maraHN","text_ar":"مَرَحٌ"},{"kind":"text","text":"; (L, TA;) the former of which signifies"},{"kind":"arabic","text_bw":"$id~apN AlmaraHi","text_ar":"شِدَّةٌ المَرَحِ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"mujaAwazapu AlHad~i fiY","text_ar":"مُجَاوَزَةُ الحَدِّ فِى"},{"kind":"arabic","text_bw":"maraHK","text_ar":"مَرَحٍ"},{"kind":"text","text":": (A:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stupified, deprived of his reason, confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed,"},{"kind":"text","text":"(S, K, Er-Rághib,)"},{"kind":"italic_en","text":"bearing wealth ill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in an evil manner, performing little of the duty imposed on him by it, and turning it to a wrong purpose:"},{"kind":"text","text":"(Er-Rághib, TA, * TK:) this is said to be the primary signification: (TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stupified, or confounded, and knew not what to prefer nor what to postpone:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed, by reason of fright:"},{"kind":"text","text":"(As, S voce"},{"kind":"arabic","text_bw":"baHira","text_ar":"بَحِرَ"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"he behaved exorbitantly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insolently, with wealth,"},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"on the occasion of having wealth:"},{"kind":"text","text":"and this, also, is said to be the primary signification: (TA:)"},{"kind":"italic_en","text":"he had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercised, little of the quality of bearing wealth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a becoming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, manner"},{"kind":"text","text":"]: (K:)"},{"kind":"italic_en","text":"he behaved proudly:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he regarded a thing with hatred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dislike, without its deserving to be so regarded: he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly:"},{"kind":"text","text":"(K:) accord. to some,"},{"kind":"italic_en","text":"he walked with an elegant and a proud and self-conceited gait, with an affected inclining of the body from side to side."},{"kind":"text","text":"(TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA yanoZuru","text_ar":"لَا يَنْظُرُ"},{"kind":"arabic","text_bw":"A@ll~`hu yawoma AlqiyaAmapi mano jar~a A_izaArahu baTarFA","text_ar":"ا@للّٰهُ يَوْمَ القِيَامَةِ مَنْ جَرَّ اـِزَارَهُ بَطَرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God will not look, on the day of resurrection, upon him who drags along his wrapper of the lower part of the body in exultation and insolence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pride:"},{"kind":"text","text":"meaning one who wears too long a wrapper of the lower part of the body]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"baTirota Eayo$aka","text_ar":"بَطِرْتَ عَيْشَكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Thou exultedst,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exultedst greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and behavedst insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in thy manner of life,"},{"kind":"text","text":"] is a phrase similar to"},{"kind":"arabic","text_bw":"ra$idota A^amoraka","text_ar":"رَشِدْتَ اَمْرَكَ"},{"kind":"text","text":"; (S, TA;) and in like manner"},{"kind":"arabic","text_bw":"baTirato maEiy$atahaA","text_ar":"بَطِرَتْ مَعِيشَتَهَا"},{"kind":"text","text":", in the Kur [xxviii. 58]; in which the verb is not trans., but the subst. is put in the accus. case because of"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"text","text":"understood before it. (Aboo-Is-hák.) ―         -b3-"},{"kind":"arabic","text_bw":"laA A^aboTaru AlginaY","text_ar":"لَا اَبْطَرُ الغِنَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I do not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will not, domineer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assume superiority, over others when I am rich."},{"kind":"text","text":"(Ham p. 517.) ―         -b4-"},{"kind":"arabic","text_bw":"baTira Aln~iEomapa","text_ar":"بَطِرَ النِّعْمَةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He held wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the favour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit, in light estimation, and was unthankful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungrateful, for it."},{"kind":"text","text":"(A.) ―         -b5-"},{"kind":"arabic","text_bw":"baTira hidaAyapa A^amorihi","text_ar":"بَطِرَ هِدَايَةَ اَمْرِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He refused the right direction as to the management of his affair, and was ignorant of it."},{"kind":"text","text":"(TA.) ―         -b6-  It is said in a trad., that pride is"},{"kind":"arabic","text_bw":"baTaru AlHaq~i","text_ar":"بَطَرُ الحَقِّ"},{"kind":"text","text":", which"},{"kind":"italic_en","text":"means (tropical:)  The considering as false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain, what God has pronounced to be the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"our duty;"},{"kind":"text","text":"namely, the confession of his unity, and the obligation of rendering Him religious service: or"},{"kind":"italic_en","text":"the being confounded at considering truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"duty, and not seeing it to be true,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"the disdaining the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right, and not accepting it"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not admitting it."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"baTarahu","text_ar":"بَطَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(S, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"baTorN","text_ar":"بَطْرٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He cut it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided it, lengthwise; slit it; split it."},{"kind":"text","text":"(S, Msb, K.) Hence the appellation"},{"kind":"arabic","text_bw":"bayoTaArN","text_ar":"بَيْطَارٌ"},{"kind":"text","text":". (S, Msb.)"}],"source_refs":["S","A","L","Msb","TA","K"]}]}}