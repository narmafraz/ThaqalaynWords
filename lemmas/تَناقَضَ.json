asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَناقَضُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَناقَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَناقَض","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَناقَض","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَناقَضا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَناقَضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَناقَضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَناقَضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَناقَضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَناقَضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَناقَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"تَناقَضْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تَناقَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَتَناقَض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَناقَض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":34,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n40426"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%86%D8%A7%D9%82%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be contradictory, to be contrary","tags":["intransitive","reciprocal"]},{"pos":"verb","gloss":"to cancel each other","tags":["reciprocal"]},{"pos":"noun","gloss":"verbal noun of تَنَاقَضَ (tanāqaḍa) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"contradiction, opposite, inconsistency, oxymoron"}]},"etymology":null,"ipa":["/ta.naː.qa.dˤa/","/ta.naː.qudˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40426","headword_ar":"تناقض","root":"nqD","body":[{"kind":"text","text":": see 8. ―         -b2-"},{"kind":"arabic","text_bw":"tanaAquDN","text_ar":"تَنَاقُضٌ"},{"kind":"text","text":"also signifies (tropical:)"},{"kind":"italic_en","text":"Mutual contradiction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repugnancy; contr. of"},{"kind":"arabic","text_bw":"tawaAfuqN","text_ar":"تَوَافُقٌ"},{"kind":"text","text":". (O, TA.) You say,"},{"kind":"arabic","text_bw":"fiY kalaAmihi tanaAquDN","text_ar":"فِى كَلَامِهِ تَنَاقُضٌ"},{"kind":"text","text":"(A, Mgh, Msb, TA,) (tropical:)  ["},{"kind":"italic_en","text":"In his speech is contradiction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repugnancy, between different parts;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one part of his speech necessarily implies the annulment of another part;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"his second saying contradicted"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"naAqaDa","text_ar":"نَاقَضَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"his first."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"tanaAqaDa AlqawolaAni","text_ar":"تَنَاقَضَ القَوْلَانِ"},{"kind":"text","text":", (A, Mgh,) or"},{"kind":"arabic","text_bw":"AlkalaAmaAni","text_ar":"الكَلَامَانِ"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"The two saying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentences, contradicted each other;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"were mutually repugnant;"},{"kind":"text","text":"as though each undid the other; (Msb;) ["},{"kind":"italic_en","text":"they annulled each other."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"tnAqD Al$~aAEiraAni","text_ar":"تناقض الشَّاعِرَانِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The two poets contradicted each other."},{"kind":"text","text":"] (A, TA.) And"},{"kind":"arabic","text_bw":"tnAqD maEonaAhu","text_ar":"تناقض مَعْنَاهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Its meaning was contradictory."},{"kind":"text","text":"(S, * K, TA.)       -A2-  [It is also used transitively:] you say,"},{"kind":"arabic","text_bw":"tanaAqaDaA AlbayoEa","text_ar":"تَنَاقَضَا البَيْعَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They two mutually dissolved the sale:"},{"kind":"text","text":"as though compared with the saying"},{"kind":"arabic","text_bw":"taraA='awuA AlhilaAla","text_ar":"تَرَا=ءَوُا الهِلَالَ"},{"kind":"text","text":", meaning “ they [together] saw the new moon; ” and"},{"kind":"arabic","text_bw":"tadaAEawuA Alqawoma","text_ar":"تَدَاعَوُا القَوْمَ"},{"kind":"text","text":", meaning “ they [together] called the people; ” and"},{"kind":"arabic","text_bw":"tasaA='aluwhumo","text_ar":"تَسَا=ءَلُوهُمْ"},{"kind":"text","text":", meaning “ they [together] asked them; ” notwithstanding that"},{"kind":"arabic","text_bw":"tnAqD","text_ar":"تناقض"},{"kind":"text","text":"is [properly] intransitive. (Mgh.) And"},{"kind":"arabic","text_bw":"tanaAqaDuwA Euhuwdahumo","text_ar":"تَنَاقَضُوا عُهُودَهُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"They mutually dissolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke, their compacts, contracts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covenants"},{"kind":"text","text":"]. (T, voce"},{"kind":"arabic","text_bw":"tnAkvwA","text_ar":"تناكثوا"},{"kind":"text","text":".)"}],"source_refs":["A","Mgh","Msb","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D9%86%D8%A7%D9%82%D8%B6/","headword_ar":"تناقض","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23147#490faf","body_html":"<span>التناقض: هو اختلاف القضيتين بالإيجاب والسلب، بحيث يقتضي لذاته صدق إحداهما وكذب الأخرى، كقولنا: زيد إنسان، زيد ليس بإنسان.</span>"}]}}