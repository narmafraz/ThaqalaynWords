{"lemma":"قارَّةٍ","slug":"قارَّةٍ","root":"ق.ر.ر","root_slug":"ق-ر-ر","root_link":"/words/roots/ق-ر-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n35341","n36401","n42868"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D8%B1%D9%8E%D9%91%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"continent"},{"pos":"adj","gloss":"feminine singular of قَارّ (qārr)","tags":["feminine","form-of","singular"]},{"pos":"noun","gloss":"hill"}]},"etymology":null,"ipa":["/qaːr.ra/","/qaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35341","headword_ar":"قَارَّهُ","root":"qr","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muqaAr~apN","text_ar":"مُقَارَّةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He settled, became fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quiet"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"still"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at rest, rested, remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, with him."},{"kind":"text","text":"(S, K.) You say"},{"kind":"arabic","text_bw":"A^anaA laA A^uqaAr~uka EalaY maA A^anota Ealayohi","text_ar":"اَنَا لَا اُقَارُّكَ عَلَى مَا اَنْتَ عَلَيْهِ"},{"kind":"italic_en","text":"I will not settle,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with thee in the state in which thou art."},{"kind":"text","text":"(TA.) And hence the saying of Ibn-Mes'ood,"},{"kind":"arabic","text_bw":"qaAr~uwA AlS~alaApa","text_ar":"قَارُّوا الصَّلَاةَ"},{"kind":"text","text":", (S, * K,) from"},{"kind":"arabic","text_bw":"AlqaraAru","text_ar":"القَرَارُ"},{"kind":"text","text":", not from"},{"kind":"arabic","text_bw":"AlwaqaAru","text_ar":"الوَقَارُ"},{"kind":"text","text":", (S,) meaning,"},{"kind":"italic_en","text":"Be ye still, without motion, and without play, during prayer."},{"kind":"text","text":"(TA.)"}],"source_refs":["S"]},{"entry_id":"n36401","headword_ar":"قَارَةٌ","root":"qwr","body":[{"kind":"italic_en","text":"A small mountain separate from other mountains:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a small mountain upon another mountain:"},{"kind":"text","text":"such [or"},{"kind":"italic_en","text":"a knoll of a mountain"},{"kind":"text","text":"] seems to be meant by"},{"kind":"arabic","text_bw":"qaArapu jabalK","text_ar":"قَارَةُ جَبَلٍ"},{"kind":"text","text":":) (TA:) or the"},{"kind":"italic_en","text":"smallest of mountains:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"a small, black, isolated mountain, resembling an"},{"kind":"arabic","text_bw":"A^akamapN","text_ar":"اَكَمَةٌ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"a black"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^akamapN","text_ar":"اَكَمَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a hill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mound,"},{"kind":"text","text":"&c.]: (S:) or the"},{"kind":"italic_en","text":"smallest of mountains and"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"largest of"},{"kind":"arabic","text_bw":"A=kaAm","text_ar":"ا=كَام"},{"kind":"text","text":";"},{"kind":"italic_en","text":"scattered, rough, and abounding with stones:"},{"kind":"text","text":"(Lth:) or"},{"kind":"italic_en","text":"a small mountain, slender, compact, and lofty, not extending along the surface of the ground, as though it were a collection of stones, and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sometimes"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"great, and round:"},{"kind":"text","text":"(ISh:) or"},{"kind":"italic_en","text":"a great rock,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"smaller than a mountain:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a black rock:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a tract of ground containing black stones;"},{"kind":"text","text":"(K, TA;) i. e.,"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"Har~ap","text_ar":"حَرَّة"},{"kind":"text","text":": (TA:) pl."},{"kind":"arabic","text_bw":"qaArN","text_ar":"قَارٌ"},{"kind":"text","text":", (S, K,) [or rather this is a coll. gen. n.,] and"},{"kind":"arabic","text_bw":"qaAraAtN","text_ar":"قَارَاتٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"quwrN","text_ar":"قُورٌ"},{"kind":"text","text":"(Lth, S, A, K) and"},{"kind":"arabic","text_bw":"qiyraAnN","text_ar":"قِيرَانٌ"},{"kind":"text","text":". (Lth, K.)"}],"source_refs":["K","TA","A","S","Lth","ISh"]},{"entry_id":"n42868","headword_ar":"قَارَةٌ","root":"qwr","body":[{"kind":"italic_en","text":"A she-bear:"},{"kind":"text","text":"see an ex. in art."},{"kind":"arabic","text_bw":"fTn","text_ar":"فطن"},{"kind":"text","text":"(conj. 2)."}],"source_refs":[]}]},"classical_definitions":null}