{"lemma":"أَحْوَجَ","slug":"أَحْوَجَ","root":"ح.#.ج","root_slug":"ح-_-ج","root_link":"/words/roots/ح-_-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n9425"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AD%D9%92%D9%88%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to need, to want, to require"},{"pos":"verb","gloss":"to require"},{"pos":"verb","gloss":"to compel, to oblige"},{"pos":"verb","gloss":"to impoverish, to reduce to poverty"},{"pos":"adj","gloss":"in greater need"}]},"etymology":null,"ipa":["/ʔaħ.wa.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9425","headword_ar":"اَحْوَجَ","root":"Hwj","body":[{"kind":"text","text":": see 1.       -A2-  It is also transitive. (Msb.) You say,"},{"kind":"arabic","text_bw":"A^aHowajahu A_ilayohi gayoruhu","text_ar":"اَحْوَجَهُ اـِلَيْهِ غَيْرُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Another made him to want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be in need of, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"A^aHowajaniY","text_ar":"اَحْوَجَنِى"},{"kind":"arabic","text_bw":"A_ilayokumo zamaAnu Als~uwo'i","text_ar":"اـِلَيْكُمْ زَمَانُ السُّوْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Evil time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil fortune, made me to be in need of thee"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"laA A^aHowajaniY","text_ar":"لَا اَحْوَجَنِى"},{"kind":"arabic","text_bw":"A@ll~`hu A_ilaY fulaAnK","text_ar":"ا@للّٰهُ اـِلَى فُلَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God not cause me to want such a one"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^uHowijotu A_ilayohi","text_ar":"اُحْوِجْتُ اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was caused to want him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"A^aHowajahu","text_ar":"اَحْوَجَهُ"},{"kind":"arabic","text_bw":"A@ll~`hu A_ilaY ka*aA","text_ar":"ا@للّٰهُ اـِلَى كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God caused him to want such a thing"},{"kind":"text","text":"]. (Msb.)"}],"source_refs":[]}]},"classical_definitions":null}