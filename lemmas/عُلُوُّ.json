{"lemma":"عُلُوُّ","slug":"عُلُوُّ","root":"ع.ل.#","root_slug":"ع-ل-_","root_link":"/words/roots/ع-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"عُلُوّ","root":"علو","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n30402","n30403","n30404","n30420","n30421"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D9%84%D9%8F%D9%88%D9%8F%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of عَلَا (ʕalā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"highness, elevation"},{"pos":"noun","gloss":"altitude"}]},"etymology":null,"ipa":["/ʕu.luww/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30402","headword_ar":"عَلْوٌ","root":"Elw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EulowN","text_ar":"عُلْوٌ"},{"kind":"text","text":"in five places. ―         -b2-  Also"},{"kind":"italic_en","text":"A high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an elevated, state of the base,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foundation, of a building."},{"kind":"text","text":"(TA.) ―         -b3-  And you say,"},{"kind":"arabic","text_bw":"A^axa*ahu EalowFA","text_ar":"اَخَذَهُ عَلْوًا"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He took him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, by force."},{"kind":"text","text":"(K, TA.) See also the next but one of the preceding paragraphs."}],"source_refs":[]},{"entry_id":"n30403","headword_ar":"عُلْوٌ","root":"Elw","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EilowN","text_ar":"عِلْوٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EalowN","text_ar":"عَلْوٌ","orth_type":"arrow"},{"kind":"text","text":"(K) signify The"},{"kind":"italic_en","text":"higher,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest, part"},{"kind":"text","text":"(S, Msb, K) of a house, or an abode, (S, Msb,) or of a thing; (K;) as also ↓"},{"kind":"arabic","text_bw":"EilowapN","text_ar":"عِلْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K voce"},{"kind":"arabic","text_bw":"sufolN","text_ar":"سُفْلٌ"},{"kind":"text","text":") and ↓"},{"kind":"arabic","text_bw":"EulaAwapN","text_ar":"عُلَاوَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaAliyapN","text_ar":"عَالِيَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K in the present art.) You say,"},{"kind":"arabic","text_bw":"qaEadotu","text_ar":"قَعَدْتُ"},{"kind":"arabic","text_bw":"Eulowahu","text_ar":"عُلْوَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eilowahu","text_ar":"عِلْوَهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiY Eulowihi","text_ar":"فِى عُلْوِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fY Eilowihi","text_ar":"فى عِلْوِهِ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I sat in the higher,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest, part of it"},{"kind":"text","text":"]. (TA.) And Aashà-Báhileh says,"},{"kind":"quote","text":"A_in~iY A^atanoniY lisaAnN laA A^usar~u bihaA\n                      \n                     \n                        laA EajabN minohaA walaA suxuru ↓mino Ealowa"},{"kind":"text","text":"(S,) or, as in one of my copies of the S,"},{"kind":"arabic","text_bw":"A^asur~u","text_ar":"اَسُرُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saxaru","text_ar":"سَخَرُ"},{"kind":"text","text":",) i. e."},{"kind":"italic_en","text":"Verily information has come to me"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by which I shall not be rejoiced"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"by which I shall not rejoice"},{"kind":"text","text":"others, accord. to the latter reading mentioned above,)]"},{"kind":"italic_en","text":"from the higher,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest, parts of Nejd,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mino A^aEolaY najodK","text_ar":"مِنْ اَعْلَى نَجْدٍ"},{"kind":"text","text":", thus in some copies of the S and in the TA, but in other copies of the S the word"},{"kind":"arabic","text_bw":"najodK","text_ar":"نَجْدٍ"},{"kind":"text","text":"is omitted,) ["},{"kind":"italic_en","text":"at which there is no wondering, as at a thing that is improbable, nor any scoffing;"},{"kind":"text","text":"] related [thus] with fet-h to the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"and with damm thereto and with kesr thereto [i. e."},{"kind":"arabic","text_bw":"Ealowa","text_ar":"عَلْوَ"},{"kind":"text","text":"as above and also ↓"},{"kind":"arabic","text_bw":"Ealowu","text_ar":"عَلْوُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ealowi","text_ar":"عَلْوِ","orth_type":"arrow"},{"kind":"text","text":"]. (S, TA.) ―         -b2-  One says also,"},{"kind":"arabic","text_bw":"h`*aA $iEoru Eulow","text_ar":"هٰذَا شِعْرُ عُلْو"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"EulowK","text_ar":"عُلْوٍ"},{"kind":"text","text":"], meaning (assumed tropical:)"},{"kind":"italic_en","text":"This is poetry of a high class:"},{"kind":"text","text":"or [the last word may be ↓"},{"kind":"arabic","text_bw":"Ealowa","text_ar":"عَلْوَ","orth_type":"arrow"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Ealowu","text_ar":"عَلْوُ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Ealowi","text_ar":"عَلْوِ"},{"kind":"text","text":", for it may mean],"},{"kind":"italic_en","text":"of the higher,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"highest, part of Nejd."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n30404","headword_ar":"عِلْوٌ","root":"Elw","body":[{"kind":"text","text":": see the next preceding paragraph, in three places."}],"source_refs":[]},{"entry_id":"n30420","headword_ar":"عَلُوٌّ","root":"Elw","body":[{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Eaduw~N","text_ar":"عَدُوٌّ"},{"kind":"text","text":"[in measure], an epithet used in the phrase"},{"kind":"arabic","text_bw":"rajulN Ealuw~N lilr~ijaAli","text_ar":"رَجُلٌ عَلُوٌّ لِلرِّجَالِ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"A man wont to exalt himself to"},{"kind":"text","text":"other"},{"kind":"italic_en","text":"men"},{"kind":"text","text":"]. (TA.)"}],"source_refs":[]},{"entry_id":"n30421","headword_ar":"عُلُوٌّ","root":"Elw","body":[{"kind":"text","text":": [see 1, of which it is an inf. n., and] see"},{"kind":"arabic","text_bw":"EiliY~N","text_ar":"عِلِىٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]}}