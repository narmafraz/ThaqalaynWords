s":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِيثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرُثْنَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرِثْنَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رِثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رِثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رُثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رُثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرُوث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُوث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرِيث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرِيث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":128,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n16962","n17222"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dung, to drop ordure (said especially of a solid-hoofed animal)"},{"pos":"verb","gloss":"to tarry, to linger, to be slow","examples":[{"text":"اِنْتَظَرْنَا الْحَسَنَ وَرَاثَ عَلَيْنَا حَتَّى قَرُبْنَا مِنْ وَقْتِ قِيَامِهِ","english":"We expected Al-Ḥasan and he let us wait until the very time."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16962","headword_ar":"رَاثَ","root":"rwv","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"arabic","text_bw":"yaruwvu","text_ar":"يَرُوثُ"},{"kind":"text","text":", (T, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"rawovN","text_ar":"رَوْثٌ"},{"kind":"text","text":", (T, M, A, Msb,) said of a horse (S, Msb, K) and the like, (Msb,) [i. e.] of a solid-hoofed animal (T, M, A) of any kind, (T,)"},{"kind":"italic_en","text":"He dunged."},{"kind":"text","text":"(M, Msb. *) It is said in a prov.,"},{"kind":"arabic","text_bw":"A^aHu$~uka wa taruwvuniY","text_ar":"اَحُشُّكَ وَ تَرُوثُنِى"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"A^aHu$~uki wa taruwviynaniY","text_ar":"اَحُشُّكِ وَ تَرُوثِينَنِى"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"H$","text_ar":"حش"},{"kind":"text","text":", in which it is explained.)"}],"source_refs":["T","A","Msb","M","S","K"]},{"entry_id":"n17222","headword_ar":"رَاثَ","root":"ryv","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"arabic","text_bw":"yariyvu","text_ar":"يَرِيثُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"rayovN","text_ar":"رَيْثٌ"},{"kind":"text","text":", (S, M, A, Mgh, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slow, tardy, dilatory, late,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"backward;"},{"kind":"text","text":"(T, S, M, A, Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"try~v","text_ar":"تريّث","orth_type":"arrow"},{"kind":"text","text":". (T, K.) You say,"},{"kind":"arabic","text_bw":"raAva EalaY~a xabaruka","text_ar":"رَاثَ عَلَىَّ خَبَرُكَ"},{"kind":"text","text":", (S, A,) or"},{"kind":"arabic","text_bw":"rAv EalayonaA xabaruhu","text_ar":"راث عَلَيْنَا خَبَرُهُ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"Thy news"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the news of thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his news"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the news of him, was slow,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in coming to me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to us."},{"kind":"text","text":"(T, S, A.) And"},{"kind":"arabic","text_bw":"EalayonaA fulaAnN","text_ar":"عَلَيْنَا فُلَانٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"try~v","text_ar":"تريّث","orth_type":"arrow"},{"kind":"italic_en","text":"Such a one was slow,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in coming to us."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"rub~a EajalapK wa habato rayovFA","text_ar":"رُبَّ عَجَلَةٍ وَ هَبَتْ رَيْثًا"},{"kind":"text","text":", or, accord. to one relation of the saying,"},{"kind":"arabic","text_bw":"tahabu rayovFA","text_ar":"تَهَبُ رَيْثًا"},{"kind":"text","text":", the meaning in both cases being the same, from"},{"kind":"arabic","text_bw":"Alhibapu","text_ar":"الهِبَةُ"},{"kind":"text","text":"; [i. e."},{"kind":"italic_en","text":"Many an act of haste causes"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"gives"},{"kind":"text","text":")"},{"kind":"italic_en","text":"slowness,"},{"kind":"text","text":"&c.;] (S;) or"},{"kind":"arabic","text_bw":"tuEoqibu rayovFA","text_ar":"تُعْقِبُ رَيْثًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"occasions, as its result, slowness,"},{"kind":"text","text":"&c.]: (A:) a proverb. (S, A.) And it appears from the following saying of Maakil Ibn-Khuweylid,"},{"kind":"quote","text":"laEamoruka laloyaA^osu gayoru Almuriyvi xayorN mina AlT~amaEi AlkaA*ibi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By thy life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by thy religion, assuredly despair that is not slow"},{"kind":"text","text":"in its issue"},{"kind":"italic_en","text":"is better than hope that gives a false promise,"},{"kind":"text","text":"if this be his meaning,] that ↓"},{"kind":"arabic","text_bw":"ArAv","text_ar":"اراث","orth_type":"arrow"},{"kind":"text","text":"may be a dial. var. of"},{"kind":"arabic","text_bw":"raAva","text_ar":"رَاثَ"},{"kind":"text","text":": but the poet may mean ["},{"kind":"italic_en","text":"that does not make"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"slow,"},{"kind":"text","text":"i. e.]"},{"kind":"arabic","text_bw":"gayoru Almuriyvi Almaro'a","text_ar":"غَيْرُ المُرِيثِ المَرْءَ"},{"kind":"text","text":". (M.)"}],"source_refs":["S","Msb","M","A","Mgh","K","T"]}]},"classical_definitions":null}