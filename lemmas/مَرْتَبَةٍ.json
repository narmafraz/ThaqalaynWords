lic_en","text":"upon which are stationed"},{"kind":"text","text":"(↓"},{"kind":"arabic","text_bw":"turabu","text_ar":"تُرَبُ","orth_type":"arrow"},{"kind":"text","text":")"},{"kind":"italic_en","text":"scouts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spies:"},{"kind":"text","text":"(T, S:) or"},{"kind":"italic_en","text":"places to which scouts ascend, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon, mountains."},{"kind":"text","text":"(A.) ―         -b3-  The pl. also signifies"},{"kind":"italic_en","text":"Narrow and rugged parts of valleys."},{"kind":"text","text":"(TA from a trad.) ―         -b4-  And the sing.,"},{"kind":"italic_en","text":"Any difficult station"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"position."},{"kind":"text","text":"(M.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"ratabN","text_ar":"رَتَبٌ"},{"kind":"text","text":", in two places. ―         -b6-  [In post-classical works, and in the language of the present day, it is applied to"},{"kind":"italic_en","text":"A mattress, upon which to sit or recline or lie; such as is spread upon a couch-frame or upon the ground."},{"kind":"text","text":"]"}],"source_refs":["S","T"]}]},"classical_definitions":null}