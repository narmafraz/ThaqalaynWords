{"lemma":"شَرِيطٌ","slug":"شَرِيطٌ","root":"ش.ر.ط","root_slug":"ش-ر-ط","root_link":"/words/roots/ش-ر-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["n22125"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%90%D9%8A%D8%B7%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"rope, string, cord (originally of palm bast)"},{"pos":"noun","gloss":"tape, ribbon, band"},{"pos":"noun","gloss":"clipping of شَرِيط ڤِيدْيُو (šarīṭ vīdyū, “videotape”)","tags":["abbreviation","alt-of","clipping"]},{"pos":"noun","gloss":"strip"},{"pos":"noun","gloss":"leash, line"},{"pos":"noun","gloss":"thong, strap"},{"pos":"noun","gloss":"lacework, fringe, galloon"},{"pos":"noun","gloss":"iron wire"},{"pos":"noun","gloss":"railway track, railway line"},{"pos":"noun","gloss":"film, film strip"},{"pos":"noun","gloss":"chest, trunk"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22125","headword_ar":"شَرِيطٌ","root":"$rT","body":[{"kind":"italic_en","text":"A rope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cord, of twisted palm-leaves:"},{"kind":"text","text":"(S, Msb:) and"},{"kind":"italic_en","text":"threads of wool"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of fibres of the palm-tree"},{"kind":"text","text":"["},{"kind":"italic_en","text":"twisted together"},{"kind":"text","text":"]: (TA:) or"},{"kind":"italic_en","text":"palmleaves twisted together, with which is woven"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yu$oraTu","text_ar":"يُشْرَطُ"},{"kind":"text","text":", as in the K, or, as in the O, accord. to the TA,"},{"kind":"arabic","text_bw":"yu$oraHu","text_ar":"يُشْرَحُ"},{"kind":"text","text":", [app. a mistake for"},{"kind":"arabic","text_bw":"yu$oraju","text_ar":"يُشْرَجُ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"a couch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bier,"},{"kind":"text","text":"[app. meaning the part thereof upon which a man or corpse lies,] and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(O, K:) so called because its palm-leaves are split, and then twisted together: if of fibres of the palm-tree, it is called"},{"kind":"arabic","text_bw":"disaArN","text_ar":"دِسَارٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"a wide rope"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flat plait"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"woven of fibres"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaves of the palm-tree:"},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"qmT","text_ar":"قمط"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"a rope of any kind:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"$araAy^iTu","text_ar":"شَرَايِطُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$uruTN","text_ar":"شُرُطٌ"},{"kind":"text","text":". (TA.) Also"},{"kind":"italic_en","text":"Threads of silk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of silk and of gold, twisted together"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"woven, so as to form a kind of flat lace, like tape"},{"kind":"text","text":"]: so called as being likened to the threads of wool and of fibres of the palm-tree [twisted together]. (TA.) ―         -b2-  Also The ["},{"kind":"italic_en","text":"sort of basket,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small box, called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Eatiydap","text_ar":"عَتِيدَة"},{"kind":"italic_en","text":"in which a woman puts her perfumes"},{"kind":"text","text":"(IAar, O, K)"},{"kind":"italic_en","text":"and her utensils"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apparatus."},{"kind":"text","text":"(IAar, O.) And The ["},{"kind":"italic_en","text":"sort of receptacle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Eayobap","text_ar":"عَيْبَة"},{"kind":"text","text":"[q. v.]. (IAar, O.)"}],"source_refs":["S","Msb","TA","O","K","IAar"]}]},"classical_definitions":null}