{"lemma":"كَدَرِ","slug":"كَدَرِ","root":"ك.د.ر","root_slug":"ك-د-ر","root_link":"/words/roots/ك-د-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":13},"lanes":{"found":true,"entry_ids":["n36746","n36749","n36750","n36751"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D8%AF%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be muddy, to be turbid"},{"pos":"verb","gloss":"to be gloomy, to be dull, to be depressing","examples":[{"text":"كَدِرَ عَيْشُهُ","english":"His life became troublesome."}]},{"pos":"verb","gloss":"to render turbid"},{"pos":"verb","gloss":"to pester, to distress or depress"},{"pos":"noun","gloss":"verbal noun of كَدِرَ (kadira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"muddiness, turbidity, tarnish"},{"pos":"noun","gloss":"grief, sorrow, sadness, distress"},{"pos":"noun","gloss":"lumps of soil","tags":["collective"]},{"pos":"adj","gloss":"disturbed, worried"},{"pos":"adj","gloss":"dirty, muddy, dark"},{"pos":"adj","gloss":"common plural of أَكْدَر (ʔakdar)","tags":["common","form-of","plural"]},{"pos":"verb","gloss":"to throw down, to hurl","tags":["rare"]},{"pos":"adj","gloss":"eurysome","tags":["poetic"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36746","headword_ar":"كَدِرَ","root":"kdr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"kadura","text_ar":"كَدُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, A, Msb, K, &c.;) and"},{"kind":"arabic","text_bw":"kadara","text_ar":"كَدَرَ"},{"kind":"text","text":"; (Sgh, K;) but this last is said in the L to be allowable only as signifying “ he poured out ” water; (TA;) inf. n."},{"kind":"arabic","text_bw":"kadarN","text_ar":"كَدَرٌ"},{"kind":"text","text":", (S, A, Msb, K,) of the first, (S, Msb,) or second, (TA,) and"},{"kind":"arabic","text_bw":"kuduwrapN","text_ar":"كُدُورَةٌ"},{"kind":"text","text":", (S, A, Msb, K,) of the second, (S, Msb,) and"},{"kind":"arabic","text_bw":"kadaArapN","text_ar":"كَدَارَةٌ"},{"kind":"text","text":", (K,) also of the second, (TA,) and"},{"kind":"arabic","text_bw":"kuduwrN","text_ar":"كُدُورٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"kudorapN","text_ar":"كُدْرَةٌ"},{"kind":"text","text":", (K,) or the last is a simple subst.; (TA;) and ↓"},{"kind":"arabic","text_bw":"tkd~r","text_ar":"تكدّر","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"Akdr~","text_ar":"اكدرّ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ikodiraArN","text_ar":"اـِكْدِرَارٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Ankdr","text_ar":"انكدر","orth_type":"arrow"},{"kind":"text","text":"; (Bd lxxxi. 2;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water, S, Msb, &c.)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, turbid, thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"muddy; contr. of"},{"kind":"arabic","text_bw":"SafaA","text_ar":"صَفَا"},{"kind":"text","text":"; (S, A, K;)"},{"kind":"italic_en","text":"it ceased to be clear:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"kudorapN","text_ar":"كُدْرَةٌ"},{"kind":"text","text":"relates to colour, (K,) specially; (TA;) and"},{"kind":"arabic","text_bw":"kuduwrapN","text_ar":"كُدُورَةٌ"},{"kind":"text","text":", to water, (K,) and to life,"},{"kind":"arabic","text_bw":"AlEayo$","text_ar":"العَيْش"},{"kind":"text","text":"; in the K,"},{"kind":"arabic","text_bw":"AlEayon","text_ar":"العَيْن"},{"kind":"text","text":", but this is a mistake; (TA;) and"},{"kind":"arabic","text_bw":"kadarN","text_ar":"كَدَرٌ"},{"kind":"text","text":", to all of these. (K.) ―         -b2-"},{"kind":"arabic","text_bw":"kadira","text_ar":"كَدِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Lh, Msb,) inf. n."},{"kind":"arabic","text_bw":"kadarN","text_ar":"كَدَرٌ"},{"kind":"text","text":"(S, Msb) [and"},{"kind":"arabic","text_bw":"kudorapN","text_ar":"كُدْرَةٌ"},{"kind":"text","text":", (see above,)]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the complexion of a man, Lh) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a horse, &c., Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, of the colour termed"},{"kind":"arabic","text_bw":"kudorapN","text_ar":"كُدْرَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"dusky, dingy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclining to black and dust-colour"},{"kind":"text","text":"]. (Lh, S, Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"kadira","text_ar":"كَدِرَ"},{"kind":"arabic","text_bw":"Eayo$u fulaAnK","text_ar":"عَيْشُ فُلَانٍ"},{"kind":"text","text":", (S, A,) [inf. n."},{"kind":"arabic","text_bw":"kadarN","text_ar":"كَدَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kuduwrapN","text_ar":"كُدُورَةٌ"},{"kind":"text","text":"; (see above;)] and ↓"},{"kind":"arabic","text_bw":"tkd~r","text_ar":"تكدّر","orth_type":"arrow"},{"kind":"text","text":", (A,) (tropical:)  ["},{"kind":"italic_en","text":"The life of such a one became troublesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perturbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attended with trouble:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"maEiy$atuhu","text_ar":"مَعِيشَتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tkd~rt","text_ar":"تكدّرت","orth_type":"arrow"},{"kind":"text","text":"[signifies the same; or"},{"kind":"italic_en","text":"his means of living became attended with trouble"},{"kind":"text","text":"]. (S.) ―         -b4-"},{"kind":"arabic","text_bw":"xu*o maA SafaA wadaEo","text_ar":"خُذْ مَا صَفَا وَدَعْ"},{"kind":"arabic","text_bw":"maA kadira","text_ar":"مَا كَدِرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"kadura","text_ar":"كَدُرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"kadara","text_ar":"كَدَرَ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"Take thou what is free from trouble, and leave what is attended with trouble."},{"kind":"text","text":"] (IAar, L, Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"kadira EalaY~a","text_ar":"كَدِرَ عَلَىَّ"},{"kind":"arabic","text_bw":"fuw^aAduhu","text_ar":"فُوَادُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, became perturbed"},{"kind":"text","text":"by displeasure"},{"kind":"italic_en","text":"against me"},{"kind":"text","text":"]. (A, TA.) ―         -b6-  [And in like manner you say]"},{"kind":"arabic","text_bw":"ma*ohabuhu fY A@lomasoA^alapi","text_ar":"مَذْهَبُهُ فى ا@لْمَسْاَلَةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tkd~r","text_ar":"تكدّر","orth_type":"arrow"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"His opinion respecting the question became confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed"},{"kind":"text","text":"]. (Mgh.)       -A2-"},{"kind":"arabic","text_bw":"kadara","text_ar":"كَدَرَ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kadorN","text_ar":"كَدْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth"},{"kind":"text","text":"water. (K, TA.) Said in the L to be the only signification of this form of the verb. (TA.) [But see above.]"}],"source_refs":["S","A","Msb","K","TA","Lh"]},{"entry_id":"n36749","headword_ar":"كَدْرٌ","root":"kdr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"kadirN","text_ar":"كَدِرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n36750","headword_ar":"كَدَرٌ","root":"kdr","body":[{"kind":"text","text":"[a coll. gen. n., of which the n. of unity is"},{"kind":"arabic","text_bw":"kadarapN","text_ar":"كَدَرَةٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Handfuls of reaped corn:"},{"kind":"text","text":"(O, TA:) see"},{"kind":"arabic","text_bw":"EaSofN","text_ar":"عَصْفٌ"},{"kind":"text","text":"."}],"source_refs":["O","TA"]},{"entry_id":"n36751","headword_ar":"كَدِرٌ","root":"kdr","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"kadorN","text_ar":"كَدْرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"kadiyrN","text_ar":"كَدِيرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^akodaru","text_ar":"اَكْدَرُ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Turbid; thick; muddy:"},{"kind":"text","text":"(S, A, Msb, K) applied to water. (S, A, Msb.)       -A2-"},{"kind":"arabic","text_bw":"Eayo$N kadirN","text_ar":"عَيْشٌ كَدِرٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A^akodaru","text_ar":"اَكْدَرُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Life that is attended with trouble"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"huwa kadiru Alfuw^aAdi","text_ar":"هُوَ كَدِرُ الفُوَادِ"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is perturbed in heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind,"},{"kind":"text","text":"by displeasure"},{"kind":"italic_en","text":"against me"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","A","Msb","K"]}]},"classical_definitions":null}