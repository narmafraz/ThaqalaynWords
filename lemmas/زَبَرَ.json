{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["","n17373","n17374","n17375","n17377"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%A8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to apply stones to"},{"pos":"verb","gloss":"to scold, to chide"},{"pos":"verb","gloss":"to hinder, to repel"},{"pos":"verb","gloss":"to inscribe, to engrave, to write firmly"},{"pos":"verb","gloss":"to prune, to cut off some shoots from"},{"pos":"verb","gloss":"to prune, to cut off shoots from"},{"pos":"noun","gloss":"penis","tags":["vulgar"]},{"pos":"noun","gloss":"plural of زُبْرَة (zubra)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of زَبُور (zabūr)","tags":["form-of","plural"]},{"pos":"noun","gloss":"verbal noun of زَبَرَ (zabara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"stones"},{"pos":"noun","gloss":"alternative form of زَبُور (zabūr, “writing”)","tags":["alt-of","alternative"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17373","headword_ar":"زَبْرٌ","root":"zbr","body":[{"kind":"italic_en","text":"Stones."},{"kind":"text","text":"(K.) ―         -b2-  [The"},{"kind":"italic_en","text":"stone casing of the interior of a well:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":". ―         -b3-  And hence,] (tropical:)"},{"kind":"italic_en","text":"Understanding, intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence,"},{"kind":"text","text":"(S, A, K,) and"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"(TA,) and"},{"kind":"italic_en","text":"self-restraint:"},{"kind":"text","text":"(S, A:) originally an inf. n. [accord. to some; but this is evidently a mistake, as is shown by phrases in which it is coupled with"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":"]. (S.) One says,"},{"kind":"arabic","text_bw":"maA lahu zaborN","text_ar":"مَا لَهُ زَبْرٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He has not understanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence, nor self-restraint:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"judgment:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding to be relied upon."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"lahu zaborN wajuwlN","text_ar":"لَهُ زَبْرٌ وَجُولٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"maA fawoqa","text_ar":"مَا فَوْقَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa mazobuwrN","text_ar":"هُوَ مَزْبُورٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Aljuwli minohu waSulobN maA taHota Alz~abori mina Aljuwli","text_ar":"الجُولِ مِنْهُ وَصُلْبٌ مَا تَحْتَ الزَّبْرِ مِنَ الجُولِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":". One says also of the wind, when it veers, or shifts, and does not continue to blow from one point,"},{"kind":"arabic","text_bw":"layosa lahaA zaborN","text_ar":"لَيْسَ لَهَا زَبْرٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It has not steadiness"},{"kind":"text","text":"]. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"zibir~N","text_ar":"زِبِرٌّ"},{"kind":"text","text":"."}],"source_refs":["S","A","K","TA"]},{"entry_id":"n17374","headword_ar":"زِبْرٌ","root":"zbr","body":[{"kind":"text","text":"[A thing]"},{"kind":"italic_en","text":"written;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"zabiyrN","text_ar":"زَبِيرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) [or]"},{"kind":"italic_en","text":"a writing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"book;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"zabuwrN","text_ar":"زَبُورٌ","orth_type":"arrow"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"faEuwlN","text_ar":"فَعُولٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":", (S, Msb, K,) like"},{"kind":"arabic","text_bw":"rasuwlN","text_ar":"رَسُولٌ"},{"kind":"text","text":": (Msb, TA:)"},{"kind":"arabic","text_bw":"zabuwrN","text_ar":"زَبُورٌ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"any writing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"book:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any divine book with which it is difficult to become acquainted:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a book that is confined to intel-lectual science, exclusive of legal statutes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordinances:"},{"kind":"text","text":"(TA:) ↓"},{"kind":"arabic","text_bw":"Alz~abuwru","text_ar":"الزَّبُورُ","orth_type":"arrow"},{"kind":"text","text":"signifies particularly"},{"kind":"italic_en","text":"the Book"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the Psalms"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of David:"},{"kind":"text","text":"(S, Mgh, Msb, K:) and also, and"},{"kind":"arabic","text_bw":"lugapu Alz~abuwri","text_ar":"لُغَةُ الزَّبُورِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"the Syriac"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Hebrew"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"language:"},{"kind":"text","text":"(Mgh:) the pl. of"},{"kind":"arabic","text_bw":"ziborN","text_ar":"زِبْرٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"zubuwrN","text_ar":"زُبُورٌ"},{"kind":"text","text":"; (S, K;) and the pl. of ↓"},{"kind":"arabic","text_bw":"zabuwrN","text_ar":"زَبُورٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"zuburN","text_ar":"زُبُرٌ"},{"kind":"text","text":". (S, Msb, K.) It is said in the Kur [xxi. 105],"},{"kind":"arabic","text_bw":"walaqado katabonaA fiY","text_ar":"وَلَقَدْ كَتَبْنَا فِى"},{"kind":"arabic","text_bw":"mino baEodi A@l*~ikori","text_ar":"مِنْ بَعْدِ ا@لذِّكْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A@lz~abuwri","text_ar":"ا@لزَّبُورِ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"And we have written in the book sent down to David, after the"},{"kind":"arabic","text_bw":"taworaAp","text_ar":"تَوْرَاة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Book of the Law revealed to Moses"},{"kind":"text","text":"]: (Aboo-Hureyreh, TA:) Sa'eed Ibn-Jubeyr read"},{"kind":"page_break","n":1211},{"kind":"arabic","text_bw":"Alz~ubuwr","text_ar":"الزُّبُور"},{"kind":"text","text":", [pl. of"},{"kind":"arabic","text_bw":"Alz~iboru","text_ar":"الزِّبْرُ"},{"kind":"text","text":",] and said that it means"},{"kind":"italic_en","text":"the Book of the Law revealed to Moses"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AltwrAp","text_ar":"التوراة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and the Gospel and the Kur-án"},{"kind":"text","text":"["},{"kind":"italic_en","text":"together"},{"kind":"text","text":"]; and that"},{"kind":"arabic","text_bw":"Al*kr","text_ar":"الذكر"},{"kind":"text","text":"means what is in heaven: (TA:) and some also read"},{"kind":"arabic","text_bw":"zubuwrFA","text_ar":"زُبُورًا"},{"kind":"text","text":"in the Kur iv. 161 and xvii. 57. (S, TA.)"}],"source_refs":["K","S","Msb","TA","Mgh"]},{"entry_id":"n17375","headword_ar":"زَبَرٌ","root":"zbr","body":[{"kind":"text","text":", syn. with"},{"kind":"arabic","text_bw":"zawobarN","text_ar":"زَوْبَرٌ"},{"kind":"text","text":"&c.: see"},{"kind":"arabic","text_bw":"ziy^obirN","text_ar":"زِيْبِرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n17377","headword_ar":"زِبِرٌّ","root":"zbr","body":[{"kind":"text","text":", applied to a lion, (S, TA,) and to a man, (TA,)"},{"kind":"italic_en","text":"Strong;"},{"kind":"text","text":"(AA, S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"zaborN","text_ar":"زَبْرٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":["S","TA"]}]},"classical_definitions":null}