{"lemma":"أَعْظَمَيْ","slug":"أَعْظَمَيْ","root":"ع.ظ.م","root_slug":"ع-ظ-م","root_link":"/words/roots/ع-ظ-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَعْظَم","root":"عظم","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n29669"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%B8%D9%8E%D9%85%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"elative degree of عَظِيم (ʕaẓīm):; greater; greatest"},{"pos":"adj","gloss":"elative degree of عَظِيم (ʕaẓīm):; more important; most important"},{"pos":"adj","gloss":"supreme, paramount"}]},"etymology":{"source":"wiktextract","text":"Elative of عَظِيم (ʕaẓīm, “great”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29669","headword_ar":"اعظم","root":"EZm","body":[{"kind":"text","text":"as intrans.: see 1, former half.       -A2-"},{"kind":"arabic","text_bw":"AEZmhu","text_ar":"اعظمهُ"},{"kind":"text","text":": see 2: ―         -b2-  and 10, in two places. ―         -b3-  One says also,"},{"kind":"arabic","text_bw":"A^aEoZamaniY maA qulota","text_ar":"اَعْظَمَنِى مَا قُلْتَ"},{"kind":"text","text":", meaning ↓"},{"kind":"arabic","text_bw":"hAlaniY waEaZuma","text_ar":"هالَنِى وَعَظُمَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"EalaY~a","text_ar":"عَلَىَّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"What thou saidst frightened me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified me, and was grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, in its effect upon me"},{"kind":"text","text":"(like"},{"kind":"arabic","text_bw":"kabura EalaY~a","text_ar":"كَبُرَ عَلَىَّ"},{"kind":"text","text":")]: and ↓"},{"kind":"arabic","text_bw":"maA yaEoZumuniY","text_ar":"مَا يَعْظُمُنِى","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^ano A^afoEala *`lika","text_ar":"اَنْ اَفْعَلَ ذٰلِكَ"},{"kind":"text","text":"[if not a mistranscription for"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"arabic","text_bw":"yuEoZimuniY","text_ar":"يُعْظِمُنِى"},{"kind":"text","text":"], meaning"},{"kind":"arabic","text_bw":"maA yahuwluniY","text_ar":"مَا يَهُولُنِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My doing that will not frighten me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrify me"},{"kind":"text","text":"]. (TA.)       -A3-"},{"kind":"arabic","text_bw":"AEZm","text_ar":"اعظم"},{"kind":"arabic","text_bw":"Alkaloba","text_ar":"الكَلْبَ"},{"kind":"text","text":": see 1, last sentence but one."}],"source_refs":[]}]}}