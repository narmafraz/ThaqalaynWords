l,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29948","headword_ar":"عَقَصٌ","root":"EqS","body":[{"kind":"text","text":"[app. an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"EaqiSa","text_ar":"عَقِصَ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"A twisting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contortion,"},{"kind":"text","text":"in the horn of a sheep or goat: (A:) or"},{"kind":"italic_en","text":"a twisting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contortion, of the horns of a goat, upon his ears, backwards."},{"kind":"text","text":"(S.)"}],"source_refs":["A"]},{"entry_id":"n29949","headword_ar":"عَقِصٌ","root":"EqS","body":[{"kind":"italic_en","text":"Sand accumulated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"congested, in which there is no way:"},{"kind":"text","text":"(S, O, K:) said to be syn. with"},{"kind":"arabic","text_bw":"EaqidN","text_ar":"عَقِدٌ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"EaqaSapN","text_ar":"عَقَصَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"sand like such as is termed"},{"kind":"arabic","text_bw":"silosilapN","text_ar":"سِلْسِلَةٌ"},{"kind":"text","text":"[q. v.]; or"},{"kind":"arabic","text_bw":"EaqaSapN","text_ar":"عَقَصَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaqiSapN","text_ar":"عَقِصَةٌ","orth_type":"arrow"},{"kind":"text","text":", as expl. by Aboo-'Alee, signify"},{"kind":"italic_en","text":"sand contorted, one part upon another, and extended;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EaqadapN","text_ar":"عَقَدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaqidapN","text_ar":"عَقِدَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And The"},{"kind":"italic_en","text":"neck of the"},{"kind":"arabic","text_bw":"kari$","text_ar":"كَرِش"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stomach of a ruminant animal"},{"kind":"text","text":"]. (IF, O, K. [In the CK, for"},{"kind":"arabic","text_bw":"waEunuqu Alkari$i","text_ar":"وَعُنُقُ الكَرِشِ"},{"kind":"text","text":"is erroneously put"},{"kind":"arabic","text_bw":"wkEunuqK Alkari$u","text_ar":"وكعُنُقٍ الكَرِشُ"},{"kind":"text","text":"; after which a"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"should have been inserted.]) ―         -b3-  Also, (S, O, K,) and ↓"},{"kind":"arabic","text_bw":"Eiq~iySN","text_ar":"عِقِّيصٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K,) and ↓"},{"kind":"arabic","text_bw":"EayoqaSN","text_ar":"عَيْقَصٌ","orth_type":"arrow"},{"kind":"text","text":", (IDrd, O, K,) and ↓"},{"kind":"arabic","text_bw":"A^aEoqaSu","text_ar":"اَعْقَصُ","orth_type":"arrow"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"Niggardly, stingy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"close-handed,"},{"kind":"text","text":"(S, O, K, TA,) and"},{"kind":"italic_en","text":"evil in disposition:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"EqyS","text_ar":"عقيص"},{"kind":"text","text":"[app. ↓"},{"kind":"arabic","text_bw":"Eiq~iySN","text_ar":"عِقِّيصٌ","orth_type":"arrow"},{"kind":"text","text":", or perhaps ↓"},{"kind":"arabic","text_bw":"EaqiySN","text_ar":"عَقِيصٌ","orth_type":"arrow"},{"kind":"text","text":",] signifies"},{"kind":"italic_en","text":"evil and perverse in disposition."},{"kind":"text","text":"(TA.)"},{"kind":"page_break","n":2112}],"source_refs":["S","O","K","IDrd","TA"]}]},"classical_definitions":null}