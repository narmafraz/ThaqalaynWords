ind":"italic_en","text":"of wailing"},{"kind":"text","text":"]: so, accord. to some, in the verse cited in the second paragraph [q. v.]. (O.)       -A4-  See also"},{"kind":"arabic","text_bw":"muEowalN","text_ar":"مُعْوَلٌ"},{"kind":"text","text":"."}],"source_refs":["S","O","TA"]}]},"classical_definitions":null}