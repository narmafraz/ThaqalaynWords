on":{"source":"lanes","entries":[{"entry_id":"n10199","headword_ar":"خَاذِلٌ","root":"x*l","body":[{"kind":"italic_en","text":"Abstaining from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglecting, the rendering of aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assistance."},{"kind":"text","text":"(S, K.) ―         -b2-  And Any one"},{"kind":"italic_en","text":"leaving, forsaking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deserting."},{"kind":"text","text":"(TA.) ―         -b3-  Also, and ↓"},{"kind":"arabic","text_bw":"xa*uwlN","text_ar":"خَذُولٌ","orth_type":"arrow"},{"kind":"text","text":", (T, K,) A female gazelle, and a [wild] cow,"},{"kind":"italic_en","text":"holding back from going with her female companions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining behind them, with her young one,"},{"kind":"text","text":"in the place of pasturage: or"},{"kind":"italic_en","text":"remaining alone with him:"},{"kind":"text","text":"(T:) or a female gazelle, &c., (K,) as, for instance, a [wild] cow, (TA,)"},{"kind":"italic_en","text":"holding back from going with her female companions, and remaining alone:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"holding back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining behind, not overtaking"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the others"},{"kind":"text","text":"]: (K:) or the latter signifies a female gazelle"},{"kind":"italic_en","text":"that has left, forsaken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deserted, her young ones."},{"kind":"text","text":"(EM p. 60.) ―         -b4-  And the former, A female gazelle"},{"kind":"italic_en","text":"remaining attending to her young one;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muxo*ilN","text_ar":"مُخْذِلٌ","orth_type":"arrow"},{"kind":"text","text":". (K. [See 1.]) ―         -b5-  Also"},{"kind":"italic_en","text":"Routed, defeated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put to flight."},{"kind":"text","text":"(IAar, K.)"}],"source_refs":["T","K","TA"]}]},"classical_definitions":null}