{"lemma":"قِرْدَيْ","slug":"قِرْدَيْ","root":"ق.ر.د","root_slug":"ق-ر-د","root_link":"/words/roots/ق-ر-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":18},"lanes":{"found":true,"entry_ids":["n35465","n35469","n35470","n35471"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%90%D8%B1%D9%92%D8%AF%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"monkey, ape (mammal)"},{"pos":"noun","gloss":"tick","tags":["collective"]},{"pos":"verb","gloss":"to collect, to gather, to hoard up"},{"pos":"verb","gloss":"to fall off from a sheep"},{"pos":"verb","gloss":"to be spoiled, to get matted, to become curly"},{"pos":"verb","gloss":"to be attacked by worms"},{"pos":"verb","gloss":"to be yellow"},{"pos":"verb","gloss":"to be or become speechless"},{"pos":"verb","gloss":"to be submissive, to be abject and humble"},{"pos":"verb","gloss":"to be or become speechless"},{"pos":"verb","gloss":"to make submissive, to make tractable"},{"pos":"verb","gloss":"to be submissive"},{"pos":"verb","gloss":"to delouse or detick a camel"},{"pos":"verb","gloss":"to beguile"},{"pos":"verb","gloss":"to wheedle, to cajole"},{"pos":"verb","gloss":"to wish one to blazes"},{"pos":"noun","gloss":"verbal noun of قَرَدَ (qarada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of قَرِدَ (qarida) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Ge'ez ቅርድ (ḳərd)."},"ipa":["/qird/","/qɪrd/","/qard/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35465","headword_ar":"قَرِدَ","root":"qrd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"qaradN","text_ar":"قَرَدٌ"},{"kind":"text","text":", (S, L),"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(wool)"},{"kind":"italic_en","text":"fell off by degrees from the sheep, and became compacted in lumps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clotted:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(wool, L, and hair, L, K)"},{"kind":"italic_en","text":"became contracted together,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"and knotted in its extremities;"},{"kind":"text","text":"(L;) as also ↓"},{"kind":"arabic","text_bw":"tqr~d","text_ar":"تقرّد","orth_type":"arrow"},{"kind":"text","text":". (L, K.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a tanned skin)"},{"kind":"italic_en","text":"became worm-eaten."},{"kind":"text","text":"(S, K.)       -A2-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent by reason of impotence of speech;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"Aqrd","text_ar":"اقرد","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qr~d","text_ar":"قرّد","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, abject,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive:"},{"kind":"text","text":"or, acc. to IAar ↓"},{"kind":"arabic","text_bw":"Aqrd","text_ar":"اقرد","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent by reason of abjectness:"},{"kind":"text","text":"[see also"},{"kind":"arabic","text_bw":"xrida","text_ar":"خرِدَ"},{"kind":"text","text":":] or, acc. to another,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still and abject."},{"kind":"text","text":"(TA.) See"},{"kind":"arabic","text_bw":"Aqrd","text_ar":"اقرد"},{"kind":"text","text":"below. The verbs are used in these senses because, when a raven or crow lights upon a camel and picks off the ticks ("},{"kind":"arabic","text_bw":"qrodaAn","text_ar":"قرْدَان"},{"kind":"text","text":"), the beast remains still on account of the ease which it occasions him. (TA.)       -A3-"},{"kind":"arabic","text_bw":"qarada","text_ar":"قَرَدَ"},{"kind":"text","text":", (L, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"qarodN","text_ar":"قَرْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He collected together, and gained,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"for his family."},{"kind":"text","text":"(L.) [You say]"},{"kind":"arabic","text_bw":"qarada fiY","text_ar":"قَرَدَ فِى"},{"kind":"arabic","text_bw":"Als~iqaA='i","text_ar":"السِّقَا=ءِ"},{"kind":"italic_en","text":"He collected clarified butter in the skin;"},{"kind":"text","text":"(L, K;) as also"},{"kind":"arabic","text_bw":"qarada samonFA fY Als~iqaA='i","text_ar":"قَرَدَ سَمْنًا فى السِّقَا=ءِ"},{"kind":"text","text":": (S, L:) or"},{"kind":"italic_en","text":"he collected milk in the skin."},{"kind":"text","text":"(L, K.) See also"},{"kind":"arabic","text_bw":"qalada","text_ar":"قَلَدَ"},{"kind":"text","text":"."}],"source_refs":["S","L","K"]},{"entry_id":"n35469","headword_ar":"قِرْدٌ","root":"qrd","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"ape;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"monkey;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"baboon;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain animal,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"well known:"},{"kind":"text","text":"(L, K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, L, Msb:) pl. [of pauc., of the masc.,]"},{"kind":"arabic","text_bw":"A^aqorudN","text_ar":"اَقْرُدٌ"},{"kind":"text","text":", (L, Msb,) and"},{"kind":"arabic","text_bw":"A^aqoraAdN","text_ar":"اَقْرَادٌ"},{"kind":"text","text":", (L, K,) and [of mult., of the same,]"},{"kind":"arabic","text_bw":"quruwdN","text_ar":"قُرُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qiradapN","text_ar":"قِرَدَةٌ"},{"kind":"text","text":", (S, L, Msb, K,) and [quasi-pl. n.]"},{"kind":"arabic","text_bw":"qaridapN","text_ar":"قَرِدَةٌ"},{"kind":"text","text":"; (K;) and pl. of the fem., (S, L, Msb,)"},{"kind":"arabic","text_bw":"qiradN","text_ar":"قِرَدٌ"},{"kind":"text","text":". (S, L, Msb, K.) Hence the proverb"},{"kind":"arabic","text_bw":"A^azonaY mino qirodK","text_ar":"اَزْنَى مِنْ قِرْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More incontinent than an ape"},{"kind":"text","text":"]; because the"},{"kind":"arabic","text_bw":"qirod","text_ar":"قِرْد"},{"kind":"text","text":"is the most incontinent of animals: (K:) such is generally said to be the meaning of this proverb: (TA:) or (accord. to A'Obeyd, S, L) by"},{"kind":"arabic","text_bw":"qrd","text_ar":"قرد"},{"kind":"text","text":"is here meant a man of the tribe of Hudheyl, named Kird, the son of Mo'áwiyeh. (S, L, K.)       -A2-"},{"kind":"arabic","text_bw":"Aibonu Alqirodi","text_ar":"اِبْنُ القِرْدِ"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Hawodal","text_ar":"حَوْدَل"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"bnY","text_ar":"بنى"},{"kind":"text","text":".)"}],"source_refs":["TA","L","K","S","Msb"]},{"entry_id":"n35470","headword_ar":"قَرَدٌ","root":"qrd","body":[{"kind":"text","text":"[a coll. gen. n.]"},{"kind":"italic_en","text":"Refuse of wool;"},{"kind":"text","text":"(L, K;) afterwards applied also to"},{"kind":"italic_en","text":"soft hair"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"wabar","text_ar":"وَبَر"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and other hair, and flax:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"soft hair and wool that fall off by degrees from the animals, and become compacted in lumps, or clotted:"},{"kind":"text","text":"(L, K:) or"},{"kind":"italic_en","text":"refuse of wool, and what falls off by degrees from the sheep, and becomes compacted in lumps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clotted:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"bad wool:"},{"kind":"text","text":"(R:) or the"},{"kind":"italic_en","text":"worst of wool and soft hair, and what is picked up thereof from the ground:"},{"kind":"text","text":"(Nh:) a piece thereof"},{"kind":"page_break","n":2513},{"kind":"text","text":"is termed"},{"kind":"arabic","text_bw":"qaradapN","text_ar":"قَرَدَةٌ"},{"kind":"text","text":". (S.) It is said in a proverb,"},{"kind":"arabic","text_bw":"Eakarato EalaY Algazoli biA^axarapK falamo tadaEo binajodK qaradapN","text_ar":"عَكَرَتْ عَلَى الغَزْلِ بِاَخَرَةٍ فَلَمْ تَدَعْ بِنَجْدٍ قَرَدَةٌ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"Eakarato","text_ar":"عَكَرَتْ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"EaTafato","text_ar":"عَطَفَتْ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"She returned to spinning at last, and left not in Nejd a piece of refuse of wool"},{"kind":"text","text":"]: (S, L:) in the K,"},{"kind":"arabic","text_bw":"Eavarato","text_ar":"عَثَرَتْ"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"Eakarato","text_ar":"عَكَرَتْ"},{"kind":"text","text":"; and both readings are mentioned by the relaters of proverbs: ["},{"kind":"arabic","text_bw":"Evrt ElY Algzl","text_ar":"عثرت على الغزل"},{"kind":"text","text":"app. signifies she applied herself by chance to spinning:] the proverb is applied to him who neglects a needful business when it is possible, and seeks to accomplish it when it is beyond his reach: (K:) its origin is the fact, that a woman neglects spinning while she finds that which she may spin, (of cotton or flax &c., L,) until, when it is beyond her reach, she seeks for refuse of wool among sweepings and rubbish. (L, K.) ―         -b2-  Also,"},{"kind":"italic_en","text":"Palmbranches stripped of their leaves:"},{"kind":"text","text":"n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (K.) ―         -b3-  Also,"},{"kind":"italic_en","text":"A thing like down, sticking to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"plant called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Turovuwv","text_ar":"طُرْثُوث"},{"kind":"text","text":". (K.) ―         -b4-  Also,"},{"kind":"italic_en","text":"Little things,"},{"kind":"text","text":"[i. e.,"},{"kind":"italic_en","text":"little flocks of clouds,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"less than"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"saHaAb","text_ar":"سَحَاب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"clouds in the common acceptation of the term"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not conjoined;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mutaqar~idN","text_ar":"مُتَقَرِّدٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) in some copies of the K ↓"},{"kind":"arabic","text_bw":"mutaqar~idapN","text_ar":"مُتَقَرِّدَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) See also"},{"kind":"arabic","text_bw":"qaridN","text_ar":"قَرِدٌ"},{"kind":"text","text":".       -A2-  Also,"},{"kind":"italic_en","text":"A hesitation in speech;"},{"kind":"text","text":"(El-Hejeree, L, K;) because a man who hesitates in his speech is silent respecting somewhat of that which he would say. (L.) See also"},{"kind":"arabic","text_bw":"qarida","text_ar":"قَرِدَ"},{"kind":"text","text":"."}],"source_refs":["L","K","S","R","Nh"]},{"entry_id":"n35471","headword_ar":"قَرِدٌ","root":"qrd","body":[{"kind":"text","text":"Wool"},{"kind":"italic_en","text":"sticking together,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"compacted in a lump"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lumps:"},{"kind":"text","text":"(A:) wool, and hair,"},{"kind":"italic_en","text":"contracted together,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"knotted in its extremities."},{"kind":"text","text":"(L.) ―         -b2-  [Hence,] a cloud, or collection of clouds,"},{"kind":"italic_en","text":"dissundered, in the tracts of the sky, in parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portions, one upon another; cirro-cumulus:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"of which the several portions are compacted together,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"one upon another;"},{"kind":"text","text":"likened to soft hair such as is thus termed: (M:) or compacted in lumps, not smooth; as also ↓"},{"kind":"arabic","text_bw":"mutaqar~idN","text_ar":"مُتَقَرِّدٌ","orth_type":"arrow"},{"kind":"text","text":". (AHn.) See also"},{"kind":"arabic","text_bw":"qaridN","text_ar":"قَرِدٌ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"qaridu AlxaSiyli","text_ar":"قَرِدُ الخَصِيلِ"},{"kind":"text","text":"A horse ["},{"kind":"italic_en","text":"compact in frame;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not lax."},{"kind":"text","text":"(L, K.)       -A2-  A camel [&c.] abounding with"},{"kind":"arabic","text_bw":"qirodaAn","text_ar":"قِرْدَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ticks"},{"kind":"text","text":"]. (K.)       -A3-  And"},{"kind":"arabic","text_bw":"qaridN","text_ar":"قَرِدٌ"},{"kind":"text","text":"[an epithet used as a subst.]"},{"kind":"italic_en","text":"Accumulated foam"},{"kind":"text","text":"which the camel casts forth from his mouth. (TA in art."},{"kind":"arabic","text_bw":"twj","text_ar":"توج"},{"kind":"text","text":". See an ex. in that art. voce"},{"kind":"arabic","text_bw":"mataAwiju","text_ar":"مَتَاوِجُ"},{"kind":"text","text":".)"}],"source_refs":["A","S","L","M","K"]}]}}