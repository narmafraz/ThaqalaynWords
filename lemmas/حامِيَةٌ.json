t", "text": "[or"}, {"kind": "italic_en", "text": "frogs"}, {"kind": "text", "text": "],"}, {"kind": "italic_en", "text": "like hard date-stones:"}, {"kind": "text", "text": "(Aboo-Dáwood, TA:) or the"}, {"kind": "italic_en", "text": "right and left sides of the solid hoof."}, {"kind": "text", "text": "(K.) ―         -b4-  [The pl. also signifies The"}, {"kind": "italic_en", "text": "sides of a mountain."}, {"kind": "text", "text": "(Freytag, from the Deewán of Jereer.)] ―         -b5-  Also, the sing.,"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "A^uvofiy~apN", "text_ar": "اُثْفِيَّةٌ"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "Any one of the three stones on which the cookingpot is placed"}, {"kind": "text", "text": "]: (AA, K:) pl. as above. (TA.) ―         -b6-"}, {"kind": "arabic", "text_bw": "maDayotu EalaY HaAmiyatiY", "text_ar": "مَضَيْتُ عَلَى حَامِيَتِى"}, {"kind": "text", "text": "means"}, {"kind": "italic_en", "text": "I went my own way."}, {"kind": "text", "text": "(Sgh, K.)"}], "source_refs": ["K", "TA", "ISh", "AO", "S", "AA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}