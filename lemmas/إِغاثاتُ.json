{"lemma":"إِغاثاتُ","slug":"إِغاثاتُ","root":"غ.#.ث","root_slug":"غ-_-ث","root_link":"/words/roots/غ-_-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n32590"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D8%BA%D8%A7%D8%AB%D8%A7%D8%AA%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32590","headword_ar":"اغاثهُ","root":"gwv","body":[{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_igaAvapN","text_ar":"اـِغَاثَةٌ"},{"kind":"text","text":"(Msb, K) and ↓"},{"kind":"arabic","text_bw":"maguwvapN","text_ar":"مَغُوثَةٌ","orth_type":"arrow"},{"kind":"text","text":"[which is anomalous], (K,)"},{"kind":"italic_en","text":"He aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succoured, him;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(i. e. God, Msb)"},{"kind":"italic_en","text":"removed from him trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction:"},{"kind":"text","text":"(Msb, TA:) ↓"},{"kind":"arabic","text_bw":"gaAvahu","text_ar":"غَاثَهُ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagiyvuhu","text_ar":"يَغِيثُهُ"},{"kind":"text","text":", is used in the sense of"},{"kind":"arabic","text_bw":"AgAvhu","text_ar":"اغاثهُ"},{"kind":"text","text":", but is rare, and is said [by some] to be from"},{"kind":"arabic","text_bw":"Algayovu","text_ar":"الغَيْثُ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"AlA_igaAvapu","text_ar":"الاـِغَاثَةُ"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"gAvhu","text_ar":"غاثهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaguwvuhu","text_ar":"يَغُوثُهُ"},{"kind":"text","text":", is mentioned by Az as not heard by him from any one; but ISd mentions"},{"kind":"arabic","text_bw":"gAvhu","text_ar":"غاثهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gawovN","text_ar":"غَوْثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"giyaAvN","text_ar":"غِيَاثٌ"},{"kind":"text","text":", though saying that"},{"kind":"arabic","text_bw":"AgAvhu","text_ar":"اغاثهُ"},{"kind":"text","text":"is more approved. (TA.) And one says also,"},{"kind":"arabic","text_bw":"A^agaAvanaA AlmaTaru","text_ar":"اَغَاثَنَا المَطَرُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The rain gave us relief"},{"kind":"text","text":"]. (Msb.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}