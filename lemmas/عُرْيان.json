{"lemma":"عُرْيان","slug":"عُرْيان","root":"ع.ر.#","root_slug":"ع-ر-_","root_link":"/words/roots/ع-ر-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28900"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8F%D8%B1%D9%92%D9%8A%D8%A7%D9%86"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"naked, nude"}]},"etymology":{"source":"wiktextract","text":"From عُرْي (ʕury, “nakedness”) + ـَان (-ān)."},"ipa":["/ʕur.jaːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28900","headword_ar":"عُرْيَانٌ","root":"ErY","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaArK","text_ar":"عَارٍ","orth_type":"arrow"},{"kind":"italic_en","text":"Naked, nude, bare,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without clothing;"},{"kind":"text","text":"(S, * MA, Mgh, * Msb, * K, TA;) applied to a man: (Msb, TA:) fem."},{"kind":"arabic","text_bw":"EuroyaAnapN","text_ar":"عُرْيَانَةٌ"},{"kind":"text","text":"(S, MA, Mgh, &c.) and ↓"},{"kind":"arabic","text_bw":"EaAriyapN","text_ar":"عَارِيَةٌ","orth_type":"arrow"},{"kind":"text","text":", (MA, Mgh, Msb, &c.,) applied to a woman: (S, Msb:) the pl. of"},{"kind":"arabic","text_bw":"EuroyaAnN","text_ar":"عُرْيَانٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EuroyaAnuwna","text_ar":"عُرْيَانُونَ"},{"kind":"text","text":"; (K;) and the pl. of ↓"},{"kind":"arabic","text_bw":"EaArK","text_ar":"عَارٍ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EuraApN","text_ar":"عُرَاةٌ"},{"kind":"text","text":", (Msb, K,) and that of"},{"kind":"arabic","text_bw":"EaAriyapN","text_ar":"عَارِيَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EaAriyaAtN","text_ar":"عَارِيَاتٌ"},{"kind":"text","text":". (Msb.) [Also, sometimes,"},{"kind":"italic_en","text":"Bare of clothing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his clothes, except one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more, of his inner garments."},{"kind":"text","text":"] See also"},{"kind":"arabic","text_bw":"EuroYN","text_ar":"عُرْىٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"EuroyaAnN","text_ar":"عُرْيَانٌ"},{"kind":"text","text":"applied to sand, (assumed tropical:)"},{"kind":"italic_en","text":"An extended and gibbous tract"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"naqFA","text_ar":"نَقًا"},{"kind":"text","text":"), or"},{"kind":"italic_en","text":"such as is accumulated and congested"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EaqidN","text_ar":"عَقِدٌ"},{"kind":"text","text":", in the CK"},{"kind":"arabic","text_bw":"EaqodN","text_ar":"عَقْدٌ"},{"kind":"text","text":"), of sand,"},{"kind":"italic_en","text":"having no trees upon it."},{"kind":"text","text":"(ISd, K, TA.) ―         -b3-  Applied to a plant, or to herbage, (assumed tropical:)"},{"kind":"italic_en","text":"Such as has become apparent."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"EuroyaAnu Aln~ajiY~i","text_ar":"عُرْيَانُ النَّجِىِّ"},{"kind":"text","text":"is an appellation applied to (assumed tropical:)"},{"kind":"italic_en","text":"A wife:"},{"kind":"text","text":"but in the A it is implied that it is used as denoting anyone"},{"kind":"italic_en","text":"who will not conceal a secret."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"EuroyaAnN","text_ar":"عُرْيَانٌ"},{"kind":"text","text":"applied to a horse signifies (assumed tropical:)"},{"kind":"italic_en","text":"Light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active, and quick; tall; and long in the legs."},{"kind":"text","text":"(K, TA. [Expl. in the K and TA by the words"},{"kind":"arabic","text_bw":"muqal~S Tawiyl","text_ar":"مُقَلّص طَوِيل"},{"kind":"text","text":"; to which is added in the TA"},{"kind":"arabic","text_bw":"AlqawaAy^im","text_ar":"القَوَايِم"},{"kind":"text","text":": the first of these words I find written, in copies of the K, only"},{"kind":"arabic","text_bw":"muqal~aS","text_ar":"مُقَلَّص"},{"kind":"text","text":"; but it is correctly"},{"kind":"arabic","text_bw":"muqal~iS","text_ar":"مُقَلِّص"},{"kind":"text","text":".])"}],"source_refs":["Msb","TA","S","K"]}]}}