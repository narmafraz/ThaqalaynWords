s","form":"أَنْصَبّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23604","n39877"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%B5%D9%8E%D8%A8%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pain, depress, weary tire out"},{"pos":"verb","gloss":"to put a handle to a knife"}]},"etymology":null,"ipa":["/ʔan.sˤa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23604","headword_ar":"انصبّ","root":"Sb","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water, S, M, and the like, M)"},{"kind":"italic_en","text":"poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"(S, M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"Sab~a","text_ar":"صَبَّ","orth_type":"arrow"},{"kind":"text","text":", (M, Msb, K,) aor."},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"SabiybN","text_ar":"صَبِيبٌ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tSb~b","text_ar":"تصبّب","orth_type":"arrow"},{"kind":"text","text":", (M, K,) which is of a form rarely occurring as that of a quasi-pass. of an unaugmented triliteral verb, being generally that of the quasi-pass. of a verb of the form"},{"kind":"arabic","text_bw":"faE~ala","text_ar":"فَعَّلَ"},{"kind":"text","text":"; (MF, TA;) [but this app. denotes its doing so"},{"kind":"italic_en","text":"repeatedly;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"abundantly,"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"tadaf~aqa","text_ar":"تَدَفَّقَ"},{"kind":"text","text":", q. v.;] and ↓"},{"kind":"arabic","text_bw":"ASTb~","text_ar":"اصطبّ","orth_type":"arrow"},{"kind":"text","text":". (K.) One says,"},{"kind":"arabic","text_bw":"AlmaA='u yanoSab~u mina Aljabali","text_ar":"المَا=ءُ يَنْصَبُّ مِنَ الجَبَلِ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"mn Aljbl","text_ar":"من الجبل"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yataSab~abu","text_ar":"يَتَصَبَّبُ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"The water descends, little by little, from the mountain."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"AlEaraqu","text_ar":"العَرَقُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tSb~b","text_ar":"تصبّب","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The sweat flowed"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Ald~amu","text_ar":"الدَّمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the blood"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"EaraqFA","text_ar":"عَرَقًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taSab~abotu","text_ar":"تَصَبَّبْتُ","orth_type":"arrow"},{"kind":"text","text":"[which may be rendered"},{"kind":"italic_en","text":"I flowed with sweat"},{"kind":"text","text":"] is a phrase of the Arabs, meaning"},{"kind":"arabic","text_bw":"tSb~b EaraqiY","text_ar":"تصبّب عَرَقِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"my sweat flowed"},{"kind":"text","text":"]: thus the act is literally ascribed to the speaker, and what is essentially the agent becomes a specificative: it is not allowable to say"},{"kind":"arabic","text_bw":"EaraqFA taSab~abotu","text_ar":"عَرَقًا تَصَبَّبْتُ"},{"kind":"text","text":"; for, as it is not allowable to put the agent before the verb, so it is not allowable to put the specificative, when it is virtually the agent, before the verb. (IJ, M.) ―         -b2-  One says also,"},{"kind":"arabic","text_bw":"AnSb~ Alkuwzu","text_ar":"انصبّ الكُوزُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The mug had its contents poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"dfq","text_ar":"دفق"},{"kind":"text","text":".) ―         -b3-  See also 1, in three places. ―         -b4-"},{"kind":"arabic","text_bw":"AnSb Aln~aAsu EalaY AlmaA='i","text_ar":"انصب النَّاسُ عَلَى المَا=ءِ"},{"kind":"text","text":"[generally implies descent, but] means (assumed tropical:)"},{"kind":"italic_en","text":"The people collected together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assembled, at the water."},{"kind":"text","text":"(Msb.) ―         -b5-  [And"},{"kind":"arabic","text_bw":"AnSb~","text_ar":"انصبّ"},{"kind":"text","text":"is often said of a place, or the ground, &c., meaning (assumed tropical:)"},{"kind":"italic_en","text":"It sloped downwards."},{"kind":"text","text":"―         -b6-  Har (p. 125) uses the phrase"},{"kind":"arabic","text_bw":"tanoSab~u A_ilaY All~ahowi","text_ar":"تَنْصَبُّ اـِلَى اللَّهْوِ"},{"kind":"text","text":", meaning (as there expl.) (assumed tropical:)"},{"kind":"italic_en","text":"Thou inclinest to diversion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sport."},{"kind":"text","text":".]"}],"source_refs":["M","Msb","K","TA","S"]},{"entry_id":"n39877","headword_ar":"اَنْصَبُ","root":"nSb","body":[{"kind":"text","text":"A goat"},{"kind":"italic_en","text":"having erect horns:"},{"kind":"text","text":"(S, K:) fem."},{"kind":"arabic","text_bw":"naSobaA='u","text_ar":"نَصْبَا=ءُ"},{"kind":"text","text":". (S.) ―         -b2-"},{"kind":"arabic","text_bw":"naSobaA='u","text_ar":"نَصْبَا=ءُ"},{"kind":"text","text":"A she-camel"},{"kind":"italic_en","text":"having an elevated breast."},{"kind":"text","text":"(S, K.) ―         -b3-"},{"kind":"arabic","text_bw":"A^a*unN naSobaA='u","text_ar":"اَذُنٌ نَصْبَا=ءُ"},{"kind":"italic_en","text":"An ear that is erect, and approaches the other ear."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}