},{"role":"present_3fd","form":"تَثْقُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَثْقُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَثْقُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَثْقُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"ثَقَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ثَقَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ثُقِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ثُقِبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَثْقُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَثْقُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":21,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n4524"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D9%82%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pierce; to penetrate"},{"pos":"verb","gloss":"to tear, to rip"},{"pos":"verb","gloss":"to permeate"},{"pos":"verb","gloss":"to pierce into"},{"pos":"verb","gloss":"to bore holes into"},{"pos":"verb","gloss":"to puncture"},{"pos":"noun","gloss":"verbal noun of ثَقَبَ (ṯaqaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"hole"},{"pos":"noun","gloss":"hollow"},{"pos":"noun","gloss":"perforation, bore"},{"pos":"noun","gloss":"puncture"},{"pos":"noun","gloss":"plural of ثُقْبَة (ṯuqba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4524","headword_ar":"ثَقَبَ","root":"vqb","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (JK, Msb,) inf. n."},{"kind":"arabic","text_bw":"vaqobN","text_ar":"ثَقْبٌ"},{"kind":"text","text":", (JK, S, Msb,)"},{"kind":"italic_en","text":"He made a hole in"},{"kind":"text","text":"a thing (JK, * S, * A, Mgh, Msb, K) with a"},{"kind":"arabic","text_bw":"mivoqab","text_ar":"مِثْقَب"},{"kind":"text","text":"; (A, Msb;) meaning,"},{"kind":"italic_en","text":"a hole of small size;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"such as passed through; he perforated, bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"it: (A, Mgh, K:) and in like manner, ↓"},{"kind":"arabic","text_bw":"vq~b","text_ar":"ثقّب","orth_type":"arrow"},{"kind":"text","text":", (K,) but this signifies he did so"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or to several, or many, things; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":". (K, TA) You say,"},{"kind":"arabic","text_bw":"vaqaba Ald~ur~a","text_ar":"ثَقَبَ الدُّرَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced, the pearls"},{"kind":"text","text":"]; (A, TA;) and"},{"kind":"arabic","text_bw":"AlA~u*una","text_ar":"الاُّذُنَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the ear"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"vaqaba","text_ar":"ثَقَبَ"},{"kind":"arabic","text_bw":"AlqaroHa","text_ar":"القَرْحَ"},{"kind":"italic_en","text":"He pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punctured, the purulent pustule, in order that the fluid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"water, in process of excretion, might issue."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"vaqaba AlHalamu Aljiloda","text_ar":"ثَقَبَ الحَلَمُ الجِلْدَ"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ticks called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"italic_en","text":"pierced holes in the skin."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"AlbaraAqiEa","text_ar":"البَرَاقِعَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"vaq~abona","text_ar":"ثَقَّبْنَ","orth_type":"arrow"},{"kind":"text","text":"(A, Mgh)"},{"kind":"italic_en","text":"They made holes in the face-veils,"},{"kind":"text","text":"(Mgh,)"},{"kind":"arabic","text_bw":"liEuyuwnihin~a","text_ar":"لِعُيُونِهِنَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for their eyes"},{"kind":"text","text":"]: (A:) said of women. (Mgh.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"vaqaba Alkawokabu","text_ar":"ثَقَبَ الكَوْكَبُ"},{"kind":"text","text":", (K, and Ham p. 701,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (JK, Ham,) (tropical:)"},{"kind":"italic_en","text":"The star shone brightly"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it pierced through the darkness:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"vaAqibN","text_ar":"ثَاقِبٌ"},{"kind":"text","text":"]: (K:) or"},{"kind":"italic_en","text":"shone and glistened intensely."},{"kind":"text","text":"(Ham ubi suprà.) And"},{"kind":"arabic","text_bw":"vaqabati Aln~aAru","text_ar":"ثَقَبَتِ النَّارُ"},{"kind":"text","text":", (S, L, K,) aor."},{"kind":"text","text":", (S, L,) inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"vaqaAbapN","text_ar":"ثَقَابَةٌ"},{"kind":"text","text":", (S, L,) (tropical:)"},{"kind":"italic_en","text":"The fire burned brightly; burned, blazed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flamed, up."},{"kind":"text","text":"(S, L, K.) And"},{"kind":"arabic","text_bw":"vaqaba Alz~anodu","text_ar":"ثَقَبَ الزَّنْدُ"},{"kind":"text","text":", (JK, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)  ["},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"znd","text_ar":"زند"},{"kind":"italic_en","text":"emitted fire"},{"kind":"text","text":"]: said when the spark falls (JK, TA) upon [or from] the"},{"kind":"arabic","text_bw":"znd","text_ar":"زند"},{"kind":"text","text":"[or wooden instrument for producing fire]. (JK.) ―         -b3-"},{"kind":"arabic","text_bw":"vaqabati Alr~aAy^iHapu","text_ar":"ثَقَبَتِ الرَّايِحَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The odour diffused itself, and rose."},{"kind":"text","text":"(K, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"vaqaba raA^oyuhu","text_ar":"ثَقَبَ رَاْيُهُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"His judgment was penetrating;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":". (K.) ―         -b5-"},{"kind":"arabic","text_bw":"vaqabati Aln~aAqapu","text_ar":"ثَقَبَتِ النَّاقَةُ"},{"kind":"text","text":", (JK, S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (JK, TA,) (tropical:)"},{"kind":"italic_en","text":"The she-camel had"},{"kind":"page_break","n":342},{"kind":"italic_en","text":"much milk; abounded with milk."},{"kind":"text","text":"(JK, S, K.)       -A2-"},{"kind":"arabic","text_bw":"vaquba","text_ar":"ثَقُبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"vaqaAbapN","text_ar":"ثَقَابَةٌ"},{"kind":"text","text":", (JK, A, K,) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, JK, A)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, very red;"},{"kind":"text","text":"(JK, A, K;)"},{"kind":"italic_en","text":"so as to be likened to the flame of fire."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["JK","Msb","S","A","Mgh","K","TA","Ham","L"]}]}}