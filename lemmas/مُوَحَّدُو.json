{"lemma":"مُوَحَّدُو","slug":"مُوَحَّدُو","root":"#.ح.د","root_slug":"_-ح-د","root_link":"/words/roots/_-ح-د","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n41746","n41747"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%88%D9%8E%D8%AD%D9%8E%D9%91%D8%AF%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"active participle of وَحَّدَ (waḥḥada)","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"Muwahhid, Almohad"},{"pos":"verb","gloss":"passive participle of وَحَّدَ (waḥḥada)","tags":["form-of","participle","passive"]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb وَحَّدَ (waḥḥada), from the root و ح د (w ḥ d).\n\nDerived from the passive participle of the verb وَحَّدَ (waḥḥada), from the root و ح د (w ḥ d)."},"ipa":["/mu.waħ.ħid/","/mu.waħ.ħad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41746","headword_ar":"مُوحِدٌ","root":"wHd","body":[{"kind":"text","text":"A ewe"},{"kind":"italic_en","text":"bringing forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that brings forth, one ewe only."},{"kind":"text","text":"(S, K.) [See"},{"kind":"arabic","text_bw":"mugoridN","text_ar":"مُغْرِدٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n41747","headword_ar":"مَوْحَدَ","root":"wHd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"wuHaAda","text_ar":"وُحَادَ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^uHaAda","text_ar":"اُحَادَ"},{"kind":"text","text":"[used adverbially] are imperfectly decl. because of their having the quality of an epithet and deviating from their original form, (S, L,) which is"},{"kind":"arabic","text_bw":"waAHidFA","text_ar":"وَاحِدًا"},{"kind":"text","text":": (L, K:) or because they differ from their original both as to the letter and the meaning; the original word being changed as above stated, and the meaning being changed to"},{"kind":"arabic","text_bw":"waAHidFA waAHidFA","text_ar":"وَاحِدًا وَاحِدًا"},{"kind":"text","text":": (S, L:) you say"},{"kind":"arabic","text_bw":"daxaluwA mawoHada mawoHada","text_ar":"دَخَلُوا مَوْحَدَ مَوْحَدَ"},{"kind":"text","text":", (S, L, K,) [and"},{"kind":"arabic","text_bw":"wuHaAda wuHaAda","text_ar":"وُحَادَ وُحَادَ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"A^uHaAda A^uHaAda","text_ar":"اُحَادَ اُحَادَ"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"They entered one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one and one"},{"kind":"text","text":"]; or"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one by one"},{"kind":"text","text":"]; (K;) or"},{"kind":"italic_en","text":"one at a time; one after another."},{"kind":"text","text":"(S, L.)"}],"source_refs":["S","L","K"]}]},"classical_definitions":null}