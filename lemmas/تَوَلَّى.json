:"Compare وَلِيَ (waliya, “to be near, to govern”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44748","headword_ar":"تَوَلَّى","root":"wlY","body":[{"kind":"italic_en","text":"He turned himself,"},{"kind":"arabic","text_bw":"AlY","text_ar":"الى"},{"kind":"italic_en","text":"towards."},{"kind":"text","text":"(Jel, ii. 139.)"},{"kind":"italic_en","text":"He turned away"},{"kind":"text","text":"(Idem, xix. 50; and S, Msb)"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"italic_en","text":"from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"tawal~aY","text_ar":"تَوَلَّى"},{"kind":"italic_en","text":"He turned the back"},{"kind":"text","text":"to another: see a verse in art."},{"kind":"arabic","text_bw":"fyl","text_ar":"فيل"},{"kind":"text","text":", conj. 1. ―         -b3-"},{"kind":"arabic","text_bw":"twl~Y A^amorFA","text_ar":"تولّى اَمْرًا"},{"kind":"italic_en","text":"He took upon himself an affair."},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"tawal~aY kiborahu","text_ar":"تَوَلَّى كِبْرَهُ"},{"kind":"italic_en","text":"He took upon himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"undertook, the main part thereof;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taHam~ala muEoZamahu","text_ar":"تَحَمَّلَ مُعْظَمَهُ"},{"kind":"text","text":". (Jel, xxiv. ii.) ―         -b5-"},{"kind":"arabic","text_bw":"tawl~aAhu","text_ar":"تَولَّاهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"waliyahu","text_ar":"وَلِيَهُ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}