{"lemma":"عَمَّرَ","slug":"عَمَّرَ","root":"ع.م.ر","root_slug":"ع-م-ر","root_link":"/words/roots/ع-م-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَمَّرْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَمَّرْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَمَّرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَمَّرْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَمَّرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَمَّرَ","in_corpus":true,"count":733,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَمَّرَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَمَّرا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَمَّرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَمَّرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَمَّرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعَمِّر","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعَمِّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعَمِّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعَمِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَمِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَمِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَمِّر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَمِّر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَمِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَمِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَمِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَمَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَمَّرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَمِّر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَمِّر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":752,"cross_references":{"qac":{"found":true,"lemma_key":"عَمَّرَ","root":"عمر","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":8,"pos_tags":["name","noun","verb"],"has_etymology":true,"sense_count":22},"lanes":{"found":true,"entry_ids":["n30513","n30517","n30518","n30519","n30520"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%85%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to live long, to be long-lived"},{"pos":"verb","gloss":"to fill with life, to cause to thrive, to make prosperous"},{"pos":"verb","gloss":"to inhabit, to live, to dwell"},{"pos":"verb","gloss":"to fill, to pervade"},{"pos":"verb","gloss":"to reign"},{"pos":"verb","gloss":"to build, to erect, to construct"},{"pos":"verb","gloss":"to rebuild, to restore, to reconstruct"},{"pos":"verb","gloss":"to thrive, to prosper, to flourish, to flower, to bloom"},{"pos":"verb","gloss":"to be inhabited, to be peopled, to be populated"},{"pos":"verb","gloss":"to be civilized, to be cultivated"},{"pos":"verb","gloss":"to be full, to be filled"},{"pos":"verb","gloss":"to prolong life, to grant long life","examples":[{"text":"يَوَدُّ أَحَدُهُمْ لَوْ يُعَمَّرُ أَلْفَ سَنَةٍ"}]},{"pos":"verb","gloss":"to populate, to people"},{"pos":"verb","gloss":"to build, to erect, to construct"},{"pos":"verb","gloss":"to rebuild, to reconstruct"},{"pos":"verb","gloss":"to repair, to restore, to overhaul, to refurbish, to recondition"},{"pos":"noun","gloss":"verbal noun of عَمَرَ (ʕamara) (form I), \"living long\"/\"long living\" (in the gerundal sense)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَمَرَ (ʕamara) (form I), \"living long\"/\"long living\" (in the gerundal sense)","tags":["form-of","noun-from-verb"]},{"pos":"name","gloss":"a male given name, Umar or Omar"},{"pos":"name","gloss":"ʿUmar ibn al-Ḵaṭṭāb, recognized as the Islamic prophet's second rightly-guided successor in Sunni Islam"},{"pos":"noun","gloss":"life as a period of time, length of life, lifespan, lifetime","examples":[{"text":"كَمْ تَبْلُغُ مِنَ الْعُمْر؟","english":"How old are you?"}]},{"pos":"noun","gloss":"age"}]},"etymology":{"source":"wiktextract","text":"From the Arabic triliteral root ع م ر (ʿayn - mīm - rā), from which are rendered terms relating to the granting, extension and duration of life, to maintenance in various significations, and to increase in general. See https://corpus.quran.com/qurandictionary.jsp?q=Emr"},"ipa":["/ʕa.ma.ra/","/ʕa.mu.ra/","/ʕam.ma.ra/","/ʕamr/","/ʕu.mar/","/ʕu.mur/","/ʕumr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30513","headword_ar":"عَمِرَ","root":"Emr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, O, Msb, K;) and"},{"kind":"arabic","text_bw":"Eamara","text_ar":"عَمَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(K) and"},{"kind":"text","text":"; (Sb, K;) inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"(S, O,"},{"kind":"page_break","n":2154},{"kind":"text","text":"Msb, K) and"},{"kind":"arabic","text_bw":"EumorN","text_ar":"عُمْرٌ"},{"kind":"text","text":", (S, O, Msb,) both anomalous, as inf. ns. of"},{"kind":"arabic","text_bw":"Eamira","text_ar":"عَمِرَ"},{"kind":"text","text":", for by rule the inf. n. should be"},{"kind":"arabic","text_bw":"EamarN","text_ar":"عَمَرٌ"},{"kind":"text","text":", (S,) but"},{"kind":"arabic","text_bw":"EamarN","text_ar":"عَمَرٌ"},{"kind":"text","text":"is also an inf. n., (TA,) and"},{"kind":"arabic","text_bw":"EumurN","text_ar":"عُمُرٌ"},{"kind":"text","text":", which is the most chaste, (O,) and"},{"kind":"arabic","text_bw":"EamaArapN","text_ar":"عَمَارَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He lived,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"continued in life"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"baqiYa","text_ar":"بَقِىَ"},{"kind":"text","text":"), (K,)"},{"kind":"italic_en","text":"long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a long time;"},{"kind":"text","text":"(S, O, K; *)"},{"kind":"italic_en","text":"his life was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"Eamira","text_ar":"عَمِرَ"},{"kind":"italic_en","text":"he grew old."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Eamara bimakaAnK","text_ar":"عَمَرَ بِمَكَانٍ"},{"kind":"italic_en","text":"He remained, continued, stayed, resided, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in a place."},{"kind":"text","text":"(B, TA.)       -A2-"},{"kind":"arabic","text_bw":"Eamara","text_ar":"عَمَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EumoraAnN","text_ar":"عُمْرَانٌ"},{"kind":"text","text":", (MA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a place of abode)"},{"kind":"italic_en","text":"became inhabited;"},{"kind":"text","text":"(MA, Msb;)"},{"kind":"arabic","text_bw":"biA^aholhi","text_ar":"بِاَهْلهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by its people"},{"kind":"text","text":"]: (Msb:) ["},{"kind":"italic_en","text":"it became peopled, well peopled, well stocked with people and the like, in a flourishing state, in a state the contrary of desolate"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waste"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of good repair:"},{"kind":"text","text":"] and in like manner you say,"},{"kind":"arabic","text_bw":"Eamirati Ald~aAru","text_ar":"عَمِرَتِ الدَّارُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"the house became inhabited"},{"kind":"text","text":"[&c.]. (MA.) ―         -b2-  [You say also,"},{"kind":"arabic","text_bw":"Eamarati AlA^aroDu","text_ar":"عَمَرَتِ الاَرْضُ"},{"kind":"italic_en","text":"The land became inhabited, peopled, well stocked with people and camels and the like, colonized, cultivated, well cultivated, in a flourishing state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state the contrary of waste:"},{"kind":"text","text":"see its act. part. n.,"},{"kind":"arabic","text_bw":"EaAmirN","text_ar":"عَامِرٌ"},{"kind":"text","text":".] ―         -b3-  And"},{"kind":"arabic","text_bw":"Eamara AlmaAlu","text_ar":"عَمَرَ المَالُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Eamira","text_ar":"عَمِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"Eamura","text_ar":"عَمُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Sb, K;) inf. n."},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":"; (K; [so in most copies; in the TA,"},{"kind":"arabic","text_bw":"EamaArapN","text_ar":"عَمَارَةٌ"},{"kind":"text","text":", and there said to be inf. n. of"},{"kind":"arabic","text_bw":"Eamura","text_ar":"عَمُرَ"},{"kind":"text","text":"; but, I think, erroneously;])"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SaAra EaAmirFA","text_ar":"صَارَ عَامِرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The property, consisting of camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, became in a flourishing state"},{"kind":"text","text":"]; (K;)"},{"kind":"italic_en","text":"the property became much; the camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, became many,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"numerous."},{"kind":"text","text":"(Sgh.)       -A3-"},{"kind":"arabic","text_bw":"Eamarahu","text_ar":"عَمَرَهُ"},{"kind":"text","text":", (Msb, K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":"(K [so in most copies, but in the TA,"},{"kind":"arabic","text_bw":"EamaArapN","text_ar":"عَمَارَةٌ"},{"kind":"text","text":", with fet-h, which I think erroneous;]) and"},{"kind":"arabic","text_bw":"EumuwrN","text_ar":"عُمُورٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"EumoraAnN","text_ar":"عُمْرَانٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He inhabited it; remained, continued, stayed, resided, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in it;"},{"kind":"text","text":"namely, a place of abode: (Msb:)"},{"kind":"italic_en","text":"he kept to it;"},{"kind":"text","text":"namely, his property, or his camels or the like, and his house, or tent: (K:) one should not say, of a man,"},{"kind":"arabic","text_bw":"manozilihu","text_ar":"مَنْزِلِهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEomara","text_ar":"اَعْمَرَ","orth_type":"arrow"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":". (Az, TA.)"},{"kind":"arabic","text_bw":"A_in~amaA yaEomuru masaAjida A@ll~`hi","text_ar":"اـِنَّمَا يَعْمُرُ مَسَاجِدَ ا@للّٰهِ"},{"kind":"text","text":", in the Kur [ix. 18], signifies"},{"kind":"italic_en","text":"Only he shall abide in the mosques,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"places of worship, of God:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall visit them:"},{"kind":"text","text":"(TA:) see 8: but Z says, I know not"},{"kind":"arabic","text_bw":"Eamara","text_ar":"عَمَرَ"},{"kind":"text","text":"as occurring in the sense of"},{"kind":"arabic","text_bw":"AEtmr","text_ar":"اعتمر"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he visited"},{"kind":"text","text":"]: (TA:) or"},{"kind":"italic_en","text":"shall enter them and sit in them:"},{"kind":"text","text":"(Jel:) or the verb in the above-cited phrase of the Kur has another signification, which see below. (TA.)       -A4-"},{"kind":"arabic","text_bw":"Eamarahu","text_ar":"عَمَرَهُ"},{"kind":"text","text":"is also syn. with"},{"kind":"arabic","text_bw":"Eam~arahu","text_ar":"عَمَّرَهُ"},{"kind":"text","text":", in the first of the senses expl. below: see 2.       -A5-"},{"kind":"arabic","text_bw":"Eamara A@ll~`hu bika manozilaka","text_ar":"عَمَرَ ا@للّٰهُ بِكَ مَنْزِلَكَ"},{"kind":"text","text":", (AZ, S, O, K, *) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"A^aEomarahu","text_ar":"اَعْمَرَهُ","orth_type":"arrow"},{"kind":"text","text":"; (AZ, S, O, K;)"},{"kind":"italic_en","text":"May God make thy place of abode to become peopled,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"well peopled, well stocked with people and the like, in a flourishing state, in a state the contrary of ruined"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waste"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desolate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of good repair,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by thee"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"by thy means"},{"kind":"text","text":"]: (K, * TA:) but AZ says that one should not say, of a man,"},{"kind":"arabic","text_bw":"manozilahu","text_ar":"مَنْزِلَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEomara","text_ar":"اَعْمَرَ","orth_type":"arrow"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":". (S.) ―         -b2-"},{"kind":"arabic","text_bw":"Eamara AlxaraAba","text_ar":"عَمَرَ الخَرَابَ"},{"kind":"text","text":", aor. and inf. n. as above, ["},{"kind":"italic_en","text":"He made the ruin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, to become in a state of good repair, in a state the contrary of ruined"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waste"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desolate."},{"kind":"text","text":"] (S, O, TA.) ―         -b3-  ["},{"kind":"arabic","text_bw":"Eamara","text_ar":"عَمَرَ"},{"kind":"arabic","text_bw":"AlA^aroDa","text_ar":"الاَرْضَ"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"He peopled the land; stocked it well with people and camels and the like; colonized it; cultivated it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cultivated it well; rendered it in a flourishing state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state the contrary of waste."},{"kind":"text","text":"] ―         -b4-  And"},{"kind":"arabic","text_bw":"Eamara AlbinaA='a","text_ar":"عَمَرَ البِنَا=ءَ"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"He kept the building in a good state;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HafiZahu","text_ar":"حَفِظَهُ"},{"kind":"text","text":". (TA.) So accord. to some, in the Kur,"},{"kind":"arabic","text_bw":"A_in~amaA yaEomuru masaAjida A@ll~`hi","text_ar":"اـِنَّمَا يَعْمُرُ مَسَاجِدَ ا@للّٰهِ"},{"kind":"text","text":", [quoted above,]"},{"kind":"italic_en","text":"Only he shall keep in a good state"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"in repair"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the mosques,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"places of worship, of God:"},{"kind":"text","text":"(TA:) among the significations of the verb as here used, are these;"},{"kind":"italic_en","text":"he shall adorn them with carpets"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and light them with lamps, and continue the performance of religious worship and praise and the study of science in them, and guard them from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"desecration by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that for which they are not built, such as worldly discourse."},{"kind":"text","text":"(Bd.) ―         -b5-"},{"kind":"arabic","text_bw":"Eamara Ald~aAra","text_ar":"عَمَرَ الدَّارَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":", (MA,) or this, accord. to the Msb, is a simple subst.],"},{"kind":"italic_en","text":"He built the house."},{"kind":"text","text":"(Msb.) [And]"},{"kind":"italic_en","text":"He made the house to be inhabited; he peopled it;"},{"kind":"text","text":"(MA;) [or"},{"kind":"italic_en","text":"made it to be well stocked with people and the like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a flourishing state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of good repair."},{"kind":"text","text":"] ―         -b6-"},{"kind":"arabic","text_bw":"Eamara Alxayora","text_ar":"عَمَرَ الخَيْرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":", [app.,"},{"kind":"italic_en","text":"He instituted what was good:"},{"kind":"text","text":"or perhaps,"},{"kind":"italic_en","text":"he cultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"promoted, it:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he kept to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observed it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regarded it."},{"kind":"text","text":"] (Az, TA.)       -A6-"},{"kind":"arabic","text_bw":"Eamara rab~ahu","text_ar":"عَمَرَ رَبَّهُ"},{"kind":"text","text":", (IAar, K,) aor."},{"kind":"text","text":", (IAar, O,) [inf. n."},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He served,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worshipped, his Lord;"},{"kind":"text","text":"(IAar, K;)"},{"kind":"italic_en","text":"he prayed and fasted."},{"kind":"text","text":"(Ks, Lh, O, K.) You say"},{"kind":"arabic","text_bw":"tarakotu fulaAnFA yaEomuru rab~ahu","text_ar":"تَرَكْتُ فُلَانًا يَعْمُرُ رَبَّهُ"},{"kind":"italic_en","text":"I left such a one worshipping his Lord, praying and fasting."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","S","O","Msb","TA","MA","Jel","IAar"]},{"entry_id":"n30517","headword_ar":"عَمْرٌ","root":"Emr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EumorN","text_ar":"عُمْرٌ","orth_type":"arrow"},{"kind":"text","text":"are both inf. ns., signifying the same. (S, O.) [See 1. As such, the former is the more common.] And both of these words, (Mgh, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"EumurN","text_ar":"عُمُرٌ","orth_type":"arrow"},{"kind":"text","text":", (K, &c.,) [used as"},{"kind":"page_break","n":2155},{"kind":"text","text":"simple substs., or abstract ns., in which case the second is more common than the first, except in forms of swearing, in which the former is used, and the third is more chaste than the second,] signify"},{"kind":"italic_en","text":"Life;"},{"kind":"text","text":"(Msb, K;) [the"},{"kind":"italic_en","text":"age to which the life extends;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"period during which the body is inhabited by life:"},{"kind":"text","text":"so that it denotes less than"},{"kind":"arabic","text_bw":"baqaA='N","text_ar":"بَقَا=ءٌ"},{"kind":"text","text":": wherefore the latter is [frequently] used as an attribute of God; but"},{"kind":"arabic","text_bw":"Emr","text_ar":"عمر"},{"kind":"text","text":"is seldom used as such: (Er-Rághib, B:) pl."},{"kind":"arabic","text_bw":"A^aEomaArN","text_ar":"اَعْمَارٌ"},{"kind":"text","text":". (K.) You say ↓"},{"kind":"arabic","text_bw":"A^aTaAla A@ll~`hu Eumuraka","text_ar":"اَطَالَ ا@للّٰهُ عُمُرَكَ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eamoraka","text_ar":"عَمْرَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God prolong thy life"},{"kind":"text","text":"]. (S, O.) In a form of swearing,"},{"kind":"arabic","text_bw":"Eamor","text_ar":"عَمْر"},{"kind":"text","text":"only is used. (S.) [In a case of this kind, when"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is not prefixed to it, it is in the accus. case, as will be shown and expl. below: but when"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is prefixed to it, it is in the nom.] You say"},{"kind":"arabic","text_bw":"laEamoruka laA^afoEalan~a","text_ar":"لَعَمْرُكَ لَاَفْعَلَنَّ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"By thy life, I will assuredly do"},{"kind":"text","text":"[such a thing]. (Msb.)"},{"kind":"arabic","text_bw":"laEamoruka","text_ar":"لَعَمْرُكَ"},{"kind":"text","text":"occurs in the Kur xv. 72, and means"},{"kind":"italic_en","text":"By thy life:"},{"kind":"text","text":"(I'Ab, Akh, Bd, Jel:) and ↓"},{"kind":"arabic","text_bw":"laEamaruka","text_ar":"لَعَمَرُكَ","orth_type":"arrow"},{"kind":"text","text":"is a dial. var., mentioned by Yoo: (O:) or the former, accord. to the grammarians, means"},{"kind":"italic_en","text":"by thy religion:"},{"kind":"text","text":"(AHeyth, O:) and [in like manner]"},{"kind":"arabic","text_bw":"laEamoriY","text_ar":"لَعَمْرِى"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"laEamariY","text_ar":"لَعَمَرِى","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"by my life,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"by my religion."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"laEamoruka","text_ar":"لَعَمْرُكَ"},{"kind":"text","text":"is an inchoative, of which the enunciative,"},{"kind":"arabic","text_bw":"maA A^uqosimu","text_ar":"مَا اُقْسِمُ"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"that by which I swear,"},{"kind":"text","text":"so that the entire phrase means"},{"kind":"italic_en","text":"thy life is that by which I swear,"},{"kind":"text","text":"] is understood; therefore it is in the nom. case: (IJ, TA:) or the complete phrase is"},{"kind":"arabic","text_bw":"waEamorika","text_ar":"وَعَمْرِكَ"},{"kind":"arabic","text_bw":"falaEamoruka EaZiymN","text_ar":"فَلَعَمْرُكَ عَظِيمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by thy life,"},{"kind":"text","text":"&c.:"},{"kind":"italic_en","text":"and thy life is of great account"},{"kind":"text","text":"]. (Fr, as related by A'Obeyd.) You say also"},{"kind":"arabic","text_bw":"laEamoru A^abiyka Alxayora","text_ar":"لَعَمْرُ اَبِيكَ الخَيْرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alxayori","text_ar":"الخَيْرِ"},{"kind":"text","text":"; the former meaning"},{"kind":"italic_en","text":"By thy father's instituting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"promoting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regarding, what is good;"},{"kind":"arabic","text_bw":"Alxyr","text_ar":"الخير"},{"kind":"text","text":"being the objective complement of"},{"kind":"arabic","text_bw":"Emr","text_ar":"عمر"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"Eamara Alxayora","text_ar":"عَمَرَ الخَيْرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EimaArapN","text_ar":"عِمَارَةٌ"},{"kind":"text","text":"; [see 1;] but in the latter case,"},{"kind":"arabic","text_bw":"Alxayori","text_ar":"الخَيْرِ"},{"kind":"text","text":"is an epithet added to"},{"kind":"arabic","text_bw":"A^abiyka","text_ar":"اَبِيكَ"},{"kind":"text","text":"[so that the meaning is"},{"kind":"italic_en","text":"by the life of thy good father"},{"kind":"text","text":"]. (AHeyth, Az, O, TA.) [See also art."},{"kind":"arabic","text_bw":"xyr","text_ar":"خير"},{"kind":"text","text":".] You also say"},{"kind":"arabic","text_bw":"laEamoru A@ll~`hi","text_ar":"لَعَمْرُ ا@للّٰهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"By the everlasting existence of God;"},{"kind":"text","text":"(S, O, K;)"},{"kind":"arabic","text_bw":"Emr","text_ar":"عمر"},{"kind":"text","text":"being here in the nom. case as an inchoative, with"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"prefixed to it as a corroborative of the inchoative state: the enunciative is understood; the complete phrase being"},{"kind":"arabic","text_bw":"laEamoru A@ll~`hi qasamiY","text_ar":"لَعَمْرُ ا@للّٰهِ قَسَمِى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"maA A^uqosimu bihi","text_ar":"مَا اُقْسِمُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the everlasting existence of God is my oath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that by which I swear"},{"kind":"text","text":"]. (S, O.) This expression is forbidden in a trad., (K,) because"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"[properly] means the life of the body: (TA:) [but]"},{"kind":"arabic","text_bw":"laEamoru","text_ar":"لَعَمْرُ"},{"kind":"arabic","text_bw":"A_il`hika","text_ar":"اـِلٰهِكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"By the everlasting existence of thy God,"},{"kind":"text","text":"occurs in a trad. (TA.) When you do not prefix"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":", you make it to be in the accus. case, as an inf. n.: thus you say,"},{"kind":"arabic","text_bw":"Emora A@ll~`hi maA faEalotu ka*aA","text_ar":"عمْرَ ا@للّٰهِ مَا فَعَلْتُ كَذَا"},{"kind":"text","text":"(S, O, K) I swear"},{"kind":"italic_en","text":"by the everlasting existence of God, I did not so:"},{"kind":"text","text":"(S, O:) and"},{"kind":"arabic","text_bw":"Eamoraka A@ll~`ha maA","text_ar":"عَمْرَكَ ا@للّٰهَ مَا"},{"kind":"arabic","text_bw":"faEalotu ka*aA","text_ar":"فَعَلْتُ كَذَا"},{"kind":"text","text":"(S, O, K, [in the CK"},{"kind":"arabic","text_bw":"All~`hu","text_ar":"اللّٰهُ"},{"kind":"text","text":", but this is a mistake,])"},{"kind":"italic_en","text":"By thine acknowledgment of the everlasting existence of God, I did not so:"},{"kind":"text","text":"(S, O:) or the original thereof is"},{"kind":"arabic","text_bw":"Eam~arotuka A@ll~`ha taEomiyrFA","text_ar":"عَمَّرْتُكَ ا@للّٰهَ تَعْمِيرًا"},{"kind":"text","text":", (O, K,) i. e.,"},{"kind":"italic_en","text":"I ask,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beg, God to prolong thy life:"},{"kind":"text","text":"(Ks, O:) [and it is said in the S that"},{"kind":"arabic","text_bw":"Eamoraka","text_ar":"عَمْرَكَ"},{"kind":"arabic","text_bw":"A@ll~`ha","text_ar":"ا@للّٰهَ"},{"kind":"text","text":"sometimes has this signification:] and in like manner"},{"kind":"arabic","text_bw":"Eamoraka A@ll~`ha laA A^afoEalu *aAka","text_ar":"عَمْرَكَ ا@للّٰهَ لَا اَفْعَلُ ذَاكَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I beg God to prolong thy life: I will not do that:"},{"kind":"text","text":"or it may be a form of oath without"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"waEamorika","text_ar":"وَعَمْرِكَ"},{"kind":"text","text":"]: (Ks:) and you say"},{"kind":"arabic","text_bw":"Eamoraka A@ll~`ha AifoEalo ka*aA","text_ar":"عَمْرَكَ ا@للّٰهَ اِفْعَلْ كَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_il~aA faEalota","text_ar":"اـِلَّا فَعَلْتَ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"A_il~aA maA faEalota ka*aA","text_ar":"اـِلَّا مَا فَعَلْتَ كَذَا"},{"kind":"italic_en","text":"By thine acknowledgment of the everlasting existence of God,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"do thou so"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"Eamoraka A@ll~`ha","text_ar":"عَمْرَكَ ا@للّٰهَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"by thy worship of God:"},{"kind":"text","text":"(AHeyth:) or I remind thee,"},{"kind":"italic_en","text":"reminding thee, of God."},{"kind":"text","text":"(K.) Mbr says of this phrase,"},{"kind":"arabic","text_bw":"Emrk All~`h","text_ar":"عمرك اللّٰه"},{"kind":"text","text":", that"},{"kind":"arabic","text_bw":"Emr","text_ar":"عمر"},{"kind":"text","text":"may be in the accus. case on account of a verb understood; [such, for instance, as"},{"kind":"arabic","text_bw":"A^u*ak~iruka","text_ar":"اُذَكِّرُكَ"},{"kind":"text","text":";] or by reason of"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"suppressed, the complete phrase being"},{"kind":"arabic","text_bw":"waEamorika A@ll~`ha","text_ar":"وَعَمْرِكَ ا@للّٰهَ"},{"kind":"text","text":"; or as being for [the inf. n.]"},{"kind":"arabic","text_bw":"taEomiyr","text_ar":"تَعْمِير"},{"kind":"text","text":". (TA.) It may also be [found written]"},{"kind":"arabic","text_bw":"Eamora A@ll~`ha","text_ar":"عَمْرَ ا@للّٰهَ"},{"kind":"text","text":"; but this is bad. (Ks.) Some of the Arabs, for"},{"kind":"arabic","text_bw":"laEamoruka","text_ar":"لَعَمْرُكَ"},{"kind":"text","text":", said"},{"kind":"arabic","text_bw":"raEamoluka","text_ar":"رَعَمْلُكَ"},{"kind":"text","text":". (Az.) ―         -b2-"},{"kind":"arabic","text_bw":"EamorFA wa$abaAbFA","text_ar":"عَمْرًا وَشَبَابًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"quHaAbN","text_ar":"قُحَابٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"(AHeyth, K) and ↓"},{"kind":"arabic","text_bw":"EamarN","text_ar":"عَمَرٌ","orth_type":"arrow"},{"kind":"text","text":"(K) signify"},{"kind":"italic_en","text":"Religion;"},{"kind":"text","text":"(AHeyth, K;) as in the phrases"},{"kind":"arabic","text_bw":"laEamoriY","text_ar":"لَعَمْرِى"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"laEamariY","text_ar":"لَعَمَرِى","orth_type":"arrow"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"laEamoruka","text_ar":"لَعَمْرُكَ"},{"kind":"text","text":"(AHeyth) [mentioned above].       -A3-  Also"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":"(S, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EumorN","text_ar":"عُمْرٌ","orth_type":"arrow"},{"kind":"text","text":"(IAth, O, K) The"},{"kind":"italic_en","text":"flesh that is between the teeth:"},{"kind":"text","text":"(S, O, Msb, K:) or the"},{"kind":"italic_en","text":"pendent piece of flesh between the teeth:"},{"kind":"text","text":"(Az, Msb:) or the"},{"kind":"italic_en","text":"flesh that is between the places in which the teeth are set:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"flesh of the gum:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"the flesh of the gum that runs between any two teeth:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"what appears of the gum:"},{"kind":"text","text":"(Kh, Msb:) or (so accord. to the TA, but in the K “ and ”)"},{"kind":"italic_en","text":"anything of an oblong shape between two teeth:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"EumuwrN","text_ar":"عُمُورٌ"},{"kind":"text","text":": (S, O, Msb, K:) which some explain as signifying the"},{"kind":"italic_en","text":"places whence the teeth grow."},{"kind":"text","text":"(TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A^awoSaAniY jiboriylu","text_ar":"اَوْصَانِى جِبْرِيلُ"},{"kind":"arabic","text_bw":"biAls~iwaAki Hat~aY xa$iytu EalaY EumuwriY","text_ar":"بِالسِّوَاكِ حَتَّى خَشِيتُ عَلَى عُمُورِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Gabriel enjoined me to make use of the tooth-stick so that I feared for my"},{"kind":"arabic","text_bw":"Emwr","text_ar":"عمور"},{"kind":"text","text":"]. (O, TA.)       -A4-"},{"kind":"arabic","text_bw":"A^um~u EamorKw","text_ar":"اُمُّ عَمْرٍو"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaAmirN","text_ar":"عَامِرٌ"},{"kind":"text","text":"."}],"source_refs":["O","AHeyth","IJ","TA","K","S","Ks","Msb","IAth","Az","Kh"]},{"entry_id":"n30518","headword_ar":"عُمْرٌ","root":"Emr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n30519","headword_ar":"عَمَرٌ","root":"Emr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":", in four places."}],"source_refs":[]},{"entry_id":"n30520","headword_ar":"عُمُرٌ","root":"Emr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamorN","text_ar":"عَمْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}