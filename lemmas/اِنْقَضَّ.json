rm":"نَنْقَضّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":228,"cross_references":{"qac":{"found":true,"lemma_key":"اِنْقَضَّ","root":"نقض","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n35804"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D9%82%D9%8E%D8%B6%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cut, to split"},{"pos":"verb","gloss":"to weigh, to add weight to"},{"pos":"verb","gloss":"to name, to denominate, to term"},{"pos":"verb","gloss":"to make something produce a sound"}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":["/ʔan.qa.dˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35804","headword_ar":"انقضّ","root":"qD","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"broke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became broken."},{"kind":"text","text":"(Msb.) Said of a wall, it signifies the same: (T, Msb, TA:) or"},{"kind":"italic_en","text":"it became thrown down, pulled down, pulled to pieces, demolished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destroyed, with violence:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"it fell down:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"it cracked, without falling down;"},{"kind":"text","text":"(M, K;) as also"},{"kind":"arabic","text_bw":"AinoqaAD~a","text_ar":"اِنْقَاضَّ"},{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"naqaDa","text_ar":"نَقَضَ"},{"kind":"text","text":"]; inf. n. [of the former]"},{"kind":"arabic","text_bw":"AinoqiDaADN","text_ar":"اِنْقِضَاضٌ"},{"kind":"text","text":"; (K;) [and"},{"kind":"arabic","text_bw":"AinoqaADa","text_ar":"اِنْقَاضَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AinoqiyaADN","text_ar":"اِنْقِيَاضٌ"},{"kind":"text","text":";] but if it fall, you say,"},{"kind":"arabic","text_bw":"taqay~aDa","text_ar":"تَقَيَّضَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taqay~uDN","text_ar":"تَقَيُّضٌ"},{"kind":"text","text":": so says AZ: (TA:) A 'Obeyd and others reckon it a biliteral-radical word, belonging to this art.; (M;) or AZ reckons it as such; (TA;) but Aboo- 'Alee makes it a triliteral-radical, [like its syn."},{"kind":"arabic","text_bw":"AinoqaAD~a","text_ar":"اِنْقَاضَّ"},{"kind":"text","text":",] from"},{"kind":"arabic","text_bw":"naqaDa","text_ar":"نَقَضَ"},{"kind":"text","text":", holding its measure to be"},{"kind":"arabic","text_bw":"AifoEal~a","text_ar":"اِفْعَلَّ"},{"kind":"text","text":". (M, TA.) ―         -b2-"},{"kind":"italic_en","text":"It became cut in pieces."},{"kind":"text","text":"(TA.) ―         -b3-  [And hence,]"},{"kind":"arabic","text_bw":"AnqD~t A^awoSaAluhu","text_ar":"انقضّت اَوْصَالُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His connections became sundered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"AnfD~","text_ar":"انفضّ"},{"kind":"text","text":".] ―         -b4-  [And from"},{"kind":"arabic","text_bw":"AnqD~","text_ar":"انقضّ"},{"kind":"text","text":"as explained above on the authority of the S, or of the A, is derived the phrase]"},{"kind":"arabic","text_bw":"AnqD~ AlT~aAy^iru","text_ar":"انقضّ الطَّايِرُ"},{"kind":"text","text":"(S, M, A, &c.) (tropical:)"},{"kind":"italic_en","text":"The bird dropped down"},{"kind":"text","text":"(S, M, Mgh, Msb, K)"},{"kind":"italic_en","text":"swiftly from the air,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"in its flight,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"to alight"},{"kind":"text","text":"(M, K, TA)"},{"kind":"italic_en","text":"upon a thing;"},{"kind":"text","text":"(TA;) [i. e."},{"kind":"italic_en","text":"pounced down, darted down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a stoop;"},{"kind":"text","text":"] as also ↓"},{"kind":"arabic","text_bw":"taqaD~aDa","text_ar":"تَقَضَّضَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taqaD~aY","text_ar":"تَقَضَّى","orth_type":"arrow"},{"kind":"text","text":", (M, K,) the latter of which is formed by permutation; (M;) or only the latter of these two is used; (S;) or the latter of them is the more chaste;"},{"kind":"page_break","n":2537},{"kind":"text","text":"(TA;) for the three dáds are found difficult of pronunciation, and therefore one of them is changed into yé, like as is the case in"},{"kind":"arabic","text_bw":"taZan~aY","text_ar":"تَظَنَّى"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"taZan~ana","text_ar":"تَظَنَّنَ"},{"kind":"text","text":"], from"},{"kind":"arabic","text_bw":"AlZ~an~N","text_ar":"الظَّنٌّ"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"tamaT~aY","text_ar":"تَمَطَّى"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"tamaT~aTa","text_ar":"تَمَطَّطَ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"AnqD~ AlbaAziY EalaY AlS~ayodi","text_ar":"انقضّ البَازِى عَلَى الصَّيْدِ"},{"kind":"italic_en","text":"The hawk"},{"kind":"text","text":"["},{"kind":"italic_en","text":"made a stoop,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"flew down swiftly upon the prey,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarry."},{"kind":"text","text":"(TA.) ―         -b5-  Hence, (S,)"},{"kind":"arabic","text_bw":"AnqD~","text_ar":"انقضّ"},{"kind":"text","text":"said of a star, or an asterism, (S, A,) (tropical:)  ["},{"kind":"italic_en","text":"It darted down:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"it dropped down."},{"kind":"text","text":"(TA.) ―         -b6-  Hence also, (TA,)"},{"kind":"arabic","text_bw":"AnqD~t Ealayohimo Alxayolu","text_ar":"انقضّت عَلَيْهِمْ الخَيْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The horses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"horsemen, rushed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went swiftly, upon them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"against them:"},{"kind":"text","text":"(S, * TA:) or"},{"kind":"italic_en","text":"dispersed themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became dispersed, against them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon them."},{"kind":"text","text":"(M, K.)"}],"source_refs":["T","Msb","TA","A","S","M","Mgh","K"]}]}}