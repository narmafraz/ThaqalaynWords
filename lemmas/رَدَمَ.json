:true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n15277"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AF%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cover with dust; to bury-over","tags":["transitive"]},{"pos":"verb","gloss":"to fill up (a hole in the ground)","tags":["transitive"]},{"pos":"verb","gloss":"to fill up (a hole in the ground); to backfill (a dug site, a trench, an excavation, and so on)","tags":["transitive"]}]},"etymology":null,"ipa":["/ra.da.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15277","headword_ar":"رَدَمَ","root":"rdm","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (S, K,) or"},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"radomN","text_ar":"رَدْمٌ"},{"kind":"text","text":", (Lth, T, S, M, Msb,)"},{"kind":"italic_en","text":"He stopped up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"closed,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sad~a","text_ar":"سَدَّ"},{"kind":"text","text":", (Lth, T, S, M, Msb, K,) a door, (Lth, T, M, K,) or a place of entrance, (T,) and a gap, or breach, (Lth, T, S, M, Msb, K,) and the like, (Lth, T, M, Msb,)"},{"kind":"italic_en","text":"wholly:"},{"kind":"text","text":"(Lth, T, K:) or"},{"kind":"italic_en","text":"to the extent of a third thereof:"},{"kind":"text","text":"(K:) or it signifies more than"},{"kind":"arabic","text_bw":"sad~a","text_ar":"سَدَّ"},{"kind":"text","text":"; (M, K;) [i. e."},{"kind":"italic_en","text":"he stopped up by putting one thing upon another;"},{"kind":"text","text":"as in building up a doorway or the like;] for"},{"kind":"arabic","text_bw":"Alr~adomu","text_ar":"الرَّدْمُ"},{"kind":"text","text":"is “ that of which one part is put upon another. ” (M.) ―         -b2-  And"},{"kind":"arabic","text_bw":"radama","text_ar":"رَدَمَ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"radomN","text_ar":"رَدْمٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"rd~m","text_ar":"ردّم","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tarodiymN","text_ar":"تَرْدِيمٌ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"trd~m","text_ar":"تردّم","orth_type":"arrow"},{"kind":"text","text":"; (S, K, TA;)"},{"kind":"italic_en","text":"He patched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieced,"},{"kind":"text","text":"a garment, or piece of cloth; or"},{"kind":"italic_en","text":"patched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieced,"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"in several places."},{"kind":"text","text":"(S, K, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"rudima","text_ar":"رُدِمَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"was put, and joined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sewed, one part to another."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"radama Alqawosa","text_ar":"رَدَمَ القَوْسَ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"radomN","text_ar":"رَدْمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He caused the bow to make a sound,"},{"kind":"text","text":"[i. e.,"},{"kind":"italic_en","text":"to twang,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by pulling the string and then letting it go."},{"kind":"text","text":"(M, K. *) And"},{"kind":"arabic","text_bw":"rudimati Alqawosu","text_ar":"رُدِمَتِ القَوْسُ"},{"kind":"italic_en","text":"The bow was so caused to make a sound."},{"kind":"text","text":"(T, M.)       -A3-"},{"kind":"arabic","text_bw":"radama","text_ar":"رَدَمَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yarodimu","text_ar":"يَرْدِمُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"yarodumu","text_ar":"يَرْدُمُ"},{"kind":"text","text":", with damm, (accord. to different copies of the S, [in one copy"},{"kind":"arabic","text_bw":"raduma","text_ar":"رَدُمَ"},{"kind":"text","text":", with damm, which is a mistake,]) inf. n."},{"kind":"arabic","text_bw":"rudaAmN","text_ar":"رُدَامٌ"},{"kind":"text","text":"; (S, K; *) or"},{"kind":"arabic","text_bw":"radama","text_ar":"رَدَمَ"},{"kind":"text","text":", said of a camel, and of an ass, aor."},{"kind":"arabic","text_bw":"yarodimu","text_ar":"يَرْدِمُ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"radomN","text_ar":"رَدْمٌ"},{"kind":"text","text":", (M, K, *) and"},{"kind":"arabic","text_bw":"rudaAmN","text_ar":"رُدَامٌ"},{"kind":"text","text":"is the subst.; or"},{"kind":"arabic","text_bw":"radama bihaA","text_ar":"رَدَمَ بِهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"radomN","text_ar":"رَدْمٌ"},{"kind":"text","text":", used in a general manner; (M;)"},{"kind":"italic_en","text":"He broke wind, with a sound."},{"kind":"text","text":"(S, M, K. *)       -A4-  See also 4, in two places."}],"source_refs":["S","M","Msb","K","Lth","T","TA"]}]}}