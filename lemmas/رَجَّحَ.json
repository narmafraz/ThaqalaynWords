p":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَجِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَجِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَجِّح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَجِّح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَجِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَجِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَجِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَجِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَجِّحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَجِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَجِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُرَجِّح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَجِّح","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَجَّحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَجَّحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n14825"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AC%D9%8E%D9%91%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to weigh more, to outweigh","tags":["ambitransitive"]},{"pos":"verb","gloss":"to be likely","tags":["intransitive"]},{"pos":"verb","gloss":"to weigh","tags":["transitive"]},{"pos":"verb","gloss":"to weigh out, to balance"},{"pos":"verb","gloss":"to give more weight to, to give precedence to, to prefer"},{"pos":"verb","gloss":"to claim the preponderance of"},{"pos":"verb","gloss":"to hold as likely","examples":[{"text":"ويشار بحسب المجلة، بان اعداد إرهابيي داعش الأجانب ما زال كبيرا جدا على الرغم من التقديرات التي ترجح مقتل الآلاف منهم، حيث تظهر البيانات المجموعة من 33 دولة لها مواطنين يقاتلون مع عصابات داعش الإرهابية، ان ما يزيد عن 6000 منهم قد تمكنوا من العودة الى بلدانهم، فيما تصل اعداد الغائبين إلى الآلاف المضاعفة.","english":"It is shown by the magazine that the number of foreign ISIS terrorists has not ceased to be very large in spite of assessments that affirm the death of thousands of them as likely, whereas the data gathered from 33 states to which citizens fighting for terrorist ISIS groups belong reveals that more than 6000 of them have had the opportunity of returning to their homelands, while the number of absentees has reached several thousands."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14825","headword_ar":"رَجَحَ","root":"rjH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"rujuwHN","text_ar":"رُجُوحٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"rajaHaAnN","text_ar":"رَجَحَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rujoHaAnN","text_ar":"رُجْحَانٌ"},{"kind":"text","text":", (TA,) or this last is a simple subst., (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"exceeded another thing in weight; outweighed; preponderated."},{"kind":"text","text":"(Msb, TA. *) And"},{"kind":"arabic","text_bw":"rajaHa AlmyzaAnu","text_ar":"رَجَحَ الميزَانُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"text","text":"(S, Msb, K, but omitted in some copies of the S) and"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"rujoHaAnN","text_ar":"رُجْحَانٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"rujuwHN","text_ar":"رُجُوحٌ"},{"kind":"text","text":", (K,) [but see what is said of the former above,]"},{"kind":"italic_en","text":"The balance inclined;"},{"kind":"text","text":"(S, Msb, K;) i. e."},{"kind":"italic_en","text":"the scale, of the balance, in which was the thing weighed was heavier than the other;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"trj~H","text_ar":"ترجّح","orth_type":"arrow"},{"kind":"text","text":". (MA.) And"},{"kind":"arabic","text_bw":"rajaHato A_iHodaY Alkaf~atayoni","text_ar":"رَجَحَتْ اـِحْدَى الكَفَّتَيْنِ"},{"kind":"arabic","text_bw":"EalaY AlA^uxuriY","text_ar":"عَلَى الاُخُرِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"One of the two scales outweighed the other"},{"kind":"text","text":"]. (A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"rajaHa A^aHadu qawolayohi EalaY","text_ar":"رَجَحَ اَحَدُ قَوْلَيْهِ عَلَى"},{"kind":"arabic","text_bw":"AlA=xari","text_ar":"الا=خَرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"One of his two sayings outweighed the other; surpassed, excelled, was preferable to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of more force"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"validity than, the other"},{"kind":"text","text":"]. (A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"rajaHa Al$~aYo'u","text_ar":"رَجَحَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"rjHn","text_ar":"رجحن"},{"kind":"text","text":"[q. v.].) ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"rajaHa fiY majolisihi","text_ar":"رَجَحَ فِى مَجْلِسِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy,"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"dull, torpid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drowsy,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not light,"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"not lively"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in his sitting-place."},{"kind":"text","text":"(TA.)       -A2-  It is also used transitively: one says,"},{"kind":"arabic","text_bw":"rajaHotuhu","text_ar":"رَجَحْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I outweighed him"},{"kind":"text","text":"]. (Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"rajaHahu","text_ar":"رَجَحَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He surpassed him in gravity, staidness, sedateness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"forbearance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clemency; was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, more grave, staid, sedate,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"forbearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clement,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^arozan","text_ar":"اَرْزَن"},{"kind":"text","text":", S, K, TA, and"},{"kind":"arabic","text_bw":"A^aHolam","text_ar":"اَحْلَم"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"than he."},{"kind":"text","text":"(S, K, TA.) So in the saying,"},{"kind":"arabic","text_bw":"naAwaA^onaA qawomFA","text_ar":"نَاوَاْنَا قَوْمًا"},{"kind":"arabic","text_bw":"farajaHonaAhumo","text_ar":"فَرَجَحْنَاهُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"We vied with a people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, and surpassed them in gravity,"},{"kind":"text","text":"&c.]. (TA.) And"},{"kind":"arabic","text_bw":"farajaHotuhu","text_ar":"فَرَجَحْتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raAjaHotuhu","text_ar":"رَاجَحْتُهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I vied with him in gravity,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and surpassed him therein"},{"kind":"text","text":"]. (S, K, TA.) ―         -b3-  You say also,"},{"kind":"arabic","text_bw":"rajaHa Al$~aYo'a biyadihi","text_ar":"رَجَحَ الشَّىْءَ بِيَدِهِ"},{"kind":"italic_en","text":"He weighed the thing with his hand, trying what was its weight:"},{"kind":"text","text":"(TA:) or so"},{"kind":"arabic","text_bw":"rajaHahu","text_ar":"رَجَحَهُ"},{"kind":"text","text":"alone. (A.)"}],"source_refs":["Msb","TA","S","A","K"]}]}}