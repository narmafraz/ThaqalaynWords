N","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":", (S, O, Msb, K,)"},{"kind":"italic_en","text":"of a country:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"a place, region, quarter, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point, towards which a person,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing, goes, tends,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is directed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jihapN","text_ar":"جِهَةٌ"},{"kind":"text","text":": and"},{"kind":"italic_en","text":"a place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of descending and stopping"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sojourning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lodging"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settling;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place of abode"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settlement;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maHal~apN","text_ar":"مَحَلَّةٌ"},{"kind":"text","text":": (Msb:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aSoqaAEN","text_ar":"اَصْقَاعٌ"},{"kind":"text","text":", (O, TA,) and pl. pl."},{"kind":"arabic","text_bw":"A^aSaAqiEu","text_ar":"اَصَاقِعُ"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"SuqogN","text_ar":"صُقْغٌ"},{"kind":"text","text":"is a dial. var. thereof. (IJ, TA; and K in art."},{"kind":"arabic","text_bw":"Sqg","text_ar":"صقغ"},{"kind":"text","text":".) One says,"},{"kind":"arabic","text_bw":"fulaAnN mino A^aholi h`*aA AlS~uqoEi","text_ar":"فُلَانٌ مِنْ اَهْلِ هٰذَا الصُّقْعِ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"mino h`*ihi","text_ar":"مِنْ هٰذِهِ"},{"kind":"arabic","text_bw":"Aln~aAHiyapi","text_ar":"النَّاحِيَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is of the people of this district,"},{"kind":"text","text":"&c.]. (S, O.) And"},{"kind":"arabic","text_bw":"huwa fiY SuqoEi baniY fulaAnK","text_ar":"هُوَ فِى صُقْعِ بَنِى فُلَانٍ"},{"kind":"italic_en","text":"He is in the"},{"kind":"arabic","text_bw":"naAHiyap","text_ar":"نَاحِيَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"district,"},{"kind":"text","text":"&c.], and"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"maHal~ap","text_ar":"مَحَلَّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"place of alighting,"},{"kind":"text","text":"&c.],"},{"kind":"italic_en","text":"of the sons of such a one."},{"kind":"text","text":"(Msb.) See also"},{"kind":"arabic","text_bw":"miSoqaEN","text_ar":"مِصْقَعٌ"},{"kind":"text","text":". ―         -b2-  Also"},{"kind":"italic_en","text":"A part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, of the surrounding and inferior sides"},{"kind":"text","text":"of a well: pl."},{"kind":"arabic","text_bw":"A^aSoqaAEN","text_ar":"اَصْقَاعٌ"},{"kind":"text","text":": but the more approved word is with"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","O","Msb","K","TA"]},{"entry_id":"n24600","headword_ar":"صَقَعٌ","root":"SqE","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"SaqiEa","text_ar":"صَقِعَ"},{"kind":"text","text":". (S, &c.) ―         -b2-  Also"},{"kind":"italic_en","text":"An affection like"},{"kind":"arabic","text_bw":"gam~N","text_ar":"غَمٌّ"},{"kind":"text","text":", [i. e.]"},{"kind":"italic_en","text":"that takes away the breath,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yaA^oxu*u biAln~afasi","text_ar":"يَاْخُذُ بِالنَّفَسِ"},{"kind":"text","text":", S, O, K, [in the CK,"},{"kind":"arabic","text_bw":"bAln~afosi","text_ar":"بالنَّفْسِ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"by reason of the vehemence of the heat."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":[]},{"entry_id":"n24601","headword_ar":"صَقِعٌ","root":"SqE","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Smitten by a thunderbolt:"},{"kind":"text","text":"(see its verb,"},{"kind":"arabic","text_bw":"SaqiEa","text_ar":"صَقِعَ"},{"kind":"text","text":":) or]"},{"kind":"italic_en","text":"smitten as by a thunderbolt"},{"kind":"text","text":"from the enemy: so accord. to some: (O, TA:) 'Ows Ibn-Hajar says,"},{"kind":"quote","text":"A^abaA dulayojapa mano liHaY~K muforadK\n                      \n                     \n                        SaqiEK mina AlA^aEodaA='i fiY $aw~aAli"},{"kind":"text","text":"(S, * O, TA, but in the TA"},{"kind":"arabic","text_bw":"A^aAabaA","text_ar":"اَاَبَا"},{"kind":"text","text":") [which may be rendered"},{"kind":"italic_en","text":"O Aboo-Duleyjeh, who is for a solitary tribe, smitten as though by a thunderbolt from the enemies, in Showwál"},{"kind":"text","text":"(which was, in the time of the poet, a cold month) ?]: or, accord. to IAar, the meaning here is,"},{"kind":"italic_en","text":"in a state of retirement, remote from the enemies;"},{"kind":"text","text":"(S, * O;) for when the winter pressed severely upon the man, he used to retire to a distance, lest a guest should alight at his abode; the enemies being the strange guests; and by saying"},{"kind":"arabic","text_bw":"fY $w~Al","text_ar":"فى شوّال"},{"kind":"text","text":", he means that the cold was in Showwál: (O, TA:) or"},{"kind":"arabic","text_bw":"SaqiEN","text_ar":"صَقِعٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"absent and remote, so that one knows not where he is:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that has gone away, and alighted alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by himself:"},{"kind":"text","text":"(TA:) [pl."},{"kind":"arabic","text_bw":"SaqoEaY","text_ar":"صَقْعَى"},{"kind":"text","text":":] see an ex. voce"},{"kind":"arabic","text_bw":"daqiEN","text_ar":"دَقِعٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"A^aroDN SaqiEapN","text_ar":"اَرْضٌ صَقِعَةٌ"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"maSoquwEapN","text_ar":"مَصْقُوعَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"Earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, overspread with the"},{"kind":"arabic","text_bw":"SaqiyE","text_ar":"صَقِيع"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"hoarfrost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rime"},{"kind":"text","text":"]: (S, Msb, TA:) and in like manner,"},{"kind":"arabic","text_bw":"$ajarN SaqiEN","text_ar":"شَجَرٌ صَقِعٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"muSoqaEN","text_ar":"مُصْقَعٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"trees overspread with the"},{"kind":"arabic","text_bw":"SaqiyE","text_ar":"صَقِيع"},{"kind":"text","text":". (TA.)"}],"source_refs":["O","TA","S","Msb"]}]},"classical_definitions":null}