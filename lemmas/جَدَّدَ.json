,"gen":"m","num":"p"},{"role":"present_2mp","form":"تُجَدِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجَدِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجَدِّد","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجَدِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجَدِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجَدِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجَدِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجَدِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجَدِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجَدِّدُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجَدِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَدَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَدَّدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجَدِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجَدِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":32,"cross_references":{"qac":{"found":true,"lemma_key":"جَدَّدَ","root":"جدد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n5157","n5167"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%AF%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to renew, refresh, restore, refurbish"},{"pos":"verb","gloss":"to interweave with variegated stripes"},{"pos":"verb","gloss":"to clip the camel's udder"},{"pos":"verb","gloss":"to repeat (modern)"},{"pos":"verb","gloss":"to return in worse degree"},{"pos":"noun","gloss":"hard ground, rough ground, level ground","examples":[{"text":"إِذَا تَرَامَت بِهَا الدَيْمُومَةُ الْجَدَدُ / عَوْمَ الْقَوَادِسِ قَفَّى الْأَرْدَمُونَ بِهَا / إِذَا تَرَامَى بِهَا الْمُغْلَوْلِبُ الزَبِدُ / بِفِتْيَةٍ كَسُيُوفِ الْهِنْدِ يَبْعَثُهُم","english":"When the wasteland of the hard soil was reached / by floating in the barges, they put up behind them the foresail / And when the luxuriance of foam / hit the young men, it sent them forth like Indian swords."}]},{"pos":"noun","gloss":"plural of جُدَّة (judda)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Causative of جَدَّ (jadda, “to be new”), from the root ج د د (j d d). Sense \"interweave with variegated stripes” is denominal from جُدَّة (judda, “stripe”).\n\nSee the etymology of the corresponding lemma form."},"ipa":["/d͡ʒad.da.da/","/d͡ʒa.dad/","/d͡ʒu.dad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5157","headword_ar":"جدّد","root":"jd","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajodiydN","text_ar":"تَجْدِيدٌ"},{"kind":"text","text":": see 1.       -A2-  See also 4, in three places.       -A3-"},{"kind":"arabic","text_bw":"tjdyd","text_ar":"تجديد"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"weaving"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"stripes of different colours in a garment."},{"kind":"text","text":"(KL.)"},{"kind":"page_break","n":385}],"source_refs":[]},{"entry_id":"n5167","headword_ar":"جَدَدٌ","root":"jd","body":[{"kind":"italic_en","text":"Hard ground:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"hard level ground:"},{"kind":"text","text":"(Har p. 522:) [see also"},{"kind":"arabic","text_bw":"jadojadN","text_ar":"جَدْجَدٌ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"rough level ground:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"rough ground:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level ground:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a level and spacious tract of land; a tract such as is called"},{"kind":"arabic","text_bw":"SaHoraA='","text_ar":"صَحْرَا=ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"and such as is called"},{"kind":"arabic","text_bw":"faDaA='","text_ar":"فَضَا=ء"},{"kind":"text","text":","},{"kind":"italic_en","text":"containing no soft place in which the feet sink, nor any mountain, nor any"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hill such as is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"text","text":";"},{"kind":"italic_en","text":"sometimes wide, and sometimes of little width:"},{"kind":"text","text":"(ISh:) [and]"},{"kind":"italic_en","text":"a conspicuous road:"},{"kind":"text","text":"(Bd in xxxv. 25:) pl."},{"kind":"arabic","text_bw":"A^ajodaAdN","text_ar":"اَجْدَادٌ"},{"kind":"text","text":". (ISh.) It is said in a prov.,"},{"kind":"arabic","text_bw":"mano salaka Aljadada A^amina AlEivaAra","text_ar":"مَنْ سَلَكَ الجَدَدَ اَمِنَ العِثَارَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who walks along hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard and level, ground is secure from stumbling"},{"kind":"text","text":"]; (S, TA;) meaning, he who pursues the course marked out by common consent is secure from stumbling. (TA.) And"},{"kind":"arabic","text_bw":"makaAnN jadadN","text_ar":"مَكَانٌ جَدَدٌ"},{"kind":"text","text":"occurs in a trad., meaning"},{"kind":"italic_en","text":"Level ground."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"jadiydN","text_ar":"جَدِيدٌ"},{"kind":"text","text":". ―         -b3-  Also Sand that is"},{"kind":"italic_en","text":"thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and sloping down."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"italic_en","text":"A thing resembling a"},{"kind":"arabic","text_bw":"siloEap","text_ar":"سِلْعَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ganglion"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the neck of a camel."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","TA","ISh"]}]}}