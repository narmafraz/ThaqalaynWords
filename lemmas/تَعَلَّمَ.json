h_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D9%84%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to learn (something)","tags":["transitive"],"examples":[{"text":"فَيَتَعَلَّمُونَ مِنْهُمَا مَا يُفَرِّقُونَ بِهِ بَيْنَ ٱلْمَرْءِ وَزَوْجِهِ وَمَا هُمْ بِضَارِّينَ بِهِ مِنْ أَحَدٍ إِلَّا بِإِذْنِ اللَّهِ وَيَتَعَلَّمُونَ مَا يَضُرُّهُمْ وَلَا يَنْفَعُهُمْ"}]},{"pos":"noun","gloss":"verbal noun of تَعَلَّمَ (taʕallama) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"action of learning"}]},"etymology":null,"ipa":["/ta.ʕal.la.ma/","/ta.ʕal.lum/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30342","headword_ar":"تعلّم","root":"Elm","body":[{"kind":"text","text":"is quasi-pass. of 2 [i. e. it signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, made to know,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"taught;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he learned:"},{"kind":"text","text":"and is trans. and intrans.]. (S, Msb, K, * TA.) You say,"},{"kind":"arabic","text_bw":"tEl~m AlEiloma","text_ar":"تعلّم العِلْمَ"},{"kind":"text","text":"(MA, K)"},{"kind":"italic_en","text":"He learned"},{"kind":"text","text":"["},{"kind":"italic_en","text":"knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science"},{"kind":"text","text":"]. (MA.) See also 1, latter half, in three places. [In the last of those places,"},{"kind":"arabic","text_bw":"tEl~m","text_ar":"تعلّم"},{"kind":"text","text":"app. signifies, as it often does,"},{"kind":"italic_en","text":"He possessed knowledge as a faculty firmly rooted in his mind."},{"kind":"text","text":"] Accord. to some,"},{"kind":"arabic","text_bw":"Alt~aEal~umu","text_ar":"التَّعَلُّمُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The mind's having its attention excited to the conception of meanings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ideas."},{"kind":"text","text":"(TA.)"}],"source_refs":["MA","K"]}]},"classical_definitions":null}