D%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bark, to bay, to yelp"},{"pos":"noun","gloss":"barking, baying, yelping"}]},"etymology":null,"ipa":["/na.ba.ħa/","/nabħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39193","headword_ar":"نَبَحَ","root":"nbH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", [the former of which, accord. to the Msb, seems to be more common,] inf. n."},{"kind":"arabic","text_bw":"naboHN","text_ar":"نَبْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nabiyHN","text_ar":"نَبِيحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nubaAHN","text_ar":"نُبَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nibaAHN","text_ar":"نِبَاحٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"nubuwHN","text_ar":"نُبُوحٌ"},{"kind":"text","text":"(L,) and"},{"kind":"arabic","text_bw":"tanobaAHN","text_ar":"تَنْبَاحٌ"},{"kind":"text","text":", (K,) the last having an intensive and frequentative signification, (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a dog, S, L, K)"},{"kind":"italic_en","text":"barked."},{"kind":"text","text":"(L.) ―         -b2-  Also, (sometimes, S,) (tropical:)  said of a gazelle, (T, S, K,) when he has advanced in years, and his horns have branched forth: (T:) and (tropical:)  of a he-goat, (K,) in coupling-time: (L:) and (tropical:)  of a serpent; (K;) meaning"},{"kind":"italic_en","text":"he uttered a cry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound:"},{"kind":"text","text":"(L:) also (tropical:)  of a hoopoe, ("},{"kind":"arabic","text_bw":"hudohud","text_ar":"هُدْهُد"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"nubaAHN","text_ar":"نُبَاحٌ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"it uttered a harsh cry, by reason of age:"},{"kind":"text","text":"(L:) and (tropical:)  of a lion, inf. n."},{"kind":"arabic","text_bw":"nubaAHN","text_ar":"نُبَاحٌ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"he uttered a cry"},{"kind":"text","text":"(L, K)"},{"kind":"italic_en","text":"like the barking of a whelp."},{"kind":"text","text":"(Aboo-Kheyreh, L.) ―         -b3-"},{"kind":"arabic","text_bw":"nabaHahi Alkalobu","text_ar":"نَبَحَهِ الكَلْبُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nabaHa Ealayohi","text_ar":"نَبَحَ عَلَيْهِ"},{"kind":"text","text":", (T, Msb,) and ↓"},{"kind":"arabic","text_bw":"nAbHhu","text_ar":"نابحهُ","orth_type":"arrow"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"The dog barked at him."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"fulaAnN laA yuEowaY walaA yunobaHu","text_ar":"فُلَانٌ لَا يُعْوَى وَلَا يُنْبَحُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Such a one is not howled at nor barked at"},{"kind":"text","text":"]: i. e., by reason of his weakness, no account is taken of him, and neither good nor evil is said to him. (L.) ―         -b5-"},{"kind":"arabic","text_bw":"nabaHa","text_ar":"نَبَحَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a poet)"},{"kind":"italic_en","text":"satirized."},{"kind":"text","text":"(A.) ―         -b6-"},{"kind":"arabic","text_bw":"nabaHatoniY","text_ar":"نَبَحَتْنِى"},{"kind":"arabic","text_bw":"kilaAbuka","text_ar":"كِلَابُكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Thy revilings reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overtook, me."},{"kind":"text","text":"(L.)"}],"source_refs":["S","K","L","TA","T","Msb"]}]},"classical_definitions":null}