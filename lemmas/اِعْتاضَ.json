t":",) likewise signifies"},{"kind":"italic_en","text":"I took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received, a substitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something instead"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in exchange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a compensation:"},{"kind":"text","text":"(Lth, TA:) but Az says, “ I have not heard this on any other authority than that of Lth. ” (O, TA.) You say also,"},{"kind":"arabic","text_bw":"AiEotaADa xayorFA mim~aA *ahaba minohu","text_ar":"اِعْتَاضَ خَيْرًا مِمَّا ذَهَبَ مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He received as a substitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compensation, what was better than that which had gone from him"},{"kind":"text","text":"]; and [in like manner] ↓"},{"kind":"arabic","text_bw":"taEaw~aDa","text_ar":"تَعَوَّضَ","orth_type":"arrow"},{"kind":"text","text":". (A.)       -A2-"},{"kind":"arabic","text_bw":"AEtADhu","text_ar":"اعتاضهُ"},{"kind":"italic_en","text":"He came to him seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding, a substitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something instead"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in exchange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a compensation;"},{"kind":"text","text":"(O, K;) and"},{"kind":"italic_en","text":"a free gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gratuity."},{"kind":"text","text":"(O, TA.) [See also 10.]"}],"source_refs":["S","O","Msb","K","Lth","TA"]}]},"classical_definitions":null}