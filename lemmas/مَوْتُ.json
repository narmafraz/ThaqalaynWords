{"lemma":"مَوْتُ","slug":"مَوْتُ","root":"م.#.ت","root_slug":"م-_-ت","root_link":"/words/roots/م-_-ت","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَوْت","root":"موت","pos":"N","occurrence_count":50},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n39008"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%88%D9%92%D8%AA%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of مَاتَ (māta, “to die”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"death","examples":[{"text":"أَيۡنَمَا تَكُونُوا۟ يُدۡرِككُّمُ ٱلۡمَوۡتُ وَلَوۡ كُنتُمۡ فِي بُرُوجࣲ مُّشَيَّدَةࣲ","english":"Wherever you may be, death will overtake you, even if you should be within towers of lofty construction."}]},{"pos":"noun","gloss":"demise"},{"pos":"verb","gloss":"to die off","tags":["intransitive","obsolete"]},{"pos":"verb","gloss":"to make die, let perish, to kill, to cause the death of","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-Semitic *mawt- (“death”). Compare Akkadian 𒁁 (mūtum, “death”), Ugaritic 𐎎𐎚 (mt, “death”), Aramaic ܡܘܬܐ (mawtā), Hebrew מָוֶת (mávet, “death”), Amharic ሞት (mot, “death”) and Egyptian mtt:m*A14"},"ipa":["/mawt/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39008","headword_ar":"مَوْتٌ","root":"mwt","body":[{"kind":"text","text":"(and ↓"},{"kind":"arabic","text_bw":"mawataAnN","text_ar":"مَوَتَانٌ","orth_type":"arrow"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"Death; lifelessness;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"HayaApN","text_ar":"حَيَاةٌ"},{"kind":"text","text":": (S, TA:) as also ↓"},{"kind":"arabic","text_bw":"muwaAtN","text_ar":"مُوَاتٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"mamaAtN","text_ar":"مَمَاتٌ","orth_type":"arrow"},{"kind":"text","text":". [Occurring in the Kur, vi. 163, xvii. 77, and xlv. 20,] (S, * TA, in art."},{"kind":"arabic","text_bw":"HY","text_ar":"حى"},{"kind":"text","text":", and Jel, in vi. 163.) [See also"},{"kind":"arabic","text_bw":"muwtaAnN","text_ar":"مُوتَانٌ"},{"kind":"text","text":", below: and see 1.] Or ↓"},{"kind":"arabic","text_bw":"mawataAnN","text_ar":"مَوَتَانٌ","orth_type":"arrow"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"much death,"},{"kind":"text","text":"like as"},{"kind":"arabic","text_bw":"HayawaAnN","text_ar":"حَيَوَانٌ"},{"kind":"text","text":"signifies much life. (Msb, in art."},{"kind":"arabic","text_bw":"HY","text_ar":"حى"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"Almawotu AlA^aboyaDu","text_ar":"المَوْتُ الاَبْيَضُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AljaArifu","text_ar":"الجَارِفُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"All~aAfitu","text_ar":"اللَّافِتُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlfaAtilu","text_ar":"الفَاتِلُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Sudden death."},{"kind":"text","text":"(IAar, in T and TA, art."},{"kind":"arabic","text_bw":"flt","text_ar":"فلت"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"Almawotu AlA^aHomaru","text_ar":"المَوْتُ الاَحْمَرُ"},{"kind":"italic_en","text":"Death by slaughter with the sword."},{"kind":"text","text":"(IAar, in T, TA, art."},{"kind":"arabic","text_bw":"flt","text_ar":"فلت"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"Almawotu AlA^asowadu","text_ar":"المَوْتُ الاَسْوَدُ"},{"kind":"italic_en","text":"Death by drowning, and by suffocation."},{"kind":"text","text":"(IAar, in T and TA, art."},{"kind":"arabic","text_bw":"flt","text_ar":"فلت"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"banaAtu Almawoti","text_ar":"بَنَاتُ المَوْتِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The daughters of death;"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"deadly arrows."},{"kind":"text","text":"(A, TA, voce"},{"kind":"arabic","text_bw":"jaEobapN","text_ar":"جَعْبَةٌ"},{"kind":"text","text":", q. v.)"}],"source_refs":["S","TA","K"]}]}}