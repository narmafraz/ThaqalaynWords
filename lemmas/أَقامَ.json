r":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُقام","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَقَمْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَقَمْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُقِيم","in_corpus":true,"count":38,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُقِيم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":453,"cross_references":{"qac":{"found":true,"lemma_key":"أَقامَ","root":"قوم","pos":"V","occurrence_count":54},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n42888"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%82%D8%A7%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of أَقَامَ (ʔaqāma) (form IV)","tags":["form-of","noun-from-verb"],"examples":[{"text":"رِجَالٌ لَّا تُلْهِيهِمْ تِجَارَةٌ وَلَا بَيْعٌ عَن ذِكْرِ اللَّهِ وَإِقَامِ الصَّلَاةِ وَإِيتَاءِ الزَّكَاةِ يَخَافُونَ يَوْمًا تَتَقَلَّبُ فِيهِ الْقُلُوبُ وَالْأَبْصَارُ"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42888","headword_ar":"اَقَامَ","root":"qwm","body":[{"kind":"italic_en","text":"He set up, put up, set upright,"},{"kind":"text","text":"a thing. (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"A^aqaAmahu","text_ar":"اَقَامَهُ"},{"kind":"text","text":", said of food, ["},{"kind":"italic_en","text":"It sustained him, supported him"},{"kind":"text","text":"]. (Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"A^aqaAma EalaY xaTarK","text_ar":"اَقَامَ عَلَى خَطَرٍ"},{"kind":"italic_en","text":"He stood to a bet, wager,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake."},{"kind":"text","text":"(TA, voce"},{"kind":"arabic","text_bw":"nadiabN","text_ar":"نَدَِبٌ"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"arabic","text_bw":"Ealayohi AlH~ada","text_ar":"عَلَيْهِ الحَّدَ"},{"kind":"italic_en","text":"He inflicted upon him the punishment termed"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":". (Mgh, art."},{"kind":"arabic","text_bw":"Hd","text_ar":"حد"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"A^aqaAma daroA^ahu","text_ar":"اَقَامَ دَرْاَهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"drA^","text_ar":"درا"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"A^aqaAma lilS~alaApia","text_ar":"اَقَامَ لِلصَّلَاةَِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iqaAmapN","text_ar":"اـِقَامَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the"},{"kind":"arabic","text_bw":"mubal~ig","text_ar":"مُبَلِّغ"},{"kind":"text","text":") recited"},{"kind":"italic_en","text":"the form of words called"},{"kind":"arabic","text_bw":"A_iqaAmap","text_ar":"اـِقَامَة"},{"kind":"text","text":", q. v. infra. ―         -b7-"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"italic_en","text":"He remained, continued, stayed, tarried, resided, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"in a place:"},{"kind":"italic_en","text":"he remained stationary."},{"kind":"text","text":"―         -b8-"},{"kind":"arabic","text_bw":"A^aqaAma AlS~alaApa","text_ar":"اَقَامَ الصَّلَاةَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He observed prayer:"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A^adaAma fiEolahaA","text_ar":"اَدَامَ فِعْلَهَا"},{"kind":"text","text":". (S, Msb.) See also Bd, and Jel ii. 2. ―         -b9-"},{"kind":"arabic","text_bw":"A^aqaAma fiEolFA","text_ar":"اَقَامَ فِعْلًا"},{"kind":"italic_en","text":"He performed an action."},{"kind":"text","text":"―         -b10-  See 1. ―         -b11-"},{"kind":"arabic","text_bw":"A^aqaAmahu EalaY AlT~ariyqi","text_ar":"اَقَامَهُ عَلَى الطَّرِيقِ"},{"kind":"italic_en","text":"He made him to keep to the road:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"llqaSodi","text_ar":"للقَصْدِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"to the right way."},{"kind":"text","text":"(L, art."},{"kind":"arabic","text_bw":"lgd","text_ar":"لغد"},{"kind":"text","text":".) ―         -b12-  See 10. ―         -b13-"},{"kind":"arabic","text_bw":"A^aqaAama AlA^amora","text_ar":"اَقَاَمَ الاَمْرَ"},{"kind":"italic_en","text":"He put the affair"},{"kind":"page_break","n":2996},{"kind":"italic_en","text":"into a right state;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"naZamahu","text_ar":"نَظَمَهُ"},{"kind":"text","text":": see the latter in the Msb. ―         -b14-"},{"kind":"arabic","text_bw":"A^aqaAmahu","text_ar":"اَقَامَهُ"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"Edl","text_ar":"عدل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"He made it to be conformable with that which is right;"},{"kind":"text","text":"namely, a judgment, a judicial decision. (TK in that art.) ―         -b15-  See 2. ―         -b16-"},{"kind":"arabic","text_bw":"A^aqaAma bihi","text_ar":"اَقَامَ بِهِ"},{"kind":"text","text":"in the Hamáseh, p. 75, 1. 9, app. signifies"},{"kind":"italic_en","text":"He stood in his stead."},{"kind":"text","text":"―         -b17-"},{"kind":"arabic","text_bw":"A^aqaAma","text_ar":"اَقَامَ"},{"kind":"italic_en","text":"He observed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"duly performed,"},{"kind":"text","text":"a religious, or moral, ordinance or duty. ―         -b18-"},{"kind":"arabic","text_bw":"A^aqaAma Albay~inapa","text_ar":"اَقَامَ البَيِّنَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He established the evidence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proof;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"AqAm bihaA","text_ar":"اقام بِهَا"},{"kind":"text","text":"? the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"being redundant]. (Bd, iii. 68.) And [in like manner,]"},{"kind":"arabic","text_bw":"AqAm Huj~atahu","text_ar":"اقام حُجَّتَهُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^avobatahaA","text_ar":"اَثْبَتَهَا"},{"kind":"text","text":"; (TA in art."},{"kind":"arabic","text_bw":"vbt","text_ar":"ثبت"},{"kind":"text","text":";) and so, app.,"},{"kind":"arabic","text_bw":"biHuj~atihi","text_ar":"بِحُجَّتِهِ"},{"kind":"text","text":"; the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"being redundant, as in an ex. voce"},{"kind":"arabic","text_bw":"xuT~apN","text_ar":"خُطَّةٌ"},{"kind":"text","text":"; but this is the only ex. that I know, and it is without explanation: Golius mentions the phrase"},{"kind":"arabic","text_bw":"A^aqaAma biY Ealayokumo","text_ar":"اَقَامَ بِى عَلَيْكُمْ"},{"kind":"text","text":"; but without indicating his authority. ―         -b19-"},{"kind":"arabic","text_bw":"A^aqaAma EalaY","text_ar":"اَقَامَ عَلَى"},{"kind":"arabic","text_bw":"HaAlK","text_ar":"حَالٍ"},{"kind":"italic_en","text":"He abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, in a state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AqAm ElY A^amorK","text_ar":"اقام على اَمْرٍ"},{"kind":"italic_en","text":"the same;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he abode, continued, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited, intent upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupied in, an affair, a business,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a concern; he kept to it."}],"source_refs":[]}]},"classical_definitions":null}