{"lemma":"مُغَلَّبٌ","slug":"مُغَلَّبٌ","root":"غ.ل.ب","root_slug":"غ-ل-ب","root_link":"/words/roots/غ-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n32205"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%BA%D9%8E%D9%84%D9%8E%D9%91%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of غَلَبَ (ḡalaba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32205","headword_ar":"مُغَلَّبٌ","root":"glb","body":[{"kind":"italic_en","text":"Overcome, conquered,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"repeatedly, several times,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many times;"},{"kind":"text","text":"(S, A, K, TA;) applied to a poet: (A:) and (so applied, S, A, TA)"},{"kind":"italic_en","text":"judged to have overcome"},{"kind":"text","text":"(S, A, * K, TA)"},{"kind":"italic_en","text":"his fellow,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often:"},{"kind":"text","text":"(A:) thus having two contr. significations: (S, K:) an epithet of praise as well as of dispraise: (O:) or, when the Arabs say of a poet that he is"},{"kind":"arabic","text_bw":"mugal~ab","text_ar":"مُغَلَّب"},{"kind":"text","text":", the meaning is that he is"},{"kind":"italic_en","text":"overcome;"},{"kind":"text","text":"but if they say,"},{"kind":"arabic","text_bw":"gul~iba fulaAnN","text_ar":"غُلِّبَ فُلَانٌ"},{"kind":"text","text":", the meaning is,"},{"kind":"italic_en","text":"such a one has"},{"kind":"text","text":"["},{"kind":"italic_en","text":"been judged to have"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"overcome:"},{"kind":"text","text":"thus they say,"},{"kind":"arabic","text_bw":"gul~ibato layolaY AlA^axoyaliy~apu EalaY naAbigapi baniY jaEodapa","text_ar":"غُلِّبَتْ لَيْلَى الاَخْيَلِيَّةُ عَلَى نَابِغَةِ بَنِى جَعْدَةَ"},{"kind":"text","text":", for she overcame him, and he ([En-Nábighah] El-Jaadee) was"},{"kind":"arabic","text_bw":"mugal~ab","text_ar":"مُغَلَّب"},{"kind":"text","text":". (Mohammad Ibn-Selám, TA.)"}],"source_refs":["A","S","TA","K","O"]}]},"classical_definitions":null}