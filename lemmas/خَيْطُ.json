{"lemma":"خَيْطُ","slug":"خَيْطُ","root":"خ.#.ط","root_slug":"خ-_-ط","root_link":"/words/roots/خ-_-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَيْط","root":"خيط","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["","n11836","n11837","n11838"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%8A%D9%92%D8%B7%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of خَاطَ (ḵāṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"thread; string; cord"},{"pos":"noun","gloss":"thread"},{"pos":"verb","gloss":"to sew"}]},"etymology":null,"ipa":["/xajtˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11836","headword_ar":"خَيْطٌ","root":"xyT","body":[{"kind":"italic_en","text":"Thread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"string;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thread"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"string;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"silokN","text_ar":"سِلْكٌ"},{"kind":"text","text":"; (S, K;) the"},{"kind":"italic_en","text":"thing with which one sews;"},{"kind":"text","text":"(Msb;) [often used as a coll. gen. n.; n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":";] and ↓"},{"kind":"arabic","text_bw":"xiyaATN","text_ar":"خِيَاطٌ","orth_type":"arrow"},{"kind":"text","text":"[likewise] signifies the"},{"kind":"italic_en","text":"thing with which a garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, is sewed;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mixoyaTN","text_ar":"مِخْيَطٌ","orth_type":"arrow"},{"kind":"text","text":"; besides having another signification, common to it with the last, namely “a needle; ” (K;) the pl. of"},{"kind":"arabic","text_bw":"xayoTN","text_ar":"خَيْطٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^axoyaATN","text_ar":"اَخْيَاطٌ"},{"kind":"text","text":"[a pl. of pauc.] (IB, K) and"},{"kind":"arabic","text_bw":"xuyuwTN","text_ar":"خُيُوطٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"xuyuwTapN","text_ar":"خُيُوطَةٌ"},{"kind":"text","text":"[both pls. of mult.]. (S, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"waAlmixoyaTa","text_ar":"وَالمِخْيَطَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ad~uwA AlxiyaATa","text_ar":"اَدُّوا الخِيَاطَ","orth_type":"arrow"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Bring ye"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"xayoT","text_ar":"خَيْط"},{"kind":"italic_en","text":"and the needle."},{"kind":"text","text":"(TA.) And you say, ↓"},{"kind":"arabic","text_bw":"A^aEoTiniY xiyaATFA","text_ar":"اَعْطِنِى خِيَاطًا","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"niSaAHFA","text_ar":"نِصَاحًا"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"Give thou to me"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a single"},{"kind":"arabic","text_bw":"xayoT","text_ar":"خَيْط"},{"kind":"text","text":". (AZ, TA.) ["},{"kind":"arabic","text_bw":"A^aEoTinaY xiyaATFA","text_ar":"اَعْطِنَى خِيَاطًا"},{"kind":"arabic","text_bw":"waniSaAHFA","text_ar":"وَنِصَاحًا"},{"kind":"text","text":"may, however, mean"},{"kind":"italic_en","text":"Give thou to me a needle and thread."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"xayoTu Alr~aqabapi","text_ar":"خَيْطُ الرَّقَبَةِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"nuxaAE","text_ar":"نُخَاع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"spinal cord"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the neck."},{"kind":"text","text":"(S, K) You say,"},{"kind":"arabic","text_bw":"jaAHa$a fulaAnN Eano xayoTi raqabatihi","text_ar":"جَاحَشَ فُلَانٌ عَنْ خَيْطِ رَقَبَتِهِ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Such a one defended his blood."},{"kind":"text","text":"(S, O, L.) ―         -b3-"},{"kind":"arabic","text_bw":"AlxayoTu","text_ar":"الخَيْطُ"},{"kind":"arabic","text_bw":"AlA^aboyaDu","text_ar":"الاَبْيَضُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlxayoTu AlA^asowadu","text_ar":"الخَيْطُ الاَسْوَدُ"},{"kind":"text","text":", mentioned in the Kur ii. 183, mean (assumed tropical:)"},{"kind":"italic_en","text":"The true dawn,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the false dawn:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the whiteness of the dawn,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the blackness of night;"},{"kind":"text","text":"(K, TA;) likened to a thread because of its thinness: (TA:) or"},{"kind":"italic_en","text":"the whiteness of day,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the blackness of night:"},{"kind":"text","text":"(A 'Obeyd, Nh:) or"},{"kind":"italic_en","text":"the dawn that extends sideways,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the dawn that rises high,"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"the blackness of night:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"what appears of the true dawn, which is the"},{"kind":"arabic","text_bw":"musotaTiyr","text_ar":"مُسْتَطِير"},{"kind":"text","text":", and"},{"kind":"italic_en","text":"what extends with it of the darkness of night, which is the dawn termed the"},{"kind":"arabic","text_bw":"musotaTiyl","text_ar":"مُسْتَطِيل"},{"kind":"text","text":": (Mgh:) or"},{"kind":"italic_en","text":"what first appears of the dawn spreading sideways in the horizon,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"what extends with it of the darkness of the last part of the night:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"the dawn that rises high, filling the horizon,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the dawn that appears black, extending sideways:"},{"kind":"text","text":"(Aboo-Is-hák:) or the real meaning is"},{"kind":"italic_en","text":"the day"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the night."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"AlxayoTaAni","text_ar":"الخَيْطَانِ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"The night and the day."},{"kind":"text","text":"(L in art."},{"kind":"arabic","text_bw":"wsd","text_ar":"وسد"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"tabay~ana","text_ar":"تَبَيَّنَ"},{"kind":"arabic","text_bw":"AlxayoTu mina AlxayoTi","text_ar":"الخَيْطُ مِنَ الخَيْطِ"},{"kind":"text","text":"means (tropical:)  ["},{"kind":"italic_en","text":"The night became distinct from the day:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"what is termed"},{"kind":"arabic","text_bw":"AlxayoTu","text_ar":"الخَيْطُ"},{"kind":"arabic","text_bw":"AlA^aboyaDu","text_ar":"الاَبْيَضُ"},{"kind":"italic_en","text":"became distinct from what is termed"},{"kind":"arabic","text_bw":"AlxayoTu AlA^asowadu","text_ar":"الخَيْطُ الاَسْوَدُ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xayoTN mina AlS~uboHi","text_ar":"خَيْطٌ مِنَ الصُّبْحِ"},{"kind":"text","text":"is also said to signify (assumed tropical:)"},{"kind":"italic_en","text":"A tint of the dawn."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"bariymu AlS~uboHi","text_ar":"بَرِيمُ الصُّبْحِ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"brm","text_ar":"برم"},{"kind":"text","text":".] ―         -b4-"},{"kind":"arabic","text_bw":"xayoTu baATilK","text_ar":"خَيْطُ بَاطِلٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"What is called"},{"kind":"arabic","text_bw":"luEaAbu Al$~amosi","text_ar":"لُعَابُ الشَّمْسِ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"muxaATu Al$~ayoTaAni","text_ar":"مُخَاطُ الشَّيْطَانِ"},{"kind":"text","text":", (S, TA,) which last is explained by Z and IB as meaning"},{"kind":"italic_en","text":"what comes forth from the mouth of the spider:"},{"kind":"text","text":"(TA: [the author of which says that, accord. to this explanation, this term differs from"},{"kind":"arabic","text_bw":"lEAb Al$ms","text_ar":"لعاب الشمس"},{"kind":"text","text":": but in so saying he seems to be in"},{"kind":"page_break","n":832},{"kind":"text","text":"error: both evidently signify"},{"kind":"italic_en","text":"gossamer:"},{"kind":"text","text":"]) it was applied as a surname, or nickname, to Marwán Ibn-El-Hakam; because he was tall, and loose, or uncompact, in frame: (S:) or it signifies"},{"kind":"italic_en","text":"the air;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AlhawaA='u","text_ar":"الهَوَا=ءُ"},{"kind":"text","text":"[perhaps a mistranscription for"},{"kind":"arabic","text_bw":"AlhabaA='u","text_ar":"الهَبَا=ءُ"},{"kind":"text","text":", occurring in another explanation hereafter]: (K:) or"},{"kind":"italic_en","text":"light entering from an aperture in a wall"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into a dark place"},{"kind":"text","text":"] (Th, K:) or"},{"kind":"arabic","text_bw":"xayoTu AlbaATili","text_ar":"خَيْطُ البَاطِلِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the scattered"},{"kind":"arabic","text_bw":"habaA='","text_ar":"هَبَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"atoms that are seen in the rays of the sun"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"entering from an aperture in a wall"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into a dark place"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when the sun is hot:"},{"kind":"text","text":"and one says,"},{"kind":"arabic","text_bw":"fulaAnN A^adaq~u mino xayoTi AlbaATili","text_ar":"فُلَانٌ اَدَقُّ مِنْ خَيْطِ البَاطِلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one is less in estimation than the scattered atoms that are seen in the rays of the sun"},{"kind":"text","text":"]; a prov., applied to him who is in an abject state; thus related, on the authority of Ahmad Ibn-Yahyà, by Az and others; but by Sgh, erroneously,"},{"kind":"arabic","text_bw":"A^araq~u mino xayoTi baATilK","text_ar":"اَرَقُّ مِنْ خَيْطِ بَاطِلٍ"},{"kind":"text","text":". (TA.) ―         -b5-  See also what next follows, in two places."}],"source_refs":["IB","K","S","Msb","TA","Mgh","Bd","Th"]},{"entry_id":"n11837","headword_ar":"خِيطٌ","root":"xyT","body":[{"kind":"text","text":"(As, IDrd, S, K) and ↓"},{"kind":"arabic","text_bw":"xayoTN","text_ar":"خَيْطٌ","orth_type":"arrow"},{"kind":"text","text":"(IDrd, Msb, K) and ↓"},{"kind":"arabic","text_bw":"xayoTaY","text_ar":"خَيْطَى","orth_type":"arrow"},{"kind":"text","text":"(S, K) (assumed tropical:)"},{"kind":"italic_en","text":"A collection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flock,"},{"kind":"text","text":"of ostriches, (S, Msb, K, &c.,) and"},{"kind":"italic_en","text":"a swarm"},{"kind":"text","text":"of locusts, (K,) and a ↓"},{"kind":"arabic","text_bw":"xayoT","text_ar":"خَيْط","orth_type":"arrow"},{"kind":"text","text":"is sometimes of [wild] bulls or cows: (L, TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^axoyaATN","text_ar":"اَخْيَاطٌ"},{"kind":"text","text":"(IB) and [of mult.]"},{"kind":"arabic","text_bw":"xiyTaAnN","text_ar":"خِيطَانٌ"},{"kind":"text","text":": (K:) ↓ which last, as also ↓"},{"kind":"arabic","text_bw":"xayoTaAnN","text_ar":"خَيْطَانٌ","orth_type":"arrow"},{"kind":"text","text":", signifies likewise"},{"kind":"italic_en","text":"a company"},{"kind":"text","text":"of men. (TA.) ["},{"kind":"arabic","text_bw":"xiyTN","text_ar":"خِيطٌ"},{"kind":"text","text":"may perhaps be originally"},{"kind":"arabic","text_bw":"xuyoTN","text_ar":"خُيْطٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"xayoTaA='u","text_ar":"خَيْطَا=ءُ"},{"kind":"text","text":", q. v.]"}],"source_refs":["As","IDrd","S","K","Msb","L","TA","IB"]},{"entry_id":"n11838","headword_ar":"خَيَطٌ","root":"xyT","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Length of the neck"},{"kind":"text","text":"of an ostrich, (S, TA,) and"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"bones, such as are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qaSab","text_ar":"قَصَب"},{"kind":"text","text":"thereof: or, as some say,"},{"kind":"italic_en","text":"a constant mixture of blackness with whiteness"},{"kind":"text","text":"therein: or their"},{"kind":"italic_en","text":"being in an uninterrupted line, like an extended"},{"kind":"arabic","text_bw":"xayoT","text_ar":"خَيْط"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"thread"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","TA"]}]}}