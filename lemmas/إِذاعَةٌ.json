{"lemma":"إِذاعَةٌ","slug":"إِذاعَةٌ","root":"ذ.#.ع","root_slug":"ذ-_-ع","root_link":"/words/roots/ذ-_-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n14217"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D8%B0%D8%A7%D8%B9%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"radio channel"},{"pos":"noun","gloss":"verbal noun of أَذَاعَ (ʔaḏāʕa) (form IV)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ʔi.ðaː.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14217","headword_ar":"اذاعهُ","root":"*yE","body":[{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"A*AE bihi","text_ar":"اذاع بِهِ"},{"kind":"text","text":", (Zj, K,) as in the Kur iv. 85, (Zj,) inf. n."},{"kind":"arabic","text_bw":"A_i*aAEapN","text_ar":"اـِذَاعَةٌ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"*wE","text_ar":"ذوع"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"He spread, published, divulged, revealed, made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disclosed, it;"},{"kind":"text","text":"(Zj, S, Msb, * K;)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"(so Zj, but in the K, “ or, ”)"},{"kind":"italic_en","text":"proclaimed it among the people;"},{"kind":"text","text":"(Zj, K;) namely, information, news, or tidings, (S,) or discourse, (Msb,) or a secret. (K.) ―         -b2-  Hence, app., (TA in art."},{"kind":"arabic","text_bw":"*wE","text_ar":"ذوع"},{"kind":"text","text":",)"},{"kind":"arabic","text_bw":"A*AE Alqawomu","text_ar":"اذاع القَوْمُ"},{"kind":"text","text":"(S, K,) and"},{"kind":"arabic","text_bw":"A*AEt AlA_ibilu","text_ar":"اذاعت الاـِبِلُ"},{"kind":"text","text":", (K,)"},{"kind":"arabic","text_bw":"maA fiY AlHwD","text_ar":"مَا فِى الحوض"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"bimaA fY AlHwD","text_ar":"بِمَا فى الحوض"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the camels, drank what was in the watering-trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"all of it."},{"kind":"text","text":"(S.) ―         -b3-  And hence, app., (TA,)"},{"kind":"arabic","text_bw":"A*AE bihi","text_ar":"اذاع بِهِ"},{"kind":"text","text":"signifies also (tropical:)"},{"kind":"italic_en","text":"He took it away;"},{"kind":"text","text":"namely, another's property, (K,) and anything. (TA.) ―         -b4-  Accord. to the K, the medial radical letter is both"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; but correctly it is"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":": (TA in the present art. and in art."},{"kind":"arabic","text_bw":"*wE","text_ar":"ذوع"},{"kind":"text","text":":) so accord. to AZ and J and Z. (TA in art."},{"kind":"arabic","text_bw":"*wE","text_ar":"ذوع"},{"kind":"text","text":".)"}],"source_refs":["S","Msb","K","Zj","TA"]}]},"classical_definitions":null}