"["},{"kind":"italic_en","text":"relating to the body"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"xaArijiy~apN","text_ar":"خَارِجِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"relating to external circumstances"},{"kind":"text","text":"]. (Er-Rághib, TA.) ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Fatigue;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taEabN","text_ar":"تَعَبٌ"},{"kind":"text","text":"; but the latter has a more general signification; every"},{"kind":"arabic","text_bw":"$qAwp","text_ar":"شقاوة"},{"kind":"text","text":"being"},{"kind":"arabic","text_bw":"tEb","text_ar":"تعب"},{"kind":"text","text":", but every"},{"kind":"arabic","text_bw":"tEb","text_ar":"تعب"},{"kind":"text","text":"is not"},{"kind":"arabic","text_bw":"$qAwp","text_ar":"شقاوة"},{"kind":"text","text":". (TA.)"}],"source_refs":[]}]}}