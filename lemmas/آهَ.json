_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["intj","noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n1421","","n1422"],"search_url":"https://lanelexicon.com/?s=%D8%A2%D9%87%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"intj","gloss":"ah, aw, ooh, ouch (expression of physical or emotional pain)","examples":[{"text":"آهِ مِنْ آلَامِ ٱلرَّأْسِ","english":"Ah, my head hurts."}]},{"pos":"noun","gloss":"pain (physical or emotional)","tags":["masculine"],"examples":[{"text":"لَمْ يَبْقَ لِي مِنَ الْحَيَاةِ إِلَّا الْآهُ.","english":"All that I have left of life is the pain."}]},{"pos":"verb","gloss":"to moan, groan"}]},"etymology":{"source":"wiktextract","text":"Onomatopoeic."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1421","headword_ar":"اَهَّ","root":"Ah","body":[{"kind":"text","text":", (S in art."},{"kind":"arabic","text_bw":"Awh","text_ar":"اوه"},{"kind":"text","text":", and K,) inf. n."},{"kind":"arabic","text_bw":"A^ap~N","text_ar":"اَةٌّ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"A^ah~apN","text_ar":"اَهَّةٌ"},{"kind":"text","text":"(S, * K) and the same without teshdeed; (K, * TA; [app. meaning"},{"kind":"arabic","text_bw":"A=hapN","text_ar":"ا=هَةٌ"},{"kind":"text","text":", which, however, belongs to art."},{"kind":"arabic","text_bw":"Awh","text_ar":"اوه"},{"kind":"text","text":", q. v.;]) or"},{"kind":"arabic","text_bw":"A_ih~apN","text_ar":"اـِهَّةٌ"},{"kind":"text","text":"; (so in the CK; [but in some copies of the K, and ↓"},{"kind":"arabic","text_bw":"A^ah~aha","text_ar":"اَهَّهَ","orth_type":"arrow"},{"kind":"text","text":", as in the TK, where it is said that the inf. n. of this form of the verb is"},{"kind":"arabic","text_bw":"taA^ohiyhN","text_ar":"تَاْهِيهٌ"},{"kind":"text","text":";]) and ↓"},{"kind":"arabic","text_bw":"tA^h~h","text_ar":"تاهّه","orth_type":"arrow"},{"kind":"text","text":"; (K;) ["},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A=ha","text_ar":"ا=هَ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"A^aw~aha","text_ar":"اَوَّهَ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"taA^ahiyhN","text_ar":"تَاَهِيهٌ"},{"kind":"text","text":"; or]"},{"kind":"italic_en","text":"He expressed pain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he lamented"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complained"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moaned,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"as one in an evil state, and broken in spirit by grief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mourning, and said"},{"kind":"arabic","text_bw":"A=hi","text_ar":"ا=هِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"haAho","text_ar":"هَاهْ"},{"kind":"text","text":". (K.) [See a verse cited in art."},{"kind":"arabic","text_bw":"Awh","text_ar":"اوه"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A=hapN","text_ar":"ا=هَةٌ"},{"kind":"text","text":".]"}],"source_refs":["K","S"]},{"entry_id":"n1422","headword_ar":"اـِهْ","root":"Ah","body":[{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"A_i","text_ar":"اـِ"},{"kind":"text","text":"with the"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"of pausation; imperative of"},{"kind":"arabic","text_bw":"waA^ay","text_ar":"وَاَي"},{"kind":"text","text":", q. v. (Mughnee in art."},{"kind":"arabic","text_bw":"Alf","text_ar":"الف"},{"kind":"text","text":")"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A2%D9%87/","headword_ar":"اه","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=49897#fea046","body_html":"اه: مختصر انتهى (الطبعة المصرية للمقري)."},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=49897#8a82c7","body_html":"<h3>اه</h3><span class=\"sense\">1</span> أَهَّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> in art. اوه, and <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> أَةٌّ (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and أَهَّةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and the same without teshdeed; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>; [<abbr title=\"apparently\">app.</abbr> meaning آهَةٌ, which, however, belongs to art. اوه, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>;]) or إِهَّةٌ; (so in the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr>; [but in some copies of the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, and ↓ أَهَّهَ, as in the <abbr title=\"The Turkish translation of al-Qāmūs al-Muḥīṭ of Firuzabadi\">TK</abbr>, where it is said that the <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of this form of the verb is تَأْهِيهٌ;]) and ↓ تأهّه; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) [<abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> آهَ and أَوَّهَ and تَأَهِيهٌ; or] He expressed pain or grief or sorrow, or he lamented or complained or moaned, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) as one in an evil state, and broken in spirit by grief or mourning, and said آهِ, or هَاهْ. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) [See a verse cited in art. اوه, <abbr title=\"under the heading\">voce</abbr> آهَةٌ.]<span class=\"sense\">2</span> اَهَّّand 5: see above.<br><br>إِهْ, i. e. إِ with the ه of pausation; <abbr title=\"أَمْرٌ\">imperative</abbr> of وَأَي, <abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr> (<abbr title=\"The Mughnī of Ibn Hishām al-Anṣārī\">Mughnee</abbr> in art. الف) آهِ and آهٍ and آهًا &amp;c.: see art. اوه."}]}}