{"lemma":"بَشَرَةٌ","slug":"بَشَرَةٌ","root":"ب.ش.ر","root_slug":"ب-ش-ر","root_link":"/words/roots/ب-ش-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n2597"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B4%D9%8E%D8%B1%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"skin, outer skin, epidermis","tags":["singulative"]},{"pos":"noun","gloss":"complexion","tags":["singulative"]},{"pos":"noun","gloss":"herbage","tags":["singulative"]},{"pos":"noun","gloss":"hand","tags":["singulative"]},{"pos":"noun","gloss":"surface","tags":["singulative"]},{"pos":"noun","gloss":"human frame","tags":["singulative"]},{"pos":"noun","gloss":"humanity, mankind","tags":["singulative"]}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ب ش ر (b š r)."},"ipa":["/ba.ʃa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2597","headword_ar":"بَشَرَةٌ","root":"b$r","body":[{"kind":"text","text":"(Lth, S, M, A, Mgh, Msb) and ↓"},{"kind":"arabic","text_bw":"ba$arN","text_ar":"بَشَرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) or the latter is pl. of the former, (Msb, K,) [or rather a coll. gen. n., of which the former is the n. un.,] like"},{"kind":"arabic","text_bw":"qaSabahu","text_ar":"قَصَبَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaSabN","text_ar":"قَصَبٌ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"A^abo$aArN","text_ar":"اَبْشَارٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"ba$arN","text_ar":"بَشَرٌ"},{"kind":"text","text":", (K,) [The"},{"kind":"italic_en","text":"external skin;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"cuticle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scarf-skin;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"epidermis;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"exterior of the skin"},{"kind":"text","text":"(S, A, Mgh, Msb, K) of a human being; (S, A, K;) and, as some say, of other creatures, (K,) such as the serpent; but this is generally disallowed: (TA:) or"},{"kind":"arabic","text_bw":"ba$arapN","text_ar":"بَشَرَةٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"exterior of the skin of the head, in which grows the hair;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"A^adamapN","text_ar":"اَدَمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$awaApN","text_ar":"شَوَاةٌ"},{"kind":"text","text":": (Aboo-Safwán:) or the"},{"kind":"italic_en","text":"upper skin"},{"kind":"text","text":"(Lth, M)"},{"kind":"italic_en","text":"of the head"},{"kind":"text","text":"(M)"},{"kind":"italic_en","text":"and of the face and body"},{"kind":"text","text":"of a human being; (Lth, M;)"},{"kind":"italic_en","text":"that upon which the hair grows:"},{"kind":"text","text":"(M:) or, as some say,"},{"kind":"italic_en","text":"that which is next the flesh."},{"kind":"text","text":"(M.) It is said in a prov.,"},{"kind":"arabic","text_bw":"A_in~amaA yuEaAtabu AlA^adiymu *uw Alba$arapi","text_ar":"اـِنَّمَا يُعَاتَبُ الاَدِيمُ ذُو البَشَرَةِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adiymN","text_ar":"اَدِيمٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"ba$arapN","text_ar":"بَشَرَةٌ"},{"kind":"text","text":"sometimes means The"},{"kind":"italic_en","text":"complexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hue:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"fineness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicacy."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"ba$arapu","text_ar":"بَشَرَةُ"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The herbage appearing upon the surface of the earth."},{"kind":"text","text":"(S, A, K.) You say,"},{"kind":"arabic","text_bw":"maA A^aHosana ba$aratahaA","text_ar":"مَا اَحْسَنَ بَشَرَتَهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"How goodly is its herbage appearing upon its surface!"},{"kind":"text","text":"(S, A.) And"},{"kind":"arabic","text_bw":"ba$arapN","text_ar":"بَشَرَةٌ"},{"kind":"text","text":"[alone] signifies (tropical:)"},{"kind":"italic_en","text":"Leguminous plants; herbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"ba$arapN","text_ar":"بَشَرَةٌ"},{"kind":"text","text":"is used also as signifying (assumed tropical:)  A man's"},{"kind":"italic_en","text":"hand."},{"kind":"text","text":"(Msb.) [See 3, last sentence.]"}],"source_refs":["Lth","S","M","A","Mgh","Msb","K","TA"]}]},"classical_definitions":null}