{"lemma":"إِلٰهِيٌّ","slug":"إِلٰهِيٌّ","root":"#.ل.ه","root_slug":"_-ل-ه","root_link":"/words/roots/_-ل-ه","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"إِلٰهِيٌّ","root":"لهو","pos":"V","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n1121"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D9%84%D9%B0%D9%87%D9%90%D9%8A%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to divert, to distract, to turn away"},{"pos":"verb","gloss":"to divert, to regale, to delight"}]},"etymology":null,"ipa":["/ʔal.haː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1121","headword_ar":"اـِلهِىٌّ","root":"Alh","body":[{"kind":"text","text":"["},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A_ilaAhiY~N","text_ar":"اـِلَاهِىٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to, God"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a god; divine; theological:"},{"kind":"text","text":"Hence,"},{"kind":"arabic","text_bw":"AlEilomu AlA_ilhiY~u","text_ar":"العِلْمُ الاـِلهِىُّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"AlA_ilaAhiY~N","text_ar":"الاـِلَاهِىٌّ"},{"kind":"text","text":": see what next follows.]"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A5%D9%84%D9%87%D9%8A/","headword_ar":"إلهية","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22945#ee0837","body_html":"<span>الإلهية: أحدية جمع جميع الحقائق الوجودية، كما أن آدم عليه الصلاة والسلام أحدية لجمع جميع الصور البشرية؛ إذ للأحدية الجمعية الكمالية مرتبتان: إحداهما: قبل التفصيل؛ لكون كل كثرة مسبوقة بواحد هي فيه بالقوة هو، وتذكر قوله تعالى: {وَإِذْ أَخَذَ رَبُّكَ مِنْ بَنِي آدَمَ مِنْ ظُهُورِهِمْ ذُرِّيَّتَهُمْ وَأَشْهَدَهُمْ عَلَى أَنْفُسِهِمْ} فإنه لسانٌ من ألسنة شهود المفصل في المجمل مفصلًا ليس كشهود العالم من الخلق في النواة الواحدة النخيل الكامنة فيه بالقوة، فإنه شهود المفضل في المجمل مجملًا لا مفصلًا، وشهود المفصل في المجمل مفصلًا يختص بالحق، وبمن جاء بالحق أن يشهده من الكمل، وهو خاتم الأنبياء وخاتم الأولياء.</span>"}]}}