":"p"},{"role":"present_2mp","form":"تَسْكَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْكَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْكَر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْكَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْكَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْكَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْكَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْكَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْكَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْكَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْكَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْكَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْكَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَكِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَكِرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":true,"lemma_key":"سَكِرَ","root":"سكر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":13},"lanes":{"found":true,"entry_ids":["n20213"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%83%D9%90%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"sugar","tags":["uncountable"]},{"pos":"verb","gloss":"to sugar, to sprinkle sugar over"},{"pos":"verb","gloss":"to sweeten, to add sugar"},{"pos":"verb","gloss":"to candy"},{"pos":"verb","gloss":"to get drunk, to become intoxicated"},{"pos":"verb","gloss":"to be drunk, to be intoxicated"},{"pos":"noun","gloss":"intoxicant"},{"pos":"noun","gloss":"wine"},{"pos":"noun","gloss":"verbal noun of سَكِرَ (sakira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"drunkenness, intoxication, inebriety"},{"pos":"noun","gloss":"verbal noun of سَكِرَ (sakira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"drunk"},{"pos":"noun","gloss":"alternative form of سُكَّار (sukkār, “bolt-lock”)","tags":["alt-of","alternative"]}]},"etymology":{"source":"wiktextract","text":"Etymology tree\nProto-Indo-European *ḱorkeh₂\nProto-Indo-Iranian *ćárkaraH\nProto-Indo-Aryan *śárkaraH\nSanskrit शर्क॑रा (śárkarā)\nGandhari 𐨭𐨐𐨪 (śakara)bor.\nMiddle Persian 𐭱𐭪𐭥 (šakar)bor.\nArabic سكر\nBorrowed from Middle Persian 𐭱𐭪𐭥 (šakar), borrowed from Gandhari 𐨭𐨐𐨪 (śakara), from Sanskrit शर्क॑रा (śárkarā), from Proto-Indo-Aryan *śárkaraH, from Proto-Indo-Iranian *ćárkaraH, from Proto-Indo-European *ḱorkeh₂ (“gravel”). For the vocalism from Middle Persian to Arabic, compare أُشَّق (ʔuššaq, “ammoniacum”).\n\nFrom Proto-Semitic *šikar- (“alcoholic drink”). Cognate with Hebrew שֵׁכָר (šēḵār)."},"ipa":["/suk.kar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20213","headword_ar":"سَكِرَ","root":"skr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sakarN","text_ar":"سَكَرٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"sukorN","text_ar":"سُكْرٌ"},{"kind":"text","text":", (A, Mgh, K,) or this is a simple subst., (S, Msb,) and"},{"kind":"arabic","text_bw":"sukurN","text_ar":"سُكُرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sakorN","text_ar":"سَكْرٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"sikarN","text_ar":"سِكَرٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"sakaraAnN","text_ar":"سَكَرَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, intoxicated, inebriated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drunken;"},{"kind":"text","text":"(MA, KL, &c.;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"SaHaA","text_ar":"صَحَا"},{"kind":"text","text":". (S, A, K.) [See also"},{"kind":"arabic","text_bw":"sukorN","text_ar":"سُكْرٌ"},{"kind":"text","text":", below.] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"sakira EalaY~afulaAnN","text_ar":"سَكِرَ عَلَىَّفُلَانٌ"},{"kind":"text","text":", (A,) inf. n."},{"kind":"arabic","text_bw":"sakarN","text_ar":"سَكَرٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"Such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, violently angry with me:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"angry;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enraged."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"lahu EalaY~a sakarN","text_ar":"لَهُ عَلَىَّ سَكَرٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He has violent anger against me."},{"kind":"text","text":"(A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"sakirato A^aboSaArunaA","text_ar":"سَكِرَتْ اَبْصَارُنَا"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"sakirat A^aboSaAru Alqawomi","text_ar":"سَكِرَت اَبْصَارُ القَوْمِ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"sakirato Eayonuhu","text_ar":"سَكِرَتْ عَيْنُهُ"},{"kind":"text","text":": see 2. ―         -b4-  Also"},{"kind":"arabic","text_bw":"sakira","text_ar":"سَكِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"sakarN","text_ar":"سَكَرٌ"},{"kind":"text","text":", (IAar, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wateringtrough, or tank, TK)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, full."},{"kind":"text","text":"(IAar, K, TK.) ―         -b5-  And"},{"kind":"arabic","text_bw":"sakirati Alr~iyHu","text_ar":"سَكِرَتِ الرِّيحُ"},{"kind":"text","text":", (A, and so in my MS. copy of the K,) or"},{"kind":"arabic","text_bw":"sakarat","text_ar":"سَكَرَت"},{"kind":"text","text":", (S, O, and so in the CK,) aor."},{"kind":"text","text":", (S, O,) or, as some relate a verse of Jendel Ibn-El-Muthennà Et- Tuhawee, in which it occurs,"},{"kind":"text","text":", (O,) [indicating that the pret. is"},{"kind":"arabic","text_bw":"sakirat","text_ar":"سَكِرَت"},{"kind":"text","text":"or that the aor. is irreg.,] inf. n."},{"kind":"arabic","text_bw":"sukuwrN","text_ar":"سُكُورٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"sakaraAnN","text_ar":"سَكَرَانٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The wind became still,"},{"kind":"text","text":"(S, A, O, K,)"},{"kind":"italic_en","text":"after blowing."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"sakara","text_ar":"سَكَرَ"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"sakira","text_ar":"سَكِرَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"sukuwrN","text_ar":"سُكُورٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became still, ceasing to run:"},{"kind":"text","text":"so says AZ: and (tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the sea)"},{"kind":"italic_en","text":"became calm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless:"},{"kind":"text","text":"so says IAar. (TA.) And"},{"kind":"arabic","text_bw":"sakira","text_ar":"سَكِرَ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"sakara","text_ar":"سَكَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(food [in a cooking-pot], or hot water, A, or a hot thing, TA)"},{"kind":"italic_en","text":"ceased to boil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estuate,"},{"kind":"text","text":"(A, TA,) or"},{"kind":"italic_en","text":"to burn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be hot:"},{"kind":"text","text":"(TA:) and (assumed tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(heat)"},{"kind":"italic_en","text":"became allayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it subsided."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"sakarahu","text_ar":"سَكَرَهُ"},{"kind":"text","text":": see 4. ―         -b2-  Also, (IAar, TA,) aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"sakorN","text_ar":"سَكْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He filled it."},{"kind":"text","text":"(IAar, K, * TA.) ―         -b3-  Also, (S, Mgh, Msb,) aor. as above, (S, Msb,) and so the inf. n.; (S, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"sk~rhu","text_ar":"سكّرهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tasokiyrN","text_ar":"تَسْكِيرٌ"},{"kind":"text","text":"; (MF;)"},{"kind":"italic_en","text":"He stopped it up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dammed it;"},{"kind":"text","text":"namely, a river, or rivulet. (S, Mgh, Msb, K, MF.) And hence,"},{"kind":"arabic","text_bw":"sakara AlbaAba","text_ar":"سَكَرَ البَابَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sk~rhu","text_ar":"سكّرهُ","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He closed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped up, the door."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"sukirato A^aboSaArunaA","text_ar":"سُكِرَتْ اَبْصَارُنَا"},{"kind":"text","text":": see 2."}],"source_refs":["S","Mgh","Msb","K","A","TK","IAar","O","TA"]}]}}