ogy":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["","n30368"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D9%84%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30368","headword_ar":"اَعْلَمُ","root":"Elm","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, knowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"learned"},{"kind":"text","text":"]. Applied to God, [it may often be rendered"},{"kind":"italic_en","text":"Supreme in knowledge:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"omniscient:"},{"kind":"text","text":"but often, in this case,] it means [simply] ↓"},{"kind":"arabic","text_bw":"EaAlimN","text_ar":"عَالِمٌ","orth_type":"arrow"},{"kind":"text","text":"[in the sense of"},{"kind":"italic_en","text":"knowing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cognizant"},{"kind":"text","text":"]. (Jel in iii. 31, and I'Ak p. 240.) [Therefore"},{"kind":"arabic","text_bw":"Aall~`hu A^aEolamu","text_ar":"اَللّٰهُ اَعْلَمُ"},{"kind":"text","text":"virtually means, sometimes,"},{"kind":"italic_en","text":"God knows best;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knows all things:"},{"kind":"text","text":"and sometimes, simply,"},{"kind":"italic_en","text":"God knows."},{"kind":"text","text":"]       -A2-  Also ["},{"kind":"italic_en","text":"Harelipped;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"having a fissure in his upper lip:"},{"kind":"text","text":"(S, Mgh, Msb, K:) or"},{"kind":"italic_en","text":"in one of its two sides:"},{"kind":"text","text":"(K:) the camel is said to be"},{"kind":"arabic","text_bw":"AElm","text_ar":"اعلم"},{"kind":"text","text":"because of the fissure in his upper lip: when the fissure is in the lower lip, the epithet"},{"kind":"arabic","text_bw":"A^afolaHu","text_ar":"اَفْلَحُ"},{"kind":"text","text":"is used: and"},{"kind":"arabic","text_bw":"A^a$oramu","text_ar":"اَشْرَمُ"},{"kind":"text","text":"is used in both of these, and also in other, similar, senses: (TA:) the fem. of"},{"kind":"arabic","text_bw":"A^aEolamu","text_ar":"اَعْلَمُ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EalomaA='u","text_ar":"عَلْمَا=ءُ"},{"kind":"text","text":": (S, Msb, TA:) which is likewise applied to a lip ("},{"kind":"arabic","text_bw":"$afapN","text_ar":"شَفَةٌ"},{"kind":"text","text":"). (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AlEalomaA='u","text_ar":"العَلْمَا=ءُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"The coat of mail:"},{"kind":"text","text":"(K:) mentioned by Sh, in the book entitled"},{"kind":"arabic","text_bw":"kitaAbu Als~ilaAHi","text_ar":"كِتَابُ السِّلَاحِ"},{"kind":"text","text":"; but as not heard by him except in a verse of Zuheyr Ibn-Khabbáb [?]. (TA.)"}],"source_refs":["S","Mgh","Msb","K","TA"]}]}}