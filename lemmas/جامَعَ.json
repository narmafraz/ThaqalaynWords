{"lemma":"جامَعَ","slug":"جامَعَ","root":"ج.م.ع","root_slug":"ج-م-ع","root_link":"/words/roots/ج-م-ع","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جامَعْتَ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جامَعْتِ","in_corpus":true,"count":10,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جامَعْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جامَعْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جامَعْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جامَعَ","in_corpus":true,"count":30,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جامَعَت","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جامَعا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جامَعَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جامَعُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جامَعْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُجامِع","in_corpus":true,"count":34,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُجامِعِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُجامِعِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُجامِعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُجامِعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُجامِعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجامِعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجامِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجامِع","in_corpus":true,"count":19,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجامِع","in_corpus":true,"count":34,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجامِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجامِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجامِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجامِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجامِعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجامِعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجامِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جامَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جامَعْتُ","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجامِع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجامِع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":161,"cross_references":{"qac":{"found":true,"lemma_key":"جامَعَ","root":"جمع","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n6323"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D8%A7%D9%85%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"comprehensive, extensive, broad, general, universal"},{"pos":"noun","gloss":"collector"},{"pos":"noun","gloss":"compiler (of books)"},{"pos":"noun","gloss":"typesetter, compositor"},{"pos":"noun","gloss":"congregational mosque","examples":[{"text":"الْجَامِع الْأَزْهَر","english":"Al-Azhar [Congregational] Mosque"}]},{"pos":"verb","gloss":"to copulate with, to have intercourse with","examples":[{"text":"جَامَعَ زَوْجَتَه","english":"He had intercourse with his wife."}]},{"pos":"verb","gloss":"to congregate"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of جَمَعَ (jamaʕa, “to collect, gather”)."},"ipa":["/d͡ʒaː.miʕ/","/d͡ʒaː.ma.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6323","headword_ar":"جَامِعٌ","root":"jmE","body":[{"kind":"text","text":"[act. part. n. of 1;"},{"kind":"italic_en","text":"Collecting;"},{"kind":"text","text":"&c.] ―         -b2-"},{"kind":"arabic","text_bw":"AljaAmiEu","text_ar":"الجَامِعُ"},{"kind":"text","text":"one of the names of God; meaning"},{"kind":"italic_en","text":"The Collector of the created beings for the day of reckoning:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"the Combiner of things of similar natures and of things of contrary natures, in existence."},{"kind":"text","text":"(IAth.) ―         -b3-"},{"kind":"italic_en","text":"The belly;"},{"kind":"text","text":"[because it collects what passes from the stomach;] of the dial. of El-Yemen. (TA.) ―         -b4-  Also, (Msb,) or"},{"kind":"arabic","text_bw":"Almasojidu AljaAmiEu","text_ar":"المَسْجِدُ الجَامِعُ"},{"kind":"text","text":", (S, K,) ["},{"kind":"italic_en","text":"The congregational mosque;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the mosque in which the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"congregational"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"prayers of Friday are performed;"},{"kind":"text","text":"because it collects the people for a certain time; (Msb;) and you may also say,"},{"kind":"arabic","text_bw":"masojidu AljaAmiEi","text_ar":"مَسْجِدُ الجَامِعِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"masojidu Alyawomi AljaAmiEi","text_ar":"مَسْجِدُ اليَوْمِ الجَامِعِ"},{"kind":"text","text":", (S, K,) like as you say"},{"kind":"arabic","text_bw":"AlHaq~u","text_ar":"الحَقُّ"},{"kind":"arabic","text_bw":"Alyaqiynu","text_ar":"اليَقِينُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Haq~u Alyaqiyni","text_ar":"حَقُّ اليَقِينِ"},{"kind":"text","text":", [the latter] as meaning"},{"kind":"arabic","text_bw":"Haq~u Al$~aYo'i Alyaqiyni","text_ar":"حَقُّ الشَّىْءِ اليَقِينِ"},{"kind":"text","text":"; for it is not allowable to prefix a noun to another of the same meaning except with this kind of subaudition; or, accord. to Fr, the Arabs used to do so because of the difference of the two words themselves: (S:) or"},{"kind":"arabic","text_bw":"msjd","text_ar":"مسجد"},{"kind":"arabic","text_bw":"AljAmE","text_ar":"الجامع"},{"kind":"text","text":"is a mistake: (K:) so says Lth; but all others allow it; for the Arabs prefix a subst. to another signifying the same thing, and also to its epithet, as in the phrases in the Kur"},{"kind":"arabic","text_bw":"diynu Alqay~imapi","text_ar":"دِينُ القَيِّمَةِ"},{"kind":"text","text":"[ch. xcviii. v. 4] and"},{"kind":"arabic","text_bw":"waEoda AlS~idoqi","text_ar":"وَعْدَ الصِّدْقِ"},{"kind":"text","text":"[ch. xlvi. v. 15]: (Az, TA:) [pl."},{"kind":"arabic","text_bw":"jawaAmiEu","text_ar":"جَوَامِعُ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"miSorN jaAmiEN","text_ar":"مِصْرٌ جَامِعٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A great town comprising a large population; a comprehensive great town"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"mdn","text_ar":"مدن"},{"kind":"text","text":"[where it is given as the explanation of"},{"kind":"arabic","text_bw":"madiynapN","text_ar":"مَدِينَةٌ"},{"kind":"text","text":"]; and K in art."},{"kind":"arabic","text_bw":"qrY","text_ar":"قرى"},{"kind":"text","text":"[where it is less properly given as the explanation of"},{"kind":"arabic","text_bw":"qaroyapN","text_ar":"قَرْيَةٌ"},{"kind":"text","text":"].) ―         -b6-"},{"kind":"arabic","text_bw":"qidorN jaAmiEN","text_ar":"قِدْرٌ جَامِعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jaAmiEapN","text_ar":"جَامِعَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jimaAEN","text_ar":"جِمَاعٌ"},{"kind":"text","text":"―         -b7-"},{"kind":"arabic","text_bw":"AimoraA^apN jAmiEN","text_ar":"اِمْرَاَةٌ جامِعٌ"},{"kind":"text","text":": see the paragraph commencing with"},{"kind":"arabic","text_bw":"AljumoEu","text_ar":"الجُمْعُ"},{"kind":"text","text":"; last signification. ―         -b8-"},{"kind":"arabic","text_bw":"A^ataAnN","text_ar":"اَتَانٌ"},{"kind":"arabic","text_bw":"jaAmiEN","text_ar":"جَامِعٌ"},{"kind":"italic_en","text":"A she-ass pregnant when beginning to be so."},{"kind":"text","text":"(S, O, K.) ―         -b9-  ↓"},{"kind":"arabic","text_bw":"jaAmiEapN","text_ar":"جَامِعَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"collar of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"gul~","text_ar":"غُلّ"},{"kind":"text","text":"; (S, K;) because it collects together the two hands to the neck: (S:) pl."},{"kind":"arabic","text_bw":"jawaAmiEu","text_ar":"جَوَامِعُ"},{"kind":"text","text":". (TA.) ―         -b10-"},{"kind":"arabic","text_bw":"A^amorN jaAmiEN","text_ar":"اَمْرٌ جَامِعٌ"},{"kind":"italic_en","text":"An affair that collects people together:"},{"kind":"text","text":"or, as Er-Rághib says,"},{"kind":"italic_en","text":"a momentous affair, on account of which people collect themselves together;"},{"kind":"text","text":"as though the affair itself collected them. (TA.) [Similar to this is the saying,]"},{"kind":"arabic","text_bw":"AlS~alaApu","text_ar":"الصَّلَاةُ"},{"kind":"arabic","text_bw":"jaAmiEapN likul~i Aln~aAsi","text_ar":"جَامِعَةٌ لِكُلِّ النَّاسِ"},{"kind":"italic_en","text":"Prayer is a collector of all people."},{"kind":"text","text":"(Msb.) ―         -b11-  It is said of Mohammad, (Msb,)"},{"kind":"arabic","text_bw":"kaAna yatakal~amu bijawaAmiEi Alkalimi","text_ar":"كَانَ يَتَكَلَّمُ بِجَوَامِعِ الكَلِمِ"},{"kind":"italic_en","text":"He used to speak comprehensive but concise language; language conveying many meanings in few words."},{"kind":"text","text":"(Msb, K. [In the CK,"},{"kind":"arabic","text_bw":"Alklm","text_ar":"الكلم"},{"kind":"text","text":"is omitted.]) And hence the saying of 'Omar Ibn-'Abd-el-'Azeez,"},{"kind":"arabic","text_bw":"Eajibotu limano laAHana Aln~aAsa kayofa laA yaEorifu jawaAmiEa Alkalimi","text_ar":"عَجِبْتُ لِمَنْ لَاحَنَ النَّاسَ كَيْفَ لَا يَعْرِفُ جَوَامِعَ الكَلِمِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I wonder at him who vies with men in endeavouring to show his superiority of intelligence,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"how it is that he does not"},{"kind":"text","text":"["},{"kind":"italic_en","text":"know the way to"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"confine himself to conciseness, and abstain from superfluity, of speech."},{"kind":"text","text":"(TA.) In like manner, (TA,) it is said in a trad.,"},{"kind":"arabic","text_bw":"A^uwtiytu jawaAmiEa Alkalimi","text_ar":"اُوتِيتُ جَوَامِعَ الكَلِمِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I have had communicated to me the Kur-án,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"in which many meanings are comprised in a few words."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"AljawaAmiEu mina","text_ar":"الجَوَامِعُ مِنَ"},{"kind":"arabic","text_bw":"Ald~uEaA='i","text_ar":"الدُّعَا=ءِ"},{"kind":"text","text":", also, signifies"},{"kind":"italic_en","text":"Prayers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supplications, combining petitions for good and right objects of desire with praise of God and with the general prescribed observances proper to the case."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"AlmaHaAmidi","text_ar":"المَحَامِدِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hamidotu A@ll~`ha bimajaAmiEi","text_ar":"حَمِدْتُ ا@للّٰهَ بِمَجَامِعِ","orth_type":"arrow"},{"kind":"italic_en","text":"I praised God with words comprising various forms of praise."},{"kind":"text","text":"(Msb.) [See also"},{"kind":"arabic","text_bw":"jimaAEN","text_ar":"جِمَاعٌ"},{"kind":"text","text":".] ―         -b12-"},{"kind":"arabic","text_bw":"rajulN jaAmiEN","text_ar":"رَجُلٌ جَامِعٌ"},{"kind":"italic_en","text":"A man who combines such qualities that he is suited to hardship and to easiness of circumstances."},{"kind":"text","text":"(As. T in art."},{"kind":"arabic","text_bw":"Adm","text_ar":"ادم"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"rajulN","text_ar":"رَجُلٌ"},{"kind":"arabic","text_bw":"jaAmiEN liloxayori","text_ar":"جَامِعٌ لِلْخَيْرِ"},{"kind":"text","text":"(T and M and K in art."},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":")"},{"kind":"italic_en","text":"A man combining all kinds of good qualities."},{"kind":"text","text":"(TK in that art.) ―         -b13-"},{"kind":"arabic","text_bw":"daAb~apN jaAmiEN","text_ar":"دَابَّةٌ جَامِعٌ"},{"kind":"italic_en","text":"A beast fit for the"},{"kind":"arabic","text_bw":"A_ikaAf","text_ar":"اـِكَاف"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"saroj","text_ar":"سَرْج"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"for the saddle of either of the kinds thus called"},{"kind":"text","text":"]. (Sgh, K.) ―         -b14-"},{"kind":"arabic","text_bw":"jamalN jaAmiEN","text_ar":"جَمَلٌ جَامِعٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"naAqapN jaAmiEapN","text_ar":"نَاقَةٌ جَامِعَةٌ"},{"kind":"text","text":", (K,) accord. to ISh, (TA,)"},{"kind":"italic_en","text":"A hecamel,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a she-camel, that fails of putting forth the tooth called"},{"kind":"arabic","text_bw":"nAb","text_ar":"ناب"},{"kind":"italic_en","text":"at the time expected;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"A^axolafaA buzuwlFA","text_ar":"اَخْلَفَا بُزُولًا"},{"kind":"text","text":": but this is not said except after four years: (K:) so in the copies of the K; but correctly, accord. to the O and TS, this is not said after four years, [app. reckoned from the usual time of"},{"kind":"arabic","text_bw":"bzwl","text_ar":"بزول"},{"kind":"text","text":", for this is in the ninth year, or, sometimes, in the eighth,] without the exceptive particle. (TA.)"}],"source_refs":["Msb","S","K","Az","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AC%D8%A7%D9%85%D8%B9/","headword_ar":"جامع","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23182#3bd03e","body_html":"<span>جامع الكلم: ما يكون لفظه قليلًا ومعناه جزيلًا، كقوله صلى الله عليه وسلم: \"حفت الجنة بالمكاره، وحفت النار بالشهوات\". وقوله صلى الله عليه وسلم: \"خير الأمور أوسطها\".</span>"}]}}