{"lemma":"نَزِّ","slug":"نَزِّ","root":"ن.ز.ز","root_slug":"ن-ز-ز","root_link":"/words/roots/ن-ز-ز","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n39645","n39646"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B2%D9%90%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39645","headword_ar":"نَزٌّ","root":"nz","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"niz~N","text_ar":"نِزٌّ","orth_type":"arrow"},{"kind":"italic_en","text":"Water that exudes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oozes, from the ground:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"flowing moisture:"},{"kind":"text","text":"(Msb:) the latter is the better word; and is [said to be] Persian, arabicized: (TA:) the former is an inf. n. used as a subst. (Msb.) ―         -b2-  [The pl. is"},{"kind":"arabic","text_bw":"nuzuwzN","text_ar":"نُزُوزٌ"},{"kind":"text","text":", occurring in the TA in art."},{"kind":"arabic","text_bw":"E*w","text_ar":"عذو"},{"kind":"text","text":".] ―         -b3-  [The former is also used as an epithet: fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". You say,]"},{"kind":"arabic","text_bw":"A^aroDN naz~apN","text_ar":"اَرْضٌ نَزَّةٌ"},{"kind":"italic_en","text":"Ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land, having water exuding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oozing, from it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"*aAtu naz~K","text_ar":"ذَاتُ نَزٍّ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"naAz~apN","text_ar":"نَازَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (Lh, TA.)       -A2-  [Hence, perhaps,]"},{"kind":"arabic","text_bw":"naz~N","text_ar":"نَزٌّ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"liberal, bountiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"munificent."},{"kind":"text","text":"(Sgh, K.)       -A3-  Also,"},{"kind":"arabic","text_bw":"naz~N","text_ar":"نَزٌّ"},{"kind":"italic_en","text":"Much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many."},{"kind":"text","text":"(K.)       -A4-  A man (A'Obeyd, S)"},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active,"},{"kind":"text","text":"(A'Obeyd, S, K,) or"},{"kind":"italic_en","text":"light in spirit,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"sharp in mind,"},{"kind":"text","text":"(A'Obeyd, S, K,)"},{"kind":"italic_en","text":"clever,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ingenious,"},{"kind":"text","text":"(A'Obeyd, K,)"},{"kind":"italic_en","text":"and intel-ligent."},{"kind":"text","text":"(A'Obeyd, TA.) ―         -b2-"},{"kind":"italic_en","text":"Light, inconstant, fickle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsteady:"},{"kind":"text","text":"(K:) an epithet of dispraise. (TA.) ―         -b3-  A man (TA)"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, in motion;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"minaz~N","text_ar":"مِنَزٌّ","orth_type":"arrow"},{"kind":"text","text":": (K:) a man, (A,) and an ostrich, (S, K, TA,)"},{"kind":"italic_en","text":"that does not remain still in one place:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"that is quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, and does not remain still in one place:"},{"kind":"text","text":"(TA:) or an ostrich, and an antelope,"},{"kind":"italic_en","text":"that leaps, jumps, springs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounds:"},{"kind":"text","text":"(A:) and a"},{"kind":"italic_en","text":"light,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"active,"},{"kind":"text","text":"camel; (TA;) and so"},{"kind":"arabic","text_bw":"naz~apN","text_ar":"نَزَّةٌ"},{"kind":"text","text":", applied to a she-camel. (S, TA.) ―         -b4-"},{"kind":"italic_en","text":"Light"},{"kind":"text","text":"dust. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"$ar~K","text_ar":"شَرٍّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"niz~u","text_ar":"نِزُّ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"naziyzuhu","text_ar":"نَزِيزُهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"liz~uhu","text_ar":"لِزُّهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"laziyzuhu","text_ar":"لَزِيزُهُ"},{"kind":"text","text":". (TA, art."},{"kind":"arabic","text_bw":"lz","text_ar":"لز"},{"kind":"text","text":".)"}],"source_refs":["S","K","Msb","TA","A"]},{"entry_id":"n39646","headword_ar":"نِزٌّ","root":"nz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"naz~N","text_ar":"نَزٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}