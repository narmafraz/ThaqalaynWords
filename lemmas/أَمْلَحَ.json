ll,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُمْلِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُمْلِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُمْلِح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُمْلِح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُمْلِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُمْلِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُمْلِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمْلِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُمْلِحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمْلِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُمْلِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُمْلِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمْلِح","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"أَمْلَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَمْلَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["","","n38888"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%92%D9%84%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"elative degree of مَلِيح (malīḥ)"},{"pos":"adj","gloss":"elative degree of مَلِيح (malīḥ):; more handsome; most handsome"}]},"etymology":{"source":"wiktextract","text":"Elative of مَلِيح (malīḥ, “handsome”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38888","headword_ar":"اَمْلَحُ","root":"mlH","body":[{"kind":"text","text":"(tropical:)  A ram, (S, K,) and a he-goat, (S,)"},{"kind":"italic_en","text":"of a white colour intermixed with black:"},{"kind":"text","text":"(S, K:) any hair, and wool, and the like,"},{"kind":"italic_en","text":"in which are whiteness and blackness:"},{"kind":"text","text":"(TA:) that"},{"kind":"italic_en","text":"in which are whiteness and blackness, the former colour predominating:"},{"kind":"text","text":"(AZ, Ks and others:) or"},{"kind":"italic_en","text":"of a dusty white colour:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a clear white colour:"},{"kind":"text","text":"(Msb:) fem."},{"kind":"arabic","text_bw":"maloHaA='u","text_ar":"مَلْحَا=ءُ"},{"kind":"text","text":"; applied to a ewe"},{"kind":"italic_en","text":"of a white colour intermixed with black:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"black, with its hair pervaded by whiteness."},{"kind":"text","text":"(TA.) Aboo-Dhubyán Ibn-Er-Raabal employs"},{"kind":"arabic","text_bw":"AmlH","text_ar":"املح"},{"kind":"text","text":"as one of four epithets which he applies to those old men most hateful to him. (S.) ―         -b2-  Also, (tropical:)"},{"kind":"italic_en","text":"Blue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gray,"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"muloHapN","text_ar":"مُلْحَةٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"in such a degree as to incline to whiteness;"},{"kind":"text","text":"an epithet applied to a man, &c. (Msb)"},{"kind":"arabic","text_bw":"A^amolaHN AlEayoni","text_ar":"اَمْلَحٌ العَيْنِ"},{"kind":"italic_en","text":"Having the eye of that colour."},{"kind":"text","text":"(S.) ―         -b3-  Hence,"},{"kind":"arabic","text_bw":"katiybapN maloHaA='u","text_ar":"كَتِيبَةٌ مَلْحَا=ءُ"},{"kind":"text","text":"[meaning (tropical:)"},{"kind":"italic_en","text":"An army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a troop of horse, appearing of a white and black,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gray, hue, by reason of their glittering weapons;"},{"kind":"text","text":"see also"},{"kind":"arabic","text_bw":"ktybp $ahobaA='u","text_ar":"كتيبة شَهْبَا=ءُ"},{"kind":"text","text":"]: (S:) or"},{"kind":"italic_en","text":"one that is white and great:"},{"kind":"text","text":"(TA:) or,"},{"kind":"italic_en","text":"great."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"A^amolaHu","text_ar":"اَمْلَحُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Dew that falls in the night upon leguminous plants:"},{"kind":"text","text":"so called because of its whiteness. (L.) Er-Rá'ee says, describing some camels,"},{"kind":"quote","text":"A^aqaAmato bihi Had~a Alr~abiyEi wajaAruhaA\n                     \n                     \n                        A^axuw salowapK mas~aY bihi All~ayolu A^amolaHu"},{"kind":"text","text":"meaning [by"},{"kind":"arabic","text_bw":"AmlH","text_ar":"املح"},{"kind":"text","text":"] dew: ["},{"kind":"italic_en","text":"They remained in it during the period of the season called"},{"kind":"arabic","text_bw":"AlrbyE","text_ar":"الربيع"},{"kind":"text","text":","},{"kind":"italic_en","text":"and their preserver"},{"kind":"text","text":"from thirst"},{"kind":"italic_en","text":"was attended by comfort, being dew brought by the night"},{"kind":"text","text":"]: he says, they remained in that place during the days of the season called"},{"kind":"arabic","text_bw":"AlrbyE","text_ar":"الربيع"},{"kind":"text","text":", and while the dew lasted, so that he was ("},{"kind":"arabic","text_bw":"fahuwa","text_ar":"فَهُوَ"},{"kind":"text","text":"[but this appears to be a mistake for"},{"kind":"arabic","text_bw":"fahiYa","text_ar":"فَهِىَ"},{"kind":"text","text":", “ so that they were, ”]) in a comfortable state of life: and he says"},{"kind":"arabic","text_bw":"ms~Y bh","text_ar":"مسّى به"},{"kind":"text","text":"because the dew falls in the night: (S, L:) by"},{"kind":"arabic","text_bw":"jArhA","text_ar":"جارها"},{"kind":"text","text":"he means the night-dew which preserved them from thirst. (L.) ―         -b5-"},{"kind":"arabic","text_bw":"AlmaloHaA='u","text_ar":"المَلْحَا=ءُ"},{"kind":"text","text":"was also the name of a particular troop belonging to the family of ElMundhir, (S, K,) of the Kings of Syria, who had another called"},{"kind":"arabic","text_bw":"Al$~ahobaA='u","text_ar":"الشَّهْبَا=ءُ"},{"kind":"text","text":". (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"namirapN maloHaA='u","text_ar":"نَمِرَةٌ مَلْحَا=ءُ"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"burodap","text_ar":"بُرْدَة"},{"kind":"italic_en","text":"with black and white stripes."},{"kind":"text","text":"(L.)"},{"kind":"arabic","text_bw":"$ajarapN","text_ar":"شَجَرَةٌ"},{"kind":"arabic","text_bw":"maloHaA='u","text_ar":"مَلْحَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A tree of which the leaves have fallen,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"the branches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"twigs, remaining green."},{"kind":"text","text":"(L.) ―         -b7-"},{"kind":"arabic","text_bw":"AlmaloHaA='u","text_ar":"المَلْحَا=ءُ"},{"kind":"text","text":"(in a camel, L) (assumed tropical:)"},{"kind":"italic_en","text":"Certain flesh in the back,"},{"kind":"text","text":"("},{"kind":"italic_en","text":"situate within,"},{"kind":"text","text":"L,)"},{"kind":"italic_en","text":"extending from the withers"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlkaAhil","text_ar":"الكَاهِل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to the rump:"},{"kind":"text","text":"(L, K:) or"},{"kind":"italic_en","text":"the middle of the back, between the withers"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlkAhl","text_ar":"الكاهل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and the rump:"},{"kind":"text","text":"(T, S [in neither of which is reference made here to a camel]:) or"},{"kind":"italic_en","text":"the part between the hump of a camel and its rump:"},{"kind":"text","text":"or"},{"kind":"page_break","n":2734},{"kind":"italic_en","text":"the vertebræ of a camel over which is the hump:"},{"kind":"text","text":"(L:) or, in a camel,"},{"kind":"italic_en","text":"the part beneath the hump; containing six vertebræ"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maHaAlaAt","text_ar":"مَحَالَات"},{"kind":"text","text":"): pl."},{"kind":"arabic","text_bw":"maloHaAwaAtN","text_ar":"مَلْحَاوَاتٌ"},{"kind":"text","text":". (T.)"},{"kind":"arabic","text_bw":"faArsu AlmaloHaA='i","text_ar":"فَارسُ المَلْحَا=ءِ"},{"kind":"italic_en","text":"The fat of the hump."},{"kind":"text","text":"(L.) ―         -b8-"},{"kind":"arabic","text_bw":"A^amolaHu","text_ar":"اَمْلَحُ"},{"kind":"text","text":"A horse"},{"kind":"italic_en","text":"having the kind of swelling called"},{"kind":"arabic","text_bw":"malaHN","text_ar":"مَلَحٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","TA","Msb","L"]}]},"classical_definitions":null}