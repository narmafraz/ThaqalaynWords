i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعالَجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعالِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعالَجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عالَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عالَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعالِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعالِج","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعالَج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعالَج","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عُولِجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عُولِجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":41,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n30207"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%84%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to treat (a patient or illness or material)","tags":["transitive"],"examples":[{"text":"وزعم البحريون أن اللؤلؤ الكبار المتغير اللون تلُفُّ عليه الألْيَة الطرية المشرحة، وتُؤخذ في جوف عجين ويُدخل التنور ويُبالغ في إحمائه؛ فإنه يصفو ويَحسُن ويعود إليه الماء، وإذا بُخِّر بكافور كان ذلك، وإذا عُولج بمخ العظم وبماء البِطِّيخ فإنه يصفو.","english":"Coastal people claim that the great motley pearls should be wrapped in a freshly cut fat-tail, then taken into a dough inserted into the oven heated up high; thereby they get pure and fair and restore their moisture, and when smoked with camphor the same happens; but if treated with bone-marrow and watermelon-juice they shine."}]},{"pos":"verb","gloss":"to treat, to deal with, to have to do with, to process, to handle, to address (a subject)","tags":["transitive"],"examples":[{"text":"ومن خلال معالجة سؤال البحث المقترح، نأمل أن نتمكن من توليد نظرة للواقع الحقيقي للغة الفرنسية في البلاد.","english":"By addressing the proposed research question, we hope to be able to generate insight into the real reality of the French language in the country."}]},{"pos":"verb","gloss":"to prevail upon, to persuade, to win over","tags":["transitive"]},{"pos":"verb","gloss":"to practise","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30207","headword_ar":"عَالِجٌ","root":"Elj","body":[{"kind":"text","text":"A camel"},{"kind":"italic_en","text":"pasturing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that pastures, upon the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shrub called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EalajaAn","text_ar":"عَلَجَان"},{"kind":"text","text":". (S, O, K.)       -A2-"},{"kind":"italic_en","text":"A quantity"},{"kind":"text","text":"of sand"},{"kind":"italic_en","text":"that has become accumulated and intermixed:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"EawaAliju","text_ar":"عَوَالِجُ"},{"kind":"text","text":". (TA, from a trad.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D8%A7%D9%84%D8%AC/","headword_ar":"عَالِجٌ","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=144017#3ae32e","body_html":"عَالِجٌ:<br>باللام المكسورة، والجيم، قال ابن السكيت:<br>إذا أكل البعير العلجان، وهو نبت، قيل: بعير عالج، وهو شجر يشبه العلندى وأغصانها صلبة،<br>الواحدة علجانة، فيجوز أن يكون هذا الموضع سمّي بذلك تشبيها له بالبعير العالج أو يكون لصلوبته يعالج المشي فيه أي يمارس: وهو رملة بالبادية مسماة بهذا الاسم، قال أبو عبيد الله السكوني:<br>عالج رمال بين فيد والقريات ينزلها بنو بحتر من طيّء وهي متصلة بالثعلبية على طريق مكة لا ماء بها ولا يقدر أحد عليهم فيه، وهو مسيرة أربع ليال، وفيه برك إذا سالت الأودية امتلأت، وذهب بعضهم إلى أن رمل عالج هو متصل بوبار، قال عبيد بن أيوب اللّص:<br>أنظر فرنّق جزاك الله صالحة ... رأد الضحى اليوم هل ترتاد أظعانا<br>يعلون من عالج رملا ويعسفه ... أخو رمال بها قد طال ما كانا<br>إذا حبا عقد نكّبن أصعبه، ... واجتبن منه جماهيرا وغيطانا<br>وقال أعرابيّ:<br>ألا يا بغاث الوحش هيّجت ساكنا ... من الوجد في قلبي، أصمّك صائد<br>رميت سليم القلب بالحزن في الحشا، ... وما قلب من أشجيت بالموت طارد<br>أفي كلّ نجد من تلاد وعابر ... بغام مهاة الوحش للقلب قاصد؟<br>أتيحت لنا من كل منعرج اللّوى ... ومنتابها يوم العذيبين ناهد<br>يراشق أكباد المحبين باللّوى ... من الوحش مرتاب المذانب فارد<br>فيا راشقات العين من رمل عالج ... متى منكم سرب إلى الماء وارد؟<br>فما القلب من ذكرى أميمة نازع، ... ولا الدمع مما أضمر القلب جامد"}]}}