bw":"Euruw$","text_ar":"عُرُوش"},{"kind":"text","text":", (M,) of a well: (A 'Obeyd, T, S, M, K:) or the"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"of a well: (K:) or it has this meaning also: (M:) pl."},{"kind":"arabic","text_bw":"mavaAbaAtN","text_ar":"مَثَابَاتٌ"},{"kind":"text","text":". (T, M.) [See also"},{"kind":"arabic","text_bw":"mavaAbpN","text_ar":"مَثَابةٌ"},{"kind":"text","text":".] ―         -b5-  And (assumed tropical:)  The"},{"kind":"italic_en","text":"construction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"casing, of stones"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"TY~u AlHijaArapi","text_ar":"طىُّ الحِجَارَةِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"that succeed one another from top to bottom"},{"kind":"text","text":"["},{"kind":"italic_en","text":"round the interior of a well"},{"kind":"text","text":"]. (IAar.) [See again"},{"kind":"arabic","text_bw":"mavaAbapN","text_ar":"مَثَابَةٌ"},{"kind":"text","text":".]"}],"source_refs":["S","M","K"]}]},"classical_definitions":null}