,"text":"or"},{"kind":"italic_en","text":"in a heap"},{"kind":"text","text":"]. (S and Msb and K in art."},{"kind":"arabic","text_bw":"kwr","text_ar":"كور"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"ma$aY mujotamiEFA","text_ar":"مَشَى مُجْتَمِعًا"},{"kind":"italic_en","text":"He walked quickly,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"with vehemence of motion, and strength of limbs, not languidly."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","TA","K"]}]},"classical_definitions":null}