t":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدْلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدْلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدْلِج","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدْلِج","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدْلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدْلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدْلِجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدْلِجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدْلِجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدْلِجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدْلِجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَدْلَجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَدْلَجْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُدْلِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدْلِج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n12912"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%92%D9%84%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to set out/go out at nightfall"}]},"etymology":null,"ipa":["/ʔad.la.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12912","headword_ar":"ادلج","root":"dlj","body":[{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"A_idolaAjN","text_ar":"اـِدْلَاجٌ"},{"kind":"text","text":", Msb, TA,)"},{"kind":"italic_en","text":"He journeyed from the beginning of the night:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aid~alaja","text_ar":"اِدَّلَجَ","orth_type":"arrow"},{"kind":"italic_en","text":"he journeyed from the latter part of the night:"},{"kind":"text","text":"(Th, S, K:) or the former signifies"},{"kind":"italic_en","text":"he journeyed all the night:"},{"kind":"text","text":"and ↓ the latter,"},{"kind":"italic_en","text":"he journeyed in the latter part of the night:"},{"kind":"text","text":"(A, Msb, TA:) or the former,"},{"kind":"italic_en","text":"he journeyed in the night, at any hour from the beginning to the end thereof:"},{"kind":"text","text":"(Th, from Aboo-Suleymán ElAarábee:) or, accord. to El-Fárisee, ↓ both these verbs are syn., and each bears the first and second of the significations given above: IDrst contends against the assertions of those who make a difference between them, and affirms them to be syn., and to signify"},{"kind":"italic_en","text":"he journeyed in the night, at any time, in the beginning or middle or end thereof:"},{"kind":"page_break","n":903},{"kind":"text","text":"therefore, he says, their signification is restricted, in several examples, by the context; and hence, he adds, the appellation"},{"kind":"arabic","text_bw":"mudolijN","text_ar":"مُدْلِجٌ"},{"kind":"text","text":"given to a hedgehog: (TA:) [agreeably with this explanation,] 'Alee says,"},{"kind":"quote","text":"AiSobiro EalaY Als~ayori waAlA_idolaAji fiY Als~aHari"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Endure thou with patience travelling, and journeying in the night, in the period a little before daybreak"},{"kind":"text","text":"]. (MF.) [See another ex. voce"},{"kind":"arabic","text_bw":"A^aSobaHa","text_ar":"اَصْبَحَ"},{"kind":"text","text":".]"}],"source_refs":["Th","S","K","A","Msb","TA"]}]}}