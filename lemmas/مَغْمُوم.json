xt","text":"(Msb,) or"},{"kind":"italic_en","text":"intercepted by thin clouds,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so as not to be seen."},{"kind":"text","text":"(Msb.) ―         -b4-  Applied to a man,"},{"kind":"italic_en","text":"Grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused to mourn"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lament,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to be sorrowful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unhappy."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"italic_en","text":"Affected with the malady termed"},{"kind":"arabic","text_bw":"gumaAm","text_ar":"غُمَام"},{"kind":"text","text":". (K.)"}],"source_refs":["Msb","K"]}]}}