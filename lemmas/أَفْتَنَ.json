,"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%AA%D9%8E%D9%86%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34617","headword_ar":"افتنّ","root":"fn","body":[{"kind":"italic_en","text":"He began, commenced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon, various sorts of speech."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"Aftn~ fiY","text_ar":"افتنّ فِى"},{"kind":"arabic","text_bw":"Hadiyvihi","text_ar":"حَدِيثِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiY xuTobatihi","text_ar":"فِى خُطْبَتِهِ"},{"kind":"italic_en","text":"He produced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave utterance to, various sorts and ways of speech,"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he diversified,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in his narration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in his oration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"harangue:"},{"kind":"text","text":"(S, TA:) it is like"},{"kind":"arabic","text_bw":"Ai$otaq~a","text_ar":"اِشْتَقَّ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"he branched off"},{"kind":"text","text":"in it]. (S. [See also 5.]) And"},{"kind":"arabic","text_bw":"Aftn~ fiY xuSuwmatihi","text_ar":"افتنّ فِى خُصُومَتِهِ"},{"kind":"italic_en","text":"He expatiated,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"practised versatility, in his altercation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disputation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Aftn~ AlHimaAru","text_ar":"افتنّ الحِمَارُ"},{"kind":"arabic","text_bw":"biA^utunihi","text_ar":"بِاُتُنِهِ"},{"kind":"italic_en","text":"The he-ass betook himself to driving away his she-asses to the right and to the left and in a direct and an indirect course."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","TA"]}]},"classical_definitions":null}