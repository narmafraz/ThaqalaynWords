It is substituted, agreeably with general usage, for the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"of the form"},{"kind":"arabic","text_bw":"AifotaEala","text_ar":"اِفْتَعَلَ"},{"kind":"text","text":"and its variations, when the first radical letter is"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"AizodaAda","text_ar":"اِزْدَادَ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"AizotaAda","text_ar":"اِزْتَادَ"},{"kind":"text","text":"]; or"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"Aid~akara","text_ar":"اِدَّكَرَ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"Ai*odakara","text_ar":"اِذْدَكَرَ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"Ai*otakara","text_ar":"اِذْتَكَرَ"},{"kind":"text","text":"]; or"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"Aid~araA^a","text_ar":"اِدَّرَاَ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"AidodaraA^a","text_ar":"اِدْدَرَاَ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"AidotaraA^a","text_ar":"اِدْتَرَاَ"},{"kind":"text","text":"]: and sometimes after"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"AijodamaEuwA","text_ar":"اِجْدَمَعُوا"},{"kind":"text","text":", a dial. var. of"},{"kind":"arabic","text_bw":"AijotamaEuwA","text_ar":"اِجْتَمَعُوا"},{"kind":"text","text":": also, sometimes, for the pronominal affix"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"after"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"jalad~u","text_ar":"جَلَدُّ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"jaladotu","text_ar":"جَلَدْتُ"},{"kind":"text","text":"; and after"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"juzodu","text_ar":"جُزْدُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"juzotu","text_ar":"جُزْتُ"},{"kind":"text","text":": it is also substituted for the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"tawolajN","text_ar":"تَوْلَجٌ"},{"kind":"text","text":", contr. to analogy: and it occurs substituted for"},{"kind":"arabic","text_bw":"T","text_ar":"ط"},{"kind":"text","text":", contr. to general usage, as in"},{"kind":"arabic","text_bw":"maradaY","text_ar":"مَرَدَى"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"maraTaY","text_ar":"مَرَطَى"},{"kind":"text","text":". (MF.)       -A2-  [As a numeral, it denotes"},{"kind":"italic_en","text":"Four."},{"kind":"text","text":"]"}],"source_refs":[]}]},"classical_definitions":null}