nse_count":5},"lanes":{"found":true,"entry_ids":["n41910"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%B3%D9%92%D9%88%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to whisper"},{"pos":"verb","gloss":"to try to seduce or disquiet a person by (or as if by) whispering in his or her ear"},{"pos":"verb","gloss":"to suggest wicked or foolish things","tags":["figuratively"]},{"pos":"verb","gloss":"to disquiet, cause scruples","tags":["figuratively"]},{"pos":"verb","gloss":"to clatter"}]},"etymology":{"source":"wiktextract","text":"From the reduplicated root و س و س (w s w s)."},"ipa":["/was.wa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41910","headword_ar":"وَسْوَسَ","root":"ws","body":[{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"wasowasapN","text_ar":"وَسْوَسَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wisowaAsN","text_ar":"وِسْوَاسٌ"},{"kind":"text","text":", and simple subst."},{"kind":"arabic","text_bw":"wsowaAsN","text_ar":"وسْوَاسٌ"},{"kind":"text","text":", but see"},{"kind":"arabic","text_bw":"ZA^oZaA^a","text_ar":"ظاْظَاَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He spoke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talked, indistinctly:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft manner, with confusedness:"},{"kind":"text","text":"for] Aboo-Turáb is related to have said, that he heard Khaleefeh say,"},{"kind":"arabic","text_bw":"wasowasapN","text_ar":"وَسْوَسَةٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"speaking in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, manner, with confusedness:"},{"kind":"text","text":"or, accord. to one relation, it is ["},{"kind":"arabic","text_bw":"wa$owa$apN","text_ar":"وَشْوَشَةٌ"},{"kind":"text","text":",] with"},{"kind":"arabic","text_bw":"$","text_ar":"ش"},{"kind":"text","text":". (TA.) [It is generally intrans., agreeable with the above explanations: but sometimes trans.; for you say,]"},{"kind":"arabic","text_bw":"wasowasa Alr~ajula","text_ar":"وَسْوَسَ الرَّجُلَ"},{"kind":"italic_en","text":"He spoke to the man with low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, speech."},{"kind":"text","text":"(M.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"wasowasatN A_ilayohi nafosuhu","text_ar":"وَسْوَسَتٌ اـِلَيْهِ نَفْسُهُ"},{"kind":"text","text":", (S, M, * A, * Msb, K, *) and"},{"kind":"arabic","text_bw":"wasowasa A_ilayohi Al$~ayoTaAnu","text_ar":"وَسْوَسَ اـِلَيْهِ الشَّيْطَانُ"},{"kind":"text","text":", (S, A, * Msb, K,) and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"fiY Sadorihi","text_ar":"فِى صَدْرِهِ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"wasowsapN","text_ar":"وَسْوسَةٌ"},{"kind":"text","text":"(S, M, A, Msb, K) and"},{"kind":"arabic","text_bw":"wisowaAsN","text_ar":"وِسْوَاسٌ"},{"kind":"text","text":", with kesr, (S, A, Msb, K,) and"},{"kind":"arabic","text_bw":"wasowaAsN","text_ar":"وَسْوَاسٌ"},{"kind":"text","text":", with fet-h, is also allowable in the case of this and similar reduplicative verbs, (MF, voce"},{"kind":"arabic","text_bw":"ZaA^oZaA^a","text_ar":"ظَاْظَاَ"},{"kind":"text","text":",) or this last is a simple subst., (S, Msb, K,)"},{"kind":"italic_en","text":"His mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soul,"},{"kind":"text","text":"(S, M, A, &c.,) and"},{"kind":"italic_en","text":"the devil,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"prompted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suggested to him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"something"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"talked to him,"},{"kind":"text","text":"(S, M, Msb,) and ["},{"kind":"italic_en","text":"in him,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"in his bosom:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"suggested to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talked to him of,"},{"kind":"text","text":"(A, * K,) and"},{"kind":"italic_en","text":"suggested in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talked in him of,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"what was vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable, and destitute of good:"},{"kind":"text","text":"(A, K, TA:) and in like manner one says of the thoughts. (TA.) By the prep."},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"by which it is made trans. in the Kur, in vii. 19, is meant"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":". (S, Msb.) You say also,"},{"kind":"arabic","text_bw":"wusowisa bihi","text_ar":"وُسْوِسَ بِهِ"},{"kind":"text","text":"[as though signifying properly"},{"kind":"italic_en","text":"He had vain things suggested in him by the devil, so that his mind was disturbed thereby, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his speech became confused, and he became stupified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived of his reason."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"wasowasa AlHaloYu","text_ar":"وَسْوَسَ الحَلْىُ"},{"kind":"text","text":", (M, A, Bd, in vii. 19,) inf. n."},{"kind":"arabic","text_bw":"wasowasapN","text_ar":"وَسْوَسَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wisowaAsN","text_ar":"وِسْوَاسٌ"},{"kind":"text","text":", (M,) (tropical:)"},{"kind":"italic_en","text":"The woman's ornament sounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sounds:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"made a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gentle, sound;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a chinking."},{"kind":"text","text":"(Bd, [who holds this to be a primary signification: but it is said in the A to be tropical.]) And"},{"kind":"arabic","text_bw":"wasowasa AlqaSabu","text_ar":"وَسْوَسَ القَصَبُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The reeds made a low sound;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rustling"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"samiEotu","text_ar":"سَمِعْتُ"},{"kind":"arabic","text_bw":"wisowaAsahu","text_ar":"وِسْوَاسَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I heard its low sounding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its chinking;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its rustling"},{"kind":"text","text":"]. (A.) See also"},{"kind":"arabic","text_bw":"wasowaAsN","text_ar":"وَسْوَاسٌ"},{"kind":"text","text":"."}],"source_refs":["TA","S","Msb","K","M","A"]}]},"classical_definitions":null}