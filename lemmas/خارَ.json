n_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخِر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخُور","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخِير","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخُر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخِر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخُور","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخِير","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخُورا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخُورا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخُورانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخِيرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخِيرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخُورُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخُورُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخِيرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخِيرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَخِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خِرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خُرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خُرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخُور","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخُور","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخِير","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخِير","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":48,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n10224","n11680","n11803"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to moo, to low (of cattle)"},{"pos":"verb","gloss":"to decrease in strength, to become weak, to languish (of a person)"},{"pos":"verb","gloss":"to dwindle, to flag (of one's strength)"},{"pos":"verb","gloss":"to select, to choose","tags":["transitive"]},{"pos":"verb","gloss":"to prefer","tags":["transitive"]},{"pos":"verb","gloss":"to become wealthy"},{"pos":"verb","gloss":"to outdo (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to make good [with فِي (fī) ‘an issue’ and لِ (li) ‘for someone’] (especially of God)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10224","headword_ar":"خَارٌّ","root":"xr","body":[{"kind":"text","text":"part. n. of 1. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xur~aArN","text_ar":"خُرَّارٌ"},{"kind":"text","text":"[is a pl. thereof: and] signifies (assumed tropical:)  Men"},{"kind":"italic_en","text":"coming from one town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, to another;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xar~aArapN","text_ar":"خَرَّارَةٌ","orth_type":"arrow"},{"kind":"text","text":": which latter signifies also (assumed tropical:)  Men"},{"kind":"italic_en","text":"passing along,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n11680","headword_ar":"خَارَ","root":"xwr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxuwru","text_ar":"يَخُورُ"},{"kind":"text","text":", (S, A, Mgh,) inf. n."},{"kind":"arabic","text_bw":"xuwaArN","text_ar":"خُوَارٌ"},{"kind":"text","text":"(JK, S, A, Mgh, K *) and"},{"kind":"arabic","text_bw":"xaworN","text_ar":"خَوْرٌ"},{"kind":"text","text":", (JK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bull)"},{"kind":"italic_en","text":"uttered his cry;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"lowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bellowed;"},{"kind":"text","text":"] (Lth, JK, S, A, Mgh, K;)"},{"kind":"italic_en","text":"this being its primary signification:"},{"kind":"text","text":"(Er-Rághib:) the inf. n."},{"kind":"arabic","text_bw":"xwAr","text_ar":"خوار"},{"kind":"text","text":", used agreeably with this explanation, occurs in the Kur xx. 90 [and vii. 146]: (S:) it signifies the"},{"kind":"italic_en","text":"loud crying"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"lowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bellowing"},{"kind":"text","text":"] of a cow and of a calf: (Lth:) and the"},{"kind":"italic_en","text":"crying"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"bleating"},{"kind":"text","text":"] of sheep, or that of goats, and of gazelles, (K,) and of any beast: (Er-Rághib:) and the"},{"kind":"italic_en","text":"sounding"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"whizzing"},{"kind":"text","text":"] of arrows: (K:) of any of these, you say,"},{"kind":"arabic","text_bw":"xaAra","text_ar":"خَارَ"},{"kind":"text","text":", aor. and inf. n. as above. (TA.) [Hence,]"},{"kind":"arabic","text_bw":"lahu SawotN kaxuwaAri Alv~awori","text_ar":"لَهُ صَوْتٌ كَخُوَارِ الثَّوْرِ"},{"kind":"italic_en","text":"He has a voice like the bellowing of the bull."},{"kind":"text","text":"(A.) ―         -b2-  [And hence, (see 10,)]"},{"kind":"arabic","text_bw":"xAr Ealayohi","text_ar":"خار عَلَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He bent, turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, towards him."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"xAr","text_ar":"خار"},{"kind":"text","text":", aor. as above, (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"xuw^uwrN","text_ar":"خُوُورٌ"},{"kind":"text","text":", (S, K, [for which Golius, as on these authorities, substitutes"},{"kind":"arabic","text_bw":"xuw^uwrapN","text_ar":"خُوُورَةٌ"},{"kind":"text","text":",]) said of a man, (S,) and of anything, (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weak,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feeble,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"and languid;"},{"kind":"text","text":"(S, TA;) as also"},{"kind":"arabic","text_bw":"xawira","text_ar":"خَوِرَ"},{"kind":"text","text":", (TA,) aor."},{"kind":"arabic","text_bw":"yaxowaru","text_ar":"يَخْوَرُ"},{"kind":"text","text":", (JK,) inf. n."},{"kind":"arabic","text_bw":"xawarN","text_ar":"خَوَرٌ"},{"kind":"text","text":"; (S, * K, * TA;) and ↓"},{"kind":"arabic","text_bw":"xiw~ir","text_ar":"خِوِّر","orth_type":"arrow"},{"kind":"text","text":", (JK, TA,) inf. n."},{"kind":"arabic","text_bw":"taxowiyrN","text_ar":"تَخْوِيرٌ"},{"kind":"text","text":". (K.)"},{"kind":"arabic","text_bw":"xAr","text_ar":"خار"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xawira","text_ar":"خَوِرَ"},{"kind":"text","text":"both signify"},{"kind":"italic_en","text":"It was soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fragile;"},{"kind":"text","text":"said of anything, like a reed. (JK.) It is said in a trad. of 'Omar,"},{"kind":"arabic","text_bw":"lano yaxuwra qawiY~N maA daAma SaAHibuhaA banoziEu wayanozuw","text_ar":"لَنْ يَخُورَ قَوِىٌّ مَا دَامَ صَاحِبُهَا بَنْزِعُ وَيَنْزُو"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A possessor of strength"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"SaAHibu quw~apK","text_ar":"صَاحِبُ قُوَّةٍ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"will not be weak as long as he can pull"},{"kind":"text","text":"his bow"},{"kind":"italic_en","text":"and leap"},{"kind":"text","text":"to his beast. (TA.) In a camel that is drinking,"},{"kind":"arabic","text_bw":"xawarN","text_ar":"خَوَرٌ"},{"kind":"text","text":"denotes, or implies, a quality that is praised; i. e."},{"kind":"italic_en","text":"Patient enduring of thirst and fatigue:"},{"kind":"text","text":"and a quality dispraised; i. e. the"},{"kind":"italic_en","text":"lacking patience to endure thirst and fatigue."},{"kind":"text","text":"(TA.) ―         -b2-  Also, said of heat, (S, TA,) and of cold, inf. n."},{"kind":"arabic","text_bw":"xuw^uwrN","text_ar":"خُوُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuw^uwrapN","text_ar":"خُوُورَةٌ"},{"kind":"text","text":", (JK,) (tropical:)"},{"kind":"italic_en","text":"It became faint; it remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abated;"},{"kind":"text","text":"(JK, S, TA;) and so"},{"kind":"arabic","text_bw":"xawira","text_ar":"خَوِرَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xawarN","text_ar":"خَوَرٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"xw~r","text_ar":"خوّر","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xAr Ean~aA","text_ar":"خار عَنَّا"},{"kind":"text","text":", said of cold,"},{"kind":"italic_en","text":"It ceased from us; quitted us."},{"kind":"text","text":"(A.)       -A3-"},{"kind":"arabic","text_bw":"xaArahu","text_ar":"خَارَهُ"},{"kind":"text","text":", (JK, S,) inf. n."},{"kind":"arabic","text_bw":"xaworN","text_ar":"خَوْرٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, his"},{"kind":"arabic","text_bw":"xaworaAn","text_ar":"خَوْرَان"},{"kind":"text","text":", (JK, S, K, *) in thrusting or piercing him with a spear or the like. (JK, S.)"}],"source_refs":["S","A","Mgh","JK","Lth","K","Msb","TA"]},{"entry_id":"n11803","headword_ar":"خَارَ","root":"xyr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxiyru","text_ar":"يَخِيرُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"xayorN","text_ar":"خَيْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, possessed of"},{"kind":"arabic","text_bw":"xayor","text_ar":"خَيْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"good,"},{"kind":"text","text":"&c.]. (K, TA.) ―         -b2-  ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be came, good:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he did good: contr. of"},{"kind":"arabic","text_bw":"$ar~a","text_ar":"شَرَّ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"xirota yaA rajulu","text_ar":"خِرْتَ يَا رَجُلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou hast been good;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thou hast done good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"well; O man"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"xaAraA@ll~`hu laka fiY h`*aA AlA^amori","text_ar":"خَارَا@للّٰهُ لَكَ فِى هٰذَا الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God do good to thee, bless thee, prosper thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour thee, in this affair:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"may God cause thee to have,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appoint to thee, good in this affair:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"may God choose for thee the better thing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in this affair"},{"kind":"text","text":"]. (A.)"},{"kind":"arabic","text_bw":"Al~`hum~a xiroliY","text_ar":"الّٰهُمَّ خِرْلِى"},{"kind":"text","text":"occurs in a trad., meaning"},{"kind":"italic_en","text":"O God, choose for me the better of the two things."},{"kind":"text","text":"(TA.) ―         -b3-  See also 8. ―         -b4-"},{"kind":"arabic","text_bw":"xaArahu EalaY","text_ar":"خَارَهُ عَلَى"},{"kind":"arabic","text_bw":"SaAHibihi","text_ar":"صَاحِبِهِ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"xiyrapN","text_ar":"خِيرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiyarN","text_ar":"خِيَرٌ"},{"kind":"text","text":"(Msb, K *) and"},{"kind":"arabic","text_bw":"xiyarapN","text_ar":"خِيَرَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"xayorN","text_ar":"خَيْرٌ"},{"kind":"text","text":"; (Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"xy~rhu","text_ar":"خيّرهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taxoyiyrN","text_ar":"تَخْيِيرٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He preferred him before his companion,"},{"kind":"text","text":"(Msb, K. *) ―         -b5-"},{"kind":"arabic","text_bw":"xaAyarahu","text_ar":"خَايَرَهُ"},{"kind":"arabic","text_bw":"faxaArahu","text_ar":"فَخَارَهُ"},{"kind":"text","text":": see 3."},{"kind":"page_break","n":829}],"source_refs":["K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D8%B1/","headword_ar":"خار","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=69052#f58e07","body_html":"خار<br>عن الفارسية بمعنى شوك، أو عن خوار بمعنى حقير أو ذليل. يستخدم للذكور."}]}}