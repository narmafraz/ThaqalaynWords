n_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْتَصِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْتَصِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْتَصِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْتَصِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْتَصِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْتَصِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْتَصِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْتَصِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْتَصِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْتَصِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْتَصِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِخْتَصَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِخْتَصَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْتَصِر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْتَصِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n10767"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AE%D9%92%D8%AA%D9%8E%D8%B5%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to abbreviate"},{"pos":"verb","gloss":"to summarize"},{"pos":"verb","gloss":"to outline"}]},"etymology":null,"ipa":["/ix.ta.sˤa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10767","headword_ar":"اختصر","root":"xSr","body":[{"kind":"text","text":"(A, Mgh, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"txS~r","text_ar":"تخصّر","orth_type":"arrow"},{"kind":"text","text":", (Mgh, Msb, K,) or ↓"},{"kind":"arabic","text_bw":"txASr","text_ar":"تخاصر","orth_type":"arrow"},{"kind":"text","text":", (A, L,)"},{"kind":"italic_en","text":"He put his hand upon his"},{"kind":"arabic","text_bw":"xaSor","text_ar":"خَصْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"waist"},{"kind":"text","text":"], (A, Mgh, L, Msb,) or"},{"kind":"italic_en","text":"upon his"},{"kind":"arabic","text_bw":"xaASirap","text_ar":"خَاصِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"flank"},{"kind":"text","text":"], (Mgh, K,) in prayer. (Mgh, L, Msb.) The doing this in prayer [except in the night, when tired, (see"},{"kind":"arabic","text_bw":"AlmutaxaS~iruwna","text_ar":"المُتَخَصِّرُونَ"},{"kind":"text","text":",)] is forbidden, or disapproved. (Mgh, TA.)       -A2-"},{"kind":"arabic","text_bw":"AxtSr AlT~ariyqa","text_ar":"اختصر الطَّرِيقَ"},{"kind":"italic_en","text":"He went the nearest way."},{"kind":"text","text":"(S, A, Msb, K.) ―         -b2-  And hence, (Msb, TA,)"},{"kind":"arabic","text_bw":"AxtSr AlkalaAma","text_ar":"اختصر الكَلَامَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He abridged the language,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the discourse;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^awojazahu","text_ar":"اَوْجَزَهُ"},{"kind":"text","text":": (S, A, K:) [and in like manner,"},{"kind":"arabic","text_bw":"AlkitaAba","text_ar":"الكِتَابَ"},{"kind":"italic_en","text":"the book,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"writing:"},{"kind":"text","text":"] or, accord. to some, the latter ("},{"kind":"arabic","text_bw":"Awjzhu","text_ar":"اوجزهُ"},{"kind":"text","text":") signifies “ he expressed its correct meaning concisely, without regard to the original words; ” and the former,"},{"kind":"italic_en","text":"he curtailed its words, preserving the meaning:"},{"kind":"text","text":"(MF:) or properly,"},{"kind":"italic_en","text":"he abridged the expressions, making the words fewer, but preserving the entire meaning:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he abridged the language by omitting superfluities, and choosing from it concise expressions which conveyed the meaning."},{"kind":"text","text":"(L.) [You say,"},{"kind":"arabic","text_bw":"AxtSrhu","text_ar":"اختصرهُ"},{"kind":"arabic","text_bw":"EalaY Alr~uboEi","text_ar":"عَلَى الرُّبْعِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He reduced it by abridgment to the fourth"},{"kind":"text","text":"of its original bulk.] And"},{"kind":"arabic","text_bw":"AxtSr Als~ajodapa","text_ar":"اختصر السَّجْدَةَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He recited the chapter in which a prostration should be performed, omitting the verse requiring prostration, in order that he might not prostrate himself:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he recited only the verse requiring a prostration, to prostrate himself in so doing:"},{"kind":"text","text":"both which practices are forbidden. (T, * Mgh, * Msb, * K.) And the verb alone (assumed tropical:)"},{"kind":"italic_en","text":"He recited a verse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two verses, of the last part of the chapter,"},{"kind":"text","text":"in prayer; (K;)"},{"kind":"italic_en","text":"not the whole chapter."},{"kind":"text","text":"(TA.) ―         -b3-  Also, the verb alone,"},{"kind":"italic_en","text":"He curtailed"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"of its superfluities,"},{"kind":"text","text":"(K,) in a general sense. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"AxtSr fiY Aljaz~i","text_ar":"اختصر فِى الجَزِّ"},{"kind":"text","text":", (JK, K, TA,) in some copies of the K"},{"kind":"arabic","text_bw":"fiY AlHaz~i","text_ar":"فِى الحَزِّ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"AxtSr Aljaz~a","text_ar":"اختصر الجَزَّ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He did not extirpate in cutting; did not cut off entirely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utterly:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"he extirpated in cutting; cut off utterly."},{"kind":"text","text":"(JK.)       -A3-"},{"kind":"arabic","text_bw":"AxtSr","text_ar":"اختصر"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He took"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"mixoSarap","text_ar":"مِخْصَرَة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his hand"},{"kind":"text","text":"]: (S, * K:) and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"txS~r","text_ar":"تخصّر","orth_type":"arrow"},{"kind":"italic_en","text":"he took it in his hand;"},{"kind":"text","text":"namely, a"},{"kind":"arabic","text_bw":"mxSrp","text_ar":"مخصرة"},{"kind":"text","text":": (Har p. 122:)"},{"kind":"page_break","n":749},{"kind":"text","text":"or the former,"},{"kind":"italic_en","text":"he leaned upon"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"in walking:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he took"},{"kind":"text","text":"a"},{"kind":"arabic","text_bw":"mxSrp","text_ar":"مخصرة"},{"kind":"text","text":"or a staff"},{"kind":"italic_en","text":"in his hand, to lean upon it."},{"kind":"text","text":"(Mgh.) You say also,"},{"kind":"arabic","text_bw":"AxtSr","text_ar":"اختصر"},{"kind":"arabic","text_bw":"AlEanazapa","text_ar":"العَنَزَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took in his hand the"},{"kind":"arabic","text_bw":"Enzp","text_ar":"عنزة"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"he leaned upon the"},{"kind":"arabic","text_bw":"Enzp","text_ar":"عنزة"},{"kind":"italic_en","text":"in walking"},{"kind":"text","text":"]: it is a thing [i. e. a kind of staff, or short spear,] like the"},{"kind":"arabic","text_bw":"Euk~aAzap","text_ar":"عُكَّازَة"},{"kind":"text","text":": and in like manner, ↓"},{"kind":"arabic","text_bw":"txS~r","text_ar":"تخصّر","orth_type":"arrow"},{"kind":"text","text":"; as in the L &c.: (TA:) and"},{"kind":"arabic","text_bw":"AxtSr biAlEaSaA","text_ar":"اختصر بِالعَصَا"},{"kind":"italic_en","text":"He leaned upon the staff in walking."},{"kind":"text","text":"(A.)"}],"source_refs":["A","Mgh","L","Msb","K","TA","S","MF","JK"]}]},"classical_definitions":null}