"}, {"kind": "text", "text": "[&c.,"}, {"kind": "italic_en", "text": "put in one piece of cloth and tied up"}, {"kind": "text", "text": "]: (TA:) pl."}, {"kind": "arabic", "text_bw": "EukuwmN", "text_ar": "عُكُومٌ"}, {"kind": "text", "text": ". (K.) See also 1, first sentence. ―         -b3-  And"}, {"kind": "italic_en", "text": "A"}, {"kind": "arabic", "text_bw": "namaT", "text_ar": "نَمَط"}, {"kind": "text", "text": "[q. v.]"}, {"kind": "italic_en", "text": "in which a woman puts what she lays up for a time of need"}, {"kind": "text", "text": "("}, {"kind": "arabic", "text_bw": "*axiyratahaA", "text_ar": "ذَخِيرَتَهَا"}, {"kind": "text", "text": "). (S, K. [See also"}, {"kind": "arabic", "text_bw": "EakomN", "text_ar": "عَكْمٌ"}, {"kind": "text", "text": ".]) ―         -b4-  See also"}, {"kind": "arabic", "text_bw": "EikaAmN", "text_ar": "عِكَامٌ"}, {"kind": "text", "text": ". ―         -b5-  Also The"}, {"kind": "arabic", "text_bw": "bakorap", "text_ar": "بَكْرَة"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "pulley,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sheave of the pulley,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "of a well."}, {"kind": "text", "text": "(K.)"}], "source_refs": ["S", "TA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-14", "pipeline_version": "words.translation.v1.spark"}}