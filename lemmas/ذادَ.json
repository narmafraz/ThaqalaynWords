c","text_bw":"*Ad AlA_ibali Eani AlmaA='i","text_ar":"ذاد الاـِبَلِ عَنِ المَا=ءِ"},{"kind":"text","text":", (A, Msb,) aor."},{"kind":"arabic","text_bw":"ya*uwdu","text_ar":"يَذُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*awodN","text_ar":"ذَوْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*iyaAdN","text_ar":"ذِيَادٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the pastor) ["},{"kind":"italic_en","text":"drove away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repelled,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"kept back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred, the camels from the water;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prevented them from coming to it."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"*Adhu Eano","text_ar":"ذادهُ عَنْ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":", (A,) and"},{"kind":"arabic","text_bw":"*udotuhu","text_ar":"ذُدْتُهُ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I, drove him away from such a thing."},{"kind":"text","text":"(S, A. [And the like is said in the M.]) And"},{"kind":"arabic","text_bw":"*Ad Eani AlHarami","text_ar":"ذاد عَنِ الحَرَمِ"},{"kind":"italic_en","text":"He repelled from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defended, the sacred territory."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Alv~aworu ya*uwdu Eano nafosihi bimi*owadihi","text_ar":"الثَّوْرُ يَذُودُ عَنْ نَفْسِهِ بِمِذْوَدِهِ"},{"kind":"text","text":", i. e. (tropical:)  ["},{"kind":"italic_en","text":"The bull repels from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defends, himself"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his horn: and"},{"kind":"arabic","text_bw":"AlfaArisu bimi*owadihi","text_ar":"الفَارِسُ بِمِذْوَدِهِ"},{"kind":"text","text":", i. e. (tropical:)  ["},{"kind":"italic_en","text":"the horseman"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his spear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"short spear."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"*Ad Eano","text_ar":"ذاد عَنْ"},{"kind":"arabic","text_bw":"EiroDihi","text_ar":"عِرْضِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He defended his honour."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"*Ad","text_ar":"ذاد"},{"kind":"arabic","text_bw":"Ean~iY Alham~a","text_ar":"عَنِّى الهَمَّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He dispelled from me anxiety."},{"kind":"text","text":"] (A.)"}],"source_refs":["M","A","T","S","K","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B0%D8%A7%D8%AF/","headword_ar":"ذاد","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=125776#c55c55","body_html":"ذاد<br>عن العبريةبمعنى شرير ومؤذ ومستهتر. يستخدم للذكور."}]}}