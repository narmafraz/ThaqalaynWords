{"lemma":"مُلِحَّةٍ","slug":"مُلِحَّةٍ","root":"ل.ح.ح","root_slug":"ل-ح-ح","root_link":"/words/roots/ل-ح-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُلِحّ","root":"ملح","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n38874","n38875","n38876"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%84%D9%90%D8%AD%D9%8E%D9%91%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"salt"},{"pos":"noun","gloss":"salt water"},{"pos":"noun","gloss":"wit, intellect"},{"pos":"noun","gloss":"knowledge"},{"pos":"noun","gloss":"scholar"},{"pos":"noun","gloss":"beauty, loveliness, grace"},{"pos":"noun","gloss":"oath"},{"pos":"adj","gloss":"salty, saline"},{"pos":"verb","gloss":"to salt"}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-West Semitic *milḥ-."},"ipa":["/milħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38874","headword_ar":"مَلْحَةٌ","root":"mlH","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A single feed taken by a child from the breast."},{"kind":"arabic","text_bw":"malojapN","text_ar":"مَلْجَةٌ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":", signifies a single suck. (TA.)       -A2-"},{"kind":"arabic","text_bw":"maloHapN","text_ar":"مَلْحَةٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"main body of the sea;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"fathomless deep of the sea;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a great expanse"},{"kind":"page_break","n":2733},{"kind":"italic_en","text":"of sea of which the extremities cannot be seen."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n38875","headword_ar":"مُلْحَةٌ","root":"mlH","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"malaHN","text_ar":"مَلَحٌ","orth_type":"arrow"},{"kind":"text","text":"(K) (tropical:)"},{"kind":"italic_en","text":"A white colour intermixed with black:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"whiteness overspreading blackness"},{"kind":"text","text":"in the human hair, and in anything: or"},{"kind":"italic_en","text":"a dusty white colour:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a clear white colour:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whiteness inclining to any kind of redness;"},{"kind":"text","text":"like the colour of the antelope. (L.) [See also"},{"kind":"arabic","text_bw":"A^amolaHu","text_ar":"اَمْلَحُ"},{"kind":"text","text":".] ―         -b2-  Also,"},{"kind":"arabic","text_bw":"muloHapN","text_ar":"مُلْحَةٌ"},{"kind":"text","text":"(tropical:)  The"},{"kind":"italic_en","text":"utmost degree of blueness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grayness,"},{"kind":"text","text":"[app. meaning the latter, from"},{"kind":"arabic","text_bw":"miloHN","text_ar":"مِلْحٌ"},{"kind":"text","text":"as signifying “ salt, ” as salt in the state in which it is commonly used in Arabia is of"},{"kind":"italic_en","text":"a pale gray colour,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^a$ad~u Alz~arqi","text_ar":"اَشَدُّ الزَّرقِ"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"blueness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grayness,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"zuroqap","text_ar":"زُرْقَة"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of such a degree as to incline to whiteness."},{"kind":"text","text":"(S.) [See"},{"kind":"arabic","text_bw":"A^amolaHu","text_ar":"اَمْلَحُ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"muloHapN","text_ar":"مُلْحَةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A goodly, beautiful, pretty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facetious, story,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narrative, and word,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech; a bon-mot;"},{"kind":"text","text":"(L;)"},{"kind":"arabic","text_bw":"waAHidapu AlmulaHi mina AlA^aHaAdiyvi","text_ar":"وَاحِدَةُ المُلَحِ مِنَ الاَحَادِيثِ"},{"kind":"text","text":"; (S, K;) ["},{"kind":"italic_en","text":"what is deemed beautiful, elegant, facetious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"of stories, &c.: (Ibr D:) and so ↓"},{"kind":"arabic","text_bw":"A^umoluwHapN","text_ar":"اُمْلُوحَةٌ","orth_type":"arrow"},{"kind":"text","text":", coupled with"},{"kind":"arabic","text_bw":"A^ufokuwhapN","text_ar":"اُفْكُوهَةٌ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"fkh","text_ar":"فكه"},{"kind":"text","text":"in the TA:] also said to signify"},{"kind":"italic_en","text":"a bad, an abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a foul, word, saying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech;"},{"kind":"text","text":"a meaning taken from a trad. of 'Áïsheh, who applied this term [perhaps ironically] to a bad answer which she had given in consequence of her having misunderstood a question put to her: (L:) pl."},{"kind":"arabic","text_bw":"mulaHN","text_ar":"مُلَحٌ"},{"kind":"text","text":". (S, K.) As said"},{"kind":"arabic","text_bw":"nilotu biAlmulaHi","text_ar":"نِلْتُ بِالمُلَحِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have attained"},{"kind":"text","text":"to the station, or rank, to which I have attained"},{"kind":"italic_en","text":"by means of goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facetious, sayings, &c."},{"kind":"text","text":"] (S.)"},{"kind":"arabic","text_bw":"Had~avotuhu biAlmulaHi","text_ar":"حَدَّثْتُهُ بِالمُلَحِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I related to him goodly, beautiful, pretty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facetious, stories."},{"kind":"text","text":"] (A.) ―         -b4-  ["},{"kind":"italic_en","text":"A curiosity, an extraordinary thing."},{"kind":"text","text":"]"}],"source_refs":["S","K","L"]},{"entry_id":"n38876","headword_ar":"مِلْحَةٌ","root":"mlH","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"miloHN","text_ar":"مِلْحٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}