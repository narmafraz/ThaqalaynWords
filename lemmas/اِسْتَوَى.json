{"lemma":"اِسْتَوَى","slug":"اِسْتَوَى","root":"س.#.#","root_slug":"س-_-_","root_link":"/words/roots/س-_-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"اِسْتَوَيْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"اِسْتَوَيْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"اِسْتَوَيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"اِسْتَوَيْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"اِسْتَوَيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"اِسْتَوَى","in_corpus":true,"count":28,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"اِسْتَوَت","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"اِسْتَوَيا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"اِسْتَوَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"اِسْتَوَوْا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"اِسْتَوَيْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْتَوِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُسْتَوَى","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْتَو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْتَوِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْتَوِي","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْتَوِيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْتَوِيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْتَوُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْتَوُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْتَوِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْتَوِي","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُسْتَوَى","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْتَو","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْتَوِي","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُسْتَوَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْتَو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْتَوِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْتَوِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْتَوِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْتَوِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْتَوُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْتَوُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْتَوِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِسْتَوَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِسْتَوَيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْتَوِي","in_corpus":true,"count":28,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْتَوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُسْتَوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسْتَوَى","in_corpus":true,"count":28,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْتَو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْتَو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":123,"cross_references":{"qac":{"found":true,"lemma_key":"اِسْتَوَى","root":"سوي","pos":"V","occurrence_count":35},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n21351"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%88%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21351","headword_ar":"استوى","root":"swY","body":[{"kind":"text","text":"[seems, accord. to Bd, to signify primarily"},{"kind":"italic_en","text":"He sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, what was equal, equable, uniform, even,"},{"kind":"text","text":"or the like: for he says (in ii. 27) that the primary meaning of"},{"kind":"arabic","text_bw":"AlAisotiwaA='u","text_ar":"الاِسْتِوَا=ءُ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Tlabu Als~awaA='i","text_ar":"طلَبُ السَّوَا=ءِ"},{"kind":"text","text":"; app. indicating the sense in which"},{"kind":"arabic","text_bw":"AlswA='","text_ar":"السوا=ء"},{"kind":"text","text":"is here used by what follows. ―         -b2-  And hence, accord. to him, but I would rather say primarily, as being quasi-pass. of"},{"kind":"arabic","text_bw":"saw~aAhu","text_ar":"سَوَّاهُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, equal, equable, uniform, even, level, flat, plane"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"equal in respect of elevation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of depression,"},{"kind":"text","text":"(see 2, first sentence,)]"},{"kind":"italic_en","text":"straight, right, direct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rightly directed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AiEotadala","text_ar":"اِعْتَدَلَ"},{"kind":"text","text":"(S, M, Msb, K, TA, and Ksh and Bd in ii. 27)"},{"kind":"arabic","text_bw":"fiY *aAtihi","text_ar":"فِى ذَاتِهِ"},{"kind":"text","text":", (TA,) said of a place, (Msb,) and"},{"kind":"arabic","text_bw":"AisotaqaAma","text_ar":"اِسْتَقَامَ"},{"kind":"text","text":", said of a stick, or piece of wood, &c. (Ksh ubi suprà.) And ↓"},{"kind":"arabic","text_bw":"saw~aY","text_ar":"سَوَّى","orth_type":"arrow"},{"kind":"text","text":", [if not a mistranscription for"},{"kind":"arabic","text_bw":"suw~iYa","text_ar":"سُوِّىَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"tasowiyapN","text_ar":"تَسْوِيَةٌ"},{"kind":"text","text":", signifies the same as"},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"text","text":"[app. meaning as above], accord. to IAar; and so does ↓"},{"kind":"arabic","text_bw":"A^asowaY","text_ar":"اَسْوَى","orth_type":"arrow"},{"kind":"text","text":", as also"},{"kind":"arabic","text_bw":"A^awosaY","text_ar":"اَوْسَى"},{"kind":"text","text":", formed from it by transposition. (TA.) One says,"},{"kind":"arabic","text_bw":"Aisotawato bihi AlA^aroDu","text_ar":"اِسْتَوَتْ بِهِ الاَرْضُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"The earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, became equable, uniform, even,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with him,"},{"kind":"text","text":"he having been buried in it], meaning"},{"kind":"italic_en","text":"he perished in the earth;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tasaw~ato","text_ar":"تَسَوَّتْ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"suw~iyato","text_ar":"سُوِّيَتْ","orth_type":"arrow"},{"kind":"text","text":". (M, K.) And"},{"kind":"arabic","text_bw":"Astwt","text_ar":"استوت"},{"kind":"arabic","text_bw":"A^aroDuhumo","text_ar":"اَرْضُهُمْ"},{"kind":"italic_en","text":"Their land became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"even in its surface, being"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"affected with drought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"barrenness."},{"kind":"text","text":"(M, *"},{"kind":"page_break","n":1478},{"kind":"text","text":"TA.) And"},{"kind":"arabic","text_bw":"AstwY AlmaA='u waAlxa$abapa","text_ar":"استوى المَا=ءُ وَالخَشَبَةَ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"maEa","text_ar":"مَعَ"},{"kind":"arabic","text_bw":"Alxa$abapi","text_ar":"الخَشَبَةِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The water became even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level, with the piece of wood"},{"kind":"text","text":"]. (TA.) See also 6, in four places. One says also,"},{"kind":"arabic","text_bw":"AstwY AlmuEaw~aju","text_ar":"استوى المُعَوَّجُ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"AlmuEowj~u","text_ar":"المُعْوجُّ"},{"kind":"text","text":"(as in the MA) i. e."},{"kind":"italic_en","text":"The crooked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uneven, became straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"even"},{"kind":"text","text":"]: (Mgh:) and"},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"arabic","text_bw":"mini A@EuwijaAjK","text_ar":"مِنِ ا@عُوِجَاجٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It became even from a state of unevenness"},{"kind":"text","text":"]. (S.)"},{"kind":"arabic","text_bw":"faA@sotawaY EalaY suwqihi","text_ar":"فَا@سْتَوَى عَلَى سُوقِهِ"},{"kind":"text","text":", in the Kur xlviii. last verse, means"},{"kind":"italic_en","text":"And has stood straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erect,"},{"kind":"text","text":"(Bd,) or"},{"kind":"italic_en","text":"become strong, and stood straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erect,"},{"kind":"text","text":"(Jel,)"},{"kind":"italic_en","text":"upon its stems."},{"kind":"text","text":"(Bd, Jel. [Golius erroneously assigns a similar meaning to"},{"kind":"arabic","text_bw":"AstswY","text_ar":"استسوى"},{"kind":"text","text":", a verb which I do not anywhere find.]) And"},{"kind":"arabic","text_bw":"faA@sotawaY","text_ar":"فَا@سْتَوَى"},{"kind":"text","text":"in the same, liii. 6,"},{"kind":"italic_en","text":"And he stood straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erect, in his proper form in which God created him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was endowed by his strength with power over the affair appointed to him:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"became firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady."},{"kind":"text","text":"(Jel.)"},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"text","text":"said of a stick &c. means"},{"kind":"italic_en","text":"It stood up"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"erect:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straight:"},{"kind":"text","text":"hence one says,"},{"kind":"arabic","text_bw":"AstwY A_ilayohi kaAls~ahomi Almurosali","text_ar":"استوى اـِلَيْهِ كَالسَّهْمِ المُرْسَلِ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went towards him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with an undeviating, a direct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a straight, course, like the arrow hot forth:"},{"kind":"text","text":"and hence,"},{"kind":"arabic","text_bw":"vum~a A@sotawaY A_ilaY Als~amaA='i","text_ar":"ثُمَّ ا@سْتَوَى اـِلَى السَّمَا=ءِ"},{"kind":"text","text":"is metaphorically said of God, in the Kur ii. 27 [and xli. 10]; (Ksh;) meaning (tropical:)  Then"},{"kind":"italic_en","text":"He directed himself by his will to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"heaven,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"elevated regions,"},{"kind":"text","text":"(Ksh, Bd,) or"},{"kind":"italic_en","text":"upwards,"},{"kind":"text","text":"(Ksh,) or"},{"kind":"italic_en","text":"to the heavenly bodies;"},{"kind":"text","text":"(Bd;) syn."},{"kind":"arabic","text_bw":"Eamada","text_ar":"عَمَدَ"},{"kind":"text","text":", (Zj, M, K,) and"},{"kind":"arabic","text_bw":"qaSada","text_ar":"قَصَدَ"},{"kind":"text","text":"(Zj, S, M, K, and Ksh and Bd)"},{"kind":"arabic","text_bw":"biA_iraAdatipi","text_ar":"بِاـِرَادَتِةِ"},{"kind":"text","text":"; (Ksh, Bd;) for when"},{"kind":"arabic","text_bw":"AlAisotiwaA='u","text_ar":"الاِسْتِوَا=ءُ"},{"kind":"text","text":"is trans. by means of"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"it imports the meaning of"},{"kind":"italic_en","text":"the directing of oneself,"},{"kind":"text","text":"or, as in this case,"},{"kind":"italic_en","text":"of one's design:"},{"kind":"text","text":"(TA;) you say of any one who has finished a work and has directed himself to another,"},{"kind":"arabic","text_bw":"qadi A@sotawaY lahu","text_ar":"قَدِ ا@سْتَوَى لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":": (Har p. 631:) or the meaning here is"},{"kind":"arabic","text_bw":"SaEida","text_ar":"صَعِدَ"},{"kind":"text","text":", (Zj, M, K,) or"},{"kind":"arabic","text_bw":"SaEida A^amoruhu","text_ar":"صَعِدَ اَمْرُهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"his command ascended"},{"kind":"text","text":"]; (M;) and this is what is intended here by"},{"kind":"arabic","text_bw":"SaEida","text_ar":"صَعِدَ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"A^aqobala EalayohaA","text_ar":"اَقْبَلَ عَلَيْهَا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He advanced to it,"},{"kind":"text","text":"namely, the heaven]; (Fr, Th, M, K;) like as one says,"},{"kind":"arabic","text_bw":"kaAna fulaAnN muqobilFA EalaY fulaAnK vum~a A@sotawaY EalaY~a","text_ar":"كَانَ فُلَانٌ مُقْبِلًا عَلَى فُلَانٍ ثُمَّ ا@سْتَوَى عَلَىَّ"},{"kind":"arabic","text_bw":"yu$aAtimuniY","text_ar":"يُشَاتِمُنِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilaY~D","text_ar":"اـِلَىّض"},{"kind":"text","text":"also, meaning"},{"kind":"arabic","text_bw":"A^aqobala","text_ar":"اَقْبَلَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Such a one was advancing against such a one, then he advanced against me,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to me, reviling me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contending with me in reviling"},{"kind":"text","text":"]: (TA:) or it means"},{"kind":"arabic","text_bw":"AisotawolaY","text_ar":"اِسْتَوْلَى"},{"kind":"text","text":", (M, K,) as some say: (M:) J says, [in the S,] but not explaining thereby the verse above cited, that it signifies also"},{"kind":"arabic","text_bw":"AisotawolaY","text_ar":"اِسْتَوْلَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Zahara","text_ar":"ظَهَرَ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"He had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained, the mastery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"victory"},{"kind":"text","text":"]: and hence the saying of El-Akhtal, cited by him [in the S,]"},{"kind":"quote","text":"qadi A@sotawaY bi$orN EalaY AlEiraAqi\n                      \n                     \n                        mino gayori sayofK wadamK muhoraAqi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Bishr has gained the mastery over El-'Irák without sword and"},{"kind":"text","text":"without"},{"kind":"italic_en","text":"shed blood"},{"kind":"text","text":"]: Er-Rághib says that when this verb is trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":", it imports the meaning of"},{"kind":"arabic","text_bw":"AlAisotiylaA='","text_ar":"الاِسْتِيلَا=ء"},{"kind":"text","text":"; as in the saying in the Kur [xx. 4],"},{"kind":"arabic","text_bw":"Aalr~aHom`nu EalaY","text_ar":"اَلرَّحْمٰنُ عَلَى"},{"kind":"arabic","text_bw":"A@loEaro$i A@sotawaY","text_ar":"ا@لْعَرْشِ ا@سْتَوَى"},{"kind":"text","text":"[which may be rendered,"},{"kind":"italic_en","text":"The Compassionate hath ascendancy over the empyrean so as to have everything in the universe equally within his grasp;"},{"kind":"text","text":"agreeably with what here follows]: he then adds, it is said to mean that everything is alike in relation to Him in such manner that no one thing is nearer to Him than another thing, since He is not like the bodies that abide in one place exclusively of another place. (TA.) The saying"},{"kind":"arabic","text_bw":"lam~aA A@sotawato bihi","text_ar":"لَمَّا ا@سْتَوَتْ بِهِ"},{"kind":"arabic","text_bw":"raAHilatuhu EalaY AlbayodaA='i","text_ar":"رَاحِلَتُهُ عَلَى البَيْدَا=ءِ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"When his riding-camel"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ascended with him upon the desert:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stood up with him straight upon its legs."},{"kind":"text","text":"(Mgh.) And one says,"},{"kind":"arabic","text_bw":"AstwY EalaY Zahori daAb~atihi","text_ar":"استوى عَلَى ظَهْرِ دَابَّتِهِ"},{"kind":"text","text":", (S, TA,) or"},{"kind":"arabic","text_bw":"EalaY Alfarasi","text_ar":"عَلَى الفَرَسِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he settled himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became firmly seated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sat firmly,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon the back of his beast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the horse:"},{"kind":"text","text":"(S, Msb, TA:) and"},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"arabic","text_bw":"jaAlisFA","text_ar":"جَالِسًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He became firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, sitting;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he settled himself in his sitting place;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sat firmly"},{"kind":"text","text":"]. (Msb.) ["},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"text","text":"as quasi-pass. of"},{"kind":"arabic","text_bw":"saw~aAhu","text_ar":"سَوَّاهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, symmetrical; congruous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consistent in its several parts: was made, formed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fashioned, in a suitable manner: was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, adapted to the exigencies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requirements, of its case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of wisdom: was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, complete: was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good; became rectified, adjusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put into a right"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good state."},{"kind":"text","text":"And hence,]"},{"kind":"arabic","text_bw":"AstwY","text_ar":"استوى"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"balaga A^a$ud~ahu","text_ar":"بَلَغَ اَشُدَّهُ"},{"kind":"text","text":"[q. v.]; (M, K;) [generally meaning]"},{"kind":"italic_en","text":"The man"},{"kind":"text","text":"["},{"kind":"italic_en","text":"became full-grown, of full vigour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mature, in body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in body and intellect;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"attained the utmost limit of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the period termed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his"},{"kind":"arabic","text_bw":"$abaAb","text_ar":"شَبَاب"},{"kind":"text","text":"; (S;) or"},{"kind":"italic_en","text":"attained the utmost limit of his"},{"kind":"arabic","text_bw":"$abaAb","text_ar":"شَبَاب"},{"kind":"text","text":","},{"kind":"italic_en","text":"and the completion of his make and of his intellect, by the completion of from twenty-eight to thirty"},{"kind":"text","text":"["},{"kind":"italic_en","text":"years"},{"kind":"text","text":"]: (T, TA:) or"},{"kind":"italic_en","text":"attained to forty"},{"kind":"text","text":"(T, M, K)"},{"kind":"italic_en","text":"years."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"AstwY AlT~aEaAmu","text_ar":"استوى الطَّعَامُ"},{"kind":"italic_en","text":"The food became thoroughly cooked."},{"kind":"text","text":"(Msb.) ["},{"kind":"arabic","text_bw":"xaT~u AlAisotiwaA='i","text_ar":"خَطُّ الاِسْتِوَا=ءِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The equinoctial line."},{"kind":"text","text":"]"}],"source_refs":["TA","Msb","Mgh","Bd","Jel","Ksh","Zj","M","K","S","T"]}]}}