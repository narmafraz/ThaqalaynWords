{"lemma":"زَها","slug":"زَها","root":"ز.ه.#","root_slug":"ز-ه-_","root_link":"/words/roots/ز-ه-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"زَهَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"زَهَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"زَهَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"زَهَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"زَهَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"زَها","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"زَهَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"زَهَوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"زَهَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"زَهَوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"زَهَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَزْهُو","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَزْه","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَزْهِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَزْهِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَزْهُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَزْهُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَزْهُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَزْهُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَزْهُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَزْهُو","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَزْه","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَزْهُو","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَزْه","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَزْهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَزْهُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَزْهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَزْهُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَزْهُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَزْهُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَزْهُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَزْهُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَزْهُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"زَهَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"زَهَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَزْه","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَزْه","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n18338"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D9%87%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to blossom, flower, be in bloom"},{"pos":"verb","gloss":"to grow, thrive"},{"pos":"verb","gloss":"to shine brightly, be radiant, glow, gleam"},{"pos":"verb","gloss":"to give s.o. airs, be haughty, conceited"},{"pos":"verb","gloss":"to pride s.o (ب upon, both in a favourable and pejorative sense)"}]},"etymology":null,"ipa":["/za.haː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18338","headword_ar":"زَهَا","root":"zhw","body":[{"kind":"text","text":", said of seed-produce,"},{"kind":"italic_en","text":"It increased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"augmented; received increase and blessing from God;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"throve by the blessing of God:"},{"kind":"text","text":"(JK, TA:) [or,] said of herbage, aor."},{"kind":"arabic","text_bw":"yazohuw","text_ar":"يَزْهُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"it attained its full growth:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"it put forth its fruit:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became tall:"},{"kind":"text","text":"(TA:) and, said of palm-trees, ("},{"kind":"arabic","text_bw":"naxolN","text_ar":"نَخْلٌ"},{"kind":"text","text":", S, Msb, K, TA,) and likewise of plants, (TA,) aor. as above, (Msb, TA,) and so the inf. n., (S, Msb, TA,)"},{"kind":"italic_en","text":"they became tall;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"became tall and fullgrown;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became of their full height, and blossomed;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"AzhY","text_ar":"ازهى","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) or both signify"},{"kind":"italic_en","text":"they"},{"kind":"text","text":"(i. e. palm-trees)"},{"kind":"italic_en","text":"showed redness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"yellowness, in their fruit;"},{"kind":"text","text":"(S, Msb;) the latter verb mentioned by AZ, but [it is said that] As did not know it: (S: [see, however, what follows:]) or, as some say, the former signifies"},{"kind":"italic_en","text":"they put forth their fruit;"},{"kind":"text","text":"and ↓ the latter, as expl. next before: (Msb:) accord. to Abu-lKhattáb and Lth, one says of palm-trees ("},{"kind":"arabic","text_bw":"naxol","text_ar":"نَخْل"},{"kind":"text","text":") only"},{"kind":"arabic","text_bw":"yuzohiY","text_ar":"يُزْهِى"},{"kind":"text","text":"; not"},{"kind":"arabic","text_bw":"yazohuw","text_ar":"يَزْهُو"},{"kind":"text","text":": and As [is related to have] said, [contr. to what has been asserted of him above,] that when redness appears in [the fruit of] palm-trees, one says"},{"kind":"arabic","text_bw":"AzhY","text_ar":"ازهى"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"arabic","text_bw":"Alt~amoru","text_ar":"التَّمْرُ"},{"kind":"text","text":", (JK,) or"},{"kind":"arabic","text_bw":"Albusoru","text_ar":"البُسْرُ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AzhY","text_ar":"ازهى","orth_type":"arrow"},{"kind":"text","text":"; (Mgh, K;) and ↓"},{"kind":"arabic","text_bw":"zh~Y","text_ar":"زهّى","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tazohiyapN","text_ar":"تَزْهِيَةٌ"},{"kind":"text","text":"; (TA;) ["},{"kind":"italic_en","text":"The dates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dates beginning to ripen,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"showed their goodness by redness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"yellowness:"},{"kind":"text","text":"(JK:)"},{"kind":"italic_en","text":"became red,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"yellow:"},{"kind":"text","text":"(Mgh:)"},{"kind":"italic_en","text":"became coloured."},{"kind":"text","text":"(K.) Hence the trad.,"},{"kind":"arabic","text_bw":"nahaY Eano bayoEi vamari Aln~axoli Hat~aY yazohuwa","text_ar":"نَهَى عَنْ بَيْعِ ثَمَرِ النَّخْلِ حَتَّى يَزْهُوَ"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"yuzohiYa","text_ar":"يُزْهِىَ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He forbade the selling of the fruit of the palm-trees until its becoming red"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"yellow"},{"kind":"text","text":"], thus differently related. (Mgh.) ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"zahaA AlgulaAmu","text_ar":"زَهَا الغُلَامُ"},{"kind":"text","text":", (K,) aor. and inf. n. as above, (TA,)"},{"kind":"italic_en","text":"The boy grew up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained to youthful vigour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the prime of manhood."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"zahati","text_ar":"زَهَتِ"},{"kind":"arabic","text_bw":"Al$~aApu","text_ar":"الشَّاةُ"},{"kind":"text","text":", (JK, S, K,) aor. as above, (S,) and so the inf. n., (JK, S,)"},{"kind":"italic_en","text":"The ewe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she-goat, became large in her udder:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"secreted milk in her udder, and was near to bringing forth."},{"kind":"text","text":"(AZ, S, K. *) ―         -b4-  And"},{"kind":"arabic","text_bw":"zahati Alr~iyHu","text_ar":"زَهَتِ الرِّيحُ"},{"kind":"italic_en","text":"The wind rose, blew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became in a state of commotion."},{"kind":"text","text":"(S.) ―         -b5-  And"},{"kind":"arabic","text_bw":"zahati AlA_ibilu","text_ar":"زَهَتِ الاـِبِلُ"},{"kind":"text","text":", (JK, S, M, K,) aor. as above, (JK, M,) and so the inf. n., (S, M,)"},{"kind":"italic_en","text":"The camels journeyed, after coming to water,"},{"kind":"text","text":"(JK, S, M, K,)"},{"kind":"italic_en","text":"a night"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more,"},{"kind":"text","text":"(JK, S, M,) so says A'Obeyd, (S,) or"},{"kind":"italic_en","text":"a night"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two nights."},{"kind":"text","text":"(K.) And"},{"kind":"italic_en","text":"The camels passed along,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mar~at","text_ar":"مَرَّت"},{"kind":"text","text":",) so in the copies of the K, but correctly"},{"kind":"arabic","text_bw":"mad~at","text_ar":"مَدَّت"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"made much advance in journeying"},{"kind":"text","text":"], as in the M, (TA,)"},{"kind":"italic_en","text":"in search of pasturage, after they had drunk,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"not pasturing around the water."},{"kind":"text","text":"(TA.) The verb used in relation to camels is also trans., as will be shown below. (S, &c.)       -A2-"},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":"[as inf. n. of the trans. v."},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazohaY","text_ar":"يَزْهَى"},{"kind":"text","text":",] primarily signifies The act of"},{"kind":"italic_en","text":"raising,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevating:"},{"kind":"text","text":"and the act of"},{"kind":"italic_en","text":"shaking;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"putting in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into a state of commotion:"},{"kind":"text","text":"whence"},{"kind":"arabic","text_bw":"zahaAhu Als~araAbu","text_ar":"زَهَاهُ السَّرَابُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zahati Alr~iyHu Aln~abaAta","text_ar":"زَهَتِ الرِّيحُ النَّبَاتَ"},{"kind":"text","text":"[both expl. in what follows]. (Har p. 171.) You say,"},{"kind":"arabic","text_bw":"zahati AlA^amowaAju Als~afiynapa","text_ar":"زَهَتِ الاَمْوَاجُ السَّفِينَةَ"},{"kind":"italic_en","text":"The waves raised the ship."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"zahaA Als~araAbu Al$~aYo'a","text_ar":"زَهَا السَّرَابُ الشَّىْءَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazohaAhu","text_ar":"يَزْهَاهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The mirage raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the eye,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the thing"},{"kind":"text","text":"[seen in it or beyond it; or rather,"},{"kind":"italic_en","text":"made it to appear tall, and as though quivering, vibrating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"playing up and down;"},{"kind":"text","text":"as is perhaps meant to be indicated by the citation above from Har]; syn."},{"kind":"arabic","text_bw":"rafaEahu","text_ar":"رَفَعَهُ"},{"kind":"text","text":"; written only [thus] with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"[in the pret. and in the aor.]: (S:) and"},{"kind":"arabic","text_bw":"Als~araAbu yazohaY Alqubuwra","text_ar":"السَّرَابُ يَزْهَى القُبُورَ"},{"kind":"arabic","text_bw":"waAlHumuwla","text_ar":"وَالحُمُولَ"},{"kind":"italic_en","text":"The mirage is as though it raised the tombs and the women's camel-vehicles;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated them;"},{"kind":"text","text":"expl. by the words"},{"kind":"arabic","text_bw":"kaA^an~ahu yarofaEuhaA","text_ar":"كَاَنَّهُ يَرْفَعُهَا"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"zahaA AlmirowaHapa","text_ar":"زَهَا المِرْوَحَةَ"},{"kind":"text","text":", said of a person fanning,"},{"kind":"italic_en","text":"He put in motion the fan;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put it into a state of commotion;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"zah~aAhaA","text_ar":"زَهَّاهَا","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"zahati","text_ar":"زَهَتِ"},{"kind":"arabic","text_bw":"AlriyHu Al$~ajara","text_ar":"الرِيحُ الشَّجَرَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Aln~abaAta","text_ar":"النَّبَاتَ"},{"kind":"text","text":", (K, * TA,) aor."},{"kind":"arabic","text_bw":"tazohaAhu","text_ar":"تَزْهَاهُ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"The wind shook,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into a state of commotion,"},{"kind":"text","text":"(S, K, * TA,)"},{"kind":"italic_en","text":"the trees,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"the plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, after the dew"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rain"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"gib~a Aln~adaY","text_ar":"غِبَّ النَّدَى"},{"kind":"text","text":"). (K, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"zahaAhu","text_ar":"زَهَاهُ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"AzdhAhu","text_ar":"ازدهاهُ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"AizodihaA='N","text_ar":"اِزْدِهَا=ءٌ"},{"kind":"text","text":"; (K, TA;) [not"},{"kind":"arabic","text_bw":"AzhAhu","text_ar":"ازهاهُ"},{"kind":"text","text":", as in the TK, followed by Freytag;]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Aisotaxaf~ahu","text_ar":"اِسْتَخَفَّهُ"},{"kind":"text","text":": (S, K, * TA:) and"},{"kind":"arabic","text_bw":"tahaAwana bihi","text_ar":"تَهَاوَنَ بِهِ"},{"kind":"text","text":": (S:) [the former of these two explanations as meaning"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, incited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited him, to briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to lightness, levity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsteadiness:"},{"kind":"text","text":"and the latter of them, or both of them, for the former is often syn. with the latter, as meaning"},{"kind":"italic_en","text":"he held him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light, estimation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"account,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in contempt; he contemned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"despised, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"but of this latter meaning I do not remember to have met with any ex.:] and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AzdhY","text_ar":"ازدهى","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"AzdhAh","text_ar":"ازدهاه"},{"kind":"text","text":"(TA) meaning"},{"kind":"arabic","text_bw":"tahaAwana bihi","text_ar":"تَهَاوَنَ بِهِ"},{"kind":"text","text":". (JK.) You say,"},{"kind":"arabic","text_bw":"zahaAhu Al$~aYo'u","text_ar":"زَهَاهُ الشَّىْءُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AzdhAhu","text_ar":"ازدهاهُ","orth_type":"arrow"},{"kind":"text","text":", meaning [agreeably with the former of the two explanations in the sentence immediately preceding]"},{"kind":"arabic","text_bw":"Aisotaxaf~ahu TarabFA","text_ar":"اِسْتَخَفَّهُ طَرَبًا"},{"kind":"text","text":": (Har p. 359:) and ↓"},{"kind":"arabic","text_bw":"yazodahiyniY","text_ar":"يَزْدَهِينِى","orth_type":"arrow"},{"kind":"text","text":"as meaning [agreeably with the same explanation]"},{"kind":"arabic","text_bw":"yasotafiz~uniY","text_ar":"يَسْتَفِزُّنِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yasotaxif~uniY","text_ar":"يَسْتَخِفُّنِى"},{"kind":"text","text":": (Id. p. 131:) and"},{"kind":"arabic","text_bw":"Alqawoma","text_ar":"القَوْمَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AzdhY","text_ar":"ازدهى","orth_type":"arrow"},{"kind":"text","text":"as meaning [in like manner]"},{"kind":"arabic","text_bw":"Aisotaxaf~ahumo mina AlT~arabi","text_ar":"اِسْتَخَفَّهُمْ مِنَ الطَّرَبِ"},{"kind":"text","text":"; and also as meaning"},{"kind":"italic_en","text":"He pleased the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party:"},{"kind":"text","text":"(Id. p. 427:) and ↓"},{"kind":"arabic","text_bw":"AizodahaAhu","text_ar":"اِزْدَهَاهُ","orth_type":"arrow"},{"kind":"text","text":"also as meaning"},{"kind":"arabic","text_bw":"Hamalahu EalaY Alz~ahowi","text_ar":"حَمَلَهُ عَلَى الزَّهْوِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He incited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited him, to pride,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]: (Id. p. 131:) and"},{"kind":"arabic","text_bw":"zahaAhu Alkiboru","text_ar":"زَهَاهُ الكِبْرُ"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Pride rendered him self-conceited."},{"kind":"text","text":"(TK.) 'Omar Ibn-'Abee-Rabeea says,"},{"kind":"quote","text":"walam~aA taqaAwaDonaA AlHadiyva waA^asofarato\n                      \n                     \n                        wujuwhN zahaAhaA AlHusonu A^ano tataqan~aEaA"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"And when we discoursed together, and faces shone, beauty excited"},{"kind":"text","text":"the possessors of"},{"kind":"italic_en","text":"them to levity"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Aisotaxaf~a A^arobaAbahaA","text_ar":"اِسْتَخَفَّ اَرْبَابَهَا"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and prevented their veiling them with the"},{"kind":"arabic","text_bw":"qinaAE","text_ar":"قِنَاع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"head-covering"},{"kind":"text","text":"], by reason of self-admiration: or, as some say, the"},{"kind":"arabic","text_bw":"hA","text_ar":"ها"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"zhAhA","text_ar":"زهاها"},{"kind":"text","text":"refers to a woman mentioned before, not to"},{"kind":"arabic","text_bw":"wjwh","text_ar":"وجوه"},{"kind":"text","text":"; and the meaning is,"},{"kind":"italic_en","text":"beauty excited her"},{"kind":"text","text":"&c.: and thus the women of the Arabs used to do when they were beautiful: or you may consider the complement of"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":"as suppressed; as though he said, when we did all that, we behaved with mutual familiarity, or the like; for the complements of"},{"kind":"arabic","text_bw":"lawo","text_ar":"لَوْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hiyna","text_ar":"حِينَ"},{"kind":"text","text":"may be suppressed, and their vagueness by reason of their suppression is more forcible in respect of the meaning:"},{"kind":"arabic","text_bw":"A^ano tataqan~aEaA","text_ar":"اَنْ تَتَقَنَّعَا"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"mino A^ano tataqan~aEaA","text_ar":"مِنْ اَنْ تَتَقَنَّعَا"},{"kind":"text","text":"; for they often suppress the preposition with"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":": (Ham pp. 552-3:) [J gives two readings of this verse, accord to one of my copies of the S: one is with"},{"kind":"arabic","text_bw":"tanaAzaEaA","text_ar":"تَنَازَعَا"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"taqaAwaDonaA","text_ar":"تَقَاوَضْنَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^a$oraqato","text_ar":"اَشْرَقَتْ"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"A^asofarato","text_ar":"اَسْفَرَتْ"},{"kind":"text","text":"; which make no difference in the meaning: but this is omitted in my other copy: the other is as follows:]"},{"kind":"quote","text":"falam~aA tawaAfaqonaA sal~amotu A^aqobalato\n                      \n                     \n                        wujuwhN zahaAhaA AlHusonu A^ano tataqan~aEaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And when we agreed together, and I saluted, faces advanced, which beauty excited"},{"kind":"text","text":"&c, or the possessors of which"},{"kind":"italic_en","text":"beauty excited"},{"kind":"text","text":"&c.]. (S.) And hence their saying,"},{"kind":"arabic","text_bw":"bixadiyEapK","text_ar":"بِخَدِيعَةٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fulaAnN laA yuzodahaY","text_ar":"فُلَانٌ لَا يُزْدَهَى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one will not be incited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited, to briskness,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"by means of deceit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guile"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"AlfaraHu","text_ar":"الفَرَحُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AzdhAhu","text_ar":"ازدهاهُ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"Aisotaxaf~ahu","text_ar":"اِسْتَخَفَّهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Joy incited him,"},{"kind":"text","text":"&c.]. (MA.) [And hence, perhaps, may be derived most of the following significations.] ―         -b4-"},{"kind":"arabic","text_bw":"zahaA AlT~al~u Alnawora","text_ar":"زَهَا الطَّلُّ النَوْرَ"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Tl~","text_ar":"طلّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fine drizzling rain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"made the flowers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blossoms, to increase in beauty of aspect."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"zahaA Als~iraAja","text_ar":"زَهَا السِّرَاجَ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yzhwhu","text_ar":"يزهوهُ"},{"kind":"text","text":"[perhaps a mistranscription for"},{"kind":"arabic","text_bw":"yazohaAhu","text_ar":"يَزْهَاهُ"},{"kind":"text","text":"], inf. n."},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He made the"},{"kind":"arabic","text_bw":"srAj","text_ar":"سراج"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lamp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lighted wick,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to give a bright light."},{"kind":"text","text":"(K.) ―         -b6-"},{"kind":"arabic","text_bw":"zahawotu AlA_ibila","text_ar":"زَهَوْتُ الاـِبِلَ"},{"kind":"page_break","n":1265},{"kind":"italic_en","text":"I made the camels to journey, after coming to water,"},{"kind":"text","text":"(A 'Obeyd, JK, S, K,)"},{"kind":"italic_en","text":"a night"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more,"},{"kind":"text","text":"(A 'Obeyd, JK, S,) or"},{"kind":"italic_en","text":"a night"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two nights."},{"kind":"text","text":"(K.) Thus the verb in relation to camels is trans. as well as intrans. (S.) ―         -b7-"},{"kind":"arabic","text_bw":"zahaA biAls~ayofu","text_ar":"زَهَا بِالسَّيْفُ"},{"kind":"italic_en","text":"He made a sign with the sword by waving it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brandishing it."},{"kind":"text","text":"(K, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"zahaA biAlEaSaA","text_ar":"زَهَا بِالعَصَا"},{"kind":"italic_en","text":"He struck with the staff,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick."},{"kind":"text","text":"(K.) ―         -b9-"},{"kind":"arabic","text_bw":"zahaA bimiAy^api riTolK","text_ar":"زَهَا بِمِايَةِ رِطْلٍ"},{"kind":"italic_en","text":"He computed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"computed by conjecture,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to be of the weight of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a hundred pounds."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"zahaAhu bimiAy^api riTolK","text_ar":"زَهَاهُ بِمِايَةِ رِطْلٍ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"xrzh","text_ar":"خرزه"},{"kind":"text","text":"[a mistake for"},{"kind":"arabic","text_bw":"Hazarahu","text_ar":"حَزَرَهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"He computed it,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to be of the weight of a hundred pounds"},{"kind":"text","text":"]. (TK. In the TA,"},{"kind":"arabic","text_bw":"zhA flAn","text_ar":"زها فلان"},{"kind":"arabic","text_bw":"bmAy^p rTl","text_ar":"بماية رطل"},{"kind":"text","text":", ["},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"or the like being omitted by an oversight,] aor."},{"kind":"arabic","text_bw":"yazohaAhu","text_ar":"يَزْهَاهُ"},{"kind":"text","text":"[which indicates an omission after"},{"kind":"arabic","text_bw":"flAn","text_ar":"فلان"},{"kind":"text","text":"].) And"},{"kind":"arabic","text_bw":"zahawotu Alqawoma","text_ar":"زَهَوْتُ القَوْمَ"},{"kind":"italic_en","text":"I computed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"computed by conjecture, the number of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(JK.)       -A3-"},{"kind":"arabic","text_bw":"zuhiYa","text_ar":"زُهِىَ"},{"kind":"text","text":", (JK, S, K,) like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":"; (S, K;) and"},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"text","text":", (IDrd, S, K,) like"},{"kind":"arabic","text_bw":"daEaA","text_ar":"دَعَا"},{"kind":"text","text":", but this is rare, (K,) and was dissallowed by As in the sense of"},{"kind":"arabic","text_bw":"zuhiYa","text_ar":"زُهِىَ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"nxw","text_ar":"نخو"},{"kind":"text","text":",) aor."},{"kind":"arabic","text_bw":"yazohuw","text_ar":"يَزْهُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zahowN","text_ar":"زَهْوٌ"},{"kind":"text","text":"; (IDrd, S;) and ↓"},{"kind":"arabic","text_bw":"A^azohaY","text_ar":"اَزْهَى","orth_type":"arrow"},{"kind":"text","text":"; (K;) said of a man, (JK, S,)"},{"kind":"italic_en","text":"He behaved proudly, haughtily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insolently;"},{"kind":"text","text":"(S, K, * TA;)"},{"kind":"italic_en","text":"he was proud, vain,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"boastful;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"was pleased with himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self-conceited:"},{"kind":"text","text":"(JK:)"},{"kind":"arabic","text_bw":"AzdhY","text_ar":"ازدهى"},{"kind":"text","text":"[i. e. ↓"},{"kind":"arabic","text_bw":"AuzoduhiYa","text_ar":"اُزْدُهِىَ","orth_type":"arrow"},{"kind":"text","text":"], in like manner, means"},{"kind":"arabic","text_bw":"takab~ara","text_ar":"تَكَبَّرَ"},{"kind":"text","text":": (Har p. 264: [but this more properly signifies, as shown above by an explanation of"},{"kind":"arabic","text_bw":"AizodahaAhu","text_ar":"اِزْدَهَاهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he was incited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited, to lightness, levity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsteadiness:"},{"kind":"text","text":"]) the first of these verbs [may be originally pass. of"},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"zahaAhu Alkiboru","text_ar":"زَهَاهُ الكِبْرُ"},{"kind":"text","text":", mentioned before, but, as J says,] is one of a class of verbs used in the pass. form though having the sense of the act. form: in using it imperatively, you say,"},{"kind":"arabic","text_bw":"lituzoha yaA rajulu","text_ar":"لِتُزْهَ يَا رَجُلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Behave thou proudly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"O man;"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"]; and like this is the aor. [used as an imperative] of every verb of which the agent is not named; for when it is reduced to its essential import, you thereby command something, other than the person whom you address, to affect, or befall, that person; and the third person of the [aor. used as an] imperative is never without"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":", as when you say,"},{"kind":"arabic","text_bw":"liyaqumo zayodN","text_ar":"لِيَقُمْ زَيْدٌ"},{"kind":"text","text":": (S, TA:) J also says, (TA,) I said to an Arab of the desert, of [the tribe of] Benoo-Suleym, What is the meaning of"},{"kind":"arabic","text_bw":"zuhiYa Alr~ajulu","text_ar":"زُهِىَ الرَّجُلُ"},{"kind":"text","text":"? and he answered,"},{"kind":"italic_en","text":"The man was pleased with himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"self-conceited:"},{"kind":"text","text":"I said, Dost thou say,"},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"Aifotaxara","text_ar":"اِفْتَخَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted,"},{"kind":"text","text":"&c.]? and he answered, As for us, we do not say it. (S, TA.) One says also,"},{"kind":"arabic","text_bw":"zuhiYa fulaAnN","text_ar":"زُهِىَ فُلَانٌ"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"nuxiYa","text_ar":"نُخِىَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"magnified himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved proudly, by reason of such a thing"},{"kind":"text","text":"]; as though meaning"},{"kind":"arabic","text_bw":"zahaAhu","text_ar":"زَهَاهُ"},{"kind":"arabic","text_bw":"AlA_iEojaAbu binafosihi","text_ar":"الاـِعْجَابُ بِنَفْسِهِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"self-conceit elevated him"},{"kind":"text","text":"by reason of such a thing]. (Har p. 171.) ―         -b2-  And one says,"},{"kind":"arabic","text_bw":"zuhiYa Al$~aYo'u biEayonayoka","text_ar":"زُهِىَ الشَّىْءُ بِعَيْنَيْكَ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"liEayonayoka","text_ar":"لِعَيْنَيْكَ"},{"kind":"italic_en","text":"The thing was beautiful in aspect in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to, thine eyes."},{"kind":"text","text":"(S, accord. to different copies. [The meaning is there shown by what immediately precedes. In three copies of the S, I find the verb in this phrase thus written,"},{"kind":"arabic","text_bw":"zuhiYa","text_ar":"زُهِىَ"},{"kind":"text","text":"; and only in the PS,"},{"kind":"arabic","text_bw":"zhA","text_ar":"زها"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"zahaA","text_ar":"زَهَا"},{"kind":"text","text":", which is the form given by Golius: Freytag writes the phrase"},{"kind":"arabic","text_bw":"zahaY Al$Y bEynk","text_ar":"زَهَى الشى بعينك"},{"kind":"text","text":".])"}],"source_refs":["JK","TA","Msb","S","K","Mgh","M","IDrd"]}]},"classical_definitions":null}