_url":"https://lanelexicon.com/?s=%D8%B5%D8%A7%D8%A8%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bear stoutly"},{"pos":"adj","gloss":"patient"},{"pos":"adj","gloss":"suffering, enduring, forbearing"},{"pos":"adj","gloss":"steadfast"},{"pos":"name","gloss":"a male given name, Sabir"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of صَبَرَ (ṣabara, “to be patient, to endure”)."},"ipa":["/sˤaː.ba.ra/","/sˤaː.bir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23692","headword_ar":"صَابِرٌ","root":"Sbr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SabuwrN","text_ar":"صَبُورٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) the latter of which is also applied to a female, without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", (M,) and ↓"},{"kind":"arabic","text_bw":"SabiyrN","text_ar":"صَبِيرٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"Sab~aArN","text_ar":"صَبَّارٌ","orth_type":"arrow"},{"kind":"text","text":", (M,) are epithets from"},{"kind":"arabic","text_bw":"Sabara","text_ar":"صَبَرَ"},{"kind":"text","text":"“ he was patient, or enduring: ” (M, K:) the five following epithets are said to denote different degrees of patience:"},{"kind":"arabic","text_bw":"SaAbirN","text_ar":"صَابِرٌ"},{"kind":"text","text":"is the most general of them [in signification, meaning simply"},{"kind":"italic_en","text":"Patient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enduring"},{"kind":"text","text":"]: ↓"},{"kind":"arabic","text_bw":"muSoTabirN","text_ar":"مُصْطَبِرٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"acquiring patience;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"tried with patience:"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mutaSab~irN","text_ar":"مُتَصَبِّرٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"constraining himself to be patient:"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SabuwrN","text_ar":"صَبُورٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"having great patience;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"very patient;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"whose patience is greater than that of others;"},{"kind":"text","text":"[as also ↓"},{"kind":"arabic","text_bw":"SabiyrN","text_ar":"صَبِيرٌ","orth_type":"arrow"},{"kind":"text","text":"; or this signifies"},{"kind":"italic_en","text":"rendered patient,"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Sabarahu","text_ar":"صَبَرَهُ"},{"kind":"text","text":";] denoting quality, or manner: and ↓"},{"kind":"arabic","text_bw":"Sab~aArN","text_ar":"صَبَّارٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"having an intense degree of patience;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"having very great patience;"},{"kind":"text","text":"] denoting measure, and quantity: the pl. of ↓"},{"kind":"arabic","text_bw":"SabuwrN","text_ar":"صَبُورٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"SuburN","text_ar":"صُبُرٌ"},{"kind":"text","text":". (TA.) As an epithet applied to God, (Aboo-Is-hák [i. e. Zj],) ↓"},{"kind":"arabic","text_bw":"AlS~abuwru","text_ar":"الصَّبُورُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The Clement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Forbearing, who does not hastily avenge Himself upon the disobedient, but forgives,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defers:"},{"kind":"text","text":"(Aboo-Is-hák, K:) [it may be well rendered"},{"kind":"italic_en","text":"The Long-suffering:"},{"kind":"text","text":"] it is an intensive epithet. (TA.) One says also,"},{"kind":"arabic","text_bw":"huwa SaAbirN","text_ar":"هُوَ صَابِرٌ"},{"kind":"arabic","text_bw":"EalaY Albarodi","text_ar":"عَلَى البَرْدِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is a patient endurer of cold"},{"kind":"text","text":"]. (A.)"}],"source_refs":["M","K"]}]},"classical_definitions":null}