"in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدْخَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدْخُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدْخُلا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدْخَلُوا","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدْخَلُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْخُلُونَ","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْخُلُوا","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدْخَلْنَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَدْخُلْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُدْخَل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدْخَل","in_corpus":true,"count":104,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَدْخُل","in_corpus":true,"count":104,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدْخُل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"دَخَلْنا","in_corpus":true,"count":13,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَخَلْتُ","in_corpus":true,"count":144,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1955,"cross_references":{"qac":{"found":true,"lemma_key":"دَخَلَ","root":"دخل","pos":"V","occurrence_count":76},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":22},"lanes":{"found":true,"entry_ids":["n12246"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%AE%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to enter, go in, come in"},{"pos":"verb","gloss":"to penetrate, to pierce"},{"pos":"verb","gloss":"to befall, to seize, to come over (someone) (e.g. of a doubt, joy, etc.)"},{"pos":"verb","gloss":"to take up (a profession, etc.), to start"},{"pos":"verb","gloss":"to drop in on, to come to see, to call on, to visit"},{"pos":"verb","gloss":"to consummate a marriage, to cohabit, to sleep","examples":[{"text":"[…] مِنْ نِسَائِكُمُ اللَّاتِي دَخَلْتُمْ بِهِنَّ فَإِنْ لَمْ تَكُونُوا دَخَلْتُمْ بِهِنَّ فَلَا جُنَاحَ عَلَيْكُمْ […]","english":"[born] of the wives whom you have gone into—but if you have not gone into them there is no sin upon you"}]},{"pos":"verb","gloss":"to acquire"},{"pos":"verb","gloss":"to join, to convert to","examples":[{"text":"وَرَأَيْتَ ٱلنَّاسَ يَدْخُلُونَ فِي دِينِ ٱللّٰهِ أَفْوَاجًا","english":"and you see the people entering God's religion in throngs"}]},{"pos":"verb","gloss":"to participate in (something)"},{"pos":"verb","gloss":"to belong to, to pertain to, to be included among"},{"pos":"verb","gloss":"to be newly introduced [with عَلَى (ʕalā) ‘into something’] (e.g. of a factor, aspect, element, etc.)"},{"pos":"verb","gloss":"to be prefixed"},{"pos":"verb","gloss":"to begin (of an event or occurrence)"},{"pos":"verb","gloss":"to be diseased, to be abnormal"},{"pos":"verb","gloss":"to make enter, to bring in, to let in"},{"pos":"verb","gloss":"to enter, to insert, to include"},{"pos":"noun","gloss":"income"},{"pos":"noun","gloss":"revenues, receipts, returns"},{"pos":"noun","gloss":"interference, intervention"},{"pos":"noun","gloss":"doubt, misgiving"},{"pos":"noun","gloss":"disturbance, imbalance, derangement, disorder, mental defect"},{"pos":"noun","gloss":"defect, infirmity"}]},"etymology":null,"ipa":["/da.xa.la/","/dax.xa.la/","/daxl/","/da.xal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12246","headword_ar":"دَخَلَ","root":"dxl","body":[{"kind":"text","text":", (S, K, &c.,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"duxuwlN","text_ar":"دُخُولٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"madoxalN","text_ar":"مَدْخَلٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, entered;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, came, passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, in; contr. of"},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"text","text":"; (K;) as also ↓"},{"kind":"arabic","text_bw":"Aid~axala","text_ar":"اِدَّخَلَ","orth_type":"arrow"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"AifotaEala","text_ar":"اِفْتَعَلَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Andxl","text_ar":"اندخل","orth_type":"arrow"},{"kind":"text","text":", (S, K,) this last occuring in poetry, but not chaste, (S,) and ↓"},{"kind":"arabic","text_bw":"tdx~l","text_ar":"تدخّل","orth_type":"arrow"},{"kind":"text","text":", (K,) or this signifies"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"entered by little and little."},{"kind":"text","text":"(S, O.) You say,"},{"kind":"arabic","text_bw":"daxalotu madoxalFA HasanFA","text_ar":"دَخَلْتُ مَدْخَلًا حَسَنًا"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"duxuwlFA HasanFA","text_ar":"دُخُولًا حَسَنًا"},{"kind":"italic_en","text":"I entered with a good entering"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"daxalotu Albayota","text_ar":"دَخَلْتُ البَيْتَ"},{"kind":"text","text":"(S) or"},{"kind":"arabic","text_bw":"Ald~aAra","text_ar":"الدَّارَ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"I entered the house,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"I became within the house,"},{"kind":"text","text":"and the like, (Msb,) correctly meaning"},{"kind":"arabic","text_bw":"A_ilaY Albayoti","text_ar":"اـِلَى البَيْتِ"},{"kind":"text","text":"[&c., or"},{"kind":"arabic","text_bw":"fiY Albayoti","text_ar":"فِى البَيْتِ"},{"kind":"text","text":"&c., i. e."},{"kind":"italic_en","text":"I entered into the house,"},{"kind":"text","text":"&c.], the prep. being suppressed, and the noun put in the accus. case after the manner of an objective complement: for nouns of place are of two kinds, vague and definite; the vague being such as the six relative locations,"},{"kind":"arabic","text_bw":"xalofN","text_ar":"خَلْفٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qud~aAmN","text_ar":"قُدَّامٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"yamiynN","text_ar":"يَمِينٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"$imaAlN","text_ar":"شِمَالٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fawoqN","text_ar":"فَوْقٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"taHotN","text_ar":"تَحْتٌ"},{"kind":"text","text":", and the like, such as"},{"kind":"arabic","text_bw":"A^amaAmN","text_ar":"اَمَامٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"waraA='N","text_ar":"وَرَا=ءٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^aEolaY","text_ar":"اَعْلَى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^asofalu","text_ar":"اَسْفَلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Einoda","text_ar":"عِنْدَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"laduno","text_ar":"لَدُنْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"wasoTN","text_ar":"وَسْطٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"bayonN","text_ar":"بَيْنٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qubaAlapN","text_ar":"قُبَالَةٌ"},{"kind":"text","text":", all which, and similar nouns of place, may become adverbs, because indefinite; for dost thou not see that what is"},{"kind":"arabic","text_bw":"xalof","text_ar":"خَلْف"},{"kind":"text","text":"to thee may be"},{"kind":"arabic","text_bw":"qud~aAm","text_ar":"قُدَّام"},{"kind":"text","text":"to another? but that which is definite, having make, and corporeal substance, and tracts that comprehend it, as a mountain and a valley and a market and a house and a mosque, the noun signifying such a thing cannot become an adverb; for you may not say,"},{"kind":"arabic","text_bw":"qaEadotu Ald~aAra","text_ar":"قَعَدْتُ الدَّارَ"},{"kind":"text","text":", nor"},{"kind":"arabic","text_bw":"Sal~ayotu Almasojida","text_ar":"صَلَّيْتُ المَسْجِدَ"},{"kind":"text","text":", nor"},{"kind":"arabic","text_bw":"nimotu Aljabala","text_ar":"نِمْتُ الجَبَلَ"},{"kind":"text","text":", nor"},{"kind":"arabic","text_bw":"qumotu AlwaAdiYa","text_ar":"قُمْتُ الوَادِىَ"},{"kind":"text","text":"; the phrases of this kind that occur being instances of the suppression of a prep.; as"},{"kind":"arabic","text_bw":"daxalotu Albayota","text_ar":"دَخَلْتُ البَيْتَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"nazalotu AlwaAdiYa","text_ar":"نَزَلْتُ الوَادِىَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"SaEidotu Aljabala","text_ar":"صَعِدْتُ الجَبَلَ"},{"kind":"text","text":". (S, O, TA.) You say also,"},{"kind":"arabic","text_bw":"daxalotu EalaY zayodK Ald~aAra","text_ar":"دَخَلْتُ عَلَى زَيْدٍ الدَّارَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I entered the house after Zeyd, he being in it."},{"kind":"text","text":"(Msb.) [And simply"},{"kind":"arabic","text_bw":"daxala Ealayohi","text_ar":"دَخَلَ عَلَيْهِ"},{"kind":"italic_en","text":"He came in upon him:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"he came upon him;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"invaded him."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"daxala biA@moraA^atihi","text_ar":"دَخَلَ بِا@مْرَاَتِهِ"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"text","text":", (MA,) inf. n."},{"kind":"arabic","text_bw":"duxuwlN","text_ar":"دُخُولٌ"},{"kind":"text","text":", (Mgh, Msb,) [like"},{"kind":"arabic","text_bw":"daxala biA^aholihi","text_ar":"دَخَلَ بِاَهْلِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EalayohaA","text_ar":"عَلَيْهَا"},{"kind":"text","text":", (see"},{"kind":"arabic","text_bw":"A^aholN","text_ar":"اَهْلٌ"},{"kind":"text","text":",) i. e. (tropical:)"},{"kind":"italic_en","text":"He went in to his wife"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"woman,"},{"kind":"text","text":"] is a metonymical phrase, denoting"},{"kind":"arabic","text_bw":"AljimaAE","text_ar":"الجِمَاع"},{"kind":"text","text":", (Msb, TA,) i. e."},{"kind":"arabic","text_bw":"AlwaTo'","text_ar":"الوَطْء"},{"kind":"text","text":", (Mgh, Msb, TA,) whether it be such as is allowed by the law or such as is forbidden, (Mgh,) generally such as is lawful. (Msb, TA. [See what is said in explanation of the term"},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"text","text":"in the first paragraph of art."},{"kind":"arabic","text_bw":"xlw","text_ar":"خلو"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"daxala baEoDuhu fiY","text_ar":"دَخَلَ بَعْضُهُ فِى"},{"kind":"arabic","text_bw":"baEoDK","text_ar":"بَعْضٍ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"tadaAxala","text_ar":"تَدَاخَلَ"},{"kind":"text","text":"[q. v.]. (TA in art."},{"kind":"arabic","text_bw":"qSr","text_ar":"قصر"},{"kind":"text","text":", &c.) [For ex.,] you say,"},{"kind":"arabic","text_bw":"daxala baEoDu Aln~ujuwmi fiY baEoDK","text_ar":"دَخَلَ بَعْضُ النُّجُومِ فِى بَعْضٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The stars became confused together"},{"kind":"text","text":"]. (Mgh and TA in art."},{"kind":"arabic","text_bw":"$bk","text_ar":"شبك"},{"kind":"text","text":": in the former coupled with"},{"kind":"arabic","text_bw":"AixotalaTato","text_ar":"اِخْتَلَطَتْ"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"daxala fiyhimo","text_ar":"دَخَلَ فِيهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He entered among them, so as to become a member of their community, confraternity, party, sect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"] said of a stranger. (K.) [And"},{"kind":"arabic","text_bw":"daxala fiY TaAEatihi","text_ar":"دَخَلَ فِى طَاعَتِهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TaAy^iEN","text_ar":"طَايِعٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"TwE","text_ar":"طوع"},{"kind":"text","text":".] When"},{"kind":"arabic","text_bw":"daxala","text_ar":"دَخَلَ"},{"kind":"text","text":"is said of income, or revenue, [meaning"},{"kind":"italic_en","text":"It came in, accrued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was received,"},{"kind":"text","text":"] the aor. is as above, and the inf. n."},{"kind":"arabic","text_bw":"daxolN","text_ar":"دَخْلٌ"},{"kind":"text","text":": (Msb:) and you say,"},{"kind":"arabic","text_bw":"yadoxulu EalaY","text_ar":"يَدْخُلُ عَلَى"},{"kind":"arabic","text_bw":"AlA_inosaAni","text_ar":"الاـِنْسَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It comes in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accrues, to the man"},{"kind":"text","text":"]. (Msb, K. *)"},{"kind":"arabic","text_bw":"daxala bihi","text_ar":"دَخَلَ بِهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He entered with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]: see 4. ―         -b2-  [Hence,"},{"kind":"arabic","text_bw":"daxala fiyhi","text_ar":"دَخَلَ فِيهِ"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"It became included, comprehended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comprised, in it."},{"kind":"text","text":"And hence,]"},{"kind":"arabic","text_bw":"daxala fiY diyni AlA_isolaAmi","text_ar":"دَخَلَ فِى دِينِ الاـِسْلَامِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He entered within the pale of the religion of ElIslám; he entered the communion of that religion; he entered into, embraced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became a proselyte to, that religion"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"slm","text_ar":"سلم"},{"kind":"text","text":", &c. [See Kur cx. 2.]) And"},{"kind":"arabic","text_bw":"daxala fiY AlA^amori","text_ar":"دَخَلَ فِى الاَمْرِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"duxuwlN","text_ar":"دُخُولٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He entered upon, began,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, the affair."},{"kind":"text","text":"(Msb.) [And"},{"kind":"arabic","text_bw":"daxala fiY A^amori gayorihi","text_ar":"دَخَلَ فِى اَمْرِ غَيْرِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^umuwri gayorihi","text_ar":"اُمُورِ غَيْرِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tdx~l","text_ar":"تدخّل","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tdAxl","text_ar":"تداخل","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He entered into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixed himself in, another's affair,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"another's affairs."},{"kind":"text","text":"] ―         -b3-  [Hence also,"},{"kind":"arabic","text_bw":"daxala Ealayohi","text_ar":"دَخَلَ عَلَيْهِ"},{"kind":"text","text":"said of night, &c.,"},{"kind":"italic_en","text":"It came upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"invaded him."},{"kind":"text","text":"And said of a word, such as a prep. &c.,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prefixed to it, preposed to it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put before it."},{"kind":"text","text":"] ―         -b4-  ["},{"kind":"arabic","text_bw":"daxalaniY minohu","text_ar":"دَخَلَنِى مِنْهُ"},{"kind":"text","text":"seems (from an instance in art."},{"kind":"arabic","text_bw":"bDE","text_ar":"بضع"},{"kind":"text","text":"in the K) to mean (assumed tropical:)"},{"kind":"italic_en","text":"An evil opinion of him entered my mind;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"daxolN","text_ar":"دَخْلٌ"},{"kind":"text","text":"as signifying “ a thing that induces doubt, or suspicion, or evil opinion. ”]       -A2-"},{"kind":"arabic","text_bw":"duxila","text_ar":"دُخِلَ"},{"kind":"text","text":", (S, K,) like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"daxila","text_ar":"دَخِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; inf. n. [of the former]"},{"kind":"arabic","text_bw":"daxolN","text_ar":"دَخْلٌ"},{"kind":"text","text":"and [of the latter]"},{"kind":"arabic","text_bw":"daxalN","text_ar":"دَخَلٌ"},{"kind":"text","text":"; (K;) (assumed tropical:)"},{"kind":"italic_en","text":"He had an unsoundness"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"daxalN","text_ar":"دَخَلٌ"},{"kind":"text","text":", S, K, i. e."},{"kind":"arabic","text_bw":"fasaAdN","text_ar":"فَسَادٌ"},{"kind":"text","text":", K)"},{"kind":"italic_en","text":"in his intel-lect,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"in his body,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"in his grounds of pretension to respect."},{"kind":"text","text":"(TA in explanation of the former verb.) And"},{"kind":"arabic","text_bw":"daxila A^amoruhu","text_ar":"دَخِلَ اَمْرُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"daxalN","text_ar":"دَخَلٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"His affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, intrinsically bad"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"duxila AlT~aEaAmu","text_ar":"دُخِلَ الطَّعَامُ"},{"kind":"italic_en","text":"The corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"food, became eaten by worms"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(JK.) ―         -b3-"},{"kind":"arabic","text_bw":"duxila Ealayohi","text_ar":"دُخِلَ عَلَيْهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was led into a mistake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an error, respecting a thing, without knowing it, by his having preconceived it."},{"kind":"text","text":"(Msb.)"}],"source_refs":["TA","S","Msb","K","MA","Mgh"]}]}}