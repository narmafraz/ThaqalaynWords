":"f","num":"s"},{"role":"present_2md","form":"تَطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَطْبَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُطْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُطْبَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطْبَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُطْبَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطْبَع","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُطْبَع","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطْبَع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُطْبَع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطْبَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطْبَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْبَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُطْبَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طَبَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَبَعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَطْبَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْبَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُطْبَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطْبَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":true,"lemma_key":"طَبَعَ","root":"طبع","pos":"V","occurrence_count":11},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n26313"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%A8%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to print, imprint, stamp"},{"pos":"verb","gloss":"to type"},{"pos":"verb","gloss":"to coin"},{"pos":"verb","gloss":"to train, to tame (an animal)"},{"pos":"verb","gloss":"to train, to teach (someone)"},{"pos":"verb","gloss":"to normalize (relations)","examples":[{"text":"طَبَّعَتِ الدَوْلَتانِ عَلاقَاتِهِمَا الدِبْلُوماسِيّة.","english":"The two countries normalized their diplomatic relations."}]},{"pos":"verb","gloss":"to embellish (fabric) when printing"},{"pos":"verb","gloss":"to defile"},{"pos":"noun","gloss":"verbal noun of طَبَعَ (ṭabaʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"printing, print"},{"pos":"noun","gloss":"nature"},{"pos":"noun","gloss":"characteristic"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26313","headword_ar":"طَبَعَ","root":"TbE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He sealed, stamped, imprinted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impressed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xatama","text_ar":"خَتَمَ"},{"kind":"text","text":": (Msb:) [and, as now used,"},{"kind":"italic_en","text":"he printed"},{"kind":"text","text":"a book or the like:]"},{"kind":"arabic","text_bw":"taboEN","text_ar":"تَبْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xatomN","text_ar":"خَتْمٌ"},{"kind":"text","text":"both signify the"},{"kind":"italic_en","text":"making an impression"},{"kind":"text","text":"in, or upon, clay and the like: (S, Mgh, O, K:) or, as Er-Rághib says, the"},{"kind":"italic_en","text":"impressing"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with the engraving of the signet and stamp:"},{"kind":"text","text":"(TA in this art. and in art."},{"kind":"arabic","text_bw":"xtm","text_ar":"ختم"},{"kind":"text","text":": [see more in the first paragraph of the latter art:]) and he says also that"},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"figuring"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with some particular figure;"},{"kind":"text","text":"as in the case of the"},{"kind":"arabic","text_bw":"TaboE","text_ar":"طَبْع"},{"kind":"text","text":"of the die for stamping coins, and the"},{"kind":"arabic","text_bw":"TaboE","text_ar":"طَبْع"},{"kind":"text","text":"of coins [themselves]: but that it is"},{"kind":"italic_en","text":"more general in signification than"},{"kind":"arabic","text_bw":"xatomN","text_ar":"خَتْمٌ"},{"kind":"text","text":", and"},{"kind":"italic_en","text":"more particular than"},{"kind":"arabic","text_bw":"naqo$N","text_ar":"نَقْشٌ"},{"kind":"text","text":"; as will be shown by what follows: accord. to Aboo-Is-hák the Grammarian,"},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xatomN","text_ar":"خَتْمٌ"},{"kind":"text","text":"both signify the"},{"kind":"italic_en","text":"covering over"},{"kind":"text","text":"a thing,"},{"kind":"italic_en","text":"and securing oneself from a thing's entering"},{"kind":"text","text":"it: and IAth says [in like manner] that they held"},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":"to be"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"rayonN","text_ar":"رَيْنٌ"},{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"raAna","text_ar":"رَانَ"},{"kind":"text","text":"]: but Mujáhid says that"},{"kind":"arabic","text_bw":"rayonN","text_ar":"رَيْنٌ"},{"kind":"text","text":"denotes less than"},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":", less than"},{"kind":"arabic","text_bw":"A_iqofaAlN","text_ar":"اـِقْفَالٌ"},{"kind":"text","text":"[or the “ closing with a lock: ” this he says with reference to a phrase in the Kur xlvii. 26]. (TA.) You say,"},{"kind":"arabic","text_bw":"TabaEa AlkitaAba","text_ar":"طَبَعَ الكِتَابَ"},{"kind":"text","text":", (Mgh, Msb,) and"},{"kind":"arabic","text_bw":"TabaEa EalaY","text_ar":"طَبَعَ عَلَى"},{"kind":"arabic","text_bw":"AlkitaAbi","text_ar":"الكِتَابِ"},{"kind":"text","text":", (S, Mgh, Msb, K, *)"},{"kind":"italic_en","text":"He sealed"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xatama","text_ar":"خَتَمَ"},{"kind":"text","text":", S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"the writing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"letter."},{"kind":"text","text":"(S, Mgh, Msb.) And"},{"kind":"arabic","text_bw":"TabaEa","text_ar":"طَبَعَ"},{"kind":"italic_en","text":"He branded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise marked, the sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat."},{"kind":"text","text":"(O. [See"},{"kind":"arabic","text_bw":"TaAbaEN","text_ar":"طَابَعٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"TabaEa A@ll~`hu EalaY qalobihi","text_ar":"طَبَعَ ا@للّٰهُ عَلَى قَلْبِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"God sealed"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"set a seal upon"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his"},{"kind":"text","text":"[i. e. an unbeliever's]"},{"kind":"italic_en","text":"heart, so that he should not heed admonition, nor be disposed to that which is good;"},{"kind":"text","text":"(Mgh;) or"},{"kind":"italic_en","text":"so that belief should not enter it:"},{"kind":"text","text":"(O:) [and in like manner,"},{"kind":"arabic","text_bw":"xatama Ealayohi","text_ar":"خَتَمَ عَلَيْهِ"},{"kind":"text","text":", q. v.:] in this, regard is had to the"},{"kind":"arabic","text_bw":"TaboE","text_ar":"طَبْع"},{"kind":"text","text":", and the"},{"kind":"arabic","text_bw":"TabiyEap","text_ar":"طَبِيعَة"},{"kind":"text","text":", which is the natural constitution or disposition; for it denotes the characterizing of the soul with some particular quality or qualities, either by creation or by habit, and more especially by creation. (Er-Rághib, TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He began to make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manufacture,"},{"kind":"text","text":"a thing: and"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"[a thing] as in instances here following. (Mgh.) You say,"},{"kind":"arabic","text_bw":"TabaEa mina AlT~iyni","text_ar":"طَبَعَ مِنَ الطِّينِ"},{"kind":"arabic","text_bw":"jar~apF","text_ar":"جَرَّةً"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fashioned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moulded,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the clay, a jar."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"TabaEa All~abina","text_ar":"طَبَعَ اللَّبِنَ"},{"kind":"text","text":", (Mgh, TA,) and"},{"kind":"arabic","text_bw":"Als~ayofa","text_ar":"السَّيْفَ"},{"kind":"text","text":", (S, Mgh, O, K,) and"},{"kind":"arabic","text_bw":"Ald~irohamu","text_ar":"الدِّرْهَمُ"},{"kind":"text","text":", (S, O, K,)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"(S, Mgh, O, K) ["},{"kind":"italic_en","text":"the crude bricks,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the sword,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the dirhem"},{"kind":"text","text":"]: or"},{"kind":"arabic","text_bw":"TabaEa","text_ar":"طَبَعَ"},{"kind":"arabic","text_bw":"Ald~araAhima","text_ar":"الدَّرَاهِمَ"},{"kind":"italic_en","text":"he struck"},{"kind":"text","text":"(Mgh, Msb)"},{"kind":"italic_en","text":"with the die"},{"kind":"text","text":"(Msb) [i. e."},{"kind":"italic_en","text":"coined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"minted,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the dirhems,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"money."},{"kind":"text","text":"(Mgh, Msb.) And [hence] one says,"},{"kind":"arabic","text_bw":"Tabaqahu A@ll~`hu","text_ar":"طَبَقَهُ ا@للّٰهُ"},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"text","text":", aor. and inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"God created him with an adaptation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disposition, to the thing, affair, state, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adapted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposed him, by creation,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"nature"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"thereto."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"TubiEa EalaY Al$~aYo'i","text_ar":"طُبِعَ عَلَى الشَّىْءِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, O, TA)"},{"kind":"italic_en","text":"was created with an adaptation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disposition, to the thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was adapted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposed, by creation"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"nature"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"thereto;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jubila","text_ar":"جُبِلَ"},{"kind":"text","text":", (IDrd, O, K, TA,) or"},{"kind":"arabic","text_bw":"fuTira","text_ar":"فُطِرَ"},{"kind":"text","text":". (Lh, TA.) ―         -b3-  Also, (aor. as above, TA, and so the inf. n., O, TA,)"},{"kind":"italic_en","text":"He filled"},{"kind":"text","text":"(Er-Rághib, O, K, TA) a measure for corn or the like, (Er-Rághib, TA,) or a leathern bucket, (O, K, TA,) and a skin, (O, TA,) &c.; (O;) and so ↓"},{"kind":"arabic","text_bw":"Tb~E","text_ar":"طبّع","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"taTobiyEN","text_ar":"تَطْبِيعٌ"},{"kind":"text","text":": (S, O:) because the quantity that fills it is a sign that prevents the taking a portion of what is in it [without the act's being discovered]. (Er-Rághib, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"TabaEa qafaAhu","text_ar":"طَبَعَ قَفَاهُ"},{"kind":"text","text":", (IAar, O, K,) inf. n. as above, (IAar, O,)"},{"kind":"italic_en","text":"He struck the back of his neck with his hand;"},{"kind":"text","text":"(IAar, O, K;) i. e. the back of the neck of a boy: if with the ends of the fingers, one says,"},{"kind":"arabic","text_bw":"qa*~a qafaAhu","text_ar":"قَذَّ قَفَاهُ"},{"kind":"text","text":". (IAar, O.) ―         -b5-"},{"kind":"arabic","text_bw":"maA A^adoriY mino A^ayona TabaEa","text_ar":"مَا اَدْرِى مِنْ اَيْنَ طَبَعَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I know not whence he came forth;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TalaEa","text_ar":"طَلَعَ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"TabiEa","text_ar":"طَبِعَ"},{"kind":"text","text":", (aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"TabaEN","text_ar":"طَبَعٌ"},{"kind":"text","text":", said of a sword,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rusty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overspread with rust:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"very rusty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overspread with much rust."},{"kind":"text","text":"(K, TA: from an explanation of the aor.: but this is written in the CK and in my MS. copy of the K, and in the O,"},{"kind":"arabic","text_bw":"yuTobaEu","text_ar":"يُطْبَعُ"},{"kind":"text","text":". [An explanation of"},{"kind":"arabic","text_bw":"TabaEN","text_ar":"طَبَعٌ"},{"kind":"text","text":"in the O and K confirms the reading"},{"kind":"arabic","text_bw":"yaTobaEu","text_ar":"يَطْبَعُ"},{"kind":"text","text":"; and another confirmation thereof will be found in what follows in this paragraph.]) ―         -b2-  Said of a thing, (Msb,) or of a garment, or piece of cloth, (TA,) inf. n."},{"kind":"arabic","text_bw":"TabaEN","text_ar":"طَبَعٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dirty;"},{"kind":"text","text":"(Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"tT~bE","text_ar":"تطّبع","orth_type":"arrow"},{"kind":"text","text":"is likewise said [in the same sense] of a garment, or piece of cloth. (M and TA voce"},{"kind":"arabic","text_bw":"raAna","text_ar":"رَانَ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"ryn","text_ar":"رين"},{"kind":"text","text":".) ―         -b3-  Said of a man, (assumed tropical:)"},{"kind":"italic_en","text":"He was"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, filthy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in character"},{"kind":"text","text":"]. (S.) And (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sluggish, lazy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indolent."},{"kind":"text","text":"(S.) One says of a man,"},{"kind":"arabic","text_bw":"yaTobaEu","text_ar":"يَطْبَعُ"},{"kind":"text","text":", (O, K,) like"},{"kind":"arabic","text_bw":"yaforaHu","text_ar":"يَفْرَحُ"},{"kind":"text","text":", (K,) meaning (assumed tropical:)"},{"kind":"italic_en","text":"He has no penetrative energy, sharpness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effectiveness, in the affairs that are the means,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"causes, of attaining honour, like the sword that is overspread with much rust."},{"kind":"text","text":"(O, K.)       -A3-"},{"kind":"arabic","text_bw":"TubiEa","text_ar":"طُبِعَ"},{"kind":"text","text":", (O, K,) inf. n."},{"kind":"arabic","text_bw":"TaboEN","text_ar":"طَبْعٌ"},{"kind":"text","text":", (O,) said of a man, (assumed tropical:)"},{"kind":"italic_en","text":"He was rendered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pronounced"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"filthy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in character"},{"kind":"text","text":"]; (O, K;) on the authority of Sh; (O;) and so"},{"kind":"arabic","text_bw":"TabiEa","text_ar":"طَبِعَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"fariHa","text_ar":"فَرِحَ"},{"kind":"text","text":"; (TA as on the authority of Sh; [but this I think doubtful;])"},{"kind":"italic_en","text":"and disgraced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishonoured:"},{"kind":"text","text":"(K:) and ↓"},{"kind":"arabic","text_bw":"Tub~iEa","text_ar":"طُبِّعَ","orth_type":"arrow"},{"kind":"text","text":", (O, TA,) inf. n."},{"kind":"arabic","text_bw":"taTobiyEN","text_ar":"تَطْبِيعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"he was rendered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pronounced"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"filthy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in character"},{"kind":"text","text":"], (O, TA,)"},{"kind":"italic_en","text":"and blamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discommended."},{"kind":"text","text":"(O.)"}],"source_refs":["Msb","S","Mgh","O","K","TA","IDrd","IAar"]}]}}