:"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعْوِزُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعْوِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعْوِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعْوِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعْوِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْوِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعْوِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْوِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعْوِزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعْوِزُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعْوِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُعْوِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْوِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَعْوَزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَعْوَزْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n30998",""],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D9%88%D9%8E%D8%B2%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30998","headword_ar":"اعوز","root":"Ewz","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iEowaAzN","text_ar":"اـِعْوَازٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Eawiza","text_ar":"عَوِزَ"},{"kind":"text","text":", in three places.       -A2-"},{"kind":"arabic","text_bw":"AEwzhu Ald~ahoru","text_ar":"اعوزهُ الدَّهْرُ"},{"kind":"italic_en","text":"Fortune caused him to became in want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"need;"},{"kind":"text","text":"(S, O, K;) or"},{"kind":"italic_en","text":"rendered him poor;"},{"kind":"text","text":"(A, Msb;) [i. e.,]"},{"kind":"italic_en","text":"poverty befell him."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"AEwzhu Al$~aYo'u","text_ar":"اعوزهُ الشَّىْءُ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"The thing caused him to want;"},{"kind":"text","text":"meaning]"},{"kind":"italic_en","text":"he wanted, needed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"required, the thing,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"had it not,"},{"kind":"text","text":"] (S, O, K,)"},{"kind":"italic_en","text":"and was unable to attain it:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"the thing escaped him, so that he was unable to attain it,"},{"kind":"text","text":"(M, Mgh, Msb,)"},{"kind":"italic_en","text":"it being much wanted by him;"},{"kind":"text","text":"(M, TA;) as also"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaAzahu","text_ar":"عَازَهُ","orth_type":"arrow"},{"kind":"text","text":": (M, TA:) or the latter, [virtually, like"},{"kind":"arabic","text_bw":"EaAza Al$~aYo'a","text_ar":"عَازَ الشَّىْءَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"he found not the thing:"},{"kind":"text","text":"(O, K, TA:) but Az says that this latter phrase is not known. (O, TA.) ―         -b3-"},{"kind":"italic_en","text":"The thing was little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scarce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in his estimation, and needful to him."},{"kind":"text","text":"(Mgh, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"AEwzhu AlA^amoru","text_ar":"اعوزهُ الاَمْرُ"},{"kind":"italic_en","text":"The affair was hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult, to him."},{"kind":"text","text":"(A, TA.) So in the saying,"},{"kind":"arabic","text_bw":"masoA^alapN yaxotalifu fiyhaA kibaAru","text_ar":"مَسْاَلَةٌ يَخْتَلِفُ فِيهَا كِبَارُ"},{"kind":"arabic","text_bw":"AlS~aHaAbapi yuEowizu fiqohuhaA","text_ar":"الصَّحَابَةِ يُعْوِزُ فِقْهُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A question respecting which the great men of the Companions differ;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the knowledge whereof is difficult."},{"kind":"text","text":"(Mgh.)       -A3-  And one says,"},{"kind":"arabic","text_bw":"maA yuEowizu lifulaAnK $aYo'N A_il~aA *ahaba bihi","text_ar":"مَا يُعْوِزُ لِفُلَانٍ شَىْءٌ اـِلَّا ذَهَبَ بِهِ"},{"kind":"italic_en","text":"A thing does not come within sight of such a one but he takes it away:"},{"kind":"text","text":"(Ibn-Háni, O, K:) a saying disapproved by As, but held by AZ to be correct, [thus said by him with"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":", (TA,)] and heard from the Arabs. (O.) [See also"},{"kind":"arabic","text_bw":"A^aEowara","text_ar":"اَعْوَرَ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":".]"}],"source_refs":["S","O","K","M","Mgh","Msb","TA"]}]},"classical_definitions":null}