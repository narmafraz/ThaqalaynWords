{"lemma":"حُنْكَة","slug":"حُنْكَة","root":"ح.ن.ك","root_slug":"ح-ن-ك","root_link":"/words/roots/ح-ن-ك","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n9345","n9353"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D9%86%D9%92%D9%83%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"prudence, being seasoned, sophistication, resourcefulness, discretion, wisdom, acumen"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9345","headword_ar":"حنّكهُ","root":"Hnk","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHoniykN","text_ar":"تَحْنِيكٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He rubbed his"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"palate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft palate,"},{"kind":"text","text":"] (K, TA)"},{"kind":"italic_en","text":"so as to make it bleed:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he stuck a piece of wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick, into his"},{"kind":"text","text":"(a beast's)"},{"kind":"italic_en","text":"upper"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"the extremity of a horn, so as to make it bleed;"},{"kind":"text","text":"because of something happening therein. (Az, TA.) ―         -b2-  See also 1, in three places. ―         -b3-  Also"},{"kind":"italic_en","text":"He turned the piece of cloth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"forming part of the grave-clothing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"beneath his"},{"kind":"text","text":"(a corpse's)"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"the part beneath his chin."},{"kind":"text","text":"(Mgh.) [See also"},{"kind":"arabic","text_bw":"AlmiHonaku","text_ar":"المِحْنَكُ"},{"kind":"text","text":", below.]"}],"source_refs":["K","TA"]},{"entry_id":"n9353","headword_ar":"حُنْكَةٌ","root":"Hnk","body":[{"kind":"text","text":"(Lth, S, K) and ↓"},{"kind":"arabic","text_bw":"HunokN","text_ar":"حُنْكٌ","orth_type":"arrow"},{"kind":"text","text":", (Lth, K,) or ↓"},{"kind":"arabic","text_bw":"HinokN","text_ar":"حِنْكٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"HunukN","text_ar":"حُنُكٌ","orth_type":"arrow"},{"kind":"text","text":", (Lth, TA,) (tropical:)"},{"kind":"italic_en","text":"Firmness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundness, of judgment,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"produced by experience:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"age and experience,"},{"kind":"text","text":"(Lth, TA,)"},{"kind":"italic_en","text":"and knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill, in affairs:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"experience, and good judgment:"},{"kind":"text","text":"(W p. 176:) or"},{"kind":"italic_en","text":"mature, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right, judgment."},{"kind":"text","text":"(MA.) They say, ↓"},{"kind":"arabic","text_bw":"humo A^aholu AlHunoki","text_ar":"هُمْ اَهْلُ الحُنْكِ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AlHunuki","text_ar":"الحُنُكِ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlHunokapi","text_ar":"الحُنْكَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They are people of age and experience"},{"kind":"text","text":"[&c.]. (Lth, TA.)       -A2-  Also the first, (S, K,) and ↓"},{"kind":"arabic","text_bw":"HinaAkN","text_ar":"حِنَاكٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [or] the latter is pl. of the former, (A 'Obeyd, S,) [or is also pl. of the former,]"},{"kind":"italic_en","text":"A thong,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qid~apN","text_ar":"قِدَّةٌ"},{"kind":"text","text":", A 'Obeyd, S, K, [in the CK"},{"kind":"arabic","text_bw":"qud~apN","text_ar":"قُدَّةٌ"},{"kind":"text","text":",]) or"},{"kind":"italic_en","text":"a piece of wood,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"which conjoins the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"pieces of wood called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EaraASiyf","text_ar":"عَرَاصِيف"},{"kind":"text","text":", (so in two copies of the S,) or"},{"kind":"arabic","text_bw":"garaADiyf","text_ar":"غَرَاضِيف"},{"kind":"text","text":", (K, TA, [in the CK"},{"kind":"arabic","text_bw":"AlEarADiyf","text_ar":"العَراضِيف"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"saddle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":": so in the T. (TA.)"}],"source_refs":["Lth","S","K","TA"]}]}}