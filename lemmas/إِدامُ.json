{"lemma":"إِدامُ","slug":"إِدامُ","root":"#.د.م","root_slug":"_-د-م","root_link":"/words/roots/_-د-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n452","n454"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D8%AF%D8%A7%D9%85%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to perpetuate, to make last, to make permanent"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n452","headword_ar":"اـِدَامٌ","root":"Adm","body":[{"kind":"text","text":"(T, S, M, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"A^udomN","text_ar":"اُدْمٌ","orth_type":"arrow"},{"kind":"text","text":"(the same except the K) ["},{"kind":"italic_en","text":"Seasoning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condiment,"},{"kind":"text","text":"for bread; and"},{"kind":"italic_en","text":"any savoury food;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what is used for seasoniny"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maA yuw^otadamu bihi","text_ar":"مَا يُوْتَدَمُ بِهِ"},{"kind":"text","text":", T, S, M, * Mgh, Msb, K)"},{"kind":"italic_en","text":"with bread;"},{"kind":"text","text":"(T, TA;)"},{"kind":"italic_en","text":"that which renders bread pleasant and good and savoury;"},{"kind":"text","text":"(IAmb, Mgh;)"},{"kind":"italic_en","text":"whether fluid or not fluid;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"arabic","text_bw":"SibogN","text_ar":"صِبْغٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SibaAgN","text_ar":"صِبَاغٌ"},{"kind":"text","text":"being peculiarly applied to that which is fluid: (Mgh:) or"},{"kind":"arabic","text_bw":"A^udomN","text_ar":"اُدْمٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"anything that is eaten with bread:"},{"kind":"text","text":"(TA:) the pl. [of mult.] of"},{"kind":"arabic","text_bw":"A_idaAmN","text_ar":"اـِدَامٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^udumN","text_ar":"اُدُمٌ"},{"kind":"text","text":", (Mgh, Msb,) and, by contraction,"},{"kind":"arabic","text_bw":"A^udomN","text_ar":"اُدْمٌ"},{"kind":"text","text":", which is also used as the sing., (Msb,) and [pl. of pauc.]"},{"kind":"arabic","text_bw":"A=dimapN","text_ar":"ا=دِمَةٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"A=daAmN","text_ar":"ا=دَامٌ"},{"kind":"text","text":"; (K;) or this last is pl. of"},{"kind":"arabic","text_bw":"A^udomN","text_ar":"اُدْمٌ"},{"kind":"text","text":". (M, Mgh, Msb, TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"niEoma AlA_idaAmu Alxal~u","text_ar":"نِعْمَ الاـِدَامُ الخَلُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Excellent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most excel-lent, is the seasoning, vinegar!"},{"kind":"text","text":"]. (T, TA.) And in another,"},{"kind":"arabic","text_bw":"say~idu A=daAmi Ald~unoyaA waAlA=xirapi All~aHomu","text_ar":"سَيِّدُ ا=دَامِ الدُّنْيَا وَالا=خِرَةِ اللَّحْمُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The prince of the seasonings of the present world and of the world to come is flesh-meat"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"huwa A_idaAmu A^aholihi","text_ar":"هُوَ اـِدَامُ اَهْلِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A_idaAmu qawomihi","text_ar":"اـِدَامُ قَوْمِهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adamapN","text_ar":"اَدَمَةٌ"},{"kind":"text","text":". ―         -b3-  Anything"},{"kind":"italic_en","text":"conforming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conformable; agreeing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agreeable; suiting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suitable."},{"kind":"text","text":"(M, K.) [Used also as a pl.: thus,] 'Ádiyeh Ed-Dubeyreeyeh says,"},{"kind":"quote","text":"kaAnuwA limano xaAlaTahumo A_idaAmaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They were, to those who mixed with them in social intercourse, conformable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agreeable."},{"kind":"text","text":"] (M.)"}],"source_refs":["T","S","M","Mgh","Msb","K","TA"]},{"entry_id":"n454","headword_ar":"اَدَّامٌ","root":"Adm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^adamiY~N","text_ar":"اَدَمِىٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]}}