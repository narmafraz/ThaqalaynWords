lic_en","text":"one of the sorts of variegated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figured, cloths"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that serve for the coverings"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"women's camel-vehicles called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hawaAdij","text_ar":"هَوَادِج"},{"kind":"text","text":"; (TA;) as also the second; and so"},{"kind":"arabic","text_bw":"EaqobapN","text_ar":"عَقْبَةٌ"},{"kind":"text","text":": (O and TA in art."},{"kind":"arabic","text_bw":"Eqb","text_ar":"عقب"},{"kind":"text","text":":) but some, Lh adds, say that it signifies"},{"kind":"italic_en","text":"sorts of"},{"kind":"arabic","text_bw":"labin","text_ar":"لَبِن"},{"kind":"text","text":"[evidently, I think, a mistranscription for"},{"kind":"arabic","text_bw":"libos","text_ar":"لِبْس"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"clothing"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"white"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"red."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","S"]},{"entry_id":"n30009","headword_ar":"عُقْمٌ","root":"Eqm","body":[{"kind":"text","text":"[accord. to the S and K an inf. n., but accord. to the Msb a simple subst.,]"},{"kind":"italic_en","text":"Dryness that prevents the receiving of an impression:"},{"kind":"text","text":"this is the primary signification accord. to Er-Rághib. (TA.) ―         -b2-  [And]"},{"kind":"italic_en","text":"Barrenness"},{"kind":"text","text":"of the womb: (Msb:) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"hazomap","text_ar":"هَزْمَة"},{"kind":"text","text":"[generally and properly signifying a"},{"kind":"italic_en","text":"depression,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dint,"},{"kind":"text","text":"but here app. meaning a"},{"kind":"italic_en","text":"stricture,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EaqiymN","text_ar":"عَقِيمٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"that takes place in the womb, in consequence of which it is incapable of receiving offspring:"},{"kind":"text","text":"(K, TA:) so in the M. (TA.)"}],"source_refs":["Msb","K","TA"]},{"entry_id":"n30010","headword_ar":"عِقْمٌ","root":"Eqm","body":[{"kind":"text","text":"["},{"kind":"text","text":"accord. to the TK signifies the same as"},{"kind":"arabic","text_bw":"EaqomN","text_ar":"عَقْمٌ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"EaqomapN","text_ar":"عَقْمَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiqomapN","text_ar":"عِقْمَةٌ"},{"kind":"text","text":": but this I do not find in the K.]"}],"source_refs":[]}]},"classical_definitions":null}