{"lemma":"حَرِيّ","slug":"حَرِيّ","root":"ح.ر.#","root_slug":"ح-ر-_","root_link":"/words/roots/ح-ر-_","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n7503","n7586","n7803","n7519","n7796","n7799","n7802"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D9%90%D9%8A%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become scarce (e.g. of food)"},{"pos":"verb","gloss":"to be or become angry"},{"pos":"verb","gloss":"to intend, to aim for (a goal, etc.)"},{"pos":"verb","gloss":"it is hoped, it may be","tags":["archaic","impersonal","invariable"],"examples":[{"text":"حَرَى ٱلطَّبِيبُ أَنْ يُعَالِجَ ٱلْمَرْضَى.","english":"It is hoped that the doctor cures the patients"},{"text":"حَرَى الرِّيَاحُ أَنْ تَهُبَّ.","english":"It is hoped that the winds blow"}]}]},"etymology":null,"ipa":["/ħa.raː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7503","headword_ar":"حِرِىٌّ","root":"Hr","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"HrH","text_ar":"حرح"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7586","headword_ar":"حِرِىٌّ","root":"HrH","body":[{"kind":"text","text":", and (if you will, S) ↓"},{"kind":"arabic","text_bw":"HiraHiY~N","text_ar":"حِرَحِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) in which latter the medial radical letter is with fet-h, as in the rel. ns. formed from"},{"kind":"arabic","text_bw":"yadu","text_ar":"يَدُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gadN","text_ar":"غَدٌ"},{"kind":"text","text":", namely,"},{"kind":"arabic","text_bw":"yadawiY~N","text_ar":"يَدَوِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gadawiY~N","text_ar":"غَدَوِىٌّ"},{"kind":"text","text":"; (S;) ["},{"kind":"italic_en","text":"Of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"belonging to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to, the vulva,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pudendum, of a woman;"},{"kind":"text","text":"] rel. ns. of"},{"kind":"arabic","text_bw":"HirN","text_ar":"حِرٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"HiroHN","text_ar":"حِرْحٌ"},{"kind":"text","text":"]: and (if you will, S) you may say ↓"},{"kind":"arabic","text_bw":"HariHN","text_ar":"حَرِحٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"satipN","text_ar":"سَتِةٌ"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","K"]},{"entry_id":"n7803","headword_ar":"حِرِىٌّ","root":"HrY","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"HrH","text_ar":"حرح"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7519","headword_ar":"حَرِّىٌّ","root":"Hr","body":[{"kind":"text","text":"A camel"},{"kind":"italic_en","text":"that pastures in a stony tract such as is termed"},{"kind":"arabic","text_bw":"Har~apN","text_ar":"حَرَّةٌ"},{"kind":"text","text":". (S, K.)"}],"source_refs":[]},{"entry_id":"n7796","headword_ar":"حَرَى","root":"HrY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHoriY","text_ar":"يَحْرِى"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"HaroYN","text_ar":"حَرْىٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing S)"},{"kind":"italic_en","text":"decreased, diminished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waned,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"after increase;"},{"kind":"text","text":"(TA;) as does, for instance, the moon. (S, TA.) [See an ex. in a verse cited in art."},{"kind":"arabic","text_bw":"Ast","text_ar":"است"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"HaraY A^ano yakuwna *`lika","text_ar":"حَرَى اَنْ يَكُونَ ذٰلِكَ"},{"kind":"text","text":"i. q."},{"kind":"arabic","text_bw":"EasaY","text_ar":"عَسَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May-be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may-hap,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"that will be"},{"kind":"text","text":"]. (TA.)       -A3-"},{"kind":"arabic","text_bw":"HariYa bika*aA","text_ar":"حَرِىَ بِكَذَا"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, adapted, disposed, apt, meet, suited, suitable, fitted, fit, competent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, for such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy of it."},{"kind":"text","text":"(MA.)       -A4-"},{"kind":"arabic","text_bw":"HaraAhu","text_ar":"حَرَاهُ"},{"kind":"text","text":": see 5."}],"source_refs":["S","K","TA"]},{"entry_id":"n7799","headword_ar":"حَرًى","root":"HrY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"vicinage, quarter, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region,"},{"kind":"text","text":"(As, T, S, IAth, Mgh, K,) of a man, (As, T, IAth,) or of a people; (Mgh;) the"},{"kind":"italic_en","text":"environs"},{"kind":"text","text":"(As, T, S) of a man, (As, T,) or of a house; (S;) and ↓"},{"kind":"arabic","text_bw":"HaraApN","text_ar":"حَرَاةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (S, K:) and [it is said that] the former signifies also the"},{"kind":"italic_en","text":"place of the eggs"},{"kind":"text","text":"of an ostrich: (S, K:) and"},{"kind":"italic_en","text":"a covert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hiding-place, among trees,"},{"kind":"text","text":"of a gazelle: (K, * TA:) Lth says that it signifies the"},{"kind":"italic_en","text":"place of laying eggs"},{"kind":"text","text":"of the ostrich; or the"},{"kind":"italic_en","text":"covert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lodging-place,"},{"kind":"text","text":"of the gazelle: but this is false; for with the Arabs the word signifies as explained above on the authority of As and the"},{"kind":"arabic","text_bw":"HrY","text_ar":"حرى"},{"kind":"text","text":"of the place of laying eggs of the ostrich, and of the covert of the gazelle, is the"},{"kind":"italic_en","text":"environs"},{"kind":"text","text":"thereof: (T, TA:) pl."},{"kind":"arabic","text_bw":"A^aHoraA='N","text_ar":"اَحْرَا=ءٌ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Ai*ohabo falaA A^arayan~aka biHaraAYa","text_ar":"اِذْهَبْ فَلَا اَرَيَنَّكَ بِحَرَاىَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HaraAtiY","text_ar":"حَرَاتِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Go thou, so that I may by no means see thee in my vicinage,"},{"kind":"text","text":"&c.]. (S.) And"},{"kind":"arabic","text_bw":"laA taTuro HaraAnaA","text_ar":"لَا تَطُرْ حَرَانَا"},{"kind":"italic_en","text":"Approach not thou our environs."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"nazalotu biHaraAhu","text_ar":"نَزَلْتُ بِحَرَاهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biEaraAhu","text_ar":"بِعَرَاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I alighted,"},{"kind":"text","text":"or"},{"kind":"page_break","n":558},{"kind":"italic_en","text":"descended and abode, in his vicinage,"},{"kind":"text","text":"&c.]. (S.)       -A2-  See also"},{"kind":"arabic","text_bw":"HariY~N","text_ar":"حَرِىٌّ"},{"kind":"text","text":", in six places."}],"source_refs":["As","T","S","IAth","Mgh","K","TA"]},{"entry_id":"n7802","headword_ar":"حَرِىٌّ","root":"HrY","body":[{"kind":"italic_en","text":"Adapted, disposed, apt, meet, suited, suitable, fitted, fit, competent, proper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HarK","text_ar":"حَرٍ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HarFY","text_ar":"حَرًى","orth_type":"arrow"},{"kind":"text","text":", which last has no dual nor pl., (S, Msb, K,) nor a fem. form, remaining unaltered, because it is [originally] an inf. n.; [see a verse cited voce"},{"kind":"arabic","text_bw":"naqorN","text_ar":"نَقْرٌ"},{"kind":"text","text":";] or, accord. to Lh, one may say"},{"kind":"arabic","text_bw":"HarayaAni","text_ar":"حَرَيَانِ"},{"kind":"text","text":", because Ks has related that some of the Arabs dualize what they do not pluralize: (TA:) the pl. of"},{"kind":"arabic","text_bw":"HariY~N","text_ar":"حَرِىٌّ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Hariy~uwna","text_ar":"حَرِيُّونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aHoriyaA='u","text_ar":"اَحْرِيَا=ءُ"},{"kind":"text","text":"; (S, Msb;) and the pl. of"},{"kind":"arabic","text_bw":"Hariy~apN","text_ar":"حَرِيَّةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Hariy~aAtN","text_ar":"حَرِيَّاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaraAyaA","text_ar":"حَرَايَا"},{"kind":"text","text":": the pl. of ↓"},{"kind":"arabic","text_bw":"HarK","text_ar":"حَرٍ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^aHoraA='N","text_ar":"اَحْرَا=ءٌ"},{"kind":"text","text":"(S, TA) and"},{"kind":"arabic","text_bw":"Haruwna","text_ar":"حَرُونَ"},{"kind":"text","text":"; and the pl. of"},{"kind":"arabic","text_bw":"HariyapN","text_ar":"حَرِيَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"HariyaAtN","text_ar":"حَرِيَاتٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"A_in~ahu","text_ar":"اـِنَّهُ"},{"kind":"arabic","text_bw":"laHariY~N bika*aA","text_ar":"لَحَرِىٌّ بِكَذَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"laHari","text_ar":"لَحَرِ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"laHarFY","text_ar":"لَحَرًى","orth_type":"arrow"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"Verily he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is adapted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy of such a thing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"huwa HariY~N","text_ar":"هُوَ حَرِىٌّ"},{"kind":"arabic","text_bw":"A^ano yafoEala *aAka","text_ar":"اَنْ يَفْعَلَ ذَاكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"HarK","text_ar":"حَرٍ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"HarFY","text_ar":"حَرًى","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He is adapted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to do that:"},{"kind":"text","text":"(S, Msb:) and"},{"kind":"arabic","text_bw":"An","text_ar":"ان"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"An~h lamaHorFY","text_ar":"انّه لَمَحْرًى","orth_type":"arrow"},{"kind":"arabic","text_bw":"yfEl","text_ar":"يفعل"},{"kind":"text","text":", (Lh, K, [in some copies of the K, erroneously,"},{"kind":"arabic","text_bw":"lamaHoriY~N","text_ar":"لَمَحْرِىٌّ"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"lamaHoraApN","text_ar":"لَمَحْرَاةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) which last has no dual nor pl. nor fem. form, like"},{"kind":"arabic","text_bw":"maxolaqapN","text_ar":"مَخْلَقَةٌ"},{"kind":"text","text":"[q. v.] and"},{"kind":"arabic","text_bw":"maqomanapN","text_ar":"مَقْمَنَةٌ"},{"kind":"text","text":": (TA:) and ↓"},{"kind":"arabic","text_bw":"h`*aA AlA^amoru maHoraApN","text_ar":"هٰذَا الاَمْرُ مَحْرَاةٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"li*`lika","text_ar":"لِذٰلِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This thing, or affair, is adapted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to that"},{"kind":"text","text":"]. (S.) And hence the phrase,"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"biA@loHaraY","text_ar":"بِا@لْحَرَى","orth_type":"arrow"},{"kind":"arabic","text_bw":"yakuwna *aAka","text_ar":"يَكُونَ ذَاكَ"},{"kind":"text","text":"(S, * K)"},{"kind":"italic_en","text":"It is suitable, fit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, that that should be."},{"kind":"text","text":"(PS.) [But this phrase, in the present day, means"},{"kind":"italic_en","text":"Rather that should be."},{"kind":"text","text":"And hence, ↓"},{"kind":"arabic","text_bw":"kamo biA@lHaraY","text_ar":"كَمْ بِا@لحَرَى","orth_type":"arrow"},{"kind":"italic_en","text":"How much rather."},{"kind":"text","text":"] One says also, of a man who has attained to fifty [years], ↓"},{"kind":"arabic","text_bw":"faHarFY","text_ar":"فَحَرًى","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He is adapted,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to attain all that is good."},{"kind":"text","text":"(Th, TA.) And one says"},{"kind":"arabic","text_bw":"A_in~ahu laHariY~N","text_ar":"اـِنَّهُ لَحَرِىٌّ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"Verily it is probable;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"likely to happen"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to have happened"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"been;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"laxaliyqN","text_ar":"لَخَلِيقٌ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"xlq","text_ar":"خلق"},{"kind":"text","text":".)"}],"source_refs":["S","Msb","K","TA"]}]}}