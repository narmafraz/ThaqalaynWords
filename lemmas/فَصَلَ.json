"role":"present_2mp","form":"تَفْصِلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْصِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْصِل","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْصِل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْصِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْصِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْصِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْصِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْصِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْصِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْصِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فَصَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَصَلْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْصِل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْصِل","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":40,"cross_references":{"qac":{"found":true,"lemma_key":"فَصَلَ","root":"فصل","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":19},"lanes":{"found":true,"entry_ids":["n33998"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B5%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of فَصَلَ (faṣala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"separation, division, partition"},{"pos":"noun","gloss":"decision"},{"pos":"noun","gloss":"incision"},{"pos":"noun","gloss":"season"},{"pos":"noun","gloss":"chapter, paragraph, division"},{"pos":"noun","gloss":"class (group of students)"},{"pos":"noun","gloss":"joint"},{"pos":"noun","gloss":"interstice, gap"},{"pos":"noun","gloss":"point"},{"pos":"noun","gloss":"difference"},{"pos":"noun","gloss":"sagacity"},{"pos":"adj","gloss":"conclusive, decisive (speech)","tags":["invariable"]},{"pos":"verb","gloss":"to separate, to divide","tags":["invariable"]},{"pos":"verb","gloss":"to judge between (+بَيْنَ (bayna))","tags":["invariable"],"examples":[{"text":"إِنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ الْقِيَامَةِ فِيمَا كَانُوا فِيهِ يَخْتَلِفُونَ"}]},{"pos":"verb","gloss":"to fire (from a job)","tags":["invariable"]},{"pos":"verb","gloss":"to wean","tags":["invariable"]},{"pos":"verb","gloss":"to go away, to leave","tags":["invariable"]},{"pos":"verb","gloss":"to detail","tags":["invariable","transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33998","headword_ar":"فَصَلَ","root":"fSl","body":[{"kind":"text","text":", (S, M, O, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faSolN","text_ar":"فَصْلٌ"},{"kind":"text","text":", (M, Msb, K,)"},{"kind":"italic_en","text":"He separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided,"},{"kind":"text","text":"(S, O, Msb, K,) and"},{"kind":"italic_en","text":"put apart,"},{"kind":"text","text":"(Msb,) a thing, (S, O, Msb, *)"},{"kind":"arabic","text_bw":"Eano gayorihi","text_ar":"عَنْ غَيْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from another thing"},{"kind":"text","text":"], (Msb,) and"},{"kind":"arabic","text_bw":"baEoDahu mino baEoDK","text_ar":"بَعْضَهُ مِنْ بَعْضٍ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"Eano baEoDK","text_ar":"عَنْ بَعْضٍ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"part thereof from part"},{"kind":"text","text":"]. (M and TA in art."},{"kind":"arabic","text_bw":"myz","text_ar":"ميز"},{"kind":"text","text":".) And (K,)"},{"kind":"italic_en","text":"He made a separation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"partition,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"arabic","text_bw":"bayonahumaA","text_ar":"بَيْنَهُمَا"},{"kind":"text","text":"(M, TA *) i. e."},{"kind":"italic_en","text":"between them two,"},{"kind":"text","text":"meaning, two things,"},{"kind":"italic_en","text":"making it known that the former had come to an end:"},{"kind":"text","text":"so says Er-Rághib: (TA:) and"},{"kind":"arabic","text_bw":"faSala AlHad~u bayona AlA^aroDayoni","text_ar":"فَصَلَ الحَدُّ بَيْنَ الاَرْضَيْنِ"},{"kind":"text","text":", [aor. and] inf. n. as above,"},{"kind":"italic_en","text":"The limit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boundary, made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"formed, a separation between the two lands:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"faSalotu bayona Alqawomi","text_ar":"فَصَلْتُ بَيْنَ القَوْمِ"},{"kind":"italic_en","text":"I made a division,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separation, between,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"among, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(O.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"faSala Alr~DiyEa Eano A^um~ihi","text_ar":"فَصَلَ الرّضِيعَ عَنْ اُمِّهِ"},{"kind":"text","text":", (S, Mgh, O,) or"},{"kind":"arabic","text_bw":"Almawoluwda","text_ar":"المَوْلُودَ"},{"kind":"text","text":"(M, K)"},{"kind":"arabic","text_bw":"Eani Alr~aDaAEi","text_ar":"عَنِ الرَّضَاعِ"},{"kind":"text","text":", (M,) aor. as above,"},{"kind":"page_break","n":2406},{"kind":"text","text":"(M, K,) inf. n."},{"kind":"arabic","text_bw":"fiSaAlN","text_ar":"فِصَالٌ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"faSolN","text_ar":"فَصْلٌ"},{"kind":"text","text":", and the former is a simple subst., (M, K,) or both, (Mgh,)"},{"kind":"italic_en","text":"He weaned"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the suckling from his mother,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the young infant from sucking the breast"},{"kind":"text","text":"]; (S, M, Mgh, O, K;) as also ↓"},{"kind":"arabic","text_bw":"AftSlhu","text_ar":"افتصلهُ","orth_type":"arrow"},{"kind":"text","text":": (S, M, O:) or"},{"kind":"arabic","text_bw":"faSalati AlmaroA^apu raDiyEahaA","text_ar":"فَصَلَتِ المَرْاَةُ رَضِيعَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"faSolN","text_ar":"فَصْلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiSaAlN","text_ar":"فِصَالٌ"},{"kind":"text","text":"is the subst.,"},{"kind":"italic_en","text":"the woman weaned her suckling."},{"kind":"text","text":"(Msb.) ―         -b3-  Hence also, i. e. from"},{"kind":"arabic","text_bw":"faSala","text_ar":"فَصَلَ"},{"kind":"text","text":"as first expl. above,"},{"kind":"arabic","text_bw":"faSolu AlxuSuwmaAti","text_ar":"فَصْلُ الخُصُومَاتِ"},{"kind":"italic_en","text":"The deciding of litigations, altercations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disputes:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"faSolu AlxiTaAbi","text_ar":"فَصْلُ الخِطَابِ"},{"kind":"text","text":": (Msb:) or this latter means"},{"kind":"italic_en","text":"distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain speech; which he to whom it is addressed distinctly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly, understands; which is not confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dubious, to him:"},{"kind":"text","text":"(Ksh in explanation of it in the Kur xxxviii. 19, and Mgh:) or"},{"kind":"italic_en","text":"such as decides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinguishes, between what is true and what is false,"},{"kind":"text","text":"(Ksh ibid., Mgh, O, K,)"},{"kind":"italic_en","text":"and what is sound and what is corrupt,"},{"kind":"text","text":"(Ksh, Mgh,)"},{"kind":"italic_en","text":"and what is correct and what is erroneous:"},{"kind":"text","text":"(Ksh:) or"},{"kind":"italic_en","text":"such as decides the judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judicial sentence:"},{"kind":"text","text":"(Er-Rághib, TA:) or"},{"kind":"italic_en","text":"the evidence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proof, that is obligatory"},{"kind":"text","text":"[as a condition of his justification]"},{"kind":"italic_en","text":"upon the claimant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plaintiff,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the oath that is obligatory"},{"kind":"text","text":"[in like manner]"},{"kind":"italic_en","text":"upon him against whom the claim,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plaint, is urged;"},{"kind":"text","text":"(Ksh, O, K; [an explanation of which a part is dropped in the CK;]) thus accord. to 'Alee: (Ksh:) or"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"using of the"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"phrase"},{"kind":"arabic","text_bw":"A^am~aA baEodu","text_ar":"اَمَّا بَعْدُ"},{"kind":"text","text":". (Ksh, O, K. [Respecting this phrase, and for other explanations, see 3 in art"},{"kind":"arabic","text_bw":"xTb","text_ar":"خطب"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"kalimapu AlfaSoli","text_ar":"كَلِمَةُ الفَصْلِ"},{"kind":"text","text":"in the Kur xlii. 20 means"},{"kind":"italic_en","text":"The sentence of God's deciding between mankind"},{"kind":"text","text":"on the day of resurrection, (O,) which is called"},{"kind":"arabic","text_bw":"yawomu AlfaSoli","text_ar":"يَوْمُ الفَصْلِ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"AlfaSolu","text_ar":"الفَصْلُ"},{"kind":"text","text":"[alone] means"},{"kind":"italic_en","text":"The deciding judicially between what is true and what is false;"},{"kind":"text","text":"(M, O, K;) and, (O, K,) sometimes, (O,) so ↓"},{"kind":"arabic","text_bw":"AlfayoSalu","text_ar":"الفَيْصَلُ","orth_type":"arrow"},{"kind":"text","text":"; (S, O, K;) or this latter is [a simple subst, i. e.,] a name for such decision; (TA;) and is also an epithet [expl. below]. (M, O, K.)"},{"kind":"arabic","text_bw":"h`*aA yawomu A@ld~iyni h`*aA yawomu A@lofaSoli","text_ar":"هٰذَا يَوْمُ ا@لدِّينِ هٰذَا يَوْمُ ا@لْفَصْلِ"},{"kind":"text","text":", in the Kur xxxvii. 20 and 21, means ["},{"kind":"italic_en","text":"This is the day of requital:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"this is the day wherein a decision,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a distinction, shall be made"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yufoSalu fiyhi","text_ar":"يُفْصَلُ فِيهِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"between the doer of good and the doer of evil, and every one shall be requited for his work and with that wherewith God will favour his servant the Muslim."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"A_in~a rab~aka huwa yafoSilu bayonahumo yawoma A@loqiyaAmapi fiymaA kaAnuwA","text_ar":"اـِنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ ا@لْقِيَامَةِ فِيمَا كَانُوا"},{"kind":"arabic","text_bw":"fiyhi yaxotalifuwna","text_ar":"فِيهِ يَخْتَلِفُونَ"},{"kind":"text","text":", in the Kur xxxii. 25, means ["},{"kind":"italic_en","text":"Verily thy Lord"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He shall decide"},{"kind":"text","text":"["},{"kind":"italic_en","text":"between them"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and distinguish what is true from what is false,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"on the day of resurrection,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by distinguishing the speaker of what is true from the speaker of what is false, in respect of that wherein they used to disagree,"},{"kind":"text","text":"of what concerned religion. (Bd.) And one says also"},{"kind":"arabic","text_bw":"faSala AlHukoma","text_ar":"فَصَلَ الحُكْمَ"},{"kind":"text","text":"[He decided"},{"kind":"italic_en","text":"the judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judicial sentence"},{"kind":"text","text":"]. (M.)"},{"kind":"arabic","text_bw":"faSala Aln~aZoma","text_ar":"فَصَلَ النَّظْمَ"},{"kind":"text","text":", in the K, is a mistake: see 2. (TA.)       -A2-"},{"kind":"arabic","text_bw":"faSala mina Aln~aAHiyapi","text_ar":"فَصَلَ مِنَ النَّاحِيَةِ"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"mino Albaladi","text_ar":"مِنْ البَلَدِ"},{"kind":"text","text":"(K,) or"},{"kind":"arabic","text_bw":"Eano baladika*aA","text_ar":"عَنْ بَلَدِكَذَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"fuSuwlN","text_ar":"فُصُولٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He went forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the part of the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from the town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from such a town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country"},{"kind":"text","text":"]. (S, O, K.) And"},{"kind":"arabic","text_bw":"faSala","text_ar":"فَصَلَ"},{"kind":"arabic","text_bw":"AlEasokaru Eani Albaladi","text_ar":"العَسْكَرُ عَنِ البَلَدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The army went forth from the town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country"},{"kind":"text","text":"]: whence the saying of the Prophet respecting Ibn-Rawáhah,"},{"kind":"arabic","text_bw":"kaAna A^aw~alanaA fuSuwlFA","text_ar":"كَانَ اَوَّلَنَا فُصُولًا"},{"kind":"arabic","text_bw":"waA=xirunaAqufuwlFA","text_ar":"وَا=خِرُنَاقُفُولًا"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"He was the first of us in going away"},{"kind":"text","text":"(↓"},{"kind":"arabic","text_bw":"AinofiSaAlFA","text_ar":"اِنْفِصَالًا","orth_type":"arrow"},{"kind":"text","text":") from his house and his family"},{"kind":"italic_en","text":"and the last of us in returning"},{"kind":"text","text":"to [it and] them. (Mgh.) And"},{"kind":"arabic","text_bw":"faSala fulaAnN mino EinodiY","text_ar":"فَصَلَ فُلَانٌ مِنْ عِنْدِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fuSuwlN","text_ar":"فُصُولٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a one went forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from my presence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vicinage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from me"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"faSala min~iY","text_ar":"فَصَلَ مِنِّى"},{"kind":"arabic","text_bw":"kitaAbu A_ilayohi","text_ar":"كِتَابُ اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A letter"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"passed from me to him."},{"kind":"text","text":"(TA.) Thus the verb is intrans, as well as trans.; its inf. n. when it is trans, being"},{"kind":"arabic","text_bw":"faSolN","text_ar":"فَصْلٌ"},{"kind":"text","text":"; when intrans.,"},{"kind":"arabic","text_bw":"fuSuwlN","text_ar":"فُصُولٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"faSala Alkaromu","text_ar":"فَصَلَ الكَرْمُ"},{"kind":"italic_en","text":"The vine put forth small grapes, resembling lentils"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a grain similar thereto."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","M","O","Msb","K","TA","Mgh","Ksh"]}]}}