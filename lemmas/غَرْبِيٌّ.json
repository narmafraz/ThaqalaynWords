nabiy*","text_ar":"نَبِيذ"},{"kind":"italic_en","text":"that is termed"},{"kind":"arabic","text_bw":"faDiyx","text_ar":"فَضِيخ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a beverage made from crushed unripe dates without being put upon the fire"},{"kind":"text","text":"]: (K, TA:) or ["},{"kind":"italic_en","text":"a beverage"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"prepared only from fresh ripe dates; the drinker of which ceases not to possess selfrestraint as long as the wind does not blow upon him; but if he goes forth into the air, and the wind blows upon him, his reason departs:"},{"kind":"text","text":"wherefore one of its drinkers says,"},{"kind":"quote","text":"A_ino lamo yakuno garobiy~ukumo jay~idFA\n                      \n                     \n                        fanaHonu biA@ll~`hi wabiA@lr~iyHi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If your gharbee be not excellent, we"},{"kind":"text","text":"("},{"kind":"italic_en","text":"put our trust"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in God and in the wind"},{"kind":"text","text":"]. (AHn, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A certain red"},{"kind":"arabic","text_bw":"Sibog","text_ar":"صِبْغ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"dye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perhaps sauce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fluid seasoning"},{"kind":"text","text":"]. (K.)"}],"source_refs":["K","TA"]}]},"classical_definitions":null}