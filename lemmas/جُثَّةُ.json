d":"italic_en","text":"he uprooted it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eradicated it."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"jav~a","text_ar":"جَثَّ"},{"kind":"text","text":"said of a collector of honey,"},{"kind":"italic_en","text":"He took the honey with  its"},{"kind":"arabic","text_bw":"jav~","text_ar":"جَثّ"},{"kind":"italic_en","text":"and its"},{"kind":"arabic","text_bw":"maHaAriyn","text_ar":"مَحَارِين"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"the bees that had died in it."},{"kind":"text","text":"(IAar, TA.)"}],"source_refs":["S","Msb","TA","A","K","L"]},{"entry_id":"n5045","headword_ar":"جُثَّةٌ","root":"jv","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corporeal form"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figure,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$axoS","text_ar":"شَخْص"},{"kind":"text","text":".) of a man, (S, A, Msb, K,) ["},{"kind":"italic_en","text":"absolutely,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"sitting,"},{"kind":"text","text":"(S, A, Msb,) or"},{"kind":"italic_en","text":"sleeping,"},{"kind":"text","text":"[by which is meant, as in many other instances,"},{"kind":"italic_en","text":"lying down,"},{"kind":"text","text":"] (S, Msb,) or"},{"kind":"italic_en","text":"reclining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lying on the side:"},{"kind":"text","text":"(TA:) that of a man standing erect being termed"},{"kind":"arabic","text_bw":"TalalN","text_ar":"طَلَلٌ"},{"kind":"text","text":"(Msb) or"},{"kind":"arabic","text_bw":"qaAmapN","text_ar":"قَامَةٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"$xS","text_ar":"شخص"},{"kind":"text","text":"applying in common to what is termed"},{"kind":"arabic","text_bw":"jvap","text_ar":"جثَة"},{"kind":"text","text":"and what is termed"},{"kind":"arabic","text_bw":"Tll","text_ar":"طلل"},{"kind":"text","text":", in relation to a man: (Msb:) or"},{"kind":"arabic","text_bw":"jvap","text_ar":"جثَة"},{"kind":"text","text":"is used only in relation to a man"},{"kind":"italic_en","text":"upon a horse's or camel's saddle, wearing a turban:"},{"kind":"text","text":"so says IDrd on the authority of Abu-l-Khattáb ElAkhfash; but he adds that this has not been heard from any other: (TA:) pl. [of mult.]"}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_definitions":null}