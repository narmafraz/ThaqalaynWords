{"lemma":"جُذامُ","slug":"جُذامُ","root":"ج.ذ.م","root_slug":"ج-ذ-م","root_link":"/words/roots/ج-ذ-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5356"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8F%D8%B0%D8%A7%D9%85%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"leprosy"}]},"etymology":null,"ipa":["/d͡ʒu.ðaːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5356","headword_ar":"جُذَامٌ","root":"j*m","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Elephantiasis; a species of leprosy;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"leprosy that pervaded Europe in the latter part of the Middle Ages;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain disease,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"arising from the spreading of the black bile throughout the whole person, so that it corrupts the temperament of the members, and the external condition thereof; and sometimes ending in the dissundering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrosion,"},{"kind":"text","text":"(so accord. to different copies of the K, TA,)"},{"kind":"italic_en","text":"of the members, and their falling off, in consequence of ulceration;"},{"kind":"text","text":"(K, TA;) so called because"},{"kind":"italic_en","text":"it dissunders the flesh, and causes it to fall off;"},{"kind":"text","text":"(Msb;) or because"},{"kind":"italic_en","text":"the fingers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toes, become cut off:"},{"kind":"text","text":"(TA:) it is"},{"kind":"italic_en","text":"a cracking of the skin, and a dissundering, and gradual falling off, of the flesh."},{"kind":"text","text":"(Mgh.)"}],"source_refs":["S","K","TA"]}]}}