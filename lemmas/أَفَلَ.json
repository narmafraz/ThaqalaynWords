,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to set, to go beyond the horizon"}]},"etymology":{"source":"wiktextract","text":"From the root ء ف ل (ʔ f l). Compare Hebrew אֲפֵילָה (ăp̄ēlāh, “darkness”)."},"ipa":["/ʔa.fa.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n965","headword_ar":"اَفَلَ","root":"Afl","body":[{"kind":"text","text":", (T, S, Msb, K,) said of a thing, (Msb,) or of the moon, (T,) and"},{"kind":"arabic","text_bw":"A^afalato","text_ar":"اَفَلَتْ"},{"kind":"text","text":", said of the sun, (T, S, M,) and of the stars, (M,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^ufuwlN","text_ar":"اُفُولٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^folN","text_ar":"افْلٌ"},{"kind":"text","text":", (M, Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, absent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed;"},{"kind":"text","text":"(T, S, Msb, K;)"},{"kind":"italic_en","text":"it set;"},{"kind":"text","text":"(T, S, M, &c.;) and so"},{"kind":"arabic","text_bw":"A^afila","text_ar":"اَفِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":". (K.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"A^afala","text_ar":"اَفَلَ"},{"kind":"arabic","text_bw":"fulaAnN Eani Albaladi","text_ar":"فُلَانٌ عَنِ البَلَدِ"},{"kind":"italic_en","text":"Such a one became absent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, from the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town."},{"kind":"text","text":"(Msb.)"}],"source_refs":["T","S","Msb","K","M"]},{"entry_id":"n34430","headword_ar":"اَفْلُّ","root":"fl","body":[{"kind":"text","text":", applied to a sword [or the like], (T, S, O, K,)"},{"kind":"italic_en","text":"Having breaks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notches, in its edge;"},{"kind":"text","text":"(T, S, * O; *) or"},{"kind":"italic_en","text":"broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notched, in its edge;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mafoluwlN","text_ar":"مَفْلُولٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"munofal~N","text_ar":"مُنْفَلٌّ","orth_type":"arrow"},{"kind":"text","text":". (M, K.)"},{"kind":"arabic","text_bw":"AlA^afal~u","text_ar":"الاَفَلُّ"},{"kind":"text","text":"was the name of a sword of 'Adee Ibn-Hátim (O, K) Et- Tá-ee. (O.)"}],"source_refs":["T","S","O","K"]}]}}