{"lemma":"نَفْرَةٍ","slug":"نَفْرَةٍ","root":"ن.ف.ر","root_slug":"ن-ف-ر","root_link":"/words/roots/ن-ف-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n40229","n40230"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%81%D9%92%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"instance noun of نَفَرَ (nafara)"},{"pos":"noun","gloss":"detestation, aversion, dislike, abhorrence"},{"pos":"noun","gloss":"a group of people less than ten in number"},{"pos":"noun","gloss":"someone's relatives and friends who would stand with him against adversaries"},{"pos":"noun","gloss":"being in a hurry"},{"pos":"noun","gloss":"a talisman, an object that some people hang to ward off the evil eye"}]},"etymology":{"source":"wiktextract","text":"Instance noun from the verb نَفَرَ (nafara)."},"ipa":["/naf.ra/","/nuf.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40229","headword_ar":"نَفْرَةٌ","root":"nfr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"nafiyrN","text_ar":"نَفِيرٌ"},{"kind":"text","text":". ―         -b2-  A man's"},{"kind":"italic_en","text":"near kinsmen;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^usorapN","text_ar":"اُسْرَةٌ"},{"kind":"text","text":"(T, K) and"},{"kind":"arabic","text_bw":"faSiylapN","text_ar":"فَصِيلَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"who are angry on account of his anger;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"nuforapN","text_ar":"نُفْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", mentioned by Sgh and others, (TA,) and ↓"},{"kind":"arabic","text_bw":"nufuwrpN","text_ar":"نُفُورةٌ","orth_type":"arrow"},{"kind":"text","text":"(T. K) and ↓"},{"kind":"arabic","text_bw":"naAfirapN","text_ar":"نَافِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(A, * K) and ↓"},{"kind":"arabic","text_bw":"nafarN","text_ar":"نَفَرٌ","orth_type":"arrow"},{"kind":"text","text":": (T:) and"},{"kind":"arabic","text_bw":"nufuwrapN","text_ar":"نُفُورَةٌ"},{"kind":"text","text":"signifies a man's"},{"kind":"italic_en","text":"near kinsmen"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^usorap","text_ar":"اُسْرَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"who go forth with him to war when an event befalls him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oppresses him severely"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suddenly."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"jaA='anaA fiY naforatihi","text_ar":"جَا=ءَنَا فِى نَفْرَتِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nafarihi","text_ar":"نَفَرِهِ","orth_type":"arrow"},{"kind":"text","text":", (T, TA,) &c., (TA,)"},{"kind":"italic_en","text":"He came to us among his near kinsmen,"},{"kind":"text","text":"(T, TA,) &c. (TA.) And,"},{"kind":"arabic","text_bw":"galabato nufuwratunaA","text_ar":"غَلَبَتْ نُفُورَتُنَا"},{"kind":"arabic","text_bw":"nufuwratahumo","text_ar":"نُفُورَتَهُمْ"},{"kind":"italic_en","text":"Our near kinsmen overcame their near kinsmen."},{"kind":"text","text":"(T, TA.) See also"},{"kind":"arabic","text_bw":"nafarN","text_ar":"نَفَرٌ"},{"kind":"text","text":", in two places: and see"},{"kind":"arabic","text_bw":"nafiyrN","text_ar":"نَفِيرٌ"},{"kind":"text","text":"."}],"source_refs":["T","K","TA"]},{"entry_id":"n40230","headword_ar":"نُفْرَةٌ","root":"nfr","body":[{"kind":"text","text":"(Sgh, K) and ↓"},{"kind":"arabic","text_bw":"nufarapN","text_ar":"نُفَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"A thing that is hung upon a child for fear of,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"to repel,"},{"kind":"text","text":"(Sgh,)"},{"kind":"italic_en","text":"the evil eye."},{"kind":"text","text":"(Sgh, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"naforapN","text_ar":"نَفْرَةٌ"},{"kind":"text","text":"."}],"source_refs":["Sgh","K"]}]},"classical_definitions":null}