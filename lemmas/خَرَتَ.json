ions":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pierce, to bore, to perforate"}]},"etymology":null,"ipa":["/xa.ra.ta/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10262","headword_ar":"خَرَتَ","root":"xrt","body":[{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xarotN","text_ar":"خَرْتٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"He perforated, bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"(K,) the ear, (TK,) or a thing. (TA.) And"},{"kind":"arabic","text_bw":"xarata A^anofa Aljamali","text_ar":"خَرَتَ اَنْفَ الجَمَلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It perforated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slit,"},{"kind":"text","text":"(see the pass. part. n., below,)"},{"kind":"italic_en","text":"the nose of the camel"},{"kind":"text","text":"]: said of the"},{"kind":"arabic","text_bw":"xi$aA$","text_ar":"خِشَاش"},{"kind":"text","text":"[or wooden thing that is inserted in the bone of the camel's nose]. (A.)       -A2-"},{"kind":"arabic","text_bw":"xaratonaA AlA^aroDa","text_ar":"خَرَتْنَا الاَرْضَ"},{"kind":"italic_en","text":"We knew the land and its roads."},{"kind":"text","text":"(Ks, S.) [Golius omits this; but mentions, as on the authority of Ibn-Maaroof,"},{"kind":"arabic","text_bw":"xarita","text_ar":"خَرِتَ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"He was skilful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expert, in showing the way."},{"kind":"text","text":"What Ibn-Maaroof says, however, is that the inf. n."},{"kind":"arabic","text_bw":"xaratN","text_ar":"خَرَتٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"being acquainted with a road;"},{"kind":"text","text":"and,"},{"kind":"italic_en","text":"with a place."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"xir~iytu","text_ar":"خِرِّيتُ"},{"kind":"text","text":".]"}],"source_refs":["K","TK"]}]},"classical_definitions":null}