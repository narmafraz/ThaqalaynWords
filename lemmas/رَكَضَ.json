"},{"role":"present_2mp","form":"تَرْكُضُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْكُضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْكُض","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْكُض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْكُضانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْكُضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْكُضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْكُضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْكُضُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْكُضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْكُضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رَكَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَكَضْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْكُض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْكُض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n16506"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%83%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to race, to rush, to run"},{"pos":"noun","gloss":"verbal noun of رَكَضَ (rakaḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"swift run, gallop"}]},"etymology":{"source":"wiktextract","text":"Compare Classical Syriac ܪܗܛ, Hebrew רָץ (rats) and Ge'ez ሮጸ (roṣä)."},"ipa":["/ra.ka.dˤa/","/rakdˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16506","headword_ar":"رَكَضَ","root":"rkD","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He moved,"},{"kind":"text","text":"(S, A, K,) or"},{"kind":"italic_en","text":"struck with,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"his leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot:"},{"kind":"text","text":"(S, A, Msb, K:) or"},{"kind":"italic_en","text":"he struck and hit therewith, like as one strikes and hits therewith a beast."},{"kind":"text","text":"(IAth.) Hence, (S, A, K,) the phrase in the Kur [xxxviii. 41], (S,)"},{"kind":"arabic","text_bw":"AurokuDo birijolika","text_ar":"اُرْكُضْ بِرِجْلِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Strike thou"},{"kind":"text","text":"the ground"},{"kind":"italic_en","text":"with thy foot"},{"kind":"text","text":"]: (S, A, K:) or"},{"kind":"italic_en","text":"strike thou, and tread,"},{"kind":"text","text":"the ground"},{"kind":"italic_en","text":"with thy foot."},{"kind":"text","text":"(Sgh.) You say also,"},{"kind":"arabic","text_bw":"rakaDa Alr~ajulu","text_ar":"رَكَضَ الرَّجُلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man struck the ground with his foot:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rakaDati Alxayolu","text_ar":"رَكَضَتِ الخَيْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The horses struck the ground with their hoofs:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jaA='ati","text_ar":"جَا=ءَتِ"},{"kind":"arabic","text_bw":"Alxayolu rakoDFA","text_ar":"الخَيْلُ رَكْضًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The horses came striking the ground with their hoofs"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"rakaDati Aljunodabu Alr~amoDaA='a","text_ar":"رَكَضَتِ الجُنْدَبُ الرَّمْضَا=ءَ"},{"kind":"arabic","text_bw":"bikuraAEayohaA","text_ar":"بِكُرَاعَيْهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The locusts termed"},{"kind":"arabic","text_bw":"jndb","text_ar":"جندب"},{"kind":"italic_en","text":"struck the vehemently-hot ground with their two legs"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"tarakotuhu yarokuDu birijolihi lilomawoti","text_ar":"تَرَكْتُهُ يَرْكُضُ بِرِجْلِهِ لِلْمَوْتِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I left him striking the ground with his foot previously to death:"},{"kind":"text","text":"see also 8]. (A.) [The above-mentioned phrases marked as tropical are so marked on the authority of the A: but the reason of their being so I do not see.] ―         -b2-  They also said, sometimes,"},{"kind":"arabic","text_bw":"rakaDa","text_ar":"رَكَضَ"},{"kind":"arabic","text_bw":"AlT~aAy^iru","text_ar":"الطَّايِرُ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"The bird moved his wings in flying:"},{"kind":"text","text":"(S:) the inf. n.,"},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":", signifying (tropical:)  the act of"},{"kind":"italic_en","text":"moving the wing:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"arabic","text_bw":"AlT~aAy^ru","text_ar":"الطَّايرُ"},{"kind":"arabic","text_bw":"yarokuDu bijanaAHayohi","text_ar":"يَرْكُضُ بِجَنَاحَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The bird moves his wings, and puts them back against his body:"},{"kind":"text","text":"(A, TA:) or the former of these two phrases means (assumed tropical:)"},{"kind":"italic_en","text":"the bird was quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, in his flying."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":"also signifies The act of"},{"kind":"italic_en","text":"impelling;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"dafoEN","text_ar":"دَفْعٌ"},{"kind":"text","text":": and the"},{"kind":"italic_en","text":"urging"},{"kind":"text","text":"a horse"},{"kind":"italic_en","text":"to run,"},{"kind":"text","text":"(A, K, TA,) ["},{"kind":"italic_en","text":"by striking"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg:"},{"kind":"text","text":"(TA:) the"},{"kind":"italic_en","text":"striking"},{"kind":"text","text":"a beast"},{"kind":"italic_en","text":"with one's feet"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"legs, to urge him:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"putting"},{"kind":"text","text":"him"},{"kind":"italic_en","text":"in motion, whether he go on or not."},{"kind":"text","text":"(As.) You say,"},{"kind":"arabic","text_bw":"rakaDotu Alfarasa birijoliY","text_ar":"رَكَضْتُ الفَرَسَ بِرِجْلِى"},{"kind":"italic_en","text":"I urged the horse to run, with my foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg."},{"kind":"text","text":"(S, O, Msb. *) And"},{"kind":"arabic","text_bw":"rakaDa Ald~aAb~apa","text_ar":"رَكَضَ الدَّابَّةَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He struck the sides of the beast with his foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"rakaDa Ald~aAb~apa birijolK","text_ar":"رَكَضَ الدَّابَّةَ بِرِجْلٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"birijolayoni","text_ar":"بِرِجْلَيْنِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He struck the beast to urge it with a foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"with two feet"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"legs."},{"kind":"text","text":"(A.) ―         -b4-  And from frequency of usage of the phrase"},{"kind":"arabic","text_bw":"rakaDotu Alfarasa","text_ar":"رَكَضْتُ الفَرَسَ"},{"kind":"text","text":", originated the saying"},{"kind":"arabic","text_bw":"rakaDa Alfarasu","text_ar":"رَكَضَ الفَرَسُ"},{"kind":"text","text":", (AZ, * S, Mgh, Msb,) meaning (tropical:)"},{"kind":"italic_en","text":"The horse ran:"},{"kind":"text","text":"(S, Mgh: *) which some disallow; but without reason, since it has been transmitted by a good authority: (Msb:) it is disallowed by As: (TA:) [and J says,] the correct phrase is"},{"kind":"arabic","text_bw":"rukiDa Alfarasu","text_ar":"رُكِضَ الفَرَسُ"},{"kind":"text","text":": (S:) or you say,"},{"kind":"arabic","text_bw":"rukiDa Alfarasu farakaDa huwa","text_ar":"رُكِضَ الفَرَسُ فَرَكَضَ هُوَ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"The horse was urged to run,"},{"kind":"text","text":"] (assumed tropical:)"},{"kind":"italic_en","text":"and he ran:"},{"kind":"text","text":"(K:) and"},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":"signifies (assumed tropical:)  the act of"},{"kind":"italic_en","text":"running:"},{"kind":"text","text":"(K, in another place in this art.:) and (assumed tropical:)  the act of"},{"kind":"italic_en","text":"fleeing:"},{"kind":"text","text":"whence, [in the Kur xxi. 12],"},{"kind":"arabic","text_bw":"A_i*aA humo minohaA yarokuDuwna","text_ar":"اـِذَا هُمْ مِنْهَا يَرْكُضُونَ"},{"kind":"text","text":"(K) (assumed tropical:)"},{"kind":"italic_en","text":"lo, they fled from it,"},{"kind":"text","text":"from punishment: (Zj:) or (assumed tropical:)"},{"kind":"italic_en","text":"were routed, and fled from it:"},{"kind":"text","text":"(Fr:) or"},{"kind":"italic_en","text":"they ran from it:"},{"kind":"text","text":"(Mgh:) [for]"},{"kind":"arabic","text_bw":"rakaDa Alr~ajulu","text_ar":"رَكَضَ الرَّجُلُ"},{"kind":"text","text":"signifies (assumed tropical:)  The man"},{"kind":"italic_en","text":"fled,"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"ran."},{"kind":"text","text":"(ISh.) [Hence,]"},{"kind":"arabic","text_bw":"rakaDati Aln~ujuwmu fiY Als~amaA='i","text_ar":"رَكَضَتِ النُّجُومُ فِى السَّمَا=ءِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The stars moved along in the sky."},{"kind":"text","text":"(A, TA.) [And hence,]"},{"kind":"arabic","text_bw":"rakoDN","text_ar":"رَكْضٌ"},{"kind":"text","text":"also signifies (assumed tropical:)  A man's"},{"kind":"italic_en","text":"going along by both his legs together."},{"kind":"text","text":"(TA.) ―         -b5-  You also say,"},{"kind":"arabic","text_bw":"rakaDahu AlbaEiyru","text_ar":"رَكَضَهُ البَعِيرُ"},{"kind":"text","text":"(S, A, Msb) (tropical:)"},{"kind":"italic_en","text":"The camel struck him with his kind leg:"},{"kind":"text","text":"(S, Msb:) like as you say,"},{"kind":"arabic","text_bw":"ramaHahu Alfarasu","text_ar":"رَمَحَهُ الفَرَسُ"},{"kind":"text","text":": (A, Msb: *) but you should not say, [when a camel is the agent,]"},{"kind":"arabic","text_bw":"ramaHahu","text_ar":"رَمَحَهُ"},{"kind":"text","text":". (Yaakoob, S.) And"},{"kind":"arabic","text_bw":"rakaDa AlA^aroDa","text_ar":"رَكَضَ الاَرْضَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alv~awoba","text_ar":"الثَّوْبَ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He struck the ground,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, with his foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlmaroA^apu tarokuDu *uyuwlahaA waxaloxaAlahaA","text_ar":"المَرْاَةُ تَرْكُضُ ذُيُولَهَا وَخَلْخَالَهَا"},{"kind":"arabic","text_bw":"birijolayohaA A_i*aA ma$ato","text_ar":"بِرِجْلَيْهَا اـِذَا مَشَتْ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The woman kicks her skirts and her anklets with her feet when she walks"},{"kind":"text","text":"]. (A, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"rakaDati Alqawosu Als~ahoma","text_ar":"رَكَضَتِ القَوْسُ السَّهْمَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The bow propelled the arrow."},{"kind":"text","text":"(A, TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"rakaDotu","text_ar":"رَكَضْتُ"},{"kind":"arabic","text_bw":"Alqawosa","text_ar":"القَوْسَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I shot with the bow."},{"kind":"text","text":"(A, TA.) ―         -b8-  And"},{"kind":"arabic","text_bw":"huwa laA yarokuDu AlmiHojana","text_ar":"هُوَ لَا يَرْكُضُ المِحْجَنَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He does not defend himself:"},{"kind":"text","text":"(K:) or (assumed tropical:)"},{"kind":"italic_en","text":"he is not angry and vexed at a thing, nor does he defend himself."},{"kind":"text","text":"(IAar, L.) ―         -b9-  And"},{"kind":"arabic","text_bw":"rakaDa Aln~aAra baAlmirokaDi","text_ar":"رَكَضَ النَّارَ بَالمِرْكَضِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He stirred the fire with the"},{"kind":"arabic","text_bw":"markaD","text_ar":"مَركَض"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","A","K","Msb","TA","Mgh","Zj","Fr"]}]}}