ions":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"masculine plural of أَغْبَر (ʔaḡbar)","tags":["form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine plural of غَابِر (ḡābir)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":["/ɣubr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31334","headword_ar":"غَبَرَ","root":"gbr","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"gubuwrN","text_ar":"غُبُورٌ"},{"kind":"text","text":", (Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, S)"},{"kind":"italic_en","text":"remained, lasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued:"},{"kind":"text","text":"(S, Msb, TA:) and (Msb)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, JK)"},{"kind":"italic_en","text":"tarried, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited."},{"kind":"text","text":"(JK, Zbd, Msb, K.) ―         -b2-  And"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, passed, passed away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away."},{"kind":"text","text":"(Msb, K.) It is sometimes used in this latter sense; (Msb;) and thus it has two contr. significations. (Msb, K.) ―         -b3-  And"},{"kind":"italic_en","text":"It was future."},{"kind":"text","text":"(KL.)       -A2-  See also 9.       -A3-"},{"kind":"arabic","text_bw":"gabira","text_ar":"غَبِرَ"},{"kind":"text","text":": see 5, last two sentences. ―         -b2-  Also, this last, aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"gabarN","text_ar":"غَبَرٌ"},{"kind":"text","text":", (S,) said of a wound, (S, K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a corrupt state:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"it became in a healing state, and then became recrudescent:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"it was always recrudescent:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it became in a healing state upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over, corruptness:"},{"kind":"text","text":"(IKtt, TA:) or"},{"kind":"italic_en","text":"it healed externally while in a withering state internally."},{"kind":"text","text":"(L.) ―         -b3-  And [hence, perhaps,]"},{"kind":"arabic","text_bw":"gabira","text_ar":"غَبِرَ"},{"kind":"text","text":"said of a man, (assumed tropical:)"},{"kind":"italic_en","text":"He bore rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hid enmity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"violent hatred, in his heart."},{"kind":"text","text":"(IKtt, TA.)"}],"source_refs":["S","Msb","K","TA","IKtt"]}]}}