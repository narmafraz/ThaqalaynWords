{"lemma":"أَفاضَ","slug":"أَفاضَ","root":"ف.#.ض","root_slug":"ف-_-ض","root_link":"/words/roots/ف-_-ض","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَفَضْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَفَضْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَفَضْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَفَضْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَفَضْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَفاضَ","in_corpus":true,"count":20,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَفاضَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَفاضا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَفاضَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَفاضُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَفَضْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُفَض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُفِض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُفاض","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُفِيض","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُفاضِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُفاضِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُفِيضِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُفِيضِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُفاضانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُفاضا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُفِيضا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُفاضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفاضُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفِيضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفِيضُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفِض","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُفاض","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُفِيض","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفِض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُفاض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُفِيض","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفاضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفاضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفِيضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفاضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفاضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفِيضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفِيضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفاضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفاضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفِيضُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفِيضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفَضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَفَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَفَضْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُفاض","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفاض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفِيض","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفِيض","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":75,"cross_references":{"qac":{"found":true,"lemma_key":"أَفاضَ","root":"فيض","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n34962"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D8%A7%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pour out","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34962","headword_ar":"افاض","root":"fyD","body":[{"kind":"text","text":": see 1, first sentence.       -A2-"},{"kind":"italic_en","text":"He filled"},{"kind":"text","text":"a vessel"},{"kind":"italic_en","text":"so that it overflowed:"},{"kind":"text","text":"(S, M, O, K:) or [simply]"},{"kind":"italic_en","text":"he filled"},{"kind":"text","text":"a vessel, (M, Msb,) accord. to Lh; but the former. [says ISd,] in my opinion, is the correct signification. (M.) ―         -b2-"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"water, and tears, and the like,"},{"kind":"italic_en","text":"to run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flow;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to pour out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to pour out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, vehemently; to gush out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth:"},{"kind":"text","text":"(M:)"},{"kind":"italic_en","text":"he poured"},{"kind":"text","text":"[water &c.]"},{"kind":"italic_en","text":"out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"he poured"},{"kind":"text","text":"water"},{"kind":"italic_en","text":"out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth, copiously."},{"kind":"text","text":"(Mgh.) You say,"},{"kind":"arabic","text_bw":"AfAD AlmaA='a EalaY nafosihi","text_ar":"افاض المَا=ءَ عَلَى نَفْسِهِ"},{"kind":"text","text":", (S, O, K,) or"},{"kind":"arabic","text_bw":"ElY jasadihi","text_ar":"على جَسَدِهِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He poured the water"},{"kind":"text","text":"(S, O, Msb, K)"},{"kind":"italic_en","text":"upon himself,"},{"kind":"text","text":"(S, O, K,) or"},{"kind":"italic_en","text":"upon his body."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AfAD dumuwEahu","text_ar":"افاض دُمُوعَهُ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"damoEahu","text_ar":"دَمْعَهُ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He poured forth his tears."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AfADt AlEayonu Ald~amoEa","text_ar":"افاضت العَيْنُ الدَّمْعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The eye poured forth tears"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AfAD A@ll~`hu","text_ar":"افاض ا@للّٰهُ"},{"kind":"arabic","text_bw":"Alxayora","text_ar":"الخَيْرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"God made good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to abound."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"AfAD Ealayohi Ald~iroEa","text_ar":"افاض عَلَيْهِ الدِّرْعَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He put on him the coat of mail:"},{"kind":"text","text":"like as you say"},{"kind":"arabic","text_bw":"Sab~ahaA","text_ar":"صَبَّهَا"},{"kind":"text","text":"[lit he poured it]. (A, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"A^afaADuwA mino EarafaAtK","text_ar":"اَفَاضُوا مِنْ عَرَفَاتٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They pushed on, pressed on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went quickly,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"dafaEuwA","text_ar":"دَفَعُوا"},{"kind":"text","text":", (S, Mgh, O, Msb, K,) or"},{"kind":"arabic","text_bw":"AinodafaEuwA","text_ar":"اِنْدَفَعُوا"},{"kind":"text","text":", (M, A,)"},{"kind":"italic_en","text":"with multitude,"},{"kind":"text","text":"(M, Mgh, O,)"},{"kind":"italic_en","text":"from 'Arafát,"},{"kind":"text","text":"(S, M, A, Mgh, O, Msb, K,) to Minè, (S, M, O,) exclaiming"},{"kind":"arabic","text_bw":"lab~ayoka","text_ar":"لَبَّيْكَ"},{"kind":"text","text":": (M:) or"},{"kind":"italic_en","text":"they returned, and dispersed themselves from 'Arafát:"},{"kind":"text","text":"(O, K:) or"},{"kind":"italic_en","text":"they hastened from 'Arafát"},{"kind":"text","text":"to another place: (K:) the last rendering is taken from Ibn-'Arafeh; and agreeably with all of these renderings, the phrase in the Kur [ii. 194],"},{"kind":"arabic","text_bw":"faA_i*aA A^afaDotumo mino EarafaAtK","text_ar":"فَاـِذَا اَفَضْتُمْ مِنْ عَرَفَاتٍ"},{"kind":"text","text":", has been explained: (TA:) and [in like manner,] you say"},{"kind":"arabic","text_bw":"AfADwA mina minaY A_ilaY","text_ar":"افاضوا مِنَ مِنَى اـِلَى"},{"kind":"arabic","text_bw":"mak~ipa","text_ar":"مَكِّةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They returned from Mine to Mekkeh;"},{"kind":"text","text":"on the day of the sacrifice: (Msb:)"},{"kind":"arabic","text_bw":"A_ifaADapN","text_ar":"اـِفَاضَةٌ"},{"kind":"text","text":"signifies (tropical:)  the"},{"kind":"italic_en","text":"advancing, and pushing on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing on,"},{"kind":"text","text":"in journeying, or pace, (A, * TA,) and the like, (A,)"},{"kind":"italic_en","text":"with multitude,"},{"kind":"text","text":"and is only after a state of separation and congregation: (TA:) it is from the same word as signifying the “ pouring out, or forth; ” (A, O, TA,) or from"},{"kind":"arabic","text_bw":"AfAD AlmaA='a","text_ar":"افاض المَا=ءَ"},{"kind":"text","text":"signifying “ he poured the water out, or forth, copiously ” (Mgh:) and the original expression is"},{"kind":"arabic","text_bw":"AfAD nafosahu","text_ar":"افاض نَفْسَهُ"},{"kind":"text","text":". or"},{"kind":"arabic","text_bw":"raAHilatahu","text_ar":"رَاحِلَتَهُ"},{"kind":"text","text":"; but they omit the objective complement, and hence the verb resembles one that is intrans.: (O, TA:) or"},{"kind":"arabic","text_bw":"AfADp","text_ar":"افاضة"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"quickly impelling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urging"},{"kind":"text","text":"[a beast]"},{"kind":"italic_en","text":"to run, with one's foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feet or legs:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AfAD","text_ar":"افاض"},{"kind":"text","text":","},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a rider)"},{"kind":"italic_en","text":"made his camel to exert himself beyond measure, to go a quick run, between the utmost rate and what is less than that;"},{"kind":"arabic","text_bw":"AfADp","text_ar":"افاضة"},{"kind":"text","text":"denoting"},{"kind":"italic_en","text":"the half"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the full rate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the run of camels having riders upon these;"},{"kind":"text","text":"and being only applied when they have riders upon them: (Khálid Ibn-Jembeh:) and every"},{"kind":"arabic","text_bw":"dafoEap","text_ar":"دَفْعَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"act of pushing on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressing on,"},{"kind":"text","text":"] is termed"},{"kind":"arabic","text_bw":"A_ifaADapN","text_ar":"اـِفَاضَةٌ"},{"kind":"text","text":". (S, Msb, K.) Hence,"},{"kind":"arabic","text_bw":"TawaAfu AlA_ifaADapi","text_ar":"طَوَافُ الاـِفَاضَةِ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"The circuiting"},{"kind":"text","text":"[around the Kaạbeh]"},{"kind":"italic_en","text":"on the return from Mine to Mekkeh;"},{"kind":"text","text":"(Msb, TA) on the day of the sacrifice: (TA:) or"},{"kind":"italic_en","text":"the circuiting of visitation."},{"kind":"text","text":"(Mgh.) ―         -b6-"},{"kind":"arabic","text_bw":"AfADwA fiY AlHadiyvi","text_ar":"افاضوا فِى الحَدِيثِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They pushed on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressed on, in discourse;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AinodafaEuwA","text_ar":"اِنْدَفَعُوا"},{"kind":"text","text":": (Lh, S, M, A, O,)"},{"kind":"italic_en","text":"they entered thereinto; launched forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut, thereinto:"},{"kind":"text","text":"(Lh, M, O;)"},{"kind":"italic_en","text":"they were large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"copious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profuse, therein;"},{"kind":"text","text":"(O, TA:) or"},{"kind":"italic_en","text":"they dilated therein"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"they began, commenced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon, discourse:"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"AstfADwhu","text_ar":"استفاضوهُ","orth_type":"arrow"},{"kind":"text","text":", (M, Msb,) accord. to some; (Msb;) but this latter is disallowed by most; (M;) or by the skilful, (Msb.) You say also,"},{"kind":"arabic","text_bw":"AfAD fiY EamalK","text_ar":"افاض فِى عَمَلٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He entered into an action,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employment;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"pushed on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pressed on, therein:"},{"kind":"text","text":"(Bd in x. 62:) or"},{"kind":"italic_en","text":"he began it, commenced it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entered upon it."},{"kind":"text","text":"(Jel, ibid.) ―         -b7-"},{"kind":"arabic","text_bw":"AfAD baAl$~ayo'i","text_ar":"افاض بَالشَّيْءِ"},{"kind":"italic_en","text":"He impelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thrust, with the thing:"},{"kind":"text","text":"(M:)"},{"kind":"italic_en","text":"he cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"threw, the thing."},{"kind":"text","text":"(M, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"AfAD AlbaEiyru","text_ar":"افاض البَعِيرُ"},{"kind":"arabic","text_bw":"bijir~atihi","text_ar":"بِجِرَّتِهِ"},{"kind":"text","text":", (Lh, S, M, A, O,) and (S, O)"},{"kind":"arabic","text_bw":"AfAD","text_ar":"افاض"},{"kind":"text","text":"alone, (S, O, K,) and"},{"kind":"arabic","text_bw":"bijir~atihi","text_ar":"بِجِرَّتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"faADa","text_ar":"فَاضَ","orth_type":"arrow"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The camel propelled his cud"},{"kind":"text","text":"(Lh, S, M, A, K)"},{"kind":"italic_en","text":"from his inside,"},{"kind":"page_break","n":2473},{"kind":"text","text":"(Lh, M, A,) or"},{"kind":"italic_en","text":"from his stomach,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and expelled it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ejected it:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"cast it forth in a scattered and copious state:"},{"kind":"text","text":"or it means ["},{"kind":"italic_en","text":"he made to be heard"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the sound of his cud, and of his chewing."},{"kind":"text","text":"(M.) ―         -b9-"},{"kind":"arabic","text_bw":"maA AfAD bikalimapK","text_ar":"مَا افاض بِكَلِمَةٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He did not make clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuous, a word,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentence."},{"kind":"text","text":"(Msb, TA.) [And"},{"kind":"arabic","text_bw":"mA AfAD bklmp","text_ar":"ما افاض بكلمة"},{"kind":"text","text":"signifies the same.] ―         -b10-"},{"kind":"arabic","text_bw":"AfAD biAlqidaAHi","text_ar":"افاض بِالقِدَاحِ"},{"kind":"text","text":", (S, M, A, O, K,) and"},{"kind":"arabic","text_bw":"EalaY AlqidaAHi","text_ar":"عَلَى القِدَاحِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"biAlqidaAHi","text_ar":"بِالقِدَاحِ"},{"kind":"text","text":", for prepositions stand in the places of other prepositions, (S, O,) and"},{"kind":"arabic","text_bw":"AfAD AlqidaAHa","text_ar":"افاض القِدَاحَ"},{"kind":"text","text":", (O, K,) (tropical:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Daraba","text_ar":"ضَرَبَ"},{"kind":"arabic","text_bw":"biAlqidaAHi","text_ar":"بِالقِدَاحِ"},{"kind":"text","text":"[which has two significations:"},{"kind":"italic_en","text":"He turned about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shuffled, the gaming-arrows:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he played with the gaming-arrows"},{"kind":"text","text":"]: (S, M, A, O, K:) and"},{"kind":"arabic","text_bw":"A^ajaAlahaA","text_ar":"اَجَالَهَا"},{"kind":"text","text":"[which has the former of the above significations]: or"},{"kind":"italic_en","text":"he dealt them forth."},{"kind":"text","text":"(TA.) Aboo-Dhu-eyb says, describing a [wild] he-ass and his she-asses,"},{"kind":"quote","text":"fakaA^an~ahun~a ribaAbapN wakaA^an~ahu\n                      \n                     \n                        yasarN yufiyDu EalaY AlqidaAHi wayaSodaEu"},{"kind":"text","text":"(S, TA) (tropical:)  ["},{"kind":"italic_en","text":"And it was as though they were a bundle of gaming-arrows, and as though he were a shuffler thereof, shuffling"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"dealing out the arrows, and deciding, and making known"},{"kind":"text","text":"what he produced: (TA:) or, accord. to Kh,"},{"kind":"italic_en","text":"and speaking with his loudest voice,"},{"kind":"text","text":"saying “ The arrow of such a one has won, ” or “ This is the arrow of such a one: ” or, accord. to some,"},{"kind":"italic_en","text":"distributing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispensing,"},{"kind":"text","text":"by means of the arrows: (TA in art."},{"kind":"arabic","text_bw":"SdE","text_ar":"صدع"},{"kind":"text","text":":) by"},{"kind":"arabic","text_bw":"EalaY AlqidaAHi","text_ar":"عَلَى القِدَاحِ"},{"kind":"text","text":"is meant"},{"kind":"arabic","text_bw":"biAlqidaAHi","text_ar":"بِالقِدَاحِ"},{"kind":"text","text":". (S voce"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":".) One relation of this verse substitutes"},{"kind":"arabic","text_bw":"yaxuwDu","text_ar":"يَخُوضُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"yufiyDu","text_ar":"يُفِيضُ"},{"kind":"text","text":". (TA.) Az says that"},{"kind":"arabic","text_bw":"A_ifaAD","text_ar":"اـِفَاض"},{"kind":"text","text":"[a mistranscription for"},{"kind":"arabic","text_bw":"A_ifaADapN","text_ar":"اـِفَاضَةٌ"},{"kind":"text","text":"] is always a consequence of a state of separation, or dispersion, and abundance, or copiousness. (TA.) ―         -b11-  Hence the saying in a trad. respecting a thing picked up from the ground,"},{"kind":"arabic","text_bw":"vum~a A^afiDohaA mino maAlika","text_ar":"ثُمَّ اَفِضْهَا مِنْ مَالِكَ"},{"kind":"text","text":", [app. a mistake for"},{"kind":"arabic","text_bw":"fiY maAlika","text_ar":"فِى مَالِكَ"},{"kind":"text","text":",] i. e. (assumed tropical:)"},{"kind":"italic_en","text":"Then put thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"throw thou, it, and mix it, among thy property."},{"kind":"text","text":"(TA.) ―         -b12-"},{"kind":"arabic","text_bw":"A^ufiyDato","text_ar":"اُفِيضَتْ"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"became wide in the belly:"},{"kind":"text","text":"[as though spread out:] or"},{"kind":"italic_en","text":"she became large in the belly, and flabby in flesh."},{"kind":"text","text":"(M.)       -A3-"},{"kind":"arabic","text_bw":"AfAD","text_ar":"افاض"},{"kind":"arabic","text_bw":"AlmaroA^apa","text_ar":"المَرْاَةَ"},{"kind":"italic_en","text":"He made the"},{"kind":"arabic","text_bw":"masolakaAni","text_ar":"مَسْلَكَانِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"vagina and rectum"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the woman to become one,"},{"kind":"text","text":"on the occasion of devirgination; (M;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^afoDaAhaA","text_ar":"اَفْضَاهَا"},{"kind":"text","text":"[from which it is app. formed by transposition, as is indicated in the M.]. (O, TA.)"}],"source_refs":["S","M","O","K","Msb","A","TA","Mgh","Lh"]}]},"classical_definitions":null}