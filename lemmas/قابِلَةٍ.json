{"lemma":"قابِلَةٍ","slug":"قابِلَةٍ","root":"ق.ب.ل","root_slug":"ق-ب-ل","root_link":"/words/roots/ق-ب-ل","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"قابِل","root":"قبل","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n42510"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D8%A8%D9%90%D9%84%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stand exactly opposite, to be opposite, to be face to face"},{"pos":"verb","gloss":"to confront, to face, to counter"},{"pos":"verb","gloss":"to meet, to encounter, to visit, to call on"},{"pos":"verb","gloss":"to interview, to grant an audience, to receive in audience"},{"pos":"verb","gloss":"to repay, to return"},{"pos":"verb","gloss":"to compare, to collate"},{"pos":"adj","gloss":"active participle of قَبِلَ (qabila)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"susceptible, subject, receptive [with لِ (li) ‘to something’]; -able, -ible","examples":[{"text":"قَابِل لِٱلاِحْتِرَاق","english":"burnable"}]}]},"etymology":null,"ipa":["/qaː.ba.la/","/qaː.bil/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42510","headword_ar":"قَابَلَهُ","root":"qbl","body":[{"kind":"italic_en","text":"He faced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fronted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was opposite to"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over against, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, * K.) See also ↓"},{"kind":"arabic","text_bw":"Aisotaqobalahu","text_ar":"اِسْتَقْبَلَهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, corresponded to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"qaAbalahu binafosihi","text_ar":"قَابَلَهُ بِنَفْسِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He opposed himself to him"},{"kind":"text","text":"]. (TA, art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":".) See"},{"kind":"arabic","text_bw":"EaraDa lahu","text_ar":"عَرَضَ لَهُ"},{"kind":"text","text":"; and see 4. ―         -b3-"},{"kind":"arabic","text_bw":"qaAbala","text_ar":"قَابَلَ"},{"kind":"arabic","text_bw":"ka*aA bika*aA","text_ar":"كَذَا بِكَذَا"},{"kind":"italic_en","text":"He requited such a thing with such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave, such a thing in return for such a thing;"},{"kind":"text","text":"as good for good, evil for evil, good for evil, or evil for good. (The Lexicons passim.) ―         -b4-"},{"kind":"italic_en","text":"He counteracted such a thing with such a thing."},{"kind":"text","text":"―         -b5-"},{"kind":"italic_en","text":"He compared such a thing"},{"kind":"text","text":"&c. ―         -b6-"},{"kind":"arabic","text_bw":"quwbila","text_ar":"قُوبِلَ"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"italic_en","text":"It was compensated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requited, by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with, such a thing:"},{"kind":"text","text":"see an ex. of the part. n. voce"},{"kind":"arabic","text_bw":"gunomN","text_ar":"غُنْمٌ"},{"kind":"text","text":". ―         -b7-"},{"kind":"arabic","text_bw":"qaAbala Al$~aAp","text_ar":"قَابَلَ الشَّاة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daAbara Al$Ap","text_ar":"دَابَرَ الشاة"},{"kind":"text","text":". ―         -b8-"},{"kind":"arabic","text_bw":"farasN quwbila mino","text_ar":"فَرَسٌ قُوبِلَ مِنْ"},{"kind":"