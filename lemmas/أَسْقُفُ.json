:"text","text":"[or ceiling, or roof,] in height; (TA;) and so ↓"},{"kind":"arabic","text_bw":"musaq~afN","text_ar":"مُسَقَّفٌ","orth_type":"arrow"},{"kind":"text","text":": (O, K:) or"},{"kind":"italic_en","text":"thick and big in the bones:"},{"kind":"text","text":"(K:) and [simply]"},{"kind":"italic_en","text":"bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bowed:"},{"kind":"text","text":"(TA:) and, applied to an ostrich,"},{"kind":"italic_en","text":"crooked in the neck"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"and the legs:"},{"kind":"text","text":"(TA:) fem. as above; (K;) which is applied to a female ostrich as meaning"},{"kind":"italic_en","text":"long and crooked in the legs:"},{"kind":"text","text":"(O:) or to a she-camel as meaning"},{"kind":"italic_en","text":"long in the hind legs,"},{"kind":"text","text":"and in like manner applied to a she-ostrich. (JK.) ―         -b2-  And, applied to a camel,"},{"kind":"italic_en","text":"Having no fur upon him."},{"kind":"text","text":"(K.)"}],"source_refs":["S","TA","K","O"]},{"entry_id":"n20116","headword_ar":"اُسْقُفٌ","root":"sqf","body":[{"kind":"text","text":": see the next preceding paragraph: ―         -b2-  and the next following also."}],"source_refs":[]},{"entry_id":"n20117","headword_ar":"اُسْقُفٌّ","root":"sqf","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^usoqufN","text_ar":"اُسْقُفٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) as also ↓"},{"kind":"arabic","text_bw":"saqofN","text_ar":"سَقْفٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"saqofN","text_ar":"سَقْفٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) [each a variation of] a foreign word used by the Arabs, (TA,) [from the Greek"},{"kind":"arabic","text_bw":"ἐπίσκοπος","text_ar":"ἐπίσκοπος","orth_type":"plain"},{"kind":"text","text":","},{"kind":"italic_en","text":"A bishop;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"a headman of the Christians"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"in religion;"},{"kind":"text","text":"(S, K;) or [more exactly]"},{"kind":"italic_en","text":"one who is above the"},{"kind":"arabic","text_bw":"qisiys","text_ar":"قِسِيس"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"presbyter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"priest"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and below the"},{"kind":"arabic","text_bw":"maToraAn","text_ar":"مَطْرَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"metropolitan"},{"kind":"text","text":"]: (K:) or"},{"kind":"italic_en","text":"one who is learned"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in their religion:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a king who affects lowliness in his gait:"},{"kind":"text","text":"(K: [a very strange explanation:]) pl."},{"kind":"arabic","text_bw":"A^asaAqifapN","text_ar":"اَسَاقِفَةٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"A^asaAqifu","text_ar":"اَسَاقِفُ"},{"kind":"text","text":". (K.) See also"},{"kind":"arabic","text_bw":"A^asoqafu","text_ar":"اَسْقَفُ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K","TA"]}]}}