{"lemma":"حَمَلَ","slug":"حَمَلَ","root":"ح.م.ل","root_slug":"ح-م-ل","root_link":"/words/roots/ح-م-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَمَلْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَمَلْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَمَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَمَلْتُم","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَمَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَمَلَ","in_corpus":true,"count":38,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَمَلَت","in_corpus":true,"count":38,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَمَلا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَمَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَمَلُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَمَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْمِل","in_corpus":true,"count":18,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْمِلِينَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْمِلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْمِلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْمِلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْمِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْمِلُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْمِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْمِل","in_corpus":true,"count":63,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْمِل","in_corpus":true,"count":18,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْمِلانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْمِلا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْمِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْمِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْمِلُونَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْمِلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْمِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْمِل","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْمِل","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَمَلْنا","in_corpus":true,"count":12,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَمَلْتُ","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":248,"cross_references":{"qac":{"found":true,"lemma_key":"حَمَلَ","root":"حمل","pos":"V","occurrence_count":41},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":35},"lanes":{"found":true,"entry_ids":["n9170","n9171","n9172"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%85%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to carry (to transport by lifting), to transport, to convey"},{"pos":"verb","gloss":"to carry","examples":[{"text":"أن تُصبح خاليًا من الرحمة الله هو أن تحمل علامة غضب الله.","english":"To be devoid of God's mercy is to carry the mark of God's wrath."}]},{"pos":"verb","gloss":"to bring"},{"pos":"verb","gloss":"to pick up, to lift (an item)"},{"pos":"verb","gloss":"to transmit (knowledge, etc.)","tags":["figuratively"]},{"pos":"verb","gloss":"to assume"},{"pos":"verb","gloss":"to show, to evince"},{"pos":"verb","gloss":"to harbor"},{"pos":"verb","gloss":"to know (a book) by heart"},{"pos":"verb","gloss":"to make, to cause"},{"pos":"verb","gloss":"to convince"},{"pos":"verb","gloss":"to tempt"},{"pos":"verb","gloss":"to link, to correlate"},{"pos":"verb","gloss":"to consider"},{"pos":"verb","gloss":"to exert"},{"pos":"verb","gloss":"to attack"},{"pos":"verb","gloss":"to offend"},{"pos":"verb","gloss":"to learn"},{"pos":"verb","gloss":"to take (a risk)"},{"pos":"verb","gloss":"to hold (a degree)"},{"pos":"verb","gloss":"to get pregnant"},{"pos":"verb","gloss":"to bear fruit (of a tree)","examples":[{"text":"فاغرة (var. فاكرة).\nالماهية: حب يشبه الحمص له حب كالمحلب وفي جوفه حب أسود كالشهدانج يحمل من السفالة.\nالطبع: حارة يابسة في الثالثة.\nالخواص: فيها تحليل وقبض.\nأعضاء الغذاء: يدخل في الأدوية المصلحة للمعدة والكبد الباردتين وينفع من سوء الاستمراء البارد.\nأعضاء النفض: ينفع من الإسهال البارد ويعقل البطن.","english":"Sichuan pepper:\nIts essence: The fruit resembles chickpeas, it has fruits like mahaleb cherry, and in its inner there is a black fruit like hempseed, born from below.\nIts nature: Hot and dry in the third degree.\nIts peculiarities: In it there is discharging and constipation.\nAlimentary organs: It is put into drugs by reason of availing the stomach and the liver when they are cold and it is useful against calamities of cold appetite.\nExcretory organs: It helps against cold diarrhoea and constricts the belly."}]},{"pos":"verb","gloss":"to derive, to trace"},{"pos":"verb","gloss":"to attribute, to ascribe"},{"pos":"verb","gloss":"to cause to agree grammatically"},{"pos":"verb","gloss":"to cause or ask to carry, deliver, etc.","tags":["ditransitive"]},{"pos":"verb","gloss":"to burden","tags":["ditransitive"],"examples":[{"text":"رَبَّنَا وَلَا تُحَمِّلْنَا مَا لَا طَاقَةَ لَنَا بِهِ","english":"Our Lord, and burden us not with that which we have no ability to bear."}]},{"pos":"verb","gloss":"to impose","tags":["ditransitive"]},{"pos":"noun","gloss":"verbal noun of حَمَلَ (ḥamala) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"carrying"},{"pos":"noun","gloss":"pregnancy"},{"pos":"noun","gloss":"embryo"},{"pos":"noun","gloss":"fruit of a tree"},{"pos":"noun","gloss":"burden, load"},{"pos":"noun","gloss":"lamb"}]},"etymology":null,"ipa":["/ħa.ma.la/","/ħam.ma.la/","/ħaml/","/ħiml/","/ħa.mal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9170","headword_ar":"حَمْلٌ","root":"Hml","body":[{"kind":"text","text":"[inf. n. of 1, q. v. ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"Gestation:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"A_inoYN","text_ar":"اـِنْىٌ"},{"kind":"text","text":". ―         -b3-  And hence,] (assumed tropical:)  The"},{"kind":"italic_en","text":"young that is borne in the womb"},{"kind":"text","text":"(M, K) of any animal; (M, TA;) and (assumed tropical:)  the"},{"kind":"italic_en","text":"fruit"},{"kind":"text","text":"of a tree, (IDrd, S, M, Msb, K,) as also ↓"},{"kind":"arabic","text_bw":"HimolN","text_ar":"حِمْلٌ","orth_type":"arrow"},{"kind":"text","text":": (IDrd, S, M, K:) or the former, (assumed tropical:)  the"},{"kind":"italic_en","text":"thing that is in a belly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the head of a tree:"},{"kind":"text","text":"(ISk, S, M, Mgh, K:) and ↓ the latter,"},{"kind":"italic_en","text":"a thing borne,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"on the back;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a load,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burden;"},{"kind":"text","text":"] (Msb;) the"},{"kind":"italic_en","text":"thing that is on the back"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the head:"},{"kind":"text","text":"(ISk, S, M, Mgh, K:) or the former, (assumed tropical:)"},{"kind":"italic_en","text":"a burden that is borne internally;"},{"kind":"text","text":"as the"},{"kind":"italic_en","text":"young in the belly,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"water in the clouds,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"fruit in the tree"},{"kind":"text","text":"as being likened to the"},{"kind":"arabic","text_bw":"Hamol","text_ar":"حَمْل"},{"kind":"text","text":"of the woman: and ↓ the latter,"},{"kind":"italic_en","text":"a burden that is borne externally;"},{"kind":"text","text":"as the"},{"kind":"italic_en","text":"thing that is borne on the back:"},{"kind":"text","text":"(Er-Rághib, TA:) or [when applied to fruit] the former signifies"},{"kind":"italic_en","text":"a fruit that is internal:"},{"kind":"text","text":"and ↓ the latter,"},{"kind":"italic_en","text":"a fruit that is external:"},{"kind":"text","text":"(M, K:) or the former,"},{"kind":"italic_en","text":"fruit of a tree when large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much:"},{"kind":"text","text":"and ↓ the latter,"},{"kind":"italic_en","text":"fruit when not large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"when not much and large:"},{"kind":"text","text":"(K accord. to different copies:) this is the saying of AO, mentioned in the T, in art."},{"kind":"arabic","text_bw":"$ml","text_ar":"شمل"},{"kind":"text","text":", where, in the copies of the T, is found"},{"kind":"arabic","text_bw":"mA lm ykvr","text_ar":"ما لم يكثر"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"mAlm ykbr","text_ar":"مالم يكبر"},{"kind":"text","text":": (TA:) and the former also occurs as meaning"},{"kind":"italic_en","text":"a burden that requires, for the carrying it, a beast or the hire of a porter:"},{"kind":"text","text":"(Mgh:) the pl. [of pauc.] of the latter (Mgh, Msb, K) and of the former (K) is"},{"kind":"arabic","text_bw":"A^aHomaAlN","text_ar":"اَحْمَالٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and [the pl. of mult.] (of the former, K, * TA)"},{"kind":"arabic","text_bw":"HimaAlN","text_ar":"حِمَالٌ"},{"kind":"text","text":"(K) and (of the latter, Msb)"},{"kind":"arabic","text_bw":"HumuwlN","text_ar":"حُمُولٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"HumuwlapN","text_ar":"حُمُولَةٌ"},{"kind":"text","text":". (S, M, Mgh, Sgh.) Hence, (in a trad., TA)"},{"kind":"arabic","text_bw":"h`*aA AlHimaAlu","text_ar":"هٰذَا الحِمَالُ"},{"kind":"arabic","text_bw":"laAHimaAlu xayobara","text_ar":"لَاحِمَالُ خَيْبَرَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"This is the fruit: not the fruit of Kheyber"},{"kind":"text","text":"]: meaning that it is the fruit of Paradise; and that it does not fail, or come to an end. (M, K.) ―         -b4-  See also what next follows."}],"source_refs":["M","K","IDrd","S","Msb","ISk","Mgh","TA"]},{"entry_id":"n9171","headword_ar":"حِمْلٌ","root":"Hml","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HamolN","text_ar":"حَمْلٌ"},{"kind":"text","text":", in five places. ―         -b2-"},{"kind":"arabic","text_bw":"HumuwlN","text_ar":"حُمُولٌ"},{"kind":"text","text":", (S, M, K,) as pl. of"},{"kind":"arabic","text_bw":"HimolN","text_ar":"حِمْلٌ"},{"kind":"text","text":", (M, K,) and of ↓"},{"kind":"arabic","text_bw":"HamolN","text_ar":"حَمْلٌ","orth_type":"arrow"},{"kind":"text","text":"also, (K,) signifies likewise ["},{"kind":"italic_en","text":"Vehicles of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hawaAdij","text_ar":"هَوَادِج"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"hawodajN","text_ar":"هَوْدَجٌ"},{"kind":"text","text":"], (M, K,)"},{"kind":"italic_en","text":"whether having in them women or not:"},{"kind":"text","text":"(M, TA:) or (assumed tropical:)"},{"kind":"italic_en","text":"camels upon which are"},{"kind":"arabic","text_bw":"hwAdj","text_ar":"هوادج"},{"kind":"text","text":", (AZ, S, M,"},{"kind":"page_break","n":649},{"kind":"text","text":"O, K,)"},{"kind":"italic_en","text":"whether there be in them women or not:"},{"kind":"text","text":"(AZ, S, O:) it is not applied to camels unless they have upon them"},{"kind":"arabic","text_bw":"hwAdj","text_ar":"هوادج"},{"kind":"text","text":". (M, TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"maHomilN","text_ar":"مَحْمِلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HamuwlapN","text_ar":"حَمُولَةٌ"},{"kind":"text","text":"."}],"source_refs":["S","M","K","TA","AZ","O"]},{"entry_id":"n9172","headword_ar":"حَمَلٌ","root":"Hml","body":[{"kind":"italic_en","text":"A lamb;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"young one of the ewe in the first year;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"baraqN","text_ar":"بَرَقٌ"},{"kind":"text","text":"; (S;) or"},{"kind":"arabic","text_bw":"xaruwfN","text_ar":"خَرُوفٌ"},{"kind":"text","text":"[explained in the K in art."},{"kind":"arabic","text_bw":"xrf","text_ar":"خرف"},{"kind":"text","text":"as the"},{"kind":"italic_en","text":"male young one of the sheep-kind;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as has pastured, and become strong"},{"kind":"text","text":"]: (K, and S and Msb in art."},{"kind":"arabic","text_bw":"xrf","text_ar":"خرف"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"such as is termed"},{"kind":"arabic","text_bw":"ja*aEN","text_ar":"جَذَعٌ"},{"kind":"text","text":", [i. e."},{"kind":"italic_en","text":"a year old,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from six to ten months,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the young of the sheep-kind;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"less than this"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in age"},{"kind":"text","text":"]: (ISd, K:) accord. to Er-Rághib, it signifies"},{"kind":"arabic","text_bw":"maHomuwlN","text_ar":"مَحْمُولٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"borne,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried"},{"kind":"text","text":"]; and the young of the sheep-kind is particularly called thus because borne, or carried, on account of its impotence, and of the nearness of the time when its mother was pregnant with it: (TA:) pl."},{"kind":"arabic","text_bw":"HumolaAnN","text_ar":"حُمْلَانٌ"},{"kind":"text","text":"(S, M, Mgh, Sgh, Msb, K) and"},{"kind":"arabic","text_bw":"A^aHomaAlN","text_ar":"اَحْمَالٌ"},{"kind":"text","text":". (M, K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AlHamalu","text_ar":"الحَمَلُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The sign Aries;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain sign of the zodiac;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"the first of the signs of the zodiac;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"the constellation comprising, first, the"},{"kind":"arabic","text_bw":"$araTaAni","text_ar":"شَرَطَانِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"which are its two horns; then, the"},{"kind":"arabic","text_bw":"buTayon","text_ar":"بُطَيْن"},{"kind":"text","text":";"},{"kind":"italic_en","text":"then, the"},{"kind":"arabic","text_bw":"vuray~aA","text_ar":"ثُرَيَّا"},{"kind":"text","text":". (T, TA.) One says,"},{"kind":"arabic","text_bw":"muTironaA binawo'i AlHamali","text_ar":"مُطِرْنَا بِنَوْءِ الحَمَلِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bnw' AlT~aliY~i","text_ar":"بنوء الطَّلِىِّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"We were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have been, given rain by the auroral setting of Aries:"},{"kind":"text","text":"so the pagan Arabs used to say: see"},{"kind":"arabic","text_bw":"nawo'N","text_ar":"نَوْءٌ"},{"kind":"text","text":"; and see"},{"kind":"arabic","text_bw":"manaAzilu Alqamari","text_ar":"مَنَازِلُ القَمَرِ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"nzl","text_ar":"نزل"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"h`*aA HamalN TaAliEFA","text_ar":"هٰذَا حَمَلٌ طَالِعًا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"This is Aries, rising"},{"kind":"text","text":"]; suppressing the"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", but making the noun to remain determinate; and thus one does in the case of every name of a sign of the zodiac, preserving the"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"or suppressing it. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"HamalN","text_ar":"حَمَلٌ"},{"kind":"text","text":"signifies also (tropical:)"},{"kind":"italic_en","text":"Clouds containing much water:"},{"kind":"text","text":"(M, K, TA:) or"},{"kind":"italic_en","text":"black clouds:"},{"kind":"text","text":"(T, TA: [see also"},{"kind":"arabic","text_bw":"HawomalN","text_ar":"حَوْمَلٌ"},{"kind":"text","text":", below:]) or, as some say, the"},{"kind":"italic_en","text":"rain"},{"kind":"text","text":"["},{"kind":"italic_en","text":"supposed to be given"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the"},{"kind":"arabic","text_bw":"nawo'","text_ar":"نَوْء"},{"kind":"text","text":"[see above]"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"AlHamal","text_ar":"الحَمَل"},{"kind":"text","text":". (TA.)"}],"source_refs":["ISd","K","TA","S","M","Mgh","Sgh","Msb"]}]}}