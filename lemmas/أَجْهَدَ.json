asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجْهِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجْهِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجْهِد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجْهِد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجْهِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجْهِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجْهِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْهِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجْهِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجْهِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجْهِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُجْهِد","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجْهِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَجْهَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَجْهَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":14,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n6514"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AC%D9%92%D9%87%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6514","headword_ar":"اجهد","root":"jhd","body":[{"kind":"text","text":", as trans.: see 1, in six places. ―         -b2-  Also"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incited,"},{"kind":"text","text":"another,"},{"kind":"italic_en","text":"to strive"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"labour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"toil, to exert himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"&c.; trans. of 1 in the first of the senses assigned to it above. (JK.) ―         -b3-"},{"kind":"arabic","text_bw":"A^ujohida","text_ar":"اُجْهِدَ"},{"kind":"italic_en","text":"He was thrown into a state of difficulty, distress, affliction, trouble, inconvenience,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"Ajhd maAlahu","text_ar":"اجهد مَالَهُ"},{"kind":"italic_en","text":"He consumed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wasted, and dispersed, his property:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"gave it away, and dispersed it, altogether, here and there."},{"kind":"text","text":"(En-Nadr, TA.)       -A2-  As intrans.,"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an enemy)"},{"kind":"italic_en","text":"strove, laboured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exerted himself, in enmity,"},{"kind":"text","text":"(K, TA,)"},{"kind":"arabic","text_bw":"EalayonaA","text_ar":"عَلَيْنَا"},{"kind":"italic_en","text":"against us."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"He acted with energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with the utmost energy:"},{"kind":"text","text":"so in the phrases"},{"kind":"arabic","text_bw":"saAra","text_ar":"سَارَ"},{"kind":"arabic","text_bw":"faA^ajohada","text_ar":"فَاَجْهَدَ"},{"kind":"italic_en","text":"He marched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, and did so with energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with the utmost energy;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Halafa biA@ll~`hi","text_ar":"حَلَفَ بِا@للّٰهِ"},{"kind":"arabic","text_bw":"faA^ajohada","text_ar":"فَاَجْهَدَ"},{"kind":"italic_en","text":"He swore by God, and did so with energy,"},{"kind":"text","text":"&c.: in which cases one should not say"},{"kind":"arabic","text_bw":"fajahada","text_ar":"فَجَهَدَ"},{"kind":"text","text":". (Aboo-' Amr Ibn-El-'Alà, L.) ―         -b3-"},{"kind":"italic_en","text":"He took the course prescribed by prudence, precaution, and sound judgment,"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"italic_en","text":"in the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AiHotaATa","text_ar":"اِحْتَاطَ"},{"kind":"text","text":". (L, K.) ―         -b4-"},{"kind":"italic_en","text":"He became in a state of difficulty, embarrassment, distress, affliction, trouble, inconvenience,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue."},{"kind":"text","text":"(L.) ―         -b5-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became mixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused."},{"kind":"text","text":"(K.)       -A3-"},{"kind":"italic_en","text":"He entered upon land such as is termed"},{"kind":"arabic","text_bw":"jahaAd","text_ar":"جَهَاد"},{"kind":"text","text":":"},{"kind":"italic_en","text":"he went forth into the desert;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"into the plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open country."},{"kind":"text","text":"(JK.) ―         -b2-"},{"kind":"italic_en","text":"It rose up; rose into view; appeared."},{"kind":"text","text":"(JK.) You say,"},{"kind":"arabic","text_bw":"Ajhd liYa Alqawomu","text_ar":"اجهد لِىَ القَوْمُ"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, came within my sight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"view;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^a$orafuwA","text_ar":"اَشْرَفُوا"},{"kind":"text","text":". (AA, K.) And"},{"kind":"arabic","text_bw":"Ajhd fiyhi","text_ar":"اجهد فِيهِ"},{"kind":"arabic","text_bw":"Al$~ayobu","text_ar":"الشَّيْبُ"},{"kind":"italic_en","text":"Hoariness appeared upon him, and became much:"},{"kind":"text","text":"(TA:) or (tropical:)"},{"kind":"italic_en","text":"became much, and spread:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"became much, and was quick in its progress,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and spread."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^ajohadato","text_ar":"اَجْهَدَتْ"},{"kind":"arabic","text_bw":"lahu AlA^aroDu","text_ar":"لَهُ الاَرْضُ"},{"kind":"italic_en","text":"The land became open to him."},{"kind":"text","text":"(L, K. *) And in like manner,"},{"kind":"arabic","text_bw":"Ajhd lh AlT~ariyqu","text_ar":"اجهد له الطَّرِيقُ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"AlHaq~u","text_ar":"الحَقُّ"},{"kind":"text","text":", (L, K, *)"},{"kind":"italic_en","text":"The road,"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"the truth, became open, apparent, and manifest, to him."},{"kind":"text","text":"(L, K. *) And"},{"kind":"arabic","text_bw":"Ajhd laka AlA^amoru","text_ar":"اجهد لَكَ الاَمْرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The thing became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has become, within thy power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reach;"},{"kind":"text","text":"(Aboo-Sa'eed, K;)"},{"kind":"italic_en","text":"and offered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"presented, itself to thee."},{"kind":"text","text":"(Aboo-Sa'eed, TA.)"}],"source_refs":["K","TA","A","L"]}]},"classical_definitions":null}