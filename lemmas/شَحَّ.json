,"gen":"m","num":"s"},{"role":"present_1mp","form":"نَشِحّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشِحّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"شَحَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَحَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":true,"lemma_key":"شَحَّ","root":"شحح","pos":"N","occurrence_count":5},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n21799"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%AD%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21799","headword_ar":"شَحَّ","root":"$H","body":[{"kind":"text","text":", (Msb,) sec. pers."},{"kind":"arabic","text_bw":"$aHaHota","text_ar":"شَحَحْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$uH~u","text_ar":"يَشُحُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ya$iH~u","text_ar":"يَشِحُّ"},{"kind":"text","text":", (S, O, Msb, K,) the latter of these aors. agreeable with analogy as the verb is intrans., and the former deviating therefrom; (MF;) and sec. pers."},{"kind":"arabic","text_bw":"$aHiHota","text_ar":"شَحِحْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$aH~u","text_ar":"يَشَحُّ"},{"kind":"text","text":"; (S, O, Msb, K;) [the first of which, having for its aor."},{"kind":"arabic","text_bw":"ya$uH~u","text_ar":"يَشُحُّ"},{"kind":"text","text":", is the most common;] inf. n."},{"kind":"arabic","text_bw":"$uH~N","text_ar":"شُحٌّ"},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"$iH~N","text_ar":"شِحٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$aH~N","text_ar":"شَحٌّ"},{"kind":"text","text":", (ISk, O, K,) of which three inf. ns. the first is the most approved; (TA;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly, tenacious, stingy, penurious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"yaxila","text_ar":"يَخِلَ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"bxl","text_ar":"بخل"},{"kind":"text","text":"relates to single things, or particulars; and"},{"kind":"arabic","text_bw":"$H~","text_ar":"شحّ"},{"kind":"text","text":", to things in general: or"},{"kind":"arabic","text_bw":"bxl","text_ar":"بخل"},{"kind":"text","text":"relates to wealth, or property; and"},{"kind":"arabic","text_bw":"$H~","text_ar":"شحّ"},{"kind":"text","text":", to wealth, or property, and to kindness, or beneficence: or"},{"kind":"arabic","text_bw":"$H~","text_ar":"شحّ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"&c., as above,"},{"kind":"italic_en","text":"in the utmost degree:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"&c., as above, (S, A, O, K,)"},{"kind":"italic_en","text":"and covetous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greedily"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"culpably desirous,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"with covetousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greedy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessive"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"culpable desire."},{"kind":"text","text":"(S, A, O.) You say,"},{"kind":"arabic","text_bw":"$aH~a bihi","text_ar":"شَحَّ بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$aH~a Ealayohi","text_ar":"شَحَّ عَلَيْهِ"},{"kind":"text","text":"; (T, M, K;) by the former meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of it,"},{"kind":"text","text":"i. e., of his property, or the like; and by the latter,"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"i. e., to an asker, or a beggar, or a seeker, or the like: (MF:) or [in some cases, as will be seen from phrases mentioned below, (see"},{"kind":"arabic","text_bw":"$aHiyHN","text_ar":"شَحِيحٌ"},{"kind":"text","text":",)] meaning by the latter the same as by the former. (L.) [Thus] one says,"},{"kind":"arabic","text_bw":"huwa ya$uH~u bimaAlihi","text_ar":"هُوَ يَشُحُّ بِمَالِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of his property;"},{"kind":"text","text":"and sometimes, in the same sense,"},{"kind":"arabic","text_bw":"ya$uH~u EalaY maAlihi","text_ar":"يَشُحُّ عَلَى مَالِهِ"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"$aH~a baEoDuhumo","text_ar":"شَحَّ بَعْضُهُمْ"},{"kind":"page_break","n":1511},{"kind":"arabic","text_bw":"EalaY baEoDK","text_ar":"عَلَى بَعْضٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Some of them were niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to some;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"they were niggardly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"one to another"},{"kind":"text","text":"]. (Msb, K.)"}],"source_refs":["Msb","S","O","K","A","ISk","TA","MF"]}]},"classical_definitions":null}