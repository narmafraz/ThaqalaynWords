,{"kind":"arabic","text_bw":"jariyr","text_ar":"جَرِير"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"lafoZN A_isolaAmiY~N","text_ar":"لَفْظٌ اـِسْلَامِىٌّ"},{"kind":"italic_en","text":"A word,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"phrase, introduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"used in a new sense, on the occasion of the promulgation and establishment of the religion of"},{"kind":"arabic","text_bw":"AlA_isolaAm","text_ar":"الاـِسْلَام"},{"kind":"text","text":", by means of the Kur-án &c. (Mz 20th"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":".)"}],"source_refs":[]}]},"classical_definitions":null}