null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَوِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَوَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَوَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغَوُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغَوُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغَوِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُغَوَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُغَوّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُغَوَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغَوَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"غَوَّيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غَوَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُغَوِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغَوِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":true,"lemma_key":"غَوَّى","root":"غوي","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n32566","n32570","n32576"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%88%D9%8E%D9%91%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32566","headword_ar":"غَوَى","root":"gw or gwY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagowiY","text_ar":"يَغْوِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gaY~N","text_ar":"غَىٌّ"},{"kind":"text","text":"(A 'Obeyd, S, Msb, K, TA) and"},{"kind":"arabic","text_bw":"gawaAyapN","text_ar":"غَوَايَةٌ"},{"kind":"text","text":"; (A 'Obeyd, S, TA;) [respecting which latter see what follows;] and"},{"kind":"arabic","text_bw":"gawiYa","text_ar":"غَوِىَ"},{"kind":"text","text":"(A 'Obeyd, K, TA, but not in the CK,) but this is not commonly known, (TA,) aor."},{"kind":"arabic","text_bw":"yagowaY","text_ar":"يَغْوَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gawFY","text_ar":"غَوًى"},{"kind":"text","text":", (A 'Obeyd, TA,) accord. to the M and K"},{"kind":"arabic","text_bw":"gawaAyapN","text_ar":"غَوَايَةٌ"},{"kind":"text","text":", mentioned above as of"},{"kind":"arabic","text_bw":"gawaY","text_ar":"غَوَى"},{"kind":"text","text":", (TA,) or this last, which is with fet-h, (Msb,) not to be pronounced with kesr, (K,) is a simple subst.; (Msb;)"},{"kind":"italic_en","text":"He erred; deviated from the right way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from that which was right:"},{"kind":"text","text":"(S, Msb, K:) and"},{"kind":"italic_en","text":"was disappointed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"failed of attaining his desire:"},{"kind":"text","text":"(S, Msb:) and"},{"kind":"italic_en","text":"he laboured, and persisted,"},{"kind":"text","text":"(IAth, Msb, TA,)"},{"kind":"italic_en","text":"in that which was vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false,"},{"kind":"text","text":"(IAth, TA,) or"},{"kind":"italic_en","text":"in ignorant conduct:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he acted ignorantly from misbelief."},{"kind":"text","text":"(Er-Rághib, TA.)       -A2-  See also 4, in two places.       -A3-"},{"kind":"arabic","text_bw":"gawiYa","text_ar":"غَوِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagowaY","text_ar":"يَغْوَى"},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"gawaY","text_ar":"غَوَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yagowiY","text_ar":"يَغْوِى"},{"kind":"text","text":"; (K;) inf. n. [of the former]"},{"kind":"arabic","text_bw":"gawFY","text_ar":"غَوًى"},{"kind":"text","text":"; (S, K;) said of a young camel, (S, Msb, K,) and of a lamb or kid, (S,)"},{"kind":"italic_en","text":"He suffered indigestion from the milk;"},{"kind":"text","text":"(K, TA;) i. e. (TA)"},{"kind":"italic_en","text":"he drank the milk until he suffered indigestion; and his belly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest, became in a corrupt state;"},{"kind":"text","text":"(S, Msb, * TA;) or"},{"kind":"italic_en","text":"he drank much thereof, so that he suffered indigestion:"},{"kind":"text","text":"(TA:) or, accord. to ISk, (S, TA,)"},{"kind":"italic_en","text":"he did not satisfy his thirst with the biestings of his mother,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"he did not drink thereof,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"nor satisfy his thirst with the milk"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after it"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"so that he died of emaciation:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a kid, AZ, TA)"},{"kind":"italic_en","text":"was withheld from sucking"},{"kind":"text","text":"(AZ, K, TA)"},{"kind":"italic_en","text":"until hunger injured him"},{"kind":"text","text":"(AZ, TA)"},{"kind":"italic_en","text":"so that he became emaciated,"},{"kind":"text","text":"(AZ, K, TA,)"},{"kind":"italic_en","text":"and almost perished:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he obtained not sufficient milk to satisfy his thirst so that he almost perished:"},{"kind":"text","text":"(T, TA:) or, said of a child, and of a young camel,"},{"kind":"italic_en","text":"he found not a sufficiency of milk, so that he did not satisfy his thirst, and was seen to be meagre,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated;"},{"kind":"text","text":"thus accord. to ISh; and Sh says that his companions held this to be the correct meaning: (TA:) the epithet applied to the young camel [&c.] is ↓"},{"kind":"arabic","text_bw":"gawK","text_ar":"غَوٍ","orth_type":"arrow"},{"kind":"text","text":". (K.) Z has mentioned the reading in the Kur [xx. 119],"},{"kind":"arabic","text_bw":"waEaSaY","text_ar":"وَعَصَى"},{"kind":"arabic","text_bw":"A=damu rab~ahu fagawiYa","text_ar":"ا=دَمُ رَبَّهُ فَغَوِىَ"},{"kind":"text","text":", expl. as meaning ["},{"kind":"italic_en","text":"And Adam disobeyed his Lord, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"suffered indigestion from much eating:"},{"kind":"text","text":"but better than this is what Az and Er-Rághib say; that it is"},{"kind":"arabic","text_bw":"fagawaY","text_ar":"فَغَوَى"},{"kind":"text","text":"; and that the meaning is,"},{"kind":"italic_en","text":"and his life became evil to him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was disappointed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he acted ignorantly;"},{"kind":"text","text":"or some other of the meanings mentioned by the expositors. (TA.)"}],"source_refs":["TA","Msb","K","S","IAth","AZ","T"]},{"entry_id":"n32570","headword_ar":"غَوًى","root":"gw or gwY","body":[{"kind":"italic_en","text":"Thirst."},{"kind":"text","text":"(TA.) ―         -b2-  And one says,"},{"kind":"arabic","text_bw":"bit~u gawFY","text_ar":"بِتُّ غَوًى"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"gawiy~FA","text_ar":"غَوِيًّا","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mugowiyFA","text_ar":"مُغْوِيًا","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) in the T ↓"},{"kind":"arabic","text_bw":"mugaw~FY","text_ar":"مُغَوًّى","orth_type":"arrow"},{"kind":"text","text":", (TA,) [in the CK"},{"kind":"arabic","text_bw":"magowiy~FA","text_ar":"مَغْوِيًّا"},{"kind":"text","text":",] meaning"},{"kind":"arabic","text_bw":"muxoliyFA","text_ar":"مُخْلِيًا"},{"kind":"text","text":"(K, TA) [in the CK"},{"kind":"arabic","text_bw":"muxal~ayFA","text_ar":"مُخَلَّيًا"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"muwHi$FA","text_ar":"مُوحِشًا"},{"kind":"text","text":"(TA) [i. e."},{"kind":"italic_en","text":"I passed the night empty"},{"kind":"text","text":"]: and so"},{"kind":"arabic","text_bw":"qawiyFA","text_ar":"قَوِيًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qaAwiyFA","text_ar":"قَاوِيًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"muqowiyFA","text_ar":"مُقْوِيًا"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"gawiY~N","text_ar":"غَوِىٌّ"},{"kind":"text","text":".]"}],"source_refs":["K","TA"]},{"entry_id":"n32576","headword_ar":"غَوِىٌّ","root":"gw or gwY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gaAwK","text_ar":"غَاوٍ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"gawFY","text_ar":"غَوًى"},{"kind":"text","text":". You say of a hungry person,"},{"kind":"arabic","text_bw":"raA^ayotuhu gawiy~FA mina AljuwoEi","text_ar":"رَاَيْتُهُ غَوِيًّا مِنَ الجُوْعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw him empty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lean, from hunger"},{"kind":"text","text":"]; like as one says"},{"kind":"arabic","text_bw":"qawiyFA","text_ar":"قَوِيًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DawiyFA","text_ar":"ضَوِيًا"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"DaAwiyFA","text_ar":"ضَاوِيًا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"TawiyFA","text_ar":"طَوِيًا"},{"kind":"text","text":". (TA.)"}],"source_refs":[]}]},"classical_definitions":null}