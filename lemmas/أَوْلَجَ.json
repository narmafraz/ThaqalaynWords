xt","text":"]"},{"kind":"italic_en","text":"the night:"},{"kind":"text","text":"(Jel:) or"},{"kind":"italic_en","text":"He increaseth the night with a part of the day, by taking from the latter and adding to the former, and in like manner increaseth the day with a part of the night."},{"kind":"text","text":"(S.) ―         -b3-  ["},{"kind":"arabic","text_bw":"Awlj","text_ar":"اولج"},{"kind":"text","text":"is often used for"},{"kind":"arabic","text_bw":"Awlj *krh","text_ar":"اولج ذكره"},{"kind":"text","text":"; and hence as meaning"},{"kind":"italic_en","text":"Inivit."},{"kind":"text","text":"]"}],"source_refs":["S","K","Jel"]},{"entry_id":"n42338","headword_ar":"اَوْلَجُ","root":"wlj","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, penetrating"},{"kind":"text","text":"]: applied to language or discourse. [TA, in art."},{"kind":"arabic","text_bw":"jmE","text_ar":"جمع"},{"kind":"text","text":": see an ex. voce"},{"kind":"arabic","text_bw":"mujomaEN","text_ar":"مُجْمَعٌ"},{"kind":"text","text":".]"}],"source_refs":[]}]},"classical_definitions":null}