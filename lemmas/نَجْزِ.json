{"lemma":"نَجْزِ","slug":"نَجْزِ","root":"ن.ج.ز","root_slug":"ن-ج-ز","root_link":"/words/roots/ن-ج-ز","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n39422","","n39426","n39427"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AC%D9%92%D8%B2%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39422","headword_ar":"نَجِزَ","root":"njz","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"najazN","text_ar":"نَجَزٌ"},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"najozN","text_ar":"نَجْزٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, TA,)"},{"kind":"italic_en","text":"came to an end; came to nought; perished, passed away:"},{"kind":"text","text":"(S, K, TA:) in these senses, the former is the more chaste, and has been so generally used that the latter has been said to be not allowable; but both have been heard. (TA.)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a speech or discourse)"},{"kind":"italic_en","text":"finished,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and became complete."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S:) occurring in a verse of En-Nábighah Edh-Dhubyánee: as related by J,"},{"kind":"arabic","text_bw":"najiza","text_ar":"نَجِزَ"},{"kind":"text","text":"; but as related by A 'Obeyd,"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"najaza AlwaEodu","text_ar":"نَجَزَ الوَعْدُ"},{"kind":"text","text":", (A, Mgh, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"najozN","text_ar":"نَجْزٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"najiza","text_ar":"نَجِزَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K;) inf. n."},{"kind":"arabic","text_bw":"najazN","text_ar":"نَجَزٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"The promise came to pass, and was accomplished:"},{"kind":"text","text":"(A, Mgh:) or"},{"kind":"italic_en","text":"the promise was prompt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quick, in taking effect:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the thing promised"},{"kind":"text","text":"(TK)"},{"kind":"italic_en","text":"came, arrived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became present:"},{"kind":"text","text":"(K, TA:) in this sense, the former is the more chaste; but both have been heard. (TA.)       -A3-"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":"is also trans.: see 4, in four places."}],"source_refs":["S","K","TA","A","Mgh","Msb","TK"]},{"entry_id":"n39426","headword_ar":"نَجْزٌ","root":"njz","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nujozN","text_ar":"نُجْزٌ","orth_type":"arrow"},{"kind":"text","text":"are syn. You say,"},{"kind":"arabic","text_bw":"A^anota EalaY","text_ar":"اَنْتَ عَلَى"},{"kind":"arabic","text_bw":"najozi HaAjatika","text_ar":"نَجْزِ حَاجَتِكَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaAjatika","text_ar":"حَاجَتِكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nujozi","text_ar":"نُجْزِ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"Thou art on the point of accomplishing thy want."},{"kind":"text","text":"(S, K.)"}],"source_refs":[]},{"entry_id":"n39427","headword_ar":"نُجْزٌ","root":"njz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"najozN","text_ar":"نَجْزٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}