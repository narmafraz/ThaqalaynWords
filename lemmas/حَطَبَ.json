nelexicon.com/?s=%D8%AD%D9%8E%D8%B7%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"material for fueling fire, firewood, kindling","tags":["uncountable","usually"]}]},"etymology":{"source":"wiktextract","text":"From the root ح ط ب (ḥ ṭ b). Cognate with Hebrew חטב (/⁠ḥṭb⁠/) and Ugaritic ḥṭb."},"ipa":["/ħa.tˤab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8372","headword_ar":"حَطَبَ","root":"HTb","body":[{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HaTobN","text_ar":"حَطْبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He collected"},{"kind":"arabic","text_bw":"HaTab","text_ar":"حَطَب"},{"kind":"text","text":", (S, A, K,) i. e."},{"kind":"italic_en","text":"firewood;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"AHtTb","text_ar":"احتطب","orth_type":"arrow"},{"kind":"text","text":": (S, A, K:) [and] so"},{"kind":"arabic","text_bw":"HaTaba AlHaTaba","text_ar":"حَطَبَ الحَطَبَ"},{"kind":"text","text":", (Mgh, Msb,) aor. and inf. n. as above; and ↓"},{"kind":"arabic","text_bw":"AHtTb","text_ar":"احتطب","orth_type":"arrow"},{"kind":"text","text":". (Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HaTaba fiY Habolihi","text_ar":"حَطَبَ فِى حَبْلِهِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"fY Habolihimo","text_ar":"فى حَبْلِهِمْ"},{"kind":"text","text":", (K,) [lit."},{"kind":"italic_en","text":"He collected firewood in his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their, rope;"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"he aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assisted,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"him,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"them."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"A_in~aka taHoTibu","text_ar":"اـِنَّكَ تَحْطِبُ"},{"kind":"arabic","text_bw":"fiY Habolihi wa tamiylu A_ilaY hawaAhu","text_ar":"فِى حَبْلِهِ وَ تَمِيلُ اـِلَى هَوَاهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily thou aidest him, and inclinest to his desire"},{"kind":"text","text":"]. (A, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"HaTaba Ealayohi bixayorK","text_ar":"حَطَبَ عَلَيْهِ بِخَيْرٍ"},{"kind":"text","text":"(A, Mgh) (tropical:)"},{"kind":"italic_en","text":"He brought to him"},{"kind":"arabic","text_bw":"xyr","text_ar":"خير"},{"kind":"text","text":", (Mgh,) meaning"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property."},{"kind":"text","text":"(A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"fulaAnN yaHoTibu EalaY fulaAnK","text_ar":"فُلَانٌ يَحْطِبُ عَلَى فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one incites, urges,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"instigates,"},{"kind":"text","text":"[others]"},{"kind":"italic_en","text":"against such a one."},{"kind":"text","text":"(Har p. 209.) ―         -b5-  And"},{"kind":"arabic","text_bw":"HaTaba bihi","text_ar":"حَطَبَ بِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He calumniated him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slandered him."},{"kind":"text","text":"(A, Mgh, Msb, K. [See"},{"kind":"arabic","text_bw":"HaTabN","text_ar":"حَطَبٌ"},{"kind":"text","text":", below.])       -A2-"},{"kind":"arabic","text_bw":"HaTabahu","text_ar":"حَطَبَهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He collected firewood for him:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he brought firewood to him:"},{"kind":"text","text":"(S, K:) as also"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AHtTb","text_ar":"احتطب","orth_type":"arrow"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"yaHoTibu rufaqaA='ahu wa yasoqiyhimo","text_ar":"يَحْطِبُ رُفَقَا=ءَهُ وَ يَسْقِيهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one collects firewood for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brings firewood to, his companions, and gives them to drink"},{"kind":"text","text":"]. (A, TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He collected for him"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as firewood."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"HaTabuwA karomahumo","text_ar":"حَطَبُوا كَرْمَهُمْ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaTobN","text_ar":"حَطْبٌ"},{"kind":"text","text":", [and app. also"},{"kind":"arabic","text_bw":"HiTaAbN","text_ar":"حِطَابٌ"},{"kind":"text","text":", which see below, or this may be a simple subst.,] (tropical:)"},{"kind":"italic_en","text":"They cut off the"},{"kind":"arabic","text_bw":"HaTab","text_ar":"حَطَب"},{"kind":"italic_en","text":"of their grapevine;"},{"kind":"text","text":"(A;) i. e."},{"kind":"italic_en","text":"the dry portions thereof, that were of no use but for fire."},{"kind":"text","text":"(Mgh.)       -A3-"},{"kind":"arabic","text_bw":"HaTaba","text_ar":"حَطَبَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHTb","text_ar":"احطب","orth_type":"arrow"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"(a place, K,) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a man, TA,)"},{"kind":"italic_en","text":"abounded with firewood."},{"kind":"text","text":"(K, * TA.)       -A4-"},{"kind":"arabic","text_bw":"HaTuba","text_ar":"حَطُبَ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meagre."},{"kind":"text","text":"(A.)"}],"source_refs":["S","A","K","TA","Mgh","Msb"]}]}}