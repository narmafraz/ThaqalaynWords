{"lemma":"حَنَشِ","slug":"حَنَشِ","root":"ح.ن.ش","root_slug":"ح-ن-ش","root_link":"/words/roots/ح-ن-ش","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n9308","n9309"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%86%D9%8E%D8%B4%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"snake, adder, viper"},{"pos":"verb","gloss":"to dispel, to frighten off","tags":["archaic"]},{"pos":"noun","gloss":"verbal noun of حَنَشَ (ḥanaša) (form I)","tags":["archaic","form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-Semitic *naḥaš-."},"ipa":["/ħa.naʃ/","/ħa.na.ʃa/","/ħanʃ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9308","headword_ar":"حَنَشَ","root":"Hn$","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,)"},{"kind":"italic_en","text":"He hunted, sought to catch"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"capture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caught"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"captured,"},{"kind":"text","text":"(S, A, Msb, K,) such animals as are hunted &c., (S, Msb, K,) or such as are termed"},{"kind":"arabic","text_bw":"A^aHonaA$","text_ar":"اَحْنَاش"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"Hana$N","text_ar":"حَنَشٌ"},{"kind":"text","text":"; (A;) as also ↓"},{"kind":"arabic","text_bw":"AHn$","text_ar":"احنش","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Hana$atohu AlHay~apu","text_ar":"حَنَشَتْهُ الحَيَّةُ"},{"kind":"italic_en","text":"The serpent bit him."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["S","A","Msb","K"]},{"entry_id":"n9309","headword_ar":"حَنَشٌ","root":"Hn$","body":[{"kind":"italic_en","text":"Anything that is hunted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caught"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"captured, of birds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flying things, and of"},{"kind":"text","text":"[or, accord. to the CK, this word “ of ” should be omitted here, as well as where it next occurs,]"},{"kind":"italic_en","text":"what are termed"},{"kind":"arabic","text_bw":"AlhawaAm~","text_ar":"الهَوَامّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"venomous"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noxious reptiles"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, such as scorpions and serpents"},{"kind":"text","text":"], (S, A, Mgh, * Msb, K,)"},{"kind":"italic_en","text":"and of what are termed"},{"kind":"arabic","text_bw":"Ha$araAtu AlA^aroDi","text_ar":"حَشَرَاتُ الاَرْضِ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"such as the hedgehog, and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lizards of the kinds called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"waral","text_ar":"وَرَل"},{"kind":"text","text":","},{"kind":"italic_en","text":"and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"rat called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jura*","text_ar":"جُرَذ"},{"kind":"text","text":","},{"kind":"italic_en","text":"and the common rat"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mouse, and the serpent:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"any animal whose head resembles that of the serpent,"},{"kind":"text","text":"(Lth, Mgh, Msb, * K,)"},{"kind":"italic_en","text":"of chameleons and of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the lizards called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"sawaAm~u A^aboraSa","text_ar":"سَوَامُّ اَبْرَصَ"},{"kind":"italic_en","text":"and the like:"},{"kind":"text","text":"(Lth, Mgh, * Msb: *) or"},{"kind":"italic_en","text":"any creeping thing, of beasts and of birds"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flying things:"},{"kind":"text","text":"(Kr, TA: *) and the"},{"kind":"italic_en","text":"serpent:"},{"kind":"text","text":"(S, Kr, A, Mgh, K:) or the"},{"kind":"italic_en","text":"viper:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"a kind of white and thick serpent, like the"},{"kind":"arabic","text_bw":"vuEobaAn","text_ar":"ثُعْبَان"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"larger;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"black kind thereof:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a serpent that blows, but does not hurt:"},{"kind":"text","text":"(Ham p. 626:) and the"},{"kind":"italic_en","text":"common fly:"},{"kind":"text","text":"(Ibn- 'Abbád, A, Sgh, K:) pl."},{"kind":"arabic","text_bw":"A^aHonaA$N","text_ar":"اَحْنَاشٌ"},{"kind":"text","text":"(S, A, Mgh, K) and"},{"kind":"arabic","text_bw":"Hino$aAnN","text_ar":"حِنْشَانٌ"},{"kind":"text","text":". (A, TA.)"},{"kind":"page_break","n":657}],"source_refs":["K","TA","S","Kr","A","Mgh"]}]},"classical_definitions":null}