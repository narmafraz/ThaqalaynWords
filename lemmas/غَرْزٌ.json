{"lemma":"غَرْزٌ","slug":"غَرْزٌ","root":"غ.ر.ز","root_slug":"غ-ر-ز","root_link":"/words/roots/غ-ر-ز","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n31657"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B1%D9%92%D8%B2%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pierce, to prick, to stab"},{"pos":"verb","gloss":"to fasten, to fix, to insert"},{"pos":"verb","gloss":"to lay eggs"}]},"etymology":null,"ipa":["/ɣa.ra.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31657","headword_ar":"غَرْزٌ","root":"grz","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"stirrup"},{"kind":"text","text":"(S, Mgh, K)"},{"kind":"italic_en","text":"of the camel's saddle,"},{"kind":"text","text":"(S, Mgh,)"},{"kind":"italic_en","text":"made of skin,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"sewed;"},{"kind":"text","text":"(TA;) that of iron [or brass] or wood being called"},{"kind":"arabic","text_bw":"rikaAbN","text_ar":"رِكَابٌ"},{"kind":"text","text":"; (S;) the"},{"kind":"italic_en","text":"camel's stirrup:"},{"kind":"text","text":"(Msb:) IAar says that"},{"kind":"italic_en","text":"it is to the she-camel like the"},{"kind":"arabic","text_bw":"HizaAm","text_ar":"حِزَام"},{"kind":"italic_en","text":"to the horse:"},{"kind":"text","text":"but others say, that"},{"kind":"italic_en","text":"it is to the camel like the"},{"kind":"arabic","text_bw":"rikaAb","text_ar":"رِكَاب"},{"kind":"text","text":","},{"kind":"italic_en","text":"to the mule."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"Ailozamo garoza fulaAnK","text_ar":"اِلْزَمْ غَرْزَ فُلَانٍ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Keep thou to the stirrup of such a one;"},{"kind":"text","text":"meaning,] (tropical:)"},{"kind":"italic_en","text":"keep thou to the commands and prohibitions of such a one."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"Au$odudo yadayoka bigarozihi","text_ar":"اُشْدُدْ يَدَيْكَ بِغَرْزِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Cleave thou to him,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"and leave him not."},{"kind":"text","text":"(A.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"Aisotamosiko bigarozihi","text_ar":"اِسْتَمْسِكْ بِغَرْزِهِ"},{"kind":"text","text":", meaning, (tropical:)"},{"kind":"italic_en","text":"Cling thou to him, and follow what he says and does, and disobey him not;"},{"kind":"text","text":"like as one lays hold upon the stirrup of the rider and goes with him. (TA.)       -A2-  Also sing. of"},{"kind":"arabic","text_bw":"guruwzN","text_ar":"غُرُوزٌ"},{"kind":"text","text":", which signifies"},{"kind":"italic_en","text":"Sprigs ingrafted upon the branches of the grape-vine."},{"kind":"text","text":"(K.)"}],"source_refs":["S","Mgh","K","Msb","A"]}]},"classical_definitions":null}