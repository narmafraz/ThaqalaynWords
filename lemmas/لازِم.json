"},{"kind":"italic_en","text":"Necessary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inseparable, adjuncts, accompaniments, consequences,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"results."}],"source_refs":[]}]}}