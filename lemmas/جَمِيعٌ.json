{"lemma":"جَمِيعٌ","slug":"جَمِيعٌ","root":"ج.م.ع","root_slug":"ج-م-ع","root_link":"/words/roots/ج-م-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"جَمِيع","root":"جمع","pos":"N","occurrence_count":53},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n6319"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%85%D9%90%D9%8A%D8%B9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"whole, entire, all","examples":[{"text":"الْجَمِيع","english":"everybody, everyone"},{"text":"جَمِيعًا","english":"altogether, entirely"}]},{"pos":"adj","gloss":"plural","tags":["obsolete","plural"]}]},"etymology":null,"ipa":["/d͡ʒa.miːʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6319","headword_ar":"جَمِيعٌ","root":"jmE","body":[{"kind":"italic_en","text":"In a state of collection, congregation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"union; being together; met together;"},{"kind":"text","text":"[as also ↓"},{"kind":"arabic","text_bw":"mujotamiEN","text_ar":"مُجْتَمِعٌ","orth_type":"arrow"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"mutafar~iqN","text_ar":"مُتَفَرِّقٌ"},{"kind":"text","text":". (S, K.) You say"},{"kind":"arabic","text_bw":"qawomN jamiyEN","text_ar":"قَوْمٌ جَمِيعٌ"},{"kind":"italic_en","text":"A people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"number of men, in a state of collection,"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"being together; met together;"},{"kind":"text","text":"syn. ↓"},{"kind":"arabic","text_bw":"mujotamiEuwna","text_ar":"مُجْتَمِعُونَ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and in like manner, ↓"},{"kind":"arabic","text_bw":"A_ibilN jam~aAEapN","text_ar":"اـِبِلٌ جَمَّاعَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Camels in a state of collection;"},{"kind":"text","text":"&c. (TA.) ―         -b2-  ["},{"kind":"italic_en","text":"All,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"whole,"},{"kind":"text","text":"of any things or thing.] See"},{"kind":"arabic","text_bw":"A^ajomaEu","text_ar":"اَجْمَعُ"},{"kind":"text","text":", last sentence. ―         -b3-  [As an epithet in which the quality of a subst. is predominant,]"},{"kind":"italic_en","text":"A tribe"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"any number of men"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in a state of collection, congregation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"union; being together; met together;"},{"kind":"text","text":"syn. ↓"},{"kind":"arabic","text_bw":"HaY~N mujotamiEN","text_ar":"حَىٌّ مُجْتَمِعٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) See also"},{"kind":"arabic","text_bw":"jamoEN","text_ar":"جَمْعٌ"},{"kind":"text","text":", in four places. ―         -b4-  A man"},{"kind":"italic_en","text":"compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted,"},{"kind":"text","text":"in"},{"kind":"italic_en","text":"make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frame:"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alxaloqi","text_ar":"الخَلْقِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mujotamiEu","text_ar":"مُجْتَمِعُ","orth_type":"arrow"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"strong; who has not become decrepit nor infirm."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"rajulN jamiyEN All~aA^omapi","text_ar":"رَجُلٌ جَمِيعٌ اللَّاْمَةِ"},{"kind":"italic_en","text":"A man having his arms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weapons, collected together."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"rajulN jamiyEu Alr~aA^oYi","text_ar":"رَجُلٌ جَمِيعُ الرَّاْىِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mujotamiEuhu","text_ar":"مُجْتَمِعُهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"A man of right, not disordered"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled, opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsel."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"jaEala","text_ar":"جَعَلَ"},{"kind":"page_break","n":458},{"kind":"arabic","text_bw":"AlA^amora jamiyEFA baEoda tafar~uqihi","text_ar":"الاَمْرَ جَمِيعًا بَعْدَ تَفَرُّقِهِ"},{"kind":"text","text":"(AHeyth, K)"},{"kind":"italic_en","text":"He determined, resolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decided, upon the affair, so as to make it firmly settled,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after it had been unsettled in his mind,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"after considering what might be its issues, or results, and saying at one time, I will do thus, and at another time, I will do thus."},{"kind":"text","text":"(AHeyth.)"}],"source_refs":["TA","AHeyth","K"]}]},"classical_definitions":null}