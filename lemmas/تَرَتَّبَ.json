ntry_ids":["n14663","n14670"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D9%8E%D8%AA%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be subordinate"},{"pos":"verb","gloss":"to derive, to follow logically"},{"pos":"verb","gloss":"to be caused by, to result from"},{"pos":"verb","gloss":"to be or become organized or arranged (in a particular manner)"},{"pos":"verb","gloss":"to be erected (of a statue)"},{"pos":"verb","gloss":"to be set aside (for a specific purpose)"},{"pos":"verb","gloss":"to fall in line"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14663","headword_ar":"ترتّب","root":"rtb","body":[{"kind":"text","text":": see 1, first sentence. ―         -b2-  [Also, as quasi-pass of 2,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, set in order, regularly disposed, arranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"classified."},{"kind":"text","text":"―         -b3-  And"},{"kind":"arabic","text_bw":"trt~b Ealayohi","text_ar":"ترتّب عَلَيْهِ"},{"kind":"italic_en","text":"It was consequent upon it; it resulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accrued, from it."},{"kind":"text","text":"]"}],"source_refs":[]},{"entry_id":"n14670","headword_ar":"تُرْتَبٌ","root":"rtb","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"turotubN","text_ar":"تُرْتُبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tarotubN","text_ar":"تَرْتُبٌ"},{"kind":"text","text":": see the next preceding paragraph, in four places. ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"jaAw^uwA turotabFA","text_ar":"جَاوُوا تُرْتَبًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"turotubFA","text_ar":"تُرْتُبًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"They came all together."},{"kind":"text","text":"(K.) And a poet says, (M,) namely, Ziyád Ibn-Zeyd El-'Odharee, (TA,)"},{"kind":"quote","text":"wakaAna lanaA faDolN EalaY Aln~aAsi turotabaA"},{"kind":"text","text":"meaning ["},{"kind":"italic_en","text":"And we possessed excellence above the people"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"all together:"},{"kind":"text","text":"(M, TA:) thus accord. to the reading commonly known: but, as some relate it,"},{"kind":"quote","text":"wakaAna lanaA Haq~FA EalaY Aln~aAsi turotabaA"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"And it was a just claim that we had upon the people,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established."},{"kind":"text","text":"(TA.) The first"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"turotabN","text_ar":"تُرْتَبٌ"},{"kind":"text","text":"is augmentative, because there is no word like"},{"kind":"arabic","text_bw":"juEofarN","text_ar":"جُعْفَرٌ"},{"kind":"text","text":"; and the derivation also is an evidence of this, for the word is from"},{"kind":"arabic","text_bw":"Al$~aYo'u Alr~aAtibu","text_ar":"الشَّىْءُ الرَّاتِبُ"},{"kind":"text","text":". (M.)       -A2-  Also the second of these three words, (T in art."},{"kind":"arabic","text_bw":"trb","text_ar":"ترب"},{"kind":"text","text":", and M, and L,) or the first of them, (K,)"},{"kind":"italic_en","text":"A bad slave:"},{"kind":"text","text":"(T, K:) or"},{"kind":"italic_en","text":"a slave whom three persons inherit, one after another;"},{"kind":"page_break","n":1026},{"kind":"text","text":"because of his continuance in slavery: [it being a common custom for a man to make a good slave free at his death:] mentioned by Th. (M.) ―         -b2-  Also the second, (Th, M, K,) and the first, (K,)"},{"kind":"italic_en","text":"Dust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"turaAbN","text_ar":"تُرَابٌ"},{"kind":"text","text":": (Th, M, K:) because of its long endurance. (Th, M.) ―         -b3-  And the first,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^abadN","text_ar":"اَبَدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"duration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existence, without end;"},{"kind":"text","text":"&c.: or the right reading may perhaps be"},{"kind":"arabic","text_bw":"A=bidN","text_ar":"ا=بِدٌ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"remaining constantly,"},{"kind":"text","text":"&c.]. (K.)"}],"source_refs":["M","TA","K","T","Th"]}]},"classical_definitions":null}