{"lemma":"عِبْئاً","slug":"عِبْئاً","root":"ع.ب.#","root_slug":"ع-ب-_","root_link":"/words/roots/ع-ب-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n27772","n27773"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%90%D8%A8%D9%92%D8%A6%D8%A7%D9%8B"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"burden, load, weight"}]},"etymology":null,"ipa":["/ʕibʔ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27772","headword_ar":"عَبْءٌ","root":"EbA^","body":[{"kind":"text","text":": see the next paragraph.       -A2-  Also The"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"of the sun: (IAar, O, K:) and so"},{"kind":"arabic","text_bw":"EabN","text_ar":"عَبٌ"},{"kind":"text","text":", (IAar, O, K, &c.,) of the former of which IAar says that it is not known whether it be a dial. var. of the latter or the original thereof; and he says also that"},{"kind":"arabic","text_bw":"EabowapN","text_ar":"عَبْوَةٌ"},{"kind":"text","text":"signifies the same; (TA;) or so"},{"kind":"arabic","text_bw":"EabowN","text_ar":"عَبْوٌ"},{"kind":"text","text":"; (TA in art."},{"kind":"arabic","text_bw":"Ebw","text_ar":"عبو"},{"kind":"text","text":";) the pl. of which is"},{"kind":"arabic","text_bw":"EibFY","text_ar":"عِبًى"},{"kind":"text","text":": (TA in that art. and in the present also:) so too does"},{"kind":"arabic","text_bw":"Eab~N","text_ar":"عَبٌّ"},{"kind":"text","text":", (K in art."},{"kind":"arabic","text_bw":"Eb","text_ar":"عب"},{"kind":"text","text":",) accord. to some. (TA in that art.)"}],"source_refs":["IAar","O","K"]},{"entry_id":"n27773","headword_ar":"عِبْءٌ","root":"EbA^","body":[{"kind":"italic_en","text":"A load,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burden,"},{"kind":"text","text":"(S, O, Msb, * K, TA,) of goods, or merchandise, &c.; (TA;) or"},{"kind":"italic_en","text":"such as a debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"some other reponsibility that one takes upon himself:"},{"kind":"text","text":"(Lth, TA:)"},{"kind":"italic_en","text":"a weight,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"of debt, &c.,"},{"kind":"text","text":"(Msb.) or"},{"kind":"italic_en","text":"of anything:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"A^aEobaA='N","text_ar":"اَعْبَا=ءٌ"},{"kind":"text","text":". (S, O, Msb.) One says,"},{"kind":"arabic","text_bw":"Hamalotu A^aEobaA='a Alqawomi","text_ar":"حَمَلْتُ اَعْبَا=ءَ القَوْمِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"I bore"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the weights,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burdens, of debt, &c., of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(Msb.) ―         -b2-  And"},{"kind":"italic_en","text":"A half-load;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burden borne on one side of a beast, equiponderant to another on the other side;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EidolN","text_ar":"عِدْلٌ"},{"kind":"text","text":"; (S, O, K;)"},{"kind":"italic_en","text":"of goods"},{"kind":"text","text":"["},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"]:"},{"kind":"italic_en","text":"each of what are termed"},{"kind":"arabic","text_bw":"EiboA=ni","text_ar":"عِبْا=نِ"},{"kind":"text","text":": pl. as above. (S, O.) ―         -b3-  And [hence]"},{"kind":"italic_en","text":"A like;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Eabo'N","text_ar":"عَبْءٌ","orth_type":"arrow"},{"kind":"text","text":": (S, O, K:) pl. as above. (TA.) One says,"},{"kind":"arabic","text_bw":"h`*aA Eabo'u h`*aA","text_ar":"هٰذَا عَبْءُ هٰذَا"},{"kind":"italic_en","text":"This is the like of this."},{"kind":"text","text":"(TA.)"}],"source_refs":["Lth","TA","Msb","K","S","O"]}]}}