{"lemma":"جَحِيمٌ","slug":"جَحِيمٌ","root":"ج.ح.م","root_slug":"ج-ح-م","root_link":"/words/roots/ج-ح-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"جَحِيم","root":"جحم","pos":"N","occurrence_count":26},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n5153"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%AD%D9%90%D9%8A%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"inferno, large fire"},{"pos":"noun","gloss":"A place or situation of great suffering in life","examples":[{"text":"صَارَتْ حَيَاتُهُ جَحِيمًا","english":"His life became hell."}]},{"pos":"noun","gloss":"An extremely hot place"},{"pos":"noun","gloss":"hell","examples":[{"text":"فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَى","english":"Then indeed, Hellfire will be [his] refuge."}]}]},"etymology":{"source":"wiktextract","text":"Compare جَحُمَ (jaḥuma, “(intransitive) to burn”)."},"ipa":["/d͡ʒa.ħiːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5153","headword_ar":"جَحِيمٌ","root":"jHm","body":[{"kind":"italic_en","text":"A fire burning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blazing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flaming, vehemently;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"jaAHimN","text_ar":"جَاحِمٌ","orth_type":"arrow"},{"kind":"text","text":": (Ham p. 810:) and"},{"kind":"italic_en","text":"any fire having one part above another;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jaHomapN","text_ar":"جَحْمَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"juHomapN","text_ar":"جُحْمَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) of which last the pl. is"},{"kind":"arabic","text_bw":"juHamN","text_ar":"جُحَمٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"having many live coals, and flaming much:"},{"kind":"text","text":"(so in a copy of the S:) and"},{"kind":"italic_en","text":"any great fire in a pit"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(S, K;) from the saying in the Kur [xxxvii. 95],"},{"kind":"arabic","text_bw":"qaAluwA","text_ar":"قَالُوا"},{"kind":"arabic","text_bw":"A@bonuwA lahu bunoyaAnFA faA^aloquwhu fiY AljaHiymi","text_ar":"ا@بْنُوا لَهُ بُنْيَانًا فَاَلْقُوهُ فِى الجَحِيمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They said, Build ye for him a building, and cast him into the great fire therein"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"AljaHiymu","text_ar":"الجَحِيمُ"},{"kind":"text","text":"is one of the names of"},{"kind":"italic_en","text":"The fire"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of Hell"},{"kind":"text","text":"]; (S, TA;) from which may God preserve us. (TA.) See also"},{"kind":"arabic","text_bw":"jaAHimN","text_ar":"جَاحِمٌ"},{"kind":"text","text":"."}],"source_refs":["TA"]}]},"classical_definitions":null}