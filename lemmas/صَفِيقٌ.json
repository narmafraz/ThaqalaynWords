{"lemma":"صَفِيقٌ","slug":"صَفِيقٌ","root":"ص.ف.ق","root_slug":"ص-ف-ق","root_link":"/words/roots/ص-ف-ق","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n24510"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%81%D9%90%D9%8A%D9%82%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"thick, dense, having thick fabric"},{"pos":"adj","gloss":"brazen, cheeky, impudent"}]},"etymology":{"source":"wiktextract","text":"فَعِيل (faʕīl)-type stative-verb derived from the active participle from the verb صَفُقَ (ṣafuqa, “to be or become thick”)."},"ipa":["/sˤa.fiːq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24510","headword_ar":"صَفِيقٌ","root":"Sfq","body":[{"kind":"text","text":", applied to a garment, or piece of cloth, (S, M, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"strong, stout,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firm;"},{"kind":"text","text":"(M;)"},{"kind":"italic_en","text":"thick, substantial, close,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact, in texture:"},{"kind":"text","text":"(Mgh, O, Msb, K:) and"},{"kind":"arabic","text_bw":"safiyqN","text_ar":"سَفِيقٌ"},{"kind":"text","text":"is a dial. var. thereof. (TA.) ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Hardy, strong, sturdy, enduring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patient."},{"kind":"text","text":"(M.) ―         -b3-  And applied to a face (S, O, K, TA) as meaning (tropical:)"},{"kind":"italic_en","text":"Impudent;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having little shame."},{"kind":"text","text":"(O, K, TA.) And"},{"kind":"arabic","text_bw":"rajulN Safiyqu Alwajohi","text_ar":"رَجُلٌ صَفِيقُ الوَجْهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A man having no shame."},{"kind":"text","text":"(Har p. 368.)"}],"source_refs":["S","M","Mgh","O","Msb","K","TA"]}]},"classical_definitions":null}