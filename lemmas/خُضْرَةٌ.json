abic","text_bw":"duhomap","text_ar":"دُهْمَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"blackness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deep ash-colour"},{"kind":"text","text":"]: (S, K:) in men, [and in other things,]"},{"kind":"italic_en","text":"a tawny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brownish, colour;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sumorapN","text_ar":"سُمْرَةٌ"},{"kind":"text","text":": (S:) [and"},{"kind":"italic_en","text":"a blackish hue:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a blackish hue inclining to green:"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"blackness:"},{"kind":"text","text":"(TA:) [and"},{"kind":"italic_en","text":"intense blackness:"},{"kind":"text","text":"see 9; and see also"},{"kind":"arabic","text_bw":"A^axoDaru","text_ar":"اَخْضَرُ"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"xuDarN","text_ar":"خُضَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuDorN","text_ar":"خُضْرٌ"},{"kind":"text","text":". (K.) ―         -b2-  And"},{"kind":"italic_en","text":"A green plant:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"xuDarN","text_ar":"خُضَرٌ"},{"kind":"text","text":": (TA:) or the latter signifies"},{"kind":"italic_en","text":"herbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leguminous plants;"},{"kind":"text","text":"as though pl. of the former. (Msb.) [See"},{"kind":"arabic","text_bw":"xaDaArN","text_ar":"خَضَارٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"xaDorapN","text_ar":"خَضْرَةٌ"},{"kind":"text","text":".] ―         -b3-  See also"},{"kind":"arabic","text_bw":"xaDirN","text_ar":"خَضِرٌ"},{"kind":"text","text":". ―         -b4-  Also"},{"kind":"italic_en","text":"Softness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tenderness,"},{"kind":"text","text":"(IAar, K,) of seed-produce [and the like]; (TA;) and so ↓"},{"ki