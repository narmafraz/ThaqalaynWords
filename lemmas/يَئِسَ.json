":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَيْئِسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَيْئِسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَيْأَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَيْأَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَيْئِسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَيْئِسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَيْأَسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَيْأَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَيْئِسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَيْأَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَيْئِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَيْئِس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"يَئِسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"يَئِسْتُ","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَيْأَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَيْأَس","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":49,"cross_references":{"qac":{"found":true,"lemma_key":"يَئِسَ","root":"يأس","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to give up hope, to despair, to be hopeless","examples":[{"text":"الأمل الذي يعطيه الكتاب المقدس يساعدنا أن نتحمَّل مشاكلنا ولا نيأس","english":"The hope given by the Bible helps us to endure our problems and not despair."}]},{"pos":"verb","gloss":"to become barren"},{"pos":"verb","gloss":"to know, to have certainty, to realize or to accept, to come to a realization to know a thing to be so or true","tags":["archaic","dialectal"],"examples":[{"text":"أَفَلَمْ يَيْأَسِ الَّذِينَ آمَنُوا أَنْ لَوْ يَشَاءُ اللَّهُ لَهَدَى النَّاسَ جَمِيعًا","english":"...Do not those who have trusted come to the realization that, if God caused it to be, He could certainly direct aright all people?..."}]}]},"etymology":{"source":"wiktextract","text":"From the same root of a barren woman, to have no hope of conceiving; developing to mean just accepting that this is how things are, knowing that she cannot, to know one cannot succeed, to have no hope of anything other.\nFrom there the sense of to stop hoping, to give up being concerned with, to abandon worrying over, to accept it to be so; a parallel semantic sense can be found in Jewish Palestinian Aramaic, Jewish Literary Aramaic יאּש (yaʾʾēš, “to remove desperate thoughts, to stop one's mind from thinking about”)."},"ipa":null,"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%8A%D8%A6%D8%B3/","headword_ar":"يئس","entries":[{"lexicon_id":"dictionary_16","lexicon_en":"Abu Ḥayyān al-Gharnāṭī, Tuḥfat al-Arīb bi-mā fī l-Qurʾān min al-Gharīb (d. 1344 CE)","lexicon_ar":"تحفة الأريب بما في القرآن من الغريب لأبي حيان الغرناطي الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=10949#6a1902","body_html":"<span class=\"title1\">يئس</span><span>: اليأس: القنوط. و {أفلم ييأس}: معناه بلغة النخع: يعلم ويتبين، والله أعلم بالصواب.</span>"},{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=10949#e17a5b","body_html":"<span class=\"title1\">ي ئ س</span><br><br><span>يئس منه يأساً واستيأس، وأيأسته. وهو بين عطفة مطمعٍ وصدفة مؤيسٍ. ورجل يؤوس. وتقول: الله يخلف ويؤوس، والعبد كنود يؤوس.</span><br><br><span>ومن المجاز: قد يئست أنك رجل صدق بمعنى علمت. قال سحيم:</span><br><br><span>أقول لهم بالشّعب إذ ييسرونني </span><span class=\"red\">...</span><span> ألم تيأسوا أني ابن فارس زهدم</span><br><br><span>وقال آخر:</span><br><br><span>ألم تيأس الأقوام أني أنا ابنه </span><span class=\"red\">...</span><span> وإن كنت عن عرض العشيرة نائياً</span><br><br><span>وذلك أن مع الطمع القلق ومع انقطاعه السكون والطمأنينة كما مع العلم ولذلك قيل: \" اليأس إحدى الراحتين \".</span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=10949#030cd1","body_html":"<span class=\"title1\">[يئس]</span><span> اليأْسُ: القنوطُ. وقد يَئِسَ من الشئ ييأس. وفيه لغة أخرى: يَئِسَ ييْئِسُ بالكسر فيهما، وهو شاذ. ورجل يؤوس. قال المبرد: منهم من يبدل في المستقبل من الياء الثانية ألفا ويقول: ياءس ويائس. وقال الاصمعي: يقال: يئس ييئس، وحسب يحسب، ونعم ينعم، بالكسر فيهن. وقال أبو زيد: عليا مضر: يحسب وينعم وييئس بالكسر، وسفلاها بالفتح. وقال سيبويه: وهذا عند أصحابنا إنما يجئ على لغتين: يعنى يئس ييأس ويأس ييئس لغتان، ثم يركب منهما لغة. وأما ومق يمق، ووفق يفق، وورم يرم، وولى يلى، ووثق يثق، وورث يرث، فلا يجوز فيهن إلا الكسر لغة واحدة. </span><a></a><span>ويئس أيضا بمعنى علم، في لغة النخع. قال سحيم بن وثيل اليربوعي : أقول لهم بالشعب إذ ييسرونى * ألم تَيْأسوا أنَّي ابنُ فارسٍ زَهْدَمِ * ومنه قوله تعالى: {أفَلَمْ ييئس الذين آمنوا} . وآيسه فلان من كذا فاسْتَيْأَسَ منه، بمعنى أيس، واتأس أيضا، وهو افتعل، فأدغم مثل اتعد.</span>"}]}}