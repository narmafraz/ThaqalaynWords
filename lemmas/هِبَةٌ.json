"kind":"italic_en","text":"quivers, and penetrates into the thing struck with it:"},{"kind":"text","text":"(S:) and,"},{"kind":"italic_en","text":"that falls with vehemence."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"hab~apN","text_ar":"هَبَّةٌ"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"hib~apN","text_ar":"هِبَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or the latter only, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short time,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sAEp","text_ar":"ساعة"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"remaining before dawn."},{"kind":"text","text":"(As, S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"hab~apN","text_ar":"هَبَّةٌ"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"hib~apN","text_ar":"هِبَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or the latter only, (TA,) (tropical:)"},{"kind":"italic_en","text":"An indefinite period"},{"kind":"text","text":"of time; syn."},{"kind":"arabic","text_bw":"HiqobapN","text_ar":"حِقْبَةٌ"},{"kind":"text","text":": (S, K:)"},{"kind":"italic_en","text":"a long time;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"dahorN","text_ar":"دَهْرٌ"},{"kind":"text","text":". (Az.) Ex."},{"kind":"arabic","text_bw":"Ei$onaA bi*`lika hb~pF mina Ald~ahori","text_ar":"عِشْنَا بِذٰلِكَ هبّةً مِنَ الدَّهْرِ"},{"kind":"italic_en","text":"We lived therein,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in that"},{"kind":"text","text":"["},{"kind":"italic_en","text":"state"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"some time,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a long time"},{"kind":"text","text":"]: like the saying"},{"kind":"arabic","text_bw":"sab~apF","text_ar":"سَبَّةً"},{"kind":"text","text":". (AZ, S.) ―         -b5-  [You say]"},{"kind":"arabic","text_bw":"raA^ayotuhu hab~apF","text_ar":"رَاَيْتُهُ هَبَّةً"},{"kind":"italic_en","text":"I saw him once"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"in life."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"qado jaA'aniY hab~apF","text_ar":"قَدْ جَاءَنِى هَبَّةً"},{"kind":"italic_en","text":"He has come"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to me once."},{"kind":"text","text":"Occurring in a trad.; said by a woman in allusion to her husband's having once come in to her: (TA:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"waqoEapF","text_ar":"وَقْعَةً"},{"kind":"text","text":". (Msb.) See art."},{"kind":"arabic","text_bw":"Esl","text_ar":"عسل"},{"kind":"text","text":"in the Mgh."}],"source_refs":["S","K","TA"]},{"entry_id":"n40810","headword_ar":"هِبَّةٌ","root":"hb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"hab~apN","text_ar":"هَبَّةٌ"},{"kind":"text","text":"throughout. ―         -b2-"},{"kind":"italic_en","text":"A state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition:"},{"kind":"text","text":"[or perhaps the meaning intended is the"},{"kind":"italic_en","text":"state of being brisk, lively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly, and quick"},{"kind":"text","text":"]. (K.) Ex."},{"kind":"arabic","text_bw":"A_in~ahu laHasanu Alhib~api","text_ar":"اـِنَّهُ لَحَسَنُ الهِبَّةِ"},{"kind":"italic_en","text":"Verily he is in a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, &c."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"hib~apN","text_ar":"هِبَّةٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"state"},{"kind":"text","text":"of a stallion"},{"kind":"italic_en","text":"when excited by desire of the female."},{"kind":"text","text":"(S.) See 1.       -A2-"},{"kind":"arabic","text_bw":"hib~apN","text_ar":"هِبَّةٌ"},{"kind":"italic_en","text":"A piece of a garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"hibobN","text_ar":"هِبْبٌ"},{"kind":"text","text":", (S, K:)"},{"kind":"italic_en","text":"a piece of rag."},{"kind":"text","text":"(TA.) ―         -b2-  See"},{"kind":"arabic","text_bw":"vawobN habaAy^ibu","text_ar":"ثَوْبٌ هَبَايِبُ"},{"kind":"text","text":"."}],"source_refs":["K","S"]},{"entry_id":"n44230","headword_ar":"هُبَةٌ","root":"hbw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^ahobapN","text_ar":"اَهْبَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n42389","headword_ar":"هُبَةٌ","root":"whb","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^uhobapN","text_ar":"اُهْبَةٌ"},{"kind":"text","text":"q. v. (K, in art."},{"kind":"arabic","text_bw":"Ahb","text_ar":"اهب"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n42388","headword_ar":"هَِبةٌ","root":"whb","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mawohabapN","text_ar":"مَوْهَبَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A gift"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"thing bestowed"},{"kind":"text","text":"); properly,"},{"kind":"italic_en","text":"one that is freely and disinterestedly given, not for any compensation; a free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disinterested, gift."},{"kind":"text","text":"(L.) [In the K, the latter is explained as signifying simply"},{"kind":"italic_en","text":"a gift."},{"kind":"text","text":"] Pl. of the former"},{"kind":"arabic","text_bw":"hibaApN","text_ar":"هِبَاةٌ"},{"kind":"text","text":"; and of the latter,"},{"kind":"arabic","text_bw":"mawaAhibu","text_ar":"مَوَاهِبُ"},{"kind":"text","text":". (A, &c.) ―         -b2-  [A"},{"kind":"arabic","text_bw":"hibaApN","text_ar":"هِبَاةٌ"},{"kind":"text","text":"is of two kinds:"},{"kind":"arabic","text_bw":"mawaAhibu","text_ar":"مَوَاهِبُ"},{"kind":"italic_en","text":"A free gift, for no requital,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compensation:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hibapu vawaAbK","text_ar":"هِبَةُ ثَوَابٍ"},{"kind":"italic_en","text":"A gift for a requital,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compensation."},{"kind":"text","text":"This distinction is made in law, &c.]"}],"source_refs":[]}]},"classical_definitions":null}