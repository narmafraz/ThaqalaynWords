ole":"present_1mp","form":"نَجْب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْبِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْبِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُجْبَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْبَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَبَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَبَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":399,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5024"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%A8%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to collect, to levy, to raise"}]},"etymology":{"source":"wiktextract","text":"From the root ج ب ي (j b y). Compare Hebrew גָּבָה (gāḇâ) and Classical Syriac ܓܒܐ."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5024","headword_ar":"جَبَى","root":"jbw and jbY","body":[{"kind":"text","text":", (K,) first pers."},{"kind":"arabic","text_bw":"jabayotu","text_ar":"جَبَيْتُ"},{"kind":"text","text":", (Ks, S, Er-Rághib,) aor."},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"jabaY","text_ar":"جَبَى"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) said by MF to be unknown, and also, because neither the second nor the third radical is a faucial letter, unreasonable, but mentioned by Sb, though held by him to be of weak authority, and mentioned also by IAar, as extr., like"},{"kind":"arabic","text_bw":"A^abaY","text_ar":"اَبَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^obaY","text_ar":"يَاْبَى"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"jabaA","text_ar":"جَبَا"},{"kind":"text","text":", (TA,) first pers."},{"kind":"arabic","text_bw":"jabawotu","text_ar":"جَبَوْتُ"},{"kind":"text","text":", (Ks, S, TA,) aor."},{"kind":"text","text":"; (TA;) inf. n. [of the first and second]"},{"kind":"arabic","text_bw":"jaboYN","text_ar":"جَبْىٌ"},{"kind":"text","text":"(Sh, K) and [probably of the last only]"},{"kind":"arabic","text_bw":"jabFA","text_ar":"جَبًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jibFA","text_ar":"جِبًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jubFA","text_ar":"جُبًا"},{"kind":"text","text":"and [of the last, but whether in the first or the second of the senses here following is not shown,]"},{"kind":"arabic","text_bw":"jibowapN","text_ar":"جِبْوَةٌ"},{"kind":"text","text":"; (K; [or this last has a different application, explained below;])"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"water in a trough or tank for beasts &c. [Ks, S, K, Er-Rághib.) ―         -b2-  And (hence, metaphorically, Er-Rághib, TA) the first of these verbs, (S, Mgh, Msb, K, Er-Rághib,) and the second, (K,) and the third; (S, Msb, TA;) inf. n. (of the first, S, Msb)"},{"kind":"arabic","text_bw":"jibaAyapN","text_ar":"جِبَايَةٌ"},{"kind":"text","text":"(S, Mgh, Msb, K, Er-Rághib) and (of the last, S, Msb)"},{"kind":"arabic","text_bw":"jibaAwapN","text_ar":"جِبَاوَةٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"jabowN","text_ar":"جَبْوٌ"},{"kind":"text","text":"(TA) [and probably"},{"kind":"arabic","text_bw":"jibowapN","text_ar":"جِبْوَةٌ"},{"kind":"text","text":"also, which see above]; (tropical:)"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"the [tax called]"},{"kind":"arabic","text_bw":"xaraAj","text_ar":"خَرَاج"},{"kind":"text","text":", (S, Mgh, Msb, K, Er-Rághib,) and [other] property. (Msb, TA.) The last of these verbs is said in the S to be originally with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", though pronounced without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; but IB says that this is not the case, and that it has not been heard with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":". (TA.) You say also,"},{"kind":"arabic","text_bw":"jabaAhu Alqawoma","text_ar":"جَبَاهُ القَوْمَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He collected it from the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men"},{"kind":"text","text":"]; (M, K, * TA;) and"},{"kind":"arabic","text_bw":"jabaY minohumo","text_ar":"جَبَى مِنْهُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He collected from them"},{"kind":"text","text":"]. (M, K, TA.) ―         -b3-  Also"},{"kind":"arabic","text_bw":"jabaA","text_ar":"جَبَا"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"jabaY","text_ar":"جَبَى"},{"kind":"text","text":"], (TA,) first pers."},{"kind":"arabic","text_bw":"jabayotu","text_ar":"جَبَيْتُ"},{"kind":"text","text":", (Zj, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He appropriated"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"purely to himself, exclusively of any partner; chose"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"took"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"in preference, for himself."},{"kind":"text","text":"(Zj, TA.) And hence, (Zj, TA,) ↓"},{"kind":"arabic","text_bw":"AjtbAhu","text_ar":"اجتباهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He chose it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selected it,"},{"kind":"text","text":"(Zj, S, K)"},{"kind":"arabic","text_bw":"linafosihi","text_ar":"لِنَفْسِهِ"},{"kind":"italic_en","text":"for himself."},{"kind":"text","text":"(TA.)       -A2-  And"},{"kind":"arabic","text_bw":"jabaY","text_ar":"جَبَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jabaA","text_ar":"جَبَا"},{"kind":"text","text":", [originally"},{"kind":"arabic","text_bw":"jabaA^a","text_ar":"جَبَاَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He returned, receded, retreated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went back."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","Ks","S","Sh","Msb","Zj"]}]}}