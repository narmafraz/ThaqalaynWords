rences":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23518","n23524"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D8%A7%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to spread, to become more widely present","tags":["intransitive"],"examples":[{"text":"إِنَّ الَّذِينَ يُحِبُّونَ أَن تَشِيعَ الْفَاحِشَةُ فِي الَّذِينَ آمَنُوا لَهُمْ عَذَابٌ أَلِيمٌ فِي الدُّنْيَا وَالْآخِرَةِ","english":"Indeed, those who love to see indecency spread among the believers will suffer a painful punishment in this life and the Hereafter."}]},{"pos":"verb","gloss":"to fill"}]},"etymology":null,"ipa":["/ʃaː.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23518","headword_ar":"شَاعَ","root":"$yE","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$iyEu","text_ar":"يَشِيعُ"},{"kind":"text","text":", (S, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$uyuwEN","text_ar":"شُيُوعٌ"},{"kind":"text","text":"(O, Msb, K) and"},{"kind":"arabic","text_bw":"$ayoEuwEapN","text_ar":"شَيْعُوعَةٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"$ayoEN","text_ar":"شَيْعٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"$ayaEaAnN","text_ar":"شَيَعَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ma$aAEN","text_ar":"مَشَاعٌ"},{"kind":"text","text":", (O, K, the last, in the CK,"},{"kind":"arabic","text_bw":"ma$aAEap","text_ar":"مَشَاعَة"},{"kind":"text","text":",) said of information, an announcement, a piece of news, or a narrative, or story, (TA,) or of a thing, (O, Msb,)"},{"kind":"italic_en","text":"It became spread, published, divulged, revealed, made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disclosed;"},{"kind":"text","text":"(S, O, K, TA;) or"},{"kind":"italic_en","text":"it became apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifest;"},{"kind":"text","text":"(Msb, TA;)"},{"kind":"arabic","text_bw":"fiY Aln~aAsi","text_ar":"فِى النَّاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"among the people"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"so as to reach every one, becoming equally known by the people, not known by some exclusively of others."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"$AE","text_ar":"شاع"},{"kind":"text","text":", aor. as above, said of a thing, signifies also (assumed tropical:)"},{"kind":"italic_en","text":"It became scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"$aE~a","text_ar":"شَعَّ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"$E","text_ar":"شع"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"$AE All~abanu fiY AlmaA='i","text_ar":"شاع اللَّبَنُ فِى المَا=ءِ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"$AEt qaTorapN mina All~abani fiY AlmaA='i","text_ar":"شاعت قَطْرَةٌ مِنَ اللَّبَنِ فِى المَا=ءِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"t$y~Et","text_ar":"تشيّعت","orth_type":"arrow"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The milk,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"the drop of milk,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"became dispersed in the water,"},{"kind":"text","text":"(Msb, TA,)"},{"kind":"italic_en","text":"and mixed:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$ay~aEa","text_ar":"شَيَّعَ","orth_type":"arrow"},{"kind":"text","text":"likewise signifies"},{"kind":"italic_en","text":"it became dispersed in it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"$AE Al$~ayobu","text_ar":"شاع الشَّيْبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ayoEN","text_ar":"شَيْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$iyaAEN","text_ar":"شِيَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ayaEaAnN","text_ar":"شَيَعَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$uyuwEN","text_ar":"شُيُوعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$uyuwEapN","text_ar":"شُيُوعَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ma$iyEN","text_ar":"مَشِيعٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, appeared, and became scattered:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$AE fiyhi Al$~ayobu","text_ar":"شاع فِيهِ الشَّيْبُ"},{"kind":"text","text":", inf. n. as above, (tropical:)"},{"kind":"italic_en","text":"Whiteness of the hair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hoariness, spread upon him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"t$y~Ehu","text_ar":"تشيّعهُ","orth_type":"arrow"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"t$y~E fiyhi","text_ar":"تشيّع فِيهِ"},{"kind":"text","text":", agreeably with what has been said above]. (TA.) And"},{"kind":"arabic","text_bw":"$AE","text_ar":"شاع"},{"kind":"arabic","text_bw":"AlS~adoEu fiY Alz~ujaAjapi","text_ar":"الصَّدْعُ فِى الزُّجَاجَةِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The crack spread, and became dispersed, in the glass,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glass vessel."},{"kind":"text","text":"(Th, TA.) And"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"t$AyEt","text_ar":"تشايعت","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The camels became scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, themselves."},{"kind":"text","text":"(TA.)       -A2-  As trans. by means of"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":": see 4, in two places.       -A3-  [It is also trans. by itself.]"},{"kind":"arabic","text_bw":"$aAEakumu Als~alaAmu","text_ar":"شَاعَكُمُ السَّلَامُ"},{"kind":"text","text":"is like the saying"},{"kind":"arabic","text_bw":"Ealayokumu","text_ar":"عَلَيْكُمُ"},{"kind":"arabic","text_bw":"Als~alaAmu","text_ar":"السَّلَامُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Safety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peace,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light and abide, on you"},{"kind":"text","text":"]; (S, O, K;) but is only said by a man to his companions when he desires to quit them: (S, O:) or it means ["},{"kind":"italic_en","text":"may safety,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"follow you:"},{"kind":"text","text":"(O, K:) or,"},{"kind":"italic_en","text":"not quit you:"},{"kind":"text","text":"(K:) whence, (TA,) one says also"},{"kind":"arabic","text_bw":"$aAEaka Alxayoru","text_ar":"شَاعَكَ الخَيْرُ"},{"kind":"italic_en","text":"may prosperity not quit thee;"},{"kind":"text","text":"and in like manner Lebeed says of praise ("},{"kind":"arabic","text_bw":"HamodN","text_ar":"حَمْدٌ"},{"kind":"text","text":"): (O, TA:) [and J says that]"},{"kind":"arabic","text_bw":"$AEhu","text_ar":"شاعهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$iyaAEN","text_ar":"شِيَاعٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, followed him:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"$AEkm AlslAm","text_ar":"شاعكم السلام"},{"kind":"text","text":", (Yoo, O, K,) aor."},{"kind":"arabic","text_bw":"ya$aAEukum","text_ar":"يَشَاعُكُم"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ayoEN","text_ar":"شَيْعٌ"},{"kind":"text","text":", (Yoo, O,) means ["},{"kind":"italic_en","text":"may safety,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"fill you:"},{"kind":"text","text":"(Yoo, O, K:) [app. from what next follows.] ―         -b2-  One says also"},{"kind":"arabic","text_bw":"$iEotu AlA_inaA='a","text_ar":"شِعْتُ الاـِنَا=ءَ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"A^a$iyEuhu","text_ar":"اَشِيعُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$ayoEN","text_ar":"شَيْعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"I filled the vessel."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","O","Msb","K","TA","Yoo"]},{"entry_id":"n23524","headword_ar":"شَاعٌ","root":"$yE","body":[{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"$aAy^iEN","text_ar":"شَايِعٌ"},{"kind":"text","text":": see the latter word. ―         -b2-  Also The"},{"kind":"italic_en","text":"urine of the she-camel, that becomes scattered when the stallion leaps her."},{"kind":"text","text":"(As, O, K.) And, (As, O, [accord. to the K “ or, ”] The"},{"kind":"italic_en","text":"urine of the he-camel when he is excited by lust."},{"kind":"text","text":"(As, O, K.)"}],"source_refs":[]}]}}