num":"p"},{"role":"present_2mp","form":"تَبْدَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْدَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْدَع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْدَع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْدَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْدَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْدَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْدَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْدَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْدَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْدَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَبْدَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبْدَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"بَدَعْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَدَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"بَدَعَ","root":"بدع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n1994","n1995"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%AF%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to invent, introduce, to originate"},{"pos":"verb","gloss":"to attribute or impute innovation to someone or charge someone with innovation"},{"pos":"verb","gloss":"to excel in"},{"pos":"noun","gloss":"verbal noun of بَدَعَ (badaʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"innovation, novelty, creation","examples":[{"text":"بَدْعًا وَعَوْدًا","english":"repeatedly"}]},{"pos":"noun","gloss":"innovator, originator","examples":[{"text":"قُلْ مَا كُنْتُ بِدْعًۭا مِّنَ ٱلرُّسُلِ","english":"Say, “I am not the first messenger ever sent”."}]},{"pos":"noun","gloss":"novelty, original, something new","examples":[{"text":"لَا بِدْعَ أَنْ","english":"no wonder that"}]},{"pos":"noun","gloss":"plural of بِدْعَة (bidʕa)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of بَدِيع (badīʕ)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1994","headword_ar":"بِدْعٌ","root":"bdE","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"badiyEN","text_ar":"بَدِيعٌ","orth_type":"arrow"},{"kind":"text","text":", q. v., and ↓"},{"kind":"arabic","text_bw":"mubotadaEN","text_ar":"مُبْتَدَعٌ","orth_type":"arrow"},{"kind":"text","text":"; (S;) [but generally used as an epithet in which the quality of a subst. is predominant; signifying]"},{"kind":"italic_en","text":"A novelty;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing existing for the first time:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"badiyEN","text_ar":"بَدِيعٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mubotadiEN","text_ar":"مُبْتَدِعٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"a first doer;"},{"kind":"text","text":"as though meaning"},{"kind":"italic_en","text":"one who has none among his fellows to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him"},{"kind":"text","text":"in a thing, or an affair: (Msb:) pl."},{"kind":"arabic","text_bw":"A^abodaAEN","text_ar":"اَبْدَاعٌ"},{"kind":"text","text":". (Akh, S.) You say,"},{"kind":"arabic","text_bw":"fulaAnN bidoEN fiY h`*A AlA^amori","text_ar":"فُلَانٌ بِدْعٌ فِى هٰذا الاَمْرِ"},{"kind":"text","text":", (S, Msb,) i. e. ↓"},{"kind":"arabic","text_bw":"badiyEN","text_ar":"بَدِيعٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) meaning"},{"kind":"italic_en","text":"Such a one is the first doer in this affair; the first who has done it."},{"kind":"text","text":"(Msb.) And hence the saying in the Kur [xlvi. 8],"},{"kind":"arabic","text_bw":"qulo maA kunotu bidoEFA mina Alr~usuli","text_ar":"قُلْ مَا كُنْتُ بِدْعًا مِنَ الرُّسُلِ"},{"kind":"text","text":"(S, Msb, TA)"},{"kind":"italic_en","text":"Say thou, I am not the first who has been sent of the apostles:"},{"kind":"text","text":"(Msb, TA:) or the meaning is,"},{"kind":"italic_en","text":"I am not an innovator among the apostles;"},{"kind":"text","text":"inviting you to that to which they do not invite you; or able to do that which they were not able to do: and accord. to one reading, it is ↓"},{"kind":"arabic","text_bw":"bidaEFA","text_ar":"بِدَعًا","orth_type":"arrow"},{"kind":"text","text":"; as being [a sing. epithet] like"},{"kind":"arabic","text_bw":"qiyamN","text_ar":"قِيَمٌ"},{"kind":"text","text":"; or for"},{"kind":"arabic","text_bw":"*aA bidaEK","text_ar":"ذَا بِدَعٍ"},{"kind":"text","text":"[in which the latter word is pl. of"},{"kind":"arabic","text_bw":"bidoEapN","text_ar":"بِدْعَةٌ"},{"kind":"text","text":"]. (Bd.) ―         -b2-  Applied to a man, (TA,)"},{"kind":"italic_en","text":"Superlative"},{"kind":"text","text":"(Ks, K)"},{"kind":"italic_en","text":"in his kind"},{"kind":"text","text":"(Ks) in anything; (K;) in good and in evil; (Ks;) or in knowledge, or courage, or nobility: (K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": pl. of the mase."},{"kind":"arabic","text_bw":"A^abodaAEN","text_ar":"اَبْدَاعٌ"},{"kind":"text","text":"[a pl. of pauc., which is also, as is said in the L, applied to women,] and"},{"kind":"arabic","text_bw":"buduEN","text_ar":"بُدُعٌ"},{"kind":"text","text":"[a pl. of mult.]; and pl. of the fem."},{"kind":"arabic","text_bw":"bidaEN","text_ar":"بِدَعٌ"},{"kind":"text","text":". (K.) ↓ A man"},{"kind":"italic_en","text":"liberal in disposition;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gamorN","text_ar":"غَمْرٌ"},{"kind":"text","text":". (IAar, K.) ―         -b3-  A"},{"kind":"italic_en","text":"full"},{"kind":"text","text":"body. (K.)"}],"source_refs":["K","Msb","S","TA","Ks"]},{"entry_id":"n1995","headword_ar":"بِدَعٌ","root":"bdE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bidoEN","text_ar":"بِدْعٌ"},{"kind":"text","text":". ―         -b2-  It is also pl. of"},{"kind":"arabic","text_bw":"bidoEapN","text_ar":"بِدْعَةٌ"},{"kind":"text","text":", [both as a subst. and] as fem. of"},{"kind":"arabic","text_bw":"bidoEN","text_ar":"بِدْعٌ"},{"kind":"text","text":". (K.)"}],"source_refs":[]}]},"classical_definitions":null}