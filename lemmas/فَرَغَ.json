A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be empty, to be vacant","tags":["intransitive"]},{"pos":"verb","gloss":"to be exhausted, to wind up","tags":["intransitive"]},{"pos":"verb","gloss":"to empty, to void","tags":["transitive"]},{"pos":"adj","gloss":"empty, vacant"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ف ر غ (f r ḡ)."},"ipa":["/fa.ra.ɣa/","/far.ra.ɣa/","/fa.riɣ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33635","headword_ar":"فَرَغَ","root":"frg","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":"; and app."},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", as below; inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":"; or, accord. to some, the latter is a simple subst., but it is more commonly used than the former;] said of a thing,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty, vacant, void, devoid, destitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":". (Msb.) [You say,"},{"kind":"arabic","text_bw":"faraga mino ka*aA","text_ar":"فَرَغَ مِنْ كَذَا"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty, vacant, void, devoid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destitute, of such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied thereby."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"faraga laka","text_ar":"فَرَغَ لَكَ"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vacant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied, for thee;"},{"kind":"text","text":"as though it were a place, or a vessel: and hence,"},{"kind":"italic_en","text":"the thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, exclusively for thee"},{"kind":"text","text":"]. (TA voce"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":".) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"faraga","text_ar":"فَرَغَ"},{"kind":"text","text":"(O, * K, * TA) said of a man, (TA,) [and app."},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":"also, as below,] inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He died;"},{"kind":"text","text":"(O, K, TA;) because his body became devoid of his soul, or spirit. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faraga mina Al$~ugoli","text_ar":"فَرَغَ مِنَ الشُّغْلِ"},{"kind":"text","text":", (S, O, Msb, K, *) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"(S, O, Msb, K) and [more commonly]"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":", (S, O, K,) or the latter is a simple subst.; (Msb;) and"},{"kind":"arabic","text_bw":"farag","text_ar":"فَرَغ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (O, K,) mentioned by Yoo; (O;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (O, Msb, K,) of the dial. of Temeem; (Msb;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", a compound of two dial. vars.; (O, Msb;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vacant from, devoid of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from, business, occupation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employment; unoccupied, unemployed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at leisure."},{"kind":"text","text":"(K, * TA.) [See also 5.] ―         -b4-  [And hence,"},{"kind":"arabic","text_bw":"faraga mina","text_ar":"فَرَغَ مِنَ"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"italic_en","text":"He ceased from, ended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"finished, the affair."},{"kind":"text","text":"] ―         -b5-  And"},{"kind":"arabic","text_bw":"faraga lahu","text_ar":"فَرَغَ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (O, Msb, K, TA,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"fariga","text_ar":"فَرِغَ"},{"kind":"text","text":", (O, * Msb, K, * TA,) aor."},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"furuwgN","text_ar":"فُرُوغٌ"},{"kind":"text","text":"and [more commonly]"},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, his object,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the object to which he directed himself;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSada","text_ar":"قَصَدَ"},{"kind":"text","text":": (O, Msb, K, TA:) [or"},{"kind":"italic_en","text":"he made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, his exclusive object;"},{"kind":"text","text":"agreeably with an explanation of the phrase here following]: whence, in the Kur [lv. 31],"},{"kind":"arabic","text_bw":"lakumo sanaforugu","text_ar":"لَكُمْ سَنَفْرُغُ"},{"kind":"italic_en","text":"We will make you our object;"},{"kind":"text","text":"expl. by IAar as meaning"},{"kind":"arabic","text_bw":"sanaEomidu","text_ar":"سَنَعْمِدُ"},{"kind":"text","text":"[which is syn. with"},{"kind":"arabic","text_bw":"sanaqoSidu","text_ar":"سَنَقْصِدُ"},{"kind":"text","text":"]; (TA;) and some read"},{"kind":"arabic","text_bw":"sanaforagu","text_ar":"سَنَفْرَغُ"},{"kind":"text","text":"; (O, TA;) and some,"},{"kind":"arabic","text_bw":"saniforagu","text_ar":"سَنِفْرَغُ"},{"kind":"text","text":"; (O;) and some,"},{"kind":"arabic","text_bw":"saniforigu","text_ar":"سَنِفْرِغُ"},{"kind":"text","text":", asserting that Temeem say"},{"kind":"arabic","text_bw":"niEolimu","text_ar":"نِعْلِمُ"},{"kind":"text","text":"; (O, TA;) and some,"},{"kind":"arabic","text_bw":"sanaforagu A_ilayokumo","text_ar":"سَنَفْرَغُ اـِلَيْكُمْ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"sanaqoSidu","text_ar":"سَنَقْصِدُ"},{"kind":"arabic","text_bw":"A_ilayokumo","text_ar":"اـِلَيْكُمْ"},{"kind":"text","text":"; or"},{"kind":"arabic","text_bw":"sanaforugu lakumo","text_ar":"سَنَفْرُغُ لَكُمْ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"We will apply ourself exclusively"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sanatajar~adu","text_ar":"سَنَتَجَرَّدُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to"},{"kind":"text","text":"the reckoning with, and the requiting of,"},{"kind":"italic_en","text":"you;"},{"kind":"text","text":"and it is said to be a threat; (Bd;) a metaphorical phrase, from a man's saying to him whom he threatens,"},{"kind":"arabic","text_bw":"saA^aforugu","text_ar":"سَاَفْرُغُ"},{"kind":"arabic","text_bw":"laka","text_ar":"لَكَ"},{"kind":"text","text":", (Ksh, Bd,) meaning"},{"kind":"italic_en","text":"I will apply myself exclusively to"},{"kind":"text","text":"the making an assault upon"},{"kind":"italic_en","text":"thee:"},{"kind":"text","text":"(Ksh:) one says [also] in threatening,"},{"kind":"arabic","text_bw":"laA^aforugan~a laka","text_ar":"لَاَفْرُغَنَّ لَكَ"},{"kind":"text","text":"[meaning in like manner"},{"kind":"italic_en","text":"I will assuredly apply myself"},{"kind":"text","text":"&c.]. (TA.) [See, again, 5.] ―         -b6-"},{"kind":"arabic","text_bw":"fariga AlmaA='u","text_ar":"فَرِغَ المَا=ءُ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"faraAgN","text_ar":"فَرَاغٌ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"The water poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became poured out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(S, O, K.)       -A2-"},{"kind":"arabic","text_bw":"faruga","text_ar":"فَرُغَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"faraAgapN","text_ar":"فَرَاغَةٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"was easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, and quick, in pace, and wide in step."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"farugati","text_ar":"فَرُغَتِ"},{"kind":"arabic","text_bw":"AlD~arobapu","text_ar":"الضَّرْبَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"wound made by a"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"stroke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blow, was wide;"},{"kind":"text","text":"(O, K, TA;) likened to the"},{"kind":"arabic","text_bw":"farog","text_ar":"فَرْغ"},{"kind":"text","text":"of the leathern bucket. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"faraAgapN","text_ar":"فَرَاغَةٌ"},{"kind":"text","text":"(as an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"faruga","text_ar":"فَرُغَ"},{"kind":"text","text":", TK) signifies The"},{"kind":"italic_en","text":"being impatient, and disquieted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disturbed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitated."},{"kind":"text","text":"(O, K.)       -A3-"},{"kind":"arabic","text_bw":"faraga","text_ar":"فَرَغَ"},{"kind":"text","text":"as trans.: see 4."}],"source_refs":["TA","S","O","Msb","K","Ksh","Bd"]}]}}