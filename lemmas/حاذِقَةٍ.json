talic_en","text":"so as to know abstrusities and niceties,"},{"kind":"text","text":"(see 1,)] in an art, or a habitual work or occupation, and in the Kur-án: pl."},{"kind":"arabic","text_bw":"Hu*~aAqN","text_ar":"حُذَّاقٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN fiY SanoEatihi","text_ar":"فُلَانٌ فِى صَنْعَتِهِ"},{"kind":"arabic","text_bw":"HaA*iqN baA*iqN","text_ar":"حَاذِقٌ بَاذِقٌ"},{"kind":"text","text":"(S, TA) (tropical:)"},{"kind":"italic_en","text":"Such a one is skilled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in his art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habitual work"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupation;"},{"kind":"text","text":"(TA;) using the latter word as an imitative sequent. (S, TA.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"Bad, evil, wicked, mischievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xabiyvN","text_ar":"خَبِيثٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["AHn","TA","S"]}]},"classical_definitions":null}