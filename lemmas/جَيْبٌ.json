nisu Aljayobi", "text_ar": "هُوَ دَنِسُ الجَيْبِ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "He is a person of foul heart"}, {"kind": "text", "text": "]. (A in art."}, {"kind": "arabic", "text_bw": "dns", "text_ar": "دنس"}, {"kind": "text", "text": ".) And"}, {"kind": "arabic", "text_bw": "radaEa jayobahu Eanohu", "text_ar": "رَدَعَ جَيْبَهُ عَنْهُ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He cleared his heart,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "bosom, of it."}, {"kind": "text", "text": "(K in art."}, {"kind": "arabic", "text_bw": "rdE", "text_ar": "ردع"}, {"kind": "text", "text": "q. v.) ―         -b3-"}, {"kind": "arabic", "text_bw": "jayobu AlA^aroDi", "text_ar": "جَيْبُ الاَرْضِ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The place of entrance of the land,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "country:"}, {"kind": "text", "text": "(K:) pl."}, {"kind": "arabic", "text_bw": "juyuwbN", "text_ar": "جُيُوبٌ"}, {"kind": "text", "text": ". (TA.)"}], "source_refs": ["K", "S", "TA", "Msb", "MF"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}