p"}],"frequency_in_corpus":57,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n798","n805","n812","n809"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B3%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to share one's worldly possessions (ه = with s.o.), be charitable / generous (ه = with s.o.)"},{"pos":"verb","gloss":"to assist, support (ه = s.o.)"},{"pos":"verb","gloss":"to console, comfort (ه = s.o.)"},{"pos":"verb","gloss":"to treat, cure (ه = s.th., medically)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n798","headword_ar":"اُسًي","root":"Asw","body":[{"kind":"italic_en","text":"Patience."},{"kind":"text","text":"(S.)       -A2-  Also pl. of"},{"kind":"arabic","text_bw":"A^usowapN","text_ar":"اُسْوَةٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"A_isFy","text_ar":"اـِسًي"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"A_isowapN","text_ar":"اـِسْوَةٌ"},{"kind":"text","text":". (S * K, * TA.)"}],"source_refs":[]},{"entry_id":"n805","headword_ar":"اَسِىٌّ","root":"Asw","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA^osuw~N","text_ar":"مَاْسُوٌّ","orth_type":"arrow"},{"kind":"text","text":"; (S, M, K;) i. e.,"},{"kind":"italic_en","text":"Dressed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"treated curatively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surgically;"},{"kind":"text","text":"applied to a wound. (S, M. *)       -A2-  See also"},{"kind":"arabic","text_bw":"A^asowaAnu","text_ar":"اَسْوَانُ"}],"source_refs":[]},{"entry_id":"n812","headword_ar":"اَسِىٌّ","root":"AsY","body":[{"kind":"text","text":"see above."}],"source_refs":[]},{"entry_id":"n809","headword_ar":"اَسِىَ","root":"AsY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^osaY","text_ar":"يَاْسَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^asFY","text_ar":"اَسًى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A^asFA","text_ar":"اَسًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"He grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mourned,"},{"kind":"text","text":"(S, M, Msb, K,)"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (M, K.) See art."},{"kind":"arabic","text_bw":"Asw","text_ar":"اسو"},{"kind":"text","text":"."}],"source_refs":["S","M","Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%B3%D9%8A/","headword_ar":"أسي","entries":[{"lexicon_id":"dictionary_16","lexicon_en":"Abu Ḥayyān al-Gharnāṭī, Tuḥfat al-Arīb bi-mā fī l-Qurʾān min al-Gharīb (d. 1344 CE)","lexicon_ar":"تحفة الأريب بما في القرآن من الغريب لأبي حيان الغرناطي الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=10648#d958a6","body_html":"<span class=\"title1\">أسي</span><span>: {آسى}: أحزن.</span>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10648#174701","body_html":"<span>أسي: الأَسَى، مقصور: الحُزْنُ على الشَّيء.. أَسِيَ يَأْسَى أَسىً فهو أسيان، والمرأة: أَسيَى والجميع: أسايا، وأسيانون، وأَسْيَيات.. ويجوز في الوحدان: أَسْيان وأَسْوان، قال :</span><br><br><span>ماذا هنالك من أسوان مكتئب </span><span class=\"red\">...</span><span> وساهف ثمل في صعدة قِصَمِ</span><br><br><span>أي: كِسَر. وأَسَّيته أُؤَسِيّهِ تأسيةً، أي: عزّيته، وتأسَّى مثل تَعَزَّى. وآسية: اسم امرأة فرعون. والآسِيَةُ، بوزن فاعِلة: ما أسّس على بنيانٍ فأحكم، ثمّ أسس ثم رفع فوقه بناء غير ذلك من ساريةٍ أو نحوها. وإنّ منزلة فلان عند الملك آسية، على وزن فاعولة، لا تزول.</span><span> </span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=10648#98e3f4","body_html":"<span class=\"title1\">أس ي</span><br><br><span>أَسِيتُ عليه أسىً حَزِنْتُ ورَجُلٌ آسٍ وأَسْيَان وامرأة أسَيِةٌ وأسيانَةٌ والجمع أَسْيَانُون وأَسْيانات وأَسَايَا والآسِيَة البِناء المُحْكَم والآسِيَةُ الدّعامَةُ والسارِيَةُ قال</span><span>(فإن تَكُ قد وَدَّعْتَ غَيْرَ مُذَمَّم </span><span class=\"red\">...</span><span> أَواسِيَ مُلْكٍ أَثْبَتَتْها الأَوَائِلُ)</span><br><br><span>وأسَيتُ له من اللَّحْم خاصة أَسْياً أَبْقَيْتُه له والأسِيُّ بَقِيَّة الدار وخُرْثِيُّ المَتاعِ وقالوا كُلُوا فلم نُؤَسِّ لكم مُشَدَّدٌ أي لم نَتَعَمَّدْكُمْ بهذا الطعام وحكى بعضهم فلم يُؤْسّ لكم أي لم تُتَعَمَّدُوا به وآسِيَة امْرَأَةُ فِرْعَونَ والآسِي ماءٌ بِعَيْنِه قال الراعي</span><br><br><span>(ألم نترك نِساء بني زُهَيْرٍ </span><span class=\"red\">...</span><span> على الآسِي يُحَلِّقْنَ القُرُونَا)</span><br><br><span>وإنما أَثْبَتُّه في بنات الياء لأن اللام ياء أكثر منها واواً</span>"}]}}