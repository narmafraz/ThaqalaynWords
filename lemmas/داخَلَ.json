7"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D8%AE%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to befall, to seize, to come over"},{"pos":"verb","gloss":"to be familiar or intimate"},{"pos":"verb","gloss":"to respond, to deal with"},{"pos":"verb","gloss":"press someone to declare something, to confess"},{"pos":"adj","gloss":"active participle of دَخَلَ (daḵala)","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"interior"},{"pos":"noun","gloss":"inside"},{"pos":"prep","gloss":"inside"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of دَخَلَ (daḵala, “to enter, to go in”)."},"ipa":["/daː.xa.la/","/daː.xil/","/daː.xi.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12277","headword_ar":"دَاخِلٌ","root":"dxl","body":[{"kind":"text","text":"[act. part. n. of 1,"},{"kind":"italic_en","text":"Entering,"},{"kind":"text","text":"&c. Hence,]"},{"kind":"arabic","text_bw":"Ald~aAxilu","text_ar":"الدَّاخِلُ"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"dax~aAlu AlA^u*uni","text_ar":"دَخَّالُ الاُذُنِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"duxolulN","text_ar":"دُخْلُلٌ"},{"kind":"text","text":". ―         -b2-  It is [also] applied as an epithet to a disease, and to love; [as meaning"},{"kind":"italic_en","text":"Internal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inward;"},{"kind":"text","text":"] and so ↓"},{"kind":"arabic","text_bw":"daxiylN","text_ar":"دَخِيلٌ","orth_type":"arrow"},{"kind":"text","text":", in the same sense. (K.) ―         -b3-  [Also, as a subst.,] The"},{"kind":"italic_en","text":"interior"},{"kind":"text","text":"of anything; (M, Msb, * TA;) contr. of"},{"kind":"arabic","text_bw":"xaArijN","text_ar":"خَارِجٌ"},{"kind":"text","text":". (Msb.) Sb says that it is not used adverbially unless with a particle; [so that you may not say"},{"kind":"arabic","text_bw":"daAxilFA","text_ar":"دَاخِلًا"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"Within;"},{"kind":"text","text":"but you say"},{"kind":"arabic","text_bw":"fiY daAxilK","text_ar":"فِى دَاخِلٍ"},{"kind":"text","text":"; and in like manner you say"},{"kind":"arabic","text_bw":"A_ilaY daAxilK","text_ar":"اـِلَى دَاخِلٍ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"In,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inwards;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino daAxilK","text_ar":"مِنْ دَاخِلٍ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"From within;"},{"kind":"text","text":"] i. e. it is only a subst.; because it has a special signification, like"},{"kind":"arabic","text_bw":"yadN","text_ar":"يَدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rijolN","text_ar":"رِجْلٌ"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"daAxilu AlHub~i","text_ar":"دَاخِلُ الحُبِّ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"duxolulN","text_ar":"دُخْلُلٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}