rences":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n13665","n14144","n14148"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dissolve, to melt, to thaw","examples":[{"text":"الثَّلْجُ يَذُوبُ","english":"the snow is melting"},{"text":"وَنَهْرٍ كَمَا ذَابَتْ سَبَائِكُ فِضَّةٍ / حَكَتْ بِمَحَانِيهِ ٱنْعِطَافَ الْأَرَاقِمِ"}]}]},"etymology":null,"ipa":["/ðaː.ba/","/daːb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13665","headword_ar":"ذَابٌّ","root":"*b","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"*ab~N","text_ar":"ذَبٌّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14144","headword_ar":"ذَابَ","root":"*wb","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"arabic","text_bw":"ya*uwbu","text_ar":"يَذُوبُ"},{"kind":"text","text":", (T, S, Msb,) inf. n."},{"kind":"arabic","text_bw":"*awobN","text_ar":"ذَوْبٌ"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"*awabaAnN","text_ar":"ذَوَبَانٌ"},{"kind":"text","text":", (T, S, M, Msb, K,)"},{"kind":"italic_en","text":"It melted, dissolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became fluid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liquid; contr. of"},{"kind":"arabic","text_bw":"jamada","text_ar":"جَمَدَ"},{"kind":"text","text":": (S, M, A, K:)"},{"kind":"italic_en","text":"it flowed."},{"kind":"text","text":"(T, Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"*Ab damoEuhu","text_ar":"ذاب دَمْعُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His tears flowed"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"*aAbato Hadaqatuhu","text_ar":"ذَابَتْ حَدَقَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His eye"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"shed tears;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"flowed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with tears"},{"kind":"text","text":"]. (T.) ―         -b3-"},{"kind":"arabic","text_bw":"*Ab jisomuhu","text_ar":"ذاب جِسْمُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His body became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"one says,"},{"kind":"arabic","text_bw":"vaAba baEodamaA *aAba","text_ar":"ثَابَ بَعْدَمَا ذَابَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He became fat after he had been lean"},{"kind":"text","text":"]. (A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"*aAba","text_ar":"ذَابَ"},{"kind":"text","text":"[alone] (assumed tropical:)"},{"kind":"italic_en","text":"He became foolish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupid, after having been intelligent."},{"kind":"text","text":"(T, K.) ―         -b5-"},{"kind":"arabic","text_bw":"naHonu laA najomudu","text_ar":"نَحْنُ لَا نَجْمُدُ"},{"kind":"arabic","text_bw":"fiY AlHaq~i walaA na*uwbu fiY AlbaATili","text_ar":"فِى الحَقِّ وَلَا نَذُوبُ فِى البَاطِلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"We will not be hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"niggardly, in the case of truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"right, nor will we be soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easily yielding, in the case of falsity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrong"},{"kind":"text","text":"]. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"h`*aA AlkalaAmu fiyhi","text_ar":"هٰذَا الكَلَامُ فِيهِ"},{"kind":"arabic","text_bw":"*awobu Alr~uwHi","text_ar":"ذَوْبُ الرُّوحِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse, contains that which melts the soul"},{"kind":"text","text":"]. (A.) ―         -b7-"},{"kind":"arabic","text_bw":"*aAbati Al$~amosu","text_ar":"ذَابَتِ الشَّمْسُ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"Ast*Abt","text_ar":"استذابت","orth_type":"arrow"},{"kind":"text","text":"(as is shown by a phrase mentioned in the L in art."},{"kind":"arabic","text_bw":"Sxd","text_ar":"صخد"},{"kind":"text","text":")] (tropical:)"},{"kind":"italic_en","text":"The sun became intensely hot."},{"kind":"text","text":"(S, A, K.) ―         -b8-"},{"kind":"quote","text":"A^a*uwbu All~ayaAliY A^awoyujiybu SadaAkumaA"},{"kind":"text","text":"occurring in a trad. of Kuss, means (assumed tropical:)"},{"kind":"italic_en","text":"I will wait in expectation during the lapse of the nights"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or the echo of you two shall answer"},{"kind":"text","text":"]; from"},{"kind":"arabic","text_bw":"AlA_i*aAbapu","text_ar":"الاـِذَابَةُ"},{"kind":"text","text":", which signifies “ spoil, booty, or plunder. ” (TA.) ―         -b9-"},{"kind":"arabic","text_bw":"maA *aAba fiY yadiY $aYo'N","text_ar":"مَا ذَابَ فِى يَدِى شَىْءٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"There remained not in my hand anything."},{"kind":"text","text":"(AHeyth, TA.) And"},{"kind":"arabic","text_bw":"maA *aAba fiY yadayohi minohu xayorN","text_ar":"مَا ذَابَ فِى يَدَيْهِ مِنْهُ خَيْرٌ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"fiY yadiY","text_ar":"فِى يَدِى"},{"kind":"text","text":", (K,) (assumed tropical:)"},{"kind":"italic_en","text":"There came not"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into his hands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into my hands, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, any good"},{"kind":"text","text":"]. (M, K.) ―         -b10-"},{"kind":"arabic","text_bw":"*Ab Ealayohi AlmaAlu","text_ar":"ذاب عَلَيْهِ المَالُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The property became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent, on him to render as a debt."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"*Ab liY Ealayohi Haq~N","text_ar":"ذاب لِى عَلَيْهِ حَقٌّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on him to render to me, and established against him."},{"kind":"text","text":"(S, A, Mgh, K. *) And"},{"kind":"arabic","text_bw":"*Ab Ealayohi mina AlA^amori ka*aA","text_ar":"ذاب عَلَيْهِ مِنَ الاَمْرِ كَذَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"*awobN","text_ar":"ذَوْبٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"Such a part of the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"jamada","text_ar":"جَمَدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"text","text":". (M.)       -A2-"},{"kind":"arabic","text_bw":"*Ab","text_ar":"ذاب"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He continued in the eating of"},{"kind":"arabic","text_bw":"*awob","text_ar":"ذَوْب"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"honey."},{"kind":"text","text":"(T, L, K. *)"}],"source_refs":["T","S","Msb","M","K","A"]},{"entry_id":"n14148","headword_ar":"ذَابٌ","root":"*wb","body":[{"kind":"italic_en","text":"A vice, fault, defect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(K;) like ["},{"kind":"arabic","text_bw":"*ayobN","text_ar":"ذَيْبٌ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"*aAmN","text_ar":"ذَامٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*ayomN","text_ar":"ذَيْمٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B0%D8%A7%D8%A8/","headword_ar":"ذاب","entries":[{"lexicon_id":"dictionary_51","lexicon_en":"Habib Anthony Salmone, An Advanced Learner's Arabic-English Dictionary (1889)","lexicon_ar":"حبيب سالمون، قاموس عربي انجليزي متقدم للمتعلمين","permalink":"https://arabiclexicon.hawramani.com/?p=51211#69cd61","body_html":"ذاب<br> ذَابَ(n. ac. ذَأْب [ ])<br>a. Drove, urged on.<br> b. Drove away, frightened.<br> c. Despised.<br> d. see IV (a)"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=51211#4491e8","body_html":"ذاب: ذكر فوك في مادة لاتينية معناها: (خلاف) العبارات التالية: مِنْ ذابَ، ومِنْ ذابَ لقُدَّام، ومِنْ ذابَ لأمام، مِنْ ذابَ لِبَعْد ذا. كما ذكر في مادة لاتينية معناها (فقط): ذاب الآن."}]}}