ind":"italic_en","text":"gladness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of happiness; a thing whereby one is made joyful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"happy;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"faroHapN","text_ar":"فَرْحَةٌ","orth_type":"arrow"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"masar~apN","text_ar":"مَسَرَّةٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"page_break","n":2362},{"kind":"text","text":"And"},{"kind":"italic_en","text":"A thing that thou givest to him that rejoices thee;"},{"kind":"text","text":"(L, K;)"},{"kind":"italic_en","text":"a recompense that thou givest him;"},{"kind":"text","text":"(L;) [as also ↓"},{"kind":"arabic","text_bw":"faroHapN","text_ar":"فَرْحَةٌ","orth_type":"arrow"},{"kind":"text","text":"; for] you say,"},{"kind":"arabic","text_bw":"laka EinodiY","text_ar":"لَكَ عِنْدِى"},{"kind":"arabic","text_bw":"faroHapN A_ino ba$~arotaniY","text_ar":"فَرْحَةٌ اـِنْ بَشَّرْتَنِى"},{"kind":"text","text":", (S, A, [in one of my copies of the S"},{"kind":"arabic","text_bw":"A^aYo ba$~arotaniY","text_ar":"اَىْ بَشَّرْتَنِى"},{"kind":"text","text":", as though this were an explanation, but the former is the right reading,]) and"},{"kind":"arabic","text_bw":"furoHapN","text_ar":"فُرْحَةٌ"},{"kind":"text","text":", (S,) meaning"},{"kind":"arabic","text_bw":"bu$oraY","text_ar":"بُشْرَى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"There is for thee, with me, a gift for announcing a joyful event, if thou announce to me such an event"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S"]}]},"classical_definitions":null}