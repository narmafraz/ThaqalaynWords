rch_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%A8%D9%8E%D8%B3%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2530","headword_ar":"انبسط","root":"bsT","body":[{"kind":"text","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"basaTahu","text_ar":"بَسَطَهُ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"tbs~T","text_ar":"تبسّط"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"bas~aTahu","text_ar":"بَسَّطَهُ"},{"kind":"text","text":"; both signifying"},{"kind":"italic_en","text":"It became spread"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it spread"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread out"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth; it became expanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it expanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it expanded itself; it became extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it extended itself:"},{"kind":"text","text":"[&c.]. (M, K, TA.) You say,"},{"kind":"arabic","text_bw":"AnbsT Al$~ayo'u EalaY AlA^aroDi","text_ar":"انبسط الشَّيْءُ عَلَى الاَرْضِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing became spread"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread out, &c., upon the ground"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"AnbsT Aln~ahaAru","text_ar":"انبسط النَّهَارُ"},{"kind":"italic_en","text":"The day became advanced, the sun being high: it became long:"},{"kind":"text","text":"(M, K, TA:) and in like manner one uses the verb in relation to other things. (M, TA.) ―         -b2-  [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"He expatiated."},{"kind":"text","text":"―         -b3-  And]"},{"kind":"arabic","text_bw":"AnbsT wajohuhu","text_ar":"انبسط وَجْهُهُ"},{"kind":"text","text":"(assumed tropical:) ["},{"kind":"italic_en","text":"His countenance became unwrinkled, as though dilated;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"it became open,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"AnbsT","text_ar":"انبسط"},{"kind":"text","text":"alone; or"},{"kind":"italic_en","text":"he became open,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful, in countenance,"},{"kind":"text","text":"as is said in the KL.]. (TA.) [And"},{"kind":"arabic","text_bw":"AnbsT","text_ar":"انبسط"},{"kind":"text","text":", alone, (tropical:)"},{"kind":"italic_en","text":"He became dilated in heart;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he rejoiced;"},{"kind":"text","text":"or"},{"kind":"page_break","n":204},{"kind":"italic_en","text":"became joyous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerful:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"basaTahu","text_ar":"بَسَطَهُ"},{"kind":"text","text":".] ―         -b4-  [Hence also,]"},{"kind":"arabic","text_bw":"AnbsT","text_ar":"انبسط"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He left shyness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aversion; he became free therefrom:"},{"kind":"text","text":"(S, TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bold, forward, presumptuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrogant:"},{"kind":"text","text":"(KL, PS:)"},{"kind":"italic_en","text":"he became emboldened,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"incited to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that kind of presumptuous boldness which is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"daAl~ap","text_ar":"دَالَّة"},{"kind":"text","text":". (Har p. 155.) And"},{"kind":"arabic","text_bw":"AnbsT","text_ar":"انبسط"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"(tropical:) ["},{"kind":"italic_en","text":"He was open,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unreserved, to him in conversation: and he acted towards him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved to him, without shyness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aversion;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with boldness, forwardness, presumptuousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrogance:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he applied himself to it"},{"kind":"text","text":"(namely, an affair,)"},{"kind":"italic_en","text":"with boldness, forwardness, presumptuousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrogance."},{"kind":"text","text":"] (TA.)"}],"source_refs":["M","K","TA","S","KL","PS"]}]},"classical_definitions":null}