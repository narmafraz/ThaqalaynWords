"text":"Staying, abiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in a tent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"house."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]}}