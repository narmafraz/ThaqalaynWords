{"lemma":"حُمُقٌ","slug":"حُمُقٌ","root":"ح.م.ق","root_slug":"ح-م-ق","root_link":"/words/roots/ح-م-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n9142","n9144"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8F%D9%85%D9%8F%D9%82%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"crazy, insane"},{"pos":"adj","gloss":"stupid, silly, foolish"},{"pos":"adj","gloss":"elative degree of أَحْمَق (ʔaḥmaq)"},{"pos":"adj","gloss":"elative degree of أَحْمَق (ʔaḥmaq):; more/most foolish"},{"pos":"noun","gloss":"fool"}]},"etymology":{"source":"wiktextract","text":"Color or defect adjective from the root ح م ق (ḥ m q)."},"ipa":["/ʔaħ.maq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9142","headword_ar":"حُمُقٌ","root":"Hmq","body":[{"kind":"italic_en","text":"Foolishness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupidity;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"unsoundness in the intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding;"},{"kind":"text","text":"(T, Mgh, Msb;) and"},{"kind":"italic_en","text":"stagnancy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dulness, therein;"},{"kind":"text","text":"(T, Mgh;) or"},{"kind":"italic_en","text":"deficiency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defectiveness, therein;"},{"kind":"text","text":"(IF, Mgh;) or"},{"kind":"italic_en","text":"paucity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want, thereof;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HumuqN","text_ar":"حُمُقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HamaAqapN","text_ar":"حَمَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":"signify the same: (S, K:) [all are said to be inf. ns.; but the last, accord. to the Msb, is a simple subst.: (see 1:)] the proper and primary signification of"},{"kind":"arabic","text_bw":"HumoqN","text_ar":"حُمْقٌ"},{"kind":"text","text":"is [said to be] the"},{"kind":"italic_en","text":"putting a thing in a wrong place, with knowledge of its being bad"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to do so"},{"kind":"text","text":"]. (TA.) [Hence,]"},{"kind":"arabic","text_bw":"nawomapu AlHumoqi","text_ar":"نَوْمَةُ الحُمْقِ"},{"kind":"italic_en","text":"The sleep after"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the period of the afternoon called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"EaSor","text_ar":"عَصْر"},{"kind":"text","text":"; when no one sleeps except one who is intoxicated, or one who is insane, or unsound in mind. (Har p. 223. [See also"},{"kind":"arabic","text_bw":"xuroqN","text_ar":"خُرْقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuluqN","text_ar":"خُلُقٌ"},{"kind":"text","text":".]) ―         -b2-  And"},{"kind":"italic_en","text":"Deceit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a deception."},{"kind":"text","text":"(TA.) ―         -b3-  [It is said that]"},{"kind":"arabic","text_bw":"AlHumoqu","text_ar":"الحُمْقُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Wine:"},{"kind":"text","text":"(Z, K:) as being a cause of"},{"kind":"arabic","text_bw":"Humoq","text_ar":"حُمْق"},{"kind":"text","text":"; like as wine is called"},{"kind":"arabic","text_bw":"A_ivomN","text_ar":"اـِثْمٌ"},{"kind":"text","text":"as being a cause of"},{"kind":"arabic","text_bw":"A_ivom","text_ar":"اـِثْم"},{"kind":"text","text":": (Z, TA:) but Ez-Zejjájee disallows this: and [it is also said that] ↓"},{"kind":"arabic","text_bw":"AlHumayoqaA='u","text_ar":"الحُمَيْقَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, because wine occasions"},{"kind":"arabic","text_bw":"Humoq","text_ar":"حُمْق"},{"kind":"text","text":"to its drinker. (TA.)"}],"source_refs":["S","K","Z","TA"]},{"entry_id":"n9144","headword_ar":"حُمُقٌ","root":"Hmq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HumoqN","text_ar":"حُمْقٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}