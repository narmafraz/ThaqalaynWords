":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n22653"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be compassionate, to be tender, to melt"},{"pos":"verb","gloss":"to wary, to be on one’s guard, to shun"},{"pos":"verb","gloss":"to diminish, to lessen"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22653","headword_ar":"اشفق","root":"$fq","body":[{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was cautious;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"$afiqa","text_ar":"شَفِقَ","orth_type":"arrow"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"$afaqa","text_ar":"شَفَقَ"},{"kind":"text","text":"]; or only the former: (K, TA:) [accord. to ISd,] ↓"},{"kind":"arabic","text_bw":"$afiqa","text_ar":"شَفِقَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$afaqN","text_ar":"شَفَقٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he feared:"},{"kind":"text","text":"(M:) IDrd says, ↓"},{"kind":"arabic","text_bw":"$afiqotu","text_ar":"شَفِقْتُ","orth_type":"arrow"},{"kind":"text","text":"[in one of my copies of the S"},{"kind":"arabic","text_bw":"$faqtu","text_ar":"شفَقتُ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"A^a$ofaqotu","text_ar":"اَشْفَقْتُ"},{"kind":"text","text":"are syn., (S, O, TA,) as some assert, (O, TA,) but the lexicologists disallow this, (S, O,) saying that one should only say"},{"kind":"arabic","text_bw":"A^a$ofaqotu","text_ar":"اَشْفَقْتُ"},{"kind":"text","text":": (O:) accord. to Er-Rághib,"},{"kind":"arabic","text_bw":"AlA_i$ofaAqu","text_ar":"الاـِشْفَاقُ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"the being affected with"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"care,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solicitude, mixed with fear;"},{"kind":"text","text":"and when it is trans. by means of"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":", the meaning of fear is most apparent in it; but when trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":", the meaning of care, or solicitude, is most apparent in it: (TA: [and the like is said by Bd in xxi. 29:]) or it signifies ["},{"kind":"italic_en","text":"the being affected with"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"fright"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fear"},{"kind":"text","text":"]; sometimes"},{"kind":"italic_en","text":"mixed with faithful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sincere"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honest advice;"},{"kind":"text","text":"and sometimes"},{"kind":"italic_en","text":"divested thereof:"},{"kind":"text","text":"(Ham p. 179:) one says,"},{"kind":"arabic","text_bw":"A^a$ofaqotu minohu","text_ar":"اَشْفَقْتُ مِنْهُ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"mino ka*aA","text_ar":"مِنْ كَذَا"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"I feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was cautious of,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"such a thing:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"A$fq minohu","text_ar":"اشفق مِنْهُ"},{"kind":"italic_en","text":"he feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(MA:) and"},{"kind":"arabic","text_bw":"A^a$ofaqotu Ealayohi","text_ar":"اَشْفَقْتُ عَلَيْهِ"},{"kind":"text","text":", (S, [in which it is implied that this differs from"},{"kind":"arabic","text_bw":"A^a$ofaqotu minohu","text_ar":"اَشْفَقْتُ مِنْهُ"},{"kind":"text","text":",]) or"},{"kind":"arabic","text_bw":"EalaY AlS~agiyri","text_ar":"عَلَى الصَّغِيرِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I was affectionate, kind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassionate,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"favourably inclined,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"towards him,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"towards the little one:"},{"kind":"text","text":"(Msb: [and a similar explanation is given in the MA:]) and ↓"},{"kind":"arabic","text_bw":"$afaqotu","text_ar":"شَفَقْتُ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", is a dial. var. thereof [i. e. of"},{"kind":"arabic","text_bw":"A^a$ofaqotu","text_ar":"اَشْفَقْتُ"},{"kind":"text","text":"when trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":", and perhaps also when it is trans. by means of"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":"]: (Msb:) or"},{"kind":"arabic","text_bw":"A$fq Ealayohi","text_ar":"اشفق عَلَيْهِ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"he was solicitously affectionate,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"towards him;"},{"kind":"text","text":"agreeably with the explanation of Er-Rághib above, and with that here following;]"},{"kind":"italic_en","text":"he was affected with pity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion, and tenderness, and fear, for him, at the same time giving him faithful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sincere"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honest advice,"},{"kind":"arabic","text_bw":"A^ano yanaAlahu makoruwhN","text_ar":"اَنْ يَنَالَهُ مَكْرُوهٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lest some disliked"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil event should betide him"},{"kind":"text","text":"]: (TA:) or"},{"kind":"italic_en","text":"he feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was cautious, for him:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A$fq minohu","text_ar":"اشفق مِنْهُ"},{"kind":"italic_en","text":"he was impatient of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$afaqa","text_ar":"شَفَقَ","orth_type":"arrow"},{"kind":"text","text":"is a dial. var. [of"},{"kind":"arabic","text_bw":"A$fq","text_ar":"اشفق"},{"kind":"text","text":"when trans. by means of"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":", and app. also when trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":"]. (M.)       -A2-  See also 2.       -A3-  Also"},{"kind":"italic_en","text":"He entered upon"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the time of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"$afaq","text_ar":"شَفَق"},{"kind":"text","text":"[q. v.]. (M.) And"},{"kind":"italic_en","text":"He came in a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"time of"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"$afaq","text_ar":"شَفَق"},{"kind":"text","text":": and so ↓"},{"kind":"arabic","text_bw":"$f~q","text_ar":"شفّق","orth_type":"arrow"},{"kind":"text","text":". (M.)"}],"source_refs":["K","TA","M","S","O","Msb","MA"]}]},"classical_definitions":null}