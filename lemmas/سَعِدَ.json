m","num":"p"},{"role":"present_2mp","form":"تَسْعَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْعَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْعَد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْعَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْعَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْعَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْعَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْعَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْعَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْعَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْعَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَعِدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَعِدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْعَد","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْعَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":true,"lemma_key":"سَعِدَ","root":"سعد","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["name","noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n19773"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%B9%D9%90%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be fortunate"},{"pos":"verb","gloss":"to be propitious"},{"pos":"verb","gloss":"to be happy"},{"pos":"verb","gloss":"to be lucky"},{"pos":"verb","gloss":"to be successful"},{"pos":"verb","gloss":"to be happy"},{"pos":"verb","gloss":"to be lucky"},{"pos":"verb","gloss":"to be successful"},{"pos":"noun","gloss":"verbal noun of سَعَدَ (saʕada, “to be fortunate, propitious”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of سَعِدَ (saʕida, “to be happy, lucky, successful”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"good fortune, luck"},{"pos":"noun","gloss":"success"},{"pos":"noun","gloss":"happiness"},{"pos":"name","gloss":"a male given name"},{"pos":"noun","gloss":"sedge (Cyperus)"}]},"etymology":{"source":"wiktextract","text":"From Aramaic סוּעֲדָא / ܣܘܼܥܕܵܐ (suʿdā), ܣܸܥܕܵܐ (seʿdā, “sedge (Cyperus)”), a match too similar for such an unspecific grass to represent cognateship, denoting plants more native to the Fertile Crescent; compare the other borrowing of a name for Cyperus sedges كُولَان (kūlān). A derivation from the root cognate to س ع د (s ʕ d) meaning “prosperity” also with the sense of “moist soil”, “a land that is naturally watered”; sedge being a plant often associated with wetlands. From this root also in Akkadian 𒄑𒋆𒌋𒌋𒁺 (suādu, “an aromatic plant; Cyperus”)."},"ipa":["/suʕd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19773","headword_ar":"سَعِدَ","root":"sEd","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"suEida","text_ar":"سُعِدَ"},{"kind":"text","text":"; (S, A, Msb, K;) inf. n. of the former, (Msb,) or of the latter, (MA,) or of both, (TA,)"},{"kind":"arabic","text_bw":"saEodN","text_ar":"سَعْدٌ"},{"kind":"text","text":", (MA, Msb, TA,) and of the former, (MA,) or of both, (TA,)"},{"kind":"arabic","text_bw":"saEaAdapN","text_ar":"سَعَادَةٌ"},{"kind":"text","text":", (MA, TA,) or this latter is a simple subst.; (Msb;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, A, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prosperous, fortunate, happy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of felicity;"},{"kind":"text","text":"(S, MA, Msb, TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"$aqiYa","text_ar":"شَقِىَ"},{"kind":"text","text":"; (S, * Msb, K *) with respect to religion and with respect to worldly things. (Msb.) You say,"},{"kind":"arabic","text_bw":"saEidotu bihi","text_ar":"سَعِدْتُ بِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suEidotu","text_ar":"سُعِدْتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prosperous,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"by means of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (A.) In the Kur xi. 110, Ks read"},{"kind":"arabic","text_bw":"suEiduwA","text_ar":"سُعِدُوا"},{"kind":"text","text":"[instead of the common reading"},{"kind":"arabic","text_bw":"saEiduwA","text_ar":"سَعِدُوا"},{"kind":"text","text":"]. (S.) [See also"},{"kind":"arabic","text_bw":"saEaAdapN","text_ar":"سَعَادَةٌ"},{"kind":"text","text":", below.] ―         -b2-  And"},{"kind":"arabic","text_bw":"saEada yawomunaA","text_ar":"سَعَدَ يَوْمُنَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suEuwdN","text_ar":"سُعُودٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"saEodN","text_ar":"سَعْدٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Our day was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prosperous, fortunate, auspicious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lucky;"},{"kind":"text","text":"(S, K;) ["},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"naHisa","text_ar":"نَحِسَ"},{"kind":"text","text":"; and in like manner the verb is used in relation to a star or an asterism &c.; and]"},{"kind":"arabic","text_bw":"suEida","text_ar":"سُعِدَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saEodN","text_ar":"سَعْدٌ"},{"kind":"text","text":", signifies [likewise] the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"nuHisa","text_ar":"نُحِسَ"},{"kind":"text","text":". (Mgh.) [See also"},{"kind":"arabic","text_bw":"suEuwdapN","text_ar":"سُعُودَةٌ"},{"kind":"text","text":", below.] ―         -b3-"},{"kind":"arabic","text_bw":"saEada AlmaA='u fiYAlA^aroDi","text_ar":"سَعَدَ المَا=ءُ فِىالاَرْضِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The water came upon the land unsought;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"came flowing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"naturally"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon the surface of the land, not requiring a machine to raise it for the purpose of irrigation."},{"kind":"text","text":"(TA, from a trad.)       -A2-  See also 4, in three places."}],"source_refs":["S","A","Msb","K","MA","TA"]}]}}