{"lemma":"مَنْقَبَة","slug":"مَنْقَبَة","root":"ن.ق.ب","root_slug":"ن-ق-ب","root_link":"/words/roots/ن-ق-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40342"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%86%D9%92%D9%82%D9%8E%D8%A8%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"virtue","tags":["in-plural"]},{"pos":"noun","gloss":"place where one passes, station, pass, particularly at mountains"},{"pos":"noun","gloss":"trephine, or a similar instrument for making holes"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40342","headword_ar":"مَنْقَبَةٌ","root":"nqb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"A narrow way between two houses,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"along which one cannot pass."},{"kind":"text","text":"(L.) It is said in a trad., that one does not possess the right of pre-emption ("},{"kind":"arabic","text_bw":"Al$~ufoEap","text_ar":"الشُّفْعَة"},{"kind":"text","text":") with respect to a"},{"kind":"arabic","text_bw":"mnqbp","text_ar":"منقبة"},{"kind":"text","text":"; and this word is explained as signifying"},{"kind":"italic_en","text":"a wall:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAy^iTN","text_ar":"حَايِطٌ"},{"kind":"text","text":": [and so in the K:] or"},{"kind":"italic_en","text":"a way between two houses, as though it were perforated from one to the other:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way, over an elevated piece of ground."},{"kind":"text","text":"(L.)       -A2-"},{"kind":"arabic","text_bw":"manoqabapN","text_ar":"مَنْقَبَةٌ"},{"kind":"italic_en","text":"A virtue; an excellence; contr. of"},{"kind":"arabic","text_bw":"mavolabapN","text_ar":"مَثْلَبَةٌ"},{"kind":"text","text":": (S:)"},{"kind":"italic_en","text":"a cause of glorying:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"generosity of action,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conduct:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"good disposition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"natural quality:"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"naqiybapN","text_ar":"نَقِيبَةٌ"},{"kind":"text","text":":] (TA:)"},{"kind":"italic_en","text":"a memorable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous action, and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"good"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"internal quality:"},{"kind":"text","text":"(A:) pl."},{"kind":"arabic","text_bw":"manaAqibu","text_ar":"مَنَاقِبُ"},{"kind":"text","text":": (TA:)"},{"kind":"arabic","text_bw":"rjulN *uw manaAqiba","text_ar":"رجُلٌ ذُو مَنَاقِبَ"},{"kind":"italic_en","text":"A man of memorable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous, actions, and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"good"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"internal qualities."},{"kind":"text","text":"(A.)"}],"source_refs":["L","K","S","TA","A"]}]}}