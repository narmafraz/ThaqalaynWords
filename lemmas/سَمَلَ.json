anes_definition":{"source":"lanes","entries":[{"entry_id":"n20772","headword_ar":"سَمَلٌ","root":"sml","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"samalapN","text_ar":"سَمَلَةٌ"},{"kind":"text","text":", in three places.       -A2-  Applied to a garment, or piece of cloth,"},{"kind":"italic_en","text":"Old, and worn out;"},{"kind":"text","text":"(S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"samalapN","text_ar":"سَمَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"samiylN","text_ar":"سَمِيلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"samuwlN","text_ar":"سَمُولٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"samilN","text_ar":"سَمِلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"musomay^il~N","text_ar":"مُسْمَيِلٌّ","orth_type":"arrow"},{"kind":"text","text":": (K:) the pl. of"},{"kind":"arabic","text_bw":"samalN","text_ar":"سَمَلٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^FsomaAlN","text_ar":"اًسْمَالٌ"},{"kind":"text","text":": (A'Obeyd, TA:) and one says also"},{"kind":"arabic","text_bw":"vawobN A^asomaAlN","text_ar":"ثَوْبٌ اَسْمَالٌ"},{"kind":"text","text":", (S, M, K,) like"},{"kind":"arabic","text_bw":"rumoHu A^aqoSaAdN","text_ar":"رُمْحُ اَقْصَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buromapN A^aEo$aArN","text_ar":"بُرْمَةٌ اَعْشَارٌ"},{"kind":"text","text":". (S.) The phrase"},{"kind":"arabic","text_bw":"samalu qaTiyfapK","text_ar":"سَمَلُ قَطِيفَةٍ"},{"kind":"text","text":"occurs in a trad. [as meaning"},{"kind":"italic_en","text":"An old and worn-out garment of the kind called"},{"kind":"arabic","text_bw":"qTyfp","text_ar":"قطيفة"},{"kind":"text","text":"]: and in another trad.,"},{"kind":"arabic","text_bw":"A^asomaAlu mul~y~atayoni","text_ar":"اَسْمَالُ مُلّيَّتَيْنِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"two old and wornout small garments of the kind called"},{"kind":"arabic","text_bw":"mulaA='ap","text_ar":"مُلَا=ءَة"},{"kind":"text","text":"];"},{"kind":"arabic","text_bw":"mulay~apN","text_ar":"مُلَيَّةٌ"},{"kind":"text","text":"being a dim. of"},{"kind":"arabic","text_bw":"mulaA='apN","text_ar":"مُلَا=ءَةٌ"},{"kind":"text","text":". (TA.) And ↓"},{"kind":"arabic","text_bw":"sawomalN","text_ar":"سَوْمَلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies [in like manner]"},{"kind":"italic_en","text":"An old and worn-out"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"kisaA='","text_ar":"كِسَا=ء"},{"kind":"text","text":", on the authority of Ez-Zejjájee. (M.) ―         -b2-  Also, (i. e."},{"kind":"arabic","text_bw":"samalN","text_ar":"سَمَلٌ"},{"kind":"text","text":",) applied to a ewe,"},{"kind":"italic_en","text":"Having ragged wool:"},{"kind":"text","text":"―         -b3-  and"},{"kind":"arabic","text_bw":"samalo samalo","text_ar":"سَمَلْ سَمَلْ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"A cry by which a ewe is called to be milked."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["M","K","S"]},{"entry_id":"n20773","headword_ar":"سَمِلٌ","root":"sml","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]},"classical_definitions":null}