:false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n22581"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D8%BA%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22581","headword_ar":"اَشْغَلُ","root":"$gl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, busy"},{"kind":"text","text":"&c.]."},{"kind":"arabic","text_bw":"A^a$ogalu mino","text_ar":"اَشْغَلُ مِنْ"},{"kind":"arabic","text_bw":"*aAti Aln~iHoyayoni","text_ar":"ذَاتِ النِّحْيَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More busy than she who was the owner of the two skins of butter"},{"kind":"text","text":"] is a prov. [mentioned in the TA]: she was a woman of [the tribe of] Teym-Allah: she used to sell clarified butter, in the Time of Ignorance; and Khowwát Ibn-Jubeyr El-Ansáree came to her, demanding to buy clarified butter of her, and saw no one with her, and he bargained with her: so she untied a skin, and he looked at it: then he said to her, “ Hold thou it until I look at another: ” and she said, “ Untie thou another skin: ” and he did so, and looked at it, and said, “ I desire other than this; therefore hold thou it: ” and she did so: and when her hands were [thus] occupied, he assaulted her, and she was unable to repel the him. (Meyd.)"},{"kind":"page_break","n":1568}],"source_refs":[]}]},"classical_definitions":null}