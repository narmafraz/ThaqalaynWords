{"lemma":"قافِلَة","slug":"قافِلَة","root":"ق.ف.ل","root_slug":"ق-ف-ل","root_link":"/words/roots/ق-ف-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n42773"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D9%81%D9%90%D9%84%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"caravan"},{"pos":"noun","gloss":"column, convoy"}]},"etymology":null,"ipa":["/qaː.fi.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42773","headword_ar":"قَافِلَةٌ","root":"qfl","body":[{"kind":"italic_en","text":"A company, or an assemblage of persons, travelling together:"},{"kind":"text","text":"(El-Fárábee, Msb:) or"},{"kind":"italic_en","text":"a company returning from a journey:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"commencing a journey;"},{"kind":"text","text":"as auguring their return: (El-Fárábee, Msb, K:) he who restricts it to those returning from a journey errs: (ElFárábee, Msb, in which see more:)"},{"kind":"italic_en","text":"a caravan."}],"source_refs":["S","K"]}]}}