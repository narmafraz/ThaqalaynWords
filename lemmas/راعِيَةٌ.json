{"lemma":"راعِيَةٌ","slug":"راعِيَةٌ","root":"ر.ع.#","root_slug":"ر-ع-_","root_link":"/words/roots/ر-ع-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"راعِي","root":"رعي","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n15958"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%B9%D9%90%D9%8A%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take into account or consideration, to allow or account for"},{"pos":"verb","gloss":"to abide by, to adhere or stick or conform to, to comply with, to remain faithful to, to live up to"},{"pos":"verb","gloss":"to gaze or stare at"},{"pos":"verb","gloss":"to will to please, to indulge, to defer to, to consult"},{"pos":"verb","gloss":"to consider or regard, to lend ear or hearken or listen or pay attention to"},{"pos":"verb","gloss":"to sponsor"}]},"etymology":null,"ipa":["/raː.ʕaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15958","headword_ar":"رَاعِيَةٌ","root":"rEY","body":[{"kind":"text","text":"[fem. of"},{"kind":"arabic","text_bw":"raAEK","text_ar":"رَاعٍ"},{"kind":"text","text":". ―         -b2-  Also a subst. formed from the latter word by the affix"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"raEiy~apN","text_ar":"رَعِيَّةٌ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"raEiY~N","text_ar":"رَعِىٌّ"},{"kind":"text","text":"]: see"},{"kind":"arabic","text_bw":"rAEK","text_ar":"راعٍ"},{"kind":"text","text":", third sentence. ―         -b3-"},{"kind":"arabic","text_bw":"Alr~aAEiyapu","text_ar":"الرَّاعِيَةُ"},{"kind":"text","text":"is the name of"},{"kind":"italic_en","text":"A certain bird:"},{"kind":"text","text":"(TA:) [and] so is"},{"kind":"arabic","text_bw":"raAEiyapu Alxayoli","text_ar":"رَاعِيَةُ الخَيْلِ"},{"kind":"text","text":"; (TA, and thus in some copies of the K;) thus correctly written, as in the Tekmileh; in [some of] the copies of the K,"},{"kind":"arabic","text_bw":"rAEyp Aljbl","text_ar":"راعية الجبل"},{"kind":"text","text":"; [perhaps the same as the former bird;]"},{"kind":"italic_en","text":"a yellow bird, that is found beneath the bellies of horses or similar beasts;"},{"kind":"text","text":"thus in the Tekmileh; said by ISh to be"},{"kind":"italic_en","text":"a small bird like the sparrow, that alights beneath the bellies of the horses and other beasts, yellow, as though its neck and wings were tinged with saffron, its back having upon it a dinginess,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"duskiness, and blackness, its head being yellow, and its"},{"kind":"arabic","text_bw":"zimik~aY","text_ar":"زِمِكَّى"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tail"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"being neither long nor short;"},{"kind":"text","text":"accord. to Sgh, also called"},{"kind":"arabic","text_bw":"Alxyl","text_ar":"الخيل"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rEA'p","text_ar":"رعاءة","orth_type":"arrow"},{"kind":"text","text":". (TA [thus written without any syll. signs: if applying to the species in the manner of a coll. gen. n., perhaps a mistranscription for"},{"kind":"arabic","text_bw":"ruEaApu Alxayoli","text_ar":"رُعَاةُ الخَيْلِ"},{"kind":"text","text":"].) ―         -b4-"},{"kind":"arabic","text_bw":"raAEiyapu Al$~ayobi","text_ar":"رَاعِيَةُ الشَّيْبِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rawaAEiY Al$~ayobi","text_ar":"رَوَاعِى الشَّيْبِ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The commencement of hoariness,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"the first marks thereof."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","K"]}]},"classical_definitions":null}