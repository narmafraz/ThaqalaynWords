{"lemma":"نَطِيحٌ","slug":"نَطِيحٌ","root":"ن.ط.ح","root_slug":"ن-ط-ح","root_link":"/words/roots/ن-ط-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n40013"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B7%D9%90%D9%8A%D8%AD%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40013","headword_ar":"نَطِيحٌ","root":"nTH","body":[{"kind":"italic_en","text":"Smitten with the horn and so killed:"},{"kind":"text","text":"fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (L, K:) pl."},{"kind":"arabic","text_bw":"naToHaY","text_ar":"نَطْحَى"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"naTaAy^iHu","text_ar":"نَطَايِحُ"},{"kind":"text","text":": (Lh, L:) you say also"},{"kind":"arabic","text_bw":"naEojapN naTiyHN","text_ar":"نَعْجَةٌ نَطِيحٌ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"nTyHp","text_ar":"نطيحة"},{"kind":"text","text":". (L.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"naTiyHapN","text_ar":"نَطِيحَةٌ"},{"kind":"italic_en","text":"A sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat"},{"kind":"text","text":"(Az)"},{"kind":"italic_en","text":"smitten with the horn and so killed."},{"kind":"text","text":"(Az, S,) and of which the flesh is therefore unlawful to be eaten: (Az:) the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is added because it is made a subst., not an epithet: (Az:) or because the quality of a subst. predominates in it, as in the case of"},{"kind":"arabic","text_bw":"fariysapN","text_ar":"فَرِيسَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^akiylapN","text_ar":"اَكِيلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ramiy~apN","text_ar":"رَمِيَّةٌ"},{"kind":"text","text":". (S.) ―         -b3-"},{"kind":"arabic","text_bw":"naTiyHN","text_ar":"نَطِيحٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"naATiHN","text_ar":"نَاطِحٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"What comes to thee from before thee,"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"faces thee,"},{"kind":"text","text":"L,)"},{"kind":"italic_en","text":"of birds and wild animals"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"&c., which one rouses by throwing a stone"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by crying out, and from the course of which one augurs evil"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"qaEiydN","text_ar":"قَعِيدٌ"},{"kind":"text","text":". (S.) [The"},{"kind":"arabic","text_bw":"nTyH","text_ar":"نطيح"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"nATH","text_ar":"ناطح","orth_type":"arrow"},{"kind":"text","text":"is of evil omen.] ―         -b4-  Hence, (TA,)"},{"kind":"arabic","text_bw":"naTiyHN","text_ar":"نَطِيحٌ"},{"kind":"text","text":"(tropical:)  An"},{"kind":"italic_en","text":"unfortunate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlucky,"},{"kind":"text","text":"man. (K.) ―         -b5-"},{"kind":"arabic","text_bw":"naTiyHN","text_ar":"نَطِيحٌ"},{"kind":"text","text":"A horse"},{"kind":"italic_en","text":"having a blaze,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"white mark on his face, extending to one of his ears,"},{"kind":"text","text":"which is deemed unlucky: (L:) or a horse"},{"kind":"italic_en","text":"having on his forehead two circular"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spiral curls of hair"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"daAy^irataAni","text_ar":"دَايِرَتَانِ"},{"kind":"text","text":"), which are disliked: (S, L, K:) if there be but one, it is called"},{"kind":"arabic","text_bw":"daAy^irapu","text_ar":"دَايِرَةُ"},{"kind":"arabic","text_bw":"All~aTaApi","text_ar":"اللَّطَاةِ"},{"kind":"text","text":"; and this is not disliked; (S;) or it is called"},{"kind":"arabic","text_bw":"laTomapN","text_ar":"لَطْمَةٌ"},{"kind":"text","text":"; and the horse,"},{"kind":"arabic","text_bw":"laTiymN","text_ar":"لَطِيمٌ"},{"kind":"text","text":". (L.)"}],"source_refs":["L","K","Lh","Az","S","TA"]}]},"classical_definitions":null}