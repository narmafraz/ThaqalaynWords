ions":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"flowers, blooms, blossoms","tags":["collective"],"examples":[{"text":"فِي فَصْلِ ٱلرَّبِيعِ تَتَفَتَّحُ ٱلزُّهُورُ.","english":"In spring, flowers bloom."}]},{"pos":"noun","gloss":"die, dice","tags":["collective"]},{"pos":"noun","gloss":"cast iron","tags":["collective"]},{"pos":"verb","gloss":"to shine, to be radiant, to give light"}]},"etymology":null,"ipa":["/zahr/","/za.ha.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18302","headword_ar":"زَهَرَ","root":"zhr","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"zuhuwrN","text_ar":"زُهُورٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a star, TA, and the moon, and a lamp, and the face, K)"},{"kind":"italic_en","text":"shone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Azdhr","text_ar":"ازدهر","orth_type":"arrow"},{"kind":"text","text":": (K:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(fire, S, A, K, and the sun, A)"},{"kind":"italic_en","text":"gave light; shone;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly:"},{"kind":"text","text":"(S, A, K:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was clear in colour, and gave light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly:"},{"kind":"text","text":"(Msb:) and you say also, of the moon and of the sun,"},{"kind":"arabic","text_bw":"zahara","text_ar":"زَهَرَ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"zaharato","text_ar":"زَهَرَتْ"},{"kind":"text","text":"], aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zahorN","text_ar":"زَهْرٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"zahura","text_ar":"زَهُرَ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"zahurato","text_ar":"زَهُرَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"zahara Alz~anodu","text_ar":"زَهَرَ الزَّنْدُ"},{"kind":"italic_en","text":"The piece of stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wood, for producing fire emitted shining fire; made its fire to shine."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"zaharato bika naAriY","text_ar":"زَهَرَتْ بِكَ نَارِى"},{"kind":"text","text":"(S, A) [lit.]"},{"kind":"italic_en","text":"My fire hath become strong and abundant by means of thee:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"zaharato bika zinaAdiY","text_ar":"زَهَرَتْ بِكَ زِنَادِى"},{"kind":"text","text":"(T, K) [lit.]"},{"kind":"italic_en","text":"my pieces of stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wood, for producing fire have become powerful and abundant"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in fire"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by means of thee:"},{"kind":"text","text":"(K:) meaning, (tropical:)"},{"kind":"italic_en","text":"my want hath been accomplished by means of thee:"},{"kind":"text","text":"(T, TA:) like"},{"kind":"arabic","text_bw":"wariyato bika zinaAdiY","text_ar":"وَرِيَتْ بِكَ زِنَادِى"},{"kind":"text","text":". (S.) ―         -b4-"},{"kind":"arabic","text_bw":"zahara","text_ar":"زَهَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"zahira","text_ar":"زَهِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaharN","text_ar":"زَهَرٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"zahura","text_ar":"زَهُرَ"},{"kind":"text","text":"; (K;) (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, white;"},{"kind":"text","text":"(Msb, K;)"},{"kind":"italic_en","text":"and beautiful:"},{"kind":"text","text":"(K: [so in the CK and in my MS. copy of the K; but omitted in the TA:]) or"},{"kind":"italic_en","text":"of a bright white colour:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"of any shining colour:"},{"kind":"text","text":"(AHn, R:) and"},{"kind":"arabic","text_bw":"zahara","text_ar":"زَهَرَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, beautiful:"},{"kind":"text","text":"(AHn, TA:) and"},{"kind":"arabic","text_bw":"zahira","text_ar":"زَهِرَ"},{"kind":"text","text":"aor."},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, white,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fair, in face."},{"kind":"text","text":"(Msb.) ―         -b5-  See also 4, in two places.       -A2-"},{"kind":"arabic","text_bw":"zaharati Al$~amosu AlA_ibila","text_ar":"زَهَرَتِ الشَّمْسُ الاـِبِلَ"},{"kind":"italic_en","text":"The sun altered the camels."},{"kind":"text","text":"(K.)"}],"source_refs":["Msb","K","S","A","T","TA","AHn","R"]}]},"classical_definitions":null}