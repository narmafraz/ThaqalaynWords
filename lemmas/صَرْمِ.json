kind":"arabic","text_bw":"SuramN","text_ar":"صُرَمٌ"},{"kind":"text","text":". (MA. [This pl. is app. there mentioned as of"},{"kind":"arabic","text_bw":"SariymapN","text_ar":"صَرِيمَةٌ"},{"kind":"text","text":"; but it is more probably of"},{"kind":"arabic","text_bw":"SuromN","text_ar":"صُرْمٌ"},{"kind":"text","text":".])       -A2-"},{"kind":"arabic","text_bw":"Suromu Ald~iyki","text_ar":"صُرْمُ الدِّيكِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daliykN","text_ar":"دَلِيكٌ"},{"kind":"text","text":"."}],"source_refs":["M","K","Msb","TA"]},{"entry_id":"n24255","headword_ar":"صِرْمٌ","root":"Srm","body":[{"kind":"italic_en","text":"Tents"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aboyaAtN","text_ar":"اَبْيَاتٌ"},{"kind":"text","text":"), (S, M,)"},{"kind":"italic_en","text":"of men,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"collected together,"},{"kind":"text","text":"(S, M,)"},{"kind":"italic_en","text":"separate from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"those of other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"men:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SirobN","text_ar":"صِرْبٌ"},{"kind":"text","text":", (O in art."},{"kind":"arabic","text_bw":"Srb","text_ar":"صرب"},{"kind":"text","text":",) which means"},{"kind":"italic_en","text":"a few tents"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"buyuwt","text_ar":"بُيُوت"},{"kind":"text","text":"[in the O, erroneously,"},{"kind":"arabic","text_bw":"butuwt","text_ar":"بُتُوت"},{"kind":"text","text":"])"},{"kind":"italic_en","text":"of the weak sort of the Arabs of the desert:"},{"kind":"text","text":"(IAar, O, * K, TA; all in art."},{"kind":"arabic","text_bw":"Srb","text_ar":"صرب"},{"kind":"text","text":":) and hence, (M,)"},{"kind":"italic_en","text":"a company"},{"kind":"text","text":"(M, Msb, K, TA)"},{"kind":"italic_en","text":"of men,"},{"kind":"text","text":"(Msb, TA,)"},{"kind":"italic_en","text":"not many;"},{"kind":"text","text":"or simply"},{"kind":"italic_en","text":"a company"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"alighting and abiding with their camels by the side of the water:"},{"kind":"text","text":"(Msb, TA:) pl."},{"kind":"arabic","text_bw":"A^aSoraAmN","text_ar":"اَصْرَامٌ"},{"kind":"text","text":"[a pl. of pauc.] (S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^aSaArimu","text_ar":"اَصَارِمُ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"A^aSaAriymu","text_ar":"اَصَارِيمُ"},{"kind":"text","text":", (M,) or both, (K,) but accord. to IB the latter of these two is the right, [being a pl. pl., i. e. pl. of"},{"kind":"arabic","text_bw":"A^aSoraAmN","text_ar":"اَصْرَامٌ"},{"kind":"text","text":",] (TA,) and"},{"kind":"arabic","text_bw":"SuromaAnN","text_ar":"صُرْمَانٌ"},{"kind":"text","text":", (Sb, M, K,) with damm. (K.) ―         -b2-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"DarobN","text_ar":"ضَرْبٌ"},{"kind":"text","text":". (K. [So, app., in all the copies; accord. to the TK as meaning"},{"kind":"italic_en","text":"A sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species:"},{"kind":"text","text":"but I think it most probable that this is a mistranscription for"},{"kind":"arabic","text_bw":"SirobN","text_ar":"صِرْبٌ"},{"kind":"text","text":", with which, as has been stated above,"},{"kind":"arabic","text_bw":"SiromN","text_ar":"صِرْمٌ"},{"kind":"text","text":"is syn. accord. to the O.])       -A2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xuf~N munoEalN","text_ar":"خُفٌّ مُنْعَلٌ"},{"kind":"text","text":"(M) or"},{"kind":"arabic","text_bw":"xuf~N munaE~alN","text_ar":"خُفٌّ مُنَعَّلٌ"},{"kind":"text","text":"(K) [i. e."},{"kind":"italic_en","text":"A soled boot:"},{"kind":"text","text":"that"},{"kind":"arabic","text_bw":"xuf~","text_ar":"خُفّ"},{"kind":"text","text":"here means a boot, not a camel's foot, is indicated by its being immediately added by SM that] ↓"},{"kind":"arabic","text_bw":"Sar~aAmN","text_ar":"صَرَّامٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A seller thereof."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","Msb","K","TA","Sb"]}]},"classical_definitions":null}