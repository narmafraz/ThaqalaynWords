s":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n24398"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D8%A7%D8%BA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to form, shape, mould, fashion, create","examples":[{"text":"صاغَ الذَّهَب والفِضّة","english":"he worked in gold and silver/practiced the art of gold/silversmithing."}]},{"pos":"verb","gloss":"to formulate"},{"pos":"verb","gloss":"to coin (a word)"},{"pos":"verb","gloss":"to fabricate, invent, make up (a lie)"}]},"etymology":null,"ipa":["/sˤaː.ɣa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24398","headword_ar":"صَاغٍ","root":"Sgw and SgY","body":[{"kind":"text","text":"["},{"kind":"text","text":"part. n. of"},{"kind":"arabic","text_bw":"SagaA","text_ar":"صَغَا"},{"kind":"text","text":": fem."},{"kind":"arabic","text_bw":"SaAgiyapN","text_ar":"صَاغِيَةٌ"},{"kind":"text","text":": and pl."},{"kind":"arabic","text_bw":"SawaAgK","text_ar":"صَوَاغٍ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"SaAgiyatuka","text_ar":"صَاغِيَتُكَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Those who incline to thee,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and come to thee,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"in their cases of need:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"whoever, of thy family, come to thee as guests:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"those who incline to thee, of thy companions and relations:"},{"kind":"text","text":"(Har p. 207:) ISd thinks it to be made fem. because meaning a"},{"kind":"arabic","text_bw":"jamaAEap","text_ar":"جَمَاعَة"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"A^akorimuwA","text_ar":"اَكْرِمُوا"},{"kind":"arabic","text_bw":"fulaAnFA fiY SaAgiyatihi","text_ar":"فُلَانًا فِى صَاغِيَتِهِ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"Honour ye such a one in respect of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"those who incline to him, and who"},{"kind":"page_break","n":1693},{"kind":"italic_en","text":"come to him seeking to obtain what he has."},{"kind":"text","text":"(S.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlS~awaAgiY","text_ar":"الصَّوَاغِى"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The stars that have inclined to setting."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B5%D8%A7%D8%BA/","headword_ar":"صاغانُ","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=143354#1d2350","body_html":"صاغانُ:<br>بالغين المعجمة، وآخره نون: قرية بمرو وقد تسمى جاغان كوه، عن السمعاني، والصغانيان:<br>بلاد بما وراء النهر، وقد تشبه النسبة فيهما وتذكر في موضعها."}]}}