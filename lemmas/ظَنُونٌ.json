{"lemma": "ظَنُونٌ", "slug": "ظَنُونٌ", "root": "ظ.ن.ن", "root_slug": "ظ-ن-ن", "root_link": "/words/roots/ظ-ن-ن", "pos": "ADJ", "pos_camel": "adj", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": false}, "lanes": {"found": true, "entry_ids": ["n27699"], "search_url": "https://lanelexicon.com/?s=%D8%B8%D9%8E%D9%86%D9%8F%D9%88%D9%86%D9%8C"}}, "translations": {"en": "doubtful, suspected", "fa": "گمان‌برده، مشکوک", "ur": "گمان، مشکوک", "tr": "şüpheli, emin olmayan", "id": "ragu, dicurigai", "bn": "সন্দেহজনক, সন্দেহ", "es": "dudoso, sospechoso", "fr": "douteux, suspect", "de": "zweifelhaft, verdächtig", "ru": "сомнительный, подозрительный", "zh": "可疑的，不确定的"}, "definition": null, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n27699", "headword_ar": "ظَنُونٌ", "root": "Zn", "body": [{"kind": "text", "text": "A man"}, {"kind": "italic_en", "text": "who thinks evil"}, {"kind": "text", "text": "(S, M)"}, {"kind": "italic_en", "text": "of everyone."}, {"kind": "text", "text": "(M.) ―         -b2-  A man"}, {"kind": "italic_en", "text": "possessing little good"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "goodness:"}, {"kind": "text", "text": "or, as some say,"}, {"kind": "italic_en", "text": "of whom one asks"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "a thing"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "thinking that he will refuse, and who is as he was thought to be:"}, {"kind": "text", "text": "(M:) [or] ↓"}, {"kind": "arabic", "text_bw": "ZaniynN", "text_ar": "ظَنِينٌ", "orth_type": "arrow"}, {"kind": "text", "text": "has this latter meaning. (TA.) ―         -b3-  A man"}, {"kind": "italic_en", "text": "in whose goodness no trust,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "confidence, is to be placed."}, {"kind": "text", "text": "(M.) And Anything"}, {"kind": "italic_en", "text": "in which no trust,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "confidence, is to be placed,"}, {"kind": "text", "text": "(M, TA,) of water, and of other things; (TA;) as also ↓"}, {"kind": "arabic", "text_bw": "ZaniynN", "text_ar": "ظَنِينٌ", "orth_type": "arrow"}, {"kind": "text", "text": ". (M, TA.) A well ("}, {"kind": "arabic", "text_bw": "biy^orN", "text_ar": "بِيْرٌ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "having little water,"}, {"kind": "text", "text": "(S, M, K,)"}, {"kind": "italic_en", "text": "in the water of which no trust,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "confidence, is to be placed:"}, {"kind": "text", "text": "(M:) or a well, (S, K,) or a drinkingplace, (M,)"}, {"kind": "italic_en", "text": "of which one knows not whether there be in it water or not:"}, {"kind": "text", "text": "(S, M, K:) or water"}, {"kind": "italic_en", "text": "which one imagines,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "supposes, to exist, but of which one is not sure."}, {"kind": "text", "text": "(TA.)"}, {"kind": "arabic", "text_bw": "kul~u maniy~apK ZanuwnN", "text_ar": "كُلُّ مَنِيَّةٍ ظَنُونٌ"}, {"kind": "arabic", "text_bw": "A_il~aA Alqatola fiY sabiyli A@ll~`hi", "text_ar": "اـِلَّا القَتْلَ فِى سَبِيلِ ا@للّٰهِ"}, {"kind": "text", "text": "is a saying mentioned, but not expl., by IAar; [app. meaning"}, {"kind": "italic_en", "text": "Every death is doubtful as to its consequence except slaughter in the way,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "cause, of God;"}, {"kind": "text", "text": "but ISd says,] in my opinion the meaning is that it"}, {"kind": "italic_en", "text": "is of little good and profit."}, {"kind": "text", "text": "(M.)"}, {"kind": "arabic", "text_bw": "dayonN ZanuwnN", "text_ar": "دَيْنٌ ظَنُونٌ"}, {"kind": "text", "text": "means"}, {"kind": "italic_en", "text": "A debt of which one knows not whether he who owes it will pay it or not:"}, {"kind": "text", "text": "(A'Obeyd, T, S, M, * K:) it is said in a trad. of 'Omar that there is no poorrate in the case of such a debt. (TA.) ―         -b4-  Also A man"}, {"kind": "italic_en", "text": "suspected in relation to his intellect,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "intelligence."}, {"kind": "text", "text": "(Aboo-Tálib, TA.) And A woman"}, {"kind": "italic_en", "text": "suspected in relation to her grounds of pretension to respect,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "honour, on account of lineage &c."}, {"kind": "text", "text": "(TA.) And A woman"}, {"kind": "italic_en", "text": "of noble rank"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "quality, who is taken in marriage,"}, {"kind": "text", "text": "(M, K,)"}, {"kind": "italic_en", "text": "from a desire of obtaining off spring by her, when she is advanced in age."}, {"kind": "text", "text": "(M.) ―         -b5-  Also A"}, {"kind": "italic_en", "text": "weak"}, {"kind": "text", "text": "man. (K. [See also"}, {"kind": "arabic", "text_bw": "ZanynN", "text_ar": "ظَنينٌ"}, {"kind": "text", "text": ".]) ―         -b6-  And A man"}, {"kind": "italic_en", "text": "having little artifice, cunning, ingenuity,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "skill."}, {"kind": "text", "text": "(K.)"}], "source_refs": ["S", "M", "TA", "K"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}