{"lemma":"بُرْمَة","slug":"بُرْمَة","root":"ب.ر.م","root_slug":"ب-ر-م","root_link":"/words/roots/ب-ر-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n2383","n2388","n2389"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D8%B1%D9%92%D9%85%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"earthenware or copperware pot"}]},"etymology":null,"ipa":["/bur.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2383","headword_ar":"بَرَمَهُ","root":"brm","body":[{"kind":"text","text":": see 4, in two places.       -A2-"},{"kind":"arabic","text_bw":"barima","text_ar":"بَرِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tbr~m","text_ar":"تبرّم","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with disgust, loathing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aversion;"},{"kind":"text","text":"(M, * K;)"},{"kind":"italic_en","text":"he was vexed, grieved, disquieted by grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressed in mind."},{"kind":"text","text":"(M.) You say,"},{"kind":"arabic","text_bw":"barima bihi","text_ar":"بَرِمَ بِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baramN","text_ar":"بَرَمٌ"},{"kind":"text","text":"; (T, S, M, Msb, K;) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tbr~m","text_ar":"تبرّم","orth_type":"arrow"},{"kind":"text","text":"; (T, S, Msb, K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disgusted by it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it; he loathed it;"},{"kind":"text","text":"(T, *, M, * Msb, * K;)"},{"kind":"italic_en","text":"he was vexed, grieved, disquieted by grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressed in mind, by it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of it."},{"kind":"text","text":"(T, M, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"barima biHuj~atihi","text_ar":"بَرِمَ بِحُجَّتِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"He was unable to adduce, as he had intended, his argument, allegation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence,"},{"kind":"text","text":"] is said when one has intended to adduce an argument, allegation, or evidence, and it did not present itself to him. (A, K, TA.)"}],"source_refs":[]},{"entry_id":"n2388","headword_ar":"بُرْمَةٌ","root":"brm","body":[{"kind":"italic_en","text":"A cooking-pot"},{"kind":"text","text":"(T, M, &c.)"},{"kind":"italic_en","text":"of stone,"},{"kind":"text","text":"(T, Mgh, Msb,) or"},{"kind":"italic_en","text":"of stones:"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"muborimN","text_ar":"مُبْرِمٌ"},{"kind":"text","text":":] (M, K:) or [simply]"},{"kind":"italic_en","text":"a cooking-pot,"},{"kind":"text","text":"(S, TA,) as some say,"},{"kind":"italic_en","text":"in a general sense,"},{"kind":"text","text":"so that it may be"},{"kind":"italic_en","text":"of copper,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of iron, &c.:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"biraAmN","text_ar":"بِرَامٌ"},{"kind":"text","text":"(T, S, M, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"buramN","text_ar":"بُرَمٌ"},{"kind":"text","text":"(T, M, &c.) and [coll. gen. n.]"},{"kind":"arabic","text_bw":"buromN","text_ar":"بُرْمٌ"},{"kind":"text","text":". (T, M, K.)       -A2-  Also"},{"kind":"italic_en","text":"A certain thing which women wear upon their arms, like the bracelet."},{"kind":"text","text":"(TA.)"}],"source_refs":["T","Mgh","Msb","M","K","S","TA"]},{"entry_id":"n2389","headword_ar":"بَرَمَةٌ","root":"brm","body":[{"kind":"text","text":"[originally n. un. of"},{"kind":"arabic","text_bw":"baramN","text_ar":"بَرَمٌ"},{"kind":"text","text":"]: see"},{"kind":"arabic","text_bw":"baramN","text_ar":"بَرَمٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}