nes_definition":{"source":"lanes","entries":[{"entry_id":"n38930","headword_ar":"مَلِصَ","root":"mlS","body":[{"kind":"text","text":", (S, M, A, K,) aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"malaSN","text_ar":"مَلَصٌ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, or a rope, Lh, M, A, and a bridle, Lh, M,)"},{"kind":"italic_en","text":"slipped;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"fell, slipping;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"got loose"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaped, and slipped"},{"kind":"text","text":"["},{"kind":"italic_en","text":"away"},{"kind":"text","text":"]; (A;) or"},{"kind":"italic_en","text":"slipped out by reason of its smoothness;"},{"kind":"text","text":"(M;) from one's hand; (S, M, A;) as also ↓"},{"kind":"arabic","text_bw":"A_im~alaSa","text_ar":"اـِمَّلَصَ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tml~S","text_ar":"تملّص","orth_type":"arrow"},{"kind":"text","text":": (M:) or ↓"},{"kind":"arabic","text_bw":"AnmlS","text_ar":"انملص","orth_type":"arrow"},{"kind":"text","text":", (S, K,) also written"},{"kind":"arabic","text_bw":"A_im~alaSa","text_ar":"اـِمَّلَصَ"},{"kind":"text","text":", (S,) signifies"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, Lth, S,)"},{"kind":"italic_en","text":"escaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got loose"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free,"},{"kind":"text","text":"(Lth, S,) from one's hand, after having been seized or grasped: (Lth:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"tml~S","text_ar":"تملّص","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a thing, S, or a rope, TA, and a man, S, A,)"},{"kind":"italic_en","text":"became safe"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaped,"},{"kind":"text","text":"(S, A, K,) from one's hand. (TA.) You say,"},{"kind":"arabic","text_bw":"maliSati Als~amakapu","text_ar":"مَلِصَتِ السَّمَكَةُ"},{"kind":"arabic","text_bw":"mino yadiY","text_ar":"مِنْ يَدِى"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AnmlSt","text_ar":"انملصت","orth_type":"arrow"},{"kind":"italic_en","text":"The fish escaped and slipped from my hand."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"maA kidotu","text_ar":"مَا كِدْتُ"},{"kind":"arabic","text_bw":"mino fulaAnK","text_ar":"مِنْ فُلَانٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^atamal~aSu","text_ar":"اَتَمَلَّصُ","orth_type":"arrow"},{"kind":"italic_en","text":"I hardly escaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became secure, from such a one."},{"kind":"text","text":"(S, A. *) ―         -b2-"},{"kind":"italic_en","text":"He went back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retreated, fleeing;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"maliza","text_ar":"مَلِزَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"malazN","text_ar":"مَلَزٌ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"malaSahu","text_ar":"مَلَصَهُ"},{"kind":"italic_en","text":"He set it loose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"malaSa bisaloHihi","text_ar":"مَلَصَ بِسَلْحِهِ"},{"kind":"italic_en","text":"Alvum dejecit:"},{"kind":"text","text":"(K:) so says Ibn-'Abbád: but in the Tekmileh,"},{"kind":"arabic","text_bw":"malaSa","text_ar":"مَلَصَ"},{"kind":"arabic","text_bw":"bisahomihi","text_ar":"بِسَهْمِهِ"},{"kind":"italic_en","text":"he shot his arrow."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","A","K","Lth"]}]},"classical_definitions":null}