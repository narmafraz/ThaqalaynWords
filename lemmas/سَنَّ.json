:"present_3fd","form":"تَسُنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْنُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْنُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسَنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسَنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسُنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسُنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْنُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْنُنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْنُنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُسَنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَنّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسُنّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسُنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَنَنّا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":108,"cross_references":{"qac":{"found":true,"lemma_key":"سَنَّ","root":"سنن","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n20845"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sharpen, to whet, to hone, to grind"},{"pos":"verb","gloss":"to mold, to shape, to form"},{"pos":"verb","gloss":"to prescribe, to introduce, to enact"},{"pos":"verb","gloss":"to institute, to establish a method"},{"pos":"noun","gloss":"verbal noun of سَنَّ (sanna) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"prescription, introduction, enactment"},{"pos":"noun","gloss":"tooth, tusk, fang","examples":[{"text":"أُنَظِّفُ أَسْنَانِي","english":"I am brushing my teeth"}]},{"pos":"noun","gloss":"point or tip"},{"pos":"noun","gloss":"a spearhead or arrowhead"},{"pos":"noun","gloss":"age (years of life)"},{"pos":"noun","gloss":"cog, sprocket, prong"}]},"etymology":{"source":"wiktextract","text":"Etymologically related to سن (sinn, “tooth”, sense 3); also compare the letter ش (š).\n\nVerbal noun of سَنَّ (sanna).\n\nEtymology tree\nProto-Afroasiatic\nProto-Semitic *šinn-\nArabic سن\nInherited from Proto-Semitic *šinn-."},"ipa":["/san.na/","/sann/","/sinn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20845","headword_ar":"سِنٌّ","root":"sn","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"DirosN","text_ar":"ضِرْسٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"A tooth;"},{"kind":"text","text":"in which sense this latter word is often used; though it is frequently restricted to a molar tooth, or to any of the teeth except the central incisors]: (M, L, K:) [or, accord. to some,"},{"kind":"italic_en","text":"a single tooth;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"one that is not of the double,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"molar, kind;"},{"kind":"text","text":"as shown by a description in what follows:] of the fem. gender: (S, M, L, Msb:) pl."},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":"(S, M, L, Msb, K) and"},{"kind":"arabic","text_bw":"A^asin~apN","text_ar":"اَسِنَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^asun~N","text_ar":"اَسُنٌّ"},{"kind":"text","text":", (M, L, K,) the last of these mentioned by Lh, and this and the second anomalous; (M, L;) or the second is allowable as pl. of the first of these pls.; (S;) or it is pl. of the"},{"kind":"arabic","text_bw":"sinaAn","text_ar":"سِنَان"},{"kind":"text","text":"of the spear; but may also be pl. of"},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":"as pl. of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"applied to herbage upon which camels pasture, in an instance to be cited in what follows: (A'Obeyd, T, L:) the vulgar say"},{"kind":"arabic","text_bw":"A_isonaAn","text_ar":"اـِسْنَان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^usonaAn","text_ar":"اُسْنَان"},{"kind":"text","text":", which are wrong: (Msb:) the"},{"kind":"arabic","text_bw":"A^asonaAn","text_ar":"اَسْنَان"},{"kind":"text","text":"of a human being consist of four"},{"kind":"arabic","text_bw":"vanaAyaA","text_ar":"ثَنَايَا"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"rabaAEiyaAt","text_ar":"رَبَاعِيَات"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"A^anoyaAb","text_ar":"اَنْيَاب"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"nawaAji*","text_ar":"نَوَاجِذ"},{"kind":"text","text":", and sixteen"},{"kind":"arabic","text_bw":"A^aDoraAs","text_ar":"اَضْرَاس"},{"kind":"text","text":": or, as some say, four"},{"kind":"arabic","text_bw":"vnAyA","text_ar":"ثنايا"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"rbAEyAt","text_ar":"رباعيات"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"AnyAb","text_ar":"انياب"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"nwAj*","text_ar":"نواجذ"},{"kind":"text","text":", and four"},{"kind":"arabic","text_bw":"DawaAHik","text_ar":"ضَوَاحِك"},{"kind":"text","text":", and twelve"},{"kind":"arabic","text_bw":"A^aroHaA='","text_ar":"اَرْحَا=ء"},{"kind":"text","text":": (Msb:) or the"},{"kind":"arabic","text_bw":"A^asonaAn","text_ar":"اَسْنَان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aDoraAs","text_ar":"اَضْرَاس"},{"kind":"text","text":"together make up the number of thirty-two; the"},{"kind":"arabic","text_bw":"vnAbA","text_ar":"ثنابا"},{"kind":"text","text":"are four, two above and two below [in the middle]; next are the"},{"kind":"arabic","text_bw":"rbAEyAt","text_ar":"رباعيات"},{"kind":"text","text":", which are four, two above and two below; next are the"},{"kind":"arabic","text_bw":"AnyAb","text_ar":"انياب"},{"kind":"text","text":", which are four [likewise, two above and two below]; and next are the"},{"kind":"arabic","text_bw":"ADrAs","text_ar":"اضراس"},{"kind":"text","text":", which are twenty, on each side five above and five below; and of these [last] the four that are next to the"},{"kind":"arabic","text_bw":"AnyAb","text_ar":"انياب"},{"kind":"text","text":"are the"},{"kind":"arabic","text_bw":"DwAHk","text_ar":"ضواحك"},{"kind":"text","text":"; next to each"},{"kind":"arabic","text_bw":"nAb","text_ar":"ناب"},{"kind":"text","text":", above and below, is a"},{"kind":"arabic","text_bw":"DaAHik","text_ar":"ضَاحِك"},{"kind":"text","text":"; next to the"},{"kind":"arabic","text_bw":"DwAHk","text_ar":"ضواحك"},{"kind":"text","text":"are the"},{"kind":"arabic","text_bw":"TawaAHin","text_ar":"طَوَاحِن"},{"kind":"text","text":", also called the"},{"kind":"arabic","text_bw":"A^aroHaA='","text_ar":"اَرْحَا=ء"},{"kind":"text","text":", which are twelve, on each side [above and below] three; and next to these are the"},{"kind":"arabic","text_bw":"nwAj*","text_ar":"نواجذ"},{"kind":"text","text":", which are the last of the teeth in growth, and the last of the"},{"kind":"arabic","text_bw":"ADrAs","text_ar":"اضراس"},{"kind":"text","text":", on each side of the mouth one above and one below: (Zj in his “ Khalk el-Insán: ”) the dim. of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"sunayonapN","text_ar":"سُنَيْنَةٌ","orth_type":"arrow"},{"kind":"text","text":", because it is fem. (S.) One says,"},{"kind":"arabic","text_bw":"laA A=tiyka sin~a AlHisoli","text_ar":"لَا ا=تِيكَ سِنَّ الحِسْلِ"},{"kind":"text","text":", (S, M, L,) i. e."},{"kind":"italic_en","text":"I will not come to thee as long as remains the tooth of the young one of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of lizard called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Dab~","text_ar":"ضَبّ"},{"kind":"text","text":"; (M, L;) meaning,"},{"kind":"italic_en","text":"ever;"},{"kind":"text","text":"(S, M, * L;) because the"},{"kind":"arabic","text_bw":"Hsl","text_ar":"حسل"},{"kind":"text","text":"never sheds a tooth: (S, L:) or, as Lh relates it, on the authority of ElMufaddal,"},{"kind":"arabic","text_bw":"sin~aYo HisolK","text_ar":"سِنَّىْ حِسْلٍ"},{"kind":"text","text":"; [using the dual form of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":";] and [it may be rendered, accord. to the former reading, (assumed tropical:)"},{"kind":"italic_en","text":"during the life of the young one of the"},{"kind":"arabic","text_bw":"D~b","text_ar":"ضّب"},{"kind":"text","text":", for] he says, they assert that the"},{"kind":"arabic","text_bw":"Db~","text_ar":"ضبّ"},{"kind":"text","text":"lives three hundred years, and that it is the longest-lived creeping thing upon the earth. (M, L.) A poet (Aboo-Jarwal El-Jushamee, whose name was Hind, L) says, describing camels taken as a bloodwit,"},{"kind":"quote","text":"fajaA='ato kasin~i AlZ~aboYi lamo A^ara mivolahaA\n                      \n                     \n                        bawaA='a qatiylK A^awo Haluwbapa jaAy^iEi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And they came;"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"like the age of the gazelle"},{"kind":"text","text":"was the age of every one of them:"},{"kind":"italic_en","text":"I have not seen the like of them for an equivalent of a slain person, or a milch camel of one hungry:"},{"kind":"text","text":"(I have given a reading of this verse that I have found in the M and TA in art."},{"kind":"arabic","text_bw":"ZbY","text_ar":"ظبى"},{"kind":"text","text":", instead of that in the present art. in the S and L, in which"},{"kind":"arabic","text_bw":"snA='a","text_ar":"سنا=ءَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sanaA='a","text_ar":"سَنَا=ءَ"},{"kind":"text","text":"are put in the place of"},{"kind":"arabic","text_bw":"bawaA='a","text_ar":"بَوَا=ءَ"},{"kind":"text","text":"app. for"},{"kind":"arabic","text_bw":"sinaA='a","text_ar":"سِنَا=ءَ"},{"kind":"text","text":", an inf. n. of"},{"kind":"arabic","text_bw":"saAnaAhu","text_ar":"سَانَاهُ"},{"kind":"text","text":", and as such here meaning"},{"kind":"italic_en","text":"a soothing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":")] he means that they were"},{"kind":"arabic","text_bw":"vunoyaAn","text_ar":"ثُنْيَان"},{"kind":"text","text":", [pl. of"},{"kind":"arabic","text_bw":"vaniY~N","text_ar":"ثَنِىٌّ"},{"kind":"text","text":"], because the"},{"kind":"arabic","text_bw":"vaniY~","text_ar":"ثَنِىّ"},{"kind":"text","text":"is one shedding [or that has shed] his"},{"kind":"arabic","text_bw":"vaniy~ap","text_ar":"ثَنِيَّة"},{"kind":"text","text":", and the gazelle has no"},{"kind":"arabic","text_bw":"vaniy~ap","text_ar":"ثَنِيَّة"},{"kind":"text","text":"[in the upper jaw], so that he is always [one that may be termed] a"},{"kind":"arabic","text_bw":"vaniY~","text_ar":"ثَنِىّ"},{"kind":"text","text":". (S, L.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A_i*aA saAfarotumo fiY AlxiSobi faA^aEoTuwA Alr~ukuba","text_ar":"اـِذَا سَافَرْتُمْ فِى الخِصْبِ فَاَعْطُوا الرُّكُبَ"},{"kind":"arabic","text_bw":"A^asin~atahaA","text_ar":"اَسِنَّتَهَا"},{"kind":"text","text":", [expl. as] meaning"},{"kind":"italic_en","text":"When ye journey in the land abounding with herbage, enable ye the ridden beasts to take of the pasturage:"},{"kind":"text","text":"(S, L:) but Az states that A'Obeyd says, I know not"},{"kind":"arabic","text_bw":"A^asin~ap","text_ar":"اَسِنَّة"},{"kind":"text","text":"except as pl. of the"},{"kind":"arabic","text_bw":"sinaAn","text_ar":"سِنَان"},{"kind":"text","text":"of the spear; and if the trad. be [correctly] preserved in memory, it seems to be pl. of"},{"kind":"arabic","text_bw":"A^asonaAn","text_ar":"اَسْنَان"},{"kind":"text","text":"; for"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"[sometimes] signifies the ["},{"kind":"italic_en","text":"portion of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"herbage upon which camels pasture;"},{"kind":"text","text":"and its pl. is"},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":"; one says,"},{"kind":"arabic","text_bw":"A^asonaAnN mina AlmaroEaY","text_ar":"اَسْنَانٌ مِنَ المَرْعَى"},{"kind":"text","text":"; and the pl. of"},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^asin~apN","text_ar":"اَسِنَّةٌ"},{"kind":"text","text":": Aboo-Sa'eed says that this last is pl. of"},{"kind":"arabic","text_bw":"sinaAnN","text_ar":"سِنَانٌ"},{"kind":"text","text":", not of"},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sinaAnN","text_ar":"سِنَانٌ","orth_type":"arrow"},{"kind":"text","text":"is applied to the [plants, or trees, called]"},{"kind":"arabic","text_bw":"HamoD","text_ar":"حَمْض"},{"kind":"text","text":", as meaning (assumed tropical:)"},{"kind":"italic_en","text":"a strengthener"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a sharpener of the appetite"},{"kind":"text","text":"] of the camels for the [plants, or trees, called]"},{"kind":"arabic","text_bw":"xul~ap","text_ar":"خُلَّة"},{"kind":"text","text":": [see a phrase in the earlier part of the first paragraph:] in like manner, also, [he says,] when they light upon what is termed"},{"kind":"arabic","text_bw":"sin~N mina AlmaroEaY","text_ar":"سِنٌّ مِنَ المَرْعَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a portion of pasturage"},{"kind":"text","text":"], this is termed"},{"kind":"arabic","text_bw":"EalaY Als~ayori","text_ar":"عَلَى السَّيْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sinaAnN","text_ar":"سِنَانٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a strengthener,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpener, for journeying"},{"kind":"text","text":"]: this explanation is approved by Az, and likewise that of A'Obeyd: it is also related, on the authority of Fr, that"},{"kind":"arabic","text_bw":"Als~in~u","text_ar":"السِّنُّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the eating vehemently:"},{"kind":"text","text":"[a signification mentioned in the K as well as in the L:] and Az says, I have heard more than one of the Arabs say,"},{"kind":"arabic","text_bw":"A^aSaAbati AlA_ibilu Alyawoma sin~FA mina AlmaroEaY","text_ar":"اَصَابَتِ الاـِبِلُ اليَوْمَ سِنًّا مِنَ المَرْعَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The camels have obtained to-day a good portion of pasturage"},{"kind":"text","text":"] when they have eaten well of the best of the pasturage: Z says that ↓"},{"kind":"arabic","text_bw":"A^aEoTuwA Alr~ukuba A^asin~atahaA","text_ar":"اَعْطُوا الرُّكُبَ اَسِنَّتَهَا","orth_type":"arrow"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Give ye to the ridden beasts what will prevent their being slaughtered;"},{"kind":"text","text":"for when their owner pastures them well, they become fat, and goodly in his eye, and therefore he withholds himself, with niggardliness, from slaughtering them, and this [condition of them] is likened to"},{"kind":"arabic","text_bw":"A^asin~ap","text_ar":"اَسِنَّة"},{"kind":"text","text":"[as meaning “ spear-heads ”] pl. of"},{"kind":"arabic","text_bw":"sinaAnN","text_ar":"سِنَانٌ"},{"kind":"text","text":": [see also"},{"kind":"arabic","text_bw":"A^axa*ato rimaAHahaA","text_ar":"اَخَذَتْ رِمَاحَهَا"},{"kind":"text","text":", said of camels, voce"},{"kind":"arabic","text_bw":"rumoHN","text_ar":"رُمْحٌ"},{"kind":"text","text":":] or if the pl. of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"be intended by it, the meaning is,"},{"kind":"italic_en","text":"enable ye them"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the ridden beasts"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to take of the pasturage;"},{"kind":"text","text":"and hence the trad.,"},{"kind":"arabic","text_bw":"A^aEoTuwA Als~in~a","text_ar":"اَعْطُوا السِّنَّ"},{"kind":"arabic","text_bw":"HaZ~ahaA mina Als~in~i","text_ar":"حَظَّهَا مِنَ السِّنِّ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Give ye the possessors of the"},{"kind":"arabic","text_bw":"sin~","text_ar":"سِنّ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"tooth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"their share of the"},{"kind":"arabic","text_bw":"sin~","text_ar":"سِنّ"},{"kind":"text","text":"which is the"},{"kind":"italic_en","text":"pasture."},{"kind":"text","text":"(L.)"},{"kind":"arabic","text_bw":"Als~in~u","text_ar":"السِّنُّ"},{"kind":"text","text":"is also used for"},{"kind":"arabic","text_bw":"*awaAtu","text_ar":"ذَوَاتُ"},{"kind":"arabic","text_bw":"Als~in~i","text_ar":"السِّنِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The possessors of the tooth"},{"kind":"text","text":"] as meaning"},{"kind":"italic_en","text":"the slave and horses and the like and other animals,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"collectively,"},{"kind":"text","text":"in like manner as"},{"kind":"arabic","text_bw":"xuf~N","text_ar":"خُفٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaAfirN","text_ar":"حَافِرٌ"},{"kind":"text","text":"are used,] in a trad. of 'Omar. (L.) And it is said in a trad. of Ibn-Dhee-Yezen,"},{"kind":"arabic","text_bw":"laA^uwTiy^an~a A^asonaAna AlEarabi","text_ar":"لَاُوطِيَنَّ اَسْنَانَ العَرَبِ"},{"kind":"arabic","text_bw":"kaEobahu","text_ar":"كَعْبَهُ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"*awiY A^asonaAni AlEarabi","text_ar":"ذَوِى اَسْنَانِ العَرَبِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I will assuredly make"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the great men and the nobles"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the Arabs to tread upon his ankle"},{"kind":"text","text":"]. (L.) [But"},{"kind":"arabic","text_bw":"AsnAn","text_ar":"اسنان"},{"kind":"text","text":"in this instance may be pl. of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"in the sense here next following; so that"},{"kind":"arabic","text_bw":"*wY AsnAn","text_ar":"ذوى اسنان"},{"kind":"page_break","n":1438},{"kind":"text","text":"may be rendered"},{"kind":"italic_en","text":"the advanced in age."},{"kind":"text","text":"]) ―         -b2-  Hence, (L,) (tropical:)"},{"kind":"italic_en","text":"Life;"},{"kind":"text","text":"(S, M, L, Msb;) metaphorically used in this sense as indicative of its length and its shortness; (L;) [for the teeth vary with the length of life;] the"},{"kind":"italic_en","text":"measure,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"extent, of life;"},{"kind":"text","text":"(Msb, K;) [the"},{"kind":"italic_en","text":"age attained;"},{"kind":"text","text":"] used in relation to human beings and others: (M, L, K:) of the fem. gender in this sense also, (M, L, Msb,) because meaning"},{"kind":"arabic","text_bw":"mud~apN","text_ar":"مُدَّةٌ"},{"kind":"text","text":": (Msb:) pl."},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":", (M, L, K,) only. (M, L.) You say"},{"kind":"arabic","text_bw":"rajulN Hadiyvu","text_ar":"رَجُلٌ حَدِيثُ"},{"kind":"arabic","text_bw":"Als~in~i","text_ar":"السِّنِّ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"A young man."},{"kind":"text","text":"(S, Msb, K, all in art."},{"kind":"arabic","text_bw":"Hdv","text_ar":"حدث"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"jaAwazotu A^asonaAna A^aholi bayotiY","text_ar":"جَاوَزْتُ اَسْنَانَ اَهْلِ بَيْتِى"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I have exceeded"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the lives of the people of my house."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"SadaqaniY sin~a bakorihi","text_ar":"صَدَقَنِى سِنَّ بَكْرِهِ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"sin~u bakorihi","text_ar":"سِنُّ بَكْرِهِ"},{"kind":"text","text":", expl. in art."},{"kind":"arabic","text_bw":"bkr","text_ar":"بكر"},{"kind":"text","text":"]. (L.) ―         -b3-  And (assumed tropical:)"},{"kind":"italic_en","text":"A like, an equal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a match, in age,"},{"kind":"text","text":"of another; (M, L, K;) like"},{"kind":"arabic","text_bw":"tin~N","text_ar":"تِنٌّ"},{"kind":"text","text":"; (M, L;) as also ↓"},{"kind":"arabic","text_bw":"saniynN","text_ar":"سَنِينٌ","orth_type":"arrow"},{"kind":"text","text":", (M, L, K,) and ↓"},{"kind":"arabic","text_bw":"siniynN","text_ar":"سِنِينٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) or ↓"},{"kind":"arabic","text_bw":"sanynapN","text_ar":"سَنينَةٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) in this sense also fem.; and [therefore] the dim. is ↓"},{"kind":"arabic","text_bw":"sunayonapN","text_ar":"سُنَيْنَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (L;) one says,"},{"kind":"arabic","text_bw":"AiboniY sunayonapu A@bonika","text_ar":"اِبْنِى سُنَيْنَةُ ا@بْنِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"My son is the equal in age of thy son"},{"kind":"text","text":"]: (El-Kanánee, L:) and the pl. is"},{"kind":"arabic","text_bw":"A^asun~N","text_ar":"اَسُنٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":". (L.) ―         -b4-  Also (assumed tropical:)"},{"kind":"italic_en","text":"A tooth"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"minojal","text_ar":"مِنْجَل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"reaping-hook"},{"kind":"text","text":"]: (M, L, K: *) pl."},{"kind":"arabic","text_bw":"A^asonaAnN","text_ar":"اَسْنَانٌ"},{"kind":"text","text":", signifying its"},{"kind":"arabic","text_bw":"A^u$ur","text_ar":"اُشُر"},{"kind":"text","text":". (L and K in art."},{"kind":"arabic","text_bw":"A$r","text_ar":"اشر"},{"kind":"text","text":".) ―         -b5-  [And (assumed tropical:)"},{"kind":"italic_en","text":"A tooth"},{"kind":"text","text":"of a comb.] The Arabs say"},{"kind":"arabic","text_bw":"kaA^asonaAni Almu$oTi","text_ar":"كَاَسْنَانِ المُشْطِ"},{"kind":"text","text":"meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"Like the teeth of the comb"},{"kind":"text","text":"] in equality, in respect of any state, or condition: but if they mean equality in respect of evil, they say"},{"kind":"quote","text":"sawaAsiyapN kaA^asonaAni AlHimaAri"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Equals like the teeth of the ass"},{"kind":"text","text":"];"},{"kind":"arabic","text_bw":"swAsyp","text_ar":"سواسية"},{"kind":"text","text":"being an anomalous pl. of"},{"kind":"arabic","text_bw":"sawaA='N","text_ar":"سَوَا=ءٌ"},{"kind":"text","text":". (Har p. 39.) ―         -b6-  And (assumed tropical:)  The"},{"kind":"italic_en","text":"nib,"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"place of paring,"},{"kind":"text","text":"of a writingreed: (S, L, K:) [and"},{"kind":"italic_en","text":"each lateral half of that part;"},{"kind":"text","text":"for] the writing-reed has a right"},{"kind":"arabic","text_bw":"sin~","text_ar":"سِنّ"},{"kind":"text","text":"and a left"},{"kind":"arabic","text_bw":"sin~","text_ar":"سِنّ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"Hrf","text_ar":"حرف"},{"kind":"text","text":":) [and ↓"},{"kind":"arabic","text_bw":"sin~apN","text_ar":"سِنَّةٌ","orth_type":"arrow"},{"kind":"text","text":"occurs in the K voce"},{"kind":"arabic","text_bw":"jilofapN","text_ar":"جِلْفَةٌ"},{"kind":"text","text":"as meaning the"},{"kind":"italic_en","text":"point"},{"kind":"text","text":"of a writing-reed.] One says,"},{"kind":"arabic","text_bw":"A^aTilo sin~a qalamika wasam~inohaA","text_ar":"اَطِلْ سِنَّ قَلَمِكَ وَسَمِّنْهَا"},{"kind":"arabic","text_bw":"waHar~ifo qiT~ataka waA^ayominohaA","text_ar":"وَحَرِّفْ قِطَّتَكَ وَاَيْمِنْهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Make long the nib,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pared portion, of thy writing-reed, and make it thick"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"fat"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and make thy mode of cutting the extremity of the nib oblique, and make it to incline towards the right"},{"kind":"text","text":"]. (S, L. *) ―         -b7-"},{"kind":"italic_en","text":"A tooth"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pin"},{"kind":"text","text":"] of a key [app. of the kind of wooden lock called"},{"kind":"arabic","text_bw":"Dab~ap","text_ar":"ضَبَّة"},{"kind":"text","text":", q. v.]. (MA.) ―         -b8-  See also"},{"kind":"arabic","text_bw":"sinosinN","text_ar":"سِنْسِنٌ"},{"kind":"text","text":". ―         -b9-  Also, (M, K, and A and K in art."},{"kind":"arabic","text_bw":"fS","text_ar":"فص"},{"kind":"text","text":",) or ↓"},{"kind":"arabic","text_bw":"sin~apN","text_ar":"سِنَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, JM,)"},{"kind":"italic_en","text":"A clove,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"faS~N","text_ar":"فَصٌّ"},{"kind":"text","text":", S and A as syn. with"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"fS","text_ar":"فص"},{"kind":"text","text":", and JM in explanation of"},{"kind":"arabic","text_bw":"sin~apN","text_ar":"سِنَّةٌ"},{"kind":"text","text":"in the present art., or"},{"kind":"arabic","text_bw":"faS~apN","text_ar":"فَصَّةٌ"},{"kind":"text","text":", S and L in explanation of"},{"kind":"arabic","text_bw":"sin~apN","text_ar":"سِنَّةٌ"},{"kind":"text","text":",) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"Hab~ap","text_ar":"حَبَّة"},{"kind":"text","text":"[app. here meaning"},{"kind":"italic_en","text":"small distinct portion"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the head"},{"kind":"text","text":"[app. here meaning bulb], (M and L and K in explanation of"},{"kind":"arabic","text_bw":"sin~N","text_ar":"سِنٌّ"},{"kind":"text","text":",) of garlic. (S, M, A, L, K, JM.)       -A2-  [Accord. to some,] one says,"},{"kind":"arabic","text_bw":"waqaEa fulaAnN fiY sin~i raA^osihi","text_ar":"وَقَعَ فُلَانٌ فِى سِنِّ رَاْسِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Such a one fell into"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what equalled"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the number of his hairs, of good,"},{"kind":"text","text":"(M, * L, K, *) and"},{"kind":"italic_en","text":"of evil:"},{"kind":"text","text":"(L:) or, as some say,"},{"kind":"italic_en","text":"into what he willed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wished, and had authority to decide:"},{"kind":"text","text":"(L, K:) but this is a mistranscription: (Meyd:) the correct saying is"},{"kind":"arabic","text_bw":"fiY siY~i raA^osihi","text_ar":"فِى سِىِّ رَاْسِهِ"},{"kind":"text","text":", (Az, Meyd, L,) and"},{"kind":"arabic","text_bw":"sawaA='i raA^osihi","text_ar":"سَوَا=ءِ رَاْسِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he fell into a state of enjoyment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"welfare;"},{"kind":"text","text":"(Meyd;) the former sometimes expl. as meaning, ["},{"kind":"italic_en","text":"he lighted upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came upon, what equalled"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the number of the hairs of his head, of wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good:"},{"kind":"text","text":"(A'Obeyd, Meyd:) or"},{"kind":"italic_en","text":"what equalled"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the hairs of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his head, of abundance of herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the goods, conveniences,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comforts, of life:"},{"kind":"text","text":"(Az, L, and Meyd * on the authority of IAar:) the saying is a prov. (Meyd.)       -A3-"},{"kind":"arabic","text_bw":"Als~in~u","text_ar":"السِّنُّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"The wild bull."},{"kind":"text","text":"(L, K.)"}],"source_refs":["M","L","K","S","Msb","JM","Meyd","Az"]}]}}