{"lemma":"أَرْمَدِ","slug":"أَرْمَدِ","root":"ر.م.د","root_slug":"ر-م-د","root_link":"/words/roots/ر-م-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n16609","n16623"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D9%92%D9%85%D9%8E%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cremate, incinerate"}]},"etymology":null,"ipa":["/ram.ma.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16609","headword_ar":"ارمد","root":"rmd","body":[{"kind":"text","text":", as an intrans. v.: see 1, first sentence, in two places. ―         -b2-  Also, (S, K,) inf. n."},{"kind":"arabic","text_bw":"A_iromaAdN","text_ar":"اـِرْمَادٌ"},{"kind":"text","text":", said of a man, (S,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, poor, needy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indigent."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"Armd Alqawomu","text_ar":"ارمد القَوْمُ"},{"kind":"italic_en","text":"The people were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, afflicted with drought, barrenness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dearth,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"and their cattle perished"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in consequence thereof."},{"kind":"text","text":"(TA.)       -A2-  See also 1, last two sentences.       -A3-  And see 2.       -A4-  As a trans. v.: see 1, in the middle of the paragraph.       -A5-"},{"kind":"arabic","text_bw":"Armd Eayonahu","text_ar":"ارمد عَيْنَهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(God, S, M, L, K,) and"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(weeping, A, TA,)"},{"kind":"italic_en","text":"caused his eye to become painful and swollen, inflamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected with ophthalmia."},{"kind":"text","text":"(S, M, L, K, TA.)"}],"source_refs":["S","K","A","TA","God","M","L"]},{"entry_id":"n16623","headword_ar":"اَرْمَدُ","root":"rmd","body":[{"kind":"italic_en","text":"Of the colour of"},{"kind":"arabic","text_bw":"ramaAd","text_ar":"رَمَاد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ashes"},{"kind":"text","text":"]; (S, M, K;) ["},{"kind":"italic_en","text":"ash-coloured; ashy;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a dusty colour in which is a duskiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dinginess:"},{"kind":"text","text":"(S:) [fem."},{"kind":"arabic","text_bw":"ramodaA='u","text_ar":"رَمْدَا=ءُ"},{"kind":"text","text":": and pl."},{"kind":"arabic","text_bw":"rumodN","text_ar":"رُمْدٌ"},{"kind":"text","text":".] Hence"},{"kind":"arabic","text_bw":"ramodaA='u","text_ar":"رَمْدَا=ءُ"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"A female ostrich:"},{"kind":"text","text":"(S, K:) [and"},{"kind":"arabic","text_bw":"rumodN","text_ar":"رُمْدٌ"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"ostriches:"},{"kind":"text","text":"(see 9, last sentence:)] and hence also"},{"kind":"arabic","text_bw":"rumodN","text_ar":"رُمْدٌ"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"gnats"},{"kind":"text","text":"(T, S, A, L, K)"},{"kind":"italic_en","text":"of a certain species:"},{"kind":"text","text":"(T:) and you say"},{"kind":"arabic","text_bw":"naEaAmapN ramodaA='u","text_ar":"نَعَامَةٌ رَمْدَا=ءُ"},{"kind":"text","text":"(M, A) i. e. ["},{"kind":"italic_en","text":"an ostrich"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a female ostrich,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of an obscure black hue, like the colour of ashes:"},{"kind":"text","text":"(M:) and"},{"kind":"arabic","text_bw":"ZaliymN A^aromadu","text_ar":"ظَلِيمٌ اَرْمَدُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a male ostrich of such a colour"},{"kind":"text","text":"]: (M:) and"},{"kind":"arabic","text_bw":"naEaAmN rumodN","text_ar":"نَعَامٌ رُمْدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ostriches of such a colour"},{"kind":"text","text":"]: (A:) and"},{"kind":"arabic","text_bw":"viyaAbN rumodN","text_ar":"ثِيَابٌ رُمْدٌ"},{"kind":"italic_en","text":"garments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieces of cloth, of a dusty colour in which is a duskiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dinginess;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"ramaAdN","text_ar":"رَمَادٌ"},{"kind":"text","text":". (T.) Lh asserts that the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"in this word is a substitute for"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":". (M, L. [See"},{"kind":"arabic","text_bw":"A^arobadu","text_ar":"اَرْبَدُ"},{"kind":"text","text":".]) ―         -b2-  See also"},{"kind":"arabic","text_bw":"ramidN","text_ar":"رَمِدٌ"},{"kind":"text","text":", in six places. ―         -b3-  And see"},{"kind":"arabic","text_bw":"rimodidN","text_ar":"رِمْدِدٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","T","A","L","M"]}]},"classical_definitions":null}