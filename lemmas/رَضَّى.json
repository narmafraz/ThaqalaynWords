":"present_3fd","form":"تُرَضَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَضِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَضِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَضُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَضُّونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَضَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُرَضِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُرَضّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَضِّي","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرَضِّي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَضَّى","in_corpus":true,"count":20,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرَضَّى","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَضَّيْنا","in_corpus":true,"count":10,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَضَّيْتُ","in_corpus":true,"count":36,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":984,"cross_references":{"qac":{"found":true,"lemma_key":"رَضَّى","root":"رضو","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["name","noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15771","n15776","n15777","n15782"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B6%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"name","gloss":"Ruḍaw, a pre-Islamic Arabian god later misinterpreted as the name of a place of worship."},{"pos":"noun","gloss":"alternative form of رِضًا (riḍan)","tags":["alt-of","alternative"]}]},"etymology":{"source":"wiktextract","text":"From the root ر ض و (r ḍ w), meaning \"the contented one\". Attested as both Safaitic 𐪇𐪓𐪅 (rḍw) and 𐪇𐪓𐪚 (rḍy), and Dumaitic 𐪇𐪓𐪅 (rḍw)."},"ipa":["/ru.dˤaː/","/ri.dˤan/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15771","headword_ar":"رَضِىَ","root":"rDw","body":[{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"raDiwa","text_ar":"رَضِوَ"},{"kind":"text","text":"; the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"because of the kesreh: (S:) the tribe of Teiyi said"},{"kind":"arabic","text_bw":"raDaA","text_ar":"رَضَا"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"raDiYa","text_ar":"رَضِىَ"},{"kind":"text","text":". (IDrd in his lex., cited by Freytag; and Mughnee voce"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"there said to be a dial. var. of"},{"kind":"arabic","text_bw":"raDiYa","text_ar":"رَضِىَ"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"raDiYa Eanohu","text_ar":"رَضِىَ عَنْهُ"},{"kind":"text","text":", (S, M, Msb, K,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (M, Msb, K,) which is of the dial. of the people of El-Hijáz, (Msb,) the verb being thus made trans. by means of"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"text","text":", accord. to Ks, agreeably with the opinion of Sb respecting instances of this kind, for the purpose of making it to accord with its contr.,"},{"kind":"arabic","text_bw":"saxiTa","text_ar":"سَخِطَ"},{"kind":"text","text":", (M, TA,) aor."},{"kind":"arabic","text_bw":"yaroDaY","text_ar":"يَرْضَى"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"arabic","text_bw":"ruDFY","text_ar":"رُضًى"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"riDowaAnN","text_ar":"رِضْوَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruDowaAnN","text_ar":"رُضْوَانٌ"},{"kind":"text","text":", (S, * M, Msb, * K,) the last of the dial. of Keys and Temeem, (Msb, TA,) and mentioned by Sb, (M, TA,) but all the readers of the Kur read"},{"kind":"arabic","text_bw":"rDwAn","text_ar":"رضوان"},{"kind":"text","text":"with kesr, except 'Ásim, who is related to have read it with damm, (T, TA,) and"},{"kind":"arabic","text_bw":"maroDaApN","text_ar":"مَرْضَاةٌ"},{"kind":"text","text":", (S, * M, K,) originally"},{"kind":"arabic","text_bw":"maroDawapN","text_ar":"مَرْضَوَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was pleased, well pleased, content, contented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied, with him; regarded him with good will,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved, him;"},{"kind":"text","text":"(MA;) [i. e., as said above,]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"saxiTa","text_ar":"سَخِطَ"},{"kind":"text","text":"; (M, Msb, K;) the object being a person: (Msb:) and Sb states that they also said"},{"kind":"arabic","text_bw":"raDoyuwA","text_ar":"رَضْيُوا"},{"kind":"text","text":", with the medial radical quiescent, for"},{"kind":"arabic","text_bw":"raDuwA","text_ar":"رَضُوا"},{"kind":"text","text":"; but it is extr. (M, TA.) The saying in the Kur [v. last verse but one, and ix. 101, &c.]"},{"kind":"arabic","text_bw":"raDiYa A@ll~`hu Eanohumo waraDuwA Eanohu","text_ar":"رَضِىَ ا@للّٰهُ عَنْهُمْ وَرَضُوا عَنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God is well pleased with them and they are well pleased with Him"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"God is well pleased with their deeds and they are well pleased with the recompense that He has bestowed upon them:"},{"kind":"text","text":"(M, TA:) or, accord. to Er-Rághib,"},{"kind":"arabic","text_bw":"riDaY AlEabodi","text_ar":"رِضَى العَبْدِ"},{"kind":"arabic","text_bw":"Eani A@ll~`hi","text_ar":"عَنِ ا@للّٰهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The servant's,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"man's, being not displeased with that which God's decree has made to happen to him;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riDaY A@ll~`hi Eini AlEabodi","text_ar":"رِضَى ا@للّٰهِ عِنِ العَبْدِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"God's seeing the servant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"man, to be obedient to that which He has commanded, and refraining from that which He has forbidden."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"raDiytuhu","text_ar":"رَضِيتُهُ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"raDiytu bihi","text_ar":"رَضِيتُ بِهِ"},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"(Msb, TA) [and"},{"kind":"arabic","text_bw":"ruDFY","text_ar":"رُضًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riDowaAnN","text_ar":"رِضْوَانٌ"},{"kind":"text","text":"&c., as above]; and ↓"},{"kind":"arabic","text_bw":"AirotaDayotuhu","text_ar":"اِرْتَضَيْتُهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"I was pleased, well pleased, content, contented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied, with it; regarded it with good will,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved, it:"},{"kind":"text","text":"(MA: [for the verb is there said to have the same signification in the phrases"},{"kind":"arabic","text_bw":"raDiyahu","text_ar":"رَضِيَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raDiYa bihi","text_ar":"رَضِىَ بِهِ"},{"kind":"text","text":"as it has in"},{"kind":"arabic","text_bw":"raDiYa","text_ar":"رَضِىَ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"ArtDAh","text_ar":"ارتضاه"},{"kind":"text","text":"is there similarly explained: and the like is implied in the S and K; and is evidently agreeable with general usage:]) or"},{"kind":"italic_en","text":"he chose it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preferred it:"},{"kind":"text","text":"(Msb, TA:) the object being a thing: (S, Msb, TA:) or (accord. to explanations of"},{"kind":"arabic","text_bw":"taroDaAhaA","text_ar":"تَرْضَاهَا"},{"kind":"text","text":"in the Kur ii. 139)"},{"kind":"italic_en","text":"I loved it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liked it;"},{"kind":"text","text":"(Ksh, Bd, Jel;)"},{"kind":"italic_en","text":"inclined to it;"},{"kind":"text","text":"(Ksh;)"},{"kind":"italic_en","text":"had a desire for it."},{"kind":"text","text":"(Bd.) The saying of the lawyers, [respecting a woman whose consent to her marriage has been asked,]"},{"kind":"arabic","text_bw":"ya$ohadu EalaY riDaAhaA","text_ar":"يَشْهَدُ عَلَى رِضَاهَا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[i. e. her silence]"},{"kind":"italic_en","text":"testifies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declares, her permission"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"consent"},{"kind":"text","text":"]; because permission indicates"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":". (Msb.) You say also,"},{"kind":"arabic","text_bw":"raDiytu bihi SaAHibFA","text_ar":"رَضِيتُ بِهِ صَاحِبًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was pleased with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I liked him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chose him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preferred him, as a companion"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"raDiyahu li*`lika AlA^amori","text_ar":"رَضِيَهُ لِذٰلِكَ الاَمْرِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"ArtDAhu","text_ar":"ارتضاهُ","orth_type":"arrow"},{"kind":"text","text":", [which may be well rendered"},{"kind":"italic_en","text":"He approved him for that thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair,"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"he saw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judged him, to be fit for that thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"liSuHobatihi waxidomatihi","text_ar":"لِصُحْبَتِهِ وَخِدْمَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ArtDAhu","text_ar":"ارتضاهُ","orth_type":"arrow"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"["},{"kind":"italic_en","text":"approved him,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"chose him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preferred him;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"saw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judged him, to be fit; for his companionship, and his service."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"ruDiyato maEy$atuhu","text_ar":"رُضِيَتْ مَعيشَتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His living,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sustenance, was found pleasing, well pleasing, contenting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfying;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was liked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved"},{"kind":"text","text":"]: one should not say"},{"kind":"arabic","text_bw":"raDiyatp","text_ar":"رَضِيَتة"},{"kind":"text","text":"[in this case]. (S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"raDawotuhu","text_ar":"رَضَوْتُهُ"},{"kind":"text","text":", (S, M, K,) aor."},{"kind":"arabic","text_bw":"A^aroDuwhu","text_ar":"اَرْضُوهُ"},{"kind":"text","text":", (S, K,) signifies"},{"kind":"italic_en","text":"I surpassed him in"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"[i. e. in"},{"kind":"italic_en","text":"being pleased, well pleased, content,"},{"kind":"text","text":"&c.: see above, second sentence]: (S, * M, K *:) so in the saying,"},{"kind":"arabic","text_bw":"faraDawotuhu","text_ar":"فَرَضَوْتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raADaAniY","text_ar":"رَاضَانِى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He vied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contended, with me in being pleased, well pleased, content,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and I surpassed him therein"},{"kind":"text","text":"]: (S, M, K:) the inf. n. of"},{"kind":"arabic","text_bw":"rADAnY","text_ar":"راضانى"},{"kind":"text","text":"thus used is"},{"kind":"arabic","text_bw":"muraADaApN","text_ar":"مُرَاضَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riDaA='N","text_ar":"رِضَا=ءٌ"},{"kind":"text","text":"; (M;) both these signify the same (K, TA) as inf. ns. of this verb. (TA.)"}],"source_refs":["S","M","Msb","K","TA","T"]},{"entry_id":"n15776","headword_ar":"رُضًى","root":"rDw","body":[{"kind":"italic_en","text":"A certain idol-temple, belonging to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the tribe of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Rabee'ah:"},{"kind":"text","text":"(K:) whence they gave the name of"},{"kind":"arabic","text_bw":"Eabodu ruDFY","text_ar":"عَبْدُ رُضًى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Servant of Rudà"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K"]},{"entry_id":"n15777","headword_ar":"رِضًى","root":"rDw","body":[{"kind":"text","text":"is merely an inf. n., (S,) [as such]"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"maroDaApN","text_ar":"مَرْضَاةٌ"},{"kind":"text","text":", (K,) meaning The"},{"kind":"italic_en","text":"being pleased, well pleased, content,"},{"kind":"text","text":"&c.; [see 1;]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"saxaTN","text_ar":"سَخَطٌ"},{"kind":"text","text":": (M:) and the simple subst. is ↓"},{"kind":"arabic","text_bw":"riDaA='N","text_ar":"رِضَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", with medd.; [signifying"},{"kind":"italic_en","text":"a state of being pleased,"},{"kind":"text","text":"&c.;] (Akh, S;) or the latter is only an inf. n. of 3, (M,)"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"muraADaApN","text_ar":"مُرَاضَاةٌ"},{"kind":"text","text":": (M, K:) [but] the former [is also used as a subst., signifying"},{"kind":"italic_en","text":"content,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approval:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"permission,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consent:"},{"kind":"text","text":"and] is dualized, app. as meaning the"},{"kind":"italic_en","text":"kind"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mode"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of being pleased,"},{"kind":"text","text":"&c.]: (M:) the dual is"},{"kind":"arabic","text_bw":"riDawaAnK","text_ar":"رِضَوَانٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riDayaAni","text_ar":"رِضَيَانِ"},{"kind":"text","text":": (S, M, K:) Ks heard"},{"kind":"arabic","text_bw":"riDawaAni","text_ar":"رِضَوَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HamawaAni","text_ar":"حَمَوَانِ"},{"kind":"text","text":"as duals of"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HimFY","text_ar":"حِمًى"},{"kind":"text","text":"; and says that the proper way is to say"},{"kind":"arabic","text_bw":"riDayaAni","text_ar":"رِضَيَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HimayaAni","text_ar":"حِمَيَانِ"},{"kind":"text","text":", [which in the case of the former is strange, as its final radical is"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":",] but that the pronunciation with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is the more common: (S:) and accord. to some,"},{"kind":"arabic","text_bw":"maraADK","text_ar":"مَرَاضٍ"},{"kind":"text","text":"is an irreg. pl. of"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"; but others say that it is pl. of"},{"kind":"arabic","text_bw":"maroDaApN","text_ar":"مَرْضَاةٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"maA faEalotuhu Eino riDaAhu","text_ar":"مَا فَعَلْتُهُ عِنْ رِضَاهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"riDowatihi","text_ar":"رِضْوَتِهِ"},{"kind":"text","text":": see the latter, below. (Z, K.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"raADK","text_ar":"رَاضٍ"},{"kind":"text","text":", latter sentence.       -A2-  And"},{"kind":"arabic","text_bw":"rajulN riDFY","text_ar":"رَجُلٌ رِضًى"},{"kind":"text","text":", (M, K,) and"},{"kind":"arabic","text_bw":"qawomN riDFY","text_ar":"قَوْمٌ رِضًى"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"A man,"},{"kind":"text","text":"(M, K,) and"},{"kind":"italic_en","text":"a people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"with whom one is pleased, well pleased, contented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied; regarded with good will,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour; liked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maroDiY~N","text_ar":"مَرْضِىٌّ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"qunoEaAnN","text_ar":"قُنْعَانٌ"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"being, thus used, an inf. n. in the sense of a pass. part. n., like as the inf. n. is used in the sense of an act. part. n. in the instance of"},{"kind":"arabic","text_bw":"EadolN","text_ar":"عَدْلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"xaSomN","text_ar":"خَصْمٌ"},{"kind":"text","text":". (M.) ―         -b2-  [See also"},{"kind":"arabic","text_bw":"raDiY~N","text_ar":"رَضِىٌّ"},{"kind":"text","text":"; for which"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"riDFA","text_ar":"رِضًا"},{"kind":"text","text":"seems to be erroneously substituted, in two senses, in some copies of the K.]"}],"source_refs":["S","K","M"]},{"entry_id":"n15782","headword_ar":"رَضِىٌّ","root":"rDw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raADK","text_ar":"رَاضٍ"},{"kind":"text","text":". ―         -b2-  Also, (K, TA,) i. e. like"},{"kind":"arabic","text_bw":"ganiY~N","text_ar":"غَنِىٌّ"},{"kind":"text","text":", (TA,) [in the CK"},{"kind":"arabic","text_bw":"Alr~iDaY","text_ar":"الرِّضَى"},{"kind":"text","text":", and in my MS. copy of the K"},{"kind":"arabic","text_bw":"Alr~iDaA","text_ar":"الرِّضَا"},{"kind":"text","text":", are put in the place of"},{"kind":"arabic","text_bw":"Alr~aDiY~u","text_ar":"الرَّضِىُّ"},{"kind":"text","text":",] One"},{"kind":"italic_en","text":"who is responsible, accountable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"answerable;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"DaAminN","text_ar":"ضَامِنٌ"},{"kind":"text","text":": so in the copies of the K, and in like manner in the Tekmileh: accord. to the copies of the T,"},{"kind":"arabic","text_bw":"DaAmirN","text_ar":"ضَامِرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light of flesh,"},{"kind":"text","text":"&c.]. (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"Loving; a lover;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a friend."},{"kind":"text","text":"(IAar, K, TA.) ―         -b4-  And"},{"kind":"italic_en","text":"Obeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obedient."},{"kind":"text","text":"(IAar, TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%B6%D9%89/","headword_ar":"رضى","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=19227#493e41","body_html":"رضى: رَضِي له وبه: أذن له، أجاز له (بوشر).<br>الله يرضى عليك: أرجوك، الله يخليك (بوشر)."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=19227#50d51b","body_html":"<span class=\"title1\">رضى</span><br><span>رَضِيَ يَرْضَى رِضىً ورِضَاء - بالمَدِّ أيضاً -. والرِّضا: المَرْضِيُّ، وُيقال: مَرْضُو. والمَرْضَاةُ والرِّضْوَانُ: واحِدٌ. ورَضِيَ فلانٌ كذا يَرْضَاه رِضْوَةً.</span><br><span>والرضا والرضا والرضا - يُمَد ويُقْصَر -. وقد رُضَى مَذْهَبُه: أي رُضِيَ - لغةُ طَيئ -. وقد رَضَاكَ الناسُ: بمعنى رَضِيَكَ.</span><br><span>وما كانَ مَرْضُوّاً. وراضَاني فَرَضَوْتُه أرْضُوه.</span>"},{"lexicon_id":"dictionary_11","lexicon_en":"Ibn al-Athīr al-Jazarī, al-Nihāya fī Gharīb al-Ḥadīth wa-l-Athar (d. 1210 CE) النهاية في غريب الحديث والأثر لأبي السعادات ابن الأثير الجزري","lexicon_ar":"","permalink":"https://arabiclexicon.hawramani.com/?p=19227#5973c6","body_html":"<span class=\"title1\">(رضى)</span><br><span>فِي حَدِيثِ الدُّعَاءِ «اللَّهُمَّ إِنِّي أَعُوذُ بِرِضَاكَ مِنْ سَخَطك، وبمُعافاتِك مِنْ عُقوبتِك، وَأَعُوذُ بِكَ مِنْكَ، لَا أُحْصي ثَناءً عَلَيْكَ، أَنْتَ كَمَا أَثْنَيْتَ عَلَى نَفْسِكَ» وَفِي رِوَايَةٍ بَدَأَ بِالْمُعَافَاةِ ثُمَّ بِالرِّضَا، إِنَّمَا ابْتَدَأَ بِالْمُعَافَاةِ مِنَ الْعُقُوبَةِ؛ لِأَنَّهَا مِنْ صِفَاتِ الْأَفْعَالِ كَالْإِمَاتَةِ وَالْإِحْيَاءِ.</span><br><span>والرِّضَا والسَّخَطُ مِنْ صفاتِ الذَّاتِ. وصفاتُ الْأَفْعَالِ أدنَى رُتْبة مِنْ صِفَاتِ الذَّاتِ، فبَدأ بالأدْنى مُتَرقِّيا إِلَى الْأَعْلَى. ثُمَّ لمَّا ازْداد يقِينا وارتِقاء تَرَك الصِفات وقَصر نَظره عَلَى الذَّاتِ فَقَالَ: أَعُوذُ بِكَ مِنْكَ، ثُمَّ لَمَّا ازْداد قُربا استَحْيا مَعَهُ مِنَ الاسْتعاذة عَلَى بِساط القُرب، فالتَجأ إِلَى الثَّناء فَقَالَ:</span><br><span>لَا أُحصي ثَناءً عَلَيْكَ، ثُمَّ عَلِمَ أَنَّ ذَلِكَ قُصُورٌ فَقَالَ: أَنْتَ كَمَا أثْنَيْت عَلَى نفسِك، وَأَمَّا عَلَى الرِّوَايَةِ الأُولى فَإِنَّمَا قَدّم الِاسْتِعَاذَةَ بِالرِّضَا عَلَى السَّخَط؛ لِأَنَّ الْمُعَافَاةَ مِنَ الْعُقُوبَةِ تَحْصل بِحُصُولِ الرِّضَا، وَإِنَّمَا ذَكَرها لِأَنَّ دَلالة الأُولى عَلَيْهَا دَلالة تَضمين، فَأَرَادَ أَنْ يَدُلَّ عَلَيْهَا دَلالة مُطابقة، فكَنى عَنْهَا أَوَّلًا، ثُمَّ صرَّح بِهَا ثَانِيًا، وَلِأَنَّ الرَّاضِي قَدْ يُعاقِب للمصْلحة، أَوْ لاسْتيفاء حَقِّ الْغَيْرِ.</span>"},{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=19227#0d0e12","body_html":"<span class=\"title1\">[رضى]</span><span> نه: أعوذ \"برضاك\" من سخطك، وبمعافاتك من عقوبتك، وفي رواية بدأ بالمعافاة من العقوبة ثم بالرضا لأنهما من صفات الأفعال كالإحياء والإماتة، والرضا والسخط من صفات الذات، وصفات الأفعال أدنى رتبة فترقى منها إلى الأعلى، ثم لما ازداد يقينًا قصر نره على الذات فقال: أعوذ بك منك، ثم لما ازداد قربًا استحق من الاستعاذة على بساط القرب فالتجأ إلى الثناء فقال: لا أحصى ثناء عليك، ثم علم قصوره فقال أنت كما أثنيت، وعلى الرواية الأولى قدم الرضا لأن المعافاة من العقوبة تحصل بالرضا، وإنما ذكرها ليدل عليها مطابقة فكنى عنها أولا ثم صرح بها ثانيا، ولأن الراضي قد يعاقب لمصلحة أو لاستيفاء حق الغير. ك: إذا قال: أقرك ما أقرك الله، فهما على \"تراضيهما\" أي المقر وهو صاحب الأرض والمقر له أي ساكنها على تراضيهما، فللأول ترك إسكانه وللثاني ترك سكونه. وفيه: أما \"ترضى\" أن تكون مني بمنزلة هارون من موسى، أي في استخلافه على ذريته وأهله لا في الخلافة بعد الموت كما ظن الروافض فإن هارون توفى قبل موسى. وقال عمر: \"رضينا\" بالله، حين احفوه في المسألة، مر وجه ملائمته في ح. وفيه: لا تنكح البكر والثيب إلا \"برضاها\" أي رضا المرأة، وروى: رضاهما، وهو ظاهر. وفيه: ثم \"أرضني\" به- بهمزة القطع، أي اجعلني راضيًا به، لأنه إذا قدر له الخير ولم يرض به كان منكد العيش، ومر في خير. ن: \"رضي\" بالله ربا، أي قنع به ولم يطلب معه غيره بأن يسلك غير ما شرعه. ط: من الصلاة \"رضوان\" الله، من الصلاة بيان للوقت، ورضوان خبر بحذف مضاف، أي سبب رضوانه، أو مبالغة كزيد عدل، وهو للمحسنين، والعفو يشبه أن يكون للمقصرين. شم: أرجى أية \"ولسوف يعطيك\" و\"لا يرضى\" صلى الله عليه وسلم أن يدخل أحد النار، ولا ينافي هذا ما دل عليه الدلائل من دخول بعض العصاة النار لجواز كون الإرضاء بعد دخولهم أو يكون قوله: ولا يرضى- إلخ، متروك الظاهر.</span>"}]}}