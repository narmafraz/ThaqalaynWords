n":"m","num":"p"},{"role":"present_2mp","form":"تَشْنُعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْنُعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْنُع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْنُع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْنُعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْنُعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْنُعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْنُعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْنُعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْنُعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْنُعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَنُعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَنُعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْنُع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْنُع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n23134"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%86%D9%8F%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be atrocious, to be hideous, to be ugly"},{"pos":"verb","gloss":"to make ugly"},{"pos":"verb","gloss":"to calumniate, to libel"}]},"etymology":null,"ipa":["/ʃa.nu.ʕa/","/ʃan.na.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23134","headword_ar":"شَنُعَ","root":"$nE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$anaAEapN","text_ar":"شَنَاعَةٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"$anaEN","text_ar":"شَنَعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$anaAEN","text_ar":"شَنَاعٌ"},{"kind":"text","text":", but this last, occurring in a verse, may be used by poetic license for"},{"kind":"arabic","text_bw":"$anaAEapN","text_ar":"شَنَاعَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, evil, abominable, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unseemly;"},{"kind":"text","text":"(S, * O, * Msb, K;) syn."},{"kind":"arabic","text_bw":"qabuHa","text_ar":"قَبُحَ"},{"kind":"text","text":". (Msb. [In the S and O and K, it is said that"},{"kind":"arabic","text_bw":"$anaAEapN","text_ar":"شَنَاعَةٌ"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"faZaAEapN","text_ar":"فَظَاعَةٌ"},{"kind":"text","text":"; but the latter seems to import more than the former.])       -A2-"},{"kind":"arabic","text_bw":"$anaEa fulaAnFA","text_ar":"شَنَعَ فُلَانًا"},{"kind":"italic_en","text":"He regarded such a one as bad, evil, abominable, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unseemly,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AisotaqobaHahu","text_ar":"اِسْتَقْبَحَهُ"},{"kind":"text","text":", S, O, K, TA, in the CK"},{"kind":"arabic","text_bw":"Asotaxaf~ahu","text_ar":"اسْتَخَفَّهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and reviled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vilified, him,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$atamahu","text_ar":"شَتَمَهُ"},{"kind":"text","text":", O, K, TA, and so accord. to one of my copies of the S,) or"},{"kind":"italic_en","text":"loathed him,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"say^imahu","text_ar":"سَيِمَهُ"},{"kind":"text","text":",) thus in some of the lexicons, [and accord. to one of my copies of the S,] but [SM says that]"},{"kind":"arabic","text_bw":"$atamahu","text_ar":"شَتَمَهُ"},{"kind":"text","text":"is shown to be the right reading by the saying of IAar that"},{"kind":"arabic","text_bw":"$anaEahu","text_ar":"شَنَعَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"$anoEN","text_ar":"شَنْعٌ"},{"kind":"text","text":", means"},{"kind":"arabic","text_bw":"sab~ahu","text_ar":"سَبَّهُ"},{"kind":"text","text":". (TA.) [See also 10.] ―         -b2-  Also, (O, K,) inf. n."},{"kind":"arabic","text_bw":"$anoEN","text_ar":"شَنْعٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He disgraced such a one; put him to shame;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exposed his vices, faults,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"actions."},{"kind":"text","text":"(O, K, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$anaEa Alxiroqapa","text_ar":"شَنَعَ الخِرْقَةَ"},{"kind":"italic_en","text":"He frayed the torn-off piece of cloth so that it became shaggy"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$aE~avahaA Hat~aY tanaf~a$a","text_ar":"شَعَّثَهَا حَتَّى تَنَفَّشَ"},{"kind":"text","text":"): (O, K: [in the CK, in the place of the last word of the explanation, which is for"},{"kind":"arabic","text_bw":"tatanaf~a$a","text_ar":"تَتَنَفَّشَ"},{"kind":"text","text":", is put"},{"kind":"arabic","text_bw":"tanofa$~a","text_ar":"تَنْفَشَّ"},{"kind":"text","text":":]) and in like manner one says of a thing similar to a"},{"kind":"arabic","text_bw":"xiroqap","text_ar":"خِرْقَة"},{"kind":"text","text":". (O.)       -A3-"},{"kind":"arabic","text_bw":"$aniEa bihi","text_ar":"شَنِعَ بِهِ"},{"kind":"text","text":": see 10."}],"source_refs":["S","O","Msb","K","TA"]}]}}