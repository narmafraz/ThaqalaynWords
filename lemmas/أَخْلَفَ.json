"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُخْلِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُخْلِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُخْلِف","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُخْلِف","in_corpus":true,"count":24,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُخْلِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخْلِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخْلِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخْلِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخْلِفُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخْلِفُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخْلِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخْلِف","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخْلِف","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَخْلَفْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَخْلَفْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":73,"cross_references":{"qac":{"found":true,"lemma_key":"أَخْلَفَ","root":"خلف","pos":"V","occurrence_count":14},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n11368"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%92%D9%84%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to leave (children, offspring)","tags":["transitive"]},{"pos":"verb","gloss":"to compensate [with عَلَى (ʕalā) ‘someone’] (of God)"},{"pos":"verb","gloss":"to break (a promise)","examples":[{"text":"رَبَّنَا وَآتِنَا مَا وَعَدْتَنَا عَلَىٰ رُسُلِكَ وَلَا تُخْزِنَا يَوْمَ الْقِيَامَةِ ۗ إِنَّكَ لَا تُخْلِفُ الْمِيعَادَ"}]},{"pos":"verb","gloss":"to disappoint (one's hopes)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11368","headword_ar":"اَخْلَفُ","root":"xlf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xaAlifN","text_ar":"خَالِفٌ"},{"kind":"text","text":", in the latter half of the paragraph. ―         -b2-  Also"},{"kind":"italic_en","text":"Contrarious, hard in disposition, as though going with a leaning towards one side:"},{"kind":"text","text":"(K:) and [simply]"},{"kind":"italic_en","text":"leaning towards one side;"},{"kind":"text","text":"applied to a camel: (S, K:) so says A'Obeyd; (S, TA;) and so As. (TA.) ―         -b3-  Also A camel"},{"kind":"italic_en","text":"that has the sheath of his penis slit, and that will not remain stationary, by reason of pain:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"maxoluwfN","text_ar":"مَخْلُوفٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a camel"},{"kind":"italic_en","text":"having the sheath of his penis slit in the hinder part,"},{"kind":"text","text":"(JK, TA,)"},{"kind":"italic_en","text":"when suffering suppression of his urine in consequence of the pressure of his hind girth upon his sheath:"},{"kind":"text","text":"so says El-Fezáree. (TA.) ―         -b4-  And"},{"kind":"italic_en","text":"Left-handed."},{"kind":"text","text":"(JK, K.) ―         -b5-  And"},{"kind":"italic_en","text":"Squinteyed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aHowalu","text_ar":"اَحْوَلُ"},{"kind":"text","text":". (K.) ―         -b6-  Accord. to some, (TA,)"},{"kind":"italic_en","text":"A torrent:"},{"kind":"text","text":"(K, TA:) or, as some say,"},{"kind":"italic_en","text":"a river."},{"kind":"text","text":"(Skr, TA.) ―         -b7-  And"},{"kind":"italic_en","text":"A male serpent."},{"kind":"text","text":"(Ibn- 'Abbád, K.) [All these meanings seem to have been assigned to the word as occurring in a verse of Aboo-Kebeer El-Hudhalee, in which he likens the course of a wolf in a narrow road to the course of the"},{"kind":"arabic","text_bw":"A^axolaf","text_ar":"اَخْلَف"},{"kind":"text","text":".]       -A2-  [Also"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, wont to break promises."},{"kind":"text","text":"Hence the prov., mentioned by Meyd,"},{"kind":"arabic","text_bw":"A^axolafu mino EuroquwbK","text_ar":"اَخْلَفُ مِنْ عُرْقُوبٍ"},{"kind":"italic_en","text":"More wont to break promises than 'Orkoob:"},{"kind":"text","text":"a certain man who rendered himself notorious for breaking his promises. See Freytag's Arab. Prov. i. 454. ―         -b2-  And"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, disagreeing, differing, dissentient, contrary, contrarious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opposing."},{"kind":"text","text":"See an ex. in a prov. cited voce"},{"kind":"arabic","text_bw":"viylN","text_ar":"ثِيلٌ"},{"kind":"text","text":". ―         -b3-  And app."},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, offensive in the odour of the mouth."},{"kind":"text","text":"See Freytag's Arab. Prov. ubi suprà.]"}],"source_refs":["K","S","TA","JK"]}]},"classical_definitions":null}