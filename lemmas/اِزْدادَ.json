":"m","num":"p"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":true,"lemma_key":"اِزْدادَ","root":"زيد","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n18490"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B2%D9%92%D8%AF%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18490","headword_ar":"اِزْدَادَ","root":"zyd","body":[{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"AizotaAda","text_ar":"اِزْتَادَ"},{"kind":"text","text":"]: see 1, in four places. ―         -b2-  Also"},{"kind":"italic_en","text":"He took an addition."},{"kind":"text","text":"(Msb.) See, again, 1. ―         -b3-  Also"},{"kind":"italic_en","text":"He took in addition:"},{"kind":"text","text":"so in the saying,"},{"kind":"arabic","text_bw":"A_i*aA A@zodaAda Alr~aAhinu daraAhima mina Almurotahini","text_ar":"اـِذَا ا@زْدَادَ الرَّاهِنُ دَرَاهِمَ مِنَ المُرْتَهِنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When the pledger takes money in addition from the receiver of the pledge"},{"kind":"text","text":"]. (Mgh.) One says also,"},{"kind":"arabic","text_bw":"Aizodado mina Alxayori","text_ar":"اِزْدَدْ مِنَ الخَيْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Obtain thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gain thou,"},{"kind":"text","text":"somewhat"},{"kind":"italic_en","text":"in addition of what is good:"},{"kind":"text","text":"or it may mean"},{"kind":"italic_en","text":"seek thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desire thou, an increase,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"addition, of what is good"},{"kind":"text","text":"]. (A.) See what next follows, in two places. 10."},{"kind":"arabic","text_bw":"AstzAd","text_ar":"استزاد"},{"kind":"italic_en","text":"He sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, an increase, an addition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more;"},{"kind":"text","text":"(A, Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"AizodaAda","text_ar":"اِزْدَادَ","orth_type":"arrow"},{"kind":"text","text":"; whence the saying, to a man to whom a thing has been given, ↓"},{"kind":"arabic","text_bw":"halo tazodaAdu","text_ar":"هَلْ تَزْدَادُ","orth_type":"arrow"},{"kind":"italic_en","text":"Dost thou seek,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demand, more"},{"kind":"text","text":"than what I have given thee? (L.) ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"yasotaziydu fiY Hadiyvihi","text_ar":"يَسْتَزِيدُ فِى حَدِيثِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He seeks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desires, to add,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exaggerate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to exceed the due bounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to embellish with lies and additions, in his narration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse"},{"kind":"text","text":"]. (A, TA. [See also 5.]) ―         -b5-"},{"kind":"arabic","text_bw":"AstzAdhu","text_ar":"استزادهُ"},{"kind":"italic_en","text":"He sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, of him an increase, an addition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more."},{"kind":"text","text":"(Msb, K.) You say, ↓"},{"kind":"arabic","text_bw":"lawi A@sotazadotuhu lazaAdaniY","text_ar":"لَوِ ا@سْتَزَدْتُهُ لَزَادَنِى","orth_type":"arrow"},{"kind":"italic_en","text":"If I had sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, an increase,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"he had given me an increase,"},{"kind":"text","text":"&c. (Msb.) ―         -b6-  [And hence,] (tropical:)"},{"kind":"italic_en","text":"He reckoned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held him, to have fallen short of doing what he ought to have done,"},{"kind":"text","text":"(S, A, K, TA,)"},{"kind":"italic_en","text":"and complained of him,"},{"kind":"text","text":"(A, TA,) or"},{"kind":"italic_en","text":"reproved him, for a thing that he did not approve."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"kataba A_ilayohi kitaAba A@sotizaAdapK","text_ar":"كَتَبَ اـِلَيْهِ كِتَابَ ا@سْتِزَادَةٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He wrote to him a letter of complaint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reproof, for his having fallen short,"},{"kind":"text","text":"&c.; requiring him to do more]. (A.)"}],"source_refs":["S","A","K","TA"]}]},"classical_definitions":null}