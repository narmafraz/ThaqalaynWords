ymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n38480"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%85%D9%92%D8%B1%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38480","headword_ar":"امرض","root":"mrD","body":[{"kind":"text","text":": see 1. ―         -b2-"},{"kind":"italic_en","text":"He had a bane,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"murrain,"},{"kind":"text","text":"(Yaakoob, S,) or"},{"kind":"italic_en","text":"a disease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distemper,"},{"kind":"text","text":"(A, TA,)"},{"kind":"italic_en","text":"in his beasts,"},{"kind":"text","text":"(Yaakoob, S, A,) or"},{"kind":"italic_en","text":"camels."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"AmrDhu","text_ar":"امرضهُ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God, S, Msb)"},{"kind":"italic_en","text":"rendered him"},{"kind":"arabic","text_bw":"mariyD","text_ar":"مَرِيض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"diseased,"},{"kind":"text","text":"&c.]. (Sb, S, * Msb, K.) You say also,"},{"kind":"arabic","text_bw":"A^akala maA lamo yuwaAfiqohu","text_ar":"اَكَلَ مَا لَمْ يُوَافِقْهُ"},{"kind":"arabic","text_bw":"faA^amoraDahu","text_ar":"فَاَمْرَضَهُ"},{"kind":"text","text":"(A, TA) ["},{"kind":"italic_en","text":"He ate what did not agree with him, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it caused him to fall into"},{"kind":"arabic","text_bw":"AlmaraD","text_ar":"المَرَض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"disease,"},{"kind":"text","text":"&c.]. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A_imoraADu","text_ar":"اـِمْرَاضُ"},{"kind":"arabic","text_bw":"AlA^jofaAni","text_ar":"الاجْفَانِ"},{"kind":"text","text":"(S, voce"},{"kind":"arabic","text_bw":"A_isojaAdN","text_ar":"اـِسْجَادٌ"},{"kind":"text","text":") (tropical:)"},{"kind":"italic_en","text":"The lowering of the eyelids"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a languid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languishing, manner:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"mariyDN","text_ar":"مَرِيضٌ"},{"kind":"text","text":"]. (TK, voce"},{"kind":"arabic","text_bw":"A_isojaAdN","text_ar":"اـِسْجَادٌ"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"AmrDhu","text_ar":"امرضهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He found him to be"},{"kind":"arabic","text_bw":"mariyD","text_ar":"مَرِيض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"diseased,"},{"kind":"text","text":"&c.]. (K.)       -A3-  Also"},{"kind":"arabic","text_bw":"AmrD","text_ar":"امرض"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was near to being right in opinion,"},{"kind":"text","text":"(S, L, K, *)"},{"kind":"italic_en","text":"though not altogether right."},{"kind":"text","text":"(L.) In the K, this signification is wrongly assigned to"},{"kind":"arabic","text_bw":"AmrDhu","text_ar":"امرضهُ"},{"kind":"text","text":". (TA.) A poet says, (S,) namely El-Ukeyshir El-Asadee, praising 'Abd-el-Melik Ibn-Marwán, (TA.)"},{"kind":"quote","text":"wal`kino taHota *aAka Al$~ayobi HazomN\n                     \n                     \n                        A_i*aA maA Zan~a A^amoraDa A^awo A^aSaAbaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"But beneath that hoariness is good judgment: when he forms an opinion, he is nearly right, or he is right"},{"kind":"text","text":"]. (S, TA.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"AmrDhu fulaAnN","text_ar":"امرضهُ فُلَانٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one was near to attaining the object of his"},{"kind":"text","text":"[another's]"},{"kind":"italic_en","text":"want."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["A","TA","God","S","Msb"]}]},"classical_definitions":null}