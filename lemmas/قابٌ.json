{"lemma":"قابٌ","slug":"قابٌ","root":"ق.#.ب","root_slug":"ق-_-ب","root_link":"/words/roots/ق-_-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"قاب","root":"قوب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n36339"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dig (a hole, etc.)"},{"pos":"verb","gloss":"to dig up, to hollow out (the ground)"},{"pos":"verb","gloss":"to crack open (an egg) (of a chick hatching)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36339","headword_ar":"قَابٌ","root":"qwb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"of a bow,"},{"kind":"italic_en","text":"that is between the part that is grasped by the hand and the curved extremity:"},{"kind":"text","text":"to every bow there are"},{"kind":"arabic","text_bw":"qaAbaAni","text_ar":"قَابَانِ"},{"kind":"text","text":": (S, O, Msb, K:) or, accord. to El-Khafájee, it is [the"},{"kind":"italic_en","text":"space"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between the string and the part that is grasped by the hand,"},{"kind":"text","text":"of the bow; as also ↓"},{"kind":"arabic","text_bw":"qiybN","text_ar":"قِيبٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) in the Kur [liii. 9],"},{"kind":"arabic","text_bw":"fakaAna qaAba qawosayoni","text_ar":"فَكَانَ قَابَ قَوْسَيْنِ"},{"kind":"text","text":"accord. to some, is an inverted phrase, meaning"},{"kind":"arabic","text_bw":"fkAn qaAbaYo qawosK","text_ar":"فكان قَابَىْ قَوْسٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"And he was at the distance of the measure of the two portions between the part that is grasped by the hand and each of the curved extremities of a bow"},{"kind":"text","text":"]: (S, O:) [but]"},{"kind":"arabic","text_bw":"qaAbN","text_ar":"قَابٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"a measure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"space;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"qiybN","text_ar":"قِيبٌ","orth_type":"arrow"},{"kind":"text","text":": (S, O, K:) one says,"},{"kind":"arabic","text_bw":"bayonahumaA qaAbu qawosK","text_ar":"بَيْنَهُمَا قَابُ قَوْسٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qawosK","text_ar":"قَوْسٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qiybu","text_ar":"قِيبُ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"Between them two is the measure of a bow"},{"kind":"text","text":"], and likewise"},{"kind":"arabic","text_bw":"qaAdu quwosK","text_ar":"قَادُ قُوْسٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qiydu qawosK","text_ar":"قِيدُ قَوْسٍ"},{"kind":"text","text":": (S, O: *) and it is said that"},{"kind":"arabic","text_bw":"qaAba qawosayoni","text_ar":"قَابَ قَوْسَيْنِ"},{"kind":"text","text":"[in the case mentioned above] means"},{"kind":"italic_en","text":"at"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the distance of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the length of two bows:"},{"kind":"text","text":"or as Fr says,"},{"kind":"italic_en","text":"at"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the distance of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the measure of two Arabian bows."},{"kind":"text","text":"(TA.) ["},{"kind":"arabic","text_bw":"qAbu","text_ar":"قابُ"},{"kind":"arabic","text_bw":"qawosK","text_ar":"قَوْسٍ"},{"kind":"text","text":"is also a term often used in astronomy to denote the distance between two stars; and seems to be syn. with"},{"kind":"arabic","text_bw":"*iraAEN","text_ar":"ذِرَاعٌ"},{"kind":"text","text":"(q. v.) as so used, thus meaning"},{"kind":"italic_en","text":"A cubit;"},{"kind":"text","text":"which is the measure of each"},{"kind":"arabic","text_bw":"qAb","text_ar":"قاب"},{"kind":"text","text":"of a bow, or nearly so.]"}],"source_refs":["S","O","Msb","K","TA"]}]},"classical_definitions":null}