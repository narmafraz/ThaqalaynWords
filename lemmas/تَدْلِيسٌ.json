{"lemma":"تَدْلِيسٌ","slug":"تَدْلِيسٌ","root":"د.ل.س","root_slug":"د-ل-س","root_link":"/words/roots/د-ل-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of دَلَّسَ (dallasa) (form II)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"deceit"},{"pos":"noun","gloss":"concealment of a fault or defect"},{"pos":"noun","gloss":"concealment (Hadith terminology)"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of دَلَّسَ (dallasa)."},"ipa":["/tad.liːs/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%AF%D9%84%D9%8A%D8%B3/","headword_ar":"تدليس","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23062#541d8c","body_html":"<span>التدليس: من الحديث هي اللطيفة الروحانية، وقد يطلق على الواسطة اللطيفة الرابطة بين الشيئين، كالمدد الواصل من الحق إلى العبد.</span>"},{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23062#b62b46","body_html":"<span>التدليس: من الحديث قسمان: أحدهما: تدليس الإسناد، وهو أن </span><span>يروي عمن لقيه، ولم يسمعه منه موهمًا أنه سمعه منه، أو عمن عاصره ولم يلقه موهمًا أنه لقيه، أو سمعه منه، والآخر تدليس الشيوخ: وهو أن يروي عن شيخ حديثا سمعه منه فيسميه أو يكنيه ويصفه بما لم يعرف به كي لا يعرف.</span>"}]}}