{"lemma": "أُرْبٌ", "slug": "أُرْبٌ", "root": "#.ر.ب", "root_slug": "_-ر-ب", "root_link": "/words/roots/_-ر-ب", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 5, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 2}, "lanes": {"found": true, "entry_ids": ["n517", "n518", "n522", "n523", "n524", "n525"], "search_url": "https://lanelexicon.com/?s=%D8%A3%D9%8F%D8%B1%D9%92%D8%A8%D9%8C"}}, "translations": {"en": "to be cunning", "fa": "زرنگ بودن", "ur": "چالاک ہونا", "tr": "züppeli olmak", "id": "pandai", "bn": "চতুর হওয়া", "es": "ser astuto", "fr": "être rusé", "de": "schlau sein", "ru": "хитрить", "zh": "狡猾"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to blow continuously (of the wind)"}, {"pos": "verb", "gloss": "to rain nonstop (of clouds, etc.)"}]}, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n517", "headword_ar": "اَرُبَ", "root": "Arb", "body": [{"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", (T, S, M, K,) inf. n."}, {"kind": "arabic", "text_bw": "A^araAbapN", "text_ar": "اَرَابَةٌ"}, {"kind": "text", "text": "(AZ, T, S, M, K) and"}, {"kind": "arabic", "text_bw": "A_irabN", "text_ar": "اـِرَبٌ"}, {"kind": "text", "text": ", like"}, {"kind": "arabic", "text_bw": "SigarN", "text_ar": "صِغَرٌ"}, {"kind": "text", "text": ", (S, K,)"}, {"kind": "italic_en", "text": "He was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, cunning, characterized by intelligence with craft and forecast,"}, {"kind": "text", "text": "or simply"}, {"kind": "italic_en", "text": "intelligent, excellent in judgment, sagacious,"}, {"kind": "text", "text": "(T, [in which it is said that As is related to have assigned this signification to"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ"}, {"kind": "text", "text": ",] S, M, K,)"}, {"kind": "italic_en", "text": "and knowing in affairs."}, {"kind": "text", "text": "(M.) [The TA assigns the former inf. n. to it when it signifies simply intelligence, and the latter when it has the more comprehensive signification of cunning.] ―         -b2-"}, {"kind": "arabic", "text_bw": "A^ariba biAl$~aYo'i", "text_ar": "اَرِبَ بِالشَّىْءِ"}, {"kind": "text", "text": ", [aor."}, {"kind": "text", "text": ",]"}, {"kind": "italic_en", "text": "He became expert,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "skilful, in the thing:"}, {"kind": "text", "text": "(M:) or"}, {"kind": "italic_en", "text": "he became accustomed to,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "practised"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "exercised in, the thing,"}, {"kind": "text", "text": "(S, K, *)"}, {"kind": "italic_en", "text": "and became knowing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "skilful"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "therein"}, {"kind": "text", "text": "]. (S.) ―         -b3-"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ"}, {"kind": "text", "text": ", is also"}, {"kind": "italic_en", "text": "syn. with"}, {"kind": "arabic", "text_bw": "A^anisa", "text_ar": "اَنِسَ"}, {"kind": "text", "text": "[app. as meaning"}, {"kind": "italic_en", "text": "He became familiar"}, {"kind": "text", "text": "with a person or thing]. (M.) ―         -b4-  And"}, {"kind": "arabic", "text_bw": "A^ariba biAl$~aYo'i", "text_ar": "اَرِبَ بِالشَّىْءِ"}, {"kind": "text", "text": "also signifies"}, {"kind": "italic_en", "text": "He devoted,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "addicted, himself,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "clave,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "kept, to the thing:"}, {"kind": "text", "text": "(T, K:) and"}, {"kind": "italic_en", "text": "he was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, niggardly, avaricious,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "tenacious, of the thing."}, {"kind": "text", "text": "(T, M, TA.) ―         -b5-  And"}, {"kind": "arabic", "text_bw": "A^ariba fiY AlA^amori", "text_ar": "اَرِبَ فِى الاَمْرِ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "fiyhi", "text_ar": "فِيهِ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "tA^r~b", "text_ar": "تارّب", "orth_type": "arrow"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He exerted,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "employed, his power and ability in the affair, and understood it:"}, {"kind": "text", "text": "(ISh, T:) or"}, {"kind": "arabic", "text_bw": "tA^r~b", "text_ar": "تارّب"}, {"kind": "text", "text": "signifies"}, {"kind": "italic_en", "text": "he exerted his strength, force,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "energy;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "strained himself;"}, {"kind": "text", "text": "(As, S, M;)"}, {"kind": "arabic", "text_bw": "fiy Al$~aYo'i", "text_ar": "فِي الشَّىْءِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "in the thing"}, {"kind": "text", "text": "]; (As, S;) and"}, {"kind": "arabic", "text_bw": "fiY HaAjatihi", "text_ar": "فِى حَاجَتِهِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "in his needful affair,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in the accomplishment of his want"}, {"kind": "text", "text": "]. (As, S, M.) ―         -b6-"}, {"kind": "arabic", "text_bw": "A^ariba Ealayohi", "text_ar": "اَرِبَ عَلَيْهِ"}, {"kind": "italic_en", "text": "He had,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "obtained, power over him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it."}, {"kind": "text", "text": "(M.)       -A2-"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ", (T, S, K,) inf. n."}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ"}, {"kind": "text", "text": ", (T, S,)"}, {"kind": "italic_en", "text": "He was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, in want,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "need."}, {"kind": "text", "text": "(T, S, K.) [See"}, {"kind": "arabic", "text_bw": "A^aribota", "text_ar": "اَرِبْتَ"}, {"kind": "arabic", "text_bw": "Eano *iY yadayoka", "text_ar": "عَنْ ذِى يَدَيْكَ"}, {"kind": "text", "text": ", and two other phrases following it, in a later part of this paragraph.] ―         -b2-"}, {"kind": "arabic", "text_bw": "A^ariba A_ilayohi", "text_ar": "اَرِبَ اـِلَيْهِ"}, {"kind": "text", "text": ", (M, Msb,) or"}, {"kind": "arabic", "text_bw": "bihi", "text_ar": "بِهِ"}, {"kind": "text", "text": "(T,) aor. and inf. n. as above,"}, {"kind": "italic_en", "text": "He wanted it; was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, in want,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "need, of it;"}, {"kind": "text", "text": "(T, M, Msb;) and"}, {"kind": "italic_en", "text": "sought it,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "desired it;"}, {"kind": "text", "text": "(T;) namely, a thing. (T, Msb.) ―         -b3-"}, {"kind": "arabic", "text_bw": "A^ariba Ald~ahoru", "text_ar": "اَرِبَ الدَّهْرُ"}, {"kind": "italic_en", "text": "Fortune was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, hard,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "adverse:"}, {"kind": "text", "text": "(T, S, K:) as though it wanted something of us, for which it pressed hard. (M, TA.) And"}, {"kind": "arabic", "text_bw": "A^ariba Ealayohi", "text_ar": "اَرِبَ عَلَيْهِ"}, {"kind": "italic_en", "text": "He was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, hard upon him"}, {"kind": "text", "text": "in his demand. (TA, from a trad.)       -A3-"}, {"kind": "arabic", "text_bw": "A^arabahu", "text_ar": "اَرَبَهُ"}, {"kind": "text", "text": ", [from"}, {"kind": "arabic", "text_bw": "A_irabN", "text_ar": "اـِرَبٌ"}, {"kind": "text", "text": ",]"}, {"kind": "italic_en", "text": "He struck upon a member,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "limb, belonging to him."}, {"kind": "text", "text": "(K, *"}, {"kind": "page_break", "n": 45}, {"kind": "text", "text": "TA.) ―         -b2-"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": ", (T, S, K, TA,)"}, {"kind": "italic_en", "text": "His member,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "limb,"}, {"kind": "text", "text": "(generally meaning the"}, {"kind": "italic_en", "text": "arm,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "hand,"}, {"kind": "text", "text": "M,)"}, {"kind": "italic_en", "text": "was cut off:"}, {"kind": "text", "text": "(M, K:) or"}, {"kind": "italic_en", "text": "dropped off:"}, {"kind": "text", "text": "(T:) and"}, {"kind": "italic_en", "text": "his members,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "limbs,"}, {"kind": "text", "text": "(generally relating to [the"}, {"kind": "italic_en", "text": "members,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fingers, of] the arm,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "hand,"}, {"kind": "text", "text": "TA,)"}, {"kind": "italic_en", "text": "dropped off, one after another,"}, {"kind": "text", "text": "(S, K, TA,)"}, {"kind": "italic_en", "text": "in consequence of his being affected by the disease termed"}, {"kind": "arabic", "text_bw": "ju*aAm", "text_ar": "جُذَام"}, {"kind": "text", "text": ": (TA:) and"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(said of a member, or limb,)"}, {"kind": "italic_en", "text": "dropped off."}, {"kind": "text", "text": "(TA.) The phrase,"}, {"kind": "arabic", "text_bw": "A^aribota", "text_ar": "اَرِبْتَ"}, {"kind": "arabic", "text_bw": "Eano *iY yadayoka", "text_ar": "عَنْ ذِى يَدَيْكَ"}, {"kind": "text", "text": ", (T, TA,) or"}, {"kind": "arabic", "text_bw": "mino *Y ydyk", "text_ar": "مِنْ ذى يديك"}, {"kind": "text", "text": ", (S, TA, [and said in the latter to be likewise found in the T, but I have consulted two copies of the T and found only"}, {"kind": "arabic", "text_bw": "En", "text_ar": "عن"}, {"kind": "text", "text": ",]) or"}, {"kind": "arabic", "text_bw": "fiY *Y ydyk", "text_ar": "فِى ذى يديك"}, {"kind": "text", "text": ", (IAar, as related by Sh,) or"}, {"kind": "arabic", "text_bw": "mino yadayoka", "text_ar": "مِنْ يَدَيْكَ"}, {"kind": "text", "text": ", (K,) but MF says that"}, {"kind": "arabic", "text_bw": "mn", "text_ar": "من"}, {"kind": "text", "text": "in this phrase is a mistranscription, (TA,) means,"}, {"kind": "italic_en", "text": "May the members"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "fingers] of thy hands,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "arms, drop off:"}, {"kind": "text", "text": "(S, K, TA:) or it means,"}, {"kind": "italic_en", "text": "may what is in thy hands depart from thee, so that thou shalt be in want:"}, {"kind": "text", "text": "occurring in a trad. (IAar, T, TA.) And"}, {"kind": "arabic", "text_bw": "A^ariba maA lahu", "text_ar": "اَرِبَ مَا لَهُ"}, {"kind": "text", "text": ", said by Mohammad on the occasion of a man's coming to him and asking him to acquaint him with some work that should introduce him into Paradise, means, accord. to Kt,"}, {"kind": "italic_en", "text": "May his members,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "limbs, drop off,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "be cut off: what aileth him?"}, {"kind": "text", "text": "(TA:) or, accord. to IAar,"}, {"kind": "italic_en", "text": "may he become in want: what aileth him?"}, {"kind": "text", "text": "(T, TA:) but IAth says that this has been related in three different ways: first,"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": ", signifying an imprecation, [as rendered above,] and used as expressive of wonder: secondly,"}, {"kind": "arabic", "text_bw": "m~aA lahu", "text_ar": "مَّا لَهُ"}, {"kind": "text", "text": "↓"}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ", "orth_type": "arrow"}, {"kind": "text", "text": "; i. e."}, {"kind": "arabic", "text_bw": "HaAjapN lahu", "text_ar": "حَاجَةٌ لَهُ"}, {"kind": "text", "text": ";"}, {"kind": "arabic", "text_bw": "maA", "text_ar": "مَا"}, {"kind": "text", "text": "being [syntactically] redundant, denoting littleness; the meaning being,"}, {"kind": "italic_en", "text": "he has some little want:"}, {"kind": "text", "text": "or, as some say,"}, {"kind": "italic_en", "text": "a want hath brought him: what aileth him?"}, {"kind": "text", "text": "thirdly, ↓"}, {"kind": "arabic", "text_bw": "A^aribN", "text_ar": "اَرِبٌ", "orth_type": "arrow"}, {"kind": "text", "text": "; i. e."}, {"kind": "arabic", "text_bw": "huwa A^aribN", "text_ar": "هُوَ اَرِبٌ"}, {"kind": "text", "text": "; meaning"}, {"kind": "italic_en", "text": "he is intelligent,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sagacious,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "skilful,"}, {"kind": "text", "text": "[as is said in the T,]"}, {"kind": "italic_en", "text": "and perfect: what aileth him?"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "what is his affair?"}, {"kind": "text", "text": "the inchoative being suppressed. (TA.)"}, {"kind": "arabic", "text_bw": "maA lahu A^aribato yaduhu", "text_ar": "مَا لَهُ اَرِبَتْ يَدُهُ"}, {"kind": "text", "text": ", (M, K, *) another form of imprecation, (M,) means"}, {"kind": "italic_en", "text": "What aileth him? may his arm,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "hand, be cut off:"}, {"kind": "text", "text": "or,"}, {"kind": "italic_en", "text": "may he become poor, and want what is in the hands of others."}, {"kind": "text", "text": "(M, K. *) ―         -b3-  [Hence, perhaps,]"}, {"kind": "arabic", "text_bw": "A^aribato maEidatuhu", "text_ar": "اَرِبَتْ مَعِدَتُهُ"}, {"kind": "italic_en", "text": "His stomach became vitiated, disordered,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in an unsound state."}, {"kind": "text", "text": "(K.) ―         -b4-"}, {"kind": "arabic", "text_bw": "A^ariba", "text_ar": "اَرِبَ"}, {"kind": "text", "text": "also signifies"}, {"kind": "italic_en", "text": "He prostrated himself firmly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fixedly, upon his [seven] members [mentioned in the explanations of the word"}, {"kind": "arabic", "text_bw": "A_irobN", "text_ar": "اـِرْبٌ"}, {"kind": "text", "text": "]. (T.)"}], "source_refs": ["T", "S", "M", "K", "AZ", "ISh", "Msb", "TA"]}, {"entry_id": "n518", "headword_ar": "ارّب", "root": "Arb", "body": [{"kind": "text", "text": ", inf. n."}, {"kind": "arabic", "text_bw": "taA^riybN", "text_ar": "تَارِيبٌ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, [made,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "rendered, cunning,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "intelligent, excellent in judgment, sagacious, and knowing in affairs;"}, {"kind": "text", "text": "(see"}, {"kind": "arabic", "text_bw": "A^aruba", "text_ar": "اَرُبَ"}, {"kind": "text", "text": ";)]"}, {"kind": "italic_en", "text": "made to have knowledge,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "skill;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "made to understand."}, {"kind": "text", "text": "(M, TA.)       -A2-"}, {"kind": "italic_en", "text": "He was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, avaricious; [in a state of vehement want"}, {"kind": "text", "text": "of a thing;]"}, {"kind": "italic_en", "text": "eagerly desirous."}, {"kind": "text", "text": "(A'Obeyd, TA.) [See also 1.]       -A3-"}, {"kind": "italic_en", "text": "He cut up,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "cut into pieces,"}, {"kind": "text", "text": "(T, A, Mgh,) a sheep, or goat, (A, Mgh,)"}, {"kind": "italic_en", "text": "limb by limb."}, {"kind": "text", "text": "(T, A, Mgh.) ―         -b2-"}, {"kind": "italic_en", "text": "He cut off"}, {"kind": "text", "text": "a member, or limb,"}, {"kind": "italic_en", "text": "entire."}, {"kind": "text", "text": "(M, TA.) ―         -b3-"}, {"kind": "italic_en", "text": "He made entire,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "complete,"}, {"kind": "text", "text": "(T, S, M, K,) a thing, (S,) a lot, or portion, (T, TA,) or anything. (M.)"}], "source_refs": ["T", "A", "Mgh", "S", "M", "K", "TA"]}, {"entry_id": "n522", "headword_ar": "اَرْبٌ", "root": "Arb", "body": [{"kind": "text", "text": ": see what next follows, in two places."}], "source_refs": []}, {"entry_id": "n523", "headword_ar": "اـِرْبٌ", "root": "Arb", "body": [{"kind": "italic_en", "text": "Cunning, intelligence with craft and forecast,"}, {"kind": "text", "text": "or simply"}, {"kind": "italic_en", "text": "intelligence, excellence of judgment, sagacity,"}, {"kind": "text", "text": "(T, S, M, L, K,)"}, {"kind": "italic_en", "text": "and knowledge in affairs;"}, {"kind": "text", "text": "(M, L;) as also ↓"}, {"kind": "arabic", "text_bw": "A_irobapN", "text_ar": "اـِرْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "A^urobapN", "text_ar": "اُرْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(M, K) and ↓"}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (M, A,) or ↓"}, {"kind": "arabic", "text_bw": "A^arobN", "text_ar": "اَرْبٌ", "orth_type": "arrow"}, {"kind": "text", "text": ". (L.) You say,"}, {"kind": "arabic", "text_bw": "huwa *uw A_irobK", "text_ar": "هُوَ ذُو اـِرْبٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He is a possessor of cunning,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "intelligence,"}, {"kind": "text", "text": "&c.]. (S.) ―         -b2-"}, {"kind": "italic_en", "text": "Intelligence and religion."}, {"kind": "text", "text": "(Th, M, K.) ―         -b3-"}, {"kind": "italic_en", "text": "Deceit, guile, artifice,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fraud;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "makorN", "text_ar": "مَكْرٌ"}, {"kind": "text", "text": ": so in the L and other lexicons: in the K,"}, {"kind": "arabic", "text_bw": "nukorN", "text_ar": "نُكْرٌ"}, {"kind": "text", "text": "[i. e. “cunning,” &c., as above]: (TA:) and so ↓"}, {"kind": "arabic", "text_bw": "A_irobapN", "text_ar": "اـِرْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "; syn."}, {"kind": "arabic", "text_bw": "HiylapN", "text_ar": "حِيلَةٌ"}, {"kind": "text", "text": ". (K.) ―         -b4-"}, {"kind": "italic_en", "text": "Wickedness, mischievousness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "malignity; hidden rancour, malevolence,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "malice."}, {"kind": "text", "text": "(K, TA.) [In a trad. it occurs in this sense written, in the TA, ↓"}, {"kind": "arabic", "text_bw": "A^arob", "text_ar": "اَرْب", "orth_type": "arrow"}, {"kind": "text", "text": ".]       -A2-  See also"}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ"}, {"kind": "text", "text": ", in four places.       -A3-  Also"}, {"kind": "italic_en", "text": "A member; a distinct and complete part of an animal body; a limb;"}, {"kind": "text", "text": "(T, S, M, Mgh, Msb, K;) or"}, {"kind": "italic_en", "text": "such as is made complete,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "entire, not wanting anything:"}, {"kind": "text", "text": "(M:) pl."}, {"kind": "arabic", "text_bw": "A=raAbN", "text_ar": "ا=رَابٌ"}, {"kind": "text", "text": "(S, M, Mgh, Msb) and"}, {"kind": "arabic", "text_bw": "A^aroA=bN", "text_ar": "اَرْا=بٌ"}, {"kind": "text", "text": "; (S, Mgh;) the latter formed by transposition. (Mgh.) You say,"}, {"kind": "arabic", "text_bw": "qaT~aEotuhu A_irobFA A_irobFA", "text_ar": "قَطَّعْتُهُ اـِرْبًا اـِرْبًا"}, {"kind": "italic_en", "text": "I cut him up, member by member,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "limb by limb."}, {"kind": "text", "text": "(TA.) And"}, {"kind": "arabic", "text_bw": "Als~ujuwdu EalaY saboEapi A=raAbK", "text_ar": "السُّجُودُ عَلَى سَبْعَةِ ا=رَابٍ"}, {"kind": "text", "text": "or"}, {"kind": "arabic", "text_bw": "A^aroA=bK", "text_ar": "اَرْا=بٍ"}, {"kind": "italic_en", "text": "Prostration"}, {"kind": "text", "text": "[in prayer]"}, {"kind": "italic_en", "text": "is"}, {"kind": "text", "text": "[performed]"}, {"kind": "italic_en", "text": "on seven members;"}, {"kind": "text", "text": "(S, Mgh;) namely, the. forehead, the hands, the knees, and the feet. (TA.) ―         -b2-  Also The"}, {"kind": "italic_en", "text": "membrum genitale;"}, {"kind": "text", "text": "the"}, {"kind": "italic_en", "text": "pudendum;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "farojN", "text_ar": "فَرْجٌ"}, {"kind": "text", "text": ": (M, K:) but some say that this signification is not known: [see"}, {"kind": "arabic", "text_bw": "A^arabN", "text_ar": "اَرَبٌ"}, {"kind": "text", "text": ":] in some copies of the K, the explanation is written"}, {"kind": "arabic", "text_bw": "faraHN", "text_ar": "فَرَحٌ"}, {"kind": "text", "text": ", with the unpointed"}, {"kind": "arabic", "text_bw": "H", "text_ar": "ح"}, {"kind": "text", "text": ". (TA.) ―         -b3-"}, {"kind": "arabic", "text_bw": "A=raAbN", "text_ar": "ا=رَابٌ"}, {"kind": "text", "text": "[the pl.] also signifies"}, {"kind": "italic_en", "text": "Pieces of flesh,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "of flesh-meat."}, {"kind": "text", "text": "(M.)"}], "source_refs": ["T", "S", "M", "L", "K", "A", "TA", "Mgh", "Msb"]}, {"entry_id": "n524", "headword_ar": "اَرَبٌ", "root": "Arb", "body": [{"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "A_irobN", "text_ar": "اـِرْبٌ"}, {"kind": "text", "text": ".       -A2-"}, {"kind": "italic_en", "text": "Want,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "need;"}, {"kind": "text", "text": "(T, S, M, Mgh, Msb, K;) as also ↓"}, {"kind": "arabic", "text_bw": "A_irobN", "text_ar": "اـِرْبٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "A_robapN", "text_ar": "اـرْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(the same, and A) and ↓"}, {"kind": "arabic", "text_bw": "A^urobapN", "text_ar": "اُرْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(K) and ↓"}, {"kind": "arabic", "text_bw": "maA^orabapN", "text_ar": "مَاْرَبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and ↓"}, {"kind": "arabic", "text_bw": "maA^orubapN", "text_ar": "مَاْرُبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(T, S, M, A, Msb, K) and ↓"}, {"kind": "arabic", "text_bw": "maA^oribapN", "text_ar": "مَاْرِبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(K) and ↓"}, {"kind": "arabic", "text_bw": "maA^orabN", "tex