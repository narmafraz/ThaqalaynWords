translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be polite to, to be courteous to, to be amiable to","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6363","headword_ar":"جَامِلٌ","root":"jml","body":[{"kind":"text","text":"[act. part. n. of"},{"kind":"arabic","text_bw":"jamala","text_ar":"جَمَلَ"},{"kind":"text","text":".       -A2-  And also part. n. of"},{"kind":"arabic","text_bw":"jamula","text_ar":"جَمُلَ"},{"kind":"text","text":"]. The Arabs say,"},{"kind":"arabic","text_bw":"Aujomulo A_ino kunota jaAmilFA","text_ar":"اُجْمُلْ اـِنْ كُنْتَ جَامِلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Become beautiful,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"if thou be becoming beautiful,"},{"kind":"text","text":"&c.]: but when they mean the quality [alone], they say,"},{"kind":"arabic","text_bw":"A_in~ahu lajamiylN","text_ar":"اـِنَّهُ لَجَمِيلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily he is beautiful,"},{"kind":"text","text":"&c.]. (Lh, TA.)       -A3-  A man"},{"kind":"italic_en","text":"possessing a"},{"kind":"arabic","text_bw":"jamal","text_ar":"جَمَل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he-camel"},{"kind":"text","text":"]. (TA. [See also"},{"kind":"arabic","text_bw":"jam~aAlN","text_ar":"جَمَّالٌ"},{"kind":"text","text":".]) ―         -b2-"},{"kind":"italic_en","text":"A herd,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct number, of camels,"},{"kind":"text","text":"(S, K, * TA,)"},{"kind":"italic_en","text":"males and females,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"with their pastors and their owners:"},{"kind":"text","text":"(S, K, TA: [also said in the K to be a pl. of"},{"kind":"arabic","text_bw":"jamalN","text_ar":"جَمَلٌ"},{"kind":"text","text":": in the CK,"},{"kind":"arabic","text_bw":"AljAmiEu","text_ar":"الجامِعُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"AljaAmilu","text_ar":"الجَامِلُ"},{"kind":"text","text":":]) or a word formed to denote a pl., meaning"},{"kind":"italic_en","text":"camels,"},{"kind":"text","text":"(Ham pp. 122 and 490,)"},{"kind":"italic_en","text":"males and females;"},{"kind":"text","text":"(Id p. 122;) derived from"},{"kind":"arabic","text_bw":"jamalN","text_ar":"جَمَلٌ"},{"kind":"text","text":"; (Id. p. 490;) like"},{"kind":"arabic","text_bw":"baAqirN","text_ar":"بَاقِرٌ"},{"kind":"text","text":"(Id. ib. and TA) from"},{"kind":"arabic","text_bw":"baqarN","text_ar":"بَقَرٌ"},{"kind":"text","text":", (Ham p. 490,) and"},{"kind":"arabic","text_bw":"kaAlibN","text_ar":"كَالِبٌ"},{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"kalobN","text_ar":"كَلْبٌ"},{"kind":"text","text":"]. (TA.) ―         -b3-  Also"},{"kind":"italic_en","text":"A great tribe."},{"kind":"text","text":"(AHeyth, K.)"}],"source_refs":["TA"]}]},"classical_definitions":null}