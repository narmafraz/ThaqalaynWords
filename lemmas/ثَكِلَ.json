ثَكَلٌ","root":"vkl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"vukolN","text_ar":"ثُكْلٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}