{"lemma":"عَجْوَةُ","slug":"عَجْوَةُ","root":"ع.ج.#","root_slug":"ع-ج-_","root_link":"/words/roots/ع-ج-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n28271"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%92%D9%88%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28271","headword_ar":"عَجْوَةٌ","root":"Ejw and EjY","body":[{"kind":"text","text":"(S, K, &c.) and ↓"},{"kind":"arabic","text_bw":"EajaAwapN","text_ar":"عَجَاوَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EajaAyapN","text_ar":"عَجَايَةٌ","orth_type":"arrow"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"EujaAwapN","text_ar":"عُجَاوَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EujaAyapN","text_ar":"عُجَايَةٌ","orth_type":"arrow"},{"kind":"text","text":", (accord. to different"},{"kind":"page_break","n":1969},{"kind":"text","text":"copies of the K, [but in the TA these two words are expl. only as in another paragraph which will be found below,])"},{"kind":"italic_en","text":"A sort of dates in El-Medeeneh,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"of the best kind, the palm-tree of which is called"},{"kind":"arabic","text_bw":"liynapN","text_ar":"لِينَةٌ"},{"kind":"text","text":"; (S; [or, accord. to Fr and Akh, cited in the TA in art."},{"kind":"arabic","text_bw":"lwn","text_ar":"لون"},{"kind":"text","text":", the term"},{"kind":"arabic","text_bw":"liynapN","text_ar":"لِينَةٌ"},{"kind":"text","text":"is applied to a palm-tree but not to that of the"},{"kind":"arabic","text_bw":"Eajowap","text_ar":"عَجْوَة"},{"kind":"text","text":";])"},{"kind":"italic_en","text":"said to be from what was planted by the hand of the Prophet;"},{"kind":"text","text":"accord. to IAth, they are"},{"kind":"italic_en","text":"larger than the"},{"kind":"arabic","text_bw":"SayoHaAniY~","text_ar":"صَيْحَانِىّ"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"inclining to blackness;"},{"kind":"text","text":"but accord. to Az,"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"Eajowap","text_ar":"عَجْوَة"},{"kind":"italic_en","text":"in El-Medeeneh are the"},{"kind":"arabic","text_bw":"SayoHaAniy~ap","text_ar":"صَيْحَانِيَّة"},{"kind":"text","text":","},{"kind":"italic_en","text":"and there are sorts of the"},{"kind":"arabic","text_bw":"Ejwp","text_ar":"عجوة"},{"kind":"italic_en","text":"there that have not the sweetness nor the odour nor the fulness of the"},{"kind":"arabic","text_bw":"SyHAny~p","text_ar":"صيحانيّة"},{"kind":"text","text":": (TA:) or the"},{"kind":"italic_en","text":"best of dates:"},{"kind":"text","text":"(Mgh:) and,"},{"kind":"italic_en","text":"in El-Hijáz,"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"dates that are stuffed"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maHo$iY~","text_ar":"مَحْشِىّ"},{"kind":"text","text":") [or"},{"kind":"italic_en","text":"pressed into a compact mass, while moist, in the receptacle of palm-leaves"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skin,"},{"kind":"text","text":"as are the dates called"},{"kind":"arabic","text_bw":"Eajowap","text_ar":"عَجْوَة"},{"kind":"text","text":"in the present day]; (K, TA;) they are"},{"kind":"italic_en","text":"termed"},{"kind":"arabic","text_bw":"A^um~u Alt~amori","text_ar":"اُمُّ التَّمْرِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"the mother of dates,"},{"kind":"text","text":"app. because many persons keep a stock thereof],"},{"kind":"italic_en","text":"to which recourse is had, like the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"dates called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"$ihoriyz","text_ar":"شِهْرِيز"},{"kind":"italic_en","text":"in El-Basrah."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","TA","Mgh"]}]},"classical_definitions":null}