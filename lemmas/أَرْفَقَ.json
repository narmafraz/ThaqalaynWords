se,"sense_count":1},"lanes":{"found":true,"entry_ids":["n16211"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D9%92%D9%81%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to attach, to enclose"}]},"etymology":null,"ipa":["/ʔar.fa.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16211","headword_ar":"اَرْفَقُ","root":"rfq","body":[{"kind":"text","text":"[compar. and superl. of"},{"kind":"arabic","text_bw":"rafiyqN","text_ar":"رَفِيقٌ"},{"kind":"text","text":"; meaning"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, gentle,"},{"kind":"text","text":"&c.] ―         -b2-  [Hence,] one says,"},{"kind":"arabic","text_bw":"h`*aA AlA^amoru A^arofaqu bika","text_ar":"هٰذَا الاَمْرُ اَرْفَقُ بِكَ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"Ealayoka","text_ar":"عَلَيْكَ"},{"kind":"text","text":"] (assumed tropical:)"},{"kind":"italic_en","text":"This affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing, is more,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"convenient, to thee."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Ewd","text_ar":"عود"},{"kind":"text","text":".) [See also an instance voce"},{"kind":"arabic","text_bw":"maHoniyapN","text_ar":"مَحْنِيَةٌ"},{"kind":"text","text":"(in art."},{"kind":"arabic","text_bw":"Hnw","text_ar":"حنو"},{"kind":"text","text":"), last sentence.]       -A2-  Also, applied to a camel,"},{"kind":"italic_en","text":"Having the elbow"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Almirofaq","text_ar":"المِرْفَق"},{"kind":"text","text":")"},{"kind":"italic_en","text":"distorted from the side:"},{"kind":"text","text":"(JK, S, O, K:) so says Lth: (O:) and so the fem."},{"kind":"arabic","text_bw":"rafoqaA='u","text_ar":"رَفْقَا=ءُ"},{"kind":"text","text":", applied to a she-camel: (JK, S:) but Az says that the epithet preserved by him in his memory as heard from"},{"kind":"page_break","n":1127},{"kind":"text","text":"the Arabs applied to a camel is"},{"kind":"arabic","text_bw":"A^adofaqu","text_ar":"اَدْفَقُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"dAl","text_ar":"دال"},{"kind":"text","text":". (O.) ―         -b2-  Accord. to As, (O,)"},{"kind":"arabic","text_bw":"rafoqaA='u","text_ar":"رَفْقَا=ءُ"},{"kind":"text","text":"applied to a she-camel signifies"},{"kind":"italic_en","text":"Having the orifice of her teat stopped up;"},{"kind":"text","text":"(O, K;) and so ↓"},{"kind":"arabic","text_bw":"rafiqapN","text_ar":"رَفِقَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) the latter is said by Zeyd Ibn-Kuthweh to signify, so applied,"},{"kind":"italic_en","text":"having the orifices of her teats stopped up."},{"kind":"text","text":"(O.)"}],"source_refs":["JK","S","O","K"]}]},"classical_definitions":null}