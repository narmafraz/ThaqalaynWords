um":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n2064"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B0%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to beat, surpass"}]},"etymology":null,"ipa":["/bað.ða/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2064","headword_ar":"بَذَّ","root":"b*","body":[{"kind":"text","text":", (M,) sec. pers."},{"kind":"arabic","text_bw":"ba*i*ota","text_ar":"بَذِذْتَ"},{"kind":"text","text":", (S, Mgh, K,) aor."},{"kind":"arabic","text_bw":"yaba*~u","text_ar":"يَبَذُّ"},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"ba*aA*apN","text_ar":"بَذَاذَةٌ"},{"kind":"text","text":"(S, M, Mgh, K) and"},{"kind":"arabic","text_bw":"bu*uw*apN","text_ar":"بُذُوذَةٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"ba*a*N","text_ar":"بَذَذٌ"},{"kind":"text","text":"(M, Mgh, K) and"},{"kind":"arabic","text_bw":"ba*aA*N","text_ar":"بَذَاذٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"bi*aA*N","text_ar":"بِذَاذٌ"},{"kind":"text","text":", with kesr, (TA,) [of all which, the third is the regular form,]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, threadbare, and shabby,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean, in the state of his apparel,"},{"kind":"text","text":"(Ks, S, M, Mgh, L,) and"},{"kind":"italic_en","text":"in an evil condition;"},{"kind":"text","text":"(M, L, K;)"},{"kind":"italic_en","text":"slovenly with respect to his person:"},{"kind":"text","text":"(Ks, M, L:) or"},{"kind":"italic_en","text":"he neglected the constant adornment of himself:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he adorned himself one day, and another day left his hair in a shaggy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishevelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"matted and dusty, state:"},{"kind":"text","text":"(T, L:) or"},{"kind":"italic_en","text":"he was humble in his apparel, not taking pleasure therein."},{"kind":"text","text":"(IAth, L.)"},{"kind":"arabic","text_bw":"ba*aA*ap","text_ar":"بَذَاذَة"},{"kind":"text","text":"is said in a trad. to be a part of religion; (Ks, T, M, Mgh, L;) meaning, in this instance, The"},{"kind":"italic_en","text":"being humble in dress, and wearing that which is not conducive to self-conceit and pride."},{"kind":"text","text":"(Mgh.)       -A2-"},{"kind":"arabic","text_bw":"ba*~ahu","text_ar":"بَذَّهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yabu*~u","text_ar":"يَبُذُّ"},{"kind":"text","text":", (T, S, M, L,) inf. n."},{"kind":"arabic","text_bw":"ba*~N","text_ar":"بَذٌّ"},{"kind":"text","text":"(S, M, L, K) and ↓"},{"kind":"arabic","text_bw":"ba*iy*apN","text_ar":"بَذِيذَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [or this may be a simple subst.,]"},{"kind":"italic_en","text":"He overcame him;"},{"kind":"text","text":"(T, S, M, L, K;)"},{"kind":"italic_en","text":"he surpassed him"},{"kind":"text","text":"in goodliness or beauty, or in any deed: (T, L:)"},{"kind":"italic_en","text":"he outstripped him."},{"kind":"text","text":"(M, L.) It is said in a trad.,"},{"kind":"arabic","text_bw":"ba*~a AlqaAy^iliyna","text_ar":"بَذَّ القَايِلِينَ"},{"kind":"italic_en","text":"He outstripped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpassed, and overcame, the speakers."},{"kind":"text","text":"(L.)"}],"source_refs":["M","S","Mgh","K","L","TA","Ks","T"]}]},"classical_definitions":null}