t"},{"kind":"italic_en","text":"to sink"},{"kind":"text","text":"in a liquid: used in this sense in chymical works; but probably post-classical. See what next follows.]"}],"source_refs":[]},{"entry_id":"n15450","headword_ar":"رَسَبٌ","root":"rsb","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rusabN","text_ar":"رُسَبٌ"},{"kind":"text","text":": see the next paragraph."}],"source_refs":[]}]},"classical_definitions":null}