{"lemma":"أَعَفَّيْ","slug":"أَعَفَّيْ","root":"ع.ف.ف","root_slug":"ع-ف-ف","root_link":"/words/roots/ع-ف-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29792"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%8E%D9%81%D9%8E%D9%91%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause some milk to remain behind in an udder after milking, to have milk ready or available in an udder"},{"pos":"verb","gloss":"to cause one to be chaste or temperate, to cause one to be moderate or abstemious"}]},"etymology":null,"ipa":["/ʔa.ʕaf.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29792","headword_ar":"اَعْفَى","root":"Efw","body":[{"kind":"text","text":"a word occurring in the saying of 'Omar Ibn-'Abd-El-'Azeez,"},{"kind":"arabic","text_bw":"laEamoriY maA AlbaraA*iynu biA^aEofaY mina","text_ar":"لَعَمْرِى مَا البَرَاذِينُ بِاَعْفَى مِنَ"},{"kind":"arabic","text_bw":"Alfarasi fiymaA kaAna mino maw^uwnapK waHarosK","text_ar":"الفَرَسِ فِيمَا كَانَ مِنْ مَوُونَةٍ وَحَرْسٍ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"By my life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by my religion, the hackneys"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"are not more easy in respect of sustenance"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and guardianship than the horse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mare, of good breed:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"farasN","text_ar":"فَرَسٌ"},{"kind":"text","text":"]. (Mgh.)"}],"source_refs":[]}]}}