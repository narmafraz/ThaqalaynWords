{"lemma":"زَعِل","slug":"زَعِل","root":"ز.ع.ل","root_slug":"ز-ع-ل","root_link":"/words/roots/ز-ع-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n17788","n17790"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%B9%D9%90%D9%84"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to prance, to leap, to spring","tags":["obsolete"]},{"pos":"verb","gloss":"to exult, to become lively, to become brisk, to behave agilely","tags":["obsolete"]},{"pos":"verb","gloss":"to be miffed, to be mad, to be surly, to huff","tags":["informal"]},{"pos":"verb","gloss":"to madden, to make surly","tags":["informal"]},{"pos":"noun","gloss":"verbal noun of زَعِلَ (zaʕila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"lively, brisk","tags":["obsolete"]},{"pos":"adj","gloss":"miffed, mad, surly","tags":["informal"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17788","headword_ar":"زَعِلَ","root":"zEl","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaEalN","text_ar":"زَعَلٌ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"tzE~l","text_ar":"تزعّل","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively, sprightly, active, agile, prompt, and quick;"},{"kind":"text","text":"(S, K, TA;) and"},{"kind":"italic_en","text":"he exulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulted greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully."},{"kind":"text","text":"(TA.) ―         -b2-  And the former, (K,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"curvetted, pranced, leaped, sprang,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounded, without his rider."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"He writhed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried out and writhed, by reason of hunger."},{"kind":"text","text":"(TA.) ―         -b4-  [In the modern language,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weary:"},{"kind":"text","text":"one says,"},{"kind":"arabic","text_bw":"zaEilotu minohu","text_ar":"زَعِلْتُ مِنْهُ"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weary of it."},{"kind":"text","text":"]"}],"source_refs":["S","K","TA"]},{"entry_id":"n17790","headword_ar":"زَعِلٌ","root":"zEl","body":[{"kind":"italic_en","text":"Brisk, lively, sprightly, active, agile, prompt, and quick;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"A_izoEiylN","text_ar":"اـِزْعِيلٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) the former is applied in this sense to a horse; and ↓ the latter, as well as the former, to an ass, [i. e. a wild ass,] as meaning"},{"kind":"italic_en","text":"brisk, lively,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and curvetting, prancing, leaping, springing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounding:"},{"kind":"text","text":"and the former signifies also"},{"kind":"italic_en","text":"exulting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulting greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and behaving insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"zuE~alN","text_ar":"زُعَّلٌ"},{"kind":"text","text":", applied by Tarafeh to male ostriches. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Writhing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying out and writhing, by reason of hunger."},{"kind":"text","text":"(S, K.)"}],"source_refs":["K"]}]}}