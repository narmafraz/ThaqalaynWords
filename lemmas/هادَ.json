ferences":{"qac":{"found":true,"lemma_key":"هاد","root":"هدي","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40975","n41399","n41500","n41501","n44268"],"search_url":"https://lanelexicon.com/?s=%D9%87%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be Jewish","tags":["obsolete"],"examples":[{"text":"قُلْ يَٰأَيُّهَا ٱلَّذِينَ هَادُوا إِنْ زَعَمْتُمْ أَنَّكُمْ أَوْلِيَاءُ لِلَّه مِنْ دُونِ ٱلنَّاسِ فَتَمَنَّوُا ٱلْمَوْتَ إِنْ كُنْتُمْ صَادِقِينَ","english":"Say, \"O you who are Jews, if you claim that you out of all of Man are God's allies then wish for death, if you should be truthful.\""}]},{"pos":"verb","gloss":"to turn; to repent","tags":["obsolete"],"examples":[{"text":"وَٱكْتُبْ لَنَا فِي هَٰذِهِ ٱلدُّنْيَا حَسَنَةً وَفِي ٱلْآخِرَةِ إِنَّا هُدْنَا إِلَيْكَ","english":"And ordain for us good in this world and in the Hereafter, surely we have turned to You."}]},{"pos":"adj","gloss":"active participle of هَدَى (hadā): guiding; guide","tags":["active","form-of","participle"],"examples":[{"text":"وَيَقُولُ ٱلَّذِينَ كَفَرُوا لَوْلَا أُنْزِلَ عَلَيْهِ آيَةٌ مِنْ رَبِّهِ إِنَّمَا أَنْتَ مُنْذِرٌ وَلِكُلِّ قَوْمٍ هَادٍ","english":"And those who disbelieved say, \"Why has a sign not been sent down to him from his Lord?\" You are only a warner, and for every people is a guide."},{"text":"أَلَيْسَ اللَّهُ بِكَافٍ عَبْدَهُ وَيُخَوِّفُونَكَ بِٱلَّذِينَ مِنْ دُونِهِ وَمَنْ يُضْلِلِ اللَّهُ فَمَا لَهُ مِنْ هَادٍ","english":"Is not Allah sufficient for His Servant [Prophet Muhammad]? And [yet], they threaten you with those [they worship] other than Him. And whoever Allah leaves astray - for him there is no guide."}]}]},"etymology":{"source":"wiktextract","text":"Denominal verb of هُود (hūd, “Jews”, collective), as if from the root ه و د (h w d) related to returning, or from reanalysis of the noun يَهُود (yahūd, “Jews, Jewry”, collective) as a third-person masculine singular verb.\n\nDerived from the active participle of هَدَى (hadā, “to guide”)"},"ipa":["/haː.da/","/haː.din/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40975","headword_ar":"هَادٌّ","root":"hd","body":[{"kind":"italic_en","text":"A certain murmuring sound from the sea;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"a sound which is heard by people inhabiting the sea-shore, coming to them from the direction of the sea, murmuring over the land, and sometimes followed by an earthquake."},{"kind":"text","text":"(S, L.)"}],"source_refs":[]},{"entry_id":"n41399","headword_ar":"هَادَ","root":"hwd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yahuwdu","text_ar":"يَهُودُ"},{"kind":"text","text":", (S, L, &c.,) inf. n."},{"kind":"arabic","text_bw":"hawodN","text_ar":"هَوْدٌ"},{"kind":"text","text":", (S, L, K, &c.,)"},{"kind":"italic_en","text":"He returned"},{"kind":"text","text":"(IAar, A, L, Msb)"},{"kind":"italic_en","text":"from evil to good"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from good to evil:"},{"kind":"text","text":"(IAar, L:)"},{"kind":"italic_en","text":"he repented,"},{"kind":"text","text":"(S, A, L, K;)"},{"kind":"italic_en","text":"and returned to the truth;"},{"kind":"text","text":"(S, L, K;) as also ↓"},{"kind":"arabic","text_bw":"thw~d","text_ar":"تهوّد","orth_type":"arrow"},{"kind":"text","text":": (L:) and the latter,"},{"kind":"italic_en","text":"he repented and did righteously."},{"kind":"text","text":"(AO, S, A, L.) ―         -b2-"},{"kind":"arabic","text_bw":"hudonaA A_ilayoka","text_ar":"هُدْنَا اـِلَيْكَ"},{"kind":"italic_en","text":"We have turned unto Thee with repentance."},{"kind":"text","text":"(Kur, vii, 155.] So accord. to Mujáhid and Sa'eed Ibn-Jubeyr and Ibráheem. (L.) It is made trans. by means of"},{"kind":"arabic","text_bw":"AlY","text_ar":"الى"},{"kind":"text","text":"because implying the meaning of"},{"kind":"arabic","text_bw":"rajaEonaA","text_ar":"رَجَعْنَا"},{"kind":"text","text":". (ISd, L.) ―         -b3-"},{"kind":"arabic","text_bw":"haAda","text_ar":"هَادَ"},{"kind":"text","text":", (S, A, L,) aor."},{"kind":"arabic","text_bw":"yahuwdu","text_ar":"يَهُودُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hawodN","text_ar":"هَوْدٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"tahw~d","text_ar":"تَهوّد","orth_type":"arrow"},{"kind":"text","text":"; (S, A, L, Msb, K;)"},{"kind":"italic_en","text":"He became a Jew;"},{"kind":"text","text":"(S, A, L, K;)"},{"kind":"italic_en","text":"he became of the Jewish religion."},{"kind":"text","text":"(L, Msb.)"}],"source_refs":["IAar","A","L","Msb","S"]},{"entry_id":"n41500","headword_ar":"هَادَ","root":"hyd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yahiydu","text_ar":"يَهِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hayodN","text_ar":"هَيْدٌ"},{"kind":"text","text":"; (S, L, K;) and ↓"},{"kind":"arabic","text_bw":"hy~d","text_ar":"هيّد","orth_type":"arrow"},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"tahoyiydN","text_ar":"تَهْيِيدٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in motion,"},{"kind":"text","text":"(S, L, K,) a thing, (S,) or anything: this is the original signification. (L.) ―         -b2-"},{"kind":"arabic","text_bw":"haAdN","text_ar":"هَادٌ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yahiydu","text_ar":"يَهِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hayodN","text_ar":"هَيْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"haAdN","text_ar":"هَادٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"hy~d","text_ar":"هيّد","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"It frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified, and afflicted, distressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oppressed,"},{"kind":"text","text":"a person. (L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"haAda","text_ar":"هَادَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yahiydu","text_ar":"يَهِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hayodN","text_ar":"هَيْدٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"hy~d","text_ar":"هيّد","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He repaired; put into a right"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper state."},{"kind":"text","text":"(L, K.) It is said in a trad., with reference to the Mosque (of Mohammad, L),"},{"kind":"arabic","text_bw":"hidohu","text_ar":"هِدْهُ"},{"kind":"text","text":", (S, L,) meaning"},{"kind":"italic_en","text":"Repair it:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"pull it down, and then repair it:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"pull it down, and recommence the building of it, and repair it, and put it into a right"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper state."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"haAda","text_ar":"هَادَ"},{"kind":"text","text":", (Yaakoob, S, L, K,) aor."},{"kind":"arabic","text_bw":"yahiydu","text_ar":"يَهِيدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hayodN","text_ar":"هَيْدٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"haAdN","text_ar":"هَادٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"hy~d","text_ar":"هيّد","orth_type":"arrow"},{"kind":"text","text":"; (Yaakoob, S, L:)"},{"kind":"italic_en","text":"He chid"},{"kind":"text","text":"a man;"},{"kind":"italic_en","text":"and turned him away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back,"},{"kind":"text","text":"from a thing: (S, * L, K:) or"},{"kind":"arabic","text_bw":"yahiydu","text_ar":"يَهِيدُ"},{"kind":"text","text":"is only used with a negative in this sense. (Yaakoob, K.) ―         -b5-"},{"kind":"arabic","text_bw":"haAda","text_ar":"هَادَ"},{"kind":"italic_en","text":"He removed"},{"kind":"text","text":"a person or thing"},{"kind":"italic_en","text":"from his"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its place."},{"kind":"text","text":"(L, K. *) ―         -b6-"},{"kind":"arabic","text_bw":"haAda","text_ar":"هَادَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it disquieted, disturbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled,"},{"kind":"text","text":"a person. (K.) ―         -b7-"},{"kind":"arabic","text_bw":"maA yahiyduniY ka*aA","text_ar":"مَا يَهِيدُنِى كَذَا"},{"kind":"italic_en","text":"Such a thing does not move me;"},{"kind":"text","text":"(L;)"},{"kind":"italic_en","text":"it does not disquiet, disturb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettle, me; I am not moved by it; do not care for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard it."},{"kind":"text","text":"(S, L.) Accord. to Yaakoob,"},{"kind":"arabic","text_bw":"yhyd","text_ar":"يهيد"},{"kind":"text","text":"is only thus used with a negative. (S, L.) One says,"},{"kind":"arabic","text_bw":"laAa yhiydan~aka h`*aA Eano raA^oyika","text_ar":"لَاَ يهِيدَنَّكَ هٰذَا عَنْ رَاْيِكَ"},{"kind":"italic_en","text":"Let not this move thee at all from thine opinion."},{"kind":"text","text":"(TA.)"}],"source_refs":["L","K","S"]},{"entry_id":"n41501","headword_ar":"هَادٌ","root":"hyd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"hayodN","text_ar":"هَيْدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n44268","headword_ar":"هَادٍ","root":"hdY","body":[{"kind":"text","text":": see an ex. of its pl."},{"kind":"arabic","text_bw":"hawaAdiY","text_ar":"هَوَادِى"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"Necks"},{"kind":"text","text":"of horses, voce"},{"kind":"arabic","text_bw":"taAlK","text_ar":"تَالٍ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"haAdiyapN","text_ar":"هَادِيَةٌ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"fore part of the neck of a horse."},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"slf","text_ar":"سلف"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"A^axa*a haAdiYa Alr~aHaY fajaEala yudiyruhaA","text_ar":"اَخَذَ هَادِىَ الرَّحَى فَجَعَلَ يُدِيرُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He took the handle of the mill, and begun to turn it"},{"kind":"text","text":"]. (K, art."},{"kind":"arabic","text_bw":"xbz","text_ar":"خبز"},{"kind":"text","text":".)"}],"source_refs":[]}]},"classical_definitions":null}