{"lemma":"تَقاعُسٌ","slug":"تَقاعُسٌ","root":"ق.ع.س","root_slug":"ق-ع-س","root_link":"/words/roots/ق-ع-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n35996"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%82%D8%A7%D8%B9%D9%8F%D8%B3%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make one's chest to stick out"},{"pos":"verb","gloss":"to hold back, to draw back"},{"pos":"noun","gloss":"verbal noun of تَقَاعَسَ (taqāʕasa) (form VI); delay","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ta.qaː.ʕa.sa/","/ta.qaː.ʕus/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35996","headword_ar":"تقاعس","root":"qEss","body":[{"kind":"italic_en","text":"He made his"},{"kind":"text","text":"[meaning his own]"},{"kind":"italic_en","text":"breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest, to stick out."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"italic_en","text":"He drew back, and became refractory, and made himself like him who has a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receding, back, and a protruding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant, breast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chest."},{"kind":"text","text":"(Har, p. 17.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"He drew back; held back;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hung back."},{"kind":"text","text":"(S, K.) You say,"},{"kind":"arabic","text_bw":"tqAEs Eani AlA^amori","text_ar":"تقاعس عَنِ الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He drew back, held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hung back, from the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, and would not go forward in it;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"qaEisa","text_ar":"قَعِسَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaEasN","text_ar":"قَعَسٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tqE~s","text_ar":"تقعّس","orth_type":"arrow"},{"kind":"text","text":": (TA:) in some copies of the S, instead of"},{"kind":"arabic","text_bw":"tqAEs","text_ar":"تقاعس"},{"kind":"text","text":", in this phrase, we find ↓"},{"kind":"arabic","text_bw":"taqaEowasa","text_ar":"تَقَعْوَسَ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And [in like manner,] ↓"},{"kind":"arabic","text_bw":"AiqoEanosasa","text_ar":"اِقْعَنْسَسَ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He drew back; he receded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went backwards."},{"kind":"text","text":"(S, K.) When a man draws water without a pulley, pulling the rope at the head of the well, his back pains him, and it is said to him,"},{"kind":"arabic","text_bw":"waA@jo*ibi Ald~alowa","text_ar":"وَا@جْذِبِ الدَّلْوَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AiqoEanosiso","text_ar":"اِقْعَنْسِسْ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Go thou backwards, and pull the bucket"},{"kind":"text","text":"]. This verb is without idghám because it is quasi-coördinate to"},{"kind":"arabic","text_bw":"AiHoranojama","text_ar":"اِحْرَنْجَمَ"},{"kind":"text","text":". (S.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse, S, K)"},{"kind":"italic_en","text":"drew back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back, and would not go forward:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"would not submit to his leader;"},{"kind":"text","text":"(K;) [as also ↓"},{"kind":"arabic","text_bw":"AqEnss","text_ar":"اقعنسس","orth_type":"arrow"},{"kind":"text","text":"; as appears from an explanation of its part. n., below.] You say also,"},{"kind":"arabic","text_bw":"Ald~aAb~apu","text_ar":"الدَّابَّةُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tqE~st","text_ar":"تقعّست","orth_type":"arrow"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"The beast of carriage stood still, and would not move from its place."},{"kind":"text","text":"(TA.) ―         -b5-  (assumed tropical:)  ["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man) and]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(might or strength)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, and resisted;"},{"kind":"text","text":"[as also ↓"},{"kind":"arabic","text_bw":"AqEnss","text_ar":"اقعنسس","orth_type":"arrow"},{"kind":"text","text":"; as appears from an explanation of its part. n., below:] and ↓"},{"kind":"arabic","text_bw":"AqEnss","text_ar":"اقعنسس","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm, and did not bow his head:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaEisa","text_ar":"قَعِسَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qaEasN","text_ar":"قَعَسٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, inaccessible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unapproachable, and mighty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong, and firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady."},{"kind":"text","text":"(TA.) ―         -b6-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the night)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protracted; as though it did not quit its place;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"baraka","text_ar":"بَرَكَ"},{"kind":"text","text":". (A, TA.) See"},{"kind":"arabic","text_bw":"A^aqoEasu","text_ar":"اَقْعَسُ"},{"kind":"text","text":"."}],"source_refs":["TA","S"]}]},"classical_definitions":null}