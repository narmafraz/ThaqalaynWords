ar":"دُوِىٌّ"},{"kind":"text","text":", (T, S, M, K,) which is pl. of"},{"kind":"arabic","text_bw":"dawFY","text_ar":"دَوًى"},{"kind":"text","text":", (S, TA,) as also"},{"kind":"arabic","text_bw":"diwiY~N","text_ar":"دِوِىٌّ"},{"kind":"text","text":", (M, K,) and"},{"kind":"arabic","text_bw":"dawayaAtN","text_ar":"دَوَيَاتٌ"},{"kind":"text","text":", (S, Msb,) which is applied to a number from three to ten [inclusive]. (S.)       -A2-  Also The"},{"kind":"italic_en","text":"rind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skin, of the colocynth,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the grape,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the melon;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"*awaApN","text_ar":"ذَوَاةٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","M","Msb","K","T","TA"]}]},"classical_definitions":null}