{"lemma":"فَجَرَ","slug":"فَجَرَ","root":"ف.ج.ر","root_slug":"ف-ج-ر","root_link":"/words/roots/ف-ج-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فَجَرْتَ","in_corpus":true,"count":14,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فَجَرْتِ","in_corpus":true,"count":14,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فَجَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فَجَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فَجَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فَجَرَ","in_corpus":true,"count":16,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فَجَرَت","in_corpus":true,"count":14,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فَجَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فَجَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فَجَرُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فَجَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفْجُر","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفْجُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفْجُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفْجُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفْجُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفْجُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفْجُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْجُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْجُر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْجُر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْجُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْجُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْجُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْجُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْجُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْجُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْجُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فَجَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَجَرْتُ","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْجُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْجُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":78,"cross_references":{"qac":{"found":true,"lemma_key":"فَجَرَ","root":"فجر","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["name","noun","verb"],"has_etymology":true,"sense_count":12},"lanes":{"found":true,"entry_ids":["n33042"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AC%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"sinning, committing adultery"},{"pos":"verb","gloss":"to act immorally, to be wicked, to sin","examples":[{"text":"بَلْ يُرِيدُ الْإِنْسَانُ لِيَفْجُرَ أَمَامَهُ","english":"but man desires to act sinfully in what is before him"}]},{"pos":"verb","gloss":"to cleave, to break up, to dig up"},{"pos":"verb","gloss":"to create an outlet or passage (for water)"},{"pos":"verb","gloss":"to let pour forth","examples":[{"text":"إِذَا السَّمَاء ٱنْفَطَرَتْ ۝ وَإِذَا ٱلْكَوَاكِبُ ٱنْتَثَرَتْ ۝ وَإِذَا ٱلْبِحَارُ فُجِّرَتْ ۝ وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ ۝ عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ ۝","english":"When the sky breaks apart / And when the stars commence to scatter / And when the seas gush forth / And when the graves are strewn / A soul will know what it has put forward and what it has set back."}]},{"pos":"verb","gloss":"to cleave, to split"},{"pos":"verb","gloss":"to explode"},{"pos":"noun","gloss":"verbal noun of فَجَرَ (fajara, “to break up, to sin”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"dawn, daybreak; dayspring","examples":[{"text":"فِي الْفَجْرِ الْبَاكِرِ، كَانَتِ الشُّوَارِعُ هَادِئَةً وَخَالِيَةً مِنَ الزُّحَامِ.","english":"In the early dawn, the streets were quiet and free from traffic."},{"text":"سَلَامٌ هِيَ حَتَّى مَطْلَعِ الْفَجْرِ","english":"Abdulala Maududi: All peace is that night until the rise of dawn."}]},{"pos":"noun","gloss":"dawn, beginning, outset, start","tags":["figuratively"]},{"pos":"noun","gloss":"اَلْفَجْر (al-fajr): ellipsis of صَلَاة الْفَجْر (ṣalāt al-fajr, “dawn prayer”)","tags":["definite"],"examples":[{"text":"صَلَّيْنَا الْفَجْرَ جَمَاعَةً","english":"we pray the dawn prayer in congregration"}]},{"pos":"name","gloss":"a female given name"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *pagr- (“body, trunk”). Cognate with Akkadian 𒇿 (pagrum, “body, trunk, torso, corpse, carcass”), Hebrew פֶּגֶר (péger, “corpse, carcass”), Classical Syriac ܦܲܓܪܵܐ (paḡrā), and Classical Mandaic ࡐࡀࡂࡓࡀ (pāġrā)."},"ipa":["/fad͡ʒr/","/fa.d͡ʒa.ra/","/fad͡ʒ.d͡ʒa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33042","headword_ar":"فَجَرَ","root":"fjr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (T, L, Msb,) inf. n."},{"kind":"arabic","text_bw":"fajorN","text_ar":"فَجْرٌ"},{"kind":"text","text":", (T, Mgh, L, Msb,)"},{"kind":"italic_en","text":"He clave,"},{"kind":"text","text":"[a thing];"},{"kind":"italic_en","text":"cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided,"},{"kind":"text","text":"[it]"},{"kind":"italic_en","text":"lengthwise:"},{"kind":"text","text":"this is the primary signification, whence several others, to be mentioned below, are derived: (T, L:)"},{"kind":"italic_en","text":"he clave, and opened."},{"kind":"text","text":"(Mgh.)"},{"kind":"italic_en","text":"He clave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut,"},{"kind":"text","text":"a subterranean channel for water. (Msb.)"},{"kind":"italic_en","text":"He broke open"},{"kind":"text","text":"a dam of a river or the like,"},{"kind":"italic_en","text":"that the water might break, burst,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pour, through."},{"kind":"text","text":"(T, L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"fajara AlmaA='a","text_ar":"فَجَرَ المَا=ءَ"},{"kind":"text","text":", (S, Mgh, O, Msb, K,) aor. and inf. n. as above; (S, O;) and ↓"},{"kind":"arabic","text_bw":"fj~rhu","text_ar":"فجّرهُ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"tafojiyrN","text_ar":"تَفْجِيرٌ"},{"kind":"text","text":"; (O, TA;) but the latter is with teshdeed to denote muchness, or frequency, or repetition, of the action, or its application to many objects; (S, O, TA;)"},{"kind":"italic_en","text":"He opened a way, passage, vent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel, for the water to flow forth; gave vent to it; vented it:"},{"kind":"text","text":"(S, Mgh, O, Msb:)"},{"kind":"italic_en","text":"he made the water to flow, run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stream:"},{"kind":"text","text":"(K:) and in like manner, blood, or other fluid. (TA.) [See also 4.]       -A2-"},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fujuwrN","text_ar":"فُجُورٌ"},{"kind":"text","text":", (S, O, Msb, K, &c.,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined; leant; declined;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviated."},{"kind":"text","text":"(S, O, TA.) You say,"},{"kind":"arabic","text_bw":"fajara Alr~aAkibu","text_ar":"فَجَرَ الرَّاكِبُ"},{"kind":"text","text":", (K,) aor. as above, (TA,) and so the inf. n., (K,) (tropical:)"},{"kind":"italic_en","text":"The rider leant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declined, from his saddle."},{"kind":"text","text":"(K.) ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"He declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviated, from the truth;"},{"kind":"text","text":"(K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"Afjr","text_ar":"افجر","orth_type":"arrow"},{"kind":"text","text":". (IAar, O, K.) ―         -b3-  And"},{"kind":"italic_en","text":"He erred in answering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"replying."},{"kind":"text","text":"(El-Muärrij.) ―         -b4-  Hence also, (S,)"},{"kind":"italic_en","text":"He lied;"},{"kind":"text","text":"(S, O, Msb, K;) said of a swearer; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"Afjr","text_ar":"افجر","orth_type":"arrow"},{"kind":"text","text":": (IAar, O, K:) in this sense the former has also"},{"kind":"arabic","text_bw":"fajorN","text_ar":"فَجْرٌ"},{"kind":"text","text":"for an inf. n., as well as"},{"kind":"arabic","text_bw":"fujuwrN","text_ar":"فُجُورٌ"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"he committed a foul deed; such as swearing a false oath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lying:"},{"kind":"text","text":"in which sense also it has both of these inf. ns. (TA.) ―         -b5-"},{"kind":"italic_en","text":"He committed an unlawful action:"},{"kind":"text","text":"(ISh:) [or, as it is generally explained, and most frequently used,]"},{"kind":"italic_en","text":"he acted vitiously, immorally, unrighteously, sinfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wickedly; he transgressed; went forth from, departed from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted, the way of truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the right way; forsook, relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglected, the command of God; departed from obedience; disobeyed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"fasaqa","text_ar":"فَسَقَ"},{"kind":"text","text":"; (S, Mgh, O, Msb, K;) and"},{"kind":"arabic","text_bw":"EaSaY","text_ar":"عَصَى"},{"kind":"text","text":"(Mgh, K) and"},{"kind":"arabic","text_bw":"xaAlafa","text_ar":"خَالَفَ"},{"kind":"text","text":": (K:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"fAjr","text_ar":"فاجر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mufaAjarapN","text_ar":"مُفَاجَرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fijaArN","text_ar":"فِجَارٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he did that which was vitious, immoral, unrighteous, sinful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wicked."},{"kind":"text","text":"(R, TA.) In the sense of"},{"kind":"arabic","text_bw":"ESY","text_ar":"عصى"},{"kind":"text","text":"(Mgh, O, TA) and"},{"kind":"arabic","text_bw":"xAlf","text_ar":"خالف"},{"kind":"text","text":"(O, TA) it is also trans.: you say"},{"kind":"arabic","text_bw":"fajarahu","text_ar":"فَجَرَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He disobeyed him;"},{"kind":"text","text":"(Mgh, O, TA;)"},{"kind":"italic_en","text":"he opposed him."},{"kind":"text","text":"(O, TA.) ―         -b6-"},{"kind":"italic_en","text":"He launched forth into acts of disobedience;"},{"kind":"text","text":"in which sense it has both of the inf. ns. mentioned above; (K, TA;) and is [said to be] from"},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"text","text":"in the first of the significations expl. above. (TA.) ―         -b7-"},{"kind":"italic_en","text":"He disbelieved;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kafara","text_ar":"كَفَرَ"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"Afjr","text_ar":"افجر","orth_type":"arrow"},{"kind":"text","text":": (IAar, O, K:) and"},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"italic_en","text":"he disbelieved in it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ka*~ab","text_ar":"كَذَّب"},{"kind":"text","text":". (O, K. *) The following passage of the Kur,"},{"kind":"arabic","text_bw":"balo yuriydu","text_ar":"بَلْ يُرِيدُ"},{"kind":"arabic","text_bw":"A@loA_inosaAnu liyafojura A^amaAmahu","text_ar":"ا@لْاـِنْسَانُ لِيَفْجُرَ اَمَامَهُ"},{"kind":"text","text":", [lxxv. 5], is said to mean, ["},{"kind":"italic_en","text":"But man desireth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nay, doth man desire,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to disbelieve in that which is before him,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"that which is to come,"},{"kind":"text","text":"] namely, the resurrection and reckoning and retribution: (O, TA:) or"},{"kind":"italic_en","text":"to continue in his"},{"kind":"arabic","text_bw":"fujuwr","text_ar":"فُجُور"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"vice, immorality, wickedness, unrighteousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the time to come:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"to go on therein undeviatingly:"},{"kind":"text","text":"(El-Hasan El-Basree, O:) or"},{"kind":"italic_en","text":"to defer repentance, and to do evil deeds first:"},{"kind":"text","text":"(O, TA:) or"},{"kind":"italic_en","text":"to multiply sins, and to postpone repentance:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to say I will repent at a future time."},{"kind":"text","text":"(TA.) ―         -b8-"},{"kind":"italic_en","text":"He did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committed, an action inducing doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubt combined with suspicion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil opinion."},{"kind":"text","text":"(IKtt, TA.) ―         -b9-"},{"kind":"italic_en","text":"He committed adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication;"},{"kind":"text","text":"(Msb, K;) in which sense it has both of the inf. ns. mentioned above; (K;) and ↓"},{"kind":"arabic","text_bw":"Afjr","text_ar":"افجر","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (IAar, K;) and, this latter,"},{"kind":"italic_en","text":"he committed an act,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acts, of disobedience with his genital member."},{"kind":"text","text":"(IAar, TA.) You say"},{"kind":"arabic","text_bw":"fajara biA@lomaroA^api","text_ar":"فَجَرَ بِا@لْمَرْاَةِ"},{"kind":"italic_en","text":"He committed adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication, with the woman:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fajarati A@lomaroA^apu","text_ar":"فَجَرَتِ ا@لْمَرْاَةُ"},{"kind":"italic_en","text":"The woman committed adultery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"italic_en","text":"He pursued a headlong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rash,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"random, course, and went away, not caring whither."},{"kind":"text","text":"(El-Muärrij.) ―         -b11-"},{"kind":"arabic","text_bw":"fajara A^amoruhumo","text_ar":"فَجَرَ اَمْرُهُمْ"},{"kind":"page_break","n":2341},{"kind":"italic_en","text":"Their case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state of affairs, became bad."},{"kind":"text","text":"(K.) ―         -b12-  And"},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"He became dim,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull, in his sight."},{"kind":"text","text":"(O, K.) ―         -b13-  And"},{"kind":"arabic","text_bw":"fajara mino maraDihi","text_ar":"فَجَرَ مِنْ مَرَضِهِ"},{"kind":"italic_en","text":"He became free from his disease."},{"kind":"text","text":"(O, K.)"}],"source_refs":["T","L","Msb","Mgh","S","O","K","TA","IAar","ISh","Bd"]}]}}