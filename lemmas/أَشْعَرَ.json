","gen":"f","num":"s"},{"role":"present_2md","form":"تُشْعِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشْعِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشْعَرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُشْعَرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُشْعِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشْعِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشْعَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُشْعَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشْعِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُشْعَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشْعِر","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُشْعَر","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشْعِر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُشْعَر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشْعِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشْعِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشْعَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشْعَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشْعِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْعِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْعَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْعَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشْعِرُونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْعِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْعَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْعَرُونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشْعِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُشْعَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُشْعِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْعِر","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْعَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْعَر","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَشْعَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَشْعَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n22493"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D8%B9%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22493","headword_ar":"اَشْعَرُ","root":"$Er","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, knowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cognizant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding:"},{"kind":"text","text":"see 1, first sentence. ―         -b2-  And,] applied to a verse, (T,) or to a poem, (S,)"},{"kind":"italic_en","text":"More"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"poetical."},{"kind":"text","text":"(T, S. *)       -A2-  Also, (S, A, K,) and ↓"},{"kind":"arabic","text_bw":"$aEirN","text_ar":"شَعِرٌ","orth_type":"arrow"},{"kind":"text","text":", (A, K,) and ↓"},{"kind":"arabic","text_bw":"$aEoraAniY~N","text_ar":"شَعْرَانِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (K,) which last (SM says) I have seen written"},{"kind":"arabic","text_bw":"$aEaraAniY~N","text_ar":"شَعَرَانِىٌّ"},{"kind":"text","text":", (TA,) A man"},{"kind":"italic_en","text":"having much hair upon his body:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"having hair upon the whole of the body:"},{"kind":"text","text":"(IAth, L voce"},{"kind":"arabic","text_bw":"A^ajoradu","text_ar":"اَجْرَدُ"},{"kind":"text","text":"[q. v.], in explanation of the first:) or"},{"kind":"italic_en","text":"having much and long hair"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"upon the head and body:"},{"kind":"text","text":"(TA:) and the first and second, a goat"},{"kind":"italic_en","text":"having much hair:"},{"kind":"text","text":"fem. of the first"},{"kind":"arabic","text_bw":"$aEoraA='u","text_ar":"شَعْرَا=ءُ"},{"kind":"text","text":": (TA:) and pl. of the first"},{"kind":"arabic","text_bw":"$aEorN","text_ar":"شَعْرٌ"},{"kind":"text","text":". (S, K.) One says"},{"kind":"arabic","text_bw":"A^$oEavu A^a$oEaru","text_ar":"اشْعَثُ اَشْعَرُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Having his head unshaven and not combed nor anointed."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"fulaAnN A^a$oEaru Alr~aqabapi","text_ar":"فُلَانٌ اَشْعَرُ الرَّقَبَةِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Such a one is hairy in the neck"},{"kind":"text","text":"] is said of a man though he have not hair upon his neck, as meaning (tropical:)"},{"kind":"italic_en","text":"such a one is strong, like a lion."},{"kind":"text","text":"(A, * TA.) ―         -b2-  [The fem.]"},{"kind":"arabic","text_bw":"$aEoraA='u","text_ar":"شَعْرَا=ءُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A testicle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scrotum,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xuSoyapN","text_ar":"خُصْيَةٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"having much hair:"},{"kind":"text","text":"(TA:) and the"},{"kind":"arabic","text_bw":"sawo'ap","text_ar":"سَوْءَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pudendum"},{"kind":"text","text":"]: thus used as a subst. (IAar, TA in art."},{"kind":"arabic","text_bw":"mET","text_ar":"معط"},{"kind":"text","text":".) See also"},{"kind":"arabic","text_bw":"$iEorapN","text_ar":"شِعْرَةٌ"},{"kind":"text","text":". ―         -b3-  And"},{"kind":"italic_en","text":"A furred garment."},{"kind":"text","text":"(Th, K.) ―         -b4-  And as an epithet, (tropical:)"},{"kind":"italic_en","text":"Evil, foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable:"},{"kind":"text","text":"[as being likened to that which is shaggy, and therefore unseemly:] (K, * TA:) in the K,"},{"kind":"arabic","text_bw":"Alxa$inapu","text_ar":"الخَشِنَةُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Alxabiyvapu","text_ar":"الخَبِيثَةُ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"daAhiyapN $aEoraA='u","text_ar":"دَاهِيَةٌ شَعْرَا=ءُ"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"waboraA='u","text_ar":"وَبْرَا=ءُ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"zab~aA='u","text_ar":"زَبَّا=ءُ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"zb","text_ar":"زب"},{"kind":"text","text":",) (tropical:)"},{"kind":"italic_en","text":"An evil, a foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abominable,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"a severe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"great,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"calamity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misfortune:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"$uEorN","text_ar":"شُعْرٌ"},{"kind":"text","text":". (K, TA.) And one says to a man when he has said a thing that one blames or with which one finds fault,"},{"kind":"arabic","text_bw":"jiy^ota","text_ar":"جِيْتَ"},{"kind":"arabic","text_bw":"bihaA $aEoraA='a *aAta wabarK","text_ar":"بِهَا شَعْرَا=ءَ ذَاتَ وَبَرٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Thou hast said it as a foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abominable, thing"},{"kind":"text","text":"]. (S, A. *) ―         -b5-  And"},{"kind":"arabic","text_bw":"A^a$oEaru","text_ar":"اَشْعَرُ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"hair that surrounds the solid hoof:"},{"kind":"text","text":"(S:) or [the"},{"kind":"italic_en","text":"extremity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"border, of the pastern, next the solid hoof;"},{"kind":"text","text":"i. e.] the"},{"kind":"italic_en","text":"extremity of the skin surrounding the solid hoof,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"where the small hairs grow around it:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"part between the hoof"},{"kind":"text","text":"of a horse"},{"kind":"italic_en","text":"and the place where the hair of the pastern terminates:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of a camel's foot"},{"kind":"italic_en","text":"where the hair terminates:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^a$aAEiru","text_ar":"اَشَاعِرُ"},{"kind":"text","text":", (S, TA,) because it is [in this sense] a subst. (TA.) ―         -b6-  Also The"},{"kind":"italic_en","text":"side of the vulva,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"external portion of the female organs of generation:"},{"kind":"text","text":"(K:) it is said that the"},{"kind":"arabic","text_bw":"A^a$oEaraAni","text_ar":"اَشْعَرَانِ"},{"kind":"text","text":"are the"},{"kind":"arabic","text_bw":"A_isokataAni","text_ar":"اـِسْكَتَانِ"},{"kind":"text","text":", which are the"},{"kind":"italic_en","text":"two sides"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"labia majora"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the vulva of a woman:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"two parts next to the"},{"kind":"arabic","text_bw":"$uforaAni","text_ar":"شُفْرَانِ"},{"kind":"text","text":", which are the"},{"kind":"italic_en","text":"two borders of the"},{"kind":"arabic","text_bw":"A_isokataAni","text_ar":"اـِسْكَتَانِ"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"two parts between the"},{"kind":"arabic","text_bw":"A_isokataAni","text_ar":"اـِسْكَتَانِ"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"$uforaAni","text_ar":"شُفْرَانِ"},{"kind":"text","text":": (L, TA:) or the"},{"kind":"italic_en","text":"two parts next to the"},{"kind":"arabic","text_bw":"$uforaAni","text_ar":"شُفْرَانِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"in the hair, particularly:"},{"kind":"text","text":"(Zj, in his “ Khalk el-Insán: ”) the"},{"kind":"arabic","text_bw":"A^a$aAEir","text_ar":"اَشَاعِر"},{"kind":"text","text":"of the"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"[or vulva of a camel &c.] are the"},{"kind":"italic_en","text":"parts where the hair terminates:"},{"kind":"text","text":"(TA:) and the"},{"kind":"arabic","text_bw":"A^a$aAEir","text_ar":"اَشَاعِر"},{"kind":"text","text":"of a she-camel are the"},{"kind":"italic_en","text":"sides of the vulva."},{"kind":"text","text":"(S, L, TA.) ―         -b7-  And"},{"kind":"italic_en","text":"A thing that comes forth from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"between"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the two halves of the hoof of a sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat, resembling a"},{"kind":"arabic","text_bw":"vuw^oluwl","text_ar":"ثُوْلُول"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wart"},{"kind":"text","text":"]; (Lh, K;) for which it is cauterized. (Lh, TA.) ―         -b8-  And"},{"kind":"italic_en","text":"Flesh coming forth beneath the nail:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"$uEurN","text_ar":"شُعُرٌ"},{"kind":"text","text":", (K, TA,) with two dammehs, (TA,) or"},{"kind":"arabic","text_bw":"$uEorN","text_ar":"شُعْرٌ"},{"kind":"text","text":". (So in the CK.) ―         -b9-  And [the fem.]"},{"kind":"arabic","text_bw":"$aEoraA='u","text_ar":"شَعْرَا=ءُ"},{"kind":"text","text":"also signifies (tropical:)  Land ("},{"kind":"arabic","text_bw":"A^aroD","text_ar":"اَرْض"},{"kind":"text","text":")"},{"kind":"italic_en","text":"containing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having, trees:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abounding in trees:"},{"kind":"text","text":"(A, K:) [and so, app., ↓"},{"kind":"arabic","text_bw":"$aEoraAnu","text_ar":"شَعْرَانُ","orth_type":"arrow"},{"kind":"text","text":"; for] there is a mountain in [the province of] El-Mowsil called"},{"kind":"arabic","text_bw":"$aEoraAnu","text_ar":"شَعْرَانُ"},{"kind":"text","text":", said by AA to be thus called because of the abundance of its trees: (S:) or"},{"kind":"arabic","text_bw":"$aEoraA='u","text_ar":"شَعْرَا=ءُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"many trees:"},{"kind":"text","text":"(A 'Obeyd, S:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^ajamapN","text_ar":"اَجَمَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a thicket, wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forest;"},{"kind":"text","text":"&c.]: (TA:) and a meadow ("},{"kind":"arabic","text_bw":"rawoDapN","text_ar":"رَوْضَةٌ"},{"kind":"text","text":", AHn, A, K, TA)"},{"kind":"italic_en","text":"having its upper part covered with trees,"},{"kind":"text","text":"(AHn, K * TA,) or"},{"kind":"italic_en","text":"abounding in trees,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"abounding in herbage:"},{"kind":"text","text":"(A:) and a tract of sand ("},{"kind":"arabic","text_bw":"ramolapN","text_ar":"رَمْلَةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"producing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the plant called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"naSiY~","text_ar":"نَصِىّ"},{"kind":"text","text":"(Sgh, L, K)"},{"kind":"italic_en","text":"and the like."},{"kind":"text","text":"(Sgh, K.) ―         -b10-  And (assumed tropical:)"},{"kind":"italic_en","text":"A certain tree of the kind called"},{"kind":"arabic","text_bw":"HamoD","text_ar":"حَمْض"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"not having leaves, but having"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hadab","text_ar":"هَدَب"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"very eagerly desired by the camels, and that puts forth strong twigs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"branches;"},{"kind":"text","text":"mentioned in the L on the authority of AHn, and by Sgh on the authority of Aboo-Ziyád; and the latter adds that"},{"kind":"italic_en","text":"it has firewood."},{"kind":"text","text":"(TA.) ―         -b11-  And (assumed tropical:)"},{"kind":"italic_en","text":"A certain fruit:"},{"kind":"text","text":"(AHn, TA:)"},{"kind":"italic_en","text":"a species of peach:"},{"kind":"text","text":"(S, K:) sing. and pl. the same: (AHn, S, K:) or"},{"kind":"italic_en","text":"a single peach:"},{"kind":"text","text":"(IKtt, MF:) or"},{"kind":"arabic","text_bw":"AlA^a$oEaru","text_ar":"الاَشْعَرُ"},{"kind":"text","text":"is a name of"},{"kind":"italic_en","text":"the peach,"},{"kind":"text","text":"and the pl. is"},{"kind":"arabic","text_bw":"$uEorN","text_ar":"شُعْرٌ"},{"kind":"text","text":". (Mtr, TA.) ―         -b12-  Also (assumed tropical:)"},{"kind":"italic_en","text":"A kind of fly,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"said to be that which has a sting,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"blue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"red, that alights upon camels and asses and dogs;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"$uEayoraA='u","text_ar":"شُعَيْرَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"a kind of fly that stings the ass, so that he goes round:"},{"kind":"text","text":"AHn says that"},{"kind":"italic_en","text":"it is of two species, that of the dog"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"that of the camel: that of the dog is well known, inclines to slenderness and redness, and touches nothing but the dog: that of the camel inclines to yellowness, is larger than that of the dog, has wings, and is downy under the wings: sometimes it is in such numbers that the owners of the camels cannot milk in the day-time nor ride any of them; so that they leave doing this until night: it stings the camel in the soft parts of the udder and around them, and beneath the tail and the belly and the armpits; and they do not protect the animal from it save by tar: it flies over the camels so that one hears it to make a humming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buzzing, sound."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"$uEoruwrN","text_ar":"شُعْرُورٌ"},{"kind":"text","text":", under which its pl."},{"kind":"arabic","text_bw":"$uEorN","text_ar":"شُعْرٌ"},{"kind":"text","text":"is mentioned.]) ―         -b13-  And [hence, perhaps, as this kind of fly is seen in swarms,] (assumed tropical:)"},{"kind":"italic_en","text":"A multitude of men."},{"kind":"text","text":"(K.)"}],"source_refs":["T","S","A","K","TA","L","Sgh","AHn","IKtt","MF"]}]}}