/lanelexicon.com/?s=%D9%85%D9%8E%D8%B1%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"alternative form of مَرَقَة (maraqa, “broth”)","tags":["alt-of","alternative"]},{"pos":"verb","gloss":"to fill with rich gravy"},{"pos":"verb","gloss":"to fill with rich gravy"},{"pos":"verb","gloss":"to pluck or scrape off the macerated wool from (the hide)"},{"pos":"verb","gloss":"to pierce fast"},{"pos":"verb","gloss":"to pierce, to transfix"},{"pos":"verb","gloss":"to pass by, to stray off","examples":[{"text":"يَمْرُقُونَ مِنَ الدِّينِ كَمَا يَمْرُقُ السَّهْمُ مِنَ الرَّمِيَّةِ","english":"They stray off faith like an arrow missing the game."}]},{"pos":"verb","gloss":"to lose one’s fruits on one side by reason of disbalanced weight (of a date palm)"},{"pos":"verb","gloss":"to go bad, to rot (as of an egg)"},{"pos":"verb","gloss":"to bawl, to sing badly"},{"pos":"verb","gloss":"to allow to pierce"},{"pos":"noun","gloss":"vulgar song"},{"pos":"noun","gloss":"a kind of disease of a cereal plant where the grains fall off prematurely"},{"pos":"noun","gloss":"fetid wool","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"See there."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43555","headword_ar":"مَرَقٌ","root":"mrq","body":[{"kind":"text","text":"in grapes: see"},{"kind":"arabic","text_bw":"suk~arN","text_ar":"سُكَّرٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"maraqN","text_ar":"مَرَقٌ"},{"kind":"italic_en","text":"Broth; gravy-soup;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"any decoction."}],"source_refs":[]},{"entry_id":"n16289","headword_ar":"مَرَقٌّ","root":"rq","body":[{"kind":"text","text":"sing. of"},{"kind":"arabic","text_bw":"maraAq~u","text_ar":"مَرَاقُّ"},{"kind":"text","text":", (Hr, K,) which signifies The"},{"kind":"italic_en","text":"thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate, and soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender, parts"},{"kind":"text","text":"of the belly: (S, K:) or the"},{"kind":"italic_en","text":"lower part"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"with what surrounds it, that is thin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the skin"},{"kind":"text","text":"]: (TA as from the S [but not in my copies of the latter]:) or the"},{"kind":"italic_en","text":"lower part"},{"kind":"text","text":"of the belly,"},{"kind":"italic_en","text":"in the region of the"},{"kind":"arabic","text_bw":"SifaAq","text_ar":"صِفَاق"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"beneath the navel:"},{"kind":"text","text":"(T, TA:) and metonymically applied in a trad. respecting ablution to the"},{"kind":"italic_en","text":"lower part of the belly"},{"kind":"text","text":"of a man,"},{"kind":"italic_en","text":"together with the"},{"kind":"arabic","text_bw":"rufogaAni","text_ar":"رُفْغَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groins"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the genitals and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"places of which the skin is thin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate:"},{"kind":"text","text":"and, of a camel, the"},{"kind":"arabic","text_bw":"A^arofaAg","text_ar":"اَرْفَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groins,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"similar places of flexure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"creasing"},{"kind":"text","text":"]: (TA:) or (K)"},{"kind":"arabic","text_bw":"maraAq~u","text_ar":"مَرَاقُّ"},{"kind":"text","text":"[thus applied] has no sing. (S, K.) Also The"},{"kind":"italic_en","text":"soft part"},{"kind":"text","text":"of the nose, (JK, TA,)"},{"kind":"italic_en","text":"in the side"},{"kind":"text","text":"thereof; [i. e."},{"kind":"italic_en","text":"each of the alæ"},{"kind":"text","text":"thereof;] as also ↓"},{"kind":"arabic","text_bw":"musotaraq~N","text_ar":"مُسْتَرَقٌّ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl. as above. (JK.)"}],"source_refs":["Hr","K","S","T","TA","JK"]},{"entry_id":"n16290","headword_ar":"مُرَقٌّ","root":"rq","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maroquwqN","text_ar":"مَرْقُوقٌ","orth_type":"arrow"},{"kind":"text","text":", mentioned by ISk, (Msb, TA,) and by Az, and in the 'Ináyeh, therefore the disallowing of the latter by some is not to be regarded, (TA,) or the latter is for"},{"kind":"arabic","text_bw":"maroquwqN lahu","text_ar":"مَرْقُوقٌ لَهُ"},{"kind":"text","text":"meaning “ compassionated, ” (Mgh,)"},{"kind":"italic_en","text":"Made a slave:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"possessed as a slave:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"kept as a slave:"},{"kind":"text","text":"(see 1, last sentence:)] fem. of the former with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", (Msb, TA,) and so of the latter. (Msb.) [See also"},{"kind":"arabic","text_bw":"raqiyqN","text_ar":"رَقِيقٌ"},{"kind":"text","text":", last signification.]"}],"source_refs":["Msb","TA","Mgh"]},{"entry_id":"n16291","headword_ar":"مُرِقٌّ","root":"rq","body":[{"kind":"text","text":"A horse"},{"kind":"italic_en","text":"thin in the hoof:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"light therein."},{"kind":"text","text":"(AO, TA.)"}],"source_refs":["K"]}]},"classical_definitions":null}