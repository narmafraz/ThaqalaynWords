{"lemma":"تَنازُلٌ","slug":"تَنازُلٌ","root":"ن.ز.ل","root_slug":"ن-ز-ل","root_link":"/words/roots/ن-ز-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n43924"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%86%D8%A7%D8%B2%D9%8F%D9%84%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to give up, renounce, resign, waive, forgo, yield, surrender, abandon, relinquish [+عَنْ (object)] in favour of"},{"pos":"verb","gloss":"to cede [+عَنْ (object)] to"},{"pos":"verb","gloss":"to refrain from"},{"pos":"verb","gloss":"to leave, assign, transfer, make over [+عَنْ (object)] to"},{"pos":"verb","gloss":"to lower oneself, condescend, stoop, deign, dismount"},{"pos":"verb","gloss":"to lay down, resign, abdicate [+عَنْ (object)] in favour of"},{"pos":"verb","gloss":"to show oneself obliging, conciliatory, yielding, condescending"},{"pos":"verb","gloss":"to alight, to fight each other"}]},"etymology":null,"ipa":["/ta.naː.za.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43924","headword_ar":"تَنَازَلَ","root":"nzl","body":[{"kind":"italic_en","text":"He descended gradually, by little and little."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"tnAzl A_ilaY A^aHadK","text_ar":"تنازل اـِلَى اَحَدٍ"},{"kind":"italic_en","text":"He humbled himself, condescended, to one."},{"kind":"text","text":"―         -b3-"},{"kind":"arabic","text_bw":"tnAzl Eani Almuloki","text_ar":"تنازل عَنِ المُلْكِ"},{"kind":"italic_en","text":"He abdicated the kingdom."},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"tnAzl Ean $aYo'K","text_ar":"تنازل عَن شَىْءٍ"},{"kind":"italic_en","text":"He desisted from a thing."},{"kind":"text","text":"―         -b5-"},{"kind":"arabic","text_bw":"tanaAzaluwA","text_ar":"تَنَازَلُوا"},{"kind":"italic_en","text":"They alighted and ate by turns with different people; i. q."},{"kind":"arabic","text_bw":"tanaAwabuwA","text_ar":"تَنَاوَبُوا"},{"kind":"text","text":", q. v."}],"source_refs":[]}]},"classical_definitions":null}