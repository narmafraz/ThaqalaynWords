lse,"sense_count":7},"lanes":{"found":true,"entry_ids":["n41754"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%88%D9%92%D8%AD%D9%8E%D8%B4%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be deserted, to be desolate"},{"pos":"verb","gloss":"to feel lonely"},{"pos":"verb","gloss":"to miss badly, to long for"},{"pos":"verb","gloss":"to have an aversion to, to be disgusted by"},{"pos":"verb","gloss":"to feel no warmth or liking"},{"pos":"verb","gloss":"to be alienated"},{"pos":"verb","gloss":"to be afraid"}]},"etymology":null,"ipa":["/is.taw.ħa.ʃa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41754","headword_ar":"استوحش","root":"wH$","body":[{"kind":"text","text":": see 5. ―         -b2-  It is also quasi-pass. of"},{"kind":"arabic","text_bw":"A^awoHa$a Alr~ajula","text_ar":"اَوْحَشَ الرَّجُلَ"},{"kind":"text","text":", (S, TA,) and [thus] signifies"},{"kind":"italic_en","text":"He felt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experienced,"},{"kind":"arabic","text_bw":"waHo$ap","text_ar":"وَحْشَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"loneliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solitude,"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"sadness, grief, sorrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquietude"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble of mind,"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"fear,"},{"kind":"text","text":"&c.]. (S, * K, TA.) And"},{"kind":"arabic","text_bw":"AstwH$ A_ilaY Al$~aYo'i","text_ar":"استوحش اـِلَى الشَّىْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He felt a want of the thing"},{"kind":"text","text":"]. (K, voce"},{"kind":"arabic","text_bw":"EuriYa","text_ar":"عُرِىَ"},{"kind":"text","text":", q. v.) You say also"},{"kind":"arabic","text_bw":"AstwH$ minohu","text_ar":"استوحش مِنْهُ"},{"kind":"text","text":", (A, TA,) or"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", (Msb,) [meaning"},{"kind":"italic_en","text":"He was afraid of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feared, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"agreeably with an explanation of the inf. n. in Har, p. 331: see also an instance below, voce"},{"kind":"arabic","text_bw":"waHo$N","text_ar":"وَحْشٌ"},{"kind":"text","text":": or] meaning"},{"kind":"italic_en","text":"he was shy of him; averse from him; unsocial, unsociable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfamiliar, with him; and like a wild animal."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AstwH$t AlA^aroDu","text_ar":"استوحشت الاَرْضُ"},{"kind":"text","text":": see 4.       -A2-  ["},{"kind":"italic_en","text":"He deemed"},{"kind":"text","text":"a word, or sound, &c.,"},{"kind":"italic_en","text":"strange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncouth."},{"kind":"text","text":"]"}],"source_refs":["S","TA","A","Msb"]}]}}