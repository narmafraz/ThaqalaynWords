{"lemma":"تَواضُعاتٌ","slug":"تَواضُعاتٌ","root":"#.ض.ع","root_slug":"_-ض-ع","root_link":"/words/roots/_-ض-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n44630"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%88%D8%A7%D8%B6%D9%8F%D8%B9%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be humble"},{"pos":"verb","gloss":"to behave humbly and modestly"},{"pos":"verb","gloss":"to agree","tags":["reciprocal"]},{"pos":"noun","gloss":"verbal noun of تَوَاضَعَ (tawāḍaʕa) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"humility"}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root و ض ع (w ḍ ʕ)."},"ipa":["/ta.waː.dˤa.ʕa/","/ta.waː.dˤuʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44630","headword_ar":"تَوَاضَعَ","root":"wDE","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble, submissive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of abasement:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he lowered, humbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abased, himself."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"tawaADaEaA Alr~uhuwna","text_ar":"تَوَاضَعَا الرُّهُونَ"},{"kind":"italic_en","text":"They two laid bets, wagers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stakes, each with the other;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taraAhanaA","text_ar":"تَرَاهَنَا"},{"kind":"text","text":". (TA, art."},{"kind":"arabic","text_bw":"rhn","text_ar":"رهن"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"tawaADaEati AlA^aroDu","text_ar":"تَوَاضَعَتِ الاَرْضُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The land was lower than that which was next to it."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb"]}]}}