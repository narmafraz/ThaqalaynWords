{"lemma":"بَعَثَ","slug":"بَعَثَ","root":"ب.ع.ث","root_slug":"ب-ع-ث","root_link":"/words/roots/ب-ع-ث","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَعَثْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَعَثْتِ","in_corpus":true,"count":17,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَعَثْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَعَثْتُم","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَعَثْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَعَثَ","in_corpus":true,"count":105,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَعَثَت","in_corpus":true,"count":17,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَعَثا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَعَثَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَعَثُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَعَثْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْعَث","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْعَثِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْعَثِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْعَثانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْعَثا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْعَثُونَ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْعَثُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْعَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْعَث","in_corpus":true,"count":67,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْعَث","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْعَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْعَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْعَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْعَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْعَثُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْعَثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْعَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَعَثْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَعَثْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْعَث","in_corpus":true,"count":15,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْعَث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":242,"cross_references":{"qac":{"found":true,"lemma_key":"بَعَثَ","root":"بعث","pos":"V","occurrence_count":52},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n2839","n2842","n2843","n2844","n2845"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B9%D9%8E%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to awake"},{"pos":"verb","gloss":"to incite, to induce, to instigate","examples":[{"text":"فَيَنْبَغِي أَنْ نَسْأَلَهُ عَمَّا بَعَثَهُ عَلَى ذٰلِكَ، لَعَلَّ لَهُ عُذْرًا.","english":"In Baghdad"}]},{"pos":"verb","gloss":"to raise"},{"pos":"verb","gloss":"to resurrect","examples":[{"text":"فَأَمَاتَهُ اللَّهُ مِائَةَ عَامٍ ثُمَّ بَعَثَهُ","english":"So Allah caused him to die for a hundred years then brought him back to life."}]},{"pos":"verb","gloss":"to send","examples":[{"text":"وَإِنْ خِفْتُمْ شِقَاقَ بَيْنِهِمَا فَابْعَثُوا حَكَمًا مِنْ أَهْلِهِ وَحَكَمًا مِنْ أَهْلِهَا","english":"And if ye fear a breach between them twain, send an arbiter from his folk and an arbiter from her folk. If they desire amendment, Allah will make them of one mind. Lo! Allah is ever Knower, Aware."},{"text":"هُوَ ٱلَّذِي بَعَثَ فِي ٱلۡأُمِّيِّـۧنَ رَسُولٗا مِّنۡهُمۡ يَتۡلُواْ عَلَيۡهِمۡ ءَايَٰتِهِۦ وَيُزَكِّيهِمۡ وَيُعَلِّمُهُمُ ٱلۡكِتَٰبَ وَٱلۡحِكۡمَةَ وَإِن كَانُواْ مِن قَبۡلُ لَفِي ضَلَٰلٖ مُّبِينٖ.","english":"He it is Who hath sent among the unlettered ones a messenger of their own, to recite unto them His revelations and to make them grow, and to teach them the Scripture and wisdom, though heretofore they were indeed in error manifest."}]},{"pos":"noun","gloss":"verbal noun of بَعَثَ (baʕaṯa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"sending out, emission, dispatching, delegation"},{"pos":"noun","gloss":"resurrection","examples":[{"text":"إِنْ كُنْتُمْ فِي رَيْبٍ مِنَ ٱلْبَعْثِ"}]},{"pos":"noun","gloss":"awakening, renaissance, revival, arousal, evocation"}]},"etymology":null,"ipa":["/ba.ʕa.θa/","/baʕθ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2839","headword_ar":"بَعْثٌ","root":"bEv","body":[{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"removing of that which restrains one from free action."},{"kind":"text","text":"(TA.) [And hence,] ―         -b2-"},{"kind":"arabic","text_bw":"baEavahu","text_ar":"بَعَثَهُ"},{"kind":"text","text":", (S, A, &c.,) aor."},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":"(Mgh, L, Msb, TA) and"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":", (L, TA,)"},{"kind":"italic_en","text":"He sent him;"},{"kind":"text","text":"(S, A, Mgh, Msb, K;) namely, a messenger; (Msb;) and, when said of God, an apostle; (A;) [and when said of a man, a letter, &c.;] as also ↓"},{"kind":"arabic","text_bw":"AbtEvh","text_ar":"ابتعثه","orth_type":"arrow"},{"kind":"text","text":": (S, A, Msb, K:) [or] the former is said of anything that goes, or is sent, by itself; and of anything that will not go, or be sent, by itself, as a letter, and a present, one says,"},{"kind":"arabic","text_bw":"baEava bihi","text_ar":"بَعَثَ بِهِ"},{"kind":"text","text":": (Msb:) [thus,]"},{"kind":"arabic","text_bw":"baEavahu","text_ar":"بَعَثَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he sent him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, alone, by himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by itself;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEava bihi","text_ar":"بَعَثَ بِهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he sent him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with, another,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"others:"},{"kind":"text","text":"(L:) but El-Fárábee says that the former of these two has another signification, which will be found below; and that the latter signifies"},{"kind":"italic_en","text":"he sent him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Msb.) Hence,"},{"kind":"arabic","text_bw":"Duriba Ealayohimu AlbaEovu","text_ar":"ضُرِبَ عَلَيْهِمُ البَعْثُ"},{"kind":"italic_en","text":"The being sent to the war was appointed them and imposed upon them as an obligation."},{"kind":"text","text":"(Msb.) You say,"},{"kind":"arabic","text_bw":"baEavahu lika*aA","text_ar":"بَعَثَهُ لِكَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sent him for such a thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purpose"},{"kind":"text","text":"]. (A, TA.) [And"},{"kind":"arabic","text_bw":"baEava A_ilayohi bika*aA","text_ar":"بَعَثَ اـِلَيْهِ بِكَذَا"},{"kind":"italic_en","text":"He sent to him such a thing;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"he sent to him"},{"kind":"text","text":"a messenger"},{"kind":"italic_en","text":"with such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"baEava Aljunoda A_ilaY Algazowi","text_ar":"بَعَثَ الجُنْدَ اـِلَى الغَزْوِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sent the army to the war"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"baEava Ealayohimu AlbalaA='a","text_ar":"بَعَثَ عَلَيْهِمُ البَلَا=ءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sent upon them trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he caused trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction, to befall them."},{"kind":"text","text":"(TA.) ―         -b3-  Also, (A, L, TA,) inf."},{"kind":"arabic","text_bw":"baEovN","text_ar":"بَعْثٌ"},{"kind":"text","text":"(Mgh, L, TA) and"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"taboEaAvN","text_ar":"تَبْعَاثٌ"},{"kind":"text","text":"[an intensive form], (TA,)"},{"kind":"italic_en","text":"He roused him, excited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put him in motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action;"},{"kind":"text","text":"(A, L, Mgh, TA;) namely, anything; (TA;) [i. e. any person or animal; and particularly,] an animal lying down, or a person sitting. (L, TA.) You say,"},{"kind":"arabic","text_bw":"baEava Aln~aAqapa","text_ar":"بَعَثَ النَّاقَةَ"},{"kind":"page_break","n":223},{"kind":"italic_en","text":"He roused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action, the she-camel;"},{"kind":"text","text":"(S, Mgh, K, TA;) i. e.,"},{"kind":"italic_en","text":"loosed the cord that bound her shank to her arm, and dismissed her;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he roused her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made her to rise, she being lying down."},{"kind":"text","text":"(TA.) It is said in a trad. respecting 'Áïsheh,"},{"kind":"arabic","text_bw":"fabaEavonaA AlbaEiyra fA_i*aA AlEiqodu taHotahu","text_ar":"فَبَعَثْنَا البَعِيرَ فاـِذَا العِقْدُ تَحْتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we made the camel to rise, and to, the necklace was beneath him"},{"kind":"text","text":"]. (TA.) You say also,"},{"kind":"arabic","text_bw":"baEavahu EalaY AlA^amori","text_ar":"بَعَثَهُ عَلَى الاَمْرِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"Al$~aYo'i","text_ar":"الشَّىْءِ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He roused him, excited him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put him in motion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"action, to do the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"he incited him, urged him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"instigated him, to do the thing."},{"kind":"text","text":"(L.) ―         -b4-  Also, accord. to El-Fárábee, (Msb,) or"},{"kind":"arabic","text_bw":"baEavahu mino manaAmihi","text_ar":"بَعَثَهُ مِنْ مَنَامِهِ"},{"kind":"text","text":", (S, A, K,) inf. n."},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He roused him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"awoke him, from his sleep;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AbtEvhu","text_ar":"ابتعثهُ","orth_type":"arrow"},{"kind":"text","text":". (TA, from a trad.) ―         -b5-"},{"kind":"arabic","text_bw":"baEovN","text_ar":"بَعْثٌ"},{"kind":"text","text":"(S, K, TA) and"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":"(TA) also signify The"},{"kind":"italic_en","text":"quickening, vivifying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revivifying,"},{"kind":"text","text":"of the dead; the"},{"kind":"italic_en","text":"raising"},{"kind":"text","text":"of the dead"},{"kind":"italic_en","text":"to life;"},{"kind":"text","text":"(S, K, * TA;) by God, (TA,)"},{"kind":"italic_en","text":"on the day called"},{"kind":"arabic","text_bw":"yawomu AlbaEovi","text_ar":"يَوْمُ البَعْثِ"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"the day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of resurrection,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when those who are in the graves shall be raised."},{"kind":"text","text":"(A, Mgh.) You say,"},{"kind":"arabic","text_bw":"baEava A@ll~`hu Alxaloqa","text_ar":"بَعَثَ ا@للّٰهُ الخَلْقَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlmawotaY","text_ar":"المَوْتَى"},{"kind":"text","text":","},{"kind":"italic_en","text":"God quickened, vivified, revivified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raised to life, mankind,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the dead."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"baEiva","text_ar":"بَعِثَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ"},{"kind":"text","text":", TK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was sleepless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wakeful."},{"kind":"text","text":"(K, * TA.) [See"},{"kind":"arabic","text_bw":"baEivN","text_ar":"بَعِثٌ"},{"kind":"text","text":".]"}],"source_refs":["A","K","Mgh","L","Msb","TA","S"]},{"entry_id":"n2842","headword_ar":"بَعْثٌ","root":"bEv","body":[{"kind":"text","text":"an inf. n. used as a pass. part. n.;"},{"kind":"italic_en","text":"Sent;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"baEiyvN","text_ar":"بَعِيثٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maboEwvN","text_ar":"مَبْعوثٌ","orth_type":"arrow"},{"kind":"text","text":": pl. of the first"},{"kind":"arabic","text_bw":"buEuwvN","text_ar":"بُعُوثٌ"},{"kind":"text","text":"; and of the second"},{"kind":"arabic","text_bw":"buEuvN","text_ar":"بُعُثٌ"},{"kind":"text","text":". (L, TA.) ―         -b2-  And [used as a subst., signifying]"},{"kind":"italic_en","text":"A person sent; a messenger:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"baEovaAnN","text_ar":"بَعْثَانٌ"},{"kind":"text","text":". (L.) You say also,"},{"kind":"arabic","text_bw":"muHam~adN xayoru","text_ar":"مُحَمَّدٌ خَيْرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maboEuwvK","text_ar":"مَبْعُوثٍ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mubotaEavK","text_ar":"مُبْتَعَثٍ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Mohammad is the best person that has been sent"},{"kind":"text","text":"]. (A.) And ↓"},{"kind":"arabic","text_bw":"baEayvuka","text_ar":"بَعَيثُكَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"niEomapF","text_ar":"نِعْمَةً"},{"kind":"text","text":", i. e. ↓"},{"kind":"arabic","text_bw":"maboEuwvuka","text_ar":"مَبْعُوثُكَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He whom Thou"},{"kind":"text","text":"(O God)"},{"kind":"italic_en","text":"hast sent"},{"kind":"text","text":"(namely Mohammad)"},{"kind":"italic_en","text":"as a boon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour"},{"kind":"text","text":"]. (L, from a trad. [The latter word ("},{"kind":"arabic","text_bw":"nEmp","text_ar":"نعمة"},{"kind":"text","text":") is written in the L without any syll. signs; but the context shows that it is in the accus. case as a specificative.]) ―         -b3-"},{"kind":"italic_en","text":"A people sent from one place to another;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ","orth_type":"arrow"},{"kind":"text","text":": (L, TA:)"},{"kind":"italic_en","text":"a people sent in any direction;"},{"kind":"text","text":"a word similar to"},{"kind":"arabic","text_bw":"saforN","text_ar":"سَفْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rakobN","text_ar":"رَكْبٌ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"baEovu Aln~aAri","text_ar":"بَعْثُ النَّارِ"},{"kind":"text","text":", occurring in a trad., means"},{"kind":"italic_en","text":"The people sent to the fire"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of Hell"},{"kind":"text","text":"]. (L.) ―         -b4-"},{"kind":"italic_en","text":"An army;"},{"kind":"text","text":"(S, Mgh, Msb, K;) because sent; (Mgh;) as also ↓"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"baEiyvN","text_ar":"بَعِيثٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl. of the first"},{"kind":"arabic","text_bw":"buEuwvN","text_ar":"بُعُوثٌ"},{"kind":"text","text":"; (S, A, Mgh, Msb, K;) and of the last"},{"kind":"arabic","text_bw":"buEuvN","text_ar":"بُعُثٌ"},{"kind":"text","text":": (TA:) the first, [as also the second,] an inf. n. used as a subst. (Msb.) You say,"},{"kind":"arabic","text_bw":"kunotu fiY baEovi fulaAnK","text_ar":"كُنْتُ فِى بَعْثِ فُلَانٍ"},{"kind":"italic_en","text":"I was in the army of such a one, that was sent with him."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"xaraja fiY AlbuEuwvi","text_ar":"خَرَجَ فِى البُعُوثِ"},{"kind":"italic_en","text":"He went forth among the forces that were sent to the frontiers."},{"kind":"text","text":"(A.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"baEivN","text_ar":"بَعِثٌ"},{"kind":"text","text":"."}],"source_refs":["L","TA","K"]},{"entry_id":"n2843","headword_ar":"بُعْثٌ","root":"bEv","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"baEovN","text_ar":"بَعْثٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n2844","headword_ar":"بَعَثٌ","root":"bEv","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"baEovN","text_ar":"بَعْثٌ"},{"kind":"text","text":", in two places: ―         -b2-  and see what next follows."}],"source_refs":[]},{"entry_id":"n2845","headword_ar":"بَعِثٌ","root":"bEv","body":[{"kind":"text","text":"(A, L, K) and ↓"},{"kind":"arabic","text_bw":"baEovN","text_ar":"بَعْثٌ","orth_type":"arrow"},{"kind":"text","text":"(L, TA) and ↓"},{"kind":"arabic","text_bw":"buEovN","text_ar":"بُعْثٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) or ↓"},{"kind":"arabic","text_bw":"baEavN","text_ar":"بَعَثٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"Sleepless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wakeful:"},{"kind":"text","text":"(K:) a man"},{"kind":"italic_en","text":"incessantly,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"often,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"awaking from his sleep:"},{"kind":"text","text":"(A, TA:) a man"},{"kind":"italic_en","text":"whose anxieties,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"griefs, incessantly render him sleepless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wakeful, and awake him from his sleep:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aboEAvN","text_ar":"اَبْعاثٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["A","L","K","TA"]}]}}