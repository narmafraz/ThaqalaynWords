,"gen":"m","num":"p"},{"role":"present_2mp","form":"تُطابِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُطابِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُطابِق","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُطابِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُطابِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطابِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُطابِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطابِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُطابِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطابِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُطابِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"طابَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طابَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُطابِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطابِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n26352"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D8%A8%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a large tile or brick","tags":["obsolete"]},{"pos":"noun","gloss":"a frying-pan","tags":["obsolete"]},{"pos":"noun","gloss":"a sheet of iron or flat piece of metal, for example for baking on it","tags":["obsolete"]},{"pos":"noun","gloss":"a joint, a limb or member of the body","tags":["obsolete"]},{"pos":"noun","gloss":"floor (“storey”)"},{"pos":"verb","gloss":"to be in accordance with"},{"pos":"verb","gloss":"to be commensurate to, to be congruent with, to agree with in outer properties"}]},"etymology":{"source":"wiktextract","text":"Etymology tree\nProto-Iranian *tāpaka-\nMiddle Persian tʾp̄k'bor.\nArabic طَابَق\nFrom Middle Persian tʾp̄k' (tābaq, tābag), source of the root ط ب ق (ṭ b q)."},"ipa":["/tˤaː.baq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26352","headword_ar":"طَابَقٌ","root":"Tbq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TiboqN","text_ar":"طِبْقٌ"},{"kind":"text","text":".       -A2-  Also, (S, Mgh, O, K,) and"},{"kind":"arabic","text_bw":"TaAbiqN","text_ar":"طَابِقٌ"},{"kind":"text","text":", (K,) both mentioned by Ks and Lh, [and both in one of my copies of the S,] (TA,) and ↓"},{"kind":"arabic","text_bw":"TaAbaAqN","text_ar":"طَابَاقٌ","orth_type":"arrow"},{"kind":"text","text":", (Fr, O, K,)"},{"kind":"italic_en","text":"A large brick:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"a large baked brick:"},{"kind":"text","text":"(S, O, K:) [or"},{"kind":"italic_en","text":"a large tile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flat piece of baked clay:"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"a large"},{"kind":"text","text":"["},{"kind":"italic_en","text":"piece of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"glass:"},{"kind":"text","text":"(Mgh:) arabicized, (S, Mgh, O,) from the Pers., (S, O,) i. e. from"},{"kind":"arabic","text_bw":"taAbaho","text_ar":"تَابَهْ"},{"kind":"text","text":": (Mgh, O:) [and particularly"},{"kind":"italic_en","text":"a large flat piece of baked clay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of stone, &c., that is used for a trapdoor:"},{"kind":"text","text":"] whence,"},{"kind":"arabic","text_bw":"bayotu AlT~aAbaqi","text_ar":"بَيْتُ الطَّابَقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the chamber that has a trap-door"},{"kind":"text","text":"]: (Mgh: [see also"},{"kind":"arabic","text_bw":"muTobiqN","text_ar":"مُطْبِقٌ"},{"kind":"text","text":":]) pl."},{"kind":"arabic","text_bw":"TawaAbiqu","text_ar":"طَوَابِقُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TawaAbiyqu","text_ar":"طَوَابِيقُ"},{"kind":"text","text":"; (Mgh, O, K;) the former being pl. of"},{"kind":"arabic","text_bw":"TAbq","text_ar":"طابق"},{"kind":"text","text":", and the latter of"},{"kind":"arabic","text_bw":"TAbAq","text_ar":"طاباق"},{"kind":"text","text":". (O.) ―         -b2-  And in like manner the"},{"kind":"arabic","text_bw":"TaAbaq","text_ar":"طَابَق"},{"kind":"text","text":"of iron [is from the Pers."},{"kind":"arabic","text_bw":"taAbaho","text_ar":"تَابَهْ"},{"kind":"text","text":"]: (O:) [i. e.]"},{"kind":"arabic","text_bw":"TaAbaqN","text_ar":"طَابَقٌ"},{"kind":"text","text":"signifies also, (K, TA,) and"},{"kind":"arabic","text_bw":"TaAbiqN","text_ar":"طَابِقٌ"},{"kind":"text","text":"likewise, (accord. to the K,)"},{"kind":"italic_en","text":"A certain vessel in which one cooks,"},{"kind":"text","text":"(K, TA,) [meaning"},{"kind":"italic_en","text":"a frying-pan,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of iron"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of copper:"},{"kind":"text","text":"(TA:) arabicized from"},{"kind":"arabic","text_bw":"taAbaho","text_ar":"تَابَهْ"},{"kind":"text","text":". (K, TA.) ―         -b3-  [And"},{"kind":"italic_en","text":"A plate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flat piece, of metal."},{"kind":"text","text":"]       -A3-"},{"kind":"arabic","text_bw":"biy^orN *aAtu","text_ar":"بِيْرٌ ذَاتُ"},{"kind":"arabic","text_bw":"TaAbaqK","text_ar":"طَابَقٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A well in which are projecting edges."},{"kind":"text","text":"(Ibn-'Abbád, O.)       -A4-  And"},{"kind":"arabic","text_bw":"TaAbaqN","text_ar":"طَابَقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TaAbiqN","text_ar":"طَابِقٌ"},{"kind":"text","text":"signify also"},{"kind":"italic_en","text":"A limb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"member,"},{"kind":"text","text":"(Th, O, * K, TA,) of a human being, such as the"},{"kind":"italic_en","text":"arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(Th, TA:) applied in a trad. to the"},{"kind":"italic_en","text":"hand"},{"kind":"text","text":"of a thief, which is to be cut off: (TA:) [see"},{"kind":"arabic","text_bw":"TaAy^ifN","text_ar":"طَايِفٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Twf","text_ar":"طوف"},{"kind":"text","text":":] or they signify [or signify also] the"},{"kind":"italic_en","text":"half"},{"kind":"text","text":"of a sheep, or goat: (K, TA:) or"},{"kind":"italic_en","text":"as much"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"as two persons,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"three, eat."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","O","K","TA","Fr","Th"]}]},"classical_definitions":null}