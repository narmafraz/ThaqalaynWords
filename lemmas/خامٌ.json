{"lemma":"خامٌ","slug":"خامٌ","root":"خ.#.م","root_slug":"خ-_-م","root_link":"/words/roots/خ-_-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n11459","n11555","n11762","n11903","n11899"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"raw, crude, unprocessed"}]},"etymology":{"source":"wiktextract","text":"Borrowed from Persian خام (xâm, “raw”)."},"ipa":["/xaːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11459","headword_ar":"خَامٌّ","root":"xm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xam~N","text_ar":"خَمٌّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n11555","headword_ar":"خَامٍ","root":"Quasi xmY","body":[{"kind":"text","text":"(accus."},{"kind":"arabic","text_bw":"xaAmiyFA","text_ar":"خَامِيًا"},{"kind":"text","text":") for"},{"kind":"arabic","text_bw":"xaAmisN","text_ar":"خَامِسٌ"},{"kind":"text","text":": see the latter word."}],"source_refs":[]},{"entry_id":"n11762","headword_ar":"خَامٌ","root":"xwm","body":[{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"xym","text_ar":"خيم"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n11903","headword_ar":"خَامٌ","root":"xym","body":[{"kind":"text","text":"A skin, or hide,"},{"kind":"italic_en","text":"untanned:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not tanned much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thoroughly:"},{"kind":"text","text":"and a"},{"kind":"arabic","text_bw":"kirobaAs","text_ar":"كِرْبَاس"},{"kind":"text","text":"[or coarse garment or piece of cloth, or garment or piece of cloth of white cotton,]"},{"kind":"italic_en","text":"unwashed:"},{"kind":"text","text":"(K:) a Persian word, (TA,) arabicized. (K.)"},{"kind":"italic_en","text":"Unbleached"},{"kind":"text","text":"cloth. (Msb, in art."},{"kind":"arabic","text_bw":"xwm","text_ar":"خوم"},{"kind":"text","text":".) Paper that is"},{"kind":"italic_en","text":"polished,"},{"kind":"text","text":"[app. a mistake for"},{"kind":"italic_en","text":"not polished,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"to be polished."},{"kind":"text","text":"(TA.) ["},{"kind":"italic_en","text":"Crude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raw;"},{"kind":"text","text":"applied in this sense to silk,"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"maTobuwxN","text_ar":"مَطْبُوخٌ"},{"kind":"text","text":"; and to sugar, &c.: anything"},{"kind":"italic_en","text":"unprepared for use."},{"kind":"text","text":"] Honey of dates ("},{"kind":"arabic","text_bw":"dibos","text_ar":"دِبْس"},{"kind":"text","text":")"},{"kind":"italic_en","text":"untouched by fire:"},{"kind":"text","text":"(AHn, T:) which is the best thereof. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"xaAmap","text_ar":"خَامَة"},{"kind":"text","text":"."}],"source_refs":["K","TA","AHn","T"]},{"entry_id":"n11899","headword_ar":"خَامَ","root":"xym","body":[{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"xay~ama","text_ar":"خَيَّمَ"},{"kind":"text","text":": see the latter. ―         -b2-"},{"kind":"arabic","text_bw":"xaAma Eanohu","text_ar":"خَامَ عَنْهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxiymu","text_ar":"يَخِيمُ"},{"kind":"text","text":", (JK, S, K,) inf. n."},{"kind":"arabic","text_bw":"xayomuwmapN","text_ar":"خَيْمُومَةٌ"},{"kind":"text","text":"(S) and"},{"kind":"arabic","text_bw":"xayomN","text_ar":"خَيْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xayamaAnN","text_ar":"خَيَمَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuyuwmN","text_ar":"خُيُومٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuywmapN","text_ar":"خُيومَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiyaAmN","text_ar":"خِيَامٌ"},{"kind":"text","text":", (K, the last but one omitted in the CK,)"},{"kind":"italic_en","text":"He held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrained, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, through cowardice,"},{"kind":"text","text":"(JK, S, K,) and"},{"kind":"italic_en","text":"fear:"},{"kind":"text","text":"(JK, K:) i. e., from war, (JK,) or from encounter, or conflict. (Ham p. 164.) And one says also,"},{"kind":"arabic","text_bw":"xaAmuwA fiY AlqitaAli","text_ar":"خَامُوا فِى القِتَالِ"},{"kind":"italic_en","text":"They held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrained, through cowardice, in fight, and attained no good:"},{"kind":"text","text":"and the poet Junádeh Ibn-'Ámir El-Hudhalee says,"},{"kind":"arabic","text_bw":"xAm AlqitaAla","text_ar":"خام القِتَالَ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"xAm fiY AlqitaAli","text_ar":"خام فِى القِتَالِ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"xAm","text_ar":"خام"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He drew back,"},{"kind":"text","text":"(JK, K, *)"},{"kind":"italic_en","text":"through cowardice and fear,"},{"kind":"text","text":"(JK,)"},{"kind":"italic_en","text":"from a stratagem,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plot, after he had devised it,"},{"kind":"text","text":"(JK, K, *)"},{"kind":"italic_en","text":"not seeing in it what he liked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approved."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xAm rijolahu","text_ar":"خام رِجْلَهُ"},{"kind":"text","text":", (S, K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"xayomN","text_ar":"خَيْمٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He raised his leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot."},{"kind":"text","text":"(S, K.)"},{"kind":"page_break","n":837}],"source_refs":["JK","S","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D9%85/","headword_ar":"خام","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=60794#5ed495","body_html":"خام<br>عن الفارسية خام بمعنى فج عديم الخبرة أو بعث أو خال. يستخدم للذكور."}]}}