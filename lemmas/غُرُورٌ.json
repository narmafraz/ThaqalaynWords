{"lemma":"غُرُورٌ","slug":"غُرُورٌ","root":"غ.ر.ر","root_slug":"غ-ر-ر","root_link":"/words/roots/غ-ر-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"غُرُور","root":"غرر","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n31593"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8F%D8%B1%D9%8F%D9%88%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of غَرَّ (ḡarra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"cockiness, vanity, pretension"},{"pos":"noun","gloss":"deception, delusion","examples":[{"text":"وَمَا يَعِدُهُمُ الشَّيْطَانُ إِلَّا غُرُورًا","english":"Truly Satan promises them nothing but delusion."}]}]},"etymology":{"source":"wiktextract","text":"Verbal noun of غَرَّ (ḡarra)."},"ipa":["/ɣu.ruːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31593","headword_ar":"غُرُورٌ","root":"gr","body":[{"kind":"italic_en","text":"False,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain, things; vanities:"},{"kind":"text","text":"(Zj, K:) as though pl. of"},{"kind":"arabic","text_bw":"gar~N","text_ar":"غَرٌّ"},{"kind":"text","text":", inf. n. of"},{"kind":"arabic","text_bw":"gar~ahu","text_ar":"غَرَّهُ"},{"kind":"text","text":": (Zj:) or pl. of ↓"},{"kind":"arabic","text_bw":"gaAr~N","text_ar":"غَارٌّ","orth_type":"arrow"},{"kind":"text","text":"; (Zj, K;) like as"},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"$aAhidN","text_ar":"شَاهِدٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"quEuwdN","text_ar":"قُعُودٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"qaAEidN","text_ar":"قَاعِدٌ"},{"kind":"text","text":": (Zj:) or"},{"kind":"italic_en","text":"what is false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain; a deception; a thing by which one is deceived."},{"kind":"text","text":"(AZ.) See also"},{"kind":"arabic","text_bw":"garuwrN","text_ar":"غَرُورٌ"},{"kind":"text","text":"."}],"source_refs":["Zj","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%BA%D8%B1%D9%88%D8%B1/","headword_ar":"غرور","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23443#0a7710","body_html":"<span>الغرور: هو سكون النفس إلى ما يوافق الهوى، ويميل إليه الطبع.</span>"},{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=23443#a3c733","body_html":"<span class=\"title1\">غ ر ر [غرور]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: إِنِ الْكافِرُونَ إِلَّا فِي غُرُورٍ .</span><br><span>قال: ما الكافرون إلا في باطل.</span><br><span>قال: فهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت حسان بن ثابت وهو يهجو أبي بن خلف ويقول:</span><br><span>تمنّيك الأماني من بعيد </span><span class=\"red\">...</span><span> وقول الكفر يرجع في غرور </span>"},{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=23443#19f9d5","body_html":"<span class=\"title1\">غ ر ر [غرورا]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: زُخْرُفَ الْقَوْلِ غُرُوراً .</span><br><span>قال: باطل القول غرورا.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت أوس بن حجر يقول:</span><br><span>لم يغروكم غرورا ولكن </span><span class=\"red\">...</span><span> يرفع الآل جمعكم والزهاء </span><br><span>وقال زهير بن أبي سلمى :</span><br><span>فلا تغرّنّك دنيا إن سمعت بها </span><span class=\"red\">...</span><span> عند امرئ سوءة في النّاس مغمور </span>"}]}}