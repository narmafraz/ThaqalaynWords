":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُوَكِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُوَكِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُوَكِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُوَكِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُوَكِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُوَكِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوَكِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَكِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَكِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَكِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَكِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُوَكِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَكِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"وَكَّدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"وَكَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n42298","n42299","n42301","n42302"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%83%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make fast, to fasten"},{"pos":"verb","gloss":"to consolidate"},{"pos":"verb","gloss":"to confirm, corroborate, to substantiate"},{"pos":"verb","gloss":"to affirm, to assure, to assert"},{"pos":"verb","gloss":"to emphasize"},{"pos":"verb","gloss":"to look attentively at"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42298","headword_ar":"وَكَدَ","root":"wkd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakidu","text_ar":"يَكِدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wukuwdN","text_ar":"وُكُودٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He remained, continued, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt,"},{"kind":"text","text":"(L, K,)"},{"kind":"arabic","text_bw":"bimakaAnK","text_ar":"بِمَكَانٍ"},{"kind":"italic_en","text":"in a place."},{"kind":"text","text":"(L.)       -A2-  See 2.       -A3-"},{"kind":"arabic","text_bw":"wakada A^amorFA","text_ar":"وَكَدَ اَمْرًا"},{"kind":"text","text":", (L, K, *) aor."},{"kind":"arabic","text_bw":"yakidu","text_ar":"يَكِدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wakodN","text_ar":"وَكْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He aimed at a thing; sought, endeavoured after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursued, it; desired it; intended it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSada","text_ar":"قَصَدَ"},{"kind":"text","text":"(L, K) and"},{"kind":"arabic","text_bw":"Talaba","text_ar":"طَلَبَ"},{"kind":"text","text":". (L.) See also below. ―         -b2-"},{"kind":"arabic","text_bw":"wakada wakodahu","text_ar":"وَكَدَ وَكْدَهُ"},{"kind":"italic_en","text":"He directed his course to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he pursued his"},{"kind":"text","text":"(another's)"},{"kind":"italic_en","text":"course;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSada qaSodahu","text_ar":"قَصَدَ قَصْدَهُ"},{"kind":"text","text":"; (S, L, K;)"},{"kind":"italic_en","text":"doing as he did."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"wakada A^amorFA","text_ar":"وَكَدَ اَمْرًا"},{"kind":"text","text":", aor. and inf. n. as above, also signifies"},{"kind":"italic_en","text":"He laboured at, and endeavoured after, a thing."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"wakada","text_ar":"وَكَدَ"},{"kind":"text","text":", (L, K,) aor."},{"kind":"arabic","text_bw":"yakidu","text_ar":"يَكِدُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wakodN","text_ar":"وَكْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aSaAba","text_ar":"اَصَابَ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, right; attained"},{"kind":"text","text":"an object;"},{"kind":"italic_en","text":"hit, struck, smote, affected, hurt, befell; &c."},{"kind":"text","text":"]. (L, K.)"}],"source_refs":["L","K"]},{"entry_id":"n42299","headword_ar":"وكّد","root":"wkd","body":[{"kind":"text","text":", (S, L,) inf. n."},{"kind":"arabic","text_bw":"tawokiydN","text_ar":"تَوْكِيدٌ"},{"kind":"text","text":"; (S, K;) [and ↓"},{"kind":"arabic","text_bw":"wakada","text_ar":"وَكَدَ","orth_type":"arrow"},{"kind":"text","text":"as is implied in the K, but app. by the unintentional omission of the word"},{"kind":"arabic","text_bw":"wak~ada","text_ar":"وَكَّدَ"},{"kind":"text","text":";] and ↓"},{"kind":"arabic","text_bw":"Awkd","text_ar":"اوكد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iykaAdN","text_ar":"اـِيكَادٌ"},{"kind":"text","text":"; (S, L;)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a horse's saddle, (S, L,) and a camel's, (L, K,)"},{"kind":"italic_en","text":"firm, fast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tied"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"firmly, fastly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly;"},{"kind":"text","text":"(S, L, K;) as also"},{"kind":"arabic","text_bw":"A^ak~ada","text_ar":"اَكَّدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=kada","text_ar":"ا=كَدَ"},{"kind":"text","text":": but more chaste with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":". (S, L, K. *) ―         -b2-  Also,"},{"kind":"italic_en","text":"He confirmed, ratified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corroborated,"},{"kind":"text","text":"a compact, a contract, a covenant, or an engagement; as also"},{"kind":"arabic","text_bw":"Ak~d","text_ar":"اكّد"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"A=kd","text_ar":"ا=كد"},{"kind":"text","text":": but, in this sense also, more chaste with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"; (S, L;) or in this sense more approved with"},{"kind":"page_break","n":2964},{"kind":"arabic","text_bw":"A^","text_ar":"ا"},{"kind":"text","text":": (L:) and in like manner"},{"kind":"arabic","text_bw":"wk~d","text_ar":"وكّد"},{"kind":"italic_en","text":"he confirmed"},{"kind":"text","text":"an oath: you say,"},{"kind":"arabic","text_bw":"A_i*aA Eaqadota faA^ak~ido wA_i*aA Halafota","text_ar":"اـِذَا عَقَدْتَ فَاَكِّدْ واـِذَا حَلَفْتَ"},{"kind":"arabic","text_bw":"fawak~ido","text_ar":"فَوَكِّدْ"},{"kind":"italic_en","text":"When thou makest a contract, ratify; and when thou swearest, confirm."}],"source_refs":["S","L","K"]},{"entry_id":"n42301","headword_ar":"وَكْدٌ","root":"wkd","body":[{"kind":"italic_en","text":"Desire; purpose; intention; aim; endeavour."},{"kind":"text","text":"(L, K.) See also 1."}],"source_refs":[]},{"entry_id":"n42302","headword_ar":"وُكْدٌ","root":"wkd","body":[{"kind":"italic_en","text":"Work; labour; exertion; endeavour."},{"kind":"text","text":"(L, K.) Ex."},{"kind":"arabic","text_bw":"maA zaAla *`lika wukodiY","text_ar":"مَا زَالَ ذٰلِكَ وُكْدِى"},{"kind":"italic_en","text":"That ceased not to be my work,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"and endeavour."},{"kind":"text","text":"(L.)"}],"source_refs":["L","K"]}]},"classical_definitions":null}