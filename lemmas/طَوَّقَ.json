er":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُطَوِّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُطَوِّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُطَوِّق","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُطَوِّق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُطَوِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُطَوِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُطَوِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُطَوِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُطَوِّقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُطَوِّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُطَوِّقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُطَوِّق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُطَوِّق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"طَوَّقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طَوَّقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n27331"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D9%88%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"anything that surrounds another thing, ring-shaped border, hoop, headband, necklace etc."},{"pos":"verb","gloss":"to put a hoop, ring, collar etc. around","tags":["transitive"]},{"pos":"verb","gloss":"to encircle, to surround","tags":["transitive"]},{"pos":"verb","gloss":"to cramp, to restrict that developments come out from the inner of or encroach upon from the outside, to lock up in its artistical capabilities or with legal power, to close off, to cordon off","tags":["transitive"]},{"pos":"verb","gloss":"to endow or to emburden with (also occurring in the idiom طَوَّقَ عُنْقَهُ بِـ (ṭawwaqa ʕunqa-hū bi, literally “to put X on the neck of”))","tags":["ditransitive"]},{"pos":"verb","gloss":"to press or to embrace in a good sense, to hug, to receive with open arms so to say, or perhaps to have someone on the lap, even so: يُطَوِّقُ يَدِي (yuṭawwiqu yad-ī, “he holds my hand”)","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of طَاقَ (ṭāqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"alternative form of طُوغ (ṭūḡ, “horsetail”)","tags":["alt-of","alternative"]}]},"etymology":{"source":"wiktextract","text":"Byform of طَابَق (ṭābaq), طَبَق (ṭabaq). Everything else in the root ط و ق (ṭ w q) is denominal from this word. Compare the cognate Classical Syriac ܛܰܘܩܳܐ (ṭawqā, “dish”) and ܛܰܒܩܳܐ (ṭaḇqā, “dish”), and كَوْكَب (kawkab) from Proto-Semitic *kabkab-.\n\nFrom the root ط و ق (ṭ w q), denominal verb from the word above."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27331","headword_ar":"طَوْقٌ","root":"Twq","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A neck-ring;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain ornament for the neck;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"a thing well known:"},{"kind":"text","text":"(Msb:) [its most usual from is figured in my work on the Modern Egyptians, Appendix A:] pl."},{"kind":"arabic","text_bw":"A^aTowaAqN","text_ar":"اَطْوَاقٌ"},{"kind":"text","text":". (S, O, Msb, K.) It is said in a prov.,"},{"kind":"arabic","text_bw":"kabira EamorNw","text_ar":"كَبِرَ عَمْرٌو"},{"kind":"arabic","text_bw":"Eani AlT~awoqi","text_ar":"عَنِ الطَّوْقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"'Amr has become too much advanced in age for the neck-ring"},{"kind":"text","text":"]: (A 'Obeyd, O, K, TA: in some copies of the K [erroneously]"},{"kind":"arabic","text_bw":"kabura","text_ar":"كَبُرَ"},{"kind":"text","text":":) or"},{"kind":"arabic","text_bw":"$ab~a EamorNw Eani AlT~awoqi","text_ar":"شَبَّ عَمْرٌو عَنِ الطَّوْقِ"},{"kind":"text","text":", [which has the like meaning,] as in most of the books of proverbs: (TA:) applied to him who occupies himself with a thing that is beneath his ability. (K. [For the story of the origin of this prov., see Freytag's Arab. Prov. ii. 319-21, or Har pp. 502-3; as it is too long to be quoted here.]) ―         -b2-  And"},{"kind":"italic_en","text":"Anything that surrounds another thing"},{"kind":"text","text":"(Msb, K) is called its"},{"kind":"arabic","text_bw":"Tawoq","text_ar":"طَوْق"},{"kind":"text","text":". (Msb.) ―         -b3-  Hence"},{"kind":"arabic","text_bw":"*aAtu AlT~awoqi","text_ar":"ذَاتُ الطَّوْقِ"},{"kind":"text","text":"as an appel-lation of The ["},{"kind":"italic_en","text":"ringed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"pigeon"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ring-dove"},{"kind":"text","text":"]. (Msb.) ―         -b4-  [And hence] one says,"},{"kind":"arabic","text_bw":"taqal~adotu Aln~iEomapa","text_ar":"تَقَلَّدْتُ النِّعْمَةَ"},{"kind":"arabic","text_bw":"Tawoqa AlHamaAmapi","text_ar":"طَوْقَ الحَمَامَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I bore the favour as the ring of"},{"kind":"page_break","n":1895},{"kind":"italic_en","text":"the pigeon;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"as a permanent badge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decoration"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"fiY EunuqiY TawoqN maA liY biA^adaA='i $ukorihi","text_ar":"فِى عُنُقِى طَوْقٌ مَا لِى بِاَدَا=ءِ شُكْرِهِ"},{"kind":"arabic","text_bw":"TawoqN","text_ar":"طَوْقٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Upon my neck is a permanent badge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decoration, for which I have not ability to render due acknowledgment"},{"kind":"text","text":"]: so in the A: hence also the saying of El-Mutanebbee,"},{"kind":"quote","text":"A^aqaAmato fiY Alr~iqaAbi lahu A^ayaAdK\n                      \n                     \n                        hiYa AlA^aTowaAqu waAln~aAsu AlHamaAmu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Favours of his have remained upon the necks: they are the neck-rings, and the men are the pigeons"},{"kind":"text","text":"]. (TA. [See, for this verse, p. 164 of Dieterici's ed. of the Deewán of El-Mutanebbee.]) ―         -b5-"},{"kind":"arabic","text_bw":"AlT~awoqu","text_ar":"الطَّوْقُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"The neck"},{"kind":"text","text":"[itself]. (TA.) ―         -b6-  And"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"kar~","text_ar":"كَرّ"},{"kind":"text","text":", (O,) or"},{"kind":"arabic","text_bw":"HaAbuwl","text_ar":"حَابُول"},{"kind":"text","text":", (K,) [i. e. the"},{"kind":"italic_en","text":"rope in the form of a loop"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by means of which one ascends the palm-tree."},{"kind":"text","text":"(O, K. *)       -A2-  See also the next paragraph, first and second sentences."}],"source_refs":["Msb","TA","K","O"]}]},"classical_definitions":null}