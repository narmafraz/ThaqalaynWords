form":"تَرْجُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرْجَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرْجَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْجُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْجُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْجُوْنَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُرْجَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرْج","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْجُو","in_corpus":true,"count":27,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْجُو","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَجَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَجَوْتُ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرْجَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرْجَى","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":117,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n14999"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AC%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hope (“to want something to happen”)","tags":["transitive"]},{"pos":"verb","gloss":"transitive, with conjunction أَن (ʔan), to implore, to beg, to ask someone to do something.","examples":[{"text":"1980, التطاهر وطار, الحوات والقصر\nرجاه أَن يبقى يوما آخر\nrajāhu ʔan yabqā yawman ʔāḵaran","english":"He begged him to stay one more day"},{"text":"أَرْجُو مُسَاعَدَتِي.","english":"Please help me."}]}]},"etymology":null,"ipa":["/ra.d͡ʒaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14999","headword_ar":"رَجًا","root":"rjw","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"side,"},{"kind":"text","text":"(K,) in a general sense: (TA:) or the"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of a well, (S, Msb, K,) and of the sky, (Er-Rághib, TA,) and of anything; (S, Msb; *) and ↓"},{"kind":"arabic","text_bw":"rajaA='N","text_ar":"رَجَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) the"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of a well"},{"kind":"italic_en","text":"from its top to its bottom;"},{"kind":"text","text":"(TA;) and the"},{"kind":"italic_en","text":"two sides thereof:"},{"kind":"text","text":"which last is also [or properly] the meaning of the dual; which is"},{"kind":"arabic","text_bw":"rajawaAni","text_ar":"رَجَوَانِ"},{"kind":"text","text":": (S:) pl."},{"kind":"arabic","text_bw":"A^arojaA='N","text_ar":"اَرْجَا=ءٌ"},{"kind":"text","text":". (S, Msb, K.) Hence, in the Kur [lxix. 17],"},{"kind":"arabic","text_bw":"waA@lomalaku EalaY A^arojaAy^ihaA","text_ar":"وَا@لْمَلَكُ عَلَى اَرْجَايِهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The angels being at the sides thereof"},{"kind":"text","text":"]. (S, TA.) They said,"},{"kind":"arabic","text_bw":"rumiYa bihi Alr~ajawaAni","text_ar":"رُمِىَ بِهِ الرَّجَوَانِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He was cast into places of destruction:"},{"kind":"text","text":"(S:) or it is said of one who is held in mean estimation: (M, TA:)"},{"kind":"arabic","text_bw":"AisotihozaA='N","text_ar":"اِسْتِهْزَا=ءٌ"},{"kind":"text","text":"in the K is a mistake for"},{"kind":"arabic","text_bw":"Ausotuhiyna bihi","text_ar":"اُسْتُهِينَ بِهِ"},{"kind":"text","text":", the reading in the M: (TA:) as though the two [opposite] sides of the well were cast at with him. (K.) And one says of him who will not be deceived so as to be turned away from one course to another,"},{"kind":"arabic","text_bw":"laA turomaY bihi Alr~ajawaAni","text_ar":"لَا تُرْمَى بِهِ الرَّجَوَانِ"},{"kind":"text","text":"(assumed tropical:)  [lit."},{"kind":"italic_en","text":"The two sides"},{"kind":"text","text":"of the well"},{"kind":"italic_en","text":"will not be cast at with him"},{"kind":"text","text":"]; in allusion to the well's two [opposite] sides' being cast at with the bucket. (Z, TA.)"}],"source_refs":["K","TA","S","Msb","M"]}]}}