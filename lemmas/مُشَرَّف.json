{"lemma":"مُشَرَّف","slug":"مُشَرَّف","root":"ش.ر.ف","root_slug":"ش-ر-ف","root_link":"/words/roots/ش-ر-ف","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n22178","n22179","n22180","n22182"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B4%D9%8E%D8%B1%D9%8E%D9%91%D9%81"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of أَشْرَفَ (ʔašrafa)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"imminent; impending; on the verge of","examples":[{"text":"مُشْرِفٌ عَلَى السُّقُوطِ","english":"about to fall"}]},{"pos":"noun","gloss":"supervisor","examples":[{"text":"مُشْرِف اِجْتِمَاعِيّ","english":"social supervisor"}]},{"pos":"noun","gloss":"moderator (“person who enforces the rules of a discussion forum”)","tags":["Internet"]},{"pos":"adj","gloss":"passive participle of شَرَّفَ (šarrafa)","tags":["form-of","participle","passive"]},{"pos":"adj","gloss":"honoured"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of أَشْرَفَ (ʔašrafa).\n\nDerived from the passive participle of شَرَّفَ (šarrafa, “to honour”)."},"ipa":["/muʃ.rif/","/mu.ʃar.raf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22178","headword_ar":"مَشْرَفٌ","root":"$rf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":", in the middle of the paragraph: and see also what here next follows."}],"source_refs":[]},{"entry_id":"n22179","headword_ar":"مُشْرَفٌ","root":"$rf","body":[{"kind":"text","text":", (O, K,) like"},{"kind":"arabic","text_bw":"mukoramN","text_ar":"مُكْرَمٌ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"ma$orafN","text_ar":"مَشْرَفٌ","orth_type":"arrow"},{"kind":"text","text":"[q. v. voce"},{"kind":"arabic","text_bw":"$arafN","text_ar":"شَرَفٌ"},{"kind":"text","text":"], (so in my two copies of the S,)"},{"kind":"italic_en","text":"A place from which one overlooks,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"looks upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"views,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a thing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from above."},{"kind":"text","text":"(S, O, K.) ―         -b2-  Hence the saying in a trad.,"},{"kind":"arabic","text_bw":"maA jaA='aka mino h`*aA","text_ar":"مَا جَا=ءَكَ مِنْ هٰذَا"},{"kind":"arabic","text_bw":"AlmaAli waA^anota gayoru mu$orafK walaA saAy^ilK faxo*ohu","text_ar":"المَالِ وَاَنْتَ غَيْرُ مُشْرَفٍ وَلَا سَايِلٍ فَخْذْهُ"},{"kind":"text","text":"(O, TA) i. e. ["},{"kind":"italic_en","text":"What comes to thee of this property"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thou not coveting nor looking for"},{"kind":"text","text":"it ["},{"kind":"italic_en","text":"nor asking"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"take it"},{"kind":"text","text":"]. (O.)"}],"source_refs":["O","K","TA"]},{"entry_id":"n22180","headword_ar":"مُشْرِفٌ","root":"$rf","body":[{"kind":"text","text":"[part. n. of 4;]"},{"kind":"italic_en","text":"High;"},{"kind":"text","text":"(S, Mgh, Msb;)"},{"kind":"page_break","n":1539},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"overtopping;"},{"kind":"text","text":"&c.;] applied to a mountain, (S,) or a place. (Mgh, Msb.)"}],"source_refs":["S"]},{"entry_id":"n22182","headword_ar":"مُشَرَّفٌ","root":"$rf","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exalted, in rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ennobled"},{"kind":"text","text":"]; (K, TA;) an epithet applied to a man; from"},{"kind":"arabic","text_bw":"Al$~arafu","text_ar":"الشَّرَفُ"},{"kind":"text","text":". (TA.)       -A2-  Also A garment, or piece of cloth,"},{"kind":"italic_en","text":"dyed with the red clay"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth"},{"kind":"text","text":"[&c.]"},{"kind":"italic_en","text":"called"},{"kind":"arabic","text_bw":"$araf","text_ar":"شَرَف"},{"kind":"text","text":". (IAar, TA.)"}],"source_refs":[]}]},"classical_definitions":null}