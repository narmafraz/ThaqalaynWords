{"lemma":"جَهْماتٌ","slug":"جَهْماتٌ","root":"ج.ه.م","root_slug":"ج-ه-م","root_link":"/words/roots/ج-ه-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n6595","n6598","n6599"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%87%D9%92%D9%85%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6595","headword_ar":"جَهُمَ","root":"jhm","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"juhuwmapN","text_ar":"جُهُومَةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"jahaAmapN","text_ar":"جَهَامَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"became frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted, in face;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grinning in face, with a frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contraction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stern, an austere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a morose, look:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough, and contracted, and ugly, in face."},{"kind":"text","text":"(K.) ―         -b2-  Also, said of the pubes,"},{"kind":"italic_en","text":"It was coarse, rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"big."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"jahamahu","text_ar":"جَهَمَهُ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"jahimahu","text_ar":"جَهِمَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", in both instances; (K;) and ↓"},{"kind":"arabic","text_bw":"tjh~mhu","text_ar":"تجهّمهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjh~m","text_ar":"تجهّم","orth_type":"arrow"},{"kind":"text","text":"; (JK, K;)"},{"kind":"italic_en","text":"He grinned, frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looking sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely, in his face:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he met him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regarded him, with a displeasing,"},{"kind":"text","text":"(JK, K, TA,)"},{"kind":"italic_en","text":"frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grinning and frowning,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"face:"},{"kind":"text","text":"(JK, K, TA:) or ↓"},{"kind":"arabic","text_bw":"tjh~m","text_ar":"تجهّم","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he showed a sour, a crabbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an austere, face."},{"kind":"text","text":"(TK in art."},{"kind":"arabic","text_bw":"Ebs","text_ar":"عبس"},{"kind":"text","text":".) A poet says,"},{"kind":"quote","text":"↓ \n      AljahuwmaA ↓ \n      wabalodapK tajah~amu\n                      \n                     \n                        zajarotu fiyhaA EayohalFA rasuwmaA"},{"kind":"text","text":"(S, * TA,) i. e. ["},{"kind":"italic_en","text":"Many a region"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that exhibits to the impotent that which he dislikes,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"that frowns upon the weak,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impotent, I have chidden therein a strong she-camel that leaves the marks of her footsteps upon the ground."},{"kind":"text","text":"] (S.) You say also,"},{"kind":"arabic","text_bw":"AlkiraAma","text_ar":"الكِرَامَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ald~ahoru yatajah~amu","text_ar":"الدَّهْرُ يَتَجَهَّمُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Fortune frowns upon the generous"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"A^amaliY","text_ar":"اَمَلِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tajah~amaniY","text_ar":"تَجَهَّمَنِى","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"My object of hope frowned upon me"},{"kind":"text","text":"] is said when one has not attained his object of hope. (TA.)"}],"source_refs":["S","K","JK","TA"]},{"entry_id":"n6598","headword_ar":"جَهْمٌ","root":"jhm","body":[{"kind":"italic_en","text":"A coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough, and contracted, and ugly,"},{"kind":"text","text":"face; as also ↓"},{"kind":"arabic","text_bw":"jahimN","text_ar":"جَهِمٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) or, as in some of the lexicons, ↓"},{"kind":"arabic","text_bw":"jahiymN","text_ar":"جَهِيمٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"jahomu Alwajohi","text_ar":"جَهْمُ الوَجْهِ"},{"kind":"italic_en","text":"Frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted, in face;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grinning in face, with a frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contraction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stern, an austere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a morose, look:"},{"kind":"text","text":"(S, Mgh:) or"},{"kind":"italic_en","text":"coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough, in face:"},{"kind":"text","text":"(JK, TA:) applied to a man: (JK, S, Mgh, TA:) and to a lion. (JK, TA.) And [hence,]"},{"kind":"arabic","text_bw":"Aljahomu","text_ar":"الجَهْمُ"},{"kind":"italic_en","text":"The lion."},{"kind":"text","text":"(K.)       -A2-  See also"},{"kind":"arabic","text_bw":"jahuwmN","text_ar":"جَهُومٌ"},{"kind":"text","text":"."}],"source_refs":["S","Mgh","JK","TA"]},{"entry_id":"n6599","headword_ar":"جَهِمٌ","root":"jhm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jahomN","text_ar":"جَهْمٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}