sp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَطَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"وَطَأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَطَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":64,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tread","tags":["intransitive"]},{"pos":"verb","gloss":"to step on, to tread upon, to trample","tags":["transitive"]},{"pos":"verb","gloss":"to set foot in or on","tags":["transitive"]},{"pos":"verb","gloss":"to have sexual intercourse with","tags":["transitive"]}]},"etymology":null,"ipa":["/wa.tˤi.ʔa/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%88%D8%B7%D8%A6/","headword_ar":"وطئ","entries":[{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=17568#76e885","body_html":"<span class=\"title1\">و ط ئ</span><br><br><span>وطئه برجله وطأً وطئةً، ورايت موطئ قدمه ومواطئ أقدامهم، وتوطؤوه بالأقدام حتى قتلوه. قال ذو الرمة:</span><br><br><span>وإنا لحيّ ما تزال جيادنا </span><span class=\"red\">...</span><span> توطّأ أكباد الكماة وتأسر</span><br><br><span>وأوطأته دابتي حتى وطئته. ووطّات الفراش توطئة، ووطؤ وطاءة، وفراش وطئ، وما له وطاءٌ ولا غطاء، وواطأه على الأمر مواطأة، وتواطأوا عليه، وكلّ أحد يخبر عن رسول الله صلى الله تعالى عليه وسلم من غير تواطؤ. وأوطأ في شعره إيطاء وهو اتفاق القافيتين من المواطأة.</span><br><br><span>ومن المجاز: وطئهم العدوّ وطأةً منكرة. وفي الحديث: \" اللهم اشدد وطأتك على مضر \" وثبّت الله وطأته. وفلان وطئ الخلق، وقد وطؤ وطاءة، وتقول: فيه وطاءة الخلق، ووضاءة الخلق. ويقال للمضياف: موطّأ الأكتاف إذا لم ينب جنابه عن النّزل. ودابة وطيئة: بيّنة الوطاءة. وهو في عيش وطيء، وأنا أحب وطاءة العيش.</span>"}]}}