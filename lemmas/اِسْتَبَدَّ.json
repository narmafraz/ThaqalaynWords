,"in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْتَبِدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1927"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%A8%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dominate, to overpower, to overwhelm, to show authoritarianism","examples":[{"text":"...وَٱسْتَبَدَّ بِهَا الرُّعْبُ","english":"...and she was possessed by terror"}]}]},"etymology":null,"ipa":["/is.ta.bad.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1927","headword_ar":"استبدّ","root":"bd","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone; independent of others;"},{"kind":"text","text":"(S, M, L, Msb, K; in the first and last expl. by"},{"kind":"arabic","text_bw":"tafar~ada","text_ar":"تَفَرَّدَ"},{"kind":"text","text":"; and in the others, by"},{"kind":"arabic","text_bw":"Ainofarada","text_ar":"اِنْفَرَدَ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"exclusively of others;"},{"kind":"text","text":"(L;)"},{"kind":"italic_en","text":"without any to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he had none to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him:"},{"kind":"text","text":"(Msb:)"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in it;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he had it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept it, to himself, exclusively, with none to share with him in it"},{"kind":"text","text":"]: (K:) and"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in such a thing"},{"kind":"text","text":"]: (S, L:) and"},{"kind":"arabic","text_bw":"biraA^oyihi","text_ar":"بِرَاْيِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his opinion;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he followed his own opinion only, with none to agree with him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was singular in his opinion"},{"kind":"text","text":"]: (M, L:) and"},{"kind":"arabic","text_bw":"biA^amorK","text_ar":"بِاَمْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair"},{"kind":"text","text":"]: (L, Msb:) and"},{"kind":"arabic","text_bw":"biA^amorihi","text_ar":"بِاَمْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his affair"},{"kind":"text","text":"]; meaning"},{"kind":"italic_en","text":"he obtained [absolute] predominance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"control, over his affair, so that people would not hear"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"obey] any other."},{"kind":"text","text":"(A.) It is said in a trad.,"},{"kind":"arabic","text_bw":"kun~aA naray A^an~a lanaAfiYi h`*aA AlA^amori","text_ar":"كُنَّا نَرَي اَنَّ لَنَافِىِ هٰذَا الاَمْرِ"},{"kind":"arabic","text_bw":"Haq~aA faA@sotabadotumo EalayonaA","text_ar":"حَقَّا فَا@سْتَبَدْتُمْ عَلَيْنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We used to opine that we had a right"},{"kind":"text","text":"to act"},{"kind":"italic_en","text":"in this affair, and ye have been alone"},{"kind":"text","text":"the actors, predominant"},{"kind":"italic_en","text":"over us"},{"kind":"text","text":"]. (L.) And you say,"},{"kind":"arabic","text_bw":"Astbd~ AlA^amoru bifulaAnK","text_ar":"استبدّ الاَمْرُ بِفُلَانٍ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, overcame such a one, so that he could not manage it well,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thoroughly."},{"kind":"text","text":"(A.)"}],"source_refs":["Msb","K","S","L","M"]}]}}