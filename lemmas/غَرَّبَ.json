"gen":"m","num":"p"},{"role":"present_2mp","form":"تُغَرِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُغَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُغَرِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُغَرِّب","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُغَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُغَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغَرِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغَرِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"غَرَّبْتُ","in_corpus":true,"count":23,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غَرَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغَرِّب","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُغَرِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":116,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":8,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n31602","n31603","n31607","n31608","n31609","n31610"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to go away, depart, withdraw, leave"},{"pos":"verb","gloss":"to set (of the sun, moon, etc.)"},{"pos":"verb","gloss":"to be a stranger"},{"pos":"verb","gloss":"to be strange, odd, obscure, difficult to understand"},{"pos":"verb","gloss":"to go away, depart, withdraw, leave"},{"pos":"verb","gloss":"to go west, westward"},{"pos":"verb","gloss":"to banish, exile, expatriate"},{"pos":"noun","gloss":"verbal noun of غَرَبَ (ḡaraba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"west, occident"},{"pos":"noun","gloss":"vehemence, violence, tempestuousness"},{"pos":"noun","gloss":"the disease of an abscess in the canthus of the eye, lachrymal fistula","examples":[{"text":"دوسر: الماهية: حشيشة يشبه ورقها ورق الحنطة لكنه ألين وله ثمرة لها حجابان أو ثلاثة وعليها شبه الشعر وقد يتخذ منه عصارة وتحفظ وهي أفضل من حشيشه.\nالطبع: حار في الأولى يابس في الثانية.\nالأفعال والخواص: فيها تجفيف وتحليل.\nالأورام والبثور: يلين الأورام التي أخذت تصلب ويمنع صلابتها.\nالزينة: من خواصه أنه يذهب بداء الثعلب.\nأعضاء العين: ينفع من الغرب.","english":"Goatgrass: What it is: A grass the leaves of which resemble the leaves of wheat, but it is more flaccid and it has fruits with two or three envelopes and it has a kind of hair and one may extract a juice from it and it is preserved and better than the grass itself.\nIt’s trait: Hot in the first, dry in the third grade.\nEffects and properties: It is drying and dissolving.\nSwellings and pustules: It softens swellings which have become stiff and prevents their stiffening.\nToiletry: It is amongst its properties that it goes well with baldness.\nParts of the eye: It works against lacrimal fistules."}]},{"pos":"noun","gloss":"Euphrates poplar (Populus euphratica)"},{"pos":"noun","gloss":"willow (Salix spp.)","examples":[{"text":"ويغرس في المواضع الرطب الكبيرة والندوة منها النشم والغرب والصفيراء والأيرج والميس والرند ويتوخى أن يكون شجر الأترج في مواضع مستور عن الريح الجوفية والريح الغربية مكشوف للريح القبلية.","english":"One plants on moist, spacious and humid places there elms, willows, planetree maples, citrons, hackberries, and laurels, and it is to be taken care that the citron is covered from northern and western winds and open for southeastern winds."}]},{"pos":"noun","gloss":"plural of غُرَاب (ḡurāb)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From West Semitic *ḡarab-, cognate with Biblical Hebrew עֲרָבָה (ʿărāḇā́), עָרָב (ʿārāḇ, “poplar, willow”), Aramaic עַרְבָּא (ʿarəbā) / ܥܱܪܒ݂ܳܐ (ʿarəḇā), Tigre ዕርብ (ʿərb /⁠ʿərəb⁠/, “a plant with tendrils”), Soqotri ʿarhíeb, with possible further connections to Akkadian 𒌨𒁀𒌅 (ur-ba-tu, “reed, rush”), Akkadian 𒄑𒇡𒁀𒌓 (^(GIŠ)ṣar-ba-tu₂ /⁠ṣarbatu⁠/, “Euphrates Poplar”)."},"ipa":["/ɣa.ra.ba/","/ɣa.ru.ba/","/ɣar.ra.ba/","/ɣarb/","/ɣa.rab/","/ɣurb/"]}