nces":{"qac":{"found":true,"lemma_key":"فازَ","root":"فوز","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n34808","n34811"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to win"},{"pos":"verb","gloss":"to gain victory, to triumph"},{"pos":"verb","gloss":"to succeed"}]},"etymology":null,"ipa":["/faː.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34808","headword_ar":"فَازَ","root":"fwz","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafuwzu","text_ar":"يَفُوزُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fawozN","text_ar":"فَوْزٌ"},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"mafaAzN","text_ar":"مَفَازٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mafaAzapN","text_ar":"مَفَازَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He attained, acquired, gained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"won, good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good fortune,"},{"kind":"text","text":"(S, A, O, Msb, * K,) or"},{"kind":"italic_en","text":"his wish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he desired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought;"},{"kind":"text","text":"(Bd in iii. 182, and TA;)"},{"kind":"italic_en","text":"he met with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experienced, that for which one would be regarded with a wish to be in the like condition, without its being desired that it should pass away from him; he became far from what was disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he succeeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was successful: he won,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gained the victory:"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"he had his arrow drawn,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"his arrow came forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the"},{"kind":"arabic","text_bw":"ribaAbap","text_ar":"رِبَابَة"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"in the game called"},{"kind":"arabic","text_bw":"Almayosir","text_ar":"المَيْسِر"},{"kind":"text","text":": and (tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(an arrow)"},{"kind":"italic_en","text":"won;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came forth before its fellow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or fellows in that game"},{"kind":"text","text":"]. (O, * TA.) You say,"},{"kind":"arabic","text_bw":"faAza bihi","text_ar":"فَازَ بِهِ"},{"kind":"italic_en","text":"He attained it, acquired it, gained it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"won it;"},{"kind":"text","text":"(Kh, A, O, Msb, K;) namely, good, or good fortune; (Kh, O;) or reward: (A:) and"},{"kind":"italic_en","text":"he took it away, went away with it."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"italic_en","text":"He became safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure; he escaped."},{"kind":"text","text":"(S, A, O, Msb, K.) You say,"},{"kind":"arabic","text_bw":"faAza minhu","text_ar":"فَازَ مِنهُ"},{"kind":"italic_en","text":"He became safe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"secure, from it; he escaped it;"},{"kind":"text","text":"(A, O, K;) namely, evil; (TA;) or punishment. (A, O, TA.) And"},{"kind":"arabic","text_bw":"TuwbaY limano faAza biAlv~awaAbi wafaAza mina AlEiqaAbi","text_ar":"طُوبَى لِمَنْ فَازَ بِالثَّوَابِ وَفَازَ مِنَ العِقَابِ"},{"kind":"italic_en","text":"A happy end is his who gains reward and escapes punishment."},{"kind":"text","text":"(A.)       -A2-  And"},{"kind":"arabic","text_bw":"faAza","text_ar":"فَازَ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"arabic","text_bw":"yafuwzu","text_ar":"يَفُوزُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"fawozN","text_ar":"فَوْزٌ"},{"kind":"text","text":", (S, A, K,) (tropical:)"},{"kind":"italic_en","text":"He perished:"},{"kind":"text","text":"(S, A, K:)"},{"kind":"italic_en","text":"he died;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"faw~azN","text_ar":"فَوَّزٌ","orth_type":"arrow"},{"kind":"text","text":": (S, A, O, Msb, K:) thus the former bears two contr. significations: (A, K:) but IB says that, accord. to some, the latter is not used in this sense unless preceded by another phrase such as in the following ex.:"},{"kind":"arabic","text_bw":"fulaAnN baEodahu","text_ar":"فُلَانٌ بَعْدَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maAta fulaAnN wafaw~aza","text_ar":"مَاتَ فُلَانٌ وَفَوَّزَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one died and such a one died after him"},{"kind":"text","text":"]: and accord. to others, ↓"},{"kind":"arabic","text_bw":"fw~z","text_ar":"فوّز","orth_type":"arrow"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"he became in the"},{"kind":"arabic","text_bw":"mafaAzap","text_ar":"مَفَازَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"state of"},{"kind":"text","text":"temporary"},{"kind":"italic_en","text":"safety"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which is between the present life and that which is to come."},{"kind":"text","text":"(TA.) [This last signification is given in the A.] ―         -b2-  See also 2."}],"source_refs":["S","A","O","Msb","K","TA"]},{"entry_id":"n34811","headword_ar":"فَازٌ","root":"fwz","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%A7%D8%B2/","headword_ar":"فاز","entries":[{"lexicon_id":"dictionary_39","lexicon_en":"ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)","lexicon_ar":"غريب القرآن في شعر العرب لعبد الله بن عباس","permalink":"https://arabiclexicon.hawramani.com/?p=61128#b6a44f","body_html":"<span class=\"title1\">ف وز [فاز]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: فَقَدْ فازَ .</span><br><span>قال: يعني فقد سعد ونجا.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت عبد الله بن رواحة وهو يقول:</span><br><span>وعسى أن أفوز ثمّ ألقّى </span><span class=\"red\">...</span><span> حجة التّقى بها الفتانا </span>"}]}}