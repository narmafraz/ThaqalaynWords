","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفَرِّخُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفَرِّخْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفَرِّخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفَرِّخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفَرِّخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفَرِّخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفَرِّخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفَرِّخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفَرِّخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفَرِّخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفَرِّخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفَرِّخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفَرِّخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"فَرَّخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَرَّخْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n33414","n33418","n33419"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D9%91%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"chick, young bird"},{"pos":"noun","gloss":"sprout (of a plant)"},{"pos":"verb","gloss":"to have chicks (of birds)"},{"pos":"verb","gloss":"to hatch, to incubate"},{"pos":"verb","gloss":"to germinate, to sprout"}]},"etymology":{"source":"wiktextract","text":"From the root ف ر خ (f r ḵ). Cognate with Hebrew פֶּרַח (péraḥ, “flower”), אֶפְרוֹחַ ('efróakh, “a bird chick”), and פָּרַח (pāraḥ, “to bloom”); Aramaic פְּרַח, ܦܪܰܚ (pəraḥ, “to fly”), Ge'ez ፈርኅ (färḫ, “chick”), ፈርኀ (färḫä, “to sprout, to germinate”), Akkadian 𒉺𒊏𒄷 (/⁠parāḫu⁠/, “to sprout, to germinate”)."},"ipa":["/farx/","/far.ra.xa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33414","headword_ar":"فَرِخَ","root":"frx","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"faraxN","text_ar":"فَرَخٌ"},{"kind":"text","text":", (TK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"became free from fright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fear, and at ease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm."},{"kind":"text","text":"(K.) [See also 4.] ―         -b2-  And"},{"kind":"arabic","text_bw":"farixa A_ilaY AlA^aroDi","text_ar":"فَرِخَ اـِلَى الاَرْضِ"},{"kind":"italic_en","text":"He clave to the ground;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"fr~x","text_ar":"فرّخ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["K","TK"]},{"entry_id":"n33418","headword_ar":"فَرْخٌ","root":"frx","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"young one of a bird:"},{"kind":"text","text":"(S, A, Mgh, L, K:) this is the primary signification: (L:) or,"},{"kind":"italic_en","text":"of any creature that lays eggs:"},{"kind":"text","text":"(Msb:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, A:) and, (L, K,) sometimes, (L,) the"},{"kind":"italic_en","text":"young one of any animal:"},{"kind":"text","text":"(L, K:) pl. (of pauc., S, L)"},{"kind":"arabic","text_bw":"A^aforuxN","text_ar":"اَفْرُخٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aforaAxN","text_ar":"اَفْرَاخٌ"},{"kind":"text","text":"(S, Mgh, L, Msb, K) and"},{"kind":"arabic","text_bw":"A^aforixapN","text_ar":"اَفْرِخَةٌ"},{"kind":"text","text":", (L, K,) the last of which is extr. [with respect to rule], (IAar,) and (of mult., S, L)"},{"kind":"arabic","text_bw":"firaAxN","text_ar":"فِرَاخٌ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"firoxaAnN","text_ar":"فِرْخَانٌ"},{"kind":"text","text":"(L, Msb, K) and"},{"kind":"arabic","text_bw":"furuwxN","text_ar":"فُرُوخٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"furuxN","text_ar":"فُرُخٌ"},{"kind":"text","text":". (L.) [See an ex. (from a poet) in which"},{"kind":"arabic","text_bw":"firaAx","text_ar":"فِرَاخ"},{"kind":"text","text":"is treated grammatically as a sing. in the first paragraph of art."},{"kind":"arabic","text_bw":"xlf","text_ar":"خلف"},{"kind":"text","text":".] ―         -b2-  [Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"A base, a vile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abject, man, who is driven away."},{"kind":"text","text":"(K.) And one says,"},{"kind":"arabic","text_bw":"fulAanN faroxN mina","text_ar":"فُلاَنٌ فَرْخٌ مِنَ"},{"kind":"arabic","text_bw":"AlfiraAxi","text_ar":"الفِرَاخِ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"mn Alfuruwxi","text_ar":"من الفُرُوخِ"},{"kind":"text","text":", (so in two copies of the A,) meaning (tropical:)"},{"kind":"italic_en","text":"Such a one is a bastard:"},{"kind":"text","text":"(A, TA:) said by El-Khafájee to be a phrase of the people of El-Medeeneh, peculiarly; but accord. to MF, it is a post-classical phrase common in El-Hijáz. (TA.) ―         -b3-  And (tropical:)"},{"kind":"italic_en","text":"A sucker, an offset,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a sprout, of any plant"},{"kind":"text","text":"(L, K) or"},{"kind":"italic_en","text":"tree &c.:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"a branch"},{"kind":"text","text":"of a tree: or, as some say,"},{"kind":"italic_en","text":"a branch that is in the middle"},{"kind":"text","text":"of a tree: (Ham p. 347:) or [its pl.]"},{"kind":"arabic","text_bw":"firaAxN","text_ar":"فِرَاخٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"offsets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shoots, from the roots"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stems"},{"kind":"text","text":"of trees: (A:) and this is also said to signify"},{"kind":"italic_en","text":"worms that are in herbs."},{"kind":"text","text":"(Ham p. 491.) And (tropical:)"},{"kind":"italic_en","text":"Seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, shooting forth into leaf from the grain, when the latter has cloven"},{"kind":"page_break","n":2363},{"kind":"italic_en","text":"asunder:"},{"kind":"text","text":"(Lth, TA:) or,"},{"kind":"italic_en","text":"ready to cleave open,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"when it has come up:"},{"kind":"text","text":"(S:) or,"},{"kind":"italic_en","text":"when it has shoots."},{"kind":"text","text":"(L.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Alfaroxu","text_ar":"الفَرْخُ"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"The fore part of the brain;"},{"kind":"text","text":"(K, TA;) thus called by way of comparison [to the young one of a bird], in like manner as it is called"},{"kind":"arabic","text_bw":"AlEuSofuwru","text_ar":"العُصْفُورُ"},{"kind":"text","text":"; (TA;) or the"},{"kind":"arabic","text_bw":"ESfwr","text_ar":"عصفور"},{"kind":"text","text":"is beneath the"},{"kind":"arabic","text_bw":"farox","text_ar":"فَرْخ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"ESfr","text_ar":"عصفر"},{"kind":"text","text":":) the pl. is"},{"kind":"arabic","text_bw":"firaAxN","text_ar":"فِرَاخٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Alfaroxu","text_ar":"الفَرْخُ"},{"kind":"text","text":"signifies [also, particularly,]"},{"kind":"italic_en","text":"the fore part of the brain of the horse."},{"kind":"text","text":"(TA in the present art.) In the saying of ElFarezdak,"},{"kind":"quote","text":"wayawoma jaEalonaA AlbiyDa fiyohi liEaAmirK\n                      \n                     \n                        muSam~imapF tafoA^aY firaAxa AljamaAjimi"},{"kind":"text","text":"he means ["},{"kind":"italic_en","text":"And a day in which we made the swords, penetrating into that which they smote, cleave"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the brains"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"brain"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Ald~maAg","text_ar":"الدّمَاغ"},{"kind":"text","text":") of the tribe"},{"kind":"italic_en","text":"of 'Ámir"},{"kind":"text","text":"]. (S, TA.)"}],"source_refs":["S","A","Mgh","L","K","Msb","IAar","TA","Lth"]},{"entry_id":"n33419","headword_ar":"فَرِخٌ","root":"frx","body":[{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"katifN","text_ar":"كَتِفٌ"},{"kind":"text","text":", (assumed tropical:)  A man"},{"kind":"italic_en","text":"whose grounds of pretension to respect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honour, are suspected."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]},"classical_definitions":null}