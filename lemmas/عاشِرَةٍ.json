xt_ar":"عَوَاشِرُ"},{"kind":"text","text":". (S, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EawaA$iru AlquroA=ni","text_ar":"عَوَاشِرُ القُرْا=نِ"},{"kind":"text","text":"means The"},{"kind":"italic_en","text":"verses that complete an"},{"kind":"arabic","text_bw":"Ea$or","text_ar":"عَشْر"},{"kind":"italic_en","text":"of the Kur-án."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"A_ibilN EawaA$iru","text_ar":"اـِبِلٌ عَوَاشِرُ"},{"kind":"italic_en","text":"Camels coming to water after an interval of eight days;"},{"kind":"text","text":"(S, O;)"},{"kind":"italic_en","text":"on the tenth day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"counting the day of the next preceding watering as the first"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"on the ninth day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"not counting the day of the next preceding watering:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"Ei$orN","text_ar":"عِشْرٌ"},{"kind":"text","text":"]. (K.)       -A2-  For another signification of the pl.,"},{"kind":"arabic","text_bw":"EawaA$iru","text_ar":"عَوَاشِرُ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"Ei$oru","text_ar":"عِشْرُ"},{"kind":"text","text":", last sentence.       -A3-"},{"kind":"arabic","text_bw":"EaA$irapu","text_ar":"عَاشِرَةُ"},{"kind":"text","text":"is a proper name of"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"DabuE","text_ar":"ضَبُع"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"hyena,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"female hyena"},{"kind":"text","text":"]; a determinate noun: [but it has for] pl."},{"kind":"arabic","text_bw":"EaA$iraAtN","text_ar":"عَاشِرَاتٌ"},{"kind":"text","text":". (O.)"}],"source_refs":["O","L","K"]}]},"classical_definitions":null}