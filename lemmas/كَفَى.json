corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَفَيْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":109,"cross_references":{"qac":{"found":true,"lemma_key":"كَفَى","root":"كفي","pos":"V","occurrence_count":32},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n43077"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D9%81%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43077","headword_ar":"كَفَى","root":"kfY","body":[{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, sufficed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented:"},{"kind":"text","text":"hence"},{"kind":"arabic","text_bw":"kafaAniY fulaAnN AlA^amora","text_ar":"كَفَانِى فُلَانٌ الاَمْرَ"},{"kind":"italic_en","text":"Such a one sufficed me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented me, in respect of the affair;"},{"kind":"text","text":"i. e., by taking upon himself to perform it or accomplish it if good, or to prevent it or avert it if evil: and"},{"kind":"arabic","text_bw":"kafaAniY $ahiydFA","text_ar":"كَفَانِى شَهِيدًا"},{"kind":"italic_en","text":"He sufficed me as,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, a witness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he suffices me as,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, such:"},{"kind":"text","text":"and sometimes"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"is redundantly prefixed to its agent, and sometimes to its objective complement; as in exs. cited in art."},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":". See Ham, p. 152."},{"kind":"arabic","text_bw":"kafaY","text_ar":"كَفَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It sufficed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it stood instead of another thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other things;"},{"kind":"text","text":"(Msb;) [as also"},{"kind":"arabic","text_bw":"kafaY Eano gayorihi","text_ar":"كَفَى عَنْ غَيْرِهِ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"kafaY binaA","text_ar":"كَفَى بِنَا"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"kafaAnaA","text_ar":"كَفَانَا"},{"kind":"text","text":"&c. See W, pp. 5 and 6 ―         -b3-"},{"kind":"arabic","text_bw":"kafaY","text_ar":"كَفَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakofiY","text_ar":"يَكْفِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kifaAyapN","text_ar":"كِفَايَةٌ"},{"kind":"text","text":", also signifies"},{"kind":"arabic","text_bw":"dafaEa","text_ar":"دَفَعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"manaEa","text_ar":"مَنَعَ"},{"kind":"text","text":"followed by"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":". (Har, p. 43, q. v.) [You say,"},{"kind":"arabic","text_bw":"kafaAhu Al$~ar~a","text_ar":"كَفَاهُ الشَّرَّ"},{"kind":"italic_en","text":"He repelled from him evil;"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"he defended him therefrom;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he freed him therefrom:"},{"kind":"text","text":"said of God, and of a man, &c.]"}],"source_refs":[]}]}}