},{"role":"present_2mp","form":"تَخْضَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْضَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْضَب","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْضَب","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْضَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْضَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْضَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْضَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْضَبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْضَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْضَبْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَضِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَضِبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْضَب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْضَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n10839","","n10840"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B6%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dye, to tinge, to imbue with color"},{"pos":"verb","gloss":"to become green (twigs)"},{"pos":"verb","gloss":"to dye thoroughly, to tinge, to imbue with color"},{"pos":"noun","gloss":"verbal noun of خَضَبَ (ḵaḍaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of خِضَاب (ḵiḍāb, “dye, pigment”)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10839","headword_ar":"خَضَبَ","root":"xDb","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xaDobN","text_ar":"خَضْبٌ"},{"kind":"text","text":"(S, Msb) [and accord. to MF"},{"kind":"arabic","text_bw":"xiDaAbN","text_ar":"خِضَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuDuwbN","text_ar":"خُضُوبٌ"},{"kind":"text","text":", but respecting these two inf. ns. (the latter of which seems to be peculiar to the intrans. verb"},{"kind":"arabic","text_bw":"xaDaba","text_ar":"خَضَبَ"},{"kind":"text","text":") see what follows],"},{"kind":"italic_en","text":"He coloured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tinged,"},{"kind":"text","text":"(A, K,) a thing; (S, A, * K; *) or"},{"kind":"italic_en","text":"changed"},{"kind":"text","text":"it in colour to red, or yellow, &c.; (TA;) and ↓"},{"kind":"arabic","text_bw":"xD~b","text_ar":"خضّب","orth_type":"arrow"},{"kind":"text","text":"signifies the same, [but app. in an intensive sense, or as applying to a number of objects, (see its pass. part. n. voce"},{"kind":"arabic","text_bw":"xaDiybN","text_ar":"خَضِيبٌ"},{"kind":"text","text":",)] (K,) inf. n."},{"kind":"arabic","text_bw":"taxoDiybN","text_ar":"تَخْضِيبٌ"},{"kind":"text","text":": (TA:) and the former, particularly,"},{"kind":"italic_en","text":"he tinged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dyed,"},{"kind":"text","text":"his white hair, (TA,) or the hand, &c., (Msb,) with hinnà: (Msb, TA:) but when a man has dyed his hair with any other dye than hinnà, you say,"},{"kind":"arabic","text_bw":"Sabaga","text_ar":"صَبَغَ"},{"kind":"arabic","text_bw":"$aEarahu","text_ar":"شَعَرَهُ"},{"kind":"text","text":": (Msb, TA:) or you say also,"},{"kind":"arabic","text_bw":"xaDaba biAls~awaAdi","text_ar":"خَضَبَ بِالسَّوَادِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He dyed"},{"kind":"text","text":"his hair"},{"kind":"italic_en","text":"with black"},{"kind":"text","text":"]. (Suh, TA.) When one does not mention the hair (Msb, TA) or the white hair [&c.], (Msb,) he says"},{"kind":"arabic","text_bw":"xaDaba","text_ar":"خَضَبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xiDaAbN","text_ar":"خِضَابٌ"},{"kind":"text","text":"; (IKtt, Msb;) and ↓"},{"kind":"arabic","text_bw":"AxtDb","text_ar":"اختضب","orth_type":"arrow"},{"kind":"text","text":", (S, IKtt, Msb, TA,) and ↓"},{"kind":"arabic","text_bw":"txD~b","text_ar":"تخضّب","orth_type":"arrow"},{"kind":"text","text":"; (A, TA;) [meaning"},{"kind":"italic_en","text":"He dyed his hair,"},{"kind":"text","text":"&c.,] with hinnà, (S, IKtt, Msb, TA,) and the like: (S, TA:) and in like manner one says of a woman,"},{"kind":"arabic","text_bw":"xaDabato","text_ar":"خَضَبَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AxtDb","text_ar":"اختضب","orth_type":"arrow"},{"kind":"text","text":": (TA:) which last also signifies [particularly]"},{"kind":"italic_en","text":"She dyed her hands"},{"kind":"text","text":"with hinnà. (T, TS, TA, in art."},{"kind":"arabic","text_bw":"gms","text_ar":"غمس"},{"kind":"text","text":".) ―         -b2-  Hence, in a trad.,"},{"kind":"arabic","text_bw":"bakaY Hat~aY xaDaba damoEuhu AlHaSaY","text_ar":"بَكَى حَتَّى خَضَبَ دَمْعُهُ الحَصَى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He wept so that his tears wetted the pebbles:"},{"kind":"text","text":"or, more probably,"},{"kind":"italic_en","text":"so that his tears became red, and dyed the pebbles:"},{"kind":"text","text":"(IAth, TA:) [or most probably,"},{"kind":"italic_en","text":"so that his tears caused the pebbles to appear of a reddish colour;"},{"kind":"text","text":"for such is commonly the case when pebbles are wetted.]       -A2-"},{"kind":"arabic","text_bw":"xaDaba","text_ar":"خَضَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"xaDiba","text_ar":"خَضِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"xuDiba","text_ar":"خُضِبَ"},{"kind":"text","text":"; inf. n. of each"},{"kind":"arabic","text_bw":"xuDuwbN","text_ar":"خُضُوبٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AxDwDb","text_ar":"اخضوضب","orth_type":"arrow"},{"kind":"text","text":"; (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a tree)"},{"kind":"italic_en","text":"became green."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"xaDaba","text_ar":"خَضَبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuDuwbN","text_ar":"خُضُوبٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"Its small leaves came forth in the spring, and its twigs lengthened;"},{"kind":"text","text":"said of the"},{"kind":"arabic","text_bw":"qataAd","text_ar":"قَتَاد"},{"kind":"text","text":", at the commencement of its vegetation; and likewise of the"},{"kind":"arabic","text_bw":"Earofaj","text_ar":"عَرْفَج"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eawosaj","text_ar":"عَوْسَج"},{"kind":"text","text":"; but of no other tree of the kind called"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":": or said also of the"},{"kind":"arabic","text_bw":"EurofuT","text_ar":"عُرْفُط"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samur","text_ar":"سَمُر"},{"kind":"text","text":"; meaning (assumed tropical:)"},{"kind":"italic_en","text":"it dropped its leaves, and became red and yellow:"},{"kind":"text","text":"(TA:) and you say also,"},{"kind":"arabic","text_bw":"xaDabati","text_ar":"خَضَبَتِ"},{"kind":"arabic","text_bw":"AlEiDaAhu","text_ar":"العِضَاهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"EDAh","text_ar":"عضاه"},{"kind":"italic_en","text":"became green, and broke forth;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"the sap of the"},{"kind":"arabic","text_bw":"EDAh","text_ar":"عضاه"},{"kind":"italic_en","text":"flowed in their branches, and they became green;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^axoDabato","text_ar":"اَخْضَبَتْ","orth_type":"arrow"},{"kind":"text","text":", (TA,) for which"},{"kind":"arabic","text_bw":"AxSbt","text_ar":"اخصبت"},{"kind":"text","text":", with the unpointed"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":", is said by Az to be a gross mistranscription; explained by Lth, on whose authority it is written with"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":", [as also in the K in art."},{"kind":"arabic","text_bw":"xSb","text_ar":"خصب"},{"kind":"text","text":",] as meaning"},{"kind":"italic_en","text":"the sap flowed in the branches of the"},{"kind":"arabic","text_bw":"EDAh","text_ar":"عضاه"},{"kind":"italic_en","text":"so as to reach the roots."},{"kind":"text","text":"(T and TA in art."},{"kind":"arabic","text_bw":"xSb","text_ar":"خصب"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"xaSaba Aln~axolu","text_ar":"خَصَبَ النَّخْلُ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"xaDobN","text_ar":"خَضْبٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"The palm-trees,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"the spadices of the palm-trees,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"became green."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"xaDabati AlA^aroDu","text_ar":"خَضَبَتِ الاَرْضُ"},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"xaDobN","text_ar":"خَضْبٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AxDbt","text_ar":"اخضبت","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_ixoDaAbN","text_ar":"اـِخْضَابٌ"},{"kind":"text","text":"; (TA;) or ↓"},{"kind":"arabic","text_bw":"AxtDbt","text_ar":"اختضبت","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"txD~bt","text_ar":"تخضّبت","orth_type":"arrow"},{"kind":"text","text":"; (A;)"},{"kind":"italic_en","text":"The earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land, exposed to view,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"produced,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"its herbage,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"and it"},{"kind":"text","text":"(the latter)"},{"kind":"italic_en","text":"became green."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","A","Msb","K","TA","IKtt","IAth"]},{"entry_id":"n10840","headword_ar":"خَضْبٌ","root":"xDb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"colour of a tree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the spadix of a palm-tree, when it becomes green:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"xuDuwbN","text_ar":"خُضُوبٌ"},{"kind":"text","text":". (K.) ―         -b2-  A plant"},{"kind":"italic_en","text":"fresh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"new, and green in consequence of rain;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xaDuwbN","text_ar":"خَضُوبٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"watered by rain, and imparting a colour to the ordure:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"green colour that appears in trees when they begin to put forth their leaves:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"xuDuwbN","text_ar":"خُضُوبٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["K","TA"]}]}}