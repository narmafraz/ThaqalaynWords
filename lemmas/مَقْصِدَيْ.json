{"lemma":"مَقْصِدَيْ","slug":"مَقْصِدَيْ","root":"ق.ص.د","root_slug":"ق-ص-د","root_link":"/words/roots/ق-ص-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n35760","n35761","n35762","n35765","n35766"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%82%D9%92%D8%B5%D9%90%D8%AF%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"direction, trend, drift","examples":[{"text":"مَقْصِدِي مَكَّةُ","english":"I'm heading towards Mecca."}]},{"pos":"noun","gloss":"purpose, goal, aim, destination"},{"pos":"noun","gloss":"verbal noun of قَصَدَ (qaṣada) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Noun of place from قَصَدَ (qaṣada, “to aim at, to have as a goal”)."},"ipa":["/maq.sˤid/","/maq.sˤad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35760","headword_ar":"مَقْصِدٌ","root":"qSd","body":[{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":","},{"kind":"italic_en","text":"A place to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, which one tends, repairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betakes himself; to which one directs his course; at which one aims; which one seeks, pursues, endeavours to reach, desires,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wishes for;"},{"kind":"text","text":"[pl."},{"kind":"arabic","text_bw":"maqaASidu","text_ar":"مَقَاصِدُ"},{"kind":"text","text":".] Ex."},{"kind":"arabic","text_bw":"lahu maqoSidN maEay~anN","text_ar":"لَهُ مَقْصِدٌ مَعَيَّنٌ"},{"kind":"italic_en","text":"He has a specified place to which,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards which, he tends,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repairs, &c."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"baAbuka maqoSidiY","text_ar":"بَابُكَ مَقْصِدِى"},{"kind":"italic_en","text":"Thy door,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gate, is the place to which,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards which, I tend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repair, &c."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"maqaASidu AlT~aruqi","text_ar":"مَقَاصِدُ الطَّرُقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The right places to which roads tend"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"maraA$iduhaA","text_ar":"مَرَاشِدُهَا"},{"kind":"text","text":". (S, L, K, art."},{"kind":"arabic","text_bw":"r$d","text_ar":"رشد"},{"kind":"text","text":".) See also"},{"kind":"arabic","text_bw":"maqoSadN","text_ar":"مَقْصَدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n35761","headword_ar":"مُقْصَدٌ","root":"qSd","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"who falls sick and quickly dies."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n35762","headword_ar":"مُقْصِدٌ","root":"qSd","body":[{"kind":"text","text":"[One"},{"kind":"italic_en","text":"who composes poems of the kind termed"},{"kind":"arabic","text_bw":"qaSaAy^id","text_ar":"قَصَايِد"},{"kind":"text","text":": see 4: also,] and ↓"},{"kind":"arabic","text_bw":"muqaS~idN","text_ar":"مُقَصِّدٌ","orth_type":"arrow"},{"kind":"text","text":", one"},{"kind":"italic_en","text":"who continues uninterruptedly, and prolongs, the composition of poems of the kind termed"},{"kind":"arabic","text_bw":"qSAy^d","text_ar":"قصايد"},{"kind":"text","text":". (M, L.)"}],"source_refs":[]},{"entry_id":"n35765","headword_ar":"مُقَصَّدٌ","root":"qSd","body":[{"kind":"text","text":"(tropical:)  A man"},{"kind":"italic_en","text