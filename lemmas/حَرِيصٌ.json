ind":"arabic","text_bw":"HuraSaA='u","text_ar":"حُرَصَا=ءُ"},{"kind":"text","text":", (K,) which is masc., (TA,) and"},{"kind":"arabic","text_bw":"HaraAy^iSu","text_ar":"حَرَايِصُ"},{"kind":"text","text":", fem. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Excessively solicitous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"careful, and fearful,"},{"kind":"text","text":"respecting a person; and"},{"kind":"italic_en","text":"excessively pitiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassionate."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"HariySN Ealayokumo","text_ar":"حَرِيصٌ عَلَيْكُمْ"},{"kind":"text","text":", in the Kur [ix. 129], means ["},{"kind":"italic_en","text":"Vehemently desirous,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"of profiting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefiting, you:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively soli-"},{"kind":"page_break","n":548},{"kind":"italic_en","text":"citous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"careful, and fearful, respecting you;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"excessively pitiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassionate, to you."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","A","L","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AD%D8%B1%D9%8A%D8%B5/","headword_ar":"حريص","entries":[{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=10951#951614","body_html":"<span class=\"title1\">[حريص]</span><span> يقال: ما عليها حربصيصة ولا خربصيصة، أي شئ من الحلى.</span>"}]}}