es_definition":{"source":"lanes","entries":[{"entry_id":"n9093","headword_ar":"حَمَزَ","root":"Hmz","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HamozN","text_ar":"حَمْزٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(milk)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sour,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to burn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bite, the tongue;"},{"kind":"text","text":"and so, app.,"},{"kind":"arabic","text_bw":"Hamuza","text_ar":"حَمُزَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HamaAzapN","text_ar":"حَمَازَةٌ"},{"kind":"text","text":"; (see"},{"kind":"arabic","text_bw":"HamozN","text_ar":"حَمْزٌ"},{"kind":"text","text":", below;) or]"},{"kind":"italic_en","text":"in a less degree than such as is termed"},{"kind":"arabic","text_bw":"HaAzirN","text_ar":"حَازِرٌ"},{"kind":"text","text":". (TA.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"Hamuza","text_ar":"حَمُزَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HamaAzpN","text_ar":"حَمَازةٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strong, robust, sturdy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hardy."},{"kind":"text","text":"(S, * K, * TA.)       -A2-"},{"kind":"arabic","text_bw":"Hamaza All~isaAna","text_ar":"حَمَزَ اللِّسَانَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(beverage, or wine,)"},{"kind":"italic_en","text":"stung,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bit, the tongue:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(milk, and"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"burned the tongue by its strength and sharpness."},{"kind":"text","text":"(Mgh.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Hamazahu","text_ar":"حَمَزَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"HamozN","text_ar":"حَمْزٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He took it, seized"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grasped it, contracted it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew it together;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qabaDahu","text_ar":"قَبَضَهُ"},{"kind":"text","text":", (K, * TA,) and"},{"kind":"arabic","text_bw":"Dam~ahu","text_ar":"ضَمَّهُ"},{"kind":"text","text":". (TA.) See"},{"kind":"arabic","text_bw":"HamuwzN","text_ar":"حَمُوزٌ"},{"kind":"text","text":". You say,"},{"kind":"arabic","text_bw":"Hamazati Alkalimapu fuw^aAdahu","text_ar":"حَمَزَتِ الكَلِمَةُ فُوَادَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The saying contracted his heart,"},{"kind":"text","text":"(Lh, A, TA,)"},{"kind":"italic_en","text":"and grieved him,"},{"kind":"text","text":"(Lh, TA,) or"},{"kind":"italic_en","text":"pained him."},{"kind":"text","text":"(TA.) ―         -b3-  Also, (A, TA,) aor. as above, (TA,) and so the inf. n., (K,) (tropical:)"},{"kind":"italic_en","text":"He sharpened it;"},{"kind":"text","text":"(A, K, * TA;) namely, an iron instrument, (TA,) an arrow-head or the like. (A.) So in the dial. of Hudheyl. (TA.)"}],"source_refs":["S","K","TA","Lh","A"]}]}}