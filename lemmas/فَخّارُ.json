{"lemma":"فَخّارُ","slug":"فَخّارُ","root":"ف.خ.ر","root_slug":"ف-خ-ر","root_link":"/words/roots/ف-خ-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"فَخّار","root":"فخر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n33203","n33206"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AE%D9%91%D8%A7%D8%B1%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"pottery, earthenware","examples":[{"text":"خَلَقَ الْإِنْسَانَ مِن صَلْصَالٍ كَالْفَخَّارِ","english":"He created man from clay as of pottery."}]},{"pos":"noun","gloss":"potter, crocker","tags":["rare"]}]},"etymology":{"source":"wiktextract","text":"From Aramaic פחרא / ܦܚܪܐ (paḥḥārā), from Akkadian 𒁃 (BAḪAR₂ /⁠paḫāru⁠/)."},"ipa":["/fax.xaːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33203","headword_ar":"فَخَارٌ","root":"fxr","body":[{"kind":"text","text":"[said in the Msb to be a simple subst.: see 1]."}],"source_refs":[]},{"entry_id":"n33206","headword_ar":"فَخَّارٌ","root":"fxr","body":[{"kind":"italic_en","text":"Baked pottery; baked vessels of clay:"},{"kind":"text","text":"(Msb, voce"},{"kind":"arabic","text_bw":"xazafN","text_ar":"خَزَفٌ"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"baked clay:"},{"kind":"text","text":"before it is baked, it is called"},{"kind":"arabic","text_bw":"xazafN","text_ar":"خَزَفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SaloSaAlN","text_ar":"صَلْصَالٌ"},{"kind":"text","text":": (Msb in the present art.:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xazafN","text_ar":"خَزَفٌ"},{"kind":"text","text":": (S, O, K:) or"},{"kind":"italic_en","text":"a kind of"},{"kind":"arabic","text_bw":"xazaf","text_ar":"خَزَف"},{"kind":"italic_en","text":"of which earthen vessels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jars, mugs, &c., are made:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"earthen vessels; vessels made of potters' clay:"},{"kind":"text","text":"pl. of [or rather a coll. gen. n. of which the n. un. is]"},{"kind":"arabic","text_bw":"fax~aArapN","text_ar":"فَخَّارَةٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","O","K","TA"]}]}}