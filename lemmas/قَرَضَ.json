s=%D9%82%D9%8E%D8%B1%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gnaw, nibble, to cut a bit from the outer"},{"pos":"verb","gloss":"to impart, reward"},{"pos":"verb","gloss":"to lend money"},{"pos":"verb","gloss":"to recite"},{"pos":"verb","gloss":"to swerve to the right and left in walking"},{"pos":"verb","gloss":"to depart from","tags":["transitive"],"examples":[{"text":"وَإِذَا غَرَبَت تَّقْرِضُهُمْ ذَاتَ الشِّمَالِ","english":"as it set, declining away from them to the left."}]},{"pos":"verb","gloss":"to die, be on the point of death"},{"pos":"verb","gloss":"to die"},{"pos":"verb","gloss":"to pass from one thing to another"},{"pos":"verb","gloss":"to gnaw, to cut in the exterior"},{"pos":"verb","gloss":"to exalt with praise"},{"pos":"verb","gloss":"to blame"},{"pos":"noun","gloss":"verbal noun of قَرَضَ (qaraḍa, “to cut”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"cutting"},{"pos":"noun","gloss":"gnawing, nibbling"},{"pos":"noun","gloss":"loan, debt"},{"pos":"noun","gloss":"verbal noun of قَرِضَ (qariḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of قَرُضَ (qaruḍa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35505","headword_ar":"قَرْضٌ","root":"qrD","body":[{"kind":"text","text":"(S, M, A, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"qiroDN","text_ar":"قِرْضٌ","orth_type":"arrow"},{"kind":"text","text":"; (Ks, S, M, K;) or, accord. to Th, the former is an inf. n., and the latter a simple subst., but this [says ISd] does not please me; (M;) or the former is an inf. n. used as a subst.; (Mgh;) or a subst. from"},{"kind":"arabic","text_bw":"A^aqoraDotuhu AlmaAla","text_ar":"اَقْرَضْتُهُ المَالَ"},{"kind":"text","text":"; (Msb;) ["},{"kind":"italic_en","text":"A loan:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a piece of property which a man cuts off from his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"articles of property, and which, itself, he receives back;"},{"kind":"text","text":"[in rendering the explanation in the Mgh, for the words"},{"kind":"arabic","text_bw":"fayuEoTiyh EynFA","text_ar":"فَيُعْطِيه عينًا"},{"kind":"text","text":"in my copy of that work; I read"},{"kind":"arabic","text_bw":"fayuqoDaAhu EayonFA","text_ar":"فَيُقْضَاهُ عَيْنًا"},{"kind":"text","text":", which makes this agreeable with explanations given in other works;] but what is due to the one from the other as a debt is not so called; (Mgh, [see"},{"kind":"arabic","text_bw":"dayonN","text_ar":"دَيْنٌ"},{"kind":"text","text":";])"},{"kind":"italic_en","text":"what one gives,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"to another,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"of property,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"to receive it back,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"to demand it back:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a thing that one gives to be requited for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to receive it back:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"frD","text_ar":"فرض"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"a thing of which men demand the payment"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"restitution"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"one of another:"},{"kind":"text","text":"(M, L:) or"},{"kind":"italic_en","text":"a thing which a man gives,"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"does, to be requited for it:"},{"kind":"text","text":"(Aboo-Is-hák the Grammarian, and TA:) pl."},{"kind":"arabic","text_bw":"quruwDN","text_ar":"قُرُوضٌ"},{"kind":"text","text":". (M, Msb.) You say,"},{"kind":"arabic","text_bw":"Ealayohi qaroDN","text_ar":"عَلَيْهِ قَرْضٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He owes a loan"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"quruwDN","text_ar":"قُرُوضٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"loans"},{"kind":"text","text":"]. (A.) ―         -b2-  Hence, (S, TA,) (tropical:)"},{"kind":"italic_en","text":"What one does, in order to be requited it, of good,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of evil."},{"kind":"text","text":"(S, K, TA.) See three exs. above, under 4. The Arabs also say,"},{"kind":"arabic","text_bw":"qado A^aHosanota qaroDiY","text_ar":"قَدْ اَحْسَنْتَ قَرْضِى"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Thou hast done to me a good deed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which I am bound to requite"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"laka EinodiY qaroDN HasanN","text_ar":"لَكَ عِنْدِى قَرْضٌ حَسَنٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qaroDN say~iy^N","text_ar":"قَرْضٌ سَيِّيٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I owe thee a good deed, and an evil deed."},{"kind":"text","text":"(Aboo-Is-hák the Grammarian, and TA.)"}],"source_refs":["S","M","A","Mgh","Msb","K","L","TA"]},{"entry_id":"n35506","headword_ar":"قِرْضٌ","root":"qrD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaroDN","text_ar":"قَرْضٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}