{"lemma":"رَوَّحَ","slug":"رَوَّحَ","root":"ر.#.ح","root_slug":"ر-_-ح","root_link":"/words/roots/ر-_-ح","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"رَوَّحْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"رَوَّحْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"رَوَّحْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"رَوَّحْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"رَوَّحْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"رَوَّحَ","in_corpus":true,"count":65,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"رَوَّحَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"رَوَّحا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"رَوَّحَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"رَوَّحُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"رَوَّحْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُرَوِّح","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُرَوِّحِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُرَوِّحِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُرَوِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُرَوِّحا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُرَوِّحُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَوِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَوِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَوِّح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَوِّح","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَوِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَوِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَوِّحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَوِّحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَوِّحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَوِّحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَوِّحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُرَوِّح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَوِّح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَوَّحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَوَّحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":77,"cross_references":{"qac":{"found":true,"lemma_key":"رَوَّحَ","root":"روح","pos":"N","occurrence_count":21},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n16977","n16985","n16986","n16987"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%88%D9%8E%D9%91%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"spirit (all senses), ghost"},{"pos":"noun","gloss":"soul, essence, core or essential aspect required for being"},{"pos":"noun","gloss":"life; spark of life, breath of life"},{"pos":"noun","gloss":"breath, movement of air"},{"pos":"noun","gloss":"motivation, energy, inspiration; the means to be animate or living"},{"pos":"noun","gloss":"gun barrel"},{"pos":"noun","gloss":"refreshment"}]},"etymology":{"source":"wiktextract","text":"Etymologically related to Arabic: ريح (rīḥ, “wind”). From Proto-West Semitic *rūḥ-. Cognate with Hebrew רוּחַ (rúakh)."},"ipa":["/ruːħ/","/rawħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16977","headword_ar":"روّح","root":"rwH","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He fanned"},{"kind":"text","text":"]. You say,"},{"kind":"arabic","text_bw":"rw~H Ealayohi","text_ar":"روّح عَلَيْهِ"},{"kind":"arabic","text_bw":"biAlmirowaHapi","text_ar":"بِالمِرْوَحَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fanned him with the fan"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"AiHotaAjuwA A_ilaY Alt~arowiyHi mina AlHar~i biAlmirowaHapi","text_ar":"اِحْتَاجُوا اـِلَى التَّرْوِيحِ مِنَ الحَرِّ بِالمِرْوَحَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They required to be fanned, by reason of the heat, with the fan"},{"kind":"text","text":"]. (TA.) ―         -b2-  Also, (A, Msb,) inf. n."},{"kind":"arabic","text_bw":"tarowiyHN","text_ar":"تَرْوِيحٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He perfumed oil; rendered"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"sweet in odour,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"by putting perfume in it."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"rw~H Eanohu","text_ar":"روّح عَنْهُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"raw~iHuwA binaA","text_ar":"رَوِّحُوا بِنَا"},{"kind":"text","text":": see 4. ―         -b4-"},{"kind":"arabic","text_bw":"rw~H bihimo","text_ar":"روّح بِهِمْ"},{"kind":"text","text":", (A, Mgh, Msb,) inf. n. as above, (A, Msb,)"},{"kind":"italic_en","text":"He performed with them the prayers termed"},{"kind":"arabic","text_bw":"Alt~araAwiyH","text_ar":"التَّرَاوِيح"},{"kind":"text","text":". (A, Mgh, Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"rw~H","text_ar":"روّح"},{"kind":"text","text":"having for its objects camels, and sheeep or goats: see 4. ―         -b6-"},{"kind":"arabic","text_bw":"raw~aHotuhumo","text_ar":"رَوَّحْتُهُمْ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ruHotu A_ilayohimo","text_ar":"رُحْتُ اـِلَيْهِمْ"},{"kind":"text","text":", in the latter half of the first paragraph."}],"source_refs":["A","Msb","Mgh"]},{"entry_id":"n16985","headword_ar":"رَوْحٌ","root":"rwH","body":[{"kind":"text","text":", as an epithet; fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ray~iHN","text_ar":"رَيِّحٌ"},{"kind":"text","text":", in two places.       -A2-  Also"},{"kind":"italic_en","text":"A gentle wind; a gentle gale; a breeze; the commencement of a wind before it becomes strong;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"breath of the wind when weak:"},{"kind":"text","text":"(S, K, TA:) or the"},{"kind":"italic_en","text":"cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coolness, of such gentle wind."},{"kind":"text","text":"(A, TA.) ―         -b2-"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"nafasN","text_ar":"نَفَسٌ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Breath;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"ruwHN","text_ar":"رُوحٌ"},{"kind":"text","text":"]: said to be the primary signification: (MF:) or"},{"kind":"italic_en","text":"spirit;"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"ruwHN","text_ar":"رُوحٌ"},{"kind":"text","text":";] syn."},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":"; as in the saying,"},{"kind":"arabic","text_bw":"A^aHoyaA","text_ar":"اَحْيَا"},{"kind":"arabic","text_bw":"Aln~aAsa birawoHihi","text_ar":"النَّاسَ بِرَوْحِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(meaning God)"},{"kind":"italic_en","text":"hath quickened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vivified, mankind with his spirit:"},{"kind":"text","text":"or perhaps the right reading is"},{"kind":"arabic","text_bw":"biruwHihi","text_ar":"بِرُوحِهِ"},{"kind":"text","text":"]. (A.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"raAHapN","text_ar":"رَاحَةٌ"},{"kind":"text","text":", with which it is syn. (S, K.) ―         -b4-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Joy, happiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gladness;"},{"kind":"text","text":"(AA, MF, TA;) said to be a metaphorical meaning, from the same word as syn. with"},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"; (MF;) and ↓"},{"kind":"arabic","text_bw":"ruwHN","text_ar":"رُوحٌ","orth_type":"arrow"},{"kind":"text","text":"likewise has this meaning: (IAar, TA:) or the former,"},{"kind":"italic_en","text":"rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease, from grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow, of heart."},{"kind":"text","text":"(As, TA.) In the saying of 'Alee,"},{"kind":"arabic","text_bw":"fabaA$aruwA rawoHa","text_ar":"فَبَاشَرُوا رَوْحَ"},{"kind":"arabic","text_bw":"Alyaqiyni","text_ar":"اليَقِينِ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Alyqyn","text_ar":"اليقين"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ruwHa","text_ar":"رُوحَ","orth_type":"arrow"},{"kind":"text","text":", the phrase"},{"kind":"arabic","text_bw":"rwH Alyqyn","text_ar":"روح اليقين"},{"kind":"text","text":"is thought by ISd to mean (assumed tropical:)"},{"kind":"italic_en","text":"The joy and happiness that arise from certainty."},{"kind":"text","text":"(TA. [See art."},{"kind":"arabic","text_bw":"b$r","text_ar":"بشر"},{"kind":"text","text":".]) ―         -b5-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Mercy"},{"kind":"text","text":"(S, K, TA) of God; thus called as being a cause of rest, or ease; (TA;) and so ↓"},{"kind":"arabic","text_bw":"riyHN","text_ar":"رِيحٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"rayoHaAnN","text_ar":"رَيْحَانٌ","orth_type":"arrow"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"ruwHN","text_ar":"رُوحٌ","orth_type":"arrow"},{"kind":"text","text":"is said by Az to have this meaning in the Kur iv. 169: the pl. of the first of these three words [and of the last, and accord. to some a pl. of the second also,] is"},{"kind":"arabic","text_bw":"A^arowaAHN","text_ar":"اَرْوَاحٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","TA","MF","IAar"]},{"entry_id":"n16986","headword_ar":"رُوحٌ","root":"rwH","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"soul, spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vital principle;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":"; (IAar, IAmb, L, Msb, TA, and S and K &c. in art."},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":"; [but there is a difference between these two words, for they are not always interchangeable, as I have shown in art."},{"kind":"arabic","text_bw":"nfs","text_ar":"نفس"},{"kind":"text","text":";]) [i. e.]"},{"kind":"arabic","text_bw":"maA bihi HayaApu AlA^anofusi","text_ar":"مَا بِهِ حَيَاةُ الاَنْفُسِ"},{"kind":"text","text":"; (K; [see also"},{"kind":"arabic","text_bw":"rawoHN","text_ar":"رَوْحٌ"},{"kind":"text","text":", third sentence;]) often occurring in the Kur and the Traditions in different senses, but generally signifying [as explained above, i. e.] the vital principle; (IAth, TA;) [or the"},{"kind":"italic_en","text":"nervous fluid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"animal spirit;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a subtile vaporous substance, which is the principle of vitality and of sensation and of voluntary motion;"},{"kind":"text","text":"also called the"},{"kind":"arabic","text_bw":"ruwH HayawaAniY~","text_ar":"رُوح حَيَوَانِىّ"},{"kind":"text","text":"; (KT in explanation of the term"},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":";) or"},{"kind":"italic_en","text":"a subtile body, the source of which is the hollow of the corporeal heart, and which diffuses itself into all the other parts of the body by means of the pulsing veins,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arteries:"},{"kind":"text","text":"(KT in explanation of the term"},{"kind":"arabic","text_bw":"Alr~uwHu AlHayawaAniY~u","text_ar":"الرُّوحُ الحَيَوَانِىُّ"},{"kind":"text","text":": [so too"},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":"; q. v.: see also Gen. ix. 4: many of the ancients believed the soul to reside in the blood: see Aristotle, De Anim. i. 2, and Virgil's Æn. ix. 349:]) or the"},{"kind":"italic_en","text":"vital principle in man:"},{"kind":"text","text":"(Fr, TA:) or the"},{"kind":"italic_en","text":"breath which a man breathes, and which pervades the whole body:"},{"kind":"text","text":"[and this seems to be the original idea expressed by the word:]"},{"kind":"italic_en","text":"after its exit, he ceases to breathe; and when it has completely gone forth, his eyes remain gazing towards it until they close; called in Pers."},{"kind":"arabic","text_bw":"jaAno","text_ar":"جَانْ"},{"kind":"text","text":": (AHeyth, TA:) accord. to the Sunnees, the"},{"kind":"italic_en","text":"rational soul,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Aln~afosu","text_ar":"النَّفْسُ"},{"kind":"arabic","text_bw":"Aln~aATiqapu","text_ar":"النَّاطِقَةُ"},{"kind":"text","text":", [also termed"},{"kind":"arabic","text_bw":"Alr~uwHu AlA_inosaAniY~u","text_ar":"الرُّوحُ الاـِنْسَانِىُّ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"which is adapted to the faculty of making known its ideas by means of speech, and of understanding speech, and which perishes not with the perishing of the body, being a substance, not an accident;"},{"kind":"text","text":"as is shown by the words in the Kur iii. 163, which refer to the"},{"kind":"arabic","text_bw":"rwH","text_ar":"روح"},{"kind":"text","text":": (Msb:) most of the doctors of the fundamentals of religion forbid the diving into this matter, because God has abstained from making it known: (TA:) the philosophers say that it is the"},{"kind":"italic_en","text":"blood, by the exhausting of which the life ceases:"},{"kind":"text","text":"(Msb:) the word is masc., (IAar, IAmb, Az, S, M, A, Msb, K, *) thus, with the Arabs, differing from"},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":", for this they make fem., (IAar, IAmb, Msb,) but the former is also fem., (S, M, A, Msb, K,) app. as meaning"},{"kind":"arabic","text_bw":"nafosN","text_ar":"نَفْسٌ"},{"kind":"text","text":", (Msb,) as is said in the R; (TA;) and most hold it to be as often fem. as it is masc.: (MF:) one says"},{"kind":"arabic","text_bw":"xaraja ruwHuhu","text_ar":"خَرَجَ رُوحُهُ"},{"kind":"text","text":"(IAar, Az, TA) [and also"},{"kind":"arabic","text_bw":"xarajato","text_ar":"خَرَجَتْ"},{"kind":"arabic","text_bw":"ruwHuhu","text_ar":"رُوحُهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"His soul departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forth"},{"kind":"text","text":"]: the pl. is"},{"kind":"arabic","text_bw":"A^arowaAHN","text_ar":"اَرْوَاحٌ"},{"kind":"text","text":". (S, Msb.) ―         -b2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nafoxN","text_ar":"نَفْخٌ"},{"kind":"text","text":"(K) [properly"},{"kind":"italic_en","text":"A blowing"},{"kind":"text","text":"with the mouth; but here] meaning"},{"kind":"italic_en","text":"wind that issues from the"},{"kind":"arabic","text_bw":"ruwH","text_ar":"رُوح"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"wind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breath."},{"kind":"text","text":"(ADk, TA.) Dhu-r-Rummeh says, respecting fire that he had struck, and upon which he bade his companion to blow,"},{"kind":"arabic","text_bw":"A^aHoyihaA biruwHika","text_ar":"اَحْيِهَا بِرُوحِكَ"},{"kind":"italic_en","text":"Give life to it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enliven it, with thy wind"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"breath"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"malaA^a Alqirobapa mino","text_ar":"مَلَاَ القِرْبَةَ مِنْ"},{"kind":"arabic","text_bw":"ruwHihi","text_ar":"رُوحِهِ"},{"kind":"italic_en","text":"He filled the skin with his wind; with his breath."},{"kind":"text","text":"(ADk, TA.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"Alr~uwHu","text_ar":"الرُّوحُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"Inspiration,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divine revelation;"},{"kind":"text","text":"(Zj, Th, K;)"},{"kind":"italic_en","text":"such as is imparted by means of an angel:"},{"kind":"text","text":"thus in the Kur xvi. 2 and xl. 15: so called because it quickens from the death of infidelity, and thus is, to a man, like the"},{"kind":"arabic","text_bw":"ruwH","text_ar":"رُوح"},{"kind":"text","text":"which is the vital principle of his body: (T:) or (so says Zj accord. to the L, but in the K “ and ” )"},{"kind":"italic_en","text":"the prophetic commission."},{"kind":"text","text":"(Zj, K.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"The Kur-án;"},{"kind":"text","text":"(IAar, Zj, S, * A, * K;) whereby God's creatures are [spiritually] quickened, and guided to the right way. (TA.) So in the trad.,"},{"kind":"arabic","text_bw":"taHaAyawoA","text_ar":"تَحَايَوْا"},{"kind":"arabic","text_bw":"bi*ikori A@ll~`hi wa ruwHihi","text_ar":"بِذِكْرِ ا@للّٰهِ وَ رُوحِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Revive yourselves with God's book of religion and religious laws,"},{"kind":"text","text":"(or"},{"kind":"arabic","text_bw":"*ikor","text_ar":"ذِكْر"},{"kind":"text","text":"may here have some other meaning,)"},{"kind":"italic_en","text":"and his Kur-án"},{"kind":"text","text":"]. (TA. [Mentioned also in the A; in a copy of which, in the place of"},{"kind":"arabic","text_bw":"taHaAyawoA","text_ar":"تَحَايَوْا"},{"kind":"text","text":", I find"},{"kind":"arabic","text_bw":"taHaAbuwA","text_ar":"تَحَابُوا"},{"kind":"text","text":", an evident mistranscription.]) ―         -b5-  And (assumed tropical:)"},{"kind":"italic_en","text":"What God ordains and commands"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"by means of his assistants and angels."},{"kind":"text","text":"(TA.) ―         -b6-  Also"},{"kind":"italic_en","text":"Jibreel"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Gabriel"},{"kind":"text","text":"]; (S, * A, * K;) called in the Kur [xxvi. 193]"},{"kind":"arabic","text_bw":"Alr~uwHu AlA^amiynu","text_ar":"الرُّوحُ الاَمِينُ"},{"kind":"text","text":", and [in ii. 81]"},{"kind":"arabic","text_bw":"ruwHu","text_ar":"رُوحُ"},{"kind":"arabic","text_bw":"Alqudusi","text_ar":"القُدُسِ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Alqudosi","text_ar":"القُدْسِ"},{"kind":"text","text":", as related by Az on the authority of Th. (TA.) [The last of these appellations, or generally, but incorrectly,"},{"kind":"arabic","text_bw":"Alr~uwHu Alqudusu","text_ar":"الرُّوحُ القُدُسُ"},{"kind":"text","text":", is applied by the Eastern Christians among the Arabs to"},{"kind":"italic_en","text":"The Holy Spirit; the Third Person of the Trinity."},{"kind":"text","text":"] ―         -b7-  And [sometimes"},{"kind":"italic_en","text":"Our Lord"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Jesus."},{"kind":"text","text":"(S, * A, * K.) ―         -b8-  And"},{"kind":"italic_en","text":"A certain angel,"},{"kind":"text","text":"(I'Ab, K,)"},{"kind":"italic_en","text":"in the Seventh Heaven,"},{"kind":"text","text":"(I'Ab, TA,)"},{"kind":"italic_en","text":"whose face is like that of a man, and his body like that of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"angels:"},{"kind":"text","text":"(I'Ab, K:) or"},{"kind":"italic_en","text":"certain creatures resembling mankind, but not men:"},{"kind":"text","text":"so in the Kur lxxviii. 38: (Zj:) or"},{"kind":"italic_en","text":"the watchers over the angels who are watchers over the sons of Adam, whose faces are said to be like the faces of men, and whom the other angels see not, like as we see not the watchers nor the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"angels."},{"kind":"text","text":"(Th.) ―         -b9-  See also"},{"kind":"arabic","text_bw":"rawoHN","text_ar":"رَوْحٌ"},{"kind":"text","text":", in three places.       -A2-  Also pl. of"},{"kind":"arabic","text_bw":"raw^uwHN","text_ar":"رَوُوحٌ"},{"kind":"text","text":": (L:) ―         -b2-  and of"},{"kind":"arabic","text_bw":"A^arowaHu","text_ar":"اَرْوَحُ"},{"kind":"text","text":". (S &c.)"}],"source_refs":["Fr","TA","AHeyth","Msb","IAar","IAmb","S","M","A","K","MF","Az","T","Zj","L"]},{"entry_id":"n16987","headword_ar":"رَوَحٌ","root":"rwH","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raAy^iHN","text_ar":"رَايِحٌ"},{"kind":"text","text":", of which it is said to be a quasi-pl. n., in three places.       -A2-  Also"},{"kind":"italic_en","text":"Width, wideness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ampleness."},{"kind":"text","text":"(S, K.) El-Mutanakhkhil [in the TA El-Muntakhal] El-Hudhalee says,"},{"kind":"quote","text":"l`kino kabiyru bonu hinodK yawoma *`likumu\n                      \n                     \n                        futoxu Al$~amaAy^ili fiY A^ayomaAnihimo rawaHu"},{"kind":"text","text":"(S, TA,) meaning"},{"kind":"italic_en","text":"But Kebeer Ibn-Hind,"},{"kind":"text","text":"a tribe of Hudheyl,"},{"kind":"italic_en","text":"on that day, were lax in the joints of the left hands"},{"kind":"text","text":"by reason of vehement pulling [of the bows],"},{"kind":"italic_en","text":"having wideness in their right hands"},{"kind":"text","text":"by reason of vehement striking with the sword. (TA.) ―         -b2-  And [particularly]"},{"kind":"italic_en","text":"Width,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wideness, in the space between the thighs:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"width,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wideness,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"in,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"(Mgh,) [or"},{"kind":"italic_en","text":"between,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the two legs,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"less than what is termed"},{"kind":"arabic","text_bw":"faHajN","text_ar":"فَحَجٌ"},{"kind":"text","text":", (S, K,) or"},{"kind":"italic_en","text":"less than"},{"kind":"arabic","text_bw":"fajajN","text_ar":"فَجَجٌ"},{"kind":"text","text":", (A, Mgh,)"},{"kind":"italic_en","text":"with wideness between the fore parts of the feet, and nearness of the heels, each to the other:"},{"kind":"text","text":"(S:) or [simply]"},{"kind":"italic_en","text":"wideness between the fore parts of the feet, and nearness of the heels, each to the other:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a spreading in the fore part of each foot:"},{"kind":"text","text":"(Lth, Mgh, Msb:) or"},{"kind":"italic_en","text":"a turning over of the foot upon its outer side:"},{"kind":"text","text":"IAar says that"},{"kind":"arabic","text_bw":"rawaHN","text_ar":"رَوَحٌ"},{"kind":"text","text":"in the legs is"},{"kind":"italic_en","text":"less than"},{"kind":"arabic","text_bw":"fadaEN","text_ar":"فَدَعٌ"},{"kind":"text","text":", and this is less than"},{"kind":"arabic","text_bw":"EaqalN","text_ar":"عَقَلٌ"},{"kind":"text","text":". (TA.)       -A3-"},{"kind":"arabic","text_bw":"h`*aA AlA^amoru bayonanaA rawaHN","text_ar":"هٰذَا الاَمْرُ بَيْنَنَا رَوَحٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"This is a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair, which we do by turns;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"EawarN","text_ar":"عَوَرٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","TA","Mgh","K","A","Msb","Lth"]}]}}