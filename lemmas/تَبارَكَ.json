null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَبارَكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَبارَكْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَبارَك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَبارَك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَبارَكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَبارَكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَبارَكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَبارَكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَبارَكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَبارَكُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَبارَكْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"تَبارَكْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَبارَكْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتَبارَك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَبارَك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":527,"cross_references":{"qac":{"found":true,"lemma_key":"تَبارَكَ","root":"برك","pos":"V","occurrence_count":9},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n2356"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D8%A7%D8%B1%D9%8E%D9%83%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be blessed, to be fortunate","examples":[{"text":"تَبَارَكَ ٱللهُ","english":"God is blessed"}]},{"pos":"noun","gloss":"verbal noun of تَبَارَكَ (tabāraka) (form VI)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2356","headword_ar":"تبارك","root":"brk","body":[{"kind":"text","text":", accord. to Zj, is an instance of"},{"kind":"arabic","text_bw":"tafaAEala","text_ar":"تَفَاعَلَ"},{"kind":"text","text":"[as quasi-pass. of"},{"kind":"arabic","text_bw":"faAEala","text_ar":"فَاعَلَ"},{"kind":"text","text":", i. e., of"},{"kind":"arabic","text_bw":"baAraka","text_ar":"بَارَكَ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"tabaAEada","text_ar":"تَبَاعَدَ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"baAEada","text_ar":"بَاعَدَ"},{"kind":"text","text":",] from"},{"kind":"arabic","text_bw":"Albarakapu","text_ar":"البَرَكَةُ"},{"kind":"text","text":"; and so say the lexicologists [in general]. (TA.) [Hence,]"},{"kind":"arabic","text_bw":"tbArk A@ll~`hu","text_ar":"تبارك ا@للّٰهُ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"Blessed is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be, God;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"hallowed is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be, God;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far removed is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be, He from every impurity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from everything derogatory from his glory;"},{"kind":"text","text":"(K) or"},{"kind":"italic_en","text":"highly to be exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled, is God; or highly exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled, be He;"},{"kind":"text","text":"(Abu-l-'Abbás, TA;)"},{"kind":"italic_en","text":"greatly to be magnified is God;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greatly magnified be He:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baAraka","text_ar":"بَارَكَ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qaAtala","text_ar":"قَاتَلَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taqAatala","text_ar":"تَقاَتَلَ"},{"kind":"text","text":", except that"},{"kind":"arabic","text_bw":"faAEala","text_ar":"فَاعَلَ"},{"kind":"text","text":"is trans. and"},{"kind":"arabic","text_bw":"tafaAaEala","text_ar":"تَفَاَعَلَ"},{"kind":"text","text":"is intrans.: (S:) accord. to IAmb, it means [that] one looks for a blessing by means of [uttering] his name ("},{"kind":"arabic","text_bw":"yutabar~aku biA@somihi","text_ar":"يُتَبَرَّكُ بِا@سْمِهِ"},{"kind":"text","text":") in every affair, or case: accord. to Lth, it is a phrase of glorification and magnification: (TA:) or"},{"kind":"arabic","text_bw":"tbArk","text_ar":"تبارك"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He is abundant in good;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Albarakapu","text_ar":"البَرَكَةُ"},{"kind":"text","text":", which is “abundance of good:” or"},{"kind":"italic_en","text":"He exceeds everything, and is exalted above it, in his attributes and his operations;"},{"kind":"text","text":"because"},{"kind":"arabic","text_bw":"Albarakapu","text_ar":"البَرَكَةُ"},{"kind":"text","text":"implies the meaning of increase, accession, or redundance: or"},{"kind":"italic_en","text":"He is everlasting;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":"; from"},{"kind":"arabic","text_bw":"buruwku AlT~ayori EalaY AlmaA='i","text_ar":"بُرُوكُ الطَّيْرِ عَلَى المَا=ءِ"},{"kind":"text","text":"[“the continuing of the birds at the water”]; whence"},{"kind":"arabic","text_bw":"Albirokapu","text_ar":"البِرْكَةُ"},{"kind":"text","text":", because of the continuance of the water therein: the verb is invariable [when thus used, being considered as divested of all signification of time, or used in an optative sense]; and is not employed [in any of the senses above] otherwise than in relation to God: (Bd in xxv. 1:) it is an attributive peculiar to God. (K.) ―         -b2-"},{"kind":"arabic","text_bw":"tbArk biAl$~aYo'i","text_ar":"تبارك بِالشَّىْءِ"},{"kind":"text","text":": see 5."}],"source_refs":["K","TA","S"]}]},"classical_definitions":null}