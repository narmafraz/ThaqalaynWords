{"lemma":"دَسَمُ","slug":"دَسَمُ","root":"د.س.م","root_slug":"د-س-م","root_link":"/words/roots/د-س-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n12545","n12547","n12548","n12549"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D8%B3%D9%8E%D9%85%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to obturate, to block up, to lock up, to stuff"},{"pos":"verb","gloss":"to besmear, to efface, to obliterate"},{"pos":"verb","gloss":"to have much fat, to be greasy, to drip of lard"},{"pos":"verb","gloss":"to make greasy"},{"pos":"noun","gloss":"verbal noun of دَسِمَ (dasima) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"fat, grease, adeps"},{"pos":"adj","gloss":"fatty, greasy, creamy"},{"pos":"adj","gloss":"rich, succulent, substantial etc., much that nurtures the body or mind","tags":["figuratively"]},{"pos":"adj","gloss":"common plural of أَدْسَم (ʔadsam, “greasy”)","tags":["common","form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12545","headword_ar":"دَسِمَ","root":"dsm","body":[{"kind":"text","text":", (S, M, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"dasamN","text_ar":"دَسَمٌ"},{"kind":"text","text":", (Msb, TA,) or"},{"kind":"arabic","text_bw":"dusuwmapN","text_ar":"دُسُومَةٌ"},{"kind":"text","text":", (Mgh, in which the verb is not mentioned,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Mgh, or food, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, greasy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon it, grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dripping of flesh-meat"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of fat;"},{"kind":"text","text":"(M, K, * Mgh;) as also ↓"},{"kind":"arabic","text_bw":"tds~m","text_ar":"تدسّم","orth_type":"arrow"},{"kind":"text","text":": (M:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a garment, or some other thing,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy."},{"kind":"page_break","n":880},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"dasima","text_ar":"دَسِمَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"dasamN","text_ar":"دَسَمٌ"},{"kind":"text","text":", TK,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, of the colour termed"},{"kind":"arabic","text_bw":"dusomap","text_ar":"دُسْمَة"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"dust-colour inclining to blackness."},{"kind":"text","text":"(M, K.)       -A2-"},{"kind":"arabic","text_bw":"dasama","text_ar":"دَسَمَ"},{"kind":"text","text":", (Z, K, and so in some copies of the S,) [aor., app.,"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"dasomN","text_ar":"دَسْمٌ"},{"kind":"text","text":"; (TA;) or ↓"},{"kind":"arabic","text_bw":"ds~m","text_ar":"دسّم","orth_type":"arrow"},{"kind":"text","text":"; (so in some copies of the S;) said of rain,"},{"kind":"italic_en","text":"It moistened the earth"},{"kind":"text","text":"(S, Z, K)"},{"kind":"italic_en","text":"a little,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"not much,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"so as not to reach the moist soil."},{"kind":"text","text":"(Z, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"dasama","text_ar":"دَسَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"dasomN","text_ar":"دَسْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He smeared"},{"kind":"text","text":"a camel"},{"kind":"italic_en","text":"with tar."},{"kind":"text","text":"(K.) ―         -b3-  Also, (S, M, K,) aor."},{"kind":"text","text":", (S, K, *) or"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"dasomN","text_ar":"دَسْمٌ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"He stopped up"},{"kind":"text","text":"(S, M, K) a thing, (M,) such as a wound, (S, M,) and an ear, (S,) and a flask, or bottle; as also ↓"},{"kind":"arabic","text_bw":"Adsm","text_ar":"ادسم","orth_type":"arrow"},{"kind":"text","text":"; (K;) or"},{"kind":"arabic","text_bw":"dasama AlqaAruwrapa","text_ar":"دَسَمَ القَارُورَةَ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"$ad~a rA^osahaA","text_ar":"شَدَّ راْسَهَا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"he bound the head of the flask,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bottle:"},{"kind":"text","text":"or the right reading, as the context seems to indicate, is"},{"kind":"arabic","text_bw":"sad~a raA^osahaA","text_ar":"سَدَّ رَاْسَهَا"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he stopped up the head of the flask,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bottle"},{"kind":"text","text":"]; (M;) and"},{"kind":"arabic","text_bw":"dasama AljuroHa","text_ar":"دَسَمَ الجُرْحَ"},{"kind":"italic_en","text":"he put the tent"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alfatiyla","text_ar":"الفَتِيلَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"into the wound."},{"kind":"text","text":"(TA.) ―         -b4-  And hence, i. e. from"},{"kind":"arabic","text_bw":"dasama AljuroHa","text_ar":"دَسَمَ الجُرْحَ"},{"kind":"text","text":"or from"},{"kind":"arabic","text_bw":"dasama AlqaAruwrapa","text_ar":"دَسَمَ القَارُورَةَ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"Inivit"},{"kind":"text","text":"feminam. (Kr, M, K, TA.) And hence also,] one says to the"},{"kind":"arabic","text_bw":"musotaHAaDap","text_ar":"مُسْتَحاَضَة"},{"kind":"text","text":", [see this word,]"},{"kind":"arabic","text_bw":"AudosumiY waSal~iY","text_ar":"اُدْسُمِى وَصَلِّى"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Stuff thy vagina"},{"kind":"text","text":"with cotton, to arrest the blood,"},{"kind":"italic_en","text":"and say thy prayers"},{"kind":"text","text":"]. (TA.) ―         -b5-  Also, (K,) inf. n."},{"kind":"arabic","text_bw":"dasomN","text_ar":"دَسْمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He closed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"locked,"},{"kind":"text","text":"a door; syn."},{"kind":"arabic","text_bw":"A^agolaqa","text_ar":"اَغْلَقَ"},{"kind":"text","text":". (K.)       -A3-  Also, (i. e."},{"kind":"arabic","text_bw":"dasama","text_ar":"دَسَمَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Tasama","text_ar":"طَسَمَ"},{"kind":"text","text":", [in some copies of the K, and in the TA,"},{"kind":"arabic","text_bw":"Tamasa","text_ar":"طَمَسَ"},{"kind":"text","text":", which signifies the same, i. e."},{"kind":"italic_en","text":"It became effaced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obliterated,"},{"kind":"text","text":"] said of a relic, trace, mark, or the like. (S, K.)"}],"source_refs":["S","M","Msb","K","TA","Z"]},{"entry_id":"n12547","headword_ar":"دَسْمٌ","root":"dsm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"dasamN","text_ar":"دَسَمٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"A^anaA EalaY dasomi AlA^amori","text_ar":"اَنَا عَلَى دَسْمِ الاَمْرِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"ElY TarafK minohu","text_ar":"على طَرَفٍ مِنْهُ"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"I am beside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out of, the case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair"},{"kind":"text","text":"]. (K.)"}],"source_refs":[]},{"entry_id":"n12548","headword_ar":"دَسَمٌ","root":"dsm","body":[{"kind":"text","text":"a word of well-known meaning; (S;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"wadakN","text_ar":"وَدَكٌ"},{"kind":"text","text":"; (M, K;) both signifying"},{"kind":"italic_en","text":"Grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"dripping that exudes from flesh-meat and from fat;"},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"wdk","text_ar":"ودك"},{"kind":"text","text":";) the"},{"kind":"arabic","text_bw":"wadak","text_ar":"وَدَك"},{"kind":"italic_en","text":"of flesh-meat and of fat:"},{"kind":"text","text":"(Mgh: [in the CK,"},{"kind":"arabic","text_bw":"Alwaraku","text_ar":"الوَرَكُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Alwadaku","text_ar":"الوَدَكُ"},{"kind":"text","text":":]) or, accord. to the T,"},{"kind":"italic_en","text":"anything that has"},{"kind":"arabic","text_bw":"wadak","text_ar":"وَدَك"},{"kind":"text","text":","},{"kind":"italic_en","text":"of flesh-meat and of fat:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"dirt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth:"},{"kind":"text","text":"(M, K:) and ↓"},{"kind":"arabic","text_bw":"dasomN","text_ar":"دَسْمٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"dasamN","text_ar":"دَسَمٌ"},{"kind":"text","text":", accord. to El-Kurtubee; but El-Welee El-'Irákee says, I have not seen this on the authority of any other lexicologist. (TA.) You say,"},{"kind":"arabic","text_bw":"yaduhu mina Ald~asami saliTapN","text_ar":"يَدُهُ مِنَ الدَّسَمِ سَلِطَةٌ"},{"kind":"text","text":"[app. meaning, if correctly transcribed,"},{"kind":"italic_en","text":"His hand is hard by reason of dirt"},{"kind":"text","text":"adhering to it: in my MS. copy of the K, the last word is written"},{"kind":"arabic","text_bw":"saTilapN","text_ar":"سَطِلَةٌ"},{"kind":"text","text":"; a word which I do not find in any sense: in the TK,"},{"kind":"arabic","text_bw":"sTlp","text_ar":"سطلة"},{"kind":"text","text":": this Freytag thinks to be the right reading, though I know of no such word; and he renders the phrase, “ manus ejus propter sordes inhaerentes catinus est; ” evidently assuming that"},{"kind":"arabic","text_bw":"sTlp","text_ar":"سطلة"},{"kind":"text","text":"is a dial. var. of"},{"kind":"arabic","text_bw":"saTolN","text_ar":"سَطْلٌ"},{"kind":"text","text":"]. (K.) [It seems that you say also,"},{"kind":"arabic","text_bw":"maA fiyhi dasamN","text_ar":"مَا فِيهِ دَسَمٌ"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"There is not in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, any profit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good:"},{"kind":"text","text":"a sense assigned in the TA to the phrase"},{"kind":"arabic","text_bw":"mA fyh","text_ar":"ما فيه"},{"kind":"arabic","text_bw":"dysm dsm","text_ar":"ديسم دسم"},{"kind":"text","text":"; in which I think it evident that the transcriber has written"},{"kind":"arabic","text_bw":"dysm","text_ar":"ديسم"},{"kind":"text","text":"by mistake, and forgotten to erase it after adding"},{"kind":"arabic","text_bw":"dsm","text_ar":"دسم"},{"kind":"text","text":".) ―         -b2-  Also The"},{"kind":"italic_en","text":"bowels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intestines."},{"kind":"text","text":"(TA.)       -A2-  Accord. to IAar, it means also"},{"kind":"arabic","text_bw":"kaviyru Al*~ikori","text_ar":"كَثِيرُ الذِّكْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Praising,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glorifying,"},{"kind":"text","text":"God,"},{"kind":"italic_en","text":"much"},{"kind":"text","text":"]; a sense in which it is incorrectly said in the K to be ↓"},{"kind":"arabic","text_bw":"dasiymN","text_ar":"دَسِيمٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A^amiyrN","text_ar":"اَمِيرٌ"},{"kind":"text","text":": (TA:) and hence the trad., of weak authority,"},{"kind":"arabic","text_bw":"laA ya*okuruwna A@ll~`ha A_il~aA dasamFA","text_ar":"لَا يَذْكُرُونَ ا@للّٰهَ اـِلَّا دَسَمًا"},{"kind":"text","text":": (K:) or, accord. to Z, this is from"},{"kind":"arabic","text_bw":"dasama","text_ar":"دَسَمَ"},{"kind":"text","text":"said of rain: and, as related by Abu-d-Dardà, the words are"},{"kind":"arabic","text_bw":"A^araDiytumo A_ino $abiEotumo","text_ar":"اَرَضِيتُمْ اـِنْ شَبِعْتُمْ"},{"kind":"arabic","text_bw":"EaAmFA A^al~aA ta*okuruwna A@ll~`ha A_il~aA dasamFA","text_ar":"عَامًا اَلَّا تَذْكُرُونَ ا@للّٰهَ اـِلَّا دَسَمًا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Do ye approve, if ye be satisfied in your stomachs throughout a year,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that ye should not praise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glorify, God, save a little?"},{"kind":"text","text":"(TA:) or it may denote commendation; so that the meaning of"},{"kind":"arabic","text_bw":"lA y*krwn All~`h Al~A dsmFA","text_ar":"لا يذكرون اللّٰه الّا دسمًا"},{"kind":"text","text":"is, that praise, or glorification, is the stuffing of their hearts and of their mouths: and it may denote discommendation; as meaning that they praise, or glorify, little; from"},{"kind":"arabic","text_bw":"tadosiymu nuwnapi AlS~abiY~i","text_ar":"تَدْسِيمُ نُونَةِ الصَّبِىِّ"},{"kind":"text","text":"; (K, TA;) the blackness denoted by this phrase being small in quantity: or, as some say, the meaning is, that they do not praise, or glorify, God for anything but eating, and the grease, or gravy, in their insides. (TA.)"}],"source_refs":["TA","M","K"]},{"entry_id":"n12549","headword_ar":"دَسِمٌ","root":"dsm","body":[{"kind":"text","text":"A thing"},{"kind":"italic_en","text":"greasy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon it, grease"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy,"},{"kind":"text","text":"(M, Mgh,)"},{"kind":"italic_en","text":"of flesh-meat"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of fat:"},{"kind":"text","text":"(Mgh:) [and"},{"kind":"italic_en","text":"dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"dusomN","text_ar":"دُسْمٌ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"*urobN","text_ar":"ذُرْبٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"*aribN","text_ar":"ذَرِبٌ"},{"kind":"text","text":".] You say"},{"kind":"arabic","text_bw":"maraqapN dasimapN","text_ar":"مَرَقَةٌ دَسِمَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Greasy broth"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"viyaAbN dusomN","text_ar":"ثِيَابٌ دُسْمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Dirty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filthy, garments."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"dasima Alv~awobi","text_ar":"دَسِمَ الثَّوْبِ"},{"kind":"text","text":", applied to a man, ["},{"kind":"italic_en","text":"Dirty in the garment:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"going on foot;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not riding;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^adosamu","text_ar":"اَدْسَمُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Alv~awobi","text_ar":"الثَّوْبِ"},{"kind":"text","text":". (TA.) [Hence also,] (assumed tropical:)"},{"kind":"italic_en","text":"Defiled by culpable dispositions."},{"kind":"text","text":"(TA.) A rájiz says,"},{"kind":"quote","text":"laAhum~a A_in~a EaAmira bona jahomi\n                      \n                     \n                        A^awo*ama Haj~FA fiY viyaAbK dusomi"},{"kind":"text","text":"meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"O God, verily 'Ámir Ibn-Jahm"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hath imposed upon himself,"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"w*m","text_ar":"وذم"},{"kind":"text","text":",) or"},{"kind":"italic_en","text":"hath performed,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"pilgrimage being defiled by sins."},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"w*m","text_ar":"وذم"},{"kind":"text","text":", and M.) ―         -b2-"},{"kind":"arabic","text_bw":"EimaAmapN dasimapN","text_ar":"عِمَامَةٌ دَسِمَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A black turban;"},{"kind":"text","text":"(TA;) as also"},{"kind":"arabic","text_bw":"EmAmp","text_ar":"عمامة"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"dasomaA='u","text_ar":"دَسْمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":". (Az, Mgh, TA.) And"},{"kind":"arabic","text_bw":"dasimN","text_ar":"دَسِمٌ"},{"kind":"text","text":"occurs in a trad. as meaning (assumed tropical:)"},{"kind":"italic_en","text":"Strict,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pious,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"though"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"black,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":", [or this may here mean"},{"kind":"italic_en","text":"a genuine Arab,"},{"kind":"text","text":"as opposed to"},{"kind":"arabic","text_bw":"A^aHomaru","text_ar":"اَحْمَرُ"},{"kind":"text","text":"meaning a foreigner,]) and"},{"kind":"italic_en","text":"religious."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","Mgh"]}]}}