s":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n27468"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D8%B4%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be wild, to be frivolous, to be light-headed","examples":[{"text":"طَاشَ عَقْلُهُ","english":"His mind went wild."}]}]},"etymology":null,"ipa":["/tˤaː.ʃa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27468","headword_ar":"طَاشَ","root":"Ty$","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTiy$u","text_ar":"يَطِيشُ"},{"kind":"text","text":", (O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"Tayo$N","text_ar":"طَيْشٌ"},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"Taya$aAnN","text_ar":"طَيَشَانٌ"},{"kind":"text","text":", (TA, [there only said to be syn. with"},{"kind":"arabic","text_bw":"Tayo$N","text_ar":"طَيْشٌ"},{"kind":"text","text":", but it is well known, and often occurring, as an inf. n. of"},{"kind":"arabic","text_bw":"TA$","text_ar":"طاش"},{"kind":"text","text":"in the first of the senses here explained,])"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light, inconstant, unsteady, irresolute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fickle,"},{"kind":"text","text":"syn. of the inf. n."},{"kind":"arabic","text_bw":"xif~apN","text_ar":"خِفَّةٌ"},{"kind":"text","text":", (S, A, Msb, K,) or"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"HilomN","text_ar":"حِلْمٌ"},{"kind":"text","text":", (IDrd, O,) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"nazaqN","text_ar":"نَزَقٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"after gravity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sedateness:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"light of intellect; lightwitted:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"he became bereft of his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect,"},{"kind":"text","text":"(Sh, A, O, K,)"},{"kind":"italic_en","text":"so as to be ignorant of that which he would endeavour to do."},{"kind":"text","text":"(Sh, O.) [And, said of a beast,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, restless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsteady."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"TaA$ato yaduhu fiY","text_ar":"طَاشَتْ يَدُهُ فِى"},{"kind":"arabic","text_bw":"AlS~aHofapi","text_ar":"الصَّحْفَةِ"},{"kind":"italic_en","text":"His hand was light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"active, in the bowl, and took from every side."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"TaA$ato","text_ar":"طَاشَتْ"},{"kind":"arabic","text_bw":"rijolaAhu","text_ar":"رِجْلَاهُ"},{"kind":"italic_en","text":"His legs were in a state of commotion."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"TaA$a Als~ahomu","text_ar":"طَاشَ السَّهْمُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"Tayo$N","text_ar":"طَيْشٌ"},{"kind":"text","text":", (A, Msb, K,)"},{"kind":"italic_en","text":"The arrow passed beyond the butt:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside,"},{"kind":"arabic","text_bw":"Eani Alhadafi","text_ar":"عَنِ الهَدَفِ"},{"kind":"italic_en","text":"from the butt;"},{"kind":"text","text":"(S, Msb;)"},{"kind":"italic_en","text":"and did not hit it."},{"kind":"text","text":"(Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"TaA$ato Eani AlA^um~i rijoluhu","text_ar":"طَاشَتْ عَنِ الاُمِّ رِجْلُهُ"},{"kind":"italic_en","text":"His leg turned aside"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the root"},{"kind":"text","text":"thereof]: a phrase used by Aboo-Sahm El-Hudhalee, whose leg had been cut off. (TA.)"}],"source_refs":["O","Msb","K","S","A","IDrd","TA","Sh"]}]}}