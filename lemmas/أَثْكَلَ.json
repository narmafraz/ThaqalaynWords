":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُثْكِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُثْكِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُثْكِل","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُثْكِل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُثْكِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُثْكِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُثْكِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُثْكِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُثْكِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُثْكِلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُثْكِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُثْكِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُثْكِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَثْكَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَثْكَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":false}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%AB%D9%83%D9%84/","headword_ar":"أثكل","entries":[{"lexicon_id":"dictionary_25","lexicon_en":"Murtaḍa al-Zabīdī, Tāj al-ʿArūs fī Jawāhir al-Qamūs (d. 1790 CE)","lexicon_ar":"تاج العروس لمرتضى الزبيدي","permalink":"https://arabiclexicon.hawramani.com/?p=127#1ed333","body_html":"<span class=\"title1\">أثكل</span><br><span>{الإثْكالُ،} والأُثْكُولُ: الشِّمْراخُ، كالعِثْكَالِ والعُثْكولِ، والهَمْزَةُ فيهمَا بَدَلٌ من العَين، والجَوْهَرِيُّ جَعَلَها زائِدَةً، وجاءَ بهَا فِي ثكل وسيأْتي.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=127#03822d","body_html":"<p>أثكل: في ترجمة عثكل: العُثْكُول والعِثْكال الشِّمْراخ، وما هو عليه</p><p>البُسْر من عِيدان الكِبَاسة وهو في النخل بمنزلة العُنقود من الكَرْم؛</p><p>وقول الراجز:</p><p>لو أَبْصَرَتْ سُعْدَى بها، كَنَائِلي،</p><p>طَوِيلَةَ الأَقْناءِ والأَثَاكِلِ</p><p>اراد العَثَاكل فقلب العين همزة، ويقال إِثكال وأُثْكُول. وفي حديث</p><p>الحدّ: فَجُلِد بأُثْكُول، وفي رواية: بإِثْكال، هما لغة في العُثْكُول</p><p>والعِثْكال، وهو عِذْق النخلة بما فيه من الشماريخ، والهمزة فيه بدل من العين</p><p>وليست زائدة، والجوهري جعلها زائدة وجاء به في فصل الثاء من حرف اللام،</p><p>وسنذكره أَيضاً هناك.</p>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=127#61af88","body_html":"<span class=\"title1\">(أثكل)</span><span> - في الحديث: \"فجُلِد بأُثكول النَّخلِ\"</span><br><span>الأُثكول والِإثكال: لغة في العُثْكول والعِثْكال، الهَمزة بَدلٌ من العَيْن، وليست بزائِدَة، وهو الشِّمراخ من شَمارِيخ العِذْق، قال الشاعر:</span><br><span>* طَويلةَ الأَقناءِ والأثاكل * </span><br><span>ويقال العِثْكال: الِإهانُ ما دَام رَطْباً، فإذا يَبس فهو عُرجُون.</span><span> </span>"}]}}