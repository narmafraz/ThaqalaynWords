{"lemma":"تَبِيعِي","slug":"تَبِيعِي","root":"ب.#.ع","root_slug":"ب-_-ع","root_link":"/words/roots/ب-_-ع","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بِعْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بِعْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بِعْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بِعْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بِعْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"باعَ","in_corpus":true,"count":27,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"باعَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"باعا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"باعَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"باعُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بِعْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبِع","in_corpus":true,"count":20,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَبِيع","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبِيعِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبِيعِينَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبِيعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبِيعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبِيعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبِيعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبِع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَبِيع","in_corpus":true,"count":29,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبِع","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَبِيع","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبِيعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبِيعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبِيعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبِيعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبِيعُوا","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبِيعُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بِعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بِعْتُ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبِيع","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبِيع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":127,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n3546","n3549"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D9%90%D9%8A%D8%B9%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sell (to agree to transfer goods or provide services)","tags":["ditransitive","transitive"],"examples":[{"text":"بَاعَ زَيْدٌ مَتَاعَهُ.","english":"Zayd sold his possessions."},{"text":"بَاعَنِي بَعْضَ الْأَثَاثِ.","english":"He sold me some furniture."}]},{"pos":"noun","gloss":"a linear measure derived from the distance between the two outspread arms of a man – which is mostly equal to his height, a قَامَة (qāma), a fathom, about 180 centimetres"},{"pos":"noun","gloss":"the body, including the limbs","examples":[{"text":"رَجُلٌ طَوِيلُ البَاعِ","english":"a man tall of body"}]},{"pos":"noun","gloss":"the arms (especially when extended to their full reach)"},{"pos":"noun","gloss":"reach, power, ability, eminence, nobility, honour, generosity","examples":[{"text":"هُوَ قَصِيرُ البَاعِ","english":"He is lacking in power or ability, he is stingy"},{"text":"لَهُ فِي ٱلْمَجْدِ سَابِقَةٌ وَبَاعُ","english":"He has precedence and eminence in glory, honour, dignity, or nobility"}]}]},"etymology":null,"ipa":["/baː.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3546","headword_ar":"بَاعَ","root":"bwE","body":[{"kind":"text","text":", (S, TA,) aor."},{"kind":"arabic","text_bw":"yabuwEu","text_ar":"يَبُوعُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"bawoEN","text_ar":"بَوْعٌ"},{"kind":"text","text":", (S, K, TA,)"},{"kind":"italic_en","text":"He extended his arms to their full reach;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"basaTa baAEahu","text_ar":"بَسَطَ بَاعَهُ"},{"kind":"text","text":"; (TA;) and the inf. n. by"},{"kind":"arabic","text_bw":"mad~u AlbaAEi","text_ar":"مَدُّ البَاعِ"},{"kind":"text","text":"; with a thing; as also ↓"},{"kind":"arabic","text_bw":"tbw~E","text_ar":"تبوّع","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"stretched forth his fore legs to the full"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mad~a A^abowaAEahu","text_ar":"مَدَّ اَبْوَاعَهُ"},{"kind":"text","text":"); as also ↓"},{"kind":"arabic","text_bw":"tbw~E","text_ar":"تبوّع","orth_type":"arrow"},{"kind":"text","text":"; and in like manner a gazelle: (TA:) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"stepped far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took long steps,"},{"kind":"text","text":"in his running; (S, K;) and in like manner one says ["},{"kind":"arabic","text_bw":"baAEat","text_ar":"بَاعَت"},{"kind":"text","text":"] of a she-camel. (S.) You say,"},{"kind":"arabic","text_bw":"mar~a yabuwEu","text_ar":"مَرَّ يَبُوعُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yatabaw~aEu","text_ar":"يَتَبَوَّعُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He went along stretching forth his fore-legs to the full extent of his step."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"baAEa biAlmaAli","text_ar":"بَاعَ بِالمَالِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yabuwEu","text_ar":"يَبُوعُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"bawoEN","text_ar":"بَوْعٌ"},{"kind":"text","text":", (Lth, K,)"},{"kind":"italic_en","text":"He extended his arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"liberally,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bountifully,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with the property."},{"kind":"text","text":"(Lth, K, TA.) You say also,"},{"kind":"arabic","text_bw":"buEo buEo","text_ar":"بُعْ بُعْ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Stretch forth thine arms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"baA Eayoka","text_ar":"بَا عَيْكَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in acts of obedience to God."},{"kind":"text","text":"(IAar.) And"},{"kind":"arabic","text_bw":"lilomasaAEiY","text_ar":"لِلْمَسَاعِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tabaw~aEa","text_ar":"تَبَوَّعَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He stretched forth his arms"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"mad~a baAEahu","text_ar":"مَدَّ بَاعَهُ"},{"kind":"text","text":") ["},{"kind":"italic_en","text":"to attain means of honour and elevation"},{"kind":"text","text":"]. (TA.) And ↓"},{"kind":"arabic","text_bw":"maA yudoraku tabaw~uEuhu","text_ar":"مَا يُدْرَكُ تَبَوُّعُهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The point to which he has reached is not to be attained:"},{"kind":"text","text":"(K, TA:) and, as Lh says, ↓"},{"kind":"arabic","text_bw":"laA taboluguwna tabaw~uEahu","text_ar":"لَا تَبْلُغُونَ تَبَوُّعَهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Ye will not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall not, reach the point to which he has attained:"},{"kind":"text","text":"originally, his length of step. (TA.) ―         -b4-  ↓"},{"kind":"arabic","text_bw":"A_i*aA baAEa A@nobaAEa","text_ar":"اـِذَا بَاعَ ا@نْبَاعَ","orth_type":"arrow"},{"kind":"italic_en","text":"When he accomplishes his want, he goes away."},{"kind":"text","text":"(Har p. 592.)       -A2-"},{"kind":"arabic","text_bw":"baAEa AlHabola","text_ar":"بَاعَ الحَبْلَ"},{"kind":"text","text":", (Msb, TA,) first pers."},{"kind":"arabic","text_bw":"buEotuhu","text_ar":"بُعْتُهُ"},{"kind":"text","text":", (S,) aor. and inf. n. as above, (S, Msb, TA,)"},{"kind":"italic_en","text":"He measured the rope by the"},{"kind":"arabic","text_bw":"bAE","text_ar":"باع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fathom"},{"kind":"text","text":"]; (Msb;)"},{"kind":"italic_en","text":"he extended his"},{"kind":"arabic","text_bw":"bAE","text_ar":"باع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"arms stretched to the full reach"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with the rope;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"he extended the rope with his"},{"kind":"arabic","text_bw":"bAE","text_ar":"باع"},{"kind":"text","text":"; or, which is nearly the same in meaning,"},{"kind":"italic_en","text":"he extended his arms with the rope until it became a"},{"kind":"arabic","text_bw":"bAE","text_ar":"باع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fathom in measure"},{"kind":"text","text":"]; (TA;) like as you say,"},{"kind":"arabic","text_bw":"$abarotuhu","text_ar":"شَبَرْتُهُ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Al$~iboru","text_ar":"الشِّبْرُ"},{"kind":"text","text":". (S, TA.) ―         -b2-  [And hence,]"},{"kind":"arabic","text_bw":"yabuwEu","text_ar":"يَبُوعُ"},{"kind":"arabic","text_bw":"AlA^aroDa","text_ar":"الاَرْضَ"},{"kind":"italic_en","text":"He traverses the ground with wide step and quick motion."},{"kind":"text","text":"(Ham p. 720.)"}],"source_refs":["S","TA","K","Lth","Msb"]},{"entry_id":"n3549","headword_ar":"بَاعٌ","root":"bwE","body":[{"kind":"italic_en","text":"A fathom;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"space that is between"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the extremities of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the two hands when they are extended to the right and left;"},{"kind":"text","text":"(Msb;) the"},{"kind":"italic_en","text":"measure of the extension of the two arms"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"with what is between them of the body;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"bawoEN","text_ar":"بَوْعٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"buwEN","text_ar":"بُوعٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) the last of the dial. of Hudheyl: (TA:) said by AHát to be of the masc. gender: (Msb:) pl."},{"kind":"arabic","text_bw":"A^abowaAEN","text_ar":"اَبْوَاعٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"biyEaAnN","text_ar":"بِيعَانٌ"},{"kind":"text","text":". (Ham p. 475.) ―         -b2-  [And hence,] (assumed tropical:)  The"},{"kind":"italic_en","text":"body, including the limbs;"},{"kind":"text","text":"[because a fathom in height;] as in the phrase"},{"kind":"arabic","text_bw":"rajulN Tawiylu AlbaAEi","text_ar":"رَجُلٌ طَوِيلُ البَاعِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A man tall in the body;"},{"kind":"text","text":"which has also another meaning, to be seen below: but you do not say,"},{"kind":"arabic","text_bw":"qaSiyru AlbaAEi","text_ar":"قَصِيرُ البَاعِ"},{"kind":"text","text":"as meaning short in the body. (TA.) ―         -b3-  [Also The"},{"kind":"italic_en","text":"arms;"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"when extended to their full reach;"},{"kind":"text","text":"as also the pl.: and in like manner, the"},{"kind":"italic_en","text":"fore legs"},{"kind":"text","text":"of a beast: see several examples in the first paragraph of this art.] ―         -b4-  [And hence, (tropical:)"},{"kind":"italic_en","text":"Reach; power;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"huwa qaSiyru AlbaAEi","text_ar":"هُوَ قَصِيرُ البَاعِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is lacking in power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability:"},{"kind":"text","text":"a phrase which has also another meaning, to be seen below. (TA.) And"},{"kind":"arabic","text_bw":"qaSura baAEuhu Eano *`lika","text_ar":"قَصُرَ بَاعُهُ عَنْ ذٰلِكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was unable to attain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effect, that:"},{"kind":"text","text":"in this case, ↓"},{"kind":"arabic","text_bw":"bwE","text_ar":"بوع","orth_type":"arrow"},{"kind":"text","text":"is not used. (TA.) ―         -b5-  And (tropical:)"},{"kind":"italic_en","text":"Reach, power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, in the means,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"causes, of attaining honour;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honourable, qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"actions:"},{"kind":"text","text":"(TA:) (tropical:)"},{"kind":"italic_en","text":"eminence; nobility; honour; generosity:"},{"kind":"text","text":"(Lth, S, K:) in which senses, ↓"},{"kind":"arabic","text_bw":"bwE","text_ar":"بوع","orth_type":"arrow"},{"kind":"text","text":"is not used. (Lth.) A poet says,"},{"kind":"quote","text":"lahu fiY Almajodi saAbiqapN wa baAEu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has precedence and eminence in glory, honour, dignity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"]. (Lth.) And"},{"kind":"arabic","text_bw":"rajulN Tawiylu AlbaAEi","text_ar":"رَجُلٌ طَوِيلُ البَاعِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A man of large generosity."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qaSiyru","text_ar":"قَصِيرُ"},{"kind":"arabic","text_bw":"AlbaAEi","text_ar":"البَاعِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Niggardly:"},{"kind":"text","text":"a phrase which has also another meaning, mentioned above. (TA.)"}],"source_refs":["S","K","TA","Msb","Lth"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D8%A7%D8%B9/","headword_ar":"باعبديل","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=130310#37ab95","body_html":"باعبديل<br>عن العبرية بمعنى أبي عبد الرب. يستخدم للذكور."}]}}