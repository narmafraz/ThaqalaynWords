{"lemma":"بَعْدِ","slug":"بَعْدِ","root":"ب.ع.د","root_slug":"ب-ع-د","root_link":"/words/roots/ب-ع-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"بَعْد","root":"بعد","pos":"N","occurrence_count":199},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adv","noun","prep","verb"],"has_etymology":false,"sense_count":14},"lanes":{"found":true,"entry_ids":["n2861","","n2866","n2868","n2870","n2869"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B9%D9%92%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be distant, afar, to become distant, go away (مِنْ (min) or عَنْ (ʕan) from)"},{"pos":"verb","gloss":"to die, to perish"},{"pos":"noun","gloss":"verbal noun of بَعُدَ (baʕuda) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"distance"},{"pos":"noun","gloss":"dimension"},{"pos":"noun","gloss":"absence"},{"pos":"noun","gloss":"death"},{"pos":"noun","gloss":"interval"},{"pos":"noun","gloss":"verbal noun of بَعَدَ (baʕada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of بَعِدَ (baʕida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"distance, going to a distance"},{"pos":"noun","gloss":"death"},{"pos":"prep","gloss":"after"},{"pos":"adv","gloss":"after that","examples":[{"text":"فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّينِ","english":"So what will make you deny the religion after that?"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2861","headword_ar":"بَعُدَ","root":"bEd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":"; (S, L, Msb, K;) and"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baEadN","text_ar":"بَعَدٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iboEaAdN","text_ar":"اـِبْعَادٌ"},{"kind":"text","text":", which is also trans.; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AstbEd","text_ar":"استبعد","orth_type":"arrow"},{"kind":"text","text":"; (S, K, &c.;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, distant, remote, far off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aloof: he went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdrew himself, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far off: he alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, himself: he stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept, aloof: contr. of"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":": (S, L:) [but"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"generally has the first of these significations; and ↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", the others, as also ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstbEd","text_ar":"استبعد","orth_type":"arrow"},{"kind":"text","text":":] it is the general opinion of the leading lexicologists that"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":", is thus used; but some deny this; and some assert that they may be employed alike, but that"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is more chaste than"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":"thus used. (TA.) [You say also, of a desert, and a tract of country, and the like,"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It extended far."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"zayodN Eani Almanozili","text_ar":"زَيْدٌ عَنِ المَنْزِلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"text","text":", meaning ↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Zeyd went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far, from the place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode"},{"kind":"text","text":"]. (IKt, Msb.) And"},{"kind":"arabic","text_bw":"min~iY","text_ar":"مِنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AbtEd","text_ar":"ابتعد","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tbE~d","text_ar":"تبعّد","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far, from me; he alienated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, himself from me; he shunned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided, me;"},{"kind":"text","text":"] (A;) and"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"arabic","text_bw":"En~Y","text_ar":"عنّى"},{"kind":"text","text":"signify the same]. (Msb in art."},{"kind":"arabic","text_bw":"k$H","text_ar":"كشح"},{"kind":"text","text":".) And ↓"},{"kind":"arabic","text_bw":"A_i*aA A^araA*a A^aHadukumo AlHaAjapi A^aboEada","text_ar":"اـِذَا اَرَاذَ اَحَدُكُمْ الحَاجَةِ اَبْعَدَ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb,) a trad., (Msb,) meaning"},{"kind":"italic_en","text":"When one of you desires to accomplish that which is needful,"},{"kind":"text","text":"(i. e. to ease nature,)"},{"kind":"italic_en","text":"he goes far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a great distance."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"fiY Alma*ohabi","text_ar":"فِى المَذْهَبِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aboEadotu","text_ar":"اَبْعَدْتُ","orth_type":"arrow"},{"kind":"text","text":", meaning ↓"},{"kind":"arabic","text_bw":"tabaAEadotu","text_ar":"تَبَاعَدْتُ","orth_type":"arrow"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"I went far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a great distance, to the place of ease,"},{"kind":"text","text":"i. e., to ease nature. (L.) ―         -b2-  ["},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"referring to a saying or the like, and an event, means"},{"kind":"italic_en","text":"It was far from being probable"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correct; it was improbable, extraordinary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strange:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"baEiydN","text_ar":"بَعِيدٌ"},{"kind":"text","text":", and see also 10:) often occurring in these senses.] And"},{"kind":"arabic","text_bw":"fiY nawoEihi","text_ar":"فِى نَوْعِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AbEd","text_ar":"ابعد","orth_type":"arrow"},{"kind":"italic_en","text":"It reached the utmost point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree, in its kind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species."},{"kind":"text","text":"(IAth.) And"},{"kind":"arabic","text_bw":"AbEd fiY Als~awomi","text_ar":"ابعد فِى السَّوْمِ"},{"kind":"italic_en","text":"He exceeded the due bounds in offering a thing for sale and demanding a price for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in bargaining for a thing."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"arabic","text_bw":"A^axa*ahu maA qaruba wa maA baEuda","text_ar":"اَخَذَهُ مَا قَرُبَ وَ مَا بَعُدَ"},{"kind":"italic_en","text":"Recent and old griefs took hold upon him:"},{"kind":"text","text":"a saying similar to"},{"kind":"arabic","text_bw":"A^axa*ahu maA qaduma wa maA Haduva","text_ar":"اَخَذَهُ مَا قَدُمَ وَ مَا حَدُثَ"},{"kind":"text","text":". (Mgh in art."},{"kind":"arabic","text_bw":"qdm","text_ar":"قدم"},{"kind":"text","text":".) ―         -b4-  ["},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is often used, agreeably with a general rule, in the manner of a verb of praise or dispraise; and in this case is commonly contracted into"},{"kind":"arabic","text_bw":"buEoda","text_ar":"بُعْدَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Husona","text_ar":"حُسْنَ"},{"kind":"text","text":"; as in the phrase, in a verse of Imrael-Keys,"},{"kind":"arabic","text_bw":"buEoda maA mutaA^am~alY","text_ar":"بُعْدَ مَا مُتَاَمَّلى"},{"kind":"text","text":"(in which"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"is redundant)"},{"kind":"italic_en","text":"Distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far distant, was the object of my contemplation!"},{"kind":"text","text":"or (as explained in the EM p. 52)"},{"kind":"italic_en","text":"how distant,"},{"kind":"text","text":"&c.!] ―         -b5-"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baEadN","text_ar":"بَعَدٌ"},{"kind":"text","text":"; (S, L, Msb, K;) and"},{"kind":"arabic","text_bw":"baEoda","text_ar":"بَعْدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":"; (L, K;) also signify"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, perished:"},{"kind":"text","text":"(S L, Msb:)"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"(K:) it is the general opinion of the leading lexicologists that both these verbs are used as signifying “he perished,” and both occur in different readings of v. 98 of ch. xi. of the Kur: the former is said to be used in this sense by some of the Arabs; and the latter, by others; but some disallow the latter in this sense; and some say that the"},{"kind":"italic_en","text":"former is more"},{"kind":"text","text":"chaste than the latter thus used: (TA:) or both signify"},{"kind":"italic_en","text":"he became far distant from his home"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"native country; became a stranger,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estranged, therefrom:"},{"kind":"text","text":"(L, TA:) or the Arabs say,"},{"kind":"arabic","text_bw":"baEida Alr~ajulu","text_ar":"بَعِدَ الرَّجُلُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"tbAEd","text_ar":"تباعد"},{"kind":"text","text":", when not reviling; but when reviling, they say,"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":", only. (Yoo, TA.) You say,"},{"kind":"arabic","text_bw":"laA taboEadN","text_ar":"لَا تَبْعَدٌ"},{"kind":"arabic","text_bw":"wa A_ino baEudota Ean~aY","text_ar":"وَ اـِنْ بَعُدْتَ عَنَّى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Mayest thou not perish though thou be distant from me!"},{"kind":"text","text":"] (A.) [And as an imprecation against a man, you say,"},{"kind":"arabic","text_bw":"baEidota","text_ar":"بَعِدْتَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Mayest thou perish!"},{"kind":"text","text":"(See the printed edition of the Ham, pp. 89 and 90, where"},{"kind":"arabic","text_bw":"baEidotaAYa hlkt","text_ar":"بَعِدْتَاىَ هلكت"},{"kind":"text","text":"is an evident mistake for"},{"kind":"arabic","text_bw":"aEidota A^aY halakota","text_ar":"َعِدْتَ اَى هَلَكْتَ"},{"kind":"text","text":".)] And"},{"kind":"arabic","text_bw":"buEodFA lahu","text_ar":"بُعْدًا لَهُ"},{"kind":"italic_en","text":"May God alienate him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estrange him, from good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity!"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"curse him!"},{"kind":"text","text":"(A, * K, TA;) i. e. may he not be pitied with respect to that which has befallen him! like"},{"kind":"arabic","text_bw":"suHoqFA lahu","text_ar":"سُحْقًا لَهُ"},{"kind":"text","text":": the most approved way being to put"},{"kind":"arabic","text_bw":"bEd","text_ar":"بعد"},{"kind":"text","text":"thus in the accus. case as an inf. n.; but the tribe of Temeem say,"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"suHoqN","text_ar":"سُحْقٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"gulaAmN lahu","text_ar":"غُلَامٌ لَهُ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":"is made trans. by means of [the preposition]"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":": see 4. (Msb.)"}],"source_refs":["S","L","Msb","K","TA"]},{"entry_id":"n2866","headword_ar":"بَعْدُ","root":"bEd","body":[{"kind":"text","text":"an adv. n. of time, signifying"},{"kind":"italic_en","text":"After,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afterwards:"},{"kind":"text","text":"and allowable also, accord. to some of the grammarians, as an adv. n. of place, signifying"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behind:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"qabolu","text_ar":"قَبْلُ"},{"kind":"text","text":": (S, A, K:) it is a vague adv. n., of which the meaning is not understood without its being prefixed to another noun [expressed or implied]; denoting after-time. (Msb.) When it occurs without any complement, (S, K,) a noun or the like which should be its complement being intended to be understood as to the meaning thereof but not as to the letter, (S, * TA,) it is indecl., (S, K,) because it resembles a particle, (TA,) and has damm for its termination to show that it is indecl., since it cannot have damm by any rule of desinential syntax because it cannot occur as an agent nor as an inchoative or enunciative. (S.) Sb, however, mentions [as exceptions to this rule] the phrases"},{"kind":"arabic","text_bw":"mino baEodK","text_ar":"مِنْ بَعْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Afterwards"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"A^afoEalu h`*aA baEodFA","text_ar":"اَفْعَلُ هٰذَا بَعْدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will do this afterwards"},{"kind":"text","text":"], as having been used by the Arabs. (K, * TA.) [The latter of these phrases is common in the present day. Another exception to the rule above-mentioned will be found in what follows.] Accord. to the primary rule, it is used as a prefixed n. governing its complement in the gen. case; (S;) [i. e., it is used in the manner of a preposition;] and when thus used, it is decl., (K,) because it does not in this case [always] resemble a particle. (TA.) You say,"},{"kind":"arabic","text_bw":"jaA='a zayodN baEoda EamorKw","text_ar":"جَا=ءَ زَيْدٌ بَعْدَ عَمْرٍو"},{"kind":"italic_en","text":"Zeyd came after 'Amr."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"raA^ayotuhu baEodaka","text_ar":"رَاَيْتُهُ بَعْدَكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"baEodika","text_ar":"بَعْدِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw him after thee"},{"kind":"text","text":"]. (L.) The words of the Kur [xxx. 3],"},{"kind":"arabic","text_bw":"A@ll~`hi A@loA^amoru mino qabolu wa mino baEodu","text_ar":"ا@للّٰهِ ا@لْاَمْرُ مِنْ قَبْلُ وَ مِنْ بَعْدُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"To God"},{"kind":"text","text":"belonged"},{"kind":"italic_en","text":"the command before"},{"kind":"text","text":"that the Greeks were overcome"},{"kind":"italic_en","text":"and after"},{"kind":"text","text":"that they had been overcome, [thus read when the complements of"},{"kind":"arabic","text_bw":"qbl","text_ar":"قبل"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bEd","text_ar":"بعد"},{"kind":"text","text":"are intended to be understood as to the meaning thereof but not as to the letter,] are also read"},{"kind":"arabic","text_bw":"mino qaboli wa mino baEodi","text_ar":"مِنْ قَبْلِ وَ مِنْ بَعْدِ"},{"kind":"text","text":", when each complement is intended to be understood as to the meaning and the letter, and also"},{"kind":"arabic","text_bw":"mino qabolK wa mino baEodK","text_ar":"مِنْ قَبْلٍ وَ مِنْ بَعْدٍ"},{"kind":"text","text":", meaning To God belongeth the command"},{"kind":"italic_en","text":"first and last,"},{"kind":"text","text":"[when neither complement is intended to be understood either as to the letter or as to the meaning,] but the first of these readings is the best. (L.) [You say also,"},{"kind":"arabic","text_bw":"baEoda *`lika","text_ar":"بَعْدَ ذٰلِكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"baEodi *`lika","text_ar":"بَعْدِ ذٰلِكَ"},{"kind":"italic_en","text":"After that:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEoda A^ano faEalotu","text_ar":"بَعْدَ اَنْ فَعَلْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"baEodi A^ano faEalotu","text_ar":"بَعْدِ اَنْ فَعَلْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baEoda maA faEalotu","text_ar":"بَعْدَ مَا فَعَلْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino baEodi maA","text_ar":"مِنْ بَعْدِ مَا"},{"kind":"arabic","text_bw":"faEalotu","text_ar":"فَعَلْتُ"},{"kind":"italic_en","text":"After I did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after my doing,"},{"kind":"text","text":"such a thing: &c.] Also"},{"kind":"arabic","text_bw":"jiy^otu baEodayokumaA","text_ar":"جِيْتُ بَعْدَيْكُمَا"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"baEoda kumaA","text_ar":"بَعْدَ كُمَا"},{"kind":"text","text":","},{"kind":"italic_en","text":"I came after you two."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"h`*aA mim~aA","text_ar":"هٰذَا مِمَّا"},{"kind":"arabic","text_bw":"layosa baEodahu gaAyapN fiY Aljawodapi","text_ar":"لَيْسَ بَعْدَهُ غَايَةٌ فِى الجَوْدَةِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY Alr~adaA='ap","text_ar":"فِى الرَّدَا=ءَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"This is of the things after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beyond, which there is not any extreme degree in respect of goodness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in respect of badness:"},{"kind":"text","text":"and, by way of abridgement,"},{"kind":"arabic","text_bw":"layosa baEodahu","text_ar":"لَيْسَ بَعْدَهُ"},{"kind":"text","text":"[with nothing following this]: and hence, app., the saying of Mohammad,"},{"kind":"arabic","text_bw":"waA_ino","text_ar":"وَاـِنْ"},{"kind":"arabic","text_bw":"kaAna layosa biAl~a*iY laA baEoda lahu","text_ar":"كَانَ لَيْسَ بِالَّذِى لَا بَعْدَ لَهُ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"And though"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it be not in the utmost degree"},{"kind":"text","text":"in respect of goodness:"},{"kind":"arabic","text_bw":"bEd","text_ar":"بعد"},{"kind":"text","text":"being thus used as a decl. noun. (Mgh.)"}],"source_refs":["TA","S","A","K"]},{"entry_id":"n2868","headword_ar":"بُعْدٌ","root":"bEd","body":[{"kind":"text","text":"[as an inf. n. used in the manner of a subst. signifies]"},{"kind":"italic_en","text":"Distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remoteness;"},{"kind":"text","text":"(S, A, L, K; *) and so ↓"},{"kind":"arabic","text_bw":"baEadN","text_ar":"بَعَدٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) accord. to most of the leading lexicologists, (TA, [see"},{"kind":"arabic","text_bw":"baEoda","text_ar":"بَعْدَ"},{"kind":"text","text":",]) [and ↓"},{"kind":"arabic","text_bw":"buEodapN","text_ar":"بُعْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", for] you say,"},{"kind":"arabic","text_bw":"bayonanaA buEodapN","text_ar":"بَيْنَنَا بُعْدَةٌ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Between us two is a distance"},{"kind":"text","text":"] of land or country, or of relationship. (S, K.) ―         -b2-  ["},{"kind":"italic_en","text":"Remoteness from probability"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correctness; improbability,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strangeness:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"baEuda","text_ar":"بَعُدَ"},{"kind":"text","text":". Hence the phrase,"},{"kind":"arabic","text_bw":"h`*aA mina AlbuEodi","text_ar":"هٰذَا مِنَ البُعْدِ"},{"kind":"arabic","text_bw":"bimakaAnK","text_ar":"بِمَكَانٍ"},{"kind":"italic_en","text":"This is improbable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strange:"},{"kind":"text","text":"often occurring in the TA &c.] ―         -b3-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ","orth_type":"arrow"},{"kind":"text","text":": (L, K:) this latter (S, L, Msb, K) and"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":", (L, K,) accord. to most of the leading lexicologists, as, for instance, in the Kur xi. 98, (TA, [see"},{"kind":"arabic","text_bw":"baEida","text_ar":"بَعِدَ"},{"kind":"text","text":",]) signifying"},{"kind":"italic_en","text":"Perdition;"},{"kind":"text","text":"(S, L, Msb;) or"},{"kind":"italic_en","text":"death."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"italic_en","text":"Judgment and prudence;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"buEodapN","text_ar":"بُعْدَةٌ","orth_type":"arrow"},{"kind":"text","text":": so in the phrase,"},{"kind":"arabic","text_bw":"A_in~ahu la*uw","text_ar":"اـِنَّهُ لَذُو"},{"kind":"arabic","text_bw":"buEodK","text_ar":"بُعْدٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"buEodapK","text_ar":"بُعْدَةٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Verily he is possessed of judgment and prudence:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"penetrating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effective, judgment; depth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profundity; far-reaching judgment."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"A^aboEadu","text_ar":"اَبْعَدُ"},{"kind":"text","text":".] ↓"},{"kind":"arabic","text_bw":"*uw AlbuEodapi","text_ar":"ذُو البُعْدَةِ","orth_type":"arrow"},{"kind":"text","text":"also signifies A man"},{"kind":"italic_en","text":"who goes to a great length,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far, in hostility."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"italic_en","text":"A cursing; execration; malediction;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"biEaAdN","text_ar":"بِعَادٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"buEodN lahu","text_ar":"بُعْدٌ لَهُ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"buEodFA lahu","text_ar":"بُعْدًا لَهُ"},{"kind":"text","text":": see 1, last sentence but one. (TA.)"}],"source_refs":["L","K","S","Msb"]},{"entry_id":"n2870","headword_ar":"بُعْدٌ","root":"bEd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aboEadu","text_ar":"اَبْعَدُ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n2869","headword_ar":"بَعَدٌ","root":"bEd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buEodN","text_ar":"بُعْدٌ"},{"kind":"text","text":", in two places:       -A2-  and"},{"kind":"arabic","text_bw":"baEiydN","text_ar":"بَعِيدٌ"},{"kind":"text","text":", in five places."}],"source_refs":[]}]}}