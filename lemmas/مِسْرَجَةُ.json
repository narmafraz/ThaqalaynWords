{"lemma":"مِسْرَجَةُ","slug":"مِسْرَجَةُ","root":"س.ر.ج","root_slug":"س-ر-ج","root_link":"/words/roots/س-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n19503","n19504"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%90%D8%B3%D9%92%D8%B1%D9%8E%D8%AC%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19503","headword_ar":"مَسْرَجَةٌ","root":"srj","body":[{"kind":"text","text":", with fet-h (S, Mgh, O, Msb) to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (Msb,) ["},{"kind":"italic_en","text":"A lamp;"},{"kind":"text","text":"i. e.] the"},{"kind":"italic_en","text":"thing in which is the wick and the oil:"},{"kind":"text","text":"(S, Mgh, O, TA:) and also the"},{"kind":"italic_en","text":"thing upon which the"},{"kind":"arabic","text_bw":"siraAj","text_ar":"سِرَاج"},{"kind":"text","text":"[app. here meaning"},{"kind":"italic_en","text":"lamp"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is put:"},{"kind":"text","text":"(O:) or the"},{"kind":"italic_en","text":"thing upon which the"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"misorajap","text_ar":"مِسْرَجَة","orth_type":"arrow"},{"kind":"italic_en","text":"is placed:"},{"kind":"text","text":"(Msb:) or ↓"},{"kind":"arabic","text_bw":"misorajapN","text_ar":"مِسْرَجَةٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr, has the last of these meanings:"},{"kind":"arabic","text_bw":"masorajapN","text_ar":"مَسْرَجَةٌ"},{"kind":"text","text":", with fet-h, having the first thereof: or, as some say, the reverse is the case; (Mgh;) [i. e.] ↓"},{"kind":"arabic","text_bw":"misorajapN","text_ar":"مِسْرَجَةٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr, signifies the"},{"kind":"italic_en","text":"thing in which is the wick"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and the oil"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"masorajapN","text_ar":"مَسْرَجَةٌ"},{"kind":"text","text":", with fet-h, the"},{"kind":"italic_en","text":"thing upon which that is put:"},{"kind":"text","text":"(A, TA:) the pl. (of either, Mgh) is"},{"kind":"arabic","text_bw":"masaAriju","text_ar":"مَسَارِجُ"},{"kind":"text","text":". (Mgh, Msb.) [See also"},{"kind":"arabic","text_bw":"siraAjN","text_ar":"سِرَاجٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","O","Msb","TA","A"]},{"entry_id":"n19504","headword_ar":"مِسْرَجَةٌ","root":"srj","body":[{"kind":"text","text":": see the next preceding paragraph, in three places."}],"source_refs":[]}]},"classical_definitions":null}