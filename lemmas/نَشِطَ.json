num":"p"},{"role":"present_2mp","form":"تَنْشَطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْشَطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْشَط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْشَط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْشَطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْشَطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْشَطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْشَطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْشَطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْشَطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْشَطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَنْشَط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْشَط","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"نَشِطْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَشِطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":true,"lemma_key":"نَشِطَ","root":"نشط","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n39828"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%90%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be brisk, to be lively, to be active, to be agile, to be prompt, to be quick, to be energetic"},{"pos":"verb","gloss":"to be pleased, to be cheerful, to be happy, to be willing"},{"pos":"noun","gloss":"verbal noun of نَشَطَ (našaṭa)","tags":["form-of","noun-from-verb"],"examples":[{"text":"وَٱلنَّاشِطَاتِ نَشْطًا","english":"And those who remove with ease"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39828","headword_ar":"نَشِطَ","root":"n$T","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"na$aATN","text_ar":"نَشَاطٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"mano$aTN","text_ar":"مَنْشَطٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, TA, and a beast of carriage, TA,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, lively, sprightly, frisky, active, agile, prompt,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"quick;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xaf~a","text_ar":"خَفَّ"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"A^asoraEa","text_ar":"اَسْرَعَ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"kasila","text_ar":"كَسِلَ"},{"kind":"text","text":"; (TA;) or"},{"kind":"italic_en","text":"pleased, cheerful, happy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"willing;"},{"kind":"text","text":"to do work, &c.; (Lth, K;) or by reason of his work; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"tn$~T","text_ar":"تنشّط","orth_type":"arrow"},{"kind":"text","text":", (S, * K,)"},{"kind":"arabic","text_bw":"liA^amori ka*aA","text_ar":"لِاَمْرِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on account of, such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such an affair"},{"kind":"text","text":"]. (S, TA.) You say also,"},{"kind":"arabic","text_bw":"na$iTa A_ilayohi","text_ar":"نَشِطَ اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He betook himself to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with briskness, liveliness, sprightliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (TA.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"na$iTati Ald~aAb~apu","text_ar":"نَشِطَتِ الدَّابَّةُ"},{"kind":"italic_en","text":"The beast of carriage became fat."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"na$aTa","text_ar":"نَشَطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"na$oTN","text_ar":"نَشْطٌ"},{"kind":"text","text":", (S, K, TA,)"},{"kind":"italic_en","text":"He went forth"},{"kind":"text","text":"from a place: (K:)"},{"kind":"italic_en","text":"he passed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crossed,"},{"kind":"text","text":"from one country or the like to another: (TA:) said, for instance, of a wild bull: (AO, IDrd, S, K:) and in like manner, a star, [meaning a planet,] from one sign of the zodiac to another. (S, K.) And"},{"kind":"arabic","text_bw":"na$aTati AlA_ibilu","text_ar":"نَشَطَتِ الاـِبِلُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"na$oTN","text_ar":"نَشْطٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The camels went,"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"in a right direction"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Alhumuwmu tano$iTu biSaAHibihaA","text_ar":"الهُمُومُ تَنْشِطُ بِصَاحِبِهَا"},{"kind":"text","text":"(S, TA) (assumed tropical:)"},{"kind":"italic_en","text":"Griefs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquietudes of mind, lead forth him who has them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from place to place"},{"kind":"text","text":"]. (TA.) Himyán Ibn- Koháfeh says,"},{"kind":"quote","text":"A^amosata humuwmiY tano$iTu AlmanaA$iTaA\n                      \n                     \n                        A^al$~aA^oma biY TaworFA waTaworFA waAsiTaA"},{"kind":"text","text":"[meaning"},{"kind":"arabic","text_bw":"tn$T bY AlY AlmnA$T","text_ar":"تنشط بى الى المناشط"},{"kind":"text","text":", i. e., (assumed tropical:)"},{"kind":"italic_en","text":"My griefs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquietudes of mind, became such as to lead me forth to the places to which one goes forth, to Syria at one time, and at one time to Wásit"},{"kind":"text","text":"]. (S.) You say also of a road,"},{"kind":"arabic","text_bw":"yano$iTu mina AlT~ariyqi","text_ar":"يَنْشِطُ مِنَ الطَّرِيقِ"},{"kind":"arabic","text_bw":"AlA^aEoZami","text_ar":"الاَعْظَمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It goes forth from the main road,"},{"kind":"text","text":"to the right, and to the left. (Lth, K. *) And"},{"kind":"arabic","text_bw":"na$Ta bihimo","text_ar":"نَشطَ بِهِمْ"},{"kind":"arabic","text_bw":"TariyqN faA^axa*uwhu","text_ar":"طَرِيقٌ فَاَخَذُوهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"A road led them forth, and they took it"},{"kind":"text","text":"]. (TA.)       -A3-"},{"kind":"arabic","text_bw":"na$aTa Ald~alowa","text_ar":"نَشَطَ الدَّلْوَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"(K, * TA) and"},{"kind":"text","text":", (TA,) [inf. n."},{"kind":"arabic","text_bw":"na$oTN","text_ar":"نَشْطٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He pulled out the bucket,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"pulled it up,"},{"kind":"text","text":"(TA,) from the well, (S, TA,)"},{"kind":"italic_en","text":"without a pulley."},{"kind":"text","text":"(S, K.) ―         -b2-  And hence,"},{"kind":"arabic","text_bw":"AlmalaAy^ikapu tano$iTu AlA^arowaAHa","text_ar":"المَلَايِكَةُ تَنْشِطُ الاَرْوَاحَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The angels draw forth the souls like as the bucket is drawn forth from the well:"},{"kind":"text","text":"(Zj:) and"},{"kind":"arabic","text_bw":"tano$iTu nafosa","text_ar":"تَنْشِطُ نَفْسَ"},{"kind":"arabic","text_bw":"Almuw^omini biqaboDihaA","text_ar":"المُوْمِنِ بِقَبْضِهَا"},{"kind":"text","text":"(Fr, L, K [in the CK"},{"kind":"arabic","text_bw":"taqobiDuhA","text_ar":"تَقْبِضُها"},{"kind":"text","text":"]) which means, (K,) accord. to Ibn-'Aráfeh, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"they loose the soul of the believer gently."},{"kind":"text","text":"(K, TA.) ―         -b3-  [Hence also,] one says of a she-camel, [likening the motion of her fore legs to that of the arms of a man pulling up a bucket from a well without a pulley,]"},{"kind":"arabic","text_bw":"Hasuna maA na$aTati Als~ayora","text_ar":"حَسُنَ مَا نَشَطَتِ السَّيْرَ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Good was her wide stretching out of her fore legs"},{"kind":"text","text":"(As, S, TA)"},{"kind":"italic_en","text":"in her going along."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"na$aTa AlHabola","text_ar":"نَشَطَ الحَبْلَ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (K, and so in a copy of the S,) or"},{"kind":"text","text":", (Msb, and so in a copy of the S,) inf. n."},{"kind":"arabic","text_bw":"na$oTN","text_ar":"نَشْطٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He tied the cord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rope so as to form a knot;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"n$~aThu","text_ar":"نشَّطهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"tano$iyTN","text_ar":"تَنْشِيطٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"he tied it in a knot such as is termed"},{"kind":"arabic","text_bw":"A^uno$uwTap","text_ar":"اُنْشُوطَة"},{"kind":"text","text":"; (AZ, S, Msb;) as also ↓ the latter verb: (Ham, p."},{"kind":"text","text":"742"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"na$aTa AlEuqodapa","text_ar":"نَشَطَ العُقْدَةَ"},{"kind":"italic_en","text":"he tied the knot so as to form what is thus termed:"},{"kind":"text","text":"(Mgh:) and"},{"kind":"arabic","text_bw":"na$aTa AlA^uno$uwTapa","text_ar":"نَشَطَ الاُنْشُوطَةَ"},{"kind":"italic_en","text":"he tied the knot thus termed."},{"kind":"text","text":"(TA.) [See also 4.]       -A5-"},{"kind":"arabic","text_bw":"na$aTa","text_ar":"نَشَطَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"nu$iTa mino EiqaAlK","text_ar":"نُشِطَ مِنْ عِقَالٍ"},{"kind":"text","text":": see 4."}],"source_refs":["S","Msb","K","TA","AO","IDrd","Zj","As","Mgh"]}]},"classical_definitions":null}