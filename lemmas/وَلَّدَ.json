42351","n42352"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%84%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bear, to beget","examples":[{"text":"وُلِدْتُ فِي مَدِينَةٍ كَبِيرَةٍ.","english":"I was born in a big city."},{"text":"لَمْ يَلِدْ وَلَمْ يُولَدْ","english":"He neither begets nor is born,"}]},{"pos":"verb","gloss":"to produce, to bring forth"},{"pos":"verb","gloss":"to assist in childbirth (as a midwife)"},{"pos":"verb","gloss":"to make children to, to cause to give birth"},{"pos":"verb","gloss":"to rear, to educate, to bring up"},{"pos":"verb","gloss":"to innovate, to originate, to generate, to produce","examples":[{"text":"وَجَمَالُ ٱلْأَشْخَاصِ هُوَ أَمْرٌ يُؤَثِّرُ بِٱلْمَشَاعِرِ وَيُوَلِّدُ ٱلْإنْجِذَابَ نَحْوَ الْآخَرِينَ.","english":"The beauty of people is something that affects feelings and generates attraction towards others."}]},{"pos":"verb","gloss":"to give birth"},{"pos":"verb","gloss":"to derive (a word)"},{"pos":"noun","gloss":"child (“son or daughter of any age”)","examples":[{"text":"أُرِيدُ أَنْ أَلْعَبَ مَعَ أَوْلَادِكَ.","english":"I want to play with your children."},{"text":"وَلَا تَقْتُلُوا أَوْلَادَكُمْ خَشْيَةَ إِمْلَاقٍ ۖ نَحْنُ نَرْزُقُهُمْ وَإِيَّاكُمْ ۚ إِنَّ قَتْلَهُمْ كَانَ خِطْئًا كَبِيرًا","english":"And do not kill your children for fear of poverty. We provide for them and for you. Indeed, their killing is ever a great sin."}]},{"pos":"noun","gloss":"offspring, issue","tags":["collective"]},{"pos":"noun","gloss":"boy","tags":["colloquial"]},{"pos":"noun","gloss":"son","tags":["colloquial"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *walad-.\n\nForm-II intensive/causative of وَلَدَ (walada, “to give birth”).\n\nCompare Hebrew יֶלֶד (yéled), Ge'ez ወልድ (wäld)."},"ipa":["/wa.la.da/","/wal.la.da/","/wa.lad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42349","headword_ar":"وَلْدٌ","root":"wld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n42351","headword_ar":"وِلْدٌ","root":"wld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"wulod","text_ar":"وُلْد"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n42352","headword_ar":"وَلَدٌ","root":"wld","body":[{"kind":"text","text":"(of the measure"},{"kind":"arabic","text_bw":"faEalN","text_ar":"فَعَلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":", Msb) and ↓"},{"kind":"arabic","text_bw":"wulodN","text_ar":"وُلْدٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"wilodN","text_ar":"وِلْدٌ","orth_type":"arrow"},{"kind":"text","text":"(S, L, K) and ↓"},{"kind":"arabic","text_bw":"walodN","text_ar":"وَلْدٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) each used alike as sing. and pl., (S, M, A, L, K,) and masc. and fem., (M, L, Msb,)"},{"kind":"italic_en","text":"A child, son, daughter, youngling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young one;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"children, sons, daughters, offspring, young,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"younglings; of any kind:"},{"kind":"text","text":"[often applied to"},{"kind":"italic_en","text":"an unborn child,"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"a fœtus:"},{"kind":"text","text":"] (M, L, Msb:) pl. [of pauc.] of"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":", (M, L, Msb, TA,) and of"},{"kind":"arabic","text_bw":"wulodN","text_ar":"وُلْدٌ"},{"kind":"text","text":", (M, L,)"},{"kind":"arabic","text_bw":"A^awolaAdN","text_ar":"اَوْلَادٌ"},{"kind":"text","text":"; (M, L, Msb, K;) and [pl. of pauc. of"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":",]"},{"kind":"arabic","text_bw":"wilodapN","text_ar":"وِلْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilodapN","text_ar":"اـِلْدَةٌ"},{"kind":"text","text":": (M, L, K:) and pl. of"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"wulodN","text_ar":"وُلْدٌ"},{"kind":"text","text":", (S, M, L, Msb, K, *) like as"},{"kind":"arabic","text_bw":"A^usodN","text_ar":"اُسْدٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"A^asadN","text_ar":"اَسَدٌ"},{"kind":"text","text":", (S, L, Msb,) in the dial. of the tribe of Keys, (T, Msb,) who make"},{"kind":"arabic","text_bw":"waladN","text_ar":"وَلَدٌ"},{"kind":"text","text":"singular. (T.) ―         -b2-"},{"kind":"arabic","text_bw":"mano dam~aY Eaqibayoki","text_ar":"مَنْ دَمَّى عَقِبَيْكِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wuloduki","text_ar":"وُلْدُكِ","orth_type":"arrow"},{"kind":"text","text":", a proverb, (T, S, L; but in the S,"},{"kind":"arabic","text_bw":"Eaqibayoka","text_ar":"عَقِبَيْكَ"},{"kind":"text","text":";) of the Benoo-Asad, (S, L,)"},{"kind":"italic_en","text":"Thy son is he who made thy two heels to be smeared with blood;"},{"kind":"text","text":"(TA;) i. e., whom thou thyself broughtest forth; (K, TA;) he is thy son really; not he whom thou hast taken from another, and adopted. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maA A^adoriY A^aY~u","text_ar":"مَا اَدْرِى اَىُّ"},{"kind":"arabic","text_bw":"waladi Alr~ajul huwa","text_ar":"وَلَدِ الرَّجُل هُوَ"},{"kind":"italic_en","text":"I know not what man he is."},{"kind":"text","text":"(S, K.)"}],"source_refs":["S","A","L","Msb","K","M","TA","T"]}]}}