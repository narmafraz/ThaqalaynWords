gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَكِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَكِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَكِّع","in_corpus":true,"count":58,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَكِّع","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَكِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَكِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَكِّعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَكِّعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَكِّعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَكِّعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَكِّعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُرَكِّع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَكِّع","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَكَّعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَكَّعْتُ","in_corpus":true,"count":11,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":196,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n16522"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%83%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bow, to kneel, to kowtow"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew כָּרַע (kāráʿ, “to kneel, bend down”) and Ugaritic 𐎋𐎗𐎓 (krʿ, “to prostrate onself”)."},"ipa":["/ra.ka.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16522","headword_ar":"رَكَعَ","root":"rkE","body":[{"kind":"text","text":", (Th, S, &c.,) aor."},{"kind":"text","text":", (Th, TA,) inf. n."},{"kind":"arabic","text_bw":"rukuwEN","text_ar":"رُكُوعٌ"},{"kind":"text","text":"(Th, S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"rakoEN","text_ar":"رَكْعٌ"},{"kind":"text","text":", (Th, TA,)"},{"kind":"italic_en","text":"He bowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent, himself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became bowed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent:"},{"kind":"text","text":"(Th, S, Mgh, Msb:) so says Er-Rághib, adding that it is sometimes used to denote a particular manner of doing so in prayer, and sometimes to denote humility and self-abasement either in worship or in other cases: (TA:)"},{"kind":"italic_en","text":"he lowered his head:"},{"kind":"text","text":"(Th:) and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(an old man)"},{"kind":"italic_en","text":"bowed himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became bowed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent, by reason of age:"},{"kind":"text","text":"(S, Msb, K:) this is [said to be] the primary signification: (TA:) or"},{"kind":"italic_en","text":"he fell upon his face;"},{"kind":"text","text":"(IDrd, IB, K;) and"},{"kind":"italic_en","text":"stumbled."},{"kind":"text","text":"(IB.) ―         -b2-  And hence, from"},{"kind":"arabic","text_bw":"rakaEa","text_ar":"رَكَعَ"},{"kind":"text","text":"as used in the first of the senses explained above, (S, Mgh,) or as used in the first of the senses assigned to it above when said of an old man, (TA,) or as used in the last sense explained above, (IB,)"},{"kind":"arabic","text_bw":"rukuwEu AlS~alaApi","text_ar":"رُكُوعُ الصَّلَاةِ"},{"kind":"text","text":", (S, IB, Mgh, TA,) or"},{"kind":"arabic","text_bw":"Alr~ukuwEu","text_ar":"الرُّكُوعُ"},{"kind":"arabic","text_bw":"fiY AlS~alaAp","text_ar":"فِى الصَّلَاة"},{"kind":"text","text":","},{"kind":"italic_en","text":"The lowering of the head,"},{"kind":"text","text":"(K, TA,) by a person praying, (TA,) [or"},{"kind":"italic_en","text":"in prayer,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"after the act of standing in which the recitation"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of portions of the Kur-án"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"is performed, so that the palms of the hands reach the knees;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"so that the back becomes depressed;"},{"kind":"text","text":"(K, TA;) accord. to the doctors of practical law,"},{"kind":"italic_en","text":"so that if a cup full of water be placed upon the back, it will not be spilled."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"rakaEa A_ilaY A@ll~`hi","text_ar":"رَكَعَ اـِلَى ا@للّٰهِ"},{"kind":"italic_en","text":"He lowered his head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he humbled himself, to God;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AiTomaA^an~a","text_ar":"اِطْمَاَنَّ"},{"kind":"text","text":". (Z, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"rakaEa","text_ar":"رَكَعَ"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"He prayed;"},{"kind":"text","text":"(Mgh;) and so ↓"},{"kind":"arabic","text_bw":"trk~E","text_ar":"تركّع","orth_type":"arrow"},{"kind":"text","text":". (TA.) Thus in the Kur [ii. 40],"},{"kind":"arabic","text_bw":"waA@rokaEuwA maEa Alr~aAkiEiyna","text_ar":"وَا@رْكَعُوا مَعَ الرَّاكِعِينَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"And pray ye with those who pray."},{"kind":"text","text":"(Mgh.) You say also,"},{"kind":"arabic","text_bw":"rakaEa rakoEapF","text_ar":"رَكَعَ رَكْعَةً"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rakoEatayoni","text_ar":"رَكْعَتَيْنِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"valaAva rakaEaAtK","text_ar":"ثَلَاثَ رَكَعَاتٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He prayed a rek'ah,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"two rek'ahs,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"three rek'ahs."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"rakoEapN","text_ar":"رَكْعَةٌ"},{"kind":"text","text":", below.] ―         -b5-  Also, accord. to IKoot and several others,"},{"kind":"italic_en","text":"He stood to prayer."},{"kind":"text","text":"(Msb) ―         -b6-"},{"kind":"arabic","text_bw":"lagibati AlA_ibilu Hat~aY rakaEato","text_ar":"لَغِبَتِ الاـِبِلُ حَتَّى رَكَعَتْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The camels became fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigued in the utmost degree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languid in consequence of fatigue, so that they lowered their heads, and fell upon their faces."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"rakaEati Aln~axolapu","text_ar":"رَكَعَتِ النَّخْلَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The palm-tree inclined:"},{"kind":"text","text":"a phrase which may be of classical authority, but [Mtr says,] I have not found it. (Mgh.) ―         -b8-  Said of a man, (TA,)"},{"kind":"arabic","text_bw":"rakaEa","text_ar":"رَكَعَ"},{"kind":"text","text":", also signifies (tropical:)"},{"kind":"italic_en","text":"He became poor after richness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency; and his state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, became lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abased."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["Th","TA","S","Mgh","Msb","K","IB"]}]}}