":"arabic","text_bw":"mawoDuwEN","text_ar":"مَوْضُوعٌ"},{"kind":"text","text":", in logic, (assumed tropical:)"},{"kind":"italic_en","text":"A subject, as opposed to a predicate:"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"a substance, as opposed to an accident:"},{"kind":"text","text":"in each sense,"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"maHomuwlN","text_ar":"مَحْمُولٌ"},{"kind":"text","text":". ―         -b4-  (assumed tropical:)  The"},{"kind":"italic_en","text":"subject"},{"kind":"text","text":"of a book or the like. ―         -b5-  See"},{"kind":"arabic","text_bw":"maSonuwEN","text_ar":"مَصْنُوعٌ"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"A^aSowaAtN maSuwgapN","text_ar":"اَصْوَاتٌ مَصُوغَةٌ"},{"kind":"arabic","text_bw":"mawuDuwEapN","text_ar":"مَوُضُوعَةٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Swg","text_ar":"صوغ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}