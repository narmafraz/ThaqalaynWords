"},{"role":"present_2mp","form":"تَخْسَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْسَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْسَر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْسَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْسَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْسَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْسَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْسَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْسَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْسَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْسَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْسَر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْسَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَسِرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَسِرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"خَسِرَ","root":"خسر","pos":"V","occurrence_count":16},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":16},"lanes":{"found":true,"entry_ids":["n10590"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B3%D9%90%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lose"},{"pos":"verb","gloss":"to be deceived, beguiled, cheated, circumvented"},{"pos":"verb","gloss":"to err, go astray, deviate from the right way, to become lost"},{"pos":"verb","gloss":"to perish, die"},{"pos":"verb","gloss":"to make defective or deficient"},{"pos":"verb","gloss":"to make (someone) lose"},{"pos":"verb","gloss":"to make (someone) err, go astray, to make (someone) become lost"},{"pos":"verb","gloss":"to make (someone) perish"},{"pos":"verb","gloss":"to destroy, to make perish, to mar, to scathe"},{"pos":"verb","gloss":"to put afar, to alienate, to estrange, to remove"},{"pos":"verb","gloss":"to attribute error to, to claim to have gone astray, to impute loss to"},{"pos":"noun","gloss":"verbal noun of خَسِرَ (ḵasira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَسِرَ (ḵasira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَسَرَ (ḵasara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَسِرَ (ḵasira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَسِرَ (ḵasira) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"From the root خ س ر (ḵ s r). Possibly related to Hebrew חסר (khasér, “absent, missing”) or Egyptian ḫsr (“to dispel, to drive away”)."},"ipa":["/xa.si.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10590","headword_ar":"خَسِرَ","root":"xsr","body":[{"kind":"text","text":", (S, A, Msb, K, &c.,) aor."},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"xasara","text_ar":"خَسَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) but the latter is an unusual form [except in the sense of"},{"kind":"arabic","text_bw":"A^axosara","text_ar":"اَخْسَرَ"},{"kind":"text","text":"]; (B, TA;) inf. n."},{"kind":"arabic","text_bw":"xusoraAnN","text_ar":"خُسْرَانٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"xusorN","text_ar":"خُسْرٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"xasaArapN","text_ar":"خَسَارَةٌ"},{"kind":"text","text":"(Msb, K) [which are the only forms assigned in the TA to the verb when used with reference to traffic] and"},{"kind":"arabic","text_bw":"xusurN","text_ar":"خُسُرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xasorN","text_ar":"خَسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xasarN","text_ar":"خَسَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xasaArN","text_ar":"خَسَارٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffered loss"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diminution:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was deceived, cheated, beguiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumvented:"},{"kind":"text","text":"(K:)"},{"kind":"arabic","text_bw":"fiY AlbayoEi","text_ar":"فِى البَيْعِ"},{"kind":"italic_en","text":"in selling;"},{"kind":"text","text":"(S;) or"},{"kind":"arabic","text_bw":"fiY bayaEihi","text_ar":"فِى بَيَعِهِ"},{"kind":"italic_en","text":"in his selling;"},{"kind":"text","text":"(A;) or"},{"kind":"arabic","text_bw":"fiY tijaAratihi","text_ar":"فِى تِجَارَتِهِ"},{"kind":"italic_en","text":"in his traffic:"},{"kind":"text","text":"(Msb, K: [see also 4:]) the former is the original signification: (TA:)"},{"kind":"italic_en","text":"he suffered diminution of his capital; he lost part thereof:"},{"kind":"text","text":"(B, TA:) and"},{"kind":"italic_en","text":"he lost his capital altogether."},{"kind":"text","text":"(Bd in iv. 118; &c.)"},{"kind":"arabic","text_bw":"xusoraAnN","text_ar":"خُسْرَانٌ"},{"kind":"text","text":"is also attributed to an action, as well as to a man: (B, TA:) you say, (but in this case the verb is used tropically, A,)"},{"kind":"arabic","text_bw":"xasirato tijaAratuhu","text_ar":"خَسِرَتْ تِجَارَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His traffic was losing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an occasion of loss"},{"kind":"text","text":"]; (A, B;) opposed"},{"kind":"page_break","n":737},{"kind":"text","text":"to"},{"kind":"arabic","text_bw":"rabiHato","text_ar":"رَبِحَتْ"},{"kind":"text","text":". (A.) It is also used in relation to personal acquisitions; such as health, and safety, and intellect, and faith, and the recompense or reward of obedience [to God], which God has declared [Kur xxii. 11 and xxxix. 17] to be manifest"},{"kind":"arabic","text_bw":"xusoraAn","text_ar":"خُسْرَان"},{"kind":"text","text":", (B,) since there is none like it. (Bd.) For instance, you say,"},{"kind":"arabic","text_bw":"xasira Eaqolahu","text_ar":"خَسِرَ عَقْلَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maAlahu","text_ar":"مَالَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He lost his intellect,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his property."},{"kind":"text","text":"(IAar.) [In a phrase of this kind, the noun which immediately follows the verb may be considered as put in the accus. case on account of the rejection of a prep., namely"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"text","text":": for] it is said that"},{"kind":"arabic","text_bw":"xasira","text_ar":"خَسِرَ"},{"kind":"text","text":"is never used otherwise than intransitively: though this has been contradicted, on the ground of the following phrase in the Kur [xxii. 11],"},{"kind":"arabic","text_bw":"xasira A@ld~unoyaA","text_ar":"خَسِرَ ا@لدُّنْيَا"},{"kind":"arabic","text_bw":"wa A@loA=xirapa","text_ar":"وَ ا@لْا=خِرَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He hath lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he loseth, the things of the present life and of the latter life"},{"kind":"text","text":"]; and the like; as"},{"kind":"arabic","text_bw":"A@l~a*iyna xasiruwA A^anofusahumo wa A^aholiyhimo","text_ar":"ا@لَّذِينَ خَسِرُوا اَنْفُسَهُمْ وَ اَهْلِيهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Who shall have lost themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their own souls, and their families,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"their wives;"},{"kind":"text","text":"Kur xxxix. 17 and xlii. 44]; (MF, TA;) i. e., themselves, or their own souls, by their having erred, and their families by their having caused them to err, or by being separated from them for ever; (Bd;) or by being themselves made to remain for ever in Hell, and by their not gaining access to the"},{"kind":"arabic","text_bw":"Huwr","text_ar":"حُور"},{"kind":"text","text":"prepared in Paradise [as wives] for the believers: (Jel:) or the meaning is, accord. to Fr,"},{"kind":"italic_en","text":"who shall be deceived of their own souls, &c.:"},{"kind":"text","text":"or, accord. to others,"},{"kind":"italic_en","text":"who shall have destroyed their own souls, &c."},{"kind":"text","text":"(TA.) ―         -b2-  Also ["},{"kind":"italic_en","text":"He experienced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw, that he was loser;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"his having lost became manifest to him:"},{"kind":"text","text":"so in the Kur xl. [78 and] last verse. (TA.) ―         -b3-  Also (with all the forms of the inf. n. above mentioned, K,)"},{"kind":"italic_en","text":"He erred; went astray; deviated from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"missed, the right way:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became lost; he perished;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Dal~a","text_ar":"ضَلَّ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"halaka","text_ar":"هَلَكَ"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"xasarahu","text_ar":"خَسَرَهُ"},{"kind":"text","text":", (A 'Obeyd, IAar, Zj, S, A, &c.,) aor."},{"kind":"text","text":"(Zj, Msb) and"},{"kind":"text","text":", (Bd in lv. 8,) inf. n."},{"kind":"arabic","text_bw":"xasorN","text_ar":"خَسْرٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"xusoraAnN","text_ar":"خُسْرَانٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"Axsrhu","text_ar":"اخسرهُ","orth_type":"arrow"},{"kind":"text","text":", (A 'Obeyd, Zj, S, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"A_ixosaArN","text_ar":"اـِخْسَارٌ"},{"kind":"text","text":"; (Msb, K;) and ↓"},{"kind":"arabic","text_bw":"xs~rhu","text_ar":"خسّرهُ","orth_type":"arrow"},{"kind":"text","text":"; (A;)"},{"kind":"italic_en","text":"He made it defective,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient;"},{"kind":"text","text":"(A 'Obeyd, IAar, Zj, S, A, Msb, K;) namely, the weight, and the measure; (Zj, TA;) and the thing weighed; (TA;) and the balance, (A 'Obeyd, IAar, Zj, A, Msb,) by diminishing the weight. (Msb.) ↓ The second of these forms is more common, in this sense, than the first (Zj, TA) [and than the third]. For"},{"kind":"arabic","text_bw":"A@lomiyzaAna","text_ar":"ا@لْمِيزَانَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wa laA tuxosiruwA","text_ar":"وَ لَا تُخْسِرُوا","orth_type":"arrow"},{"kind":"text","text":", in the Kur lv. 8, there are three other readings; namely"},{"kind":"arabic","text_bw":"taxosuruwA","text_ar":"تَخْسُرُوا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taxosurwA","text_ar":"تَخْسُروا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taxosaruwA","text_ar":"تَخْسَرُوا"},{"kind":"text","text":"; in the last of which, the prep."},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"text","text":"is omitted after the verb. (Bd.) ―         -b2-  [And"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, made him to lose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffer loss; to err,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"go astray; to become lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to perish."},{"kind":"text","text":"]"}],"source_refs":["S","A","Msb","K","TA","B","Jel","Zj"]}]}}