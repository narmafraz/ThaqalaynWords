,"in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْصُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْصُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْصِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْص","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعْصِي","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُعْصَى","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْص","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعْصِي","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُعْصَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْصِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْصِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْصِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْصِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْصُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْصُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْصِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَعْص","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْص","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْصِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْصِي","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعْصَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْصَى","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"عَصَيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَصَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":71,"cross_references":{"qac":{"found":true,"lemma_key":"عَصَى","root":"عصو","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29399"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B5%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to disobey; to refuse to side together with","tags":["transitive"]},{"pos":"verb","gloss":"to be unwilling to be corrected, to refuse to be corrected or act with correct behavior","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29399","headword_ar":"عَصِىٌّ","root":"ESY","body":[{"kind":"text","text":": see what follows, in two places."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D8%B5%D9%89/","headword_ar":"عصى","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=52337#58c486","body_html":"عصى<br>عَصَى عَصْياً وعِصْيَاناً. وعِرْقٌ عَاصٍ: لاَ يَرْقَأُ دَمُه. ويُجْعَلُ العَاصِي اسْماً للفَصِيْلِ إِذا لم يَتْبَعْ أُمَّه. وقيل: عَصِيْكَ: في مَعْنى عَصِيْتَ."},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=52337#a5a454","body_html":"عصى: عصى عن: في ألف ليلة (3: 428): أنا مثل سقط الفول عاص عن الماء والنار. أي أنا مثل الفول الرديء: يقاوم الماء والنار، بمعنى إنه لا يطبخ ولا ينضج. والأفضل عصى على.<br>عَصَّى (بالتشديد): جعله يعصى ولا يطيع. (فوك).<br>عاصَى: تآمر. (هلو).<br>أعصَى: أهان، شتم، أذّل. (الكالا).<br>تعاصَى: امتنع، دافع عن نفسه، تحامى. ففي الخطيب (ص175 و): اعتصم أهلها بالقصبة فتعاصتْ.<br>استعصى مثل تعصى: تصعب، عسر، صار صعباً وعسيراً. (معجم مسلم). استعصى: وجده صعباً وعسيراً. ففي تاريخ البربر (1: 487): استعصى الحصن إلا بالمطاولة. وقد ترجمها السيد دي سلان إلى الفرنسية بما معناه: رأي صعوبة الاستيلاء على الحصن إلا بعد حصار طويل.<br>عَصَاوة: استعمال عَصاوة للعصيان من لحن العامة. والعِصيان خلاف الطاعة وترك الانقياد (محيط المحيط).<br>عاصٍ: متآمر. (هلو).<br>مَعْصِيَة: وجمعها مَعاصٍ: عصيان، تمرد. (حيان) (ص49 و، ق).<br>مَعْصِيَة: خطيئة، إثم. (فوك، الكامل ص311) وفي طرائف دي ساسي (1: 162): بُقْعة يُعْمَل فيها معاصي الله. أي يعصى فيها الله وترتكب فيها المنكرات.<br>في معصية مبينة: في حالة تلبس بالجريمة (بوشر).<br>مَعْصِيَة: حرب أهلية. ففي حيان (ص38 ق): المعصية بين اليمانية والمضرية.<br>مَعْصَية: إهانة، إساءة، قدح. (الكالا)."},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=52337#8237bf","body_html":"<h3>عص</h3>ى<span class=\"sense\">1</span> عَصَاهُ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـْ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> عَصْىٌ and مَعْصِيَةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) and عِصْيَانٌ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, and so in some copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or this last is a simple <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) He ([for instance] a slave, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) disobeyed him, or rebelled against him, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) i. e., his master; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) as also ↓ عاصاهُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مُعَاصَاةٌ; (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) and عَلَيْهِ ↓ استعصى, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) meaning he opposed him, or resisted him, and did not obey him, [or he rebelled against him,] namely, his prince, or commander. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [See also an <abbr title=\"example\">ex.</abbr> of the first in a verse cited <abbr title=\"under the heading\">voce</abbr> زُجٌّ] فُلَانٌ يَعْصِى الرِيحَ means (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Such a one faces the quarter from which the wind blows, not opposing his side to the wind. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 3 عَاْصَىَ see the preceding paragraph.<span class=\"sense\">5</span> تعصّىِ It (an affair) was, or became, difficult; <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr> اِعْتَاصَ: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) said by some to be originally تَعَصَّصَ; like تَظَنَّى and تَقَضَّى. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 6 تعاصى [occurs in the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, <abbr title=\"under the heading\">voce</abbr> تَحَمَّسَ, as meaning He feigned disobedience, or rebellion: and in the <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr> and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, <abbr title=\"under the heading\">voce</abbr> تَشَاغَبَ, as meaning he manifested incompliance].<span class=\"sense\">8</span> اِعْتَصَتِ النَّوَاةُ The date-stone was, or became, hard. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 10 إِسْتَعْصَىَ see the first paragraph.<br><br>عِصْيَانٌ [mentioned above as an <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr>, but <abbr title=\"according\">accord.</abbr> to the <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr> a simple <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>,] Disobedience, or rebellion; <abbr title=\"contrary\">contr.</abbr> of طَاعَةٌ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) عَصِىٌّ: see what follows, in two places.<br><br>عَاصٍ and ↓ عَصِىٌّ Disobeying, or rebelling; or disobedient, or rebellious: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) [both are mentioned in the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> and <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> as though <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr>: but] ↓ the latter is an intensive <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> [and therefore has the latter signification, or means very disobedient or rebellious]: the <abbr title=\"plural, جَمْعٌ\">pl.</abbr> of the former is عُصَاةٌ. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b2:</span> العَاصِى is an appellation of The young camel when it disobeys its mother, and does not follow her. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> And it signifies also (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The vein that will not cease bleeding: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) belonging to this art. and to art. عصو: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>: mentioned in art. عصو in the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> العَوَاصِى. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.)"}]}}