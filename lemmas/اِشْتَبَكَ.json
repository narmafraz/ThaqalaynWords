n_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَشْتَبِكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْتَبِكْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْتَبِك","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْتَبِك","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْتَبِكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْتَبِكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْتَبِكا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْتَبِكانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْتَبِكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْتَبِكُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْتَبِكْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِشْتَبَكْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِشْتَبَكْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْتَبِك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْتَبِك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n21606"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B4%D9%92%D8%AA%D9%8E%D8%A8%D9%8E%D9%83%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to clash, to skirmish, to come to blows, to be intertwined, to close with, to catch up, to get mixed or embroiled, to engage"}]},"etymology":null,"ipa":["/iʃ.ta.ba.ka/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21606","headword_ar":"اشتبك","root":"$bk","body":[{"kind":"text","text":", quasi-pass. of"},{"kind":"arabic","text_bw":"$abakahu","text_ar":"شَبَكَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It had one part thereof infixed,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"inserted,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"into another,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts thereof into others;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"t$b~k","text_ar":"تشبّك","orth_type":"arrow"},{"kind":"text","text":", quasi-pass. of"},{"kind":"arabic","text_bw":"$b~khu","text_ar":"شبّكهُ"},{"kind":"text","text":": (K, TA:) so in the M: but ↓ the latter imports muchness, or multiplicity: (TA:) [i. e. it signifies"},{"kind":"italic_en","text":"it had many parts thereof infixed,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"inserted, into others:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"it was reticulated, retiform,"},{"kind":"page_break","n":1498},{"kind":"italic_en","text":"like a net;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"like a lattice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trellis,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cage:"},{"kind":"text","text":"and both signify also"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, commingled in its several parts, intricate, complicated, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused;"},{"kind":"text","text":"either properly, as when said of a fabric, or anything made by art, or created; or tropically, as when said of what is ideal.] One says,"},{"kind":"arabic","text_bw":"A$tbkt Aln~ujuwmu","text_ar":"اشتبكت النُّجُومُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"t$Abkt","text_ar":"تشابكت","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"$ab~akat","text_ar":"شَبَّكَت","orth_type":"arrow"},{"kind":"text","text":", [or the last may be a mistranscription for ↓"},{"kind":"arabic","text_bw":"t$b~kt","text_ar":"تشبّكت","orth_type":"arrow"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"The stars were intermixed among themselves,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"confused:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"were clustered together:"},{"kind":"text","text":"] or"},{"kind":"arabic","text_bw":"Ai$otibaAku Aln~ujuwmi","text_ar":"اِشْتِبَاكُ النُّجُومِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the stars' being numerous, and being intermixed among themselves;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"$abakapu AlS~aAy^idi","text_ar":"شَبَكَةُ الصَّايِدِ"},{"kind":"text","text":"[“the net of the fisherman” or “sportsman”]: (Mgh:) or"},{"kind":"italic_en","text":"their being numerous, and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"gathered"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"clustered"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"together:"},{"kind":"text","text":"(Msb:) or, as some say,"},{"kind":"italic_en","text":"the appearing of all the stars"},{"kind":"text","text":"[which causes them to appear confused]. (TA.) And"},{"kind":"arabic","text_bw":"A$tbkt AlEuruwqu","text_ar":"اشتبكت العُرُوقُ"},{"kind":"italic_en","text":"The veins were knit together, commingled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricately intermixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intermingled;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ai$otajarat","text_ar":"اِشْتَجَرَت"},{"kind":"text","text":". (O, TA.) And"},{"kind":"arabic","text_bw":"A$tbk Als~araAbu","text_ar":"اشتبك السَّرَابُ"},{"kind":"italic_en","text":"The mirage became intermixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A$tbk AlZ~alaAmu","text_ar":"اشتبك الظَّلَامُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The darkness became confused."},{"kind":"text","text":"(S, O, TA.) And"},{"kind":"arabic","text_bw":"A$tkbt AlA^umuwru","text_ar":"اشتكبت الاُمُورُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"t$Abkt","text_ar":"تشابكت","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"$b~kt","text_ar":"شبّكت","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) and ↓"},{"kind":"arabic","text_bw":"t$b~kt","text_ar":"تشبّكت","orth_type":"arrow"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The affairs became intricate, complicated, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"A$tkbt","text_ar":"اشتكبت"},{"kind":"arabic","text_bw":"AlHarobu bayonahumo","text_ar":"الحَرْبُ بَيْنَهُمْ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The war,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fight, became intricate, and entangled between them;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"na$ibat","text_ar":"نَشِبَت"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"n$b","text_ar":"نشب"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A$tbkt A^anoyaAbuhu waA@xotalafato","text_ar":"اشتبكت اَنْيَابُهُ وَا@خْتَلَفَتْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His canine teeth locked together, and were dissimilar"},{"kind":"text","text":"]; referring to a lion. (O. [See also"},{"kind":"arabic","text_bw":"$aAbikN","text_ar":"شَابِكٌ"},{"kind":"text","text":".])"},{"kind":"arabic","text_bw":"Ai$otibaAku","text_ar":"اِشْتِبَاكُ"},{"kind":"arabic","text_bw":"Alr~aHimi","text_ar":"الرَّحِمِ"},{"kind":"text","text":"means (tropical:)"},{"kind":"italic_en","text":"The close"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"intimate"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"connexion of relationship by birth:"},{"kind":"text","text":"(TA:) [and in like manner,"},{"kind":"arabic","text_bw":"AlA^aroHaAmi","text_ar":"الاَرْحَامِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ta$aAbuku","text_ar":"تَشَابُكُ","orth_type":"arrow"},{"kind":"italic_en","text":"such connexion of relationships by birth:"},{"kind":"text","text":"see an ex. of its part. n., voce"},{"kind":"arabic","text_bw":"mu$otabikN","text_ar":"مُشْتَبِكٌ"},{"kind":"text","text":".]"}],"source_refs":["K","TA","Mgh","Msb"]}]},"classical_definitions":null}