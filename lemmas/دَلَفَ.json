n":"m","num":"p"},{"role":"present_2mp","form":"تَدْلِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدْلِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدْلِف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدْلِف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدْلِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدْلِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدْلِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدْلِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدْلِفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْلِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْلِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"دَلَفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"دَلَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَدْلِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدْلِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n12954"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%84%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to walk slowly, to stroll, to toddle, to proceed"}]},"etymology":null,"ipa":["/da.la.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12954","headword_ar":"دَلَفَ","root":"dlf","body":[{"kind":"text","text":", (T, S, M, K,) aor."},{"kind":"text","text":", (T, M, K,) inf. n."},{"kind":"arabic","text_bw":"daliyfN","text_ar":"دَلِيفٌ"},{"kind":"text","text":"(T, S, M, K) and"},{"kind":"arabic","text_bw":"dalafN","text_ar":"دَلَفٌ"},{"kind":"text","text":"(T, M, K) and"},{"kind":"arabic","text_bw":"dalofN","text_ar":"دَلْفٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"dalafaAnN","text_ar":"دَلَفَانٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"duluwfN","text_ar":"دُلُوفٌ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"He walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, gently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leisurely:"},{"kind":"text","text":"(S, M:) said of an old man, (As, T, S, K,)"},{"kind":"italic_en","text":"he walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"(As, T, S, M, K,)"},{"kind":"italic_en","text":"with short steps,"},{"kind":"text","text":"(S, M,) or"},{"kind":"italic_en","text":"in the manner of him who is shackled,"},{"kind":"text","text":"(K,) as some say, (M,)"},{"kind":"italic_en","text":"at a rate above that which is termed"},{"kind":"arabic","text_bw":"dabiybN","text_ar":"دَبِيبٌ"},{"kind":"text","text":", (As, T, M, K,)"},{"kind":"italic_en","text":"like as does the army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of troops, to the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of troops."},{"kind":"text","text":"(As, T.) You say,"},{"kind":"arabic","text_bw":"dalafati Alkatiybapu","text_ar":"دَلَفَتِ الكَتِيبَةُ"},{"kind":"arabic","text_bw":"A_ilaY Alkatiybapi fiY AlHarobi","text_ar":"اـِلَى الكَتِيبَةِ فِى الحَرْبِ"},{"kind":"text","text":"(T, S, * M, K *) meaning"},{"kind":"italic_en","text":"The army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of troops, went gently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leisurely, to the"},{"kind":"text","text":"[other]"},{"kind":"italic_en","text":"army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of troops,"},{"kind":"italic_en","text":"in war:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forward;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taqad~amat","text_ar":"تَقَدَّمَت"},{"kind":"text","text":": (S, K:) [for]"},{"kind":"arabic","text_bw":"dalafN","text_ar":"دَلَفٌ"},{"kind":"text","text":"(T, M) accord. to A'Obeyd, or"},{"kind":"arabic","text_bw":"dalofN","text_ar":"دَلْفٌ"},{"kind":"text","text":"accord. to AA, (T,) signifies the act of"},{"kind":"italic_en","text":"advancing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going forward;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taqad~umN","text_ar":"تَقَدُّمٌ"},{"kind":"text","text":": (T, M:) and one says"},{"kind":"arabic","text_bw":"dalafonaAhumo","text_ar":"دَلَفْنَاهُمْ"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"dalafonaA lahumo","text_ar":"دَلَفْنَا لَهُمْ"},{"kind":"text","text":", (M, and so in one place in the TA,) meaning [as is implied in the S and K]"},{"kind":"italic_en","text":"we advanced to them;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taqad~amonaA","text_ar":"تَقَدَّمْنَا"},{"kind":"text","text":": (M:) and"},{"kind":"arabic","text_bw":"dalafa","text_ar":"دَلَفَ"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"italic_en","text":"he drew near to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"dalafotu","text_ar":"دَلَفْتُ"},{"kind":"text","text":"also signifies"},{"kind":"arabic","text_bw":"ma$ayotu","text_ar":"مَشَيْتُ"},{"kind":"text","text":"[i.e."},{"kind":"italic_en","text":"I walked;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went on foot,"},{"kind":"text","text":"whether"},{"kind":"italic_en","text":"quickly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slowly"},{"kind":"text","text":"]: (Ham p. 678:) and [in like manner,]"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tdl~f","text_ar":"تدلّف","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he walked,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]: (O, TA:) or this latter signifies"},{"kind":"arabic","text_bw":"tama$~aY","text_ar":"تَمَشَّى"},{"kind":"text","text":"[said in the TA, in art."},{"kind":"arabic","text_bw":"m$Y","text_ar":"مشى"},{"kind":"text","text":", to be syn. with"},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"; but it rather signifies"},{"kind":"italic_en","text":"he walked with slow steps to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"and approached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near:"},{"kind":"text","text":"(S, K:) but A'Obeyd says that"},{"kind":"arabic","text_bw":"tazal~afa","text_ar":"تَزَلَّفَ"},{"kind":"text","text":"is more common. (M.) ―         -b2-  Hence, the saying of a poet,"},{"kind":"quote","text":"dalafotu A_ilaY Samiymika biAlqawaAfiY"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"I have wounded thy heart with rhymes."},{"kind":"text","text":"(Ham ubi suprá.) ―         -b3-  [The verb seems to bear two contr. significations; for it is said that]"},{"kind":"arabic","text_bw":"dalafa liA@lotizaAmiY","text_ar":"دَلَفَ لِا@لْتِزَامِى"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He hastened to take me by the hand and embrace me."},{"kind":"text","text":"(Har p. 368.) ―         -b4-"},{"kind":"arabic","text_bw":"dalafa biHimolihi","text_ar":"دَلَفَ بِحِمْلِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"daliyfN","text_ar":"دَلِيفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(one carrying a thing)"},{"kind":"italic_en","text":"was heavily burdened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overburdened, by his load"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so that he went slowly"},{"kind":"text","text":"]. (M.) ―         -b5-  You say of a she-camel,"},{"kind":"arabic","text_bw":"tadolifu biHamolihaA","text_ar":"تَدْلِفُ بِحَمْلِهَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"She rises"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"with difficulty"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"daAlifN","text_ar":"دَالِفٌ"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"with her load."},{"kind":"text","text":"(T,* Ibn-'Abbád, K.) ―         -b6-  And"},{"kind":"arabic","text_bw":"dalafa AlmaAlu","text_ar":"دَلَفَ المَالُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"daliyfN","text_ar":"دَلِيفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cattle, clave to the ground by reason of emaciation."},{"kind":"text","text":"(M, TA.)"}],"source_refs":["T","S","M","K","TA","As","O"]}]},"classical_definitions":null}