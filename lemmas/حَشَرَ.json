en":"m","num":"d"},{"role":"present_3fd","form":"تَحْشِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْشِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْشُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْشُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْشِرُونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْشِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْشُرُونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْشُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْشِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَحْشُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْشِر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْشِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَحْشُر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْشُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَشَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَشَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":31,"cross_references":{"qac":{"found":true,"lemma_key":"حَشَرَ","root":"حشر","pos":"V","occurrence_count":37},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":12},"lanes":{"found":true,"entry_ids":["n8090"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B4%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gather, to assemble, to unite (transitive)"},{"pos":"verb","gloss":"to raise for the last judgment"},{"pos":"verb","gloss":"to expel, to banish"},{"pos":"verb","gloss":"to destroy"},{"pos":"verb","gloss":"to work out elaborately"},{"pos":"verb","gloss":"to press, to compress, to pile up, to heap up","examples":[{"text":"حَشَرَتِ ٱلسِّكِّينَ إِلَى ٱللَّحْمِ","english":"She thrust the knife into the meat."},{"text":"لَا تَحْشُرْ أَنْفَكَ فِي أَمْرِي","english":"Don't put your nose in my business."}]},{"pos":"verb","gloss":"to intermeddle, to intrigue"},{"pos":"verb","gloss":"to be dead"},{"pos":"noun","gloss":"verbal noun of حَشَرَ (ḥašara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"gathering, assembling (of people)"},{"pos":"noun","gloss":"jamming"},{"pos":"noun","gloss":"rising from the dead and assembling for judgement"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of حَشَرَ (ḥašara)."},"ipa":["/ħa.ʃa.ra/","/ħaʃr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8090","headword_ar":"حَشَرَ","root":"H$r","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, Msb, K,) the former of which aors. is found in the seven readings of the Kur, (Msb,) inf. n."},{"kind":"arabic","text_bw":"Ha$orN","text_ar":"حَشْرٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"He congregated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collected together,"},{"kind":"text","text":"(S, Msb, K,) men: (S, Msb:) or"},{"kind":"italic_en","text":"he congregated"},{"kind":"text","text":"them, or"},{"kind":"italic_en","text":"collected"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"together, and drove"},{"kind":"text","text":"them: (Msb, TA:)"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"to go forth, collected together, from one place to another:"},{"kind":"text","text":"(Bd in lix. 2:)"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, compelled"},{"kind":"text","text":"them"},{"kind":"italic_en","text":"to emigrate:"},{"kind":"text","text":"(K, * TA: [in the CK"},{"kind":"arabic","text_bw":"AlxalaA='u","text_ar":"الخَلَا=ءُ"},{"kind":"text","text":"is put by mistake for"},{"kind":"arabic","text_bw":"AljalaA'u","text_ar":"الجَلَاءُ"},{"kind":"text","text":", the explanation of the inf. n.:]) and [simply]"},{"kind":"italic_en","text":"he drove"},{"kind":"text","text":"towards a place or quarter. (TA.) Hence"},{"kind":"arabic","text_bw":"yawomu","text_ar":"يَوْمُ"},{"kind":"arabic","text_bw":"AlHa$ori","text_ar":"الحَشْرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The day of congregation,"},{"kind":"text","text":"&c.; meaning]"},{"kind":"italic_en","text":"the day of resurrection:"},{"kind":"text","text":"(S, * TA:) [see also"},{"kind":"arabic","text_bw":"maHo$irN","text_ar":"مَحْشِرٌ"},{"kind":"text","text":":] and"},{"kind":"arabic","text_bw":"suwrapu AlHa$ori","text_ar":"سُورَةُ الحَشْرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The Chapter of the"},{"kind":"italic_en","text":"Compulsion to emigration;"},{"kind":"text","text":"which is the fifty-ninth chapter of the Kur-an]. (TA.) It is said by most of the expositors of the Kur that the wild animals and other beasts, and even the flies, will be collected together ("},{"kind":"arabic","text_bw":"tuHo$aru","text_ar":"تُحْشَرُ"},{"kind":"text","text":") for retaliation; and they cite a trad. on this subject. (TA.) So in the Kur [lxxxi. 5],"},{"kind":"arabic","text_bw":"wa A_i*aA AlwuHuw$u Hu$irato","text_ar":"وَ اـِذَا الوُحُوشُ حُشِرَتْ"},{"kind":"italic_en","text":"And when the wild animals shall be collected together,"},{"kind":"text","text":"(Bd, Jel,) from every quarter, (Bd,) after resurrection; (Jel;) or"},{"kind":"italic_en","text":"raised to life,"},{"kind":"text","text":"(Bd,) for the purpose of their retaliating, one upon another; after which they shall return to dust: (Bd, Jel:) or the meaning is,"},{"kind":"italic_en","text":"shall die,"},{"kind":"text","text":"(Az, S,) in the present world; accord. to some: (Az:) and thus says 'Ikrimeh, (S, TA,) on the authority of I'Ab, (TA,) as is related by Sa'eed Ibn-Masrook: (S, TA:) but accord. to some, the two meanings are nearly the same; for each denotes collection. (TA.)"},{"kind":"arabic","text_bw":"Ha$orN","text_ar":"حَشْرٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"going forth with a people fleeing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastening"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersing themselves in war;"},{"kind":"text","text":"when used absolutely. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Ha$aratohumu Als~anapu","text_ar":"حَشَرَتْهُمُ السَّنَةُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":"(Lth,) inf. n."},{"kind":"arabic","text_bw":"Ha$orN","text_ar":"حَشْرٌ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"The year of dearth destroyed their camels and other quadrupeds;"},{"kind":"text","text":"because it causes the owners to collect themselves from the various quarters to the cities or towns: (Lth:) or"},{"kind":"italic_en","text":"it caused them to go down to the cities or towns:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"it distressed them;"},{"kind":"text","text":"app., because of their collecting themselves together from the desert to the places of settled abodes: (Abu-t- Teiyib:) and"},{"kind":"arabic","text_bw":"Ha$arati Als~anapu maAla fulaAnK","text_ar":"حَشَرَتِ السَّنَةُ مَالَ فُلَانٍ"},{"kind":"italic_en","text":"The year of dearth destroyed the camels &c. of such a one."},{"kind":"text","text":"(S, K. *)       -A2-"},{"kind":"arabic","text_bw":"Ha$arahu","text_ar":"حَشَرَهُ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"Ha$orN","text_ar":"حَشْرٌ"},{"kind":"text","text":", (S, K,) (tropical:)"},{"kind":"italic_en","text":"He made it"},{"kind":"text","text":"(a spear-head, S, A)"},{"kind":"italic_en","text":"thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slender:"},{"kind":"text","text":"(S, A, K:)"},{"kind":"italic_en","text":"he made it"},{"kind":"text","text":"(a spear-head, and a knife,)"},{"kind":"italic_en","text":"sharp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pointed, and thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slender:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he made it small, and thin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slender:"},{"kind":"text","text":"(Th:)"},{"kind":"italic_en","text":"he pared it;"},{"kind":"text","text":"namely, a stick: (TA:)"},{"kind":"italic_en","text":"he pared it, and made it sharp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pointed."},{"kind":"text","text":"(S.)"}],"source_refs":["S","Msb","K","TA","Bd","Jel","Az","Lth","A","Th"]}]}}