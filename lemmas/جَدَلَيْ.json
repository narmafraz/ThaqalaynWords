:"جُدُولٌ"},{"kind":"text","text":". (S, TA.) ―         -b4-  Also, (K,) or the former, (TA,)"},{"kind":"italic_en","text":"Any complete bone,"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"with its flesh,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not broken, nor mixed with aught beside:"},{"kind":"text","text":"pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^ajodaAlN","text_ar":"اَجْدَالٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"juduwlN","text_ar":"جُدُولٌ"},{"kind":"text","text":". (K, TA.) ―         -b5-  Also, (K,) or [the pl.]"},{"kind":"arabic","text_bw":"juduwlN","text_ar":"جُدُولٌ"},{"kind":"text","text":", (Lth, TA,) The"},{"kind":"italic_en","text":"bones of the arms and legs"},{"kind":"text","text":"(Lth, K, TA) of a man: (Lth, TA:) and"},{"kind":"italic_en","text":"of the fore and hind legs"},{"kind":"text","text":"of the victim termed"},{"kind":"arabic","text_bw":"Eaqiyqap","text_ar":"عَقِيقَة"},{"kind":"text","text":". (TA from a trad.)"}],"source_refs":["K","S","TA","Lth"]},{"entry_id":"n5252","headword_ar":"جِدْلٌ","root":"jdl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jadolN","text_ar":"جَدْلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n5253","headword_ar":"جَدَلٌ","root":"jdl","body":[{"kind":"italic_en","text":"Vehemence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"violence, in altercation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disputation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation;"},{"kind":"text","text":"(S, K;) and"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, to practise it:"},{"kind":"text","text":"(K:) [or simply"},{"kind":"italic_en","text":"contention in an altercation; disputation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation:"},{"kind":"text","text":"] a subst. from"},{"kind":"arabic","text_bw":"jaAd