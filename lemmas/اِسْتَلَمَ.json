مُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْتَلِمُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْتَلِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْتَلِم","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْتَلِم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْتَلِمانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْتَلِما","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْتَلِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْتَلِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْتَلِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْتَلِمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْتَلِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِسْتَلَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِسْتَلَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْتَلِم","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْتَلِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n20534"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D9%84%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20534","headword_ar":"استلم","root":"slm","body":[{"kind":"italic_en","text":"He became at peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reconciled."},{"kind":"text","text":"(TA.) Hence the saying, (TA,)"},{"kind":"arabic","text_bw":"huwa laA yasotalamu EalaY","text_ar":"هُوَ لَا يَسْتَلَمُ عَلَى"},{"kind":"arabic","text_bw":"saxaTihi","text_ar":"سَخَطِهِ"},{"kind":"italic_en","text":"He will not become at peace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reconciled, during his displeasure"},{"kind":"text","text":"at a thing. (K, TA.) [See also 6.] ―         -b2-"},{"kind":"arabic","text_bw":"Astlm Alz~aroEu","text_ar":"استلم الزَّرْعُ"},{"kind":"italic_en","text":"The seed-produce put forth its ears."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"Astlm AlHajara","text_ar":"استلم الحَجَرَ"},{"kind":"italic_en","text":"He touched,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"reached,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"the stone,"},{"kind":"text","text":"[meaning the Black Stone of the Kaabeh,]"},{"kind":"italic_en","text":"by kissing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with the hand:"},{"kind":"text","text":"(S, Mgh, K:) or"},{"kind":"italic_en","text":"he wiped it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stroked it, with the hand:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"he kissed the stone:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he embraced it:"},{"kind":"text","text":"(M:) and"},{"kind":"arabic","text_bw":"AisotaloA^amahu","text_ar":"اِسْتَلْاَمَهُ"},{"kind":"text","text":"signifies the same; (M, K;) but is not the original: (M:) accord. to ISk, the Arabs pronounced it with hemz, contr. to analogy; (Msb;) or it should not be pronounced with hemz, though some thus pronounce it, (S,) the original being"},{"kind":"arabic","text_bw":"Astlm","text_ar":"استلم"},{"kind":"text","text":", (ISk, Msb,) because it is from"},{"kind":"arabic","text_bw":"silaAmN","text_ar":"سِلَامٌ"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ"},{"kind":"text","text":"] signifying “ stones, ” (ISk, S, * M, Msb, * [in the Mgh, from"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ"},{"kind":"text","text":"signifying “ a stone, ” and in the Msb the pl. of"},{"kind":"arabic","text_bw":"salimapN","text_ar":"سَلِمَةٌ"},{"kind":"text","text":"is said to be"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"kalaAmN","text_ar":"كَلَامٌ"},{"kind":"text","text":",]) accord. to Sb, who says that it does not denote the act of taking; (M;) or, accord. to Sb, it is from"},{"kind":"arabic","text_bw":"Als~alaAmu","text_ar":"السَّلَامُ"},{"kind":"text","text":", with fet-h, meaning “ salutation, ” and it means the touching with the hand by way of salutation in order to obtain a blessing thereby: (TA:) but accord. to IAar, the original is with hemz, from"},{"kind":"arabic","text_bw":"AlmulaA='amapu","text_ar":"المُلَا=ءَمَةُ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"AlAijotimaAEu","text_ar":"الاِجْتِمَاعُ"},{"kind":"text","text":"[“ the coming together, ” &c., because denoting contact]. (Msb.) Abu-t-Tufeyl is related to have said,"},{"kind":"arabic","text_bw":"raA^ayotu rasuwla A@ll~`hi Sal~aY A@ll~`hu Ealayohi","text_ar":"رَاَيْتُ رَسُولَ ا@للّٰهِ صَلَّى ا@للّٰهُ عَلَيْهِ"},{"kind":"arabic","text_bw":"wasal~ama yaTuwfu EalaY raAHilatihi yasotalimu bimiHojanihi wayuqab~ilu","text_ar":"وَسَلَّمَ يَطُوفُ عَلَى رَاحِلَتِهِ يَسْتَلِمُ بِمِحْجَنِهِ وَيُقَبِّلُ"},{"kind":"arabic","text_bw":"AlmiHojana","text_ar":"المِحْجَنَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I saw the Apostle of God"},{"kind":"text","text":"("},{"kind":"italic_en","text":"may God bless and save him"},{"kind":"text","text":")"},{"kind":"italic_en","text":"circuiting"},{"kind":"text","text":"around the Kaabeh,"},{"kind":"italic_en","text":"upon his camel, touching"},{"kind":"text","text":"the Black Stone"},{"kind":"italic_en","text":"with his hooked staff, and kissing the hooked staff"},{"kind":"text","text":"]. (TA.) The primary signification of"},{"kind":"arabic","text_bw":"AlAisotilaAmu","text_ar":"الاِسْتِلَامُ"},{"kind":"text","text":"is [said to be]"},{"kind":"italic_en","text":"The wiping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stroking, the"},{"kind":"arabic","text_bw":"salimap","text_ar":"سَلِمَة"},{"kind":"text","text":", i. e. the"},{"kind":"italic_en","text":"stone:"},{"kind":"text","text":"afterwards it was used in relation to other things, and one said"},{"kind":"arabic","text_bw":"Aisotalamotu yadahaA","text_ar":"اِسْتَلَمْتُ يَدَهَا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I stroked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kissed, her hand."},{"kind":"text","text":"(Har pp. 30 and 31.) ―         -b2-"},{"kind":"arabic","text_bw":"Astlm Alxuf~u qadamayohi","text_ar":"استلم الخُفُّ قَدَمَيْهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The boot rendered his feet soft"},{"kind":"text","text":"[after he had been accustomed to walking barefoot]. (TA.)"}],"source_refs":["TA","S","K","Mgh","M","ISk","Msb"]}]}}