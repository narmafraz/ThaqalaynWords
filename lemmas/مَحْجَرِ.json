{"lemma":"مَحْجَرِ","slug":"مَحْجَرِ","root":"ح.ج.ر","root_slug":"ح-ج-ر","root_link":"/words/roots/ح-ج-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n7173","n7174","n7175"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AD%D9%92%D8%AC%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"eye socket, orbit"}]},"etymology":{"source":"wiktextract","text":"Noun of place of the verb حَجَرَ (ḥajara)."},"ipa":["/miħ.d͡ʒar/","/maħ.d͡ʒir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7173","headword_ar":"مَحْجِرٌ","root":"Hjr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ"},{"kind":"text","text":", in four places. ―         -b2-  Also, (S,) or ↓"},{"kind":"arabic","text_bw":"maHojirN","text_ar":"مَحْجِرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"miHojarN","text_ar":"مِحْجَرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) The"},{"kind":"italic_en","text":"tract surrounding a town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"village:"},{"kind":"text","text":"(S, K:) [pl."},{"kind":"arabic","text_bw":"maHaAjiru","text_ar":"مَحَاجِرُ"},{"kind":"text","text":".] Hence the"},{"kind":"arabic","text_bw":"maHaAjir","text_ar":"مَحَاجِر"},{"kind":"text","text":"of the kings ("},{"kind":"arabic","text_bw":"A^aqoyaAl","text_ar":"اَقْيَال"},{"kind":"text","text":") of ElYemen, which were"},{"kind":"italic_en","text":"Places of pasturage,"},{"kind":"text","text":"whereof each of them had one,"},{"kind":"italic_en","text":"in which no other person pastured his beasts:"},{"kind":"text","text":"(S, K:) the"},{"kind":"arabic","text_bw":"mHjr","text_ar":"محجر"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"qayol","text_ar":"قَيْل"},{"kind":"text","text":"of El-Yemen was his"},{"kind":"italic_en","text":"tract of land into which no other person than himself entered."},{"kind":"text","text":"(T.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"HajorapN","text_ar":"حَجْرَةٌ"},{"kind":"text","text":". ―         -b4-  And see"},{"kind":"arabic","text_bw":"maHojru AlEayoni","text_ar":"مَحْجرُ العَيْنِ"},{"kind":"text","text":"."}],"source_refs":["S","K"]},{"entry_id":"n7174","headword_ar":"مَحْجِرٌ","root":"Hjr","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"miHojarN","text_ar":"مِحْجَرٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"A garden surrounded by a wall;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a garden of trees;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HadiyqapN","text_ar":"حَدِيقَةٌ"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, place of pasture:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"a place in which is much pasture, with water:"},{"kind":"text","text":"(A, * TA:) pl."},{"kind":"arabic","text_bw":"maHaAjiru","text_ar":"مَحَاجِرُ"},{"kind":"text","text":". (S, A.) See also"},{"kind":"arabic","text_bw":"HaAjirN","text_ar":"حَاجِرٌ"},{"kind":"text","text":"for the former word and its pl.: and see"},{"kind":"arabic","text_bw":"maHojarN","text_ar":"مَحْجَرٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"maHojiru AlEayoni","text_ar":"مَحْجِرُ العَيْنِ"},{"kind":"text","text":"(S, K, &c.) and ↓"},{"kind":"arabic","text_bw":"maHojaruhaA","text_ar":"مَحْجَرُهَا","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"miHoHaruhA","text_ar":"مِحْحَرُها","orth_type":"arrow"},{"kind":"text","text":"(K) and simply"},{"kind":"arabic","text_bw":"AlmHjr","text_ar":"المحجر"},{"kind":"text","text":"(Msb, TA) and ↓"},{"kind":"arabic","text_bw":"AlHajoru","text_ar":"الحَجْرُ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"AlHujoru","text_ar":"الحُجْرُ","orth_type":"arrow"},{"kind":"text","text":", which occurs in a verse of El-Akhtal, (IAar,) ["},{"kind":"italic_en","text":"The part which is next below,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"around, the eye, and which appears when the rest of the face is veiled by the"},{"kind":"arabic","text_bw":"niqaAb","text_ar":"نِقَاب"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"buroquE","text_ar":"بُرْقُع"},{"kind":"text","text":":]"},{"kind":"italic_en","text":"that part"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the face, next below the eye,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which appears from out of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of veil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"niqaAb","text_ar":"نِقَاب"},{"kind":"text","text":"(T, S, A, Msb, K) of a woman (A, Msb, K) and of a man,"},{"kind":"italic_en","text":"from the lower eyelid;"},{"kind":"text","text":"and sometimes"},{"kind":"italic_en","text":"from the upper:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the part that surrounds the eye"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"on all sides,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and appears from out of the [kind of veil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"buroquE","text_ar":"بُرْقُع"},{"kind":"text","text":": (Msb, K:) or"},{"kind":"italic_en","text":"the part of the bone beneath the eyelid, which encompasses the eye:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"mHjr","text_ar":"محجر"},{"kind":"arabic","text_bw":"AlEyn","text_ar":"العين"},{"kind":"text","text":"means also"},{"kind":"italic_en","text":"what appears from beneath the turban of a man when he has put it on:"},{"kind":"text","text":"(K: [accord. to the TA, the turban itself; but this is a meaning evidently derived from a mistranscription in a copy of the K, namely,"},{"kind":"arabic","text_bw":"EimaAmatuhu","text_ar":"عِمَامَتُهُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"EimaAmatihi","text_ar":"عِمَامَتِهِ"},{"kind":"text","text":":]) also"},{"kind":"arabic","text_bw":"mHjruAlwajohi","text_ar":"محجرُالوَجْهِ"},{"kind":"italic_en","text":"that part of the face against which the"},{"kind":"arabic","text_bw":"nqAb","text_ar":"نقاب"},{"kind":"italic_en","text":"lies:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlmHjr","text_ar":"المحجر"},{"kind":"italic_en","text":"the eye"},{"kind":"text","text":"["},{"kind":"italic_en","text":"itself"},{"kind":"text","text":"]: (T, TA:) the pl. of"},{"kind":"arabic","text_bw":"mHjr","text_ar":"محجر"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"maHaAjiru","text_ar":"مَحَاجِرُ"},{"kind":"text","text":". (A, Msb.)"}],"source_refs":["S","K","T","TA","Msb","IAar","A"]},{"entry_id":"n7175","headword_ar":"مِحْجَرٌ","root":"Hjr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maHojarN","text_ar":"مَحْجَرٌ"},{"kind":"text","text":": ―         -b2-  and see also"},{"kind":"arabic","text_bw":"maHojirN","text_ar":"مَحْجِرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}