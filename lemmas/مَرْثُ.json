{"lemma":"مَرْثُ","slug":"مَرْثُ","root":"م.ر.ث","root_slug":"م-ر-ث","root_link":"/words/roots/م-ر-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n38408","n38409","n38410","n14742"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B1%D9%92%D8%AB%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38408","headword_ar":"مَرَثَ","root":"mrv","body":[{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marovN","text_ar":"مَرْثٌ"},{"kind":"text","text":", S,)"},{"kind":"italic_en","text":"He steeped"},{"kind":"text","text":"dates"},{"kind":"italic_en","text":"in water, and mashed them"},{"kind":"text","text":"(S, K) with the hand; (S;) syn."},{"kind":"arabic","text_bw":"marasa","text_ar":"مَرَسَ"},{"kind":"text","text":": (S, K;) sometimes"},{"kind":"arabic","text_bw":"mara*a","text_ar":"مَرَذَ"},{"kind":"text","text":"is also used in this sense. (S.) ―         -b2-"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marovN","text_ar":"مَرْثٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"soft,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"so that it became of such a subsistence that it might be supped, and then supped it."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marovN","text_ar":"مَرْثٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He steeped, soaked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"macerated,"},{"kind":"text","text":"a thing in water: (K:)"},{"kind":"italic_en","text":"he soaked"},{"kind":"text","text":"bread in water; as also"},{"kind":"arabic","text_bw":"mara*a","text_ar":"مَرَذَ"},{"kind":"text","text":". (Sh, As.)"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"italic_en","text":"He steeped"},{"kind":"text","text":"medicine &c. in water"},{"kind":"italic_en","text":"until it became altered."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child, S,)"},{"kind":"italic_en","text":"mumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bit softly,"},{"kind":"text","text":"his finger: (S, K:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a child)"},{"kind":"italic_en","text":"bit with his gums: he"},{"kind":"text","text":"(a child)"},{"kind":"italic_en","text":"bit and sucked"},{"kind":"text","text":"a necklace, or string of beads, such as is called"},{"kind":"arabic","text_bw":"saxaAbN","text_ar":"سَخَابٌ"},{"kind":"text","text":". (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"marovN","text_ar":"مَرْثٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"[a child]"},{"kind":"italic_en","text":"sucked"},{"kind":"text","text":"the kind of shells called cowries. (K.) ―         -b6-"},{"kind":"italic_en","text":"He sucked."},{"kind":"text","text":"(IAar.) ―         -b7-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child)"},{"kind":"italic_en","text":"sucked"},{"kind":"text","text":"his mother's breast. (IAar.) ―         -b8-"},{"kind":"arabic","text_bw":"mariva","text_ar":"مَرِثَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"maravN","text_ar":"مَرَثٌ"},{"kind":"text","text":", (IAar,)"},{"kind":"italic_en","text":"He was mild and forbearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clement; and patient in bearing altercation."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He beat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smote,"},{"kind":"text","text":"a man: (K:) or, accord. to A'Obeyd,"},{"kind":"arabic","text_bw":"mrava bihi","text_ar":"مرَثَ بِهِ"},{"kind":"page_break","n":2704},{"kind":"arabic","text_bw":"AlA^aroDa","text_ar":"الاَرْضَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mr~v","text_ar":"مرّث","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he threw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flung him, upon the ground:"},{"kind":"text","text":"or, accord. to Fr, the verb is"},{"kind":"arabic","text_bw":"marana","text_ar":"مَرَنَ"},{"kind":"text","text":". (TA.)       -A3-"},{"kind":"arabic","text_bw":"marava Als~axolapa","text_ar":"مَرَثَ السَّخْلَةَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"mr~vhA","text_ar":"مرّثها","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He imparted to the lamb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kid, a foul smell, of sweat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, so that its mother would not take to it:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"he rendered it foul and greasy with his hand, so that its mother would not suckle it:"},{"kind":"text","text":"(Ibn-Jo'eyl El-Kelbee:)"},{"kind":"italic_en","text":"he befouled it by stroking it with hands defiled by the smell of flesh-meat"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fish, so that its mother would not take to it."},{"kind":"text","text":"(El-Mufaddal Ed-Dabbee.) ―         -b2-  Also,"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"italic_en","text":"He defiled"},{"kind":"text","text":"water,"},{"kind":"italic_en","text":"by putting into it his hands foul with flesh-meat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(TA, from a trad.)"}],"source_refs":["S","K","IAar","L"]},{"entry_id":"n38409","headword_ar":"مرّث","root":"mrv","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tamoriyvN","text_ar":"تَمْرِيثٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He crumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broke into small pieces, with his fingers."},{"kind":"text","text":"(K.)       -A2-  See 1 in two places."}],"source_refs":[]},{"entry_id":"n38410","headword_ar":"مَرِثٌ","root":"mrv","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"mimoravN","text_ar":"مِمْرَثٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14742","headword_ar":"مُرِثٌّ","root":"rv","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"whose rope is old, and worn out."},{"kind":"text","text":"(K.)"}],"source_refs":[]}]}}