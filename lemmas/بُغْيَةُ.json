{"lemma":"بُغْيَةُ","slug":"بُغْيَةُ","root":"ب.غ.#","root_slug":"ب-غ-_","root_link":"/words/roots/ب-غ-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","prep"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n2963","n2964","n2967"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8F%D8%BA%D9%92%D9%8A%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of بَغَى (baḡā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wish"},{"pos":"noun","gloss":"desire"},{"pos":"prep","gloss":"to, in order to (followed by a verbal noun)"}]},"etymology":null,"ipa":["/buɣ.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2963","headword_ar":"بُغْيَةٌ","root":"bgY","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n2964","headword_ar":"بِغْيَةٌ","root":"bgY","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bugoyapN","text_ar":"بُغْيَةٌ","orth_type":"arrow"},{"kind":"text","text":"(JK, S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"bagiy~apN","text_ar":"بَغِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"A thing sought;"},{"kind":"text","text":"(JK, K;) as also ↓"},{"kind":"arabic","text_bw":"bagaAyapN","text_ar":"بَغَايَةٌ","orth_type":"arrow"},{"kind":"text","text":"[originally an inf. n. (see 1)]: (JK:) or"},{"kind":"italic_en","text":"a thing wanted, needed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"required; an object of want"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"need; a want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requisite thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"(S, Msb:) as in the saying,"},{"kind":"arabic","text_bw":"liY fiYbaniY","text_ar":"لِى فِىبَنِى"},{"kind":"arabic","text_bw":"fulaAnK bagoyapN","text_ar":"فُلَانٍ بَغْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bugoyapN","text_ar":"بُغْيَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have among the sons of such a one an object of want"},{"kind":"text","text":"]: (S:) or the first signifies"},{"kind":"italic_en","text":"a state that one seeks;"},{"kind":"text","text":"and the second,"},{"kind":"italic_en","text":"a thing itself that one wants:"},{"kind":"text","text":"(As, S, Msb: *) and the first, (JK,) or third, (K,) signifies also"},{"kind":"italic_en","text":"a stray beast that is sought:"},{"kind":"text","text":"(JK, K:) the pl. of the second is"},{"kind":"arabic","text_bw":"bugFY","text_ar":"بُغًى"},{"kind":"text","text":". (JK.)"},{"kind":"arabic","text_bw":"Airotad~ato EalaY fulaAnK bigoyatuhu","text_ar":"اِرْتَدَّتْ عَلَى فُلَانٍ بِغْيَتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing that he sought was refused to such a one"},{"kind":"text","text":"] is said of one who finds not what he seeks. (TA.)."}],"source_refs":["JK","S","Msb","K"]},{"entry_id":"n2967","headword_ar":"بَغِيَّةٌ","root":"bgY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bigoyapN","text_ar":"بِغْيَةٌ"},{"kind":"text","text":".       -A2-  Also, pl."},{"kind":"arabic","text_bw":"bagaAyaA","text_ar":"بَغَايَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"bagiY~N","text_ar":"بَغِىٌّ"},{"kind":"text","text":", last sentence."}],"source_refs":[]}]},"classical_definitions":null}