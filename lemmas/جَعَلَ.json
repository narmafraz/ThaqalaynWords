{"lemma":"جَعَلَ","slug":"جَعَلَ","root":"ج.ع.ل","root_slug":"ج-ع-ل","root_link":"/words/roots/ج-ع-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَعَلْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَعَلْتِ","in_corpus":true,"count":503,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَعَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَعَلْتُم","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَعَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَعَلَ","in_corpus":true,"count":195,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَعَلَت","in_corpus":true,"count":503,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَعَلا","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَعَلَتا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَعَلُوا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَعَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْعَل","in_corpus":true,"count":47,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْعَلِينَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْعَلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْعَلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْعَلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْعَلُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْعَلُوا","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْعَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْعَل","in_corpus":true,"count":151,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْعَل","in_corpus":true,"count":47,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْعَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْعَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْعَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْعَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْعَلُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْعَلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْعَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَعَلْنا","in_corpus":true,"count":32,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَعَلْتُ","in_corpus":true,"count":23,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْعَل","in_corpus":true,"count":51,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْعَل","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1590,"cross_references":{"qac":{"found":true,"lemma_key":"جَعَلَ","root":"جعل","pos":"V","occurrence_count":340},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n5925"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B9%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to make: to create","tags":["transitive"],"examples":[{"text":"أَجْعَلُ عَدَاوَةً بَيْنَكِ وَبَيْنَ الْمَرْأَةِ","english":"I will put enmity between thee and the woman."}]},{"pos":"verb","gloss":"to put, to place, to lay","tags":["transitive"]},{"pos":"verb","gloss":"to affect, to bring about, to make, to cause","tags":["ditransitive"],"examples":[{"text":"الْفَقْرُ وَعَدَمُ وُجُودِ ثِيَابٍ جَدِيدَةٍ يَجْعَلَانِ الْمَرْءَ بَائِسًا جِدًّا.","english":"Poverty and the lack of new clothes make one very miserable."}]},{"pos":"verb","gloss":"to fix, to set"},{"pos":"verb","gloss":"to begin to (followed by a non-past verb)","examples":[{"text":"جَعَلْتُ أَبْكِي.","english":"I began to cry"}]},{"pos":"noun","gloss":"verbal noun of جَعَلَ (jaʕala) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/d͡ʒa.ʕa.la/","/d͡ʒaʕl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5925","headword_ar":"جَعَلَ","root":"jEl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaEolN","text_ar":"جَعْلٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"juEolN","text_ar":"جُعْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jaEaAlapN","text_ar":"جَعَالَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jiEaAlapN","text_ar":"جِعَالَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"majoEalN","text_ar":"مَجْعَلٌ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing; syn."},{"kind":"arabic","text_bw":"SanaEa","text_ar":"صَنَعَ"},{"kind":"text","text":"; (Msb, K;) but having a more general signification than"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SanaEa","text_ar":"صَنَعَ"},{"kind":"text","text":"and their equivalents [as will be shown by what follows]; (Er-Rághib, TA;) and so ↓"},{"kind":"arabic","text_bw":"AjtEl","text_ar":"اجتعل","orth_type":"arrow"},{"kind":"text","text":": (K:) both these verbs signify the same. (S.) ―         -b2-"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing of, or from, a thing; as in the saying [in the Kur xvi. 74 and xlii. 9],"},{"kind":"arabic","text_bw":"jaEala lakumo mino A^anofusikumo A^azowaAjFA","text_ar":"جَعَلَ لَكُمْ مِنْ اَنْفُسِكُمْ اَزْوَاجًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He hath made for you, of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from, yourselves, wives"},{"kind":"text","text":"]; and [in the Kur xvi. 83]"},{"kind":"arabic","text_bw":"wajaEala lakumo mina AljibaAli","text_ar":"وَجَعَلَ لَكُمْ مِنَ الجِبَالِ"},{"kind":"arabic","text_bw":"A^akonaAnFA","text_ar":"اَكْنَانًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And He hath made for you, of the mountains, places of retreat;"},{"kind":"text","text":"as caves, and excavated houses or chambers: so explained by Bd]. (TA.) ―         -b3-"},{"kind":"italic_en","text":"He created;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"brought into being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existence;"},{"kind":"text","text":"(TA;) as in the saying [in the Kur vi. 1],"},{"kind":"arabic","text_bw":"waJaEala AlZ~ulumaAti waAln~uwri","text_ar":"وَچَعَلَ الظُّلُمَاتِ وَالنُّورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And hath created,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought into being, the darknesses and the light"},{"kind":"text","text":"]; (K, TA;) and [in the Kur xxi. 31]"},{"kind":"arabic","text_bw":"wajaEalonaA mina AlmaA='i kul~a $aYo'K HaY~K","text_ar":"وَجَعَلْنَا مِنَ المَا=ءِ كُلَّ شَىْءٍ حَىٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And We have created of water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the seminal fluid, everything living"},{"kind":"text","text":"]; and [in the Kur xvi. 80, &c.,]"},{"kind":"arabic","text_bw":"wajaEala","text_ar":"وَجَعَلَ"},{"kind":"arabic","text_bw":"lakumu Als~amoEa wa AlA^aboSaAra waAlA^afoy^idapa","text_ar":"لَكُمُ السَّمْعَ وَ الاَبْصَارَ وَالاَفْيِدَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And He created for you the ears and the eyes and the hearts"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared;"},{"kind":"text","text":"as in the saying [in the Kur lxv. 2],"},{"kind":"arabic","text_bw":"yajoEalu lahu maxorajFA","text_ar":"يَجْعَلُ لَهُ مَخْرَجًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He will make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepare, for him a way of escape,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"safety"},{"kind":"text","text":"]; and [in the Kur lxv. 4]"},{"kind":"arabic","text_bw":"yajoEalu lahu mino A^amorihi yusorFA","text_ar":"يَجْعَلُ لَهُ مِنْ اَمْرِهِ يُسْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He will make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepare, for him an easy state of his circumstances;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"will make his circumstances,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, easy to him"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"italic_en","text":"He made;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he made to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become; he constituted; he appointed;"},{"kind":"text","text":"[in which sense it is doubly trans.;] (S, K;) as in the saying in the Kur [xix. 31],"},{"kind":"arabic","text_bw":"wajaEaloniY nabiy~FA","text_ar":"وَجَعَلْنِى نَبِيًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And He hath made me a prophet"},{"kind":"text","text":"]; (S;) [and in the elliptical phrase,"},{"kind":"arabic","text_bw":"jaEalahu Ealayohi","text_ar":"جَعَلَهُ عَلَيْهِ"},{"kind":"italic_en","text":"He made him to be"},{"kind":"text","text":"superintendant, or the like,"},{"kind":"italic_en","text":"over it; set him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed him, over it:"},{"kind":"text","text":"] and in the phrase,"},{"kind":"arabic","text_bw":"jaEala AlqabiyHa HasanFA","text_ar":"جَعَلَ القَبِيحَ حَسَنًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made that which was bad to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, good"},{"kind":"text","text":"]. (K.) ―         -b6-"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to be in a particular state or condition;"},{"kind":"text","text":"as in the saying [in the Kur ii. 20],"},{"kind":"arabic","text_bw":"Al~a*i jaEala lakumu AlA^aroDa firaA$FA","text_ar":"الَّذِ جَعَلَ لَكُمُ الاَرْضَ فِرَاشًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Who hath made for you the earth to be as a bed"},{"kind":"text","text":"]; and [in the Kur lxxi. 15]"},{"kind":"arabic","text_bw":"wajaEala Alqamara fiyhin~a nuwrFA","text_ar":"وَجَعَلَ القَمَرَ فِيهِنَّ نُورًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And hath made the moon, in them"},{"kind":"text","text":"(the heavens),"},{"kind":"italic_en","text":"to be as a light"},{"kind":"text","text":"]; and so, as some say, in the saying [in the Kur xliii. 2],"},{"kind":"arabic","text_bw":"A_in~aA jaEalonaAhu quroA=nFA Earabiy~FA","text_ar":"اـِنَّا جَعَلْنَاهُ قُرْا=نًا عَرَبِيًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily we have made it an Arabic Kur-án"},{"kind":"text","text":"]. (TA.) ―         -b7-  ["},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to be in an altered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"changed, state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"i. e.,] the verb signifies also the changing a thing from its state or condition; as in the saying [in the Kur xi. 84 and xv. 74],"},{"kind":"arabic","text_bw":"jaEalonaA EaAliyahaA saAfilahaA","text_ar":"جَعَلْنَا عَالِيَهَا سَافِلَهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We made their upper part to be their lower part"},{"kind":"text","text":"]; (K;) and in the words of the Kur [lvi. 81],"},{"kind":"arabic","text_bw":"watajoEaluwna rizoqakumo","text_ar":"وَتَجْعَلُونَ رِزْقَكُمْ"},{"kind":"arabic","text_bw":"A^an~akumo tuka*~ibuwna","text_ar":"اَنَّكُمْ تُكَذِّبُونَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And do ye make"},{"kind":"text","text":"the thanks that ye should render for"},{"kind":"italic_en","text":"your sustenance to be that ye charge with falsehood"},{"kind":"text","text":"the Giver thereof by attributing it to the stars called"},{"kind":"arabic","text_bw":"A^anowaA='","text_ar":"اَنْوَا=ء"},{"kind":"text","text":"as expl. by Bd and Jel]. (TA.) ―         -b8-"},{"kind":"italic_en","text":"He pronounced"},{"kind":"text","text":"(Er-Rághib, K) a thing"},{"kind":"italic_en","text":"by a true judgment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decision,"},{"kind":"text","text":"(Er-Rághib,) or"},{"kind":"italic_en","text":"as a legal ordinance;"},{"kind":"text","text":"(K;) as in the saying (of the Legislator, TA),"},{"kind":"arabic","text_bw":"jaEala A@ll~`hu AlS~alawaAti","text_ar":"جَعَلَ ا@للّٰهُ الصَّلَوَاتِ"},{"kind":"arabic","text_bw":"AlmaforuwDaAti xamosFA","text_ar":"المَفْرُوضَاتِ خَمْسًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God hath pronounced the prayers that are made obligatory to be five"},{"kind":"text","text":"] (K.) And"},{"kind":"italic_en","text":"He pronounce"},{"kind":"text","text":"(Er-Rághib, K *) a thing"},{"kind":"italic_en","text":"by a false judgment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decision,"},{"kind":"text","text":"(Er-Rághib,) or"},{"kind":"italic_en","text":"according to his own judgment, heretically;"},{"kind":"text","text":"(K;) as in the saying [in the Kur xv. 91],"},{"kind":"arabic","text_bw":"Al~a*iyna jaEaluwA","text_ar":"الَّذِينَ جَعَلُوا"},{"kind":"arabic","text_bw":"AlquroA=na EiDiyna","text_ar":"القُرْا=نَ عِضِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Who pronounced the Kur-án to be lies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enchantment,"},{"kind":"text","text":"&c.]. (Er-Rághib, K.) ―         -b9-"},{"kind":"italic_en","text":"He called,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"named,"},{"kind":"text","text":"(S, Msb, K,) a thing; (Msb;) as in the saying [in the Kur xliii. 18],"},{"kind":"arabic","text_bw":"wajaEaluwA","text_ar":"وَجَعَلُوا"},{"kind":"arabic","text_bw":"AlmalaAy^ikapa Al~a*iyna humo EibaAdu Alr~aHom`ni A_inaAvFA","text_ar":"المَلَايِكَةَ الَّذِينَ هُمْ عِبَادُ الرَّحْمٰنِ اـِنَاثًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And they have called the angels, who are the servants of the Compassionate, females"},{"kind":"text","text":"]: (S, K:) or, as some say, the meaning is,"},{"kind":"italic_en","text":"have described them as, and pronounced them to be, females;"},{"kind":"text","text":"like as one says,"},{"kind":"arabic","text_bw":"jaEala fulaAnN zayodFA A^aEolama Aln~aAsi","text_ar":"جَعَلَ فُلَانٌ زَيْدًا اَعْلَمَ النَّاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one described Zeyd as, and pronounced him to be, the most learned of men"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"have held,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"believed, them to be females;"},{"kind":"text","text":"like as the verb signifies in the saying in the Kur [xvi. 59],"},{"kind":"arabic","text_bw":"wayajoEaluwna lil~`hi AlbanaAti","text_ar":"وَيَجْعَلُونَ لِلّٰهِ البَنَاتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And they hold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"believe, God to have daughters:"},{"kind":"text","text":"or this may be rendered"},{"kind":"italic_en","text":"and they attribute to God daughters"},{"kind":"text","text":"]. (TA.) You say also,"},{"kind":"arabic","text_bw":"jaEalotu zayodFA A^axaAka","text_ar":"جَعَلْتُ زَيْدًا اَخَاكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I asserted Zeyd to be related to thee"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as a brother;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I called Zeyd thy brother"},{"kind":"text","text":"]. (K.) ―         -b10-"},{"kind":"italic_en","text":"He thought;"},{"kind":"text","text":"as in the saying,"},{"kind":"arabic","text_bw":"jaEala AlbaSorapa","text_ar":"جَعَلَ البَصْرَةَ"},{"kind":"arabic","text_bw":"bagodaAda","text_ar":"بَغْدَادَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He thought El-Basrah to be Baghdád"},{"kind":"text","text":"]; (K;) and so in the saying,"},{"kind":"arabic","text_bw":"jaEalotuhu EabodFA fa$atamotuhu","text_ar":"جَعَلْتُهُ عَبْدًا فَشَتَمْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I thought him to be a slave, and consequently I reviled him"},{"kind":"text","text":"]. (Ham p. 31.) ―         -b11-"},{"kind":"italic_en","text":"He made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuous;"},{"kind":"text","text":"as in the saying [in the Kur xliii. 2, of which one explanation has been given above],"},{"kind":"arabic","text_bw":"A_in~aA jaEalonaAhu quroA=nFA Earabiy~FA","text_ar":"اـِنَّا جَعَلْنَاهُ قُرْا=نًا عَرَبِيًّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily we have made it known,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"as an Arabic Kur-án"},{"kind":"text","text":"]: (K:) or the meaning is,"},{"kind":"italic_en","text":"we have revealed it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as such"},{"kind":"text","text":"]. (TA.) ―         -b12-"},{"kind":"italic_en","text":"He exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ennobled;"},{"kind":"text","text":"as in the saying [in the Kur ii. 137],"},{"kind":"arabic","text_bw":"jaEalonaAkumo A^um~apF wasaTFA","text_ar":"جَعَلْنَاكُمْ اُمَّةً وَسَطًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We have exalted you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ennobled you, as a nation conforming to the just mean;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"equitable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good"},{"kind":"text","text":"]: (K:) [or it may be rendered,"},{"kind":"italic_en","text":"we have made you a nation"},{"kind":"text","text":"&c.:] or, as some say, the meaning is,"},{"kind":"italic_en","text":"we have called you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"named you, a nation"},{"kind":"text","text":"&c. (TA.) ―         -b13-  Also, inf. n."},{"kind":"arabic","text_bw":"jaEolN","text_ar":"جَعْلٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laid,"},{"kind":"text","text":"a thing; or"},{"kind":"italic_en","text":"put"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"laid"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"down."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jaEala baEoDahu","text_ar":"جَعَلَ بَعْضَهُ"},{"kind":"arabic","text_bw":"fuwoqa baEoDK","text_ar":"فُوْقَ بَعْضٍ"},{"kind":"italic_en","text":"He put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"threw, one part of it upon another."},{"kind":"text","text":"(K.) ―         -b14-"},{"kind":"italic_en","text":"He inserted"},{"kind":"text","text":"a thing into a thing; as in the Kur [ii. 18],"},{"kind":"arabic","text_bw":"yajoEaluwna A^aSaAbiEahumo","text_ar":"يَجْعَلُونَ اَصَابِعَهُمْ"},{"kind":"arabic","text_bw":"fiY A=*aAnihimo","text_ar":"فِى ا=ذَانِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They insert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, their fingers into their ears"},{"kind":"text","text":"]. (TA.) ―         -b15-"},{"kind":"italic_en","text":"He put"},{"kind":"text","text":"into the heart, or mind; as in the Kur [lvii. 27],"},{"kind":"arabic","text_bw":"wajalonaA fiY quluwbi","text_ar":"وَجَلْنَا فِى قُلُوبِ"},{"kind":"arabic","text_bw":"A@l~a*iyna A@t~abaEuwhu raA^ofapF waraHomapF","text_ar":"ا@لَّذِينَ ا@تَّبَعُوهُ رَاْفَةً وَرَحْمَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And we put into the hearts of those who followed him pity and com-"},{"kind":"page_break","n":431},{"kind":"italic_en","text":"passion"},{"kind":"text","text":"]. (TA.) ―         -b16-  ["},{"kind":"italic_en","text":"He appointed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assigned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stipulated to give,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave,"},{"kind":"text","text":"wages, pay, or a stipend, &c.]. You say,"},{"kind":"arabic","text_bw":"jaEalotu lahu juEolFA","text_ar":"جَعَلْتُ لَهُ جُعْلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I appointed him,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"wages, pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stipend"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"jaEala lahu ka*aA EalaY ka*aA","text_ar":"جَعَلَ لَهُ كَذَا عَلَى كَذَا"},{"kind":"italic_en","text":"He stipulated with him to give him such a thing for"},{"kind":"text","text":"["},{"kind":"italic_en","text":"doing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"such a thing."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jaEala","text_ar":"جَعَلَ"},{"kind":"text","text":"[alone]"},{"kind":"italic_en","text":"He gave wages, pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stipend, to another to serve for him in war,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"in his stead."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ajoEalotu","text_ar":"اَجْعَلْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I gave to him wages, pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stipend."},{"kind":"text","text":"(S, * Mgh.) And"},{"kind":"arabic","text_bw":"juEolFA","text_ar":"جُعْلًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ajoEalahu","text_ar":"اَجْعَلَهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ajoEalahu","text_ar":"اَجْعَلَهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He gave to him wages, pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stipend."},{"kind":"text","text":"(K, TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"jaEala","text_ar":"جَعَلَ"},{"kind":"arabic","text_bw":"liqawomihi miAy^apF mina AlA_ibili EalaY A^ano yusal~imuwA","text_ar":"لِقَوْمِهِ مِايَةً مِنَ الاـِبِلِ عَلَى اَنْ يُسَلِّمُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stipulated to give, to his people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, a hundred camels on the condition that they should surrender"},{"kind":"text","text":"]. (Mgh.)       -A2-"},{"kind":"arabic","text_bw":"jaEala yafoEalu ka*aA","text_ar":"جَعَلَ يَفْعَلُ كَذَا"},{"kind":"italic_en","text":"He set about, began, commenced, took to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself to, doing such a thing;"},{"kind":"text","text":"(K, * TA;)"},{"kind":"italic_en","text":"he became occupied in doing such a thing."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jaEala","text_ar":"جَعَلَ"},{"kind":"text","text":"is also, sometimes, an intrans. verb included among the verbs of appropinquation ("},{"kind":"arabic","text_bw":"A^afoEaAlu AlmuqaArabapi","text_ar":"اَفْعَالُ المُقَارَبَةِ"},{"kind":"text","text":"); as in the saying,"},{"kind":"quote","text":"waqado jaEalotu A_i*aA maA qumotu yuvoqiluniY\n                      \n                     \n                        vawobiY faA^anohaDu nahoDa Al$~aAribi Alv~~amili"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I was beginning to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the point of being, in such a state that, when I rose, my garment heavily burdened me, so that I stood up as stands up the intoxicated drinker"},{"kind":"text","text":"]. (K.)       -A3-"},{"kind":"arabic","text_bw":"jaEila","text_ar":"جَعِلَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jaEalN","text_ar":"جَعَلٌ"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"AjEl","text_ar":"اجعل","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"had in it many"},{"kind":"arabic","text_bw":"jiEolaAn","text_ar":"جِعْلَان"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"juEalN","text_ar":"جُعَلٌ"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"had in it dead"},{"kind":"arabic","text_bw":"jiEolaAn","text_ar":"جِعْلَان"},{"kind":"text","text":". (K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"jaEila","text_ar":"جَعِلَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"jaEalN","text_ar":"جَعَلٌ"},{"kind":"text","text":", (IAar, K, TK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a boy, TK)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, short and fat."},{"kind":"text","text":"(IAar, K. [In the explanation of"},{"kind":"arabic","text_bw":"AljaEalu","text_ar":"الجَعَلُ"},{"kind":"text","text":"in the CK,"},{"kind":"arabic","text_bw":"AlqaSiyru","text_ar":"القَصِيرُ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"AlqiSaru","text_ar":"القِصَرُ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TK)"},{"kind":"italic_en","text":"persisted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persisted obstinately;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persisted in contention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigated;"},{"kind":"arabic","text_bw":"jaEalN","text_ar":"جَعَلٌ"},{"kind":"text","text":"being syn. with"},{"kind":"arabic","text_bw":"lajaAjN","text_ar":"لَجَاجٌ"},{"kind":"text","text":". (IAar, K.)"}],"source_refs":["S","Msb","K","TA","TK","IAar"]}]}}