{"lemma":"جَنَّ","slug":"جَنَّ","root":"ج.ن.ن","root_slug":"ج-ن-ن","root_link":"/words/roots/ج-ن-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَنَنْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَنَنْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَنَنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَنَنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَنَنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَنَّ","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَنَّت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَنّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَنَّتا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَنُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَنَنَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجُنّ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَجْنُن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجُنِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجُنِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْنُنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْنُنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجُنّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجُنّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْنُنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْنُنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجُنُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجُنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْنُنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْنُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْنُنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجُنّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْنُن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجُنّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْنُن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجُنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجُنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْنُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْنُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجُنّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجُنّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْنُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْنُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجُنُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجُنُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْنُنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْنُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْنُنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَجُنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجُنّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"جَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَنَنّا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":14,"cross_references":{"qac":{"found":true,"lemma_key":"جَنَّ","root":"جنن","pos":"N","occurrence_count":22},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["","n6379"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cover, to hide, to conceal, to veil","tags":["transitive"]},{"pos":"verb","gloss":"to envelop, to enshroud, to cloak, to screen","tags":["transitive"]},{"pos":"verb","gloss":"to descend, to fall, to become night","tags":["transitive"],"examples":[{"text":"11 Century CE, Wallada bint al-Mustakfi, ترقب إذا جن الظلام زيارتي\nتَرَقَّبْ إِذَا جَنَّ الظَّلَامُ زِيَارَتِي / فَإِنِّي رَأَيْتُ اللَّيْلَ أَكْتَمَ لِلسِّرِّ\ntaraqqab ʔiḏā janna ẓ-ẓalāmu ziyāratī / fa-ʔinnī raʔaytu l-layla ʔaktama li-s-sirri","english":"Await, when darkness falls, my visit. For I found the night to be a better keeper of secrets."}]},{"pos":"noun","gloss":"spiritual or otherwise unseen, undetectable, masked, or morphed beings that may be benevolent or helpful (agathodaemons, eudaemons), neutral, or malevolent (cacodemons); demonkind, jinn, genies","tags":["collective"]},{"pos":"noun","gloss":"any mythical beings in general (such as fairies, satyrs, nymphs, elves, goblins, and sprites)","tags":["collective"]},{"pos":"noun","gloss":"a genie, a jann, one of the jinn(s).","tags":["collective","informal","singular"]},{"pos":"verb","gloss":"to be possessed; to seem or act as if possessed, to be insane, to be crazy, to be mad, to be deranged"},{"pos":"verb","gloss":"to be possessed; to be obsessed; to be infatuated"},{"pos":"noun","gloss":"verbal noun of جُنَّ (junna) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of جَنَّ (janna) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew גָּנַן (gānán, “to defend, to cover”).\n\nFormally from the root ج ن ن (j n n), related to disappearance, hiding and concealment, though most likely a back-formation from جِنِّي (jinnī), derived from Classical Syriac ܓܢܝ (gnē, “spirit, genie”), or its emphatic form Aramaic גניא (ginnāyā) or Classical Syriac ܓܢܝܐ (genyā), also meaning \"a tutelary deity\" or \"Astaroth idols\". Compare Latin genius.\n\nDenominal verb from جِنّ (jinn, “jinn; spirit, demon”), leveled to the root ج ن ن (j n n)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6379","headword_ar":"جِنٌّ","root":"jn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"darkness"},{"kind":"text","text":"of night; as also ↓"},{"kind":"arabic","text_bw":"junuwnN","text_ar":"جُنُونٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"janaAnu","text_ar":"جَنَانُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) the last [written in the CK"},{"kind":"arabic","text_bw":"junAn","text_ar":"جُنان"},{"kind":"text","text":", but it is] with fet-h: (TA:) or all signify its"},{"kind":"italic_en","text":"intense darkness:"},{"kind":"text","text":"(TA:) or all, the"},{"kind":"italic_en","text":"confusedness of the darkness"},{"kind":"text","text":"of night: (K:) [all, in these senses, are app. inf. ns.: (see 1:)] the last, ↓"},{"kind":"arabic","text_bw":"janaAnN","text_ar":"جَنَانٌ","orth_type":"arrow"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"night"},{"kind":"text","text":"[itself]: (K:) or [so in copies of the K, accord. to the TA, but in the CK “ and, ”] the"},{"kind":"italic_en","text":"dense black darkness"},{"kind":"text","text":"of night: (S, K:) and ↓"},{"kind":"arabic","text_bw":"junuwnN","text_ar":"جُنُونٌ","orth_type":"arrow"},{"kind":"text","text":", the"},{"kind":"italic_en","text":"veiling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protecting, darkness"},{"kind":"text","text":"of night. (ISk, S.) ―         -b2-"},{"kind":"italic_en","text":"Concealment:"},{"kind":"text","text":"so in the phrase,"},{"kind":"arabic","text_bw":"laA jin~a bih`*aA AlA^amori","text_ar":"لَا جِنَّ بِهٰذَا الاَمْرِ"},{"kind":"italic_en","text":"There is no concealment with this thing."},{"kind":"text","text":"(K, * TA.) One of the Hudhalees says,"},{"kind":"quote","text":"walaA jin~a biAlbagoDaA='i waAln~aZari Al$~azori"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And there is no concealment with vehement hatred and the looking with aversion"},{"kind":"text","text":"]. (TA.)       -A2-  [The"},{"kind":"italic_en","text":"genii;"},{"kind":"text","text":"and sometimes the"},{"kind":"italic_en","text":"angels;"},{"kind":"text","text":"] accord. to some, the"},{"kind":"italic_en","text":"spiritual beings that are concealed from the senses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that conceal themselves from the senses; all of such beings;"},{"kind":"text","text":"(Er-Rághib, TA;) the"},{"kind":"italic_en","text":"opposite of"},{"kind":"arabic","text_bw":"A_inosN","text_ar":"اـِنْسٌ"},{"kind":"text","text":"; (S, Mgh, Msb, Er-Rághib, TA;)"},{"kind":"italic_en","text":"thus comprising the angels; all of these being"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"; (Er-Rághib, TA;) thus called because they are feared but not seen: (S:) or, accord. to others,"},{"kind":"italic_en","text":"certain of the spiritual beings;"},{"kind":"text","text":"for the spiritual beings are of three kinds; the good being the angels; and the evil being the devils ("},{"kind":"arabic","text_bw":"$ayaATiyn","text_ar":"شَيَاطِين"},{"kind":"text","text":"); and"},{"kind":"italic_en","text":"the middle kind, among whom are good and evil,"},{"kind":"text","text":"being the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"; as is shown by the first twelve verses of ch. lxxii. of the Kur: (Er-Rághib, TA:) or it here means"},{"kind":"italic_en","text":"intelligent invisible bodies, predominantly of the fiery,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the aerial, quality:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a species of souls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirits, divested of bodies:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"human souls separate from their bodies:"},{"kind":"text","text":"(Bd:) or the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"are the"},{"kind":"italic_en","text":"angels"},{"kind":"text","text":"["},{"kind":"italic_en","text":"exclusively"},{"kind":"text","text":"]; (K;) these being so called in the Time of Ignorance, because they were concealed, or because they concealed themselves, from the eyes: so, accord. to some, in the Kur [xviii. 48], where it is said that Iblees was of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":": and so, as some say, in the Kur [vi. 100], where it is said that they called the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"partners of God: (TA:) but some reject the explanation in the K, because the angels were created of light, and the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"of fire; and the former do not propagate their kind, nor are they to be described as males and females; contrary to the case of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"; wherefore it is generally said that in the phrase [in the Kur xviii. 48, above mentioned]"},{"kind":"arabic","text_bw":"A_il~aA A_iboliysa kaAna mina Aljin~i","text_ar":"اـِلَّا اـِبْلِيسَ كَانَ مِنَ الجِنِّ"},{"kind":"text","text":", what is excepted is disunited in kind from that from which the exception is made, or that Iblees had adopted the dispositions of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":": (MF, TA:) or, as some say, the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"were"},{"kind":"italic_en","text":"a species of the angels, who were the guardians of the earth and of the gardens of Paradise:"},{"kind":"text","text":"(TA:) ↓"},{"kind":"arabic","text_bw":"jin~apN","text_ar":"جِنَّةٌ","orth_type":"arrow"},{"kind":"text","text":", also, signifies the same as"},{"kind":"arabic","text_bw":"jin~N","text_ar":"جِنٌّ"},{"kind":"text","text":": (S, Msb, K:) so in the last verse of the Kur: (S:) in the Kur xxxvii. 158 meaning the"},{"kind":"italic_en","text":"angels,"},{"kind":"text","text":"whom certain of the Arabs worshipped; (TA;) and whom they called the daughters of God: (Fr, TA:) a single individual of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"is called ↓"},{"kind":"arabic","text_bw":"jin~iY~N","text_ar":"جِنِّىٌّ","orth_type":"arrow"},{"kind":"text","text":", [fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":":] (S, TA:) and ↓"},{"kind":"arabic","text_bw":"jaAn~N","text_ar":"جَانٌّ","orth_type":"arrow"},{"kind":"text","text":", also, is syn. with"},{"kind":"arabic","text_bw":"jin~N","text_ar":"جِنٌّ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"AljaAnN","text_ar":"الجَانٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the father of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"; (S, Mgh, TA;) [i. e. any father of"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":"; for] the pl. is"},{"kind":"arabic","text_bw":"jin~aAnN","text_ar":"جِنَّانٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"HiyTaAnN","text_ar":"حِيطَانٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"HaAy^iTN","text_ar":"حَايِطٌ"},{"kind":"text","text":": (S, TA:) so says El-Hasan: it is said in the T, on the authority of"},{"kind":"page_break","n":463},{"kind":"text","text":"AA, that the"},{"kind":"arabic","text_bw":"jAn~","text_ar":"جانّ"},{"kind":"text","text":"is, or are,"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"jaAn~N","text_ar":"جَانٌّ"},{"kind":"text","text":"is a quasi-pl. n. of"},{"kind":"arabic","text_bw":"jin~N","text_ar":"جِنٌّ"},{"kind":"text","text":"; (M, K;) like"},{"kind":"arabic","text_bw":"jaAmilN","text_ar":"جَامِلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baAqirN","text_ar":"بَاقِرٌ"},{"kind":"text","text":": (M, TA:) so in the Kur lv. 56 and 74: in reading the passage in the Kur lv. 39, 'Amr Ibn- 'Obeyd pronounced it"},{"kind":"arabic","text_bw":"jaA^anN","text_ar":"جَاَنٌ"},{"kind":"text","text":": (TA:) it is related that there were"},{"kind":"italic_en","text":"certain creatures"},{"kind":"text","text":"called the"},{"kind":"arabic","text_bw":"jaAn~","text_ar":"جَانّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"who were upon the earth, and who acted corruptly therein, and shed blood, wherefore God sent angels who banished them from the earth;"},{"kind":"text","text":"and it is said that these angels became the inhabitants of the earth after them. (Zj, TA.)"},{"kind":"arabic","text_bw":"baAta fulaAnN Dayofa jin~K","text_ar":"بَاتَ فُلَانٌ ضَيْفَ جِنٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one passed the night a guest of"},{"kind":"arabic","text_bw":"jn~","text_ar":"جنّ"},{"kind":"text","text":"] means,"},{"kind":"italic_en","text":"in a desolate place, in which was no one that might cheer him by his society"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"converse."},{"kind":"text","text":"(TA.) The saying of Moosà Ibn-Jábir,"},{"kind":"quote","text":"famaA nafarato jin~iY walaA ful~a miboradiY"},{"kind":"text","text":"may mean"},{"kind":"italic_en","text":"And my companions, who were like the"},{"kind":"arabic","text_bw":"jin~","text_ar":"جِنّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"did not flee"},{"kind":"text","text":"when I came to them and informed them,"},{"kind":"italic_en","text":"nor was my tongue, that is like the file, deprived of its sharp edge:"},{"kind":"text","text":"or by his"},{"kind":"arabic","text_bw":"jn~","text_ar":"جنّ"},{"kind":"text","text":"he means his"},{"kind":"italic_en","text":"familiar"},{"kind":"arabic","text_bw":"jn~","text_ar":"جنّ"},{"kind":"text","text":", such as were asserted to aid poets when difficulties befell them; and by his"},{"kind":"arabic","text_bw":"mbrd","text_ar":"مبرد"},{"kind":"text","text":", his"},{"kind":"italic_en","text":"tongue:"},{"kind":"text","text":"(Ham p. 182 [where other explanations are proposed; but they are far-fetched]:) or by his"},{"kind":"arabic","text_bw":"jn~","text_ar":"جنّ"},{"kind":"text","text":"he means his"},{"kind":"italic_en","text":"heart;"},{"kind":"text","text":"and by his"},{"kind":"arabic","text_bw":"mbrd","text_ar":"مبرد"},{"kind":"text","text":", his"},{"kind":"italic_en","text":"tongue."},{"kind":"text","text":"(S.) The Arabs liken a man who is sharp and effective in affairs to a"},{"kind":"arabic","text_bw":"jin~iY~","text_ar":"جِنِّىّ"},{"kind":"text","text":"and a"},{"kind":"arabic","text_bw":"$ayoTaAn","text_ar":"شَيْطَان"},{"kind":"text","text":": and hence they said,"},{"kind":"arabic","text_bw":"nafarato jin~uhu","text_ar":"نَفَرَتْ جِنُّهُ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He became weak and abject."},{"kind":"text","text":"(Ham ubi suprà.) ―         -b2-  The"},{"kind":"italic_en","text":"greater, main,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, part,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"main body,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bulk,"},{"kind":"text","text":"of men, or of mankind; as also ↓"},{"kind":"arabic","text_bw":"janaAnN","text_ar":"جَنَانٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) because he who enters among them becomes concealed by them: (TA:) or the latter means the"},{"kind":"italic_en","text":"general assemblage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collective body,"},{"kind":"text","text":"of men: (IAar, S, * TA:) or"},{"kind":"italic_en","text":"what veils, conceals, covers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protects, one,"},{"kind":"text","text":"of a thing. (AA, TA.) ―         -b3-  (tropical:)  The"},{"kind":"italic_en","text":"flowers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blossoms,"},{"kind":"text","text":"of plants or herbage. (K, TA.) ―         -b4-  (tropical:)  The"},{"kind":"italic_en","text":"prime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first part,"},{"kind":"text","text":"of youth: (S, K, TA:) or the"},{"kind":"italic_en","text":"sharpness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigorousness, and briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness,"},{"kind":"text","text":"thereof. (TA.) You say,"},{"kind":"arabic","text_bw":"kaAna *`lik fiY jin~i $abaAbihi","text_ar":"كَانَ ذٰلِك فِى جِنِّ شَبَابِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"That was in the prime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first part, of his youth."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"A^afoEalu *`lika AlA^amora bijin~i *`lika","text_ar":"اَفْعَلُ ذٰلِكَ الاَمْرَ بِجِنِّ ذٰلِكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I will do that thing in the time of the first and fresh state of that."},{"kind":"text","text":"(S, TA.)"},{"kind":"arabic","text_bw":"jin~N","text_ar":"جِنٌّ"},{"kind":"text","text":"may also signify (assumed tropical:)  The"},{"kind":"italic_en","text":"madness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity, of exultation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of excessive exultation."},{"kind":"text","text":"(TA.) And one says,"},{"kind":"arabic","text_bw":"Ait~qi Aln~Aqapa faA_in~haA bijin~i","text_ar":"اِتّقِ النّاقَةَ فَاـِنّهَا بِجِنِّ"},{"kind":"arabic","text_bw":"DiraAmihaA","text_ar":"ضِرَامِهَا"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Fear thou the she-camel, for she is in her evil temper on the occasion of her bringing forth."},{"kind":"text","text":"(TA.) ―         -b5-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jd~","text_ar":"جدّ"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"jid~N","text_ar":"جِدٌّ"},{"kind":"text","text":", as meaning (assumed tropical:)"},{"kind":"italic_en","text":"Seriousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earnestness"},{"kind":"text","text":"]; because it is a thing that is an accompaniment of thought, or reflection, and is concealed by the heart. (TA.)"}],"source_refs":["K","TA","S","Bd","MF","Msb","Fr","M"]}]},"classical_definitions":null}