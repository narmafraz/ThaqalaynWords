,"text_bw":"sfh","text_ar":"سفه"},{"kind":"text","text":", conj. 3.]"}],"source_refs":[]},{"entry_id":"n35967","headword_ar":"قَاعِدَةٌ","root":"qEd","body":[{"kind":"italic_en","text":"A foundation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"basis,"},{"kind":"text","text":"of a house: (Msb:) pl."},{"kind":"arabic","text_bw":"qawaAEidu","text_ar":"قَوَاعِدُ"},{"kind":"text","text":": (S, Msb:) which signifies, accord. to Zj, the"},{"kind":"italic_en","text":"columns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"poles,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^asaATiyn","text_ar":"اَسَاطِين"},{"kind":"text","text":") of a structure,"},{"kind":"italic_en","text":"which support"},{"kind":"text","text":"it. (L.) [Hence,]"},{"kind":"arabic","text_bw":"qaAEidataA AlbaAbi","text_ar":"قَاعِدَتَا البَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The two side-posts of the door"},{"kind":"text","text":"]. (K, in art."},{"kind":"arabic","text_bw":"swm","text_ar":"سوم"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"banaY A^amorahu EalaY qaAEidapK","text_ar":"بَنَى اَمْرَهُ عَلَى قَاعِدَةٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ElY qawaAEida","text_ar":"على قَوَاعِدَ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"He built his affair upon a"},{"kind":"text","text":"firm"},{"kind":"italic_en","text":"foundation,"},{"kind":"text","text":"and,"},{"kind":"italic_en","text":"upon"},{"kind":"text","text":"firm"},{"kind":"italic_en","text":"foundations"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"qaAEidapu A^amorika waAhiyapN","text_ar":"قَاعِدَةُ اَمْرِكَ وَاهِيَةٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The foundation of thine affair is unsound"},{"kind":"text","text":"]. (A.) ―         -b3-"},{"kind":"arabic","text_bw":"qawaAEidu Als~aHaAbi","text_ar":"قَوَاعِدُ السَّحَابِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The lower parts of clouds extending across the view in the horizon, likened to the foundations of a building:"},{"kind":"text","text":"(A'Obeyd, L:) or"},{"kind":"italic_en","text":"clouds extending across the view, and lying low."},{"kind":"text","text":"(IAth, L.) ―         -b4-  [Hence]"},{"kind":"arabic","text_bw":"qawaAEidu Alhawodaji","text_ar":"قَوَاعِدُ الهَوْدَجِ"},{"kind":"italic_en","text":"The four pieces of wood,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"placed transversely,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"two across the other two, so as to form a square frame,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"beneath the"},{"kind":"arabic","text_bw":"hwdj","text_ar":"هودج"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"which is fixed upon them."},{"kind":"text","text":"(K.) [See 1 in art."},{"kind":"arabic","text_bw":"f$l","text_ar":"فشل"},{"kind":"text","text":".]       -A2-  As a conventional term, i. q."},{"kind":"arabic","text_bw":"DaAbiTN","text_ar":"ضَابِطٌ"},{"kind":"text","text":", i. e. (assumed tropical:)"},{"kind":"italic_en","text":"A universal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"general, rule,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"canon."},{"kind":"text","text":"(Msb.) [See"},{"kind":"arabic","text_bw":"DaAbiT","text_ar":"ضَابِط"},{"kind":"text","text":".]"}],"source_refs":["Msb","S","K"]}]},"classical_definitions":null}