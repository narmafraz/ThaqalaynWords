:"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُقَلِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُقَلِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُقَلِّم","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُقَلِّم","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُقَلِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُقَلِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُقَلِّمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُقَلِّما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُقَلِّمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُقَلِّمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُقَلِّمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُقَلِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُقَلِّم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"قَلَّمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَلَّمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":19,"cross_references":{"qac":{"found":true,"lemma_key":"قَلَّمَ","root":"قلم","pos":"N","occurrence_count":4},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n42810"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D9%84%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cut, to clip, to pare, to prune, to trim, to lop, to truncate, to snip, to cut back, to cut down"},{"pos":"verb","gloss":"to make stripes, to stripe"},{"pos":"verb","gloss":"to fleece, to fleece wool"},{"pos":"verb","gloss":"to cut much or frequently"},{"pos":"verb","gloss":"to striate, to stripe"},{"pos":"noun","gloss":"pen, reed pen"},{"pos":"noun","gloss":"pencil","examples":[{"text":"قَلَم رَصَاص","english":"pencil"}]},{"pos":"noun","gloss":"writing, script, calligraphic style, ductus, handwriting"},{"pos":"noun","gloss":"style"},{"pos":"noun","gloss":"office, bureau, agency"},{"pos":"noun","gloss":"window, counter"},{"pos":"noun","gloss":"item, entry"},{"pos":"noun","gloss":"stripe, streak, line, bar, stria"},{"pos":"noun","gloss":"[with بِـ] بِقَلَم (biqalam): written by (often used to indicate the writer of an article)"},{"pos":"noun","gloss":"verbal noun of قَلَمَ (qalama) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Intensive form II verb derived from form I verb قَلَمَ (qalama, “to cut”).\n\nFrom Ancient Greek κάλαμος (kálamos, “reed”). Nöldeke and Jeffery are convinced that it comes thence via Ge'ez ቀለም (ḳäläm, “reed”), while Leslau notes that ቀለም (ḳäläm, “reed”) could come from Arabic. But the meaning “reed” – referring to a plant – is not actually attested for the Arabic word, and given the peculiar semantics in Ge'ez where the word ቀለም (ḳäläm) is mixed into the root of ቀለመ (ḳälämä, “to color, to stain, to write”) and as well means “color”, “ink”, “inkstand”, as Leslau separates himself, a Ge'ez origin can explain why in Arabic the meaning is restricted to “pen” in the beginning compared with the Ancient Greek κάλαμος (kálamos) meaning “reed cane” in general."},"ipa":["/qa.la.ma/","/qal.la.ma/","/qa.lam/","/ʔa.lam/","/qələm/","/ɡa.lam/","/qlam/","/qalm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42810","headword_ar":"قَلَمٌ","root":"qlm","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qalamaAni","text_ar":"قَلَمَانِ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qalamaAnN","text_ar":"قَلَمَانٌ","orth_type":"arrow"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jalamN","text_ar":"جَلَمٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"italic_en","text":"A writing-reed prepared for writing; a reed-pen."}],"source_refs":[]}]}}