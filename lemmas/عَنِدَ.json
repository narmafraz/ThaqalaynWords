{"lemma":"عَنِدَ","slug":"عَنِدَ","root":"ع.ن.د","root_slug":"ع-ن-د","root_link":"/words/roots/ع-ن-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَنِدْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَنِدْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَنِدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَنِدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَنِدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَنِدَ","in_corpus":true,"count":1121,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَنِدَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَنِدا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَنِدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَنِدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَنِدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْنَد","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْنَدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْنَدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْنَدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْنَدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْنَدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْنَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْنَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْنَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْنَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْنَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْنَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْنَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْنَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْنَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْنَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْنَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْنَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْنَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَنِدْنا","in_corpus":true,"count":104,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَنِدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1225,"cross_references":{"qac":{"found":true,"lemma_key":"عَنِدَ","root":"عند","pos":"N","occurrence_count":197},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","prep","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n30726","n30727","n30728","n30729"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%86%D9%90%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"prep","gloss":"near, with, at the house of"},{"pos":"prep","gloss":"at the time of","examples":[{"text":"جِئْتُكَ عِنْدَ شُرُوقِ الشَّمْسِ","english":"I came to you at sunrise"}]},{"pos":"prep","gloss":"in one's sight, in one's opinion","examples":[{"text":"إِذْ تَلَقَّوْنَهُ بِأَلْسِنَتِكُمْ وَتَقُولُونَ بِأَفْوَاهِكُم مَّا لَيْسَ لَكُم بِهِ عِلْمٌ وَتَحْسَبُونَهُ هَيِّنًا وَهُوَ عِنْدَ ٱللَّهِ عَظِيمٌ","english":"When you received it with your tongues and said with your mouths that of which you had no knowledge and thought it was insignificant while it was, in the eyes of God, tremendous."},{"text":"بِذَا قَضَتِ الْأَيَّامُ مَا بَيْنَ أَهْلِهَا / مَصَائِبُ قَوْمٍ عِنْدَ قَوْمٍ فَوَائِدُ"}]},{"pos":"prep","gloss":"expresses possession, to have","examples":[{"text":"قُلْ هَلْ عِنْدَكُم مِنْ عِلْمٍ فَتُخْرِجُوهُ لَنَا","english":"Say, \"Do you have any knowledge which you can produce for us?\""}]},{"pos":"verb","gloss":"to be perverse, diverging or obstinate"},{"pos":"noun","gloss":"animus, heart, will"},{"pos":"adj","gloss":"common plural of عَنُود (ʕanūd)","tags":["common","form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"A contraction of ع ن ن (ʕ n n) or ع ي ن (ʕ y n) in the sense of viewing, and يَدَا (yadā, “hand”); see at hand, before one's eyes. Compare also لَدَى (ladā) and لَدُنْ (ladun) for parallel contractions and semantic senses."},"ipa":["/ʕin.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30726","headword_ar":"عَنْدٌ","root":"End","body":[{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Eanoda","text_ar":"عَنْدَ"},{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n30727","headword_ar":"عُنْدٌ","root":"End","body":[{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Eunoda","text_ar":"عُنْدَ"},{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n30728","headword_ar":"عِنْدٌ","root":"End","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EanodN","text_ar":"عَنْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EunodN","text_ar":"عُنْدٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K,) accord. to Ibn-'Abbád, (O,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"naAHiyapN","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":"[app. as meaning The"},{"kind":"italic_en","text":"vicinage,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"quarter, tract, region,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place,"},{"kind":"text","text":"of a person or thing]: (O, K:) whence the saying,"},{"kind":"arabic","text_bw":"huwa Einoda fulaAnK AlA=na","text_ar":"هُوَ عِنْدَ فُلَانٍ الا=نَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is in the vicinage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the quarter,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of such a one, now"},{"kind":"text","text":"]. (O.) [See also"},{"kind":"arabic","text_bw":"EanadN","text_ar":"عَنَدٌ"},{"kind":"text","text":", which has a similar meaning.]       -A2-"},{"kind":"arabic","text_bw":"Einoda","text_ar":"عِنْدَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eanoda","text_ar":"عَنْدَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eunoda","text_ar":"عُنْدَ","orth_type":"arrow"},{"kind":"text","text":"signify the same, (S, O, Msb, Mughnee, K,) being dial. vars., (S, O, Msb,) the first of which is the most common, (Mughnee,) and the most chaste: (Msb:) each is an adv. n. of place, and also of time; (S, O, Msb, Mughnee, K;) [used in the manner of a prep., though properly a prefixed noun;] of place when prefixed to a noun signifying a place [or anything local]; (TA;) of time when prefixed to a noun signifying a time: (Msb, TA:) denoting presence, (S, O,) i. e. perceptible presence, and also ideal presence, or rather the place of presence; (Mughnee;) and nearness, (S, O, Mughnee,) or the place of nearness; (Mughnee;) or the utmost nearness, and therefore it has no dim.; (T, TA;) [i. e.] it is primarily used in relation to that which is present with a person [or thing], in any adjacent part or quarter with respect to that person [or thing]; or in relation to that which is near to a person [or thing]: (Msb:) [thus it signifies"},{"kind":"italic_en","text":"At, near, nigh, by, near by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"close by,"},{"kind":"text","text":"a place, or thing;"},{"kind":"italic_en","text":"with, present with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the presence of,"},{"kind":"text","text":"a person or persons, or a thing or things;"},{"kind":"italic_en","text":"at the abode of"},{"kind":"text","text":"a person;"},{"kind":"italic_en","text":"at the place of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the region of,"},{"kind":"text","text":"a thing; or"},{"kind":"italic_en","text":"among,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amongst,"},{"kind":"text","text":"persons or things: and"},{"kind":"italic_en","text":"at, near, nigh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about,"},{"kind":"text","text":"a time; and"},{"kind":"italic_en","text":"at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon,"},{"kind":"text","text":"denoting"},{"kind":"italic_en","text":"the occasion"},{"kind":"text","text":"of an event or an action:] ―         -b2-  using it as an adv. n. of place, you say"},{"kind":"arabic","text_bw":"Einoda Albayoti","text_ar":"عِنْدَ البَيْتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"At, near, nigh, by, near by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"close by, the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent"},{"kind":"text","text":"]; (TA;) and"},{"kind":"arabic","text_bw":"Einoda AlHaAy^iTi","text_ar":"عِنْدَ الحَايِطِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"At, near, nigh,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the wall"},{"kind":"text","text":"]; (S, O;) [and"},{"kind":"arabic","text_bw":"EinodiY zayodN","text_ar":"عِنْدِى زَيْدٌ"},{"kind":"italic_en","text":"With me, present with me, in my presence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at my abode, is Zeyd;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kunotu Einoda Alqawomi","text_ar":"كُنْتُ عِنْدَ القَوْمِ"},{"kind":"italic_en","text":"I was with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"among, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party;"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"falam~aA raA=hu","text_ar":"فَلَمَّا رَا=هُ"},{"kind":"arabic","text_bw":"musotaqir~FA Einodahu","text_ar":"مُسْتَقِرًّا عِنْدَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And when he saw it standing in his presence"},{"kind":"text","text":"(in the Kur xxvii. 40)] is an ex. of its use as denoting presence perceptible by sense: and it is used as denoting nearness in the phrase"},{"kind":"arabic","text_bw":"Einoda sidorapi A@lomunotahaY","text_ar":"عِنْدَ سِدْرَةِ ا@لْمُنْتَهَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nigh to the lote-tree of the ultimate point of access"},{"kind":"text","text":"(in the Kur liii. 14)]: (Mughnee:) you say also,"},{"kind":"arabic","text_bw":"EinodiY maAlN","text_ar":"عِنْدِى مَالٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"With me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by me,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"present with me, is property;"},{"kind":"text","text":"and meaning also"},{"kind":"italic_en","text":"in my possession, and in my power and at my disposal, is property,"},{"kind":"text","text":"though absent from me;"},{"kind":"italic_en","text":"I have,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possess, property;"},{"kind":"text","text":"(Msb, Mughnee; *) and"},{"kind":"arabic","text_bw":"liY Einodahu maAlN","text_ar":"لِى عِنْدَهُ مَالٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have property in his hands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possession;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"there is property due to me in his hands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possession;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"owed to me by him"},{"kind":"text","text":"]; as also"},{"kind":"arabic","text_bw":"qibalahu","text_ar":"قِبَلَهُ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"qbl","text_ar":"قبل"},{"kind":"text","text":":) hence it is used in relation to attributes; so that one says,"},{"kind":"arabic","text_bw":"Einodahu xayorN wafaDolN","text_ar":"عِنْدَهُ خَيْرٌ وَفَضْلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possesses, goodness and excellence"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"maA Enidahu","text_ar":"مَا عنِدَهُ"},{"kind":"arabic","text_bw":"$ar~N","text_ar":"شَرٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has not evil"},{"kind":"text","text":"]: and hence the saying in the Kur [xxviii. 27],"},{"kind":"arabic","text_bw":"faA_ino A^atomamota Ea$orFA famino Einodika","text_ar":"فَاـِنْ اَتْمَمْتَ عَشْرًا فَمِنْ عِنْدِكَ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"And if thou complete ten"},{"kind":"text","text":"years, it will be]"},{"kind":"italic_en","text":"of thy redundant bounty;"},{"kind":"text","text":"(Msb;) [or"},{"kind":"italic_en","text":"of thine own freewill;"},{"kind":"text","text":"as is implied in the explanation by Bd, and agreeably with common usage:] and it is used as denoting ideal presence in the phrase"},{"kind":"arabic","text_bw":"qaAla A@l~a*iY Einodahu EilomN mina A@lokitaAbi","text_ar":"قَالَ ا@لَّذِى عِنْدَهُ عِلْمٌ مِنَ ا@لْكِتَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He with whom was,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"who possessed, knowledge the of Scripture said"},{"kind":"text","text":"(in the Kur xxvii. 40)]: (Mughnee:) [hence also] one says,"},{"kind":"arabic","text_bw":"liY Einoda fulaAnK HaAjapN","text_ar":"لِى عِنْدَ فُلَانٍ حَاجَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have an object of want to be sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"required, at the hand of such a one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a want to be supplied on the part of such a one;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"I want a thing of such a one;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"qibala fulaAnK","text_ar":"قِبَلَ فُلَانٍ"},{"kind":"text","text":"]: (TA in art."},{"kind":"arabic","text_bw":"Hwj","text_ar":"حوج"},{"kind":"text","text":":) [and in like manner one says of a right or due ("},{"kind":"arabic","text_bw":"Haq~N","text_ar":"حَقٌّ"},{"kind":"text","text":"): and"},{"kind":"arabic","text_bw":"Talaba HaAjapF Einoda fulaAnK","text_ar":"طَلَبَ حَاجَةً عِنْدَ فُلَانٍ"},{"kind":"italic_en","text":"He sought an object of want at the hand of such a one:"},{"kind":"text","text":"(see an ex. in art."},{"kind":"arabic","text_bw":"Elw","text_ar":"علو"},{"kind":"text","text":", conj. 3:)] ―         -b3-  using it as an adv. n. of time, you say"},{"kind":"arabic","text_bw":"Einoda AlS~uboHi","text_ar":"عِنْدَ الصُّبْحِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"At, near, nigh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, daybreak"},{"kind":"text","text":"]; (Msb, TA;) and"},{"kind":"arabic","text_bw":"Einoda All~ayoli","text_ar":"عِنْدَ اللَّيْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"At, near, nigh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, night"},{"kind":"text","text":"]; (S, O;) and"},{"kind":"arabic","text_bw":"jiy^otuka Einoda TuluwEi Al$~amosi","text_ar":"جِيْتُكَ عِنْدَ طُلُوعِ الشَّمْسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came to thee at, near,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the rising of the sun"},{"kind":"text","text":"]; (Mughnee;) [and"},{"kind":"arabic","text_bw":"Einoda","text_ar":"عِنْدَ"},{"kind":"arabic","text_bw":"*`lika","text_ar":"ذٰلِكَ"},{"kind":"italic_en","text":"At, on, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the occasion of, that"},{"kind":"text","text":"event;"},{"kind":"italic_en","text":"thereupon;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EinodamaA faEala ka*aA","text_ar":"عِنْدَمَا فَعَلَ كَذَا"},{"kind":"italic_en","text":"At, on, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on the occasion of, his doing such a thing."},{"kind":"text","text":"] ―         -b4-  It admits before it the prep."},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":", (S, O, Msb, Mughnee, K,) but no other prep.; (S, O, Msb;) like as does"},{"kind":"arabic","text_bw":"laduno","text_ar":"لَدُنْ"},{"kind":"text","text":": (S, O:) as in the saying,"},{"kind":"arabic","text_bw":"jiy^otu mino Einodihi","text_ar":"جِيْتُ مِنْ عِنْدِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I came from his presence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his vicinage:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I came from him;"},{"kind":"text","text":"for in this case it may be considered as redundant]: (Msb:) and in the saying"},{"kind":"arabic","text_bw":"A=tayonaAhu raHomapF mino EinodinaA waEal~amonaAhu","text_ar":"ا=تَيْنَاهُ رَحْمَةً مِنْ عِنْدِنَا وَعَلَّمْنَاهُ"},{"kind":"arabic","text_bw":"mino ladun~aA EilomFA","text_ar":"مِنْ لَدُنَّا عِلْمًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Upon whom we had bestowed mercy from us, and whom we had taught, from us, knowledge"},{"kind":"text","text":"(in the Kur xviii. 64)]: (Mughnee:) [and in an ex. above, from the Kur xxviii. 27: and one says of a gift,"},{"kind":"arabic","text_bw":"h`*aA mino EinodiY","text_ar":"هٰذَا مِنْ عِنْدِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"This is from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of, my property;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from me;"},{"kind":"text","text":"or, by way of emphasis,"},{"kind":"italic_en","text":"from myself:"},{"kind":"text","text":"] one should not say [as the vulgar do],"},{"kind":"arabic","text_bw":"maDayotu A_ilaY Einodika","text_ar":"مَضَيْتُ اـِلَى عِنْدِكَ"},{"kind":"text","text":"; nor"},{"kind":"arabic","text_bw":"A_ilaY ladunoka","text_ar":"اـِلَى لَدُنْكَ"},{"kind":"text","text":". (S, O, K. *) ―         -b5-  Being a vague adv. n., (T, TA,) it may not be used otherwise than as an adv. n., (T, S, O, K, TA,) except in the following case: (T, O, TA:) one says of a thing without knowing it,"},{"kind":"arabic","text_bw":"h`*aA EinodiY ka*aA","text_ar":"هٰذَا عِنْدِى كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is in my judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, thus"},{"kind":"text","text":"]; and thereupon another says,"},{"kind":"arabic","text_bw":"A^awalaka EinodN","text_ar":"اَوَلَكَ عِنْدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And hast thou a judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an opinion?"},{"kind":"text","text":"]: (T, A, * O, * K, * TA:) and in like manner one says,"},{"kind":"quote","text":"wamano A^anotumu Hat~aY yakuwna lakumo EinodN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And who are ye, that ye should have a judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an opinion?"},{"kind":"text","text":"]: (TA:) and thus in the saying, (Mughnee, TA,) of one of the Muwelleds, (Mughnee,)"},{"kind":"quote","text":"laA yusaAwiY niSofa Einodi \n                      \n                     \n                        kul~a EinodK laka EinodiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Every judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, of thine, in my judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, will not equal the half of a judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an opinion"},{"kind":"text","text":"]: (Mughnee, TA:) they assert that"},{"kind":"arabic","text_bw":"Einod","text_ar":"عِنْد"},{"kind":"text","text":"in this case means the"},{"kind":"italic_en","text":"mind,"},{"kind":"text","text":"(T, O, * K, * TA,) i. e."},{"kind":"arabic","text_bw":"Alqalob","text_ar":"القَلْب"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlmaEoquwl","text_ar":"المَعْقُول"},{"kind":"text","text":", (O, K,) or"},{"kind":"arabic","text_bw":"Alqalob","text_ar":"القَلْب"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA fiyhi maEoquwlu All~ub~i","text_ar":"مَا فِيهِ مَعْقُولُ اللُّبِّ"},{"kind":"text","text":"; (T, TA;) [as in the phrase"},{"kind":"arabic","text_bw":"buro liY maA Einoda fulaAnK","text_ar":"بُرْ لِى مَا عِنْدَ فُلَانٍ"},{"kind":"text","text":", expl. in the S, in art."},{"kind":"arabic","text_bw":"bwr","text_ar":"بور"},{"kind":"text","text":", as meaning"},{"kind":"italic_en","text":"Try thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examine, and learn, for me, what is in the mind"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"nafos","text_ar":"نَفْس"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of such a one;"},{"kind":"text","text":"and in many other instances:] but this assertion is not valid: (T, TA:) [in a case of this kind] it means"},{"kind":"italic_en","text":"judgment"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"opinion"},{"kind":"text","text":"]: thus one says,"},{"kind":"arabic","text_bw":"h`*aA EinodiY A^afoDalu mino h`*aA","text_ar":"هٰذَا عِنْدِى اَفْضَلُ مِنْ هٰذَا"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"This is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in my judgment"},{"kind":"text","text":"["},{"kind":"italic_en","text":"more excellent than this"},{"kind":"text","text":"]: (Msb:) and"},{"kind":"arabic","text_bw":"A^anota EinodiY *aAhibN","text_ar":"اَنْتَ عِنْدِى ذَاهِبٌ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"Thou art"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in my opinion"},{"kind":"text","text":"["},{"kind":"italic_en","text":"going away"},{"kind":"text","text":"]: (Fr, Th, TA:) and"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"arabic","text_bw":"Alqawolu EinodiY SawaAbN","text_ar":"القَوْلُ عِنْدِى صَوَابٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This saying is in my judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"correct"},{"kind":"text","text":"]: (Mughnee:) [and in like manner,"},{"kind":"arabic","text_bw":"Einoda A@ll~`hi","text_ar":"عِنْدَ ا@للّٰهِ"},{"kind":"text","text":"is generally best rendered"},{"kind":"italic_en","text":"In the estimation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sight, of God."},{"kind":"text","text":"] ―         -b6-  [Sometimes it denotes comparison: see an ex. voce"},{"kind":"arabic","text_bw":"taEaAZama","text_ar":"تَعَاظَمَ"},{"kind":"text","text":".] ―         -b7-  It is also sometimes used to denote incitement, (S, O, K,) being in this case prefixed [to"},{"kind":"arabic","text_bw":"ka","text_ar":"كَ"},{"kind":"text","text":"or the like]; not alone: (MF:) yon say,"},{"kind":"arabic","text_bw":"Einodaka zayodFA","text_ar":"عِنْدَكَ زَيْدًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Take thou Zeyd."},{"kind":"text","text":"(S, O, K.) ―         -b8-  And in cautioning a person respecting a thing before him, one says,"},{"kind":"arabic","text_bw":"Einodaka","text_ar":"عِنْدَكَ"},{"kind":"text","text":", [meaning"},{"kind":"italic_en","text":"Keep thou where thou art;"},{"kind":"text","text":"and it is still used in this sense;] in which case it is an intrans. verbal noun. (Sb, L, TA.)"}],"source_refs":["O","K","S","Msb","TA","T","Fr","Th","MF"]},{"entry_id":"n30729","headword_ar":"عَنَدٌ","root":"End","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"[of a thing]; syn."},{"kind":"arabic","text_bw":"jaAnibN","text_ar":"جَانِبٌ"},{"kind":"text","text":". (S, A, O, L, K. [See also"},{"kind":"arabic","text_bw":"EinodN","text_ar":"عِنْدٌ"},{"kind":"text","text":", first sentence.]) One says,"},{"kind":"arabic","text_bw":"yamo$iY wasaTFA laA EanadFA","text_ar":"يَمْشِى وَسَطًا لَا عَنَدًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He walks in the middle, not on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at, one side"},{"kind":"text","text":"]. (S, O.) And"},{"kind":"arabic","text_bw":"Eanadaho","text_ar":"عَنَدَهْ"},{"kind":"text","text":", [for"},{"kind":"arabic","text_bw":"Eanadahu","text_ar":"عَنَدَهُ"},{"kind":"text","text":",] occurring at the end of a verse [of which I find several different readings, and which I have cited accord. to one of those readings voce"},{"kind":"arabic","text_bw":"HubaAraY","text_ar":"حُبَارَى"},{"kind":"text","text":"], means"},{"kind":"italic_en","text":"by its side:"},{"kind":"text","text":"(O, L:) but Th says, in explaining that verse, as describing the"},{"kind":"arabic","text_bw":"HubaAraY","text_ar":"حُبَارَى"},{"kind":"text","text":"teaching its young one to fly, that"},{"kind":"arabic","text_bw":"AlEanadu","text_ar":"العَنَدُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AlAiEotiraADu","text_ar":"الاِعْتِرَاضُ"},{"kind":"text","text":": [so that"},{"kind":"arabic","text_bw":"Eanadaho","text_ar":"عَنَدَهْ"},{"kind":"text","text":"there, accord. to him, app. means"},{"kind":"arabic","text_bw":"AiEotiraADFA lahu","text_ar":"اِعْتِرَاضًا لَهُ"},{"kind":"text","text":", which may be rendered"},{"kind":"italic_en","text":"presenting itself before it:"},{"kind":"text","text":"] or, accord. to As, ["},{"kind":"arabic","text_bw":"Eanadaho","text_ar":"عَنَدَهْ"},{"kind":"text","text":"there means"},{"kind":"italic_en","text":"imitating its actions in flying;"},{"kind":"text","text":"for he says that]"},{"kind":"arabic","text_bw":"EanadN","text_ar":"عَنَدٌ"},{"kind":"text","text":"is a subst. from"},{"kind":"arabic","text_bw":"EaAnada AlHubaAraY","text_ar":"عَانَدَ الحُبَارَى"},{"kind":"arabic","text_bw":"faroxahu","text_ar":"فَرْخَهُ"},{"kind":"text","text":"[expl. above: see 3]. (L.)"}],"source_refs":["O","L"]}]}}