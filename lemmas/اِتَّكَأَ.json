tymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n42269"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AA%D9%8E%D9%91%D9%83%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to lean on, to recline, to lie at table","examples":[{"text":"عَلَى سُرُرٍ مَوْضُونَةٍ مُتَّكِئِينَ عَلَيْهَا مُتَقَابِلِينَ","english":"(They will be) on ornamented thrones, reclining on them, facing each other."}]}]},"etymology":null,"ipa":["/it.ta.ka.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42269","headword_ar":"اِتَّكَاَ","root":"wkA^","body":[{"kind":"italic_en","text":"He sat in a firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled, manner:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he sat leaning upon one of his sides:"},{"kind":"text","text":"(Msb, in art."},{"kind":"arabic","text_bw":"tkA^","text_ar":"تكا"},{"kind":"text","text":":) the vulgar know it only in the latter sense: but it signifies"},{"kind":"italic_en","text":"he leaned, rested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed, his back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his side, against,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon, a thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he leaned, rested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed, himself in any manner, upon a thing."},{"kind":"text","text":"(IAth, in Msb, art."},{"kind":"arabic","text_bw":"wkA^","text_ar":"وكا"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"Ait~akaA^a EalaY $aYo'K","text_ar":"اِتَّكَاَ عَلَى شَىْءٍ"},{"kind":"text","text":", (S,) and ↓"},{"kind":"arabic","text_bw":"twk~A^","text_ar":"توكّا","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"AwkA^","text_ar":"اوكا","orth_type":"arrow"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"takiy^a","text_ar":"تَكِيَ","orth_type":"arrow"},{"kind":"text","text":", [in which"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"is substituted for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":",] aor."},{"kind":"arabic","text_bw":"yatokaA^u","text_ar":"يَتْكَاُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tako'N","text_ar":"تَكْءٌ"},{"kind":"text","text":"; (Lth;) and ↓"},{"kind":"arabic","text_bw":"wakaA^a","text_ar":"وَكَاَ","orth_type":"arrow"},{"kind":"text","text":"; (CK;)"},{"kind":"italic_en","text":"He leaned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reclined, upon a thing; supported, propped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed, himself upon it."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"Ait~akaA^a","text_ar":"اِتَّكَاَ"},{"kind":"italic_en","text":"He reclined"},{"kind":"text","text":"upon a cushion, &c. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Ait~akaA^a","text_ar":"اِتَّكَاَ"},{"kind":"italic_en","text":"He made for him"},{"kind":"text","text":"[i. e., app., for himself,]"},{"kind":"italic_en","text":"a thing upon which to lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recline:"},{"kind":"text","text":"(CK, and a MS. copy of the K:) or"},{"kind":"italic_en","text":"he made him to be a thing upon which to lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recline."},{"kind":"text","text":"(TA.) [The latter seems to be wrong, unless the verb be read"},{"kind":"arabic","text_bw":"A^atokaA^a","text_ar":"اَتْكَاَ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"Ait~akaA^onaA Einoda fulaAnK","text_ar":"اِتَّكَاْنَا عِنْدَ فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We ate a repast with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the abode of, such a one."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Ait~akaA^ato","text_ar":"اِتَّكَاَتْ"},{"kind":"text","text":"(MF) and ↓"},{"kind":"arabic","text_bw":"tawak~aA^ato","text_ar":"تَوَكَّاَتْ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"was taken with the pains of labour, and cried out."},{"kind":"text","text":"(K.) Accord. to Lth,"},{"kind":"arabic","text_bw":"tawak~uw^u Aln~aAqapi","text_ar":"تَوَكُّوُ النَّاقَةِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"tSl~fhA End mxADhA","text_ar":"تصلّفها عند مخاضها"},{"kind":"text","text":": (TA:) [but it is evident that the right reading is"},{"kind":"arabic","text_bw":"tSl~qhA","text_ar":"تصلّقها"},{"kind":"text","text":"; and the sense agreeable with the above explanation]."}],"source_refs":["S","K","MF","TA"]}]},"classical_definitions":null}