1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22020","headword_ar":"اَشَرُّ","root":"$r","body":[{"kind":"text","text":"; and its fem.,"},{"kind":"arabic","text_bw":"$ur~aY","text_ar":"شُرَّى"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$ar~N","text_ar":"شَرٌّ"},{"kind":"text","text":", latter half, in three places. ―         -b2-"},{"kind":"arabic","text_bw":"$ur~aY","text_ar":"شُرَّى"},{"kind":"text","text":"is also applied to a woman as meaning"},{"kind":"italic_en","text":"A great imputer of vices, faults,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, to others."},{"kind":"text","text":"(AA, L.)"}],"source_refs":[]},{"entry_id":"n823","headword_ar":"اَشَرَ","root":"A$r","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(ISk, MS,) or"},{"kind":"text","text":"(Msb,) inf. n."},{"kind":"arabic","text_bw":"A^a$orN","text_ar":"اَشْرٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He divided"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sawed"},{"kind":"text","text":"] a piece of wood (ISk, Msb, K) with the"},{"kind":"arabic","text_bw":"miy^o$aAr","text_ar":"مِيْشَار"},{"kind":"text","text":"; (S, Msb, K;) as also"},{"kind":"arabic","text_bw":"wa$ara","text_ar":"وَشَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":". (Msb, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^a$arato A^asonaAnahaA","text_ar":"اَشَرَتْ اَسْنَانَهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":"[or, accord. to the Msb, it seems to be"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"A^a$orN","text_ar":"اَشْرٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"A^a$~aratohaA","text_ar":"اَشَّرَتْهَا","orth_type":"arrow"},{"kind":"text","text":"(K,) inf. n."},{"kind":"arabic","text_bw":"taA^o$iyrN","text_ar":"تَاْشِيرٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman, TA)"},{"kind":"italic_en","text":"made her teeth serrated,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and sharpened their extremities,"},{"kind":"text","text":"(S,) to render them like those of a young person: but a curse is denounced in a trad. against her who does this. (TA.) [See also art."},{"kind":"arabic","text_bw":"w$r","text_ar":"وشر"},{"kind":"text","text":"]       -A2- ,"},{"kind":"arabic","text_bw":"A^a$ira","text_ar":"اَشِرَ"},{"kind":"text","text":"aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A^a$arN","text_ar":"اَشَرٌ"},{"kind":"text","text":"(S, A, Msb,)"},{"kind":"italic_en","text":"He exulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulted greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively; and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"(S,* A,* Msb, K,* TA:) or"},{"kind":"italic_en","text":"he exulted by reason of wealth, and behaved with pride, and self-conceitedness, and boastfulness, and want of thankfulness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he behaved with the utmost exultation, &c.: or he rejoiced, and rested his mind upon things agreeable with natural desire."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"baTira","text_ar":"بَطِرَ"},{"kind":"text","text":"]"}],"source_refs":["S","Msb","K","ISk","MS","A"]},{"entry_id":"n825","headword_ar":"اَشْرٌ","root":"A$r","body":[{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^a$irN","text_ar":"اَشِرٌ"}],"source_refs":[]},{"entry_id":"n826","headword_ar":"اَشَرٌ","root":"A$r","body":[{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^a$irN","text_ar":"اَشِرٌ"}],"source_refs":[]},{"entry_id":"n827","headword_ar":"اَشُرٌ","root":"A$r","body":[{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^a$irN","text_ar":"اَشِرٌ"}],"source_refs":[]},{"entry_id":"n828","headword_ar":"اَشِرٌ","root":"A$r","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"A^a$urN","text_ar":"اَشُرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^a$orN","text_ar":"اَشْرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^a$arN","text_ar":"اَشَرٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"A^a$oraAnu","text_ar":"اَشْرَانُ","orth_type":"arrow"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"Exulting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulting greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively; and behaving insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"(S,* A, * Msb, K,* TA:) or"},{"kind":"italic_en","text":"exulting by reason of wealth, and behaving with pride, and self-conceitedness, and boastfulness, and want of thankfulness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaving with the utmost exultation, &c.:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rejoicing, and resting the mind upon things agreeable with natural desire:"},{"kind":"text","text":"(TA:) pl. [of the first]"},{"kind":"arabic","text_bw":"A^a$iruwna","text_ar":"اَشِرُونَ"},{"kind":"text","text":"and [of the second]"},{"kind":"arabic","text_bw":"A^a$uruwna","text_ar":"اَشُرُونَ"},{"kind":"text","text":"(L, K) and [of the first four]"},{"kind":"arabic","text_bw":"A^u$urN","text_ar":"اُشُرٌ"},{"kind":"text","text":"(K [accord. to the TA, but not in the copies of the K in my hands,]) and (of"},{"kind":"arabic","text_bw":"A^a$oraAnu","text_ar":"اَشْرَانُ"},{"kind":"text","text":"TA)"},{"kind":"arabic","text_bw":"A^a$oraY","text_ar":"اَشْرَى"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"A^u$aAraY","text_ar":"اُشَارَى"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"A^a$aAraY","text_ar":"اَشَارَى"},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"A^a$irN A^afirN","text_ar":"اَشِرٌ اَفِرٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^a$oraAnu","text_ar":"اَشْرَانُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^aforaAnu","text_ar":"اَفْرَانُ"},{"kind":"text","text":", using the latter word in each instance as an imitative sequent. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"baroqN A^a$irN","text_ar":"بَرْقٌ اَشِرٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Lightning flashing repeatedly to and fro."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"arabic","text_bw":"nabotN A^a$irN","text_ar":"نَبْتٌ اَشِرٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, extending beyond its proper bounds."},{"kind":"text","text":"(A.)"}],"source_refs":["S","A","Msb","K","TA","L"]},{"entry_id":"n829","headword_ar":"اُشَرٌ","root":"A$r","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]}]}}