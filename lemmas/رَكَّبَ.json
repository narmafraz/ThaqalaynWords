rl":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%83%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ride"},{"pos":"verb","gloss":"to embark"},{"pos":"verb","gloss":"to get involved in something, embark on a venture"},{"pos":"verb","gloss":"to strike on the knee"},{"pos":"verb","gloss":"to strike with the knee"},{"pos":"verb","gloss":"to commit, to perpetrate","tags":["obsolete"],"examples":[{"text":"رَكِبَ ذَنْبًا","english":"He committed a sin."},{"text":"Ibn Abbas\nإِنَّ الرَّجُل لَا يَرْكَبُ ذنْباً وَلَا يَأْتِي فَاحِشَة إِلَّا وَهُوَ جَاهِل","english":"Indeed, man doesn't commit a sin nor does he perpetrate a crime unless he is ignorant"}]},{"pos":"verb","gloss":"to assemble, compose, combine, put together, set","examples":[{"text":"فِي أَيِّ صُورَةٍ مَا شَاءَ رَكَّبَكَ","english":"In whatever form He willed has He assembled you."}]},{"pos":"verb","gloss":"to make someone ride or mount, to put on top of something","examples":[{"text":"رَكَّبَ الْخَالُ اِبْنَ أُخْتِهِ عَلَىٰ ظَهْرِهِ","english":"The uncle put his nephew on top of his back"}]},{"pos":"noun","gloss":"caravan travellers"},{"pos":"noun","gloss":"plural of رَاكِب (rākib)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to hit someone on the knee or to hit someone with the knee","tags":["rare","transitive"]},{"pos":"noun","gloss":"plural of رُكْبَة (rukba)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew רָכַב (raḵáḇ, “to ride”) and Ugaritic 𐎗𐎋𐎁 (rkb, “to ride, to mount”).\n\nSee رُكْبَة (rukba, “knee”)"},"ipa":["/ra.ka.ba/","/ru.kab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16457","headword_ar":"رَكْبٌ","root":"rkb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raAkibN","text_ar":"رَاكِبٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]},{"entry_id":"n16458","headword_ar":"رَكَبٌ","root":"rkb","body":[{"kind":"text","text":"The"},{"kind":"arabic","text_bw":"EaAnap","text_ar":"عَانَة"},{"kind":"text","text":": (ISk, Msb, K:) or the"},{"kind":"italic_en","text":"place of growth of the"},{"kind":"arabic","text_bw":"EaAnap","text_ar":"عَانَة"},{"kind":"text","text":", (S, K,) or"},{"kind":"italic_en","text":"of the hair of the"},{"kind":"arabic","text_bw":"EaAnap","text_ar":"عَانَة"},{"kind":"text","text":": (Mgh:) [i. e. it signifies the"},{"kind":"italic_en","text":"pubes;"},{"kind":"text","text":"either as meaning the"},{"kind":"italic_en","text":"hair of the mons Veneris,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"mons Veneris itself:"},{"kind":"text","text":"generally the latter; and this is often meant by the term"},{"kind":"arabic","text_bw":"EAnp","text_ar":"عانة"},{"kind":"text","text":"alone:] or the"},{"kind":"italic_en","text":"part that slopes down from the belly, and is beneath the"},{"kind":"arabic","text_bw":"vun~ap","text_ar":"ثُنَّة"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"and above the pudendum:"},{"kind":"text","text":"in all these senses said by Lh to be masc.: (TA:) or the"},{"kind":"italic_en","text":"pudendum"},{"kind":"text","text":"(Az, Msb, K)"},{"kind":"italic_en","text":"itself:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"external portion thereof:"},{"kind":"text","text":"(K:) or the"},{"kind":"arabic","text_bw":"rakabaAni","text_ar":"رَكَبَانِ"},{"kind":"text","text":"are the"},{"kind":"italic_en","text":"roots of the two thighs, upon which is the flesh of the pudendum,"},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"upon which are the two portions of flesh of the pudendum:"},{"kind":"text","text":"(TA:) the"},{"kind":"arabic","text_bw":"rkb","text_ar":"ركب"},{"kind":"text","text":"is masc.: (Msb:) it is common to the man and the woman, (S, Mgh, Msb, K, *) accord. to Fr: (S, Msb:) or peculiar to the woman, (S, Mgh, K,) accord. to Kh: (S:) ElFarezdak makes it plainly common to both, saying,"},{"kind":"quote","text":"Hiyna A@ltaqaY Alr~akabu AlmaHoluwqu biAlr~akabi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When the shaven pubes met the pubes"},{"kind":"text","text":"]: (TA: [and a similar ex. is given in the S and Msb, as cited by Fr:]) the pl. is"},{"kind":"arabic","text_bw":"A^arokaAbN","text_ar":"اَرْكَابٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"A^araAkiybu","text_ar":"اَرَاكِيبُ"},{"kind":"text","text":"; (K;) the latter being pl. of the former; but in some copies of the K"},{"kind":"arabic","text_bw":"A^araAkibu","text_ar":"اَرَاكِبُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"masaAjidu","text_ar":"مَسَاجِدُ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"Whiteness in the"},{"kind":"arabic","text_bw":"rukobap","text_ar":"رُكْبَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"knee"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["ISk","Msb","K","S","Mgh","TA","Az"]}]}}