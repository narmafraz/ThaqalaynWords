num":"p"},{"role":"present_3mp","form":"يُتَّهَمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُتَّهَمُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَّهِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُتَّهَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِتَّهَمْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِتَّهَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اُتُّهِمْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اُتُّهِمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتَّهِم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَّهِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُتَّهَم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُتَّهَم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":22,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n4152",""],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AA%D9%8E%D9%91%D9%87%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to charge, to accuse; to impeach","tags":["transitive"]}]},"etymology":null,"ipa":["/it.ta.ha.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4152","headword_ar":"اتهم","root":"thm","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"came,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"to Tihámeh:"},{"kind":"text","text":"(S, K:) Er-Riyáshee says, I have heard the Arabs of the desert say thus of him who has descended from the mountain-roads of Dhát 'Irk: (TA:) or"},{"kind":"italic_en","text":"he alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, therein:"},{"kind":"text","text":"(K:) as also ↓"},{"kind":"arabic","text_bw":"taAhama","text_ar":"تَاهَمَ","orth_type":"arrow"},{"kind":"text","text":", (JK, K, TA, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"taAh~ama","text_ar":"تَاهَّمَ"},{"kind":"text","text":",]) in the latter sense,"},{"kind":"page_break","n":320},{"kind":"text","text":"(JK,) and ↓"},{"kind":"arabic","text_bw":"tth~m","text_ar":"تتهّم","orth_type":"arrow"},{"kind":"text","text":"; (K;) or these mean"},{"kind":"italic_en","text":"he came to Tihámeh."},{"kind":"text","text":"(TA.) ―         -b2-  [Accord. to Golius, on the authority of a gloss. in the KL, it signifies also,"},{"kind":"italic_en","text":"He went into a region of hot air:"},{"kind":"text","text":"and this, if correct, may be the primary meaning.]       -A2-"},{"kind":"arabic","text_bw":"Athm","text_ar":"اتهم"},{"kind":"arabic","text_bw":"Albalada","text_ar":"البَلَدَ"},{"kind":"italic_en","text":"He found the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town, to be insalubrious,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and to have a bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul, odour."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"Athm","text_ar":"اتهم"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_itohaAmN","text_ar":"اـِتْهَامٌ"},{"kind":"text","text":"; in measure like"},{"kind":"arabic","text_bw":"A^akorama","text_ar":"اَكْرَمَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ikoraAmN","text_ar":"اـِكْرَامٌ"},{"kind":"text","text":"; (Msb;) [originally"},{"kind":"arabic","text_bw":"Awhm","text_ar":"اوهم"},{"kind":"text","text":"; or] formed from"},{"kind":"arabic","text_bw":"tuhamapN","text_ar":"تُهَمَةٌ"},{"kind":"text","text":", in consequence of imagining the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"in this word to be radical; (MF in art."},{"kind":"arabic","text_bw":"whm","text_ar":"وهم"},{"kind":"text","text":";) [like as is said of"},{"kind":"arabic","text_bw":"A^atoxama","text_ar":"اَتْخَمَ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"He did a thing that made him an object of suspicion:"},{"kind":"text","text":"(JK and Msb and TA in the present art.:) or"},{"kind":"italic_en","text":"he was an object of suspicion:"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"whm","text_ar":"وهم"},{"kind":"text","text":": [in the CK and TK, erroneously,"},{"kind":"arabic","text_bw":"At~hm","text_ar":"اتّهم"},{"kind":"text","text":":]) or"},{"kind":"italic_en","text":"there was in him that which induced suspicion:"},{"kind":"text","text":"you say of a man, when you suspect him,"},{"kind":"arabic","text_bw":"A^atohamota","text_ar":"اَتْهَمْتَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_itohaAmN","text_ar":"اـِتْهَامٌ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"A^adowaA^ota","text_ar":"اَدْوَاْتَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_idowaA='N","text_ar":"اـِدْوَا=ءٌ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"whm","text_ar":"وهم"},{"kind":"text","text":".)       -A4-"},{"kind":"arabic","text_bw":"Athmhu","text_ar":"اتهمهُ"},{"kind":"italic_en","text":"He suspected him; thought evil of him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ait~ahamahu","text_ar":"اِتَّهَمَهُ","orth_type":"arrow"},{"kind":"text","text":"[which is the more common]. (Msb in this art.) You say,"},{"kind":"arabic","text_bw":"Athmhu bika*aA","text_ar":"اتهمهُ بِكَذَا"},{"kind":"text","text":", (K, and so in some copies of the S, both in art."},{"kind":"arabic","text_bw":"whm","text_ar":"وهم"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"A_itohaAmN","text_ar":"اـِتْهَامٌ"},{"kind":"text","text":"; (K in that art.;) or"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ait~ahamahu","text_ar":"اِتَّهَمَهُ","orth_type":"arrow"},{"kind":"text","text":"; (Msb and K, and so in some copies of the S, all in that art.;) and"},{"kind":"arabic","text_bw":"A^awohamahu","text_ar":"اَوْهَمَهُ"},{"kind":"text","text":"; (K in that art.;)"},{"kind":"italic_en","text":"He suspected him of such a thing; imputed it to him;"},{"kind":"text","text":"(Msb and K * and TA, all in that art.;) [and"},{"kind":"italic_en","text":"he accused him of such a thing;"},{"kind":"text","text":"] i. e., a thing attributed to him. (TA.) And ↓"},{"kind":"arabic","text_bw":"Ait~ahamotuhu","text_ar":"اِتَّهَمْتُهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fiY qawolihi","text_ar":"فِى قَوْلِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I suspected him in respect of his saying;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I doubted of the correctness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth, of his saying."},{"kind":"text","text":"(Msb in art."},{"kind":"arabic","text_bw":"whm","text_ar":"وهم"},{"kind":"text","text":".)"}],"source_refs":["S","K","TA","JK"]}]},"classical_definitions":null}