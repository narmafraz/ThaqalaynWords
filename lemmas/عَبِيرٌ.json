{"lemma":"عَبِيرٌ","slug":"عَبِيرٌ","root":"ع.ب.ر","root_slug":"ع-ب-ر","root_link":"/words/roots/ع-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["name","noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27840"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%A8%D9%90%D9%8A%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a certain mixture of perfumes compounded with saffron"},{"pos":"noun","gloss":"scent, perfume"},{"pos":"name","gloss":"a female given name, Abeer or Abir"}]},"etymology":null,"ipa":["/ʕa.biːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27840","headword_ar":"عَبِيرٌ","root":"Ebr","body":[{"kind":"italic_en","text":"A certain mixture"},{"kind":"text","text":"(As, S, O, Msb, K)"},{"kind":"italic_en","text":"of perfumes,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"compounded with saffron:"},{"kind":"text","text":"(As, S, O:) or, (K,) with the Arabs (S, O, TA) of the Time of Ignorance, (TA,) accord. to AO, it means"},{"kind":"italic_en","text":"saffron"},{"kind":"text","text":"(S, O, K, TA)"},{"kind":"italic_en","text":"alone:"},{"kind":"text","text":"but in a trad., mention is made of smearing with"},{"kind":"arabic","text_bw":"Ebyr","text_ar":"عبير"},{"kind":"text","text":"or with saffron; and this shows"},{"kind":"arabic","text_bw":"Ebyr","text_ar":"عبير"},{"kind":"text","text":"to be different from saffron: (S, O, TA:) IAth says that it is"},{"kind":"italic_en","text":"a sort of perfume, having colour, compounded of certain mixtures."},{"kind":"text","text":"(TA.) [See a verse cited voce"},{"kind":"arabic","text_bw":"*abiyHN","text_ar":"ذَبِيحٌ"},{"kind":"text","text":"; and another cited voce"},{"kind":"arabic","text_bw":"raqoraqa","text_ar":"رَقْرَقَ"},{"kind":"text","text":".]"}],"source_refs":["As","S","O","Msb","K","TA"]}]},"classical_definitions":null}