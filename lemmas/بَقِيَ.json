rpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْقَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":564,"cross_references":{"qac":{"found":true,"lemma_key":"بَقِيَ","root":"بقي","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n3044"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%82%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stay, remain, persist, survive","tags":["intransitive"],"examples":[{"text":"رَأَيْتُكَ تُوسِعُ ٱلشُّعَرَاءَ نَيْلًا / حَدِيثَهُمُ ٱلْمُوَلَّدَ وَٱلْقَدِيمَا\nفَتُعْطِي مَنْ بَقَى مَالًا جَسِيمًا / وَتُعْطِي مَنْ مَضَى شَرَفًا عَظِيمَا\nسَمِعْتُكَ مُنْشِدًا بَيْتَيْ زِيَادٍ / نَشِيدًا مِثْلَ مُنْشِدِهِ كَرِيمَا\nفَمَا أَنْكَرْتُ مَوْضِعَهُ وَلَٰكِنْ / غَبَطْتُ بِذَاكَ أَعْظُمَهُ ٱلرَّمِيمَا"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3044","headword_ar":"بَقِيَ","root":"bqY","body":[{"kind":"text","text":"aor."},{"kind":"arabic","text_bw":"yaboqaY","text_ar":"يَبْقَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baqaA='N","text_ar":"بَقَا=ءٌ"},{"kind":"text","text":"(JK, S, Msb, K) and"},{"kind":"arabic","text_bw":"baAqiyapN","text_ar":"بَاقِيَةٌ"},{"kind":"text","text":"; (Msb; [but see this latter below;]) [and accord. to the CK,"},{"kind":"arabic","text_bw":"baqFY","text_ar":"بَقًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baqoYN","text_ar":"بَقْىٌ"},{"kind":"text","text":"; but this is a mistake;"},{"kind":"arabic","text_bw":"wabaqaY w baqoyFA","text_ar":"وَبَقَى و بَقْيًا"},{"kind":"text","text":"being there erroneously put for"},{"kind":"arabic","text_bw":"baqaY baqoyFA","text_ar":"بَقَى بَقْيًا"},{"kind":"text","text":", explained by what here follows;] and"},{"kind":"arabic","text_bw":"baqaY","text_ar":"بَقَى"},{"kind":"text","text":", [by some written"},{"kind":"arabic","text_bw":"baqaA","text_ar":"بَقَا"},{"kind":"text","text":",] (JK, S, Msb, K,) aor. as above, (JK,) inf. n."},{"kind":"arabic","text_bw":"baqoYN","text_ar":"بَقْىٌ"},{"kind":"text","text":", (K,) of the dial. of Belhárith Ibn-Kaab, (TA,) or of that of Teiyi, (JK, S, TA,) who in like manner say"},{"kind":"arabic","text_bw":"baqato","text_ar":"بَقَتْ"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"baqayato","text_ar":"بَقَيَتْ"},{"kind":"text","text":", (S, TA,) and the like is done in other verbs of the same class, (S, Msb,) whether the kesreh and the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"be original, as in"},{"kind":"arabic","text_bw":"baqiYa","text_ar":"بَقِىَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nasiYa","text_ar":"نَسِىَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faniYa","text_ar":"فَنِىَ"},{"kind":"text","text":", or accidental, as in the pass. verbs"},{"kind":"arabic","text_bw":"hudiYa","text_ar":"هُدِىَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buniYa","text_ar":"بُنِىَ"},{"kind":"text","text":"; (Msb;) ["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"namely, a thing,"},{"kind":"italic_en","text":"remained, continued, lasted, endured:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, permanent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perpetual;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, lasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existed, incessantly, always, endlessly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for ever:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"faniYa","text_ar":"فَنِىَ"},{"kind":"text","text":": (K:)"},{"kind":"arabic","text_bw":"baqaA='N","text_ar":"بَقَا=ءٌ"},{"kind":"text","text":"signifies a thing's"},{"kind":"italic_en","text":"remaining, continuing, lasting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enduring, in its first state, to a period determined by the will of God, either with respect to its corporeal substance,"},{"kind":"text","text":"as in the case of a heavenly orb,"},{"kind":"italic_en","text":"or with respect to its kind only,"},{"kind":"text","text":"as in the case of the human and other animal races; and the"},{"kind":"italic_en","text":"continuing, lasting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existing, for ever, either by self,"},{"kind":"text","text":"as in the instance of God alone,"},{"kind":"italic_en","text":"or otherwise,"},{"kind":"text","text":"and thus"},{"kind":"italic_en","text":"either with respect to the corporeal substance,"},{"kind":"text","text":"as in the case of an inhabitant of Paradise,"},{"kind":"italic_en","text":"or with respect to kind only,"},{"kind":"text","text":"as in the case of the fruits of the inhabitants of Paradise. (Er-Rághib, TA.) [Hence,]"},{"kind":"arabic","text_bw":"daAru AlbaqaA='i","text_ar":"دَارُ البَقَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The abode of everlasting existence;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the world to come."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"dwr","text_ar":"دور"},{"kind":"text","text":".) The verb is said of a thing; and in like manner of a man, as in"},{"kind":"arabic","text_bw":"baqiYa zamaAnFA TawiylFA","text_ar":"بَقِىَ زَمَانًا طَوِيلًا"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He lived"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"continued in life"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a long time."},{"kind":"text","text":"(S.) [You say also,"},{"kind":"arabic","text_bw":"baqiYa EalaY","text_ar":"بَقِىَ عَلَى"},{"kind":"arabic","text_bw":"HaAlihi","text_ar":"حَالِهِ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, in his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"as he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"baqiYa EalaY Al$~id~api","text_ar":"بَقِىَ عَلَى الشِّدَّةِ"},{"kind":"italic_en","text":"He endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bore up against, difficulty, distress,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversity."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"baqiY mina Al$~aYo'i baqiy~apN","text_ar":"بَقِى مِنَ الشَّىْءِ بَقِيَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A remain, remainder, remnant, relic,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"residue, of the thing remained."},{"kind":"text","text":"] (S.) And"},{"kind":"arabic","text_bw":"baqiYa minohu ka*aA","text_ar":"بَقِىَ مِنْهُ كَذَا"},{"kind":"italic_en","text":"Such a thing remained, over and above,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"behind, thereof;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tbq~Y","text_ar":"تبقّى","orth_type":"arrow"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"baqaAhu","text_ar":"بَقَاهُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"for the last radical, (K,) first pers."},{"kind":"arabic","text_bw":"baqayotuhu","text_ar":"بَقَيْتُهُ"},{"kind":"text","text":"(Lh, S) and"},{"kind":"arabic","text_bw":"baqawotuhu","text_ar":"بَقَوْتُهُ"},{"kind":"text","text":", (Lh, TA,) aor. of the former"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"baqoYN","text_ar":"بَقْىٌ"},{"kind":"text","text":", [of the former verb,] (K,)"},{"kind":"italic_en","text":"He looked at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(Lh, S, K:) or [so in the K, but in the S “ and, ”]"},{"kind":"italic_en","text":"he watched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observed, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(S, K:) and"},{"kind":"arabic","text_bw":"baqayotuhu","text_ar":"بَقَيْتُهُ"},{"kind":"italic_en","text":"I looked, watched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited, for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"bqw","text_ar":"بقو"},{"kind":"text","text":";) as also"},{"kind":"arabic","text_bw":"baqawotuhu","text_ar":"بَقَوْتُهُ"},{"kind":"text","text":"; (K in that art.;) but the former is the more approved. (TA in that art.) [See also art."},{"kind":"arabic","text_bw":"bqw","text_ar":"بقو"},{"kind":"text","text":".] You say also,"},{"kind":"arabic","text_bw":"fulaAnN yaboqiY Al$~aYo'a bibaSarihi","text_ar":"فُلَانٌ يَبْقِى الشَّىْءَ بِبَصَرِهِ"},{"kind":"italic_en","text":"Such a one looks at the thing,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"watches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"observes, it."},{"kind":"text","text":"(JK.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"baqayonaA rasuwla A@ll~`hi","text_ar":"بَقَيْنَا رَسُولَ ا@للّٰهِ"},{"kind":"italic_en","text":"We looked, watched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"waited, for the Apostle of God."},{"kind":"text","text":"(S.)"}],"source_refs":["JK","S","Msb","K","TA","Lh"]}]}}