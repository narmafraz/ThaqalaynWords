rpus":71,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n23755"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AD%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be healthy, to be in order, to be strong, to be correct, to be faultless, to be unblemished, to be unshakable, to be permissible, to be true"},{"pos":"verb","gloss":"to recover; to become true"}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":["/sˤaħ.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23755","headword_ar":"صَحَّ","root":"SH","body":[{"kind":"text","text":", (S, A, MA, Msb, K,) aor."},{"kind":"text","text":"(MA, Msb, K) and"},{"kind":"text","text":", (MA,) inf. n."},{"kind":"arabic","text_bw":"SiH~apN","text_ar":"صِحَّةٌ"},{"kind":"text","text":"(S, * A, * MA, Msb, * MF, TA) and"},{"kind":"arabic","text_bw":"SuH~N","text_ar":"صُحٌّ"},{"kind":"text","text":", (S, * K, * MF, TA,) two forms of the inf. n. of which there are some other exs., as"},{"kind":"arabic","text_bw":"qil~apN","text_ar":"قِلَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qul~N","text_ar":"قُلٌّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"*il~apN","text_ar":"ذِلَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*ul~N","text_ar":"ذُلٌّ"},{"kind":"text","text":", (MF, TA,) and"},{"kind":"arabic","text_bw":"SaHaAHN","text_ar":"صَحَاحٌ"},{"kind":"text","text":"also, (K, * TA, * TK,) [like"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, healthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound;"},{"kind":"text","text":"(MA;) or"},{"kind":"italic_en","text":"restored to health,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soundness,"},{"kind":"arabic","text_bw":"mino Eil~atihi","text_ar":"مِنْ عِلَّتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from his disease"},{"kind":"text","text":"]; (S, A;) as also ↓"},{"kind":"arabic","text_bw":"AstSH~","text_ar":"استصحّ","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"his disease departed."},{"kind":"text","text":"(K, TK.) And (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"proved,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sound, valid,"},{"kind":"text","text":"(MA,) ["},{"kind":"italic_en","text":"substantial, real, sure, certain,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"true, right,"},{"kind":"text","text":"(MA, Msb,)"},{"kind":"italic_en","text":"correct, just"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, whole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entire,"},{"kind":"text","text":"(MA,) or ["},{"kind":"italic_en","text":"unmarred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unimpaired,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"free from every imperfection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blemish,"},{"kind":"text","text":"(L, K, TA,)"},{"kind":"italic_en","text":"and from everything that would occasion doubt"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil opinion:"},{"kind":"text","text":"(L, TA:) and (tropical:)"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, suitable to the case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(Msb.) You say,"},{"kind":"arabic","text_bw":"SaH~ato $ahaAdatuhu","text_ar":"صَحَّتْ شَهَادَتُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His testimony was sound, valid,"},{"kind":"text","text":"&c.]. (A, TA.) And"},{"kind":"arabic","text_bw":"SaH~a qawoluhu","text_ar":"صَحَّ قَوْلُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His saying was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, true"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"SaH~a Einoda","text_ar":"صَحَّ عِنْدَ"},{"kind":"arabic","text_bw":"AlqaADiY Haq~uhu","text_ar":"القَاضِى حَقُّهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just claim, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, established, substantiated, made good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, in the estimation of the judge;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"SaH~a lahu Ealayohi ka*aA","text_ar":"صَحَّ لَهُ عَلَيْهِ كَذَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a thing became established,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, as due to him from him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"SaH~a AlEaqodu","text_ar":"صَحَّ العَقْدُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The contract became established by its execution."},{"kind":"text","text":"(Msb,) And"},{"kind":"arabic","text_bw":"SaH~ati AlS~alaApu","text_ar":"صَحَّتِ الصَّلَاةُ"},{"kind":"text","text":", as used by the lawyers, (tropical:)"},{"kind":"italic_en","text":"The prayer"},{"kind":"text","text":"["},{"kind":"italic_en","text":"was suitable to the ordinance thereof, so that it"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"annulled the obligation of performing it after the appointed time."},{"kind":"text","text":"(Msb, * and Dict. of Techn. Terms of the Mussalmans pp. 815-816. [This meaning is expressed in the former by the phrase"},{"kind":"arabic","text_bw":"A^asoqaTati","text_ar":"اَسْقَطَتِ"},{"kind":"arabic","text_bw":"AlqaDaA='a","text_ar":"القَضَا=ءَ"},{"kind":"text","text":"; which is fully expl. in the latter work, with other conventional meanings of"},{"kind":"arabic","text_bw":"SiH~apN","text_ar":"صِحَّةٌ"},{"kind":"text","text":", all reducible to explanations given above.]       -A2-"},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"[if not a mistranscription for"},{"kind":"arabic","text_bw":"A^aSaH~a","text_ar":"اَصَحَّ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"SaH~aHa","text_ar":"صَحَّحَ"},{"kind":"text","text":"] signifies (assumed tropical:)"},{"kind":"italic_en","text":"He made the thing"},{"kind":"arabic","text_bw":"SaHiyH","text_ar":"صَحِيح"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"sound, valid,"},{"kind":"text","text":"&c.]. (L, TA. [In the latter app. taken from the former.])"}],"source_refs":["S","A","MA","Msb","K","MF","TA","L"]}]}}