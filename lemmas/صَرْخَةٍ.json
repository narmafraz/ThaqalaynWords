ext_ar":"صَرَخَ"},{"kind":"text","text":", (A, Mgh, Msb,) and signifies The"},{"kind":"italic_en","text":"raising the voice, calling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calling out, crying"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying out:"},{"kind":"text","text":"(S, A, L, K:) or"},{"kind":"italic_en","text":"doing so vehemently:"},{"kind":"text","text":"(L, K:) and the"},{"kind":"italic_en","text":"calling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crying, for aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour;"},{"kind":"text","text":"(A;) which last meaning is said to be tropical, but conventionally regarded as proper; (MF;) as also"},{"kind":"arabic","text_bw":"SariyxN","text_ar":"صَرِيخٌ"},{"kind":"text","text":", (S, TA,) which is likewise an inf. n. of"},{"kind":"arabic","text_bw":"Saraxa","text_ar":"صَرَخَ"},{"kind":"text","text":": (A, Mgh:) one says,"},{"kind":"arabic","text_bw":"Saraxa","text_ar":"صَرَخَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(A, MA, Mgh, L, Msb) and"},{"kind":"text","text":", (MA,) inf. n."},{"kind":"arabic","text_bw":"SuraAxN","text_ar":"صُرَاخٌ"},{"kind":"text","text":"(A, MA, Mgh, L, Msb) and"},{"kind":"arabic","text_bw":"SariyxN","text_ar":"صَرِيخٌ"},{"kind":"text","text":", (A, Mgh,)"},{"kind":"italic_en","text":"He raised his voice, called"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"called out, cried"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried out:"},{"kind":"text","text":"(A, MA, L, Msb:) or"},{"kind":"italic_en","text":"did so vehemently:"},{"kind":"text","text":"(Mgh, L, Msb: *) and"},{"kind":"italic_en","text":"he called,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cried, for aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour,"},{"kind":"text","text":"(A, Mgh, L, Msb,)"},{"kind":"italic_en","text":"saying,"},{"kind":"arabic","text_bw":"waA gawovaAho","text_ar":"وَا غَوْثَاهْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Alas, a crying for aid!"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"waA SaroxataAho","text_ar":"وَا صَرْخَتَاهْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Alas, a crying of alarm!"},{"kind":"text","text":"]; (L;) and ↓"},{"kind":"arabic","text_bw":"AstSrx","text_ar":"استصرخ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (AHát, L:) and ↓"},{"kind":"arabic","text_bw":"ASTrxwA","text_ar":"اصطرخوا","orth_type":"arrow"},{"kind":"text","text":"is syn. with ↓"},{"kind":"arabic","text_bw":"tSArxwA","text_ar":"تصارخوا","orth_type":"arrow"},{"kind":"text","text":"; (S, TA;) meaning"},{"kind":"arabic","text_bw":"SaraxuwA","text_ar":"صَرَخُوا"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"AstSrxwA","text_ar":"استصرخوا","orth_type":"arrow"},{"kind":"text","text":"; (TA;) or [rather] meaning"},{"kind":"italic_en","text":"They called"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"called out,"},{"kind":"text","text":"&c., ("},{"kind":"arabic","text_bw":"SaraxuwA","text_ar":"صَرَخُوا"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"one to another."},{"kind":"text","text":"(TK.)"},{"kind":"arabic","text_bw":"kaAnato kaSaroxapi AlHubolaY","text_ar":"كَانَتْ كَصَرْخَةِ الحُبْلَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was like the vehement crying-out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the screaming, of the pregnant woman"},{"kind":"text","text":"] is a prov., said of a thing that comes upon one suddenly, when he is not aware. (T.)"}],"source_refs":["L","K","S","A","Mgh","Msb","TA","MA"]},{"entry_id":"n24160","headword_ar":"صَرْخَةٌ","root":"Srx","body":[{"kind":"text","text":"an inf. n. of 1 [q. v.]. (S.) ―         -b2-  Hence, (TA,) The"},{"kind":"italic_en","text":"call to prayer."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["TA"]}]},"classical_definitions":null}