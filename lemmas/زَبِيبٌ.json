{"lemma":"زَبِيبٌ","slug":"زَبِيبٌ","root":"ز.ب.ب","root_slug":"ز-ب-ب","root_link":"/words/roots/ز-ب-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n17340"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%A8%D9%90%D9%8A%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"raisins","tags":["collective"]}]},"etymology":null,"ipa":["/za.biːb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17340","headword_ar":"زَبِيبٌ","root":"zb","body":[{"kind":"italic_en","text":"Dried grapes;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raisins:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"dried figs:"},{"kind":"text","text":"(K:) said by AHn to have been used in this latter sense by an Arab of the desert: (TA:) a coll. gen. n.; masc. and fem.: (Msb:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (S, Msb.)       -A2-  Also The"},{"kind":"italic_en","text":"froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam,"},{"kind":"text","text":"of water: (K, TA:) and of a camel's mouth: (L in art."},{"kind":"arabic","text_bw":"lqH","text_ar":"لقح"},{"kind":"text","text":":) and the"},{"kind":"italic_en","text":"poison in the mouth of a serpent."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"zabiybapN","text_ar":"زَبِيبَةٌ"},{"kind":"text","text":"[is the n. un., and] signifies (tropical:)"},{"kind":"italic_en","text":"A collection of froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, in the mouth of a person speaking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talking, much:"},{"kind":"text","text":"(A, * K:) [or the dual]"},{"kind":"arabic","text_bw":"zabiybataAni","text_ar":"زَبِيبَتَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"two collections of froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"of spittle,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"of dry spittle,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"in the sides of the mouth,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"where the lips meet, next the tongue."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"gaDiba favaAra lahu zabiybataAni","text_ar":"غَضِبَ فَثَارَ لَهُ زَبِيبَتَانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was angry, and there appeared two collections of froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, in the two sides of his mouth."},{"kind":"text","text":"(A, TA.)"},{"kind":"arabic","text_bw":"zabiybataAni","text_ar":"زَبِيبَتَانِ"},{"kind":"text","text":", in a serpent, signifies (assumed tropical:)"},{"kind":"italic_en","text":"Two black small spots above the eyes:"},{"kind":"text","text":"(S, K, and Mgh in art."},{"kind":"arabic","text_bw":"$jE","text_ar":"شجع"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"two small spots next the mouth"},{"kind":"text","text":"thereof: (TA:) or"},{"kind":"italic_en","text":"two collections of froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, in the two sides of the mouth"},{"kind":"text","text":"thereof (TA, and Mgh ubi suprà) when it is angry. (Mgh.) And in a dog,"},{"kind":"italic_en","text":"Two black small spots above the eyes:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"two things above the eyes, resembling the"},{"kind":"arabic","text_bw":"zanamataAni","text_ar":"زَنَمَتَانِ"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"ranamapN","text_ar":"رَنَمَةٌ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a camel:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two pieces of flesh in the head, resembling two horns:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two fangs projecting from the mouth:"},{"kind":"text","text":"and other explanations are given by the interpreters of strange words [occurring in the traditions]. (TA.)"}],"source_refs":["K","TA","Msb","S"]}]},"classical_definitions":null}