text":"["},{"kind":"italic_en","text":"Lentils;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a well-known grain;"},{"kind":"text","text":"(S, O, K;) also called"},{"kind":"arabic","text_bw":"EalasN","text_ar":"عَلَسٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bulusN","text_ar":"بُلُسٌ"},{"kind":"text","text":": (TA:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (O, K.) ―         -b2-"},{"kind":"arabic","text_bw":"Eadasu AlmaA='i","text_ar":"عَدَسُ المَا=ءِ"},{"kind":"italic_en","text":"A certain plant"},{"kind":"text","text":"[of which I have not found any description]. (See art."},{"kind":"arabic","text_bw":"sA*j","text_ar":"ساذج"},{"kind":"text","text":", last sentence.)"}],"source_refs":["TA"]}]}}