{"lemma":"تَرَحُ","slug":"تَرَحُ","root":"ت.ر.ح","root_slug":"ت-ر-ح","root_link":"/words/roots/ت-ر-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n3863","n3865","n3866","n3867"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D9%8E%D8%AD%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3863","headword_ar":"تَرِحَ","root":"trH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taraHN","text_ar":"تَرَحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He grieved; he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sorrowful, unhappy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxious;"},{"kind":"text","text":"(Msb, K;) syn."},{"kind":"arabic","text_bw":"Hazina","text_ar":"حَزِنَ"},{"kind":"text","text":"; (Msb;) ["},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"fariHa","text_ar":"فَرِحَ"},{"kind":"text","text":"; (see"},{"kind":"arabic","text_bw":"taraHN","text_ar":"تَرَحٌ"},{"kind":"text","text":", below;)] as also ↓"},{"kind":"arabic","text_bw":"ttr~H","text_ar":"تترّح","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-  [Also"},{"kind":"italic_en","text":"He perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"died: became cut off; was put an end to;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to an end:"},{"kind":"text","text":"so accord. to explanations of"},{"kind":"arabic","text_bw":"taraHN","text_ar":"تَرَحٌ"},{"kind":"text","text":"given below on the authority of IAth.]"}],"source_refs":[]},{"entry_id":"n3865","headword_ar":"تَرْحٌ","root":"trH","body":[{"kind":"italic_en","text":"Poverty; need; indigence."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n3866","headword_ar":"تَرَحٌ","root":"trH","body":[{"kind":"italic_en","text":"Grief, sorrow, unhappiness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HuzonN","text_ar":"حُزْنٌ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"ham~N","text_ar":"هَمٌّ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"gam~N","text_ar":"غَمٌّ"},{"kind":"text","text":"; (Har p. 141;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"faraHN","text_ar":"فَرَحٌ"},{"kind":"text","text":". (S, A.) [It is the inf. n. of 1; but used as a subst., it has a pl., namely,"},{"kind":"arabic","text_bw":"A^atoraAHN","text_ar":"اَتْرَاحٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A^aforaAHN","text_ar":"اَفْرَاحٌ"},{"kind":"text","text":". Hence the saying,]"},{"kind":"arabic","text_bw":"maA Ald~unoyaA A_il~aA","text_ar":"مَا الدُّنْيَا اـِلَّا"},{"kind":"arabic","text_bw":"faraHN wataraHN","text_ar":"فَرَحٌ وَتَرَحٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The present world,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"life, is nothing but a scene,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state, of joy and grief"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"italic_en","text":"A perishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dying: becoming cut off; being put an end to;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coming to an end."},{"kind":"text","text":"(IAth, TA.) ―         -b3-"},{"kind":"italic_en","text":"A descending, going down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going down a declivity;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"hubuwTN","text_ar":"هُبُوطٌ"},{"kind":"text","text":". (Ibn-Munádhir, K.) One says,"},{"kind":"arabic","text_bw":"maA zilonaA mu*u Al~ayolapi fiY taraHK","text_ar":"مَا زِلْنَا مُذُ الَّيْلَةِ فِى تَرَحٍ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"We have not ceased from the beginning of this night to be"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in a state of descending,"},{"kind":"text","text":"&c. (Ibn-Munádhir.)"}],"source_refs":["Msb","K"]},{"entry_id":"n3867","headword_ar":"تَرِحٌ","root":"trH","body":[{"kind":"italic_en","text":"Grieving; sorrowing; unhappy."},{"kind":"text","text":"(Msb.) ―         -b2-  A man (A)"},{"kind":"italic_en","text":"who possesses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"does, little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no, good,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"so that he who asks of him grieves."},{"kind":"text","text":"(A.)"}],"source_refs":["A","K"]}]}}