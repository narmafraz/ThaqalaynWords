{"lemma":"عَقَلَ","slug":"عَقَلَ","root":"ع.ق.ل","root_slug":"ع-ق-ل","root_link":"/words/roots/ع-ق-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَقَلْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَقَلْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَقَلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَقَلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَقَلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَقَلَ","in_corpus":true,"count":9,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَقَلَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَقَلا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَقَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَقَلُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَقَلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْقِل","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْقِلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْقِلِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْقِلا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْقِلانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْقِلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْقِلُونَ","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْقِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْقِل","in_corpus":true,"count":25,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْقِل","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْقِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْقِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْقِلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْقِلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْقِلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْقِلُونَ","in_corpus":true,"count":26,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْقِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْقِل","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْقِل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَقَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَقَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":84,"cross_references":{"qac":{"found":true,"lemma_key":"عَقَلَ","root":"عقل","pos":"V","occurrence_count":49},"wiktextract":{"found":true,"entry_count":14,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":19},"lanes":{"found":true,"entry_ids":["","n29981"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%82%D9%8E%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of عَقَلَ (ʕaqala, “to be reasonable”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"understanding, reason, wisdom, sound judgment, sense","examples":[{"text":"حَدِّثِ الْعَاقِلَ بِمَا لَا يَلِيقُ، فَإِنْ صَدَّقَ فَلَا عَقْلَ لَهُ.","english":"Tell the intelligent man what does not befit him and if he deems it credible he has no sense."}]},{"pos":"noun","gloss":"mind, intellect"},{"pos":"noun","gloss":"Holy Ghost"},{"pos":"verb","gloss":"to be reasonable, to make sense"},{"pos":"verb","gloss":"to make reasonable"},{"pos":"noun","gloss":"asylum"},{"pos":"noun","gloss":"fortress"},{"pos":"verb","gloss":"to make oneself inaccessible in a high mountain, to betake oneself for refuge"},{"pos":"noun","gloss":"verbal noun of عَقَلَ (ʕaqala, “to find refuge in a high mountain”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَقَلَ (ʕaqala, “to renounce revenge for wergild”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"bloodwite, wergild, blood money"},{"pos":"verb","gloss":"to renounce revenge for wergild, to relinquish retaliation of blood"},{"pos":"verb","gloss":"to hobble, to tie with the rope عِقَال (ʕiqāl)"},{"pos":"noun","gloss":"verbal noun of عَقَلَ (ʕaqala, “to hobble”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to have a twisting in the hind leg"},{"pos":"noun","gloss":"verbal noun of عَقِلَ (ʕaqila, “to have a twisting in the hind leg”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to pasture upon camelthorn (عَاقُول (ʕāqūl))"},{"pos":"noun","gloss":"verbal noun of عَقَلَ (ʕaqala, “to pasture upon camelthorn”) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ʕaql/","/ʕa.qa.la/","/ʕaq.qa.la/","/ʕa.qal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29981","headword_ar":"عَقْلٌ","root":"Eql","body":[{"kind":"text","text":"an inf. n. used as a subst. [properly so termed], (Msb,)"},{"kind":"italic_en","text":"A bloodwit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mulct for bloodshed;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"diyapN","text_ar":"دِيَةٌ"},{"kind":"text","text":"; (As, S, Mgh, O, Msb, K;) so called for a reason mentioned in the first paragraph in the explanation of the phrase"},{"kind":"arabic","text_bw":"Eaqalotu","text_ar":"عَقَلْتُ"},{"kind":"arabic","text_bw":"Alqatiyla","text_ar":"القَتِيلَ"},{"kind":"text","text":"; (As, S, Mgh, * O, Msb;) as also ↓"},{"kind":"arabic","text_bw":"maEoqulapN","text_ar":"مَعْقُلَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, O, K,) of which ↓"},{"kind":"arabic","text_bw":"miEoqalapN","text_ar":"مِعْقَلَةٌ","orth_type":"arrow"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", is a dial. var., mentioned in the R; (TA;) and of which the pl. is"},{"kind":"arabic","text_bw":"maEaAqilu","text_ar":"مَعَاقِلُ"},{"kind":"text","text":": (S, O, K:) one says, ↓"},{"kind":"arabic","text_bw":"lanaAEinoda fulaAnK DamadN mino maEoqulapK","text_ar":"لَنَاعِنْدَ فُلَانٍ ضَمَدٌ مِنْ مَعْقُلَةٍ","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"We have a remainder of a bloodwit owed to us by such a one."},{"kind":"text","text":"(S, O.) And"},{"kind":"arabic","text_bw":"AlA^uwlaY","text_ar":"الاُولَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"humo EalaY maEaAqilihimi","text_ar":"هُمْ عَلَى مَعَاقِلِهِمِ","orth_type":"arrow"},{"kind":"italic_en","text":"They are"},{"kind":"text","text":"[acting]"},{"kind":"italic_en","text":"in conformity with"},{"kind":"text","text":"[the usages relating to]"},{"kind":"italic_en","text":"the bloodwits that were in the Time of Ignorance;"},{"kind":"text","text":"(K, TA;) or meaning"},{"kind":"arabic","text_bw":"EalaY maA kaAnuwA","text_ar":"عَلَى مَا كَانُوا"},{"kind":"arabic","text_bw":"yataEaAqaluwna Ealayohi","text_ar":"يَتَعَاقَلُونَ عَلَيْهِ"},{"kind":"text","text":"[expl. above (see 6)]: (S, O:) or"},{"kind":"italic_en","text":"they are"},{"kind":"text","text":"[acting]"},{"kind":"italic_en","text":"in conformity with the conditions of their fathers;"},{"kind":"text","text":"(K, TA;) but the former is the primary meaning: (TA:) and [hence]"},{"kind":"arabic","text_bw":"EalaY qawomihi","text_ar":"عَلَى قَوْمِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaAra damu fulaAnK maEoqulapF","text_ar":"صَارَ دَمُ فُلَانٍ مَعْقُلَةً","orth_type":"arrow"},{"kind":"italic_en","text":"The blood of such a one became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the occasion of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a debt incumbent on his people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"(S, O, K, *)"},{"kind":"italic_en","text":"to be paid by them from their possessions."},{"kind":"text","text":"(S, O.)       -A2-  And as being originally the inf. n. of"},{"kind":"arabic","text_bw":"Eaqala","text_ar":"عَقَلَ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"Eaqala Al$~aYo'a","text_ar":"عَقَلَ الشَّىْءَ"},{"kind":"text","text":"meaning ["},{"kind":"arabic","text_bw":"fahimahu","text_ar":"فَهِمَهُ"},{"kind":"text","text":"or]"},{"kind":"arabic","text_bw":"tadab~arahu","text_ar":"تَدَبَّرَهُ"},{"kind":"text","text":"; (Msb;) or as originally meaning"},{"kind":"arabic","text_bw":"AlmanoEu","text_ar":"المَنْعُ"},{"kind":"text","text":", because it withholds, or restrains, its possessor from doing that which is not suitable; or from"},{"kind":"arabic","text_bw":"AlmaEoqilu","text_ar":"المَعْقِلُ"},{"kind":"text","text":"as meaning “ the place to which one has recourse for protection &c., ” because its possessor has recourse to it; (TA;)"},{"kind":"arabic","text_bw":"AlEaqolu","text_ar":"العَقْلُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"Intelligence, understanding, intellect, mind, reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AlHajoru","text_ar":"الحَجْرُ"},{"kind":"text","text":", (S, O,) and"},{"kind":"arabic","text_bw":"Aln~uhaY","text_ar":"النُّهَى"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Aln~uhoyapu","text_ar":"النُّهْيَةُ"},{"kind":"text","text":", (O,) or"},{"kind":"arabic","text_bw":"AlHijaA","text_ar":"الحِجَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"All~ub~u","text_ar":"اللُّبُّ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"AlEilomu","text_ar":"العِلْمُ"},{"kind":"text","text":", (K,) or"},{"kind":"italic_en","text":"the contr. of"},{"kind":"arabic","text_bw":"AlHumoqu","text_ar":"الحُمْقُ"},{"kind":"text","text":"; (M, TA;) or"},{"kind":"italic_en","text":"the knowledge of the qualities of things, of their goodness and their badness, and their perfectness and their defectiveness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the knowledge of the better of two good things, and of the worse of two bad things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of affairs absolutely;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a faculty whereby is the discrimination between the bad and the good;"},{"kind":"text","text":"(K, TA;) but these and other explanations of"},{"kind":"arabic","text_bw":"AlEaqol","text_ar":"العَقْل"},{"kind":"text","text":"in the K are all in treatises of intellectual things, and not mentioned by the leading lexicologists; (TA; [in which are added several more explanations of a similar kind that have no proper place in this work;]) some say that it is"},{"kind":"italic_en","text":"an innate property by which man is prepared to understand speech;"},{"kind":"text","text":"(Msb;) the truth is, that it is"},{"kind":"italic_en","text":"a spiritual light,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"shed into the heart and the brain,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"whereby the soul acquires the instinctive and speculative kinds of knowledge, and the commencement of its existence is on the occasion of the young's becoming in the fætal state,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rather of its quickening,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"after which it continues to increase until it becomes complete on the attainment of puberty,"},{"kind":"page_break","n":2115},{"kind":"text","text":"(K, TA,) or"},{"kind":"italic_en","text":"until the attainment of forty years:"},{"kind":"text","text":"(TA:) the pl. is"},{"kind":"arabic","text_bw":"EuquwlN","text_ar":"عُقُولٌ"},{"kind":"text","text":": (K:) Sb mentions"},{"kind":"arabic","text_bw":"EaqolN","text_ar":"عَقْلٌ"},{"kind":"text","text":"as an instance of an inf. n. having a pl., namely,"},{"kind":"arabic","text_bw":"EuquwlN","text_ar":"عُقُولٌ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"$ugolN","text_ar":"شُغْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"mrD","text_ar":"مرض"},{"kind":"text","text":":) IAar says, (O,)"},{"kind":"arabic","text_bw":"AlEaqolu","text_ar":"العَقْلُ"},{"kind":"text","text":"is ["},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Alqalobu","text_ar":"القَلْبُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alqalobu","text_ar":"القَلْبُ"},{"kind":"text","text":"is ["},{"kind":"italic_en","text":"syn. with"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AlEaqolu","text_ar":"العَقْلُ"},{"kind":"text","text":": (O, K:) and ↓"},{"kind":"arabic","text_bw":"AlmaEoquwlu","text_ar":"المَعْقُولُ","orth_type":"arrow"},{"kind":"text","text":"is [said to be] a subst., or name, for"},{"kind":"arabic","text_bw":"AlEaqolu","text_ar":"العَقْلُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Almajoluwdu","text_ar":"المَجْلُودُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Almayosuwru","text_ar":"المَيْسُورُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AljalaAdapu","text_ar":"الجَلَادَةُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alyusoru","text_ar":"اليُسْرُ"},{"kind":"text","text":": (Har p. 12:) it is said in a prov., ↓"},{"kind":"arabic","text_bw":"maA lahu juwlN walaA maEoquwlN","text_ar":"مَا لَهُ جُولٌ وَلَا مَعْقُولٌ","orth_type":"arrow"},{"kind":"text","text":", (Meyd, and Har ubi suprà,) meaning"},{"kind":"italic_en","text":"He has not strong purpose of mind,"},{"kind":"text","text":"[to withhold, or protect, him,] like the"},{"kind":"arabic","text_bw":"jwl","text_ar":"جول"},{"kind":"text","text":"[or casing] of the well of the collapsing whereof one is free from fear because of its firmness,"},{"kind":"italic_en","text":"nor intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eaqol","text_ar":"عَقْل"},{"kind":"text","text":",) to withhold him from doing that which is not suitable to the likes of him. (Meyd. [But see"},{"kind":"arabic","text_bw":"maEoquwlN","text_ar":"مَعْقُولٌ"},{"kind":"text","text":"below.]) [Hence,"},{"kind":"arabic","text_bw":"A^asonaAnu AlEaqoli","text_ar":"اَسْنَانُ العَقْلِ"},{"kind":"text","text":"(see 1 in art."},{"kind":"arabic","text_bw":"Hnk","text_ar":"حنك"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"A^aDoraAsu AlEaqoli","text_ar":"اَضْرَاسُ العَقْلِ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"DirosN","text_ar":"ضِرْسٌ"},{"kind":"text","text":"), both meaning"},{"kind":"italic_en","text":"The wisdom-teeth."},{"kind":"text","text":"]       -A3-  [It is said that]"},{"kind":"arabic","text_bw":"EaqolN","text_ar":"عَقْلٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A fortress;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HiSonN","text_ar":"حِصْنٌ"},{"kind":"text","text":". (K.) [But this seems to be doubtful.] See"},{"kind":"arabic","text_bw":"maEoqilN","text_ar":"مَعْقِلٌ"},{"kind":"text","text":".       -A4-  And"},{"kind":"italic_en","text":"A sort of red cloth"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"with which the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"women's camel-vehicle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hawodaj","text_ar":"هَوْدَج"},{"kind":"italic_en","text":"is covered:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a sort of what are called"},{"kind":"arabic","text_bw":"buruwd","text_ar":"بُرُود"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"burodN","text_ar":"بُرْدٌ"},{"kind":"text","text":", q. v.] or"},{"kind":"italic_en","text":"a sort of figured cloth,"},{"kind":"text","text":"(K,) or, as in the M,"},{"kind":"italic_en","text":"of red figured cloth:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"such as is figured with long forms."},{"kind":"text","text":"(Har p. 416.)"}],"source_refs":["Msb","S","Mgh","O","K","TA"]}]}}