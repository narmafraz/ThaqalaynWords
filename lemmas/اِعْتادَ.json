p":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":97,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n30933"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B9%D9%92%D8%AA%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30933","headword_ar":"اعتاد","root":"Ewd","body":[{"kind":"text","text":": see 1, near the beginning.       -A2-"},{"kind":"arabic","text_bw":"AEtAdhu","text_ar":"اعتادهُ"},{"kind":"italic_en","text":"He frequented it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to it and returned to it;"},{"kind":"text","text":"namely, a place. (T in art."},{"kind":"arabic","text_bw":"ArY","text_ar":"ارى"},{"kind":"text","text":".) ―         -b2-  And"},{"kind":"italic_en","text":"He looked at it time after time until he knew it."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"bld","text_ar":"بلد"},{"kind":"text","text":".) ―         -b3-  And, as also ↓"},{"kind":"arabic","text_bw":"tEw~dhu","text_ar":"تعوّدهُ","orth_type":"arrow"},{"kind":"text","text":", (S, O, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"EaAdahu","text_ar":"عَادَهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, O;) and so ↓"},{"kind":"arabic","text_bw":"EAwdhu","text_ar":"عاودهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muEaAwadapN","text_ar":"مُعَاوَدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiwaAdN","text_ar":"عِوَادٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AEAdhu","text_ar":"اعادهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AstEAdhu","text_ar":"استعادهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, K;)"},{"kind":"italic_en","text":"He became accustomed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated, to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he accustomed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated, himself to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it his custom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habit."},{"kind":"text","text":"(S, O, Msb, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"Alxayora","text_ar":"الخَيْرَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taEaw~aduwA","text_ar":"تَعَوَّدُوا","orth_type":"arrow"},{"kind":"arabic","text_bw":"faA_in~a Alxayora EaAdapN waAl$~ar~a lajaAjapN","text_ar":"فَاـِنَّ الخَيْرَ عَادَةٌ وَالشَّرَّ لَجَاجَةٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Accustom yourselves to good; for good becomes a habit, and evil is persevered in."},{"kind":"text","text":"(A.) And one says, ↓"},{"kind":"arabic","text_bw":"tEw~d","text_ar":"تعوّد","orth_type":"arrow"},{"kind":"arabic","text_bw":"Alkalobu AlS~ayoda","text_ar":"الكَلْبُ الصَّيْدَ"},{"kind":"italic_en","text":"The dog became accustomed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated, to the chase."},{"kind":"text","text":"(S.) ―         -b4-  See also 1, latter half, in two places."}],"source_refs":["S","O","Msb","K"]}]},"classical_definitions":null}