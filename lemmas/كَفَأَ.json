3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكْفَأا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكْفَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْفَأُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْفَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْفَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْفَأْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكْفَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكْفَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"كَفَأْنا","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَفَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n37057"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D9%81%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37057","headword_ar":"كَفَاَ","root":"kfA^","body":[{"kind":"italic_en","text":"He turned"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"over;"},{"kind":"text","text":"as a man turns over a cake of bread in his band until it becomes even. ↓"},{"kind":"arabic","text_bw":"yatakaf~aA^u","text_ar":"يَتَكَفَّاُ","orth_type":"arrow"},{"kind":"text","text":"occurs in a trad. respecting the Day of Resurrection, accord. to one relation, for"},{"kind":"arabic","text_bw":"yakofaA^u","text_ar":"يَكْفَاُ"},{"kind":"text","text":", in this sense: it is said that the earth will be like a single cake of bread, which God will turn over in his hand, as a man in a journey turns over a cake of bread. (TA.)"},{"kind":"arabic","text_bw":"kafaA^a","text_ar":"كَفَاَ"},{"kind":"text","text":", (Ks, S, K,) inf. n."},{"kind":"arabic","text_bw":"kafN'N","text_ar":"كَفٌءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kafaA='apN","text_ar":"كَفَا=ءَةٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AkfA^","text_ar":"اكفا","orth_type":"arrow"},{"kind":"text","text":", (IAar, S, K,) and ↓"},{"kind":"arabic","text_bw":"AktfA^","text_ar":"اكتفا","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) but the first word is said to be the most chaste;"},{"kind":"italic_en","text":"He inverted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned upside-down,"},{"kind":"text","text":"(S, K,) a vessel &c. (S, TA.) [You say]"},{"kind":"arabic","text_bw":"kufiy^ato jafonatuhu","text_ar":"كُفِيَتْ جَفْنَتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His bowl was turned upside-down;"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"He was slain:"},{"kind":"text","text":"a phrase similar to"},{"kind":"arabic","text_bw":"huriyqa rifoduhu","text_ar":"هُرِيقَ رِفْدُهُ"},{"kind":"text","text":". (A in art."},{"kind":"arabic","text_bw":"rfd","text_ar":"رفد"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"kafaA^a","text_ar":"كَفَاَ"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"AkfA^","text_ar":"اكفا","orth_type":"arrow"},{"kind":"text","text":", (Ks, and rejected by As, (TA,)"},{"kind":"italic_en","text":"He inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to turn aside"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incline,"},{"kind":"text","text":"(S, K,) a bow, in shooting with it, and a vessel, (Ks, S,) &c. (TA.) And"},{"kind":"arabic","text_bw":"kafaA^a","text_ar":"كَفَاَ"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"AkfA^","text_ar":"اكفا","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AnkfA^","text_ar":"انكفا","orth_type":"arrow"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined:"},{"kind":"text","text":"intrans. (K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"kafaA^ahu Eano $aYo","text_ar":"كَفَاَهُ عَنْ شَىْ"},{"kind":"text","text":", (S, * K, * TA,) inf. n."},{"kind":"arabic","text_bw":"kafo'N","text_ar":"كَفْءٌ"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He turned him away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back from a thing;"},{"kind":"text","text":"(S, K, TA;) as from a thing that he desired to do, to another thing. (S, TA.) And"},{"kind":"arabic","text_bw":"kafaA^a Eano $aYo'K","text_ar":"كَفَاَ عَنْ شَىْءٍ"},{"kind":"italic_en","text":"He turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, from a thing:"},{"kind":"text","text":"intrans. (TA.) [See also 4 and 7.]"},{"kind":"arabic","text_bw":"kafaA^a Alqawumu","text_ar":"كَفَاَ القَوُمُ"},{"kind":"italic_en","text":"The people turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back."},{"kind":"text","text":"(K.) [See also 7.] ―         -b4-"},{"kind":"arabic","text_bw":"kafaA^a","text_ar":"كَفَاَ"},{"kind":"italic_en","text":"He drove away"},{"kind":"text","text":"a man, (K,) or camels. (L.) ―         -b5-"},{"kind":"arabic","text_bw":"kafaA^a AlA_ibila","text_ar":"كَفَاَ الاـِبِلَ"},{"kind":"italic_en","text":"He made an assault upon the camels, and took them away."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"kafaA^a","text_ar":"كَفَاَ"},{"kind":"italic_en","text":"He followed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pursued,"},{"kind":"text","text":"another. (K.) ―         -b7-"},{"kind":"arabic","text_bw":"kafaA^a Alganamu fiY Al$~iEobi","text_ar":"كَفَاَ الغَنَمُ فِى الشِّعْبِ"},{"kind":"italic_en","text":"The sheep entered the ravine."},{"kind":"text","text":"(K.) ―         -b8-"},{"kind":"arabic","text_bw":"kafaA^a lawonuhu","text_ar":"كَفَاَ لَوْنُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lwnh","text_ar":"لونه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AkfA^","text_ar":"اكفا","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lwnh","text_ar":"لونه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tkf~A^","text_ar":"تكفّا","orth_type":"arrow"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"lwzh","text_ar":"لوزه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnkfA^","text_ar":"انكفا","orth_type":"arrow"},{"kind":"text","text":", (K,) (as also"},{"kind":"arabic","text_bw":"Ankft lwnh","text_ar":"انكفت لونه"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"His,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, colour changed."},{"kind":"text","text":"(K.)"}],"source_refs":["Ks","S","K","IAar","TA"]}]}}