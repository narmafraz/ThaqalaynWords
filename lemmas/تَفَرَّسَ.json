ّسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَفَرَّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَفَرَّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَفَرَّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَفَرَّس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَفَرَّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَفَرَّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَفَرَّسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَفَرَّسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَفَرَّسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَفَرَّسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَفَرَّسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَتَفَرَّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَفَرَّس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"تَفَرَّسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تَفَرَّسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n33491"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%81%D9%8E%D8%B1%D9%8E%D9%91%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stare at, to gaze upon"},{"pos":"verb","gloss":"to look through, to scan, to examine thoroughly"},{"pos":"noun","gloss":"verbal noun of تَفَرَّسَ (tafarrasa) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"perceiving by mental acumen, detecting by sagacity"},{"pos":"noun","gloss":"perspicacity, shrewdness"},{"pos":"noun","gloss":"pretending to be a good horseman"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of تَفَرَّسَ (tafarrasa)."},"ipa":["/ta.far.ra.sa/","/ta.far.rus/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33491","headword_ar":"تفرّس","root":"frs","body":[{"kind":"italic_en","text":"He pretended to others that he was a horseman,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one skilled in horsemanship."},{"kind":"text","text":"(As, O, K.)       -A2-"},{"kind":"italic_en","text":"He acted deliberately,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"and considered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"examined,"},{"kind":"text","text":"a thing, or"},{"kind":"italic_en","text":"did so repeatedly, in order to know it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to obtain a clear knowledge of it."},{"kind":"text","text":"(S, * K, * TA.) ―         -b2-"},{"kind":"arabic","text_bw":"tfr~s","text_ar":"تفرّس"},{"kind":"arabic","text_bw":"fiyhi Al$~aYo'i","text_ar":"فِيهِ الشَّىْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He perceived in him the thing intuitively;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by a kind of thaumaturgic faculty, and by right opinion and conjecture:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by means of indications,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidences, and experiments, and the make and dispositions:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"firaAsapN","text_ar":"فِرَاسَةٌ"},{"kind":"text","text":", below:) or]"},{"kind":"italic_en","text":"he perceived in him the thing by forming a correct opinion from its outward signs;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tawas~amahu","text_ar":"تَوَسَّمَهُ"},{"kind":"text","text":". (M.) You say,"},{"kind":"arabic","text_bw":"tafar~asotu fiyhi xayorFA","text_ar":"تَفَرَّسْتُ فِيهِ خَيْرًا"},{"kind":"text","text":", (S, O,) or"},{"kind":"arabic","text_bw":"Alxayora","text_ar":"الخَيْرَ"},{"kind":"text","text":", (Msb,) ["},{"kind":"italic_en","text":"I perceived in him good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness, intuitively;"},{"kind":"text","text":"&c.: or]"},{"kind":"italic_en","text":"I discovered"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taEar~afotu","text_ar":"تَعَرَّفْتُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in him good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness, by right opinion."},{"kind":"text","text":"(Msb.) [↓"},{"kind":"arabic","text_bw":"farasa","text_ar":"فَرَسَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"biAln~aZari","text_ar":"بِالنَّظَرِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"binaZarihi","text_ar":"بِنَظَرِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biEayonihi","text_ar":"بِعَيْنِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"firaAsapN","text_ar":"فِرَاسَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faraAsapN","text_ar":"فَرَاسَةٌ"},{"kind":"text","text":", (respecting which, however, see 1, last quarter,) signifies the same as"},{"kind":"arabic","text_bw":"tfr~s","text_ar":"تفرّس"},{"kind":"text","text":"; i. e.,"},{"kind":"italic_en","text":"He perceived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discerned, the internal, inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, state, condition, character,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances, by examination"},{"kind":"text","text":"of outward indications, &c., and"},{"kind":"italic_en","text":"by his eye."},{"kind":"text","text":"And so"},{"kind":"arabic","text_bw":"fiY Aln~aAsi","text_ar":"فِى النَّاسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"farasa","text_ar":"فَرَسَ","orth_type":"arrow"},{"kind":"italic_en","text":"He saw into the internal, inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, states,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of men."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"firaAsapN","text_ar":"فِرَاسَةٌ"},{"kind":"text","text":", below.]"}],"source_refs":["S","O","K","TA","Msb"]}]},"classical_definitions":null}