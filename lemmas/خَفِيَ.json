{"lemma":"خَفِيَ","slug":"خَفِيَ","root":"خ.ف.#","root_slug":"خ-ف-_","root_link":"/words/roots/خ-ف-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَفِيْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَفِيْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَفِيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَفِيْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَفِيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَفِيَ","in_corpus":true,"count":15,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَفِيَت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَفِيا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَفِيَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَفُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَفِيْنَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْفَ","in_corpus":true,"count":14,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَخْفَى","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْفَِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْفَِي","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْفَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْفَُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْفَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْفَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخْفَى","in_corpus":true,"count":16,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْفَ","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخْفَى","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْفَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْفَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْفَ","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْفَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْفَى","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْفَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَفِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَفِيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":99,"cross_references":{"qac":{"found":true,"lemma_key":"خَفِيَ","root":"خفي","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n11144","n11150"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%81%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hide","tags":["transitive"]},{"pos":"verb","gloss":"to disappear, to become imperceptible"},{"pos":"verb","gloss":"to appear, come out into the open, become apparent"},{"pos":"verb","gloss":"to shine with a faint brilliance while furrowing the cloud"}]},"etymology":null,"ipa":["/xa.faː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11144","headword_ar":"خَفِىَ","root":"xfY","body":[{"kind":"text","text":", (Mgh, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaxofaY","text_ar":"يَخْفَى"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xafaA='N","text_ar":"خَفَا=ءٌ"},{"kind":"text","text":", (Mgh, Msb, K,) has two contr. significations: (Mgh, Msb:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unperceived"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperceptible,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hardly perceived"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perceptible, by any of the senses,"},{"kind":"text","text":"or only"},{"kind":"italic_en","text":"by the eye"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by the mind;"},{"kind":"text","text":"mostly]"},{"kind":"italic_en","text":"unapparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not apparent;"},{"kind":"text","text":"(K;) ["},{"kind":"italic_en","text":"latent; obscure;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hidden, concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covered;"},{"kind":"text","text":"(Mgh, Msb;) [or"},{"kind":"italic_en","text":"unconspicuous;"},{"kind":"text","text":"but also"},{"kind":"italic_en","text":"faint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dim, to the sight; suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stifled,"},{"kind":"text","text":"said of the voice; or"},{"kind":"italic_en","text":"low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, to the ear;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"obscure to the mind, abstruse, recondite, occult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covert;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"secret, private,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestine:"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"the contr.,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"it appeared; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apparent, open, manifest, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident;"},{"kind":"text","text":"(Mgh, Msb;) [as also ↓"},{"kind":"arabic","text_bw":"AstxfY","text_ar":"استخفى","orth_type":"arrow"},{"kind":"text","text":": (see"},{"kind":"arabic","text_bw":"musotaxofK","text_ar":"مُسْتَخْفٍ"},{"kind":"text","text":", below:)] or, accord. to some, the particle that connects it with its subject distinguishes one meaning from the other: (Msb:) you say,"},{"kind":"arabic","text_bw":"xafiY","text_ar":"خَفِى"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", aor. and inf. n. as above, (S, Mgh, Msb, TA,)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, or an affair, Mgh)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unperceived"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperceptible,"},{"kind":"text","text":"[&c.,"},{"kind":"italic_en","text":"by him;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"unapparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not apparent,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"obscure,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him;"},{"kind":"text","text":"] (TA;) or"},{"kind":"italic_en","text":"hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, from him:"},{"kind":"text","text":"(Mgh, Msb:) and"},{"kind":"arabic","text_bw":"xafiYa lahu","text_ar":"خَفِىَ لَهُ"},{"kind":"italic_en","text":"it appeared to him; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, perceptible, apparent, open,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him:"},{"kind":"text","text":"[but see what follows:] (Mgh, Msb:) whence the sayings of Mohammad, [app. the Hanafee Imám,] referring to spoils,"},{"kind":"arabic","text_bw":"faxafiY","text_ar":"فَخَفِى"},{"kind":"arabic","text_bw":"lahumo A^ano ya*ohabuwA bihaA wayakotumuwhaA A^ahola Al$~iroki","text_ar":"لَهُمْ اَنْ يَذْهَبُوا بِهَا وَيَكْتُمُوهَا اَهْلَ الشِّرْكِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"It appeared"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to them that they should go away with them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"take them away, and conceal them from the believers in a plurality of gods"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"xafiYa","text_ar":"خَفِىَ"},{"kind":"arabic","text_bw":"lahumo A^ano yuxorijuwhaA A_ilaY daAri AlA_isolaAmi","text_ar":"لَهُمْ اَنْ يُخْرِجُوهَا اـِلَى دَارِ الاـِسْلَامِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It appeared to them that they should take them forth to the territory of El-Islám]: but this is said only in relation to that which appears from a state of concealment or from a hidden quarter."},{"kind":"text","text":"(Mgh.) [Hence,]"},{"kind":"arabic","text_bw":"bariHa AlxafaA='u","text_ar":"بَرِحَ الخَفَا=ءُ"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became manifest:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"the state of concealment departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased;"},{"kind":"text","text":"but the former explanation is better: or, as some say, ↓"},{"kind":"arabic","text_bw":"AlxafaA='u","text_ar":"الخَفَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"here signifies"},{"kind":"italic_en","text":"the secret;"},{"kind":"text","text":"and the meaning is,"},{"kind":"italic_en","text":"the secret became apparent:"},{"kind":"text","text":"(TA:) or, lit.,"},{"kind":"italic_en","text":"the low ground became high and apparent;"},{"kind":"text","text":"meaning (assumed tropical:)"},{"kind":"italic_en","text":"what was concealed became revealed."},{"kind":"text","text":"(Har pp. 133-4. [See also art."},{"kind":"arabic","text_bw":"brH","text_ar":"برح"},{"kind":"text","text":".]) [And"},{"kind":"arabic","text_bw":"EalaY xafaA='K","text_ar":"عَلَى خَفَا=ءٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Covertly, secretly, privately, stealthily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestinely."},{"kind":"text","text":"(See also what follows.)] ―         -b2-"},{"kind":"arabic","text_bw":"xafiytu lahu","text_ar":"خَفِيتُ لَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"xufoyapN","text_ar":"خُفْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xifoyapN","text_ar":"خِفْيَةٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"xifowapN","text_ar":"خِفْوَةٌ"},{"kind":"text","text":", (K,) the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"being interchangeable, (TA,) signifies ↓"},{"kind":"arabic","text_bw":"Aixotafayotu","text_ar":"اِخْتَفَيْتُ","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I made myself unapparent to him, lurked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lay hid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in ambush, for him; cloaked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disguised, myself to him; hid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, myself from him"},{"kind":"text","text":"]: (K:) [for]"},{"kind":"arabic","text_bw":"AxtfY","text_ar":"اختفى"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he hid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, himself,"},{"kind":"text","text":"(Fr, * El-Fárábee, JK, * Msb, K,)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"italic_en","text":"from him;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AstxfY","text_ar":"استخفى","orth_type":"arrow"},{"kind":"text","text":", (Fr, * JK, * Msb, K,) and ↓"},{"kind":"arabic","text_bw":"AxfY","text_ar":"اخفى","orth_type":"arrow"},{"kind":"text","text":", (IAar, K,) and ↓"},{"kind":"arabic","text_bw":"txf~Y","text_ar":"تخفّى","orth_type":"arrow"},{"kind":"text","text":"also is syn. with"},{"kind":"arabic","text_bw":"AxtfY","text_ar":"اختفى"},{"kind":"text","text":"[in this sense]: (Z, TA:) or you say, ↓"},{"kind":"arabic","text_bw":"Aisotaxofayotu","text_ar":"اِسْتَخْفَيْتُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"minoka","text_ar":"مِنْكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I hid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, myself from thee;"},{"kind":"text","text":"but not ↓"},{"kind":"arabic","text_bw":"Aixotafayotu","text_ar":"اِخْتَفَيْتُ","orth_type":"arrow"},{"kind":"text","text":": (IKt, Th, S, Msb:) or ↓"},{"kind":"arabic","text_bw":"AxtfY","text_ar":"اختفى","orth_type":"arrow"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"xafiYa","text_ar":"خَفِىَ"},{"kind":"text","text":"is not of high authority, nor is it disallowed, (Az, Msb, TA,) but ↓"},{"kind":"arabic","text_bw":"AstxfY","text_ar":"استخفى","orth_type":"arrow"},{"kind":"text","text":"is more usual. (Az, TA.) You say,"},{"kind":"arabic","text_bw":"faEalotuhu xufoyapF","text_ar":"فَعَلْتُهُ خُفْيَةً"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xifoyapF","text_ar":"خِفْيَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I did it covertly, secretly, privately, stealthily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestinely"},{"kind":"text","text":"]. (Msb) And"},{"kind":"arabic","text_bw":"qutila xfoyapF","text_ar":"قُتِلَ خفْيَةً"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xifowapF","text_ar":"خِفْوَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was slain covertly, secretly,"},{"kind":"text","text":"&c.]. (JK.) And"},{"kind":"arabic","text_bw":"yaA^okuluhu xifowapF","text_ar":"يَاْكُلُهُ خِفْوَةً"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He eats it covertly,"},{"kind":"text","text":"&c.,] means"},{"kind":"italic_en","text":"he steals it."},{"kind":"text","text":"(K.) In the saying in the Kur [vii. 53],"},{"kind":"arabic","text_bw":"AudoEuw","text_ar":"اُدْعُو"},{"kind":"arabic","text_bw":"rab~akumo taDar~uEFA waxufoyapF","text_ar":"رَبَّكُمْ تَضَرُّعًا وَخُفْيَةً"},{"kind":"text","text":", the meaning [of the last word] is,"},{"kind":"italic_en","text":"Submissively, devoting yourselves to his service:"},{"kind":"text","text":"or, accord. to Zj,"},{"kind":"italic_en","text":"adhering to his service in your minds:"},{"kind":"text","text":"or, accord. to Th,"},{"kind":"italic_en","text":"celebrating Him in your minds:"},{"kind":"text","text":"or, accord. to Lh,"},{"kind":"italic_en","text":"in quietness, and stillness:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"secretly;"},{"kind":"text","text":"and so in the similar passage in the Kur vi. 63. (Jel, and so Bd on this latter passage.)"},{"kind":"arabic","text_bw":"xufoyapN","text_ar":"خُفْيَةٌ"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"A^axofayotu AlS~awota","text_ar":"اَخْفَيْتُ الصَّوْتَ"},{"kind":"text","text":"[explained below in this paragraph]: (JK:) the intrans. v. whereof is ↓"},{"kind":"arabic","text_bw":"AxtfY","text_ar":"اختفى","orth_type":"arrow"},{"kind":"text","text":"[signifying"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the voice)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stifled;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"xafiYa","text_ar":"خَفِىَ"},{"kind":"text","text":", which is more common]. (Lth, TA.)       -A2-"},{"kind":"arabic","text_bw":"xafaAhu","text_ar":"خَفَاهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxofiyhi","text_ar":"يَخْفِيهِ"},{"kind":"text","text":", (JK, S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xafoYN","text_ar":"خَفْىٌ"},{"kind":"text","text":"(JK, Msb, * K) and"},{"kind":"arabic","text_bw":"xufiY~N","text_ar":"خُفِىٌّ"},{"kind":"text","text":", (K,) also has two contr. significations: (S, Msb, TA:)"},{"kind":"italic_en","text":"He made it perceptible, apparent, open, manifest, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident:"},{"kind":"text","text":"(JK, S, Msb, K:) and"},{"kind":"italic_en","text":"he hid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covered, it;"},{"kind":"text","text":"(S, Msb, K; [in this latter sense, erroneously written in the CK"},{"kind":"arabic","text_bw":"xaf~Ahu","text_ar":"خَفّاهُ"},{"kind":"text","text":";]) as also ↓"},{"kind":"arabic","text_bw":"AxfAhu","text_ar":"اخفاهُ","orth_type":"arrow"},{"kind":"text","text":": (S, K:) or, accord. to some, this latter has the latter meaning; and the former verb has [only] the former meaning: but accord. to other, the reverse is the case: (Msb:) or, accord. to Aboo-' Alee El-Kálee, the former verb has the former meaning only; and ↓ the latter verb has both meanings: (IB, TA:) ↓ the latter is also explained as signifying"},{"kind":"italic_en","text":"he removed its"},{"kind":"arabic","text_bw":"xifaA='","text_ar":"خِفَا=ء"},{"kind":"text","text":", i. e. its"},{"kind":"italic_en","text":"covering:"},{"kind":"text","text":"(TA:) and the former, as meaning"},{"kind":"italic_en","text":"he made it to come forth from a state of concealment:"},{"kind":"text","text":"(JK:) and"},{"kind":"italic_en","text":"he drew it forth;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"AxtfAhu","text_ar":"اختفاهُ","orth_type":"arrow"},{"kind":"text","text":". (S, Msb, K.) One says,"},{"kind":"arabic","text_bw":"xafaY AlmaTaru AlfaA^ora","text_ar":"خَفَى المَطَرُ الفَاْرَ"},{"kind":"italic_en","text":"The rain made the rats,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mice, to come forth from their holes."},{"kind":"text","text":"(S.) It is said in the Kur [xx. 15],"},{"kind":"arabic","text_bw":"A_in~a Als~aAEapa A=tiyapN A^akaAdu","text_ar":"اـِنَّ السَّاعَةَ ا=تِيَةٌ اَكَادُ"},{"kind":"arabic","text_bw":"A^axofiyhaA","text_ar":"اَخْفِيهَا"},{"kind":"text","text":", (JK, TA,) or ↓"},{"kind":"arabic","text_bw":"A^uxofiyhaA","text_ar":"اُخْفِيهَا","orth_type":"arrow"},{"kind":"text","text":", (JK, S, TA,) accord. to different readers: (TA:) the former means ["},{"kind":"italic_en","text":"Verily the hour of the resurrection is coming:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I am almost making it to appear:"},{"kind":"text","text":"(JK, TA:) and the latter,"},{"kind":"italic_en","text":"I am almost removing that which conceals it:"},{"kind":"text","text":"(S, IJ, TA:) or"},{"kind":"italic_en","text":"I almost conceal it:"},{"kind":"text","text":"(JK, TA:) or, as Ubeí reads it,"},{"kind":"arabic","text_bw":"A^akaAdu A^uxofiyhaA mino nafoisY","text_ar":"اَكَادُ اُخْفِيهَا مِنْ نَفِْسى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I almost conceal it from Myself"},{"kind":"text","text":"]: and Fr says [that the meaning is],"},{"kind":"italic_en","text":"I almost conceal it from Myself,"},{"kind":"text","text":"and how then should I acquaint you therewith? (TA.) And it is said in a trad. respecting the flight [from Mekkeh],"},{"kind":"arabic","text_bw":"AxfY Ean~aA xabaraka","text_ar":"اخفى عَنَّا خَبَرَكَ"},{"kind":"text","text":"[written without the vowel-signs, so that it may be"},{"kind":"arabic","text_bw":"AixofiY","text_ar":"اِخْفِى"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"A^axofiY","text_ar":"اَخْفِى","orth_type":"arrow"},{"kind":"text","text":",] i. e."},{"kind":"italic_en","text":"Conceal thou thine information from such as may ask thee respecting us."},{"kind":"text","text":"(TA.) And in another trad.,"},{"kind":"arabic","text_bw":"kaAna yaxofiY Sawotahu biA^aniynK","text_ar":"كَانَ يَخْفِى صَوْتَهُ بِاَنِينٍ"},{"kind":"text","text":", thus with fet-h to the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He used to make his voice perceptible"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"audible, with moaning"},{"kind":"text","text":"]. (TA.) And you say,"},{"kind":"arabic","text_bw":"AlS~awota","text_ar":"الصَّوْتَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axofayotu","text_ar":"اَخْفَيْتُ","orth_type":"arrow"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"I suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stifled, the voice;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft"},{"kind":"text","text":"]. (Lth, JK, TA.) [And"},{"kind":"arabic","text_bw":"AlkalaAma","text_ar":"الكَلَامَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxfY","text_ar":"اخفى","orth_type":"arrow"},{"kind":"italic_en","text":"He uttered speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the speech, in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, tone; he spoke in a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, manner;"},{"kind":"text","text":"lit."},{"kind":"italic_en","text":"he made speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the speech, to be low,"},{"kind":"text","text":"&c.]       -A3-"},{"kind":"arabic","text_bw":"xafaY","text_ar":"خَفَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxofiY","text_ar":"يَخْفِى"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"xafiYa","text_ar":"خَفِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxofiY","text_ar":"يَخْفِى"},{"kind":"text","text":"; inf. n. of each"},{"kind":"arabic","text_bw":"xafoYN","text_ar":"خَفْىٌ"},{"kind":"text","text":"; said of lightning: see"},{"kind":"arabic","text_bw":"xafaA","text_ar":"خَفَا"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"xfw","text_ar":"خفو"},{"kind":"text","text":"."}],"source_refs":["Mgh","Msb","K","S","TA","IAar","Z","IKt","Th","Az","JK","IB","IJ"]},{"entry_id":"n11150","headword_ar":"خَفِىٌّ","root":"xfY","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaAfK","text_ar":"خَافٍ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) applied to a thing; (S;) i. e."},{"kind":"italic_en","text":"Unperceived"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperceptible,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hardly perceived"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perceptible, by any of the senses,"},{"kind":"text","text":"or only"},{"kind":"italic_en","text":"by the eye"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by the mind;"},{"kind":"text","text":"mostly]"},{"kind":"italic_en","text":"unapparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not apparent;"},{"kind":"text","text":"(K;) ["},{"kind":"italic_en","text":"latent; obscure; hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unconspicuous;"},{"kind":"text","text":"but also"},{"kind":"italic_en","text":"faint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dim, to the sight; suppressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stifled,"},{"kind":"text","text":"applied to the voice; or"},{"kind":"italic_en","text":"low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, to the ear;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"obscure to the mind, abstruse, recondite, occult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covert;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"secret, private,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestine:"},{"kind":"text","text":"see 1, first sentence:] pl."},{"kind":"arabic","text_bw":"xafaAyaA","text_ar":"خَفَايَا"},{"kind":"text","text":". (S.) [You say"},{"kind":"arabic","text_bw":"najomN xafiY~N","text_ar":"نَجْمٌ خَفِىٌّ"},{"kind":"italic_en","text":"A dim star"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asterism."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"makaAnN xafiY~N","text_ar":"مَكَانٌ خَفِىٌّ"},{"kind":"italic_en","text":"An obscure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a concealed, place."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"SawotN xafiY~N","text_ar":"صَوْتٌ خَفِىٌّ"},{"kind":"italic_en","text":"A low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, voice"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"AimoraA^apN xafiy~apu AlS~awoti","text_ar":"اِمْرَاَةٌ خَفِيَّةُ الصَّوْتِ"},{"kind":"italic_en","text":"A woman having a low, faint, gentle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, voice."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"xfD","text_ar":"خفض"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Aln~uwnu Alxafiy~apu","text_ar":"النُّونُ الخَفِيَّةُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Alxafiyfapu","text_ar":"الخَفِيفَةُ"},{"kind":"text","text":"[q. v.]. (K.) And some of the Arabs say, (Yaakoob, S,)"},{"kind":"arabic","text_bw":"A_i*aA Hasuna","text_ar":"اـِذَا حَسُنَ"},{"kind":"arabic","text_bw":"mina AlmaroA^api xafiy~aAhaA Hasuna saAy^iruhaA","text_ar":"مِنَ المَرْاَةِ خَفِيَّاهَا حَسُنَ سَايِرُهَا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"When"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the voice and the foot-mark of the woman"},{"kind":"text","text":"["},{"kind":"italic_en","text":"are good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing, the rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the whole, of what pertains to her is good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing"},{"kind":"text","text":"]: (Yaakoob, JK, S, K:) for when her voice is soft, or gentle, this indicates her being bashful, or shy; and when her foot-marks are near together, and firmly impressed, they indicate that she has [large] buttocks and haunches. (Yaakoob, S.) One says also,"},{"kind":"arabic","text_bw":"laqiytuhu xafiy~FA","text_ar":"لَقِيتُهُ خَفِيًّا"},{"kind":"italic_en","text":"I met him covertly, secretly, privately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clandestinely."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"ma$aY mi$oyapF","text_ar":"مَشَى مِشْيَةً"},{"kind":"arabic","text_bw":"xafiy~apF","text_ar":"خَفِيَّةً"},{"kind":"italic_en","text":"He walked with a soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stealthy, gait."},{"kind":"text","text":"] ―         -b2-  Also One"},{"kind":"italic_en","text":"who secludes himself from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"men; whose place is concealed from them."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]}}