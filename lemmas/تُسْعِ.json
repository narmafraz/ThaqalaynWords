{"lemma":"تُسْعِ","slug":"تُسْعِ","root":"تسع","root_slug":"تسع","root_link":"/words/roots/تسع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"تُسْعِ","root":"تسع","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","num","verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3930","n3931","n3932","n3933","n3934"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8F%D8%B3%D9%92%D8%B9%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"num","gloss":"masculine of تِسْعَة (tisʕa, “nine”)","tags":["form-of","masculine"]},{"pos":"noun","gloss":"one ninth"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *tišʕum."},"ipa":["/tisʕ/","/tu.suʕ/","/tusʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3930","headword_ar":"تَسْعٌ","root":"tsE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"tisoEapN","text_ar":"تِسْعَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n3931","headword_ar":"تُسْعٌ","root":"tsE","body":[{"kind":"italic_en","text":"A ninth part; one of nine parts;"},{"kind":"text","text":"(S, Msb, K,) as also ↓"},{"kind":"arabic","text_bw":"tusuEN","text_ar":"تُسُعٌ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tasiyEN","text_ar":"تَسِيعٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) agreeably with a rule which some hold to be applicable in the case of every similar fractional number; but Sh says, I have not heard"},{"kind":"arabic","text_bw":"tasiyEN","text_ar":"تَسِيعٌ"},{"kind":"text","text":"on any authority but that of AZ. (TA.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n3932","headword_ar":"تِسْعٌ","root":"tsE","body":[{"kind":"text","text":"fem. of"},{"kind":"arabic","text_bw":"tisoEapN","text_ar":"تِسْعَةٌ"},{"kind":"text","text":", q. v. ―         -b2-  Also"},{"kind":"italic_en","text":"A certain"},{"kind":"arabic","text_bw":"Zom'","text_ar":"ظْمء"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"A^aZomaA='","text_ar":"اَظْمَا=ء"},{"kind":"italic_en","text":"of camels;"},{"kind":"text","text":"(S, K, TA;) i. e.,"},{"kind":"italic_en","text":"their coming to water"},{"kind":"text","text":"["},{"kind":"italic_en","text":"on the ninth day, counting the day of the next preceding watering as the first;"},{"kind":"text","text":"or, in other words,]"},{"kind":"italic_en","text":"after an interval of nine days,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of which the first or last, or each of these, is not complete,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and eight nights."},{"kind":"text","text":"(TA.) ―         -b3-  Also The"},{"kind":"italic_en","text":"ninth young one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"vlv","text_ar":"ثلث"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n3933","headword_ar":"تُسَعٌ","root":"tsE","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"seventh and eighth and ninth nights of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lunar"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"month;"},{"kind":"text","text":"(K;) the"},{"kind":"italic_en","text":"three nights of the month which are after the"},{"kind":"arabic","text_bw":"nufal","text_ar":"نُفَل"},{"kind":"text","text":","},{"kind":"italic_en","text":"because the last night of these is the ninth;"},{"kind":"text","text":"(S;) among the nights of the month are three called"},{"kind":"arabic","text_bw":"gurarN","text_ar":"غُرَرٌ"},{"kind":"text","text":", [pl. of"},{"kind":"arabic","text_bw":"gur~apN","text_ar":"غُرَّةٌ"},{"kind":"text","text":",] and after these are three called"},{"kind":"arabic","text_bw":"nufalN","text_ar":"نُفَلٌ"},{"kind":"text","text":", and after these are three called"},{"kind":"arabic","text_bw":"tusaEN","text_ar":"تُسَعٌ"},{"kind":"text","text":"because the last of them is the ninth night: (Az, TA:) or the"},{"kind":"italic_en","text":"three nights of the commencement of the month,"},{"kind":"text","text":"as some say; but the first of these explanations is more agreeable with analogy. (TA.)"}],"source_refs":["Az","TA"]},{"entry_id":"n3934","headword_ar":"تُسُعٌ","root":"tsE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"tusoEN","text_ar":"تُسْعٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}