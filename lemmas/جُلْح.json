{"lemma":"جُلْح","slug":"جُلْح","root":"ج.ل.ح","root_slug":"ج-ل-ح","root_link":"/words/roots/ج-ل-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n6082","","n6085","n6090"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8F%D9%84%D9%92%D8%AD"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"bald, callow"}]},"etymology":{"source":"wiktextract","text":"Color or defect adjective from the root ج ل ح (j l ḥ)."},"ipa":["/ʔad͡ʒ.laħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6082","headword_ar":"جَلِحَ","root":"jlH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalaHN","text_ar":"جَلَحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, L, &c.)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bald in the two sides of his head:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"in the two sides of the fore part of his head:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"in the fore part of his head:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a little more bald than he who is termed"},{"kind":"arabic","text_bw":"A^anozaEu","text_ar":"اَنْزَعُ"},{"kind":"text","text":". (L.) [See also"},{"kind":"arabic","text_bw":"jalaHN","text_ar":"جَلَحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ajolaHu","text_ar":"اَجْلَحُ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"jaliHati AlA^aroDu","text_ar":"جَلِحَتِ الاَرْضُ"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"The herbage of the land was eaten;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":