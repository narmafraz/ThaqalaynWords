 what is termed"},{"kind":"arabic","text_bw":"nazaEN","text_ar":"نَزَعٌ"},{"kind":"text","text":". (L.)"}],"source_refs":["S","K","Msb"]},{"entry_id":"n6090","headword_ar":"جُلَّحٌ","root":"jlH","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^ajolaHu","text_ar":"اَجْلَحُ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}