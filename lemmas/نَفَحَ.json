en":"m","num":"p"},{"role":"present_2mp","form":"تَنْفَحُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْفَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْفَح","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْفَح","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْفَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْفَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْفَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْفَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْفَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَفَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَفَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْفَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْفَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40175"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%81%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to diffuse, to forspread (said of odors as of blood)","tags":["intransitive"]},{"pos":"verb","gloss":"to endow with (with double accusative or with accusative and بِ)","tags":["ditransitive"],"examples":[{"text":"ناولني عامل الخدمة ربطة قات شامي فاخرة، وعروسة سجائر. لاحظت أنّ عين النادل كانت تلاحق عروسة السجائر، أمرته أن ينتظر، أزلت غشاءها النايلوني الرقيق ونفحته علبة، فانصرف مسروراً.","english":"A service worker brought me a bundle of fine Levantine qāt, and a carton of cigarettes. I recognized that the eye of the waiter was fixed on the carton of cigarettes, I hight him to bide, removed the thin nylon covering and tipped him a packet, and he left in gaiety."}]},{"pos":"noun","gloss":"verbal noun of نَفَحَ (nafaḥa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"From the root ن ف ح (n f ḥ). Also compare نَفَخَ (nafaḵa) and فَاحَ (fāḥa)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40175","headword_ar":"نَفَحَ","root":"nfH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":"(L, K) and"},{"kind":"arabic","text_bw":"nufuwHN","text_ar":"نُفُوحٌ"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"nufaAHN","text_ar":"نُفَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafaHaAnN","text_ar":"نَفَحَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(perfume)"},{"kind":"italic_en","text":"diffused its odour."},{"kind":"text","text":"(S, L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"nafaHati","text_ar":"نَفَحَتِ"},{"kind":"arabic","text_bw":"Alr~iyHu","text_ar":"الرِّيحُ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"The wind blew:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"blew gently; began to be in a state of commotion:"},{"kind":"text","text":"(A:)"},{"kind":"arabic","text_bw":"nafaHato","text_ar":"نَفَحَتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lafaHato","text_ar":"لَفَحَتْ"},{"kind":"text","text":"are syn., except that the effect of"},{"kind":"arabic","text_bw":"Aln~afoH","text_ar":"النَّفْح"},{"kind":"text","text":"is greater than that of"},{"kind":"arabic","text_bw":"All~afoH","text_ar":"اللَّفْح"},{"kind":"text","text":": (Zj:) or, accord. to As, (S,) or IAar, (TA,)"},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":"relates to a cold, or cool, wind; and"},{"kind":"arabic","text_bw":"lafoHN","text_ar":"لَفْحٌ"},{"kind":"text","text":", to a hot wind: (S, TA.) [but see"},{"kind":"arabic","text_bw":"nafoHapN","text_ar":"نَفْحَةٌ"},{"kind":"text","text":"]. ―         -b3-"},{"kind":"arabic","text_bw":"nafaHatohu Aljnwb bibarodihaA","text_ar":"نَفَحَتْهُ الجنوب بِبَرْدِهَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The south wind blew upon it with its cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coolness."},{"kind":"text","text":"(IB.) ―         -b4-"},{"kind":"arabic","text_bw":"nafaHa AlEiroqa","text_ar":"نَفَحَ العِرْقَ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":", S,) (tropical:)"},{"kind":"italic_en","text":"The vein ejected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirted forth, blood."},{"kind":"text","text":"(S, K.) And in like manner,"},{"kind":"arabic","text_bw":"nafaHati AlT~aEonapu biAld~ami","text_ar":"نَفَحَتِ الطَّعْنَةُ بِالدَّمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The stab ejected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirted forth, blood."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"nafaHa All~abana nafoHapa","text_ar":"نَفَحَ اللَّبَنَ نَفْحَةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He churned the milk once."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"nafaHahu bAls~ayofi","text_ar":"نَفَحَهُ بالسَّيْفِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He struck him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, lightly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slightly, with the sword:"},{"kind":"text","text":"(A:)"},{"kind":"italic_en","text":"he reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hit, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"tanaAwalahu","text_ar":"تَنَاوَلَهُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"with the sword"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"from a distance,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"by a side-blow,"},{"kind":"arabic","text_bw":"$azorFA","text_ar":"شَزْرًا"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"nafaHa","text_ar":"نَفَحَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He struck, smote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat."},{"kind":"text","text":"(L.) See 3. ―         -b3-"},{"kind":"arabic","text_bw":"nafaHa","text_ar":"نَفَحَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He threw,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"nafaHa $ayoy^FA","text_ar":"نَفَحَ شَيْيًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He thrust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pushed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repelled, a thing from him."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"nafaHati","text_ar":"نَفَحَتِ"},{"kind":"arabic","text_bw":"Ald~aAb~apu","text_ar":"الدَّابَّةُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The horse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, kicked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"struck, with its hind leg:"},{"kind":"text","text":"(L:) or,"},{"kind":"italic_en","text":"with its hoof:"},{"kind":"text","text":"(Msb:) or,"},{"kind":"italic_en","text":"with the extremity of its hoof:"},{"kind":"arabic","text_bw":"Aln~afoHu","text_ar":"النَّفْحُ"},{"kind":"text","text":"is said to be with one hind leg: and"},{"kind":"arabic","text_bw":"Alr~amoHu","text_ar":"الرَّمْحُ"},{"kind":"text","text":", with both hind legs together. (L.)"},{"kind":"arabic","text_bw":"nafaHati","text_ar":"نَفَحَتِ"},{"kind":"arabic","text_bw":"Aln~aAqapu","text_ar":"النَّاقَةُ"},{"kind":"italic_en","text":"The she-camel struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kicked, with her hind leg."},{"kind":"text","text":"(S.)"},{"kind":"arabic","text_bw":"A^aboTala nafoHa Ald~aAb~api","text_ar":"اَبْطَلَ نَفْحَ الدَّابَّةِ"},{"kind":"italic_en","text":"He made the kicking of the horse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, with its hind leg, to be of no account;"},{"kind":"text","text":"not to require anything to be paid by its owner. (L.) [See 3 in art."},{"kind":"arabic","text_bw":"Eqb","text_ar":"عقب"},{"kind":"text","text":".]       -A3-"},{"kind":"arabic","text_bw":"nafaHahu","text_ar":"نَفَحَهُ"},{"kind":"arabic","text_bw":"bi$aYo'K","text_ar":"بِشَىْءٍ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"nafoHN","text_ar":"نَفْحٌ"},{"kind":"text","text":", Msb,) (tropical:)"},{"kind":"italic_en","text":"He gave him a thing."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"nafaHahu nafoHapF","text_ar":"نَفَحَهُ نَفْحَةً"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He gave him a gift;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conferred upon him a favour"},{"kind":"text","text":"]. (S.) [See an ex. voce"},{"kind":"arabic","text_bw":"Earabap","text_ar":"عَرَبَة"},{"kind":"text","text":".]"}],"source_refs":["S","L","K","Msb","A","Zj","TA"]}]}}