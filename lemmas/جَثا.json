_bw": "jvA", "text_ar": "جثا"}, {"kind": "text", "text": "[and"}, {"kind": "arabic", "text_bw": "jvY", "text_ar": "جثى"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "he kneeled; put himself in a kneeling posture;"}, {"kind": "text", "text": "which is the mode of sitting of him who is contending or disputing: (AZ, Har p. 512:) [or"}, {"kind": "italic_en", "text": "he put down his knees upon the ground and raised his buttocks;"}, {"kind": "text", "text": "i. e."}, {"kind": "italic_en", "text": "he kneeled with his body and thighs erect,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "nearly so"}, {"kind": "text", "text": ": see"}, {"kind": "arabic", "text_bw": "jaAvK", "text_ar": "جَاثٍ"}, {"kind": "text", "text": ":] and"}, {"kind": "arabic", "text_bw": "javaA lirukobatihi", "text_ar": "جَثَا لِرُكْبَتِهِ"}, {"kind": "italic_en", "text": "he fell"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "upon his knee"}, {"kind": "text", "text": "]; and"}, {"kind": "arabic", "text_bw": "javawoA lilr~ukabi", "text_ar": "جَثَوْا لِلرُّكَبِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "they fell upon the knees, and sank backwards so as to rest the body upon the keels"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "upon the left foot bent sideways beneath;"}, {"kind": "text", "text": "for]"}, {"kind": "arabic", "text_bw": "juvuw~N", "text_ar": "جُثُوٌّ"}, {"kind": "text", "text": "is the"}, {"kind": "italic_en", "text": "manner of sitting of the"}, {"kind": "arabic", "text_bw": "muta$ah~id", "text_ar": "مُتَشَهِّد"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "in prayer"}, {"kind": "text", "text": "]: (Ham p. 287:) or"}, {"kind": "arabic", "text_bw": "javaA", "text_ar": "جَثَا"}, {"kind": "text", "text": ", (K, TA,) inf. n."}, {"kind": "arabic", "text_bw": "javowN", "text_ar": "جَثْوٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "juvuwN", "text_ar": "جُثُوٌ"}, {"kind": "text", "text": ", (TA,)"}, {"kind": "italic_en", "text": "he stood upon the extremities of his toes;"}, {"kind": "text", "text": "(K;) like"}, {"kind": "arabic", "text_bw": "ja*aA", "text_ar": "جَذَا"}, {"kind": "text", "text": "; from which AO reckons it to be formed by substitution [of"}, {"kind": "arabic", "text_bw": "v", "text_ar": "ث"}, {"kind": "text", "text": "for"}, {"kind": "arabic", "text_bw": "*", "text_ar": "ذ"}, {"kind": "text", "text": "]; but IJ says that they are two dial. vars. (TA.) Aboo-Thumámeh says,"}, {"kind": "quote", "text": "A^uxaASimuhumo mar~aPF qaAy^imFA waA^ajovuw A_i*aA maA javawoA lilr~ukabo"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "I contending,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "disputing, with them one time standing, and falling upon my knees when they fell upon their knees"}, {"kind": "text", "text": "]. (Ham p. 287.)       -A2-"}, {"kind": "arabic", "text_bw": "javawotu", "text_ar": "جَثَوْتُ"}, {"kind": "text", "text": ", (Sgh, K,) inf. n."}, {"kind": "arabic", "text_bw": "javowN", "text_ar": "جَثْوٌ"}, {"kind": "text", "text": "; (TA;) and"}, {"kind": "arabic", "text_bw": "javayotu", "text_ar": "جَثَيْتُ"}, {"kind": "text", "text": ", (Sgh, K,) inf. n."}, {"kind": "arabic", "text_bw": "javoYN", "text_ar": "جَثْىٌ"}, {"kind": "text", "text": "; (TA;)"}, {"kind": "italic_en", "text": "I collected"}, {"kind": "text", "text": "camels, and sheep or goats. (Sgh, K.)"}], "source_refs": ["S", "Msb", "K", "TA", "Sgh"]}, {"entry_id": "n5084", "headword_ar": "جُثًا", "root": "jvw and jvY", "body": [{"kind": "text", "text": ", or"}, {"kind": "arabic", "text_bw": "juvFY", "text_ar": "جُثًى"}, {"kind": "text", "text": ", [pl. of"}, {"kind": "arabic", "text_bw": "juvowapN", "text_ar": "جُثْوَةٌ"}, {"kind": "text", "text": ", q. v.       -A2-  Also]"}, {"kind": "italic_en", "text": "A company,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "congregated body,"}, {"kind": "text", "text": "of men; (TA;) or so ↓"}, {"kind": "arabic", "text_bw": "javowapN", "text_ar": "جَثْوَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(Bd in xlv. 27) [or ↓"}, {"kind": "arabic", "text_bw": "juvowapN", "text_ar": "جُثْوَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "]: and"}, {"kind": "italic_en", "text": "companies,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "congregated bodies,"}, {"kind": "text", "text": "thereof. (TA.) It has the former meaning in a trad., where it is said,"}, {"kind": "arabic", "text_bw": "yaSiyruwna yawoma AlqiyaAmapi juvFA kul~u A^um~apK tatobaEu nabiy~ahaA", "text_ar": "يَصِيرُونَ يَوْمَ القِيَامَةِ جُثًا كُلُّ اُمَّةٍ تَتْبَعُ نَبِيَّهَا"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "They shall become, on the day of resurrection, a company,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "congregated body, each people following its prophet:"}, {"kind": "text", "text": "or here the pl. meaning is more reasonable]: and the latter in the trad.,"}, {"kind": "arabic", "text_bw": "fulaAnN mino juvaY jahan~ama", "text_ar": "فُلَانٌ مِنْ جُثَى جَهَنَّمَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Such a one is of the companies,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "congregated bodies, of Hell,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "Hellfire"}, {"kind": "text", "text": "], accord. to one recital: otherwise, ↓"}, {"kind": "arabic", "text_bw": "mino juviY~i", "text_ar": "مِنْ جُثِىِّ", "orth_type": "arrow"}, {"kind": "arabic", "text_bw": "jahan~ama", "text_ar": "جَهَنَّمَ"}, {"kind": "italic_en", "text": "of those that sit upon the knees therein."}, {"kind": "text", "text": "(TA.)       -A3-"}, {"kind": "arabic", "text_bw": "AljuvaA", "text_ar": "الجُثَا"}, {"kind": "text", "text": "is also said to have been"}, {"kind": "italic_en", "text": "A certain idol, to which sacrifices were performed."}, {"kind": "text", "text": "(TA.)"}], "source_refs": []}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}