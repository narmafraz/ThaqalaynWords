ac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n2170"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%A8%D9%92%D8%B1%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to restore to health"},{"pos":"verb","gloss":"to make, seek or ask for [+direct object] to be absolved, freed, exempted, exonerated, released, emancipated, discharged, acquitted or relieved from"}]},"etymology":null,"ipa":["/is.tab.ra.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2170","headword_ar":"استبرا","root":"brA^","body":[{"kind":"text","text":", (T,) or"},{"kind":"arabic","text_bw":"AstbrA^ mina Albawoli","text_ar":"استبرا مِنَ البَوْلِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He took extraordinary pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the utmost pains, in cleansing the orifice of his penis from the remains of urine, by shaking it and pulling it and the like, until he knew that nothing remained in it:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"he purified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleansed, himself from urine;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tanaz~ahu Eanohu","text_ar":"تَنَزَّهُ عَنْهُ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"AstbrA^","text_ar":"استبرا"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"AstbrA^ Al*~akara","text_ar":"استبرا الذَّكَرَ"},{"kind":"text","text":", (K, TA,) signifies"},{"kind":"italic_en","text":"he took extraordinary pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the utmost pains, in cleansing the penis from urine;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he cleansed it entirely from urine;"},{"kind":"text","text":"(M, * K, * TA;) and so"},{"kind":"arabic","text_bw":"AstbrA^ Alfaroja","text_ar":"استبرا الفَرْجَ"},{"kind":"text","text":": and in like manner,"},{"kind":"arabic","text_bw":"AstbrA^ti Alfaroja","text_ar":"استبراتِ الفَرْجَ"},{"kind":"text","text":"said of a woman: (El-Munáwee, TA:) but the lawyers make a distinction between"},{"kind":"arabic","text_bw":"AsotiboraA='N","text_ar":"اسْتِبْرَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AisotinoqaA='N","text_ar":"اِسْتِنْقَا=ءٌ"},{"kind":"text","text":"[which are made syn. in the M and K]: see the latter word. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"AstbrA^ AljaAriyapa","text_ar":"استبرا الجَارِيَةَ"},{"kind":"text","text":", (T, S, Mgh,) or"},{"kind":"arabic","text_bw":"AlmaroA^apa","text_ar":"المَرْاَةَ"},{"kind":"text","text":", (M, Msb, K,)"},{"kind":"italic_en","text":"He abstained from sexual intercourse"},{"kind":"text","text":"(T, M, K)"},{"kind":"italic_en","text":"with the girl"},{"kind":"text","text":"whom he had purchased or whom he had taken captive, (T,) or"},{"kind":"italic_en","text":"with the woman,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"until she had menstruated"},{"kind":"text","text":"(T, M, K)"},{"kind":"italic_en","text":"at his abode, once, and then become purified:"},{"kind":"text","text":"(T:) the meaning is, (T,)"},{"kind":"italic_en","text":"he sought to find her free from pregnancy."},{"kind":"text","text":"(T, Mgh, Msb.) ―         -b3-  Hence, (Mgh,)"},{"kind":"arabic","text_bw":"AstbrA^ Al$~ayo'i","text_ar":"استبرا الشَّيْءِ"},{"kind":"text","text":", (Z, Mgh, Msb,) or"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He searched, searched out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to find"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discover, the uttermost of the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair,"},{"kind":"text","text":"(Z, Mgh, Msb, TA,)"},{"kind":"italic_en","text":"in order that he might know it,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"to put an end to his doubt."},{"kind":"text","text":"(Z, Mgh, Msb, TA.) You say,"},{"kind":"arabic","text_bw":"AisotaboraA^otu maA Einodaka","text_ar":"اِسْتَبْرَاْتُ مَا عِنْدَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I searched,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to find"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discover,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I have searched,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"the uttermost of what thou hast,"},{"kind":"text","text":"of knowledge &c.]. (S, TA.) And"},{"kind":"arabic","text_bw":"AstbrA^ A^roDa ka*aA famaA wajada DaAl~atahu","text_ar":"استبرا ارْضَ كَذَا فَمَا وَجَدَ ضَالَّتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He searched the uttermost of such a land and found not his stray beast"},{"kind":"text","text":"]. (TA.) It is said in the Expos. of the Jámi' es-Sagheer that"},{"kind":"arabic","text_bw":"AisotiboraA='N","text_ar":"اِسْتِبْرَا=ءٌ"},{"kind":"text","text":"is an expression denoting The"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking leisurely and repeatedly, to obtain knowledge"},{"kind":"text","text":"of a thing,"},{"kind":"italic_en","text":"until one knows"},{"kind":"text","text":"it;"},{"kind":"italic_en","text":"considering"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with the endeavour to obtain a clear knowledge"},{"kind":"text","text":"of it;"},{"kind":"italic_en","text":"taking, in doing so, the course prescribed by prudence, precaution, or good judgment."},{"kind":"text","text":"(Mgh.)"}],"source_refs":["T","Msb","M","K","TA","S","Mgh","Z"]}]},"classical_definitions":null}