text","text":"and [pls. like]"},{"kind":"arabic","text_bw":"jawaArK","text_ar":"جَوَارٍ"},{"kind":"text","text":", which are the only words of this form, (K,) and"},{"kind":"arabic","text_bw":"rabaAEN","text_ar":"رَبَاعٌ"},{"kind":"text","text":", (Kr, K,) accus. of the former"},{"kind":"arabic","text_bw":"rabaAEiyFA","text_ar":"رَبَاعِيًا"},{"kind":"text","text":", (S, Msb, K,) and fem."},{"kind":"arabic","text_bw":"rabaAEiyapN","text_ar":"رَبَاعِيَةٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"Shedding its tooth called the"},{"kind":"arabic","text_bw":"rabaAEiyap","text_ar":"رَبَاعِيَة"},{"kind":"text","text":", q. v.; applied to the sheep or goat"},{"kind":"italic_en","text":"in the fourth year,"},{"kind":"text","text":"and to the bull and cow and the solid-hoofed animal"},{"kind":"italic_en","text":"in the fifth year,"},{"kind":"text","text":"and to the camel"},{"kind":"italic_en","text":"in the seventh year"},{"kind":"text","text":": (S, Msb, K:) [see 4:] pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^arobaAEN","text_ar":"اَرْبَاعٌ"},{"kind":"text","text":"(Az, K) and [of mult.]"},{"kind":"arabic","text_bw":"rubuEN","text_ar":"رُبُعٌ"},{"kind":"text","text":"(Az, S, Msb, K) and"},{"kind":"arabic","text_bw":"ruboEN","text_ar":"رُبْعٌ"},{"kind":"text","text":", (Th, Az, K,) but the former is the more common, (Az,) and"},{"kind":"arabic","text_bw":"rubaEN","text_ar":"رُبَعٌ"},{"kind":"text","text":"(IAar, K) and"},{"kind":"arabic","text_bw":"riboEaAnN","text_ar":"رِبْعَانٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"ribaAEN","text_ar":"رِبَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rabaAEiyaAtN","text_ar":"رَبَاعِيَاتٌ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"rakibotu biro*awonFA rabaAEiyFA","text_ar":"رَكِبْتُ بِرْذَوْنًا رَبَاعِيًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I rode a hackney shedding his"},{"kind":"arabic","text_bw":"rabaAEiyap","text_ar":"رَبَاعِيَة"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"in his fifth year"},{"kind":"text","text":"]. (S, Msb, K.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"HarobN rabaAEiyapN","text_ar":"حَرْبٌ رَبَاعِيَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Vehement and youthful war."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","Kr","Az","Th","IAar"]},{"entry_id":"n14543","headword_ar":"رُبَاعُ","root":"rbE","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Four and four: four and four together"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"four at a time and four at a time"},{"kind":"text","text":":] is a deviation from the original form, (S, K,) or"},{"kind":"arabic","text_bw":"A^arobaEapN A^arobaEapN","text_ar":"اَرْبَعَةٌ اَرْبَعَةٌ"},{"kind":"text","text":"; for which reason, [and, accord. to general opinion, because it is at the same time an epithet, (see"},{"kind":"arabic","text_bw":"vulaAvu","text_ar":"ثُلَاثُ"},{"kind":"text","text":",)] it is imperfectly decl.: (K:) but the dim. is ↓"},{"kind":"arabic","text_bw":"rubay~iEN","text_ar":"رُبَيِّعٌ","orth_type":"arrow"},{"kind":"text","text":", perfectly decl. (S voce"},{"kind":"arabic","text_bw":"vulaAvu","text_ar":"ثُلَاثُ"},{"kind":"text","text":", q. v.) [See exs. voce"},{"kind":"arabic","text_bw":"vulaAvu","text_ar":"ثُلَاثُ"},{"kind":"text","text":".] In the Kur iv. 3, El-Aamash read ↓"},{"kind":"arabic","text_bw":"warubaEa","text_ar":"وَرُبَعَ","orth_type":"arrow"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"warubaAEa","text_ar":"وَرُبَاعَ"},{"kind":"text","text":". (IJ, K.)"}],"source_refs":["S","K"]},{"entry_id":"n14552","headword_ar":"رَبَّاعٌ","root":"rbE","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"who often buys,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sells,"},{"kind":"arabic","text_bw":"ribaAE","text_ar":"رِبَاع"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"houses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"places of abode."},{"kind":"text","text":"(IAar, K.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%A8%D8%A7%D8%B9/","headword_ar":"رِباع","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=111415#75ebc9","body_html":"رِباع<br>من (ر ب ع) الدية التي يحملها قوم عن قوم."}]}}