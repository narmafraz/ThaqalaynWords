{"lemma":"رُعْبُ","slug":"رُعْبُ","root":"ر.ع.ب","root_slug":"ر-ع-ب","root_link":"/words/roots/ر-ع-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رُعْب","root":"رعب","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15841","","n15842","n15843","n15844"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D8%B9%D9%92%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be terrified","tags":["intransitive"]},{"pos":"verb","gloss":"to terrify, to horrify, to frighten","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15841","headword_ar":"رَعَبَ","root":"rEb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"ruEobN","text_ar":"رُعْبٌ"},{"kind":"text","text":"(K, TA) and"},{"kind":"arabic","text_bw":"ruEubN","text_ar":"رُعُبٌ"},{"kind":"text","text":", or the latter of these is a simple subst., (TA,) or each of them is a simple subst., (Msb, TA,) and the inf. n. is"},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"raEuba","text_ar":"رَعُبَ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"ruEiba","text_ar":"رُعِبَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":"; both mentioned by 'Iyád and Ibn-Kurkool, and the last by ISk also; (TA;) and ↓"},{"kind":"arabic","text_bw":"ArtEb","text_ar":"ارتعب","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He feared; he was afraid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frightened"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified:"},{"kind":"text","text":"(Msb, K, TA:) or"},{"kind":"italic_en","text":"his bosom and heart were filled with fear:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he feared in the utmost degree; was in a state of the utmost terror."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"raEaba","text_ar":"رَعَبَ"},{"kind":"text","text":"said of a valley, [like"},{"kind":"arabic","text_bw":"zaEaba","text_ar":"زَعَبَ"},{"kind":"text","text":",] aor."},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"It became filled with water."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"raEabati AlHamaAmapN","text_ar":"رَعَبَتِ الحَمَامَةٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"rE~bt","text_ar":"رعّبت","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taroEiybN","text_ar":"تَرْعِيبٌ"},{"kind":"text","text":"; (A, TA;) (tropical:)"},{"kind":"italic_en","text":"The pigeon raised, and poured forth loudly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemently, its cooing cry."},{"kind":"text","text":"(A, * K, TA.) You say ↓"},{"kind":"arabic","text_bw":"HamaAmN lahu taroEiybN","text_ar":"حَمَامٌ لَهُ تَرْعِيبٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Pigeons,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pigeon, having a loud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, cooing."},{"kind":"text","text":"(A.) ―         -b4-  And"},{"kind":"arabic","text_bw":"raEaba","text_ar":"رَعَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":",] (assumed tropical:)"},{"kind":"italic_en","text":"He composed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uttered, rhyming prose."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"raEabahu","text_ar":"رَعَبَهُ"},{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"arabic","text_bw":"ruEobN","text_ar":"رُعْبٌ"},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":"(A, MA) and"},{"kind":"arabic","text_bw":"rE~yhu","text_ar":"رعّيهُ"},{"kind":"text","text":", (MA,)"},{"kind":"italic_en","text":"He caused him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him, to fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be afraid; frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified, him:"},{"kind":"text","text":"(S, A, Msb, K:) or"},{"kind":"italic_en","text":"he filled his bosom and heart with fear:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he put him in the utmost fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terror:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"taroEiybN","text_ar":"تَرْعِيبٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, (Lb, K,) inf. n."},{"kind":"arabic","text_bw":"taroEaAbN","text_ar":"تَرْعَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ArEbhu","text_ar":"ارعبهُ"},{"kind":"text","text":"; (K;) and so does ↓"},{"kind":"arabic","text_bw":"raEaba","text_ar":"رَعَبَ","orth_type":"arrow"},{"kind":"text","text":", accord. to Ibn-Talhah El-Ishbeelee, and Ibn-Hishám El-Lakhmee, and Fei in the Msb; but this is disallowed by IAar and Th and J. (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":",] signifies also"},{"kind":"italic_en","text":"He threatened."},{"kind":"text","text":"(K, * TA.) ―         -b3-  Also, aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He charmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fascinated, by magical enchantment"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"by the eye"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"otherwise."},{"kind":"text","text":"(K, * TA.) ―         -b4-  Also, [like"},{"kind":"arabic","text_bw":"zaEaba","text_ar":"زَعَبَ"},{"kind":"text","text":",] (S, A, Msb, K,) aor."},{"kind":"text","text":", (K,)"},{"kind":"page_break","n":1104},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"raEobN","text_ar":"رَعْبٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He filled"},{"kind":"text","text":"(S, A, Msb, K) a watering-trough, or tank, (S, A,) or a vessel: (Msb:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a torrent)"},{"kind":"italic_en","text":"filled"},{"kind":"text","text":"a valley. (L, TA.)       -A3-"},{"kind":"arabic","text_bw":"raEabahu","text_ar":"رَعَبَهُ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) also signifies"},{"kind":"italic_en","text":"He cut it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into pieces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long pieces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slices,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"tiroEiybapN","text_ar":"تِرْعِيبَةٌ"},{"kind":"text","text":", below,)], namely, a camel's hump, or other thing; and so ↓"},{"kind":"arabic","text_bw":"rE~bhu","text_ar":"رعّبهُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"taroEiybN","text_ar":"تَرْعِيبٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"He broke its"},{"kind":"text","text":"(an arrow's)"},{"kind":"arabic","text_bw":"ruEob","text_ar":"رُعْب"},{"kind":"text","text":"[q. v.]. (K.)"}],"source_refs":["Msb","K","TA","S","A","MA","Lb"]},{"entry_id":"n15842","headword_ar":"رَعْبٌ","root":"rEb","body":[{"kind":"text","text":"an inf. n. of 1, in senses pointed out above. (M, A, Msb, TA.) ―         -b2-"},{"kind":"italic_en","text":"A threat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"threatening."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"italic_en","text":"A charm"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a fascination"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fascinating, by magical enchantment"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"by the eye"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"otherwise."},{"kind":"text","text":"(K.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"A rhyming prose of the Arabs."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n15843","headword_ar":"رُعْبٌ","root":"rEb","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"ruEubN","text_ar":"رُعُبٌ","orth_type":"arrow"},{"kind":"text","text":", (A, Msb, K,) both said to be inf. ns., (TA,) or the former is an inf. n. of"},{"kind":"arabic","text_bw":"raEaba","text_ar":"رَعَبَ"},{"kind":"text","text":"as intrans. (K, TA) or as trans., (A, MA,) and the latter is a simple subst., (TA,) or each of them is a simple subst., (Msb, TA,)"},{"kind":"italic_en","text":"Fear, fright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terror:"},{"kind":"text","text":"(S, A, Msb, K:) or"},{"kind":"italic_en","text":"fear that fills the bosom and heart;"},{"kind":"text","text":"as Er-Rághib and Z have indicated, following Aboo-'Alee and IJ: or the"},{"kind":"italic_en","text":"utmost fear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terror."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"faEala *`lika ruEobFA laA rugobFA","text_ar":"فَعَلَ ذٰلِكَ رُعْبًا لَا رُغْبًا"},{"kind":"italic_en","text":"He did that from fear, not from desire."},{"kind":"text","text":"(A.)       -A2-  Also the former, The"},{"kind":"italic_en","text":"socket of the head"},{"kind":"text","text":"of an arrow; the"},{"kind":"italic_en","text":"part into which the head enters, over which are the twists of sinew;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ruEoZN","text_ar":"رُعْظٌ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"riEabapN","text_ar":"رِعَبَةٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","A","Msb","K","TA","MA"]},{"entry_id":"n15844","headword_ar":"رُعُبٌ","root":"rEb","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]}}