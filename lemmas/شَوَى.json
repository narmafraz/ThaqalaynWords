","num":"s"},{"role":"present_1mp","form":"نَشْو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شَوَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَوَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُشْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْوَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَشْوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْوِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"شَوَى","root":"شوي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n23399","n23419","","n23416"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%88%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to grill"},{"pos":"verb","gloss":"to roast, have roasted, feed a roasted flesh-meat"},{"pos":"verb","gloss":"to wound not in a dangerous place"}]},"etymology":null,"ipa":["/ʃa.waː/","/ʃaw.waː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23399","headword_ar":"شَوِىٌّ","root":"$wh","body":[{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"$awiyhN","text_ar":"شَوِيهٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$aApN","text_ar":"شَاةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n23419","headword_ar":"شَوِىٌّ","root":"$wY","body":[{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"ma$owiY~N","text_ar":"مَشْوِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(Msb) ["},{"kind":"italic_en","text":"Roasted, broiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fried"},{"kind":"text","text":"], the latter originally"},{"kind":"arabic","text_bw":"ma$owuwYN","text_ar":"مَشْوُوىٌ"},{"kind":"text","text":". (Msb.) [In the K the former is said to be like"},{"kind":"arabic","text_bw":"$iwaA='N","text_ar":"شِوَا=ءٌ"},{"kind":"text","text":"; but it has the signification of the latter, i. e., of a pass. part. n.]       -A2-  See also"},{"kind":"arabic","text_bw":"$iyapN","text_ar":"شِيَةٌ"},{"kind":"text","text":".       -A3-  Ks says, (S,) in the phrase"},{"kind":"arabic","text_bw":"EayiY~N $ayiY~N","text_ar":"عَيِىٌّ شَيِىٌّ"},{"kind":"text","text":", and so in"},{"kind":"arabic","text_bw":"EayiY~N $awiY~N","text_ar":"عَيِىٌّ شَوِىٌّ"},{"kind":"text","text":", (S, K,) some say (S) the latter word is an imitative sequent to the former [i. e. a corroborative: see art."},{"kind":"arabic","text_bw":"EY","text_ar":"عى"},{"kind":"text","text":"]. (S, K.)"}],"source_refs":["K","Msb","S"]},{"entry_id":"n23416","headword_ar":"شَوًى","root":"$wY","body":[{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"$awaApN","text_ar":"شَوَاةٌ"},{"kind":"text","text":": [or rather the former is a coll. gen. n. of which the latter is the n. un.:] the latter signifies The"},{"kind":"italic_en","text":"skin of the head:"},{"kind":"text","text":"(S, TA:) so [accord. to some] in the Kur lxx. 16: (TA:) or the"},{"kind":"italic_en","text":"exterior of the skin of the head, in which grows the hair:"},{"kind":"text","text":"(Aboo-Safwán, TA in art."},{"kind":"arabic","text_bw":"b$r","text_ar":"بشر"},{"kind":"text","text":":) and some say, the"},{"kind":"italic_en","text":"exterior of all,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of any part, of the skin:"},{"kind":"text","text":"(TA in the present art.:) and the former signifies the"},{"kind":"italic_en","text":"arms"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"legs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feet,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"fore"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"hind legs,"},{"kind":"text","text":"(S, K,) and (K) the"},{"kind":"italic_en","text":"extremities"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"collectively,"},{"kind":"text","text":"(K,) and the"},{"kind":"italic_en","text":"head"},{"kind":"text","text":"of a human being, (S,) or the"},{"kind":"arabic","text_bw":"qiHof","text_ar":"قِحْف"},{"kind":"italic_en","text":"of the head"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"bone above the brain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a separate portion of the skull,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a distinct bone of the skull"},{"kind":"text","text":"], (K,) but of a horse the"},{"kind":"italic_en","text":"legs,"},{"kind":"text","text":"not the head, because one says"},{"kind":"arabic","text_bw":"Eabolu Al$~awaY","text_ar":"عَبْلُ الشَّوَى"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"thick in the legs"},{"kind":"text","text":"], for this cannot relate to the head of the horse, (S,) and"},{"kind":"italic_en","text":"any part that is not a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"vital"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"place"},{"kind":"text","text":"[i. e.]"},{"kind":"italic_en","text":"where a wound causes death"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"such"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for instance"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"as the legs."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"vaAlibapu Al$~awaY","text_ar":"ثَالِبَةُ الشَّوَى"},{"kind":"text","text":"means A woman"},{"kind":"italic_en","text":"having cracked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chapped, feet."},{"kind":"text","text":"(S and K in art."},{"kind":"arabic","text_bw":"vlb","text_ar":"ثلب"},{"kind":"text","text":".) ―         -b2-  It is also a subst. [app. meaning a quasi-inf. n.] from"},{"kind":"arabic","text_bw":"A^a$owaAhu","text_ar":"اَشْوَاهُ"},{"kind":"text","text":"[q. v.] as said of a shooter or caster: (TA:) [and hence] the saying (S, TA) of the Hudhalee, (S, [accord. to the TA, Khálid Ibn-Zuheyr,])"},{"kind":"quote","text":"faA_in~a mina Alqawoli Al~atiY laA $awaY lahaA\n                      \n                     \n                        A_i*aA zal~a Zahori All~isaAni A@nofilaAtuhu"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"And,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"verily of speech is that"},{"kind":"text","text":"sentence ("},{"kind":"arabic","text_bw":"kalimap","text_ar":"كَلِمَة"},{"kind":"text","text":", a word understood,)"},{"kind":"italic_en","text":"which does not hit a place where a wound will not occasion death,"},{"kind":"text","text":"[i. e. which does not miss its object,"},{"kind":"italic_en","text":"when its escaping from the upper surface of the tongue is quick,"},{"kind":"text","text":"] but which kills. (S, TA.) And"},{"kind":"arabic","text_bw":"$awFY","text_ar":"شَوًى"},{"kind":"text","text":"is used [app. in like manner, as a quasi-inf. n.,] in the case of anything that has missed an object of aim, though there be to it [really] no place where a wound would occasion death nor anything that is [properly] termed"},{"kind":"arabic","text_bw":"$awFY","text_ar":"شَوًى"},{"kind":"text","text":"[as meaning a place where a wound will not occasion death]. (TA.) And [hence] it signifies (assumed tropical:)"},{"kind":"italic_en","text":"A mistake; syn."},{"kind":"arabic","text_bw":"xaTaA^N","text_ar":"خَطَاٌ"},{"kind":"text","text":". (TA.) ―         -b3-  Also (tropical:)"},{"kind":"italic_en","text":"A thing,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"an affair,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"that is paltry, mean, despicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no account"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worth:"},{"kind":"text","text":"(S, K, * TA:) in this sense, from the same word as signifying the “ extremities ” [of an animal]. (IAth, TA.) Hence, in a trad. of Mujáhid,"},{"kind":"arabic","text_bw":"kul~u maA A^aSaAba AlS~aAy^ima $awFY","text_ar":"كُلُّ مَا اَصَابَ الصَّايِمَ شَوًى"},{"kind":"arabic","text_bw":"A_il~aA Algayobapa","text_ar":"اـِلَّا الغَيْبَةَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Everything that befalls the faster is a matter of no account, except absence of mind"},{"kind":"text","text":"]; i. e. nothing that befalls the faster annuls his fast except"},{"kind":"arabic","text_bw":"Algybp","text_ar":"الغيبة"},{"kind":"text","text":", for this does annul it. (TA.) ―         -b4-  And (assumed tropical:)  The"},{"kind":"italic_en","text":"worse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"viler, sort of cattle,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"of camels,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"small,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young, thereof."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"$uwaAyapN","text_ar":"شُوَايَةٌ"},{"kind":"text","text":".] ―         -b5-  And (assumed tropical:)"},{"kind":"italic_en","text":"A remainder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining portion."},{"kind":"text","text":"(TA.) [See, again,"},{"kind":"arabic","text_bw":"$uwaAyapN","text_ar":"شُوَايَةٌ"},{"kind":"text","text":".] ―         -b6-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A_iboqaA='N","text_ar":"اـِبْقَا=ءٌ"},{"kind":"text","text":"(assumed tropical:)  [The"},{"kind":"italic_en","text":"making,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"causing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffering, to remain;"},{"kind":"text","text":"or, perhaps,"},{"kind":"italic_en","text":"to continue in life,"},{"kind":"text","text":"and if it mean thus, it may be from the same word in a sense expl. above, for the animal that one hits in a part that is not vital is suffered to continue in life]. (TA.)"}],"source_refs":["S","TA","K","Msb"]}]},"classical_definitions":null}