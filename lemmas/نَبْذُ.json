nd of the latter,"},{"kind":"arabic","text_bw":"nuba*N","text_ar":"نُبَذٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"A^anobaA*N mina Aln~aAsi","text_ar":"اَنْبَاذٌ مِنَ النَّاسِ"},{"kind":"text","text":"(K, * TA) (tropical:)  The"},{"kind":"italic_en","text":"refuse of the people;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"mixed people of the baser sort."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["A","S","L","K"]}]}}