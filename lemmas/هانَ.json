 K) and"},{"kind":"arabic","text_bw":"mahaAnapN","text_ar":"مَهَانَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, base, vile, abject, mean, paltry, contemptible, despicable, ignominious, inglorious,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"weak;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"*al~a","text_ar":"ذَلَّ"},{"kind":"text","text":", (Msb, K,) and"},{"kind":"arabic","text_bw":"Haqura","text_ar":"حَقُرَ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"DaEufa","text_ar":"ضَعُفَ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"haAna Ealayohi","text_ar":"هَانَ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was of light estimation to him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was"},{"kind":"text","text":"["},{"kind":"italic_en","text":"easy and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"light to him."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"haAna","text_ar":"هَانَ"},{"kind":"text","text":"also,"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gentle,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"easy."},{"kind":"text","text":"(Msb.)"}],"source_refs":["Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%87%D8%A7%D9%86/","headword_ar":"هان","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61801#afaa15","body_html":"هان<br>الْهَوَانُ على وجهين:<br>أحدهما: تذلّل الإنسان في نفسه لما لا يلحق به غضاضة، فيمدح به نحو قوله: وَعِبادُ الرَّحْمنِ الَّذِينَ يَمْشُونَ عَلَى الْأَرْضِ هَوْناً<br>[الفرقان/ 63] ونحو ما روي عن النبيّ صلّى الله عليه وسلم:<br>«المؤمن هَيِّنٌ ليّن» .<br>الثاني: أن يكون من جهة متسلّط مستخفّ به فيذمّ به. وعلى الثاني قوله تعالى: الْيَوْمَ تُجْزَوْنَ عَذابَ الْهُونِ<br>[الأنعام/ 93] ، فَأَخَذَتْهُمْ صاعِقَةُ الْعَذابِ الْهُونِ [فصلت/ 17] ، وَلِلْكافِرِينَ عَذابٌ مُهِينٌ<br>[البقرة/ 90] ، وَلَهُمْ عَذابٌ مُهِينٌ [آل عمران/ 178] ، فَأُولئِكَ لَهُمْ عَذابٌ مُهِينٌ [الحج/ 57] ، وَمَنْ يُهِنِ اللَّهُ فَما لَهُ مِنْ مُكْرِمٍ<br>[الحج/ 18] ويقال: هانَ الأمْرُ على فلان:<br>سهل. قال الله تعالى: هُوَ عَلَيَّ هَيِّنٌ [مريم/ 21] ، وَهُوَ أَهْوَنُ عَلَيْهِ<br>[الروم/ 27] ، وَتَحْسَبُونَهُ هَيِّناً [النور/ 15] والْهَاوُونَ: فاعول من الهون، ولا يقال هارون، لأنه ليس في كلامهم فاعل."}]}}