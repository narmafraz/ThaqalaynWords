{"lemma":"صَرِيحاتٌ","slug":"صَرِيحاتٌ","root":"ص.ر.ح","root_slug":"ص-ر-ح","root_link":"/words/roots/ص-ر-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n24144"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%B1%D9%90%D9%8A%D8%AD%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"explicit, straightforward"},{"pos":"adj","gloss":"obvious, clear"}]},"etymology":null,"ipa":["/sˤa.riːħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24144","headword_ar":"صَرِيحٌ","root":"SrH","body":[{"kind":"text","text":"Anything"},{"kind":"italic_en","text":"pure, sheer, free from admixture, unmingled, unmixed, genuine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear;"},{"kind":"text","text":"(S, A, Msb, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"SaraHN","text_ar":"صَرَحٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) which is by some restricted by the [additional] epithet"},{"kind":"italic_en","text":"white,"},{"kind":"text","text":"(TA,) and ↓"},{"kind":"arabic","text_bw":"SuraAHN","text_ar":"صُرَاحٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"SiraAHN","text_ar":"صِرَاحٌ","orth_type":"arrow"},{"kind":"text","text":", which is [said to be] more chaste [though much less usual] than"},{"kind":"arabic","text_bw":"SuraAHN","text_ar":"صُرَاحٌ"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"SaraAHN","text_ar":"صَرَاحٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"SumaAriHN","text_ar":"صُمَارِحٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) in which last the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"is augmentative, or, as is related on the authority of AA, it is"},{"kind":"arabic","text_bw":"SumaAdiHN","text_ar":"صُمَادِحٌ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", but [J says] I do not think this to have been retained in the memory [as transmitted from the Arabs of classical times]. (S.) You say"},{"kind":"arabic","text_bw":"labanN SariyHN","text_ar":"لَبَنٌ صَرِيحٌ"},{"kind":"italic_en","text":"Milk of which the froth has gone,"},{"kind":"text","text":"(S, A, L,) or"},{"kind":"italic_en","text":"free from froth,"},{"kind":"text","text":"(T, L,)"},{"kind":"italic_en","text":"and clear:"},{"kind":"text","text":"(T, A, L:) or"},{"kind":"italic_en","text":"just drawn."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"zhr","text_ar":"زهر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"bawolN SariyHN","text_ar":"بَوْلٌ صَرِيحٌ"},{"kind":"italic_en","text":"Urine free from froth."},{"kind":"text","text":"(T, L.) And ↓"},{"kind":"arabic","text_bw":"xamorN SuraAHN","text_ar":"خَمْرٌ صُرَاحٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"SuraAHiyapN","text_ar":"صُرَاحِيَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) without teshdeed, (K,)"},{"kind":"italic_en","text":"Pure wine,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"without admixture."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"kaA^osN SuraAHN","text_ar":"كَاْسٌ صُرَاحٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A cup of wine without admixture."},{"kind":"text","text":"(S, A, Msb, K.) And"},{"kind":"arabic","text_bw":"jaA='a banuw tamiymK SariyHapF","text_ar":"جَا=ءَ بَنُو تَمِيمٍ صَرِيحَةً"},{"kind":"italic_en","text":"The sons of Temeem came unmixed with any others."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"rajulN SariyHN","text_ar":"رَجُلٌ صَرِيحٌ"},{"kind":"text","text":", (T, S, L, K, *) and"},{"kind":"arabic","text_bw":"EarabiY~N SariyHN","text_ar":"عَرَبِىٌّ صَرِيحٌ"},{"kind":"text","text":", (A, Msb,)"},{"kind":"italic_en","text":"A man,"},{"kind":"text","text":"(T, S, L,) and"},{"kind":"italic_en","text":"an Arab,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"of pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, race"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genealogy;"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"SuraHaA='u","text_ar":"صُرَحَا=ءُ"},{"kind":"text","text":": (T, S, A, L, Msb, K:) and"},{"kind":"arabic","text_bw":"farasN SariyHN","text_ar":"فَرَسٌ صَرِيحٌ"},{"kind":"italic_en","text":"a horse of pure race;"},{"kind":"text","text":"(T, TA;) pl."},{"kind":"arabic","text_bw":"SaraAy^iHu","text_ar":"صَرَايِحُ"},{"kind":"text","text":", (T, K, TA,) in this case as distinguished from the former. (T, TA.) And"},{"kind":"arabic","text_bw":"nasabN SariyHN","text_ar":"نَسَبٌ صَرِيحٌ"},{"kind":"italic_en","text":"Pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, race"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genealogy."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"kalimapN","text_ar":"كَلِمَةٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SuraAHN","text_ar":"صُرَاحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SuraAHiyapN","text_ar":"صُرَاحِيَةٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A word, an expression,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a sentence,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is pure, genuine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear."},{"kind":"text","text":"(K.) And ↓"},{"kind":"arabic","text_bw":"ka*ibN SuraAHN","text_ar":"كَذِبٌ صُرَاحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SiraAHN","text_ar":"صِرَاحٌ","orth_type":"arrow"},{"kind":"text","text":", the latter with kesr, and ↓"},{"kind":"arabic","text_bw":"SuraAHiyapN","text_ar":"صُرَاحِيَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SuraAHiY~N","text_ar":"صُرَاحِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"SuroHaAnN","text_ar":"صُرْحَانٌ","orth_type":"arrow"},{"kind":"text","text":"with damm, (Lh, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"A pure, sheer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmixed, lie,"},{"kind":"text","text":"(Lh, TA,)"},{"kind":"italic_en","text":"manifest, and known"},{"kind":"page_break","n":1676},{"kind":"italic_en","text":"to men."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qawolN SariyHN","text_ar":"قَوْلٌ صَرِيحٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A saying"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that is explicit, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not requiring anything to be conceived in the mind, nor any interpretation."},{"kind":"text","text":"(Msb.) And ↓"},{"kind":"arabic","text_bw":"$ar~N SuraAHN","text_ar":"شَرٌّ صُرَاحٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Pure unmixed, evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"SariyHu Aln~uSoHi","text_ar":"صَرِيحُ النُّصْحِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sincere, in admonition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsel."},{"kind":"text","text":"(L, TA.)"}],"source_refs":["S","K","TA","L","A","T","Msb","Lh"]}]},"classical_definitions":null}