{"lemma":"حَجَّرَ","slug":"حَجَّرَ","root":"ح.ج.ر","root_slug":"ح-ج-ر","root_link":"/words/roots/ح-ج-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَجَّرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَجَّرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَجَّرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَجَّرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَجَّرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَجَّرَ","in_corpus":true,"count":42,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَجَّرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَجَّرا","in_corpus":true,"count":15,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَجَّرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَجَّرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَجَّرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُحَجِّر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُحَجِّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُحَجِّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُحَجِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُحَجِّرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُحَجِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحَجِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَجِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَجِّر","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَجِّر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَجِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَجِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَجِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَجِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَجِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَجِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَجِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَجَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَجَّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَجِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَجِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":58,"cross_references":{"qac":{"found":true,"lemma_key":"حَجَّرَ","root":"حجر","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":10,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":18},"lanes":{"found":true,"entry_ids":["n7150","n7156","n7157","n7158","n7159","n7160","n7161"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AC%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stop, to hinder"},{"pos":"verb","gloss":"to deny access"},{"pos":"verb","gloss":"to forbid, to prohibit"},{"pos":"verb","gloss":"to place under legal guardianship (after declaring incompetent)"},{"pos":"verb","gloss":"to make an enclosure around"},{"pos":"noun","gloss":"verbal noun of حَجَرَ (ḥajara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of حَجَرَ (ḥajara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wall, enclosure; dam"},{"pos":"noun","gloss":"wall, enclosure; northern wall of the Kaaba"},{"pos":"noun","gloss":"wall, enclosure; gathered seam of a garment, seam of a shirt"},{"pos":"noun","gloss":"intellect"},{"pos":"adj","gloss":"forbidden, prohibited, of restricted access"},{"pos":"noun","gloss":"stone","examples":[{"text":"ثُمَّ قَسَتْ قُلُوبُكُم مِّن بَعْدِ ذَٰلِكَ فَهِيَ كَالْحِجَارَةِ أَوْ أَشَدُّ قَسْوَةً ۚ وَإِنَّ مِنَ الْحِجَارَةِ لَمَا يَتَفَجَّرُ مِنْهُ الْأَنْهَارُ ۚ وَإِنَّ مِنْهَا لَمَا يَشَّقَّقُ فَيَخْرُجُ مِنْهُ الْمَاءُ ۚ وَإِنَّ مِنْهَا لَمَا يَهْبِطُ مِنْ خَشْيَةِ اللَّهِ ۗ وَمَا اللَّهُ بِغَافِلٍ عَمَّا تَعْمَلُونَ"}]},{"pos":"adj","gloss":"stony"},{"pos":"noun","gloss":"hole of a mouse, snake, etc."},{"pos":"noun","gloss":"mare"},{"pos":"noun","gloss":"the ancient dwellings of the Thamudites"},{"pos":"noun","gloss":"bosom, embrace, lap","examples":[{"text":"وَضَعَهُ فِي حَجْرِهِ ثُمَّ دَعَا بِتَمْرَةٍ فَمَضَغَهَا ثُمَّ تَفَلَ فِي فِيهِ فَكَانَ أَوَّلَ شَىْءٍ دَخَلَ جَوْفَهُ رِيقُ رَسُولِ اللَّهِ صَلَّى اللّٰهُ عَلَيْهِ وَسَلَّمَ ثُمَّ حَنَّكَهُ بِالتَّمْرَةِ ثُمَّ دَعَا لَهُ وَبَرَّكَ عَلَيْهِ وَكَانَ أَوَّلَ مَوْلُودٍ وُلِدَ فِي الإِسْلَامِ","english":"He placed him on his lap then called for a date and then chewed it and then spat into him and the first thing that went into his stomach was the spittle of God’s messenger, then he rubbed his palate with the date, then he called for him and blessed him, and it was the first child born in Islam."}]}]},"etymology":null,"ipa":["/ħa.d͡ʒa.ra/","/ħad͡ʒ.d͡ʒa.ra/","/ħad͡ʒr/","/ħid͡ʒr/","/ħud͡ʒr/","/ħa.d͡ʒar/","/ħa.d͡ʒir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7150","headword_ar":"حَجَرَ","root":"Hjr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (ISd, TA,) inf. n."},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ"},{"kind":"text","text":"(ISd, Mgh, K) and"},{"kind":"arabic","text_bw":"HujorN","text_ar":"حُجْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HujoraAnN","text_ar":"حُجْرَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HijoraAnN","text_ar":"حِجْرَانٌ"},{"kind":"text","text":", (ISd, K)"},{"kind":"italic_en","text":"He prevented, hindered, withheld, restrained, debarred, inhibited, forbade, prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interdicted,"},{"kind":"text","text":"(ISd, Mgh, K,)"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(ISd, TA:) [or"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"is here a mistranscription for"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":": for] you say,"},{"kind":"arabic","text_bw":"laA Hajora Eanohu","text_ar":"لَا حَجْرَ عَنْهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"There is no prevention, &c., from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"Hajara Ealayohi","text_ar":"حَجَرَ عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ"},{"kind":"text","text":", (S, A, * Msb,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a Kádee, or judge, S, A)"},{"kind":"italic_en","text":"prohibited him"},{"kind":"text","text":"(a young or a lightwitted person, TA)"},{"kind":"italic_en","text":"from using,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposing of, his property according to his own free will:"},{"kind":"text","text":"(S, A, Msb, TA:) or"},{"kind":"arabic","text_bw":"Hajara","text_ar":"حَجَرَ"},{"kind":"arabic","text_bw":"Ealayohi fiY maAlihi","text_ar":"عَلَيْهِ فِى مَالِهِ"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a Kádee)"},{"kind":"italic_en","text":"prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prohibited, him from consuming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wasting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruining, his property."},{"kind":"text","text":"(Mgh.) ―         -b2-  See also 5: ―         -b3-  and 8."}],"source_refs":["ISd","TA","Mgh","K","S","A","Msb"]},{"entry_id":"n7156","headword_ar":"حَجْرٌ","root":"Hjr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ"},{"kind":"text","text":", in three places.       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, Mgh, Msb, K TA,) [the latter of which I have found to be the more common in the present day,] and ↓"},{"kind":"arabic","text_bw":"HujorN","text_ar":"حُجْرٌ","orth_type":"arrow"},{"kind":"text","text":", (K, [but this I have not found in any other lexicon, and the TA, by implication, disallows it,]) The"},{"kind":"arabic","text_bw":"HiDon","text_ar":"حِضْن"},{"kind":"text","text":"; (Mgh, Msb, K;) [i. e. the"},{"kind":"italic_en","text":"bosom;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breast;"},{"kind":"text","text":"agreeably with explanations of"},{"kind":"arabic","text_bw":"HiDon","text_ar":"حِضْن"},{"kind":"text","text":"in the K: or] the"},{"kind":"italic_en","text":"part beneath the armpit, extending to the flank;"},{"kind":"text","text":"(Mgh, Msb;) [agreeably with other explanations of"},{"kind":"arabic","text_bw":"HiDon","text_ar":"حِضْن"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"of a man or woman:"},{"kind":"text","text":"(S A, Mgh, Msb, K:) pl."},{"kind":"arabic","text_bw":"HujuwrN","text_ar":"حُجُورٌ"},{"kind":"text","text":". (S, Msb.) Hence the saying, (Mgh,)"},{"kind":"arabic","text_bw":"fulaAnN fiY Hajori fulaAnK","text_ar":"فُلَانٌ فِى حَجْرِ فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one is in the protection of such a one;"},{"kind":"text","text":"(AZ, T, Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"fY Hajoratihi","text_ar":"فى حَجْرَتِهِ","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"na$aA^a","text_ar":"نَشَاَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fiY Hijorihi","text_ar":"فِى حِجْرِهِ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hajorihi","text_ar":"حَجْرِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He grew up in his care and protection."},{"kind":"text","text":"(K.) ―         -b2-  Also ↓"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ","orth_type":"arrow"},{"kind":"text","text":"(T, K) and"},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ"},{"kind":"text","text":"(T, TA) [The"},{"kind":"italic_en","text":"bosom"},{"kind":"text","text":"as meaning] the"},{"kind":"italic_en","text":"fore part of the garment;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"part, thereof, between one's arms."},{"kind":"text","text":"(T, K.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"HajorapN","text_ar":"حَجْرَةٌ"},{"kind":"text","text":": ―         -b4-  and"},{"kind":"arabic","text_bw":"maHojiru AlEayoni","text_ar":"مَحْجِرُ العَيْنِ"},{"kind":"text","text":".       -A3-  Also"},{"kind":"italic_en","text":"An extended gibbous tract of sand."},{"kind":"text","text":"(K.)"}],"source_refs":["Mgh","T","K","TA"]},{"entry_id":"n7157","headword_ar":"حُجْرٌ","root":"Hjr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ"},{"kind":"text","text":", in three places:       -A2-  and"},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ"},{"kind":"text","text":": ―         -b2-  and"},{"kind":"arabic","text_bw":"maHojiru AlEayoni","text_ar":"مَحْجِرُ العَيْنِ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7158","headword_ar":"حِجْرٌ","root":"Hjr","body":[{"kind":"text","text":"(S A, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"HujorN","text_ar":"حُجْرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) of which the first is the most chaste, (S,) and ↓"},{"kind":"arabic","text_bw":"maHojarN","text_ar":"مَحْجَرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"HaAjuwrN","text_ar":"حَاجُورٌ","orth_type":"arrow"},{"kind":"text","text":"(K) [and ↓"},{"kind":"arabic","text_bw":"maHojuwrN","text_ar":"مَحْجُورٌ","orth_type":"arrow"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"Forbidden, prohibited, unlawful, inviolable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sacred."},{"kind":"text","text":"(S, A, Mgh, Msb, K.) Each of the first three forms occurs in different readings of the Kur vi. 139. (S.) You say,"},{"kind":"arabic","text_bw":"h`*aA HijorN Ealayoka","text_ar":"هٰذَا حِجْرٌ عَلَيْكَ"},{"kind":"italic_en","text":"This is forbidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlawful, to thee."},{"kind":"text","text":"(A.) In the time of paganism, a man meeting another whom he feared, in a sacred month, used to say, ↓"},{"kind":"arabic","text_bw":"HijorFA maHojuwrFA","text_ar":"حِجْرًا مَحْجُورًا","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It is rigorously forbidden"},{"kind":"text","text":"to thee [to commit an act of hostility against me] in this month: and the latter, thereupon, would abstain from any aggression against him: and so, on the day of resurrection, the polytheists, when they see the punishment, will say to the angels, thinking that it will profit them: (Lth, S: *) but Az says that I' Ab and his companions explain these words [occurring in the Kur xxv. 24] otherwise, i. e., as said by the angels, and meaning, the joyful annunciation is forbidden to be made to you: and accord. to El-Hasan, the former word will be said by the sinners, and the latter is said by God, meaning it will be forbidden to them to be granted refuge or protection as they used to be in their former life in the world: but Az adds, it is more proper to regard the two words as composing one saying: (TA:) and the latter word is a corroborative of the former, like"},{"kind":"arabic","text_bw":"maAy^itN","text_ar":"مَايِتٌ"},{"kind":"text","text":"in the expression"},{"kind":"arabic","text_bw":"mawotN maAy^itN","text_ar":"مَوْتٌ مَايِتٌ"},{"kind":"text","text":". (Bd.) The same words in the Kur xxv. 55 signify"},{"kind":"italic_en","text":"A strong mutual repugnance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incongruity;"},{"kind":"text","text":"as though each said what one says who seeks refuge or protection from another: or, as some say,"},{"kind":"italic_en","text":"a defined limit."},{"kind":"text","text":"(Bd.) A man says to another, “ Dost thou so and so, O such a one?” and the latter replies"},{"kind":"arabic","text_bw":"HijorFA","text_ar":"حِجْرًا"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"HujorFA","text_ar":"حُجْرًا","orth_type":"arrow"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"HajorFA","text_ar":"حَجْرًا","orth_type":"arrow"},{"kind":"text","text":", meaning [I pray for]"},{"kind":"italic_en","text":"preservation, and acquitment,"},{"kind":"text","text":"from this thing; a meaning reducible to that of prohibition, and of a thing that is prohibited. (Sb.) The Arabs say, on the occasion of a thing that they disapprove,"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"HujorFA","text_ar":"حُجْرًا","orth_type":"arrow"},{"kind":"text","text":", with damm, meaning,"},{"kind":"italic_en","text":"May it be averted."},{"kind":"text","text":"(S.) ―         -b2-  Homeyd Ibn-Thowr says,"},{"kind":"quote","text":"fahamamotu A^ano A^ago$aY A_ilayohaA maHojarFA\n                      \n                     \n                        walamivoluhaA yugo$aY A_ilayohi AlmaHojaru"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"And I purposed doing to her a forbidden action: and verily the like of her is one to whom that which is forbidden is done."},{"kind":"text","text":"(S, K.) ↓"},{"kind":"arabic","text_bw":"maHojarN","text_ar":"مَحْجَرٌ","orth_type":"arrow"},{"kind":"text","text":"is also explained as signifying"},{"kind":"arabic","text_bw":"HuromapN","text_ar":"حُرْمَةٌ"},{"kind":"text","text":"; [app. meaning"},{"kind":"italic_en","text":"a thing from which one is bound to refrain, from a motive of respect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reverence;"},{"kind":"text","text":"] and to have this meaning in the verse above. (Az.) ―         -b3-  Also, the first of these words,"},{"kind":"italic_en","text":"Any"},{"kind":"arabic","text_bw":"HaAy^iT","text_ar":"حَايِط"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"garden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walled garden of palm-trees,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which one prohibits"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the public"},{"kind":"text","text":"]. (S.) ―         -b4-  And"},{"kind":"arabic","text_bw":"AlHijoru","text_ar":"الحِجْرُ"},{"kind":"italic_en","text":"That"},{"kind":"text","text":"["},{"kind":"italic_en","text":"space"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which is comprised by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the curved wall called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"HaTiym","text_ar":"حَطِيم"},{"kind":"text","text":", (S, A, Mgh, K,)"},{"kind":"italic_en","text":"which encompasses the Kaabeh on the north"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rather north-west"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"side;"},{"kind":"text","text":"(S, A, K;)"},{"kind":"italic_en","text":"on the side of the spout:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"HTym","text_ar":"حطيم"},{"kind":"text","text":"["},{"kind":"italic_en","text":"itself"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"which encompasses the Kaabeh on the side of the spout."},{"kind":"text","text":"(Msb.) [It is applied to both of these in the present day; but more commonly to the former.] ―         -b5-  Also,"},{"kind":"arabic","text_bw":"HijorN","text_ar":"حِجْرٌ"},{"kind":"text","text":", The"},{"kind":"italic_en","text":"anterior pudendum"},{"kind":"text","text":"of a man and of a woman; and so ↓"},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) the latter the more chaste. (TA.) ―         -b6-"},{"kind":"italic_en","text":"A mare;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"female of the horse:"},{"kind":"text","text":"(S, A, Msb, K:) and"},{"kind":"italic_en","text":"a mare kept for breeding;"},{"kind":"text","text":"(A;) as though her womb were forbidden to all but generous horses: (T:) but in the latter sense the sing. is scarcely ever used; though its pl., the first of the following forms, (as well as the second, A,) is used to signify mares kept for breeding: (K:) ↓"},{"kind":"arabic","text_bw":"HijorapN","text_ar":"حِجْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", as a sing., is said by F and others to be a barbarism: it occurs in a trad.; but perhaps the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"is there added to assimilate it to"},{"kind":"arabic","text_bw":"bagolapN","text_ar":"بَغْلَةٌ"},{"kind":"text","text":", with which it is there coupled: (MF:) the pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A^aHojaArN","text_ar":"اَحْجَارٌ"},{"kind":"text","text":"(Msb, K) and [of mult.]"},{"kind":"arabic","text_bw":"HujuwrN","text_ar":"حُجُورٌ"},{"kind":"text","text":"(A, Msb, K) and"},{"kind":"arabic","text_bw":"HujuwrapN","text_ar":"حُجُورَةٌ"},{"kind":"text","text":". (K.) A poet says,"},{"kind":"quote","text":"A_i*aA xarisa AlfaHolu wasoTa AlHujuwri\n                      \n                     \n                        waSaAHa AlkilaAbu waEaq~a Alwalado"},{"kind":"italic_en","text":"When the stallion,"},{"kind":"text","text":"seeing the army and the gleaming swords,"},{"kind":"italic_en","text":"is mute in the midst of the mares kept for breeding,"},{"kind":"text","text":"and does not look towards them,"},{"kind":"italic_en","text":"and the dogs bark"},{"kind":"text","text":"at their masters, because of the change of their appearances,"},{"kind":"italic_en","text":"and children behave undutifully"},{"kind":"text","text":"to their mothers whom fear diverts from attending to them. (A.) ―         -b7-"},{"kind":"italic_en","text":"Relationship"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that prohibits marriage"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"nearness with respect to kindred."},{"kind":"text","text":"(Msb, K.) ―         -b8-"},{"kind":"italic_en","text":"Understanding, intelligence, intellect, mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reason:"},{"kind":"text","text":"(S, A, Msb, K:) so in the Kur lxxxix. 4: (S, Bd:) thus called because it forbids that which it does not behoove one to do. (Bd.) One says,"},{"kind":"arabic","text_bw":"fiY *`lika EiborapN li*iy HijorK","text_ar":"فِى ذٰلِكَ عِبْرَةٌ لِذِي حِجْرٍ"},{"kind":"italic_en","text":"In that is an admonition to him who possesses understanding,"},{"kind":"text","text":"&c. (A.)       -A2-  See also"},{"kind":"arabic","text_bw":"HajurN","text_ar":"حَجُرٌ"},{"kind":"text","text":", in three places."}],"source_refs":["S","Mgh","Msb","K","TA","A","T","MF","Bd"]},{"entry_id":"n7159","headword_ar":"حَجَرٌ","root":"Hjr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A stone;"},{"kind":"text","text":"explained in the K by"},{"kind":"arabic","text_bw":"SaxorapN","text_ar":"صَخْرَةٌ"},{"kind":"text","text":"; but this means “a rock,” or “a great mass of stone” or “of hard stone”]; (S, K, &c.;) so called because it resists, by reason of its hardness; (Mgh;) and ↓"},{"kind":"arabic","text_bw":"A^uHojur~N","text_ar":"اُحْجُرٌّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (Fr, K:) pl. (of pauc., of the former, S)"},{"kind":"arabic","text_bw":"A^aHojaArN","text_ar":"اَحْجَارٌ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"A^aHojurN","text_ar":"اَحْجُرٌ"},{"kind":"text","text":"(K) and (of mult, S)"},{"kind":"arabic","text_bw":"HijaArN","text_ar":"حِجَارٌ"},{"kind":"text","text":"and [more commonly]"},{"kind":"arabic","text_bw":"HijaArapN","text_ar":"حِجَارَةٌ"},{"kind":"text","text":", (S, K,) which last is extr. [with respect to rule], (S,) or agreeable with a usage of the Arabs, which is, to add"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"to any pl. of the measure"},{"kind":"arabic","text_bw":"fiEaAlN","text_ar":"فِعَالٌ"},{"kind":"text","text":"or of that of"},{"kind":"arabic","text_bw":"fuEuwlN","text_ar":"فُعُولٌ"},{"kind":"text","text":", as in the instances of"},{"kind":"arabic","text_bw":"*ikaArapN","text_ar":"ذِكَارَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiHaAlapN","text_ar":"فِحَالَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*ukuwrapN","text_ar":"ذُكُورَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fuHuwlapN","text_ar":"فُحُولَةٌ"},{"kind":"text","text":". (AHeyth.) And (metonymically, TA) (tropical:)"},{"kind":"italic_en","text":"Sand:"},{"kind":"text","text":"(IAar, K;) pl."},{"kind":"arabic","text_bw":"A^aHojaArN","text_ar":"اَحْجَارٌ"},{"kind":"text","text":". (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^aholu AlHajari","text_ar":"اَهْلُ الحَجَرِ"},{"kind":"italic_en","text":"The people of the desert, who dwell in stony and sandy places:"},{"kind":"text","text":"occurring in a trad., coupled with"},{"kind":"arabic","text_bw":"A^aholu Almadari","text_ar":"اَهْلُ المَدَرِ"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AlHajaru AlA^asowadu","text_ar":"الحَجَرُ الاَسْوَدُ"},{"kind":"text","text":", and simply"},{"kind":"arabic","text_bw":"AlHajaru","text_ar":"الحَجَرُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Black"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Stone of the Kaabeh."},{"kind":"text","text":"(K, TA.) El-Farezdak applies to it, in one instance, the pl."},{"kind":"arabic","text_bw":"AlA^aHojaAru","text_ar":"الاَحْجَارُ"},{"kind":"text","text":", considering the sing. as applicable to every part of it. (TA.) ―         -b4-  One says,"},{"kind":"arabic","text_bw":"fulaAnN Hajaru AlA^aroDi","text_ar":"فُلَانٌ حَجَرُ الاَرْضِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Such a one is unequalled."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"rumiYa fulaAnN biHajari AlA^aroDi","text_ar":"رُمِىَ فُلَانٌ بِحَجَرِ الاَرْضِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one has had a very sagacious and crafty and politic man made to be an assailant against him."},{"kind":"text","text":"(K, * TA.) El-Ahnaf Ibn-Keys said to 'Alee, when Mo'á- wiyeh named 'Amr Ibn-El-'Ás as one of the two umpires,"},{"kind":"arabic","text_bw":"qado rumiyta biHajari AlA^aroDi faA@joEalo maEahu A@bona","text_ar":"قَدْ رُمِيتَ بِحَجَرِ الاَرْضِ فَا@جْعَلْ مَعَهُ ا@بْنَ"},{"kind":"arabic","text_bw":"Eab~aAsK faA_in~ahu laA yaEoqidu EuqodapF A_il~aA Hal~ahaA","text_ar":"عَبَّاسٍ فَاـِنَّهُ لَا يَعْقِدُ عُقْدَةً اـِلَّا حَلَّهَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Thou hast had a most exceedingly sagacious and crafty and politic man made to be an assailant against thee: so appoint thou with him Ibn-'Abbás; for he will not tie a knot but he shall untie it:"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"one that shall stand firm like a stone upon the ground."},{"kind":"text","text":"(L from a trad.) One says also,"},{"kind":"arabic","text_bw":"rumYa","text_ar":"رُمىَ"},{"kind":"arabic","text_bw":"fulaAnN biHajarihi","text_ar":"فُلَانٌ بِحَجَرِهِ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Such a one was coupled"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"opposed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with his like:"},{"kind":"text","text":"(A:) [as though he"},{"kind":"page_break","n":518},{"kind":"text","text":"had a stone suited to the purpose of knocking him down cast at him.] ―         -b5-"},{"kind":"arabic","text_bw":"liloEaAhiri AlHajaru","text_ar":"لِلْعَاهِرِ الحَجَرُ"},{"kind":"text","text":", occurring in a trad., means (assumed tropical:)"},{"kind":"italic_en","text":"For the fornicator,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adulterer, disappointment, and prohibition:"},{"kind":"text","text":"accord. to some, it is meant to allude to"},{"kind":"italic_en","text":"stoning;"},{"kind":"text","text":"[and it may have had this meaning in the first instance in which it was used;] but [in general] this is not the case; for every fornicator is not to be stoned. (IAth, TA.) [See also art."},{"kind":"arabic","text_bw":"Ehr","text_ar":"عهر"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"AlHajaru","text_ar":"الحَجَرُ"},{"kind":"italic_en","text":"Gold:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"silver."},{"kind":"text","text":"(K.) Both together are called"},{"kind":"arabic","text_bw":"AlHajaraAni","text_ar":"الحَجَرَانِ"},{"kind":"text","text":". (S.)"}],"source_refs":["Fr","K","S","Mgh","A"]},{"entry_id":"n7160","headword_ar":"حَجِرٌ","root":"Hjr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Stony; abounding with stones"},{"kind":"text","text":"]. You say"},{"kind":"arabic","text_bw":"A^aroDN HajirapN","text_ar":"اَرْضٌ حَجِرَةٌ"},{"kind":"text","text":"[so in several copies of the K; in the CK"},{"kind":"arabic","text_bw":"HajorapN","text_ar":"حَجْرَةٌ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"Land abounding with stones;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HajiyrapN","text_ar":"حَجِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mutaHaj~irapN","text_ar":"مُتَحَجِّرَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":[]},{"entry_id":"n7161","headword_ar":"حُجُرٌ","root":"Hjr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"flesh surrounding the nail."},{"kind":"text","text":"(K.)"}],"source_refs":[]}]}}