":"tSr~mt","text_ar":"تصرّمت","orth_type":"arrow"},{"kind":"arabic","text_bw":"Als~anapu","text_ar":"السَّنَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The year ended:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"AlqitaAlu","text_ar":"القِتَالُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tSr~m","text_ar":"تصرّم","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The fighting ended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased."},{"kind":"text","text":"(Mgh.)"},{"kind":"page_break","n":1684}],"source_refs":["Msb","TA"]}]},"classical_definitions":null}