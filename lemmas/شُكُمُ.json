{"lemma":"شُكُمُ","slug":"شُكُمُ","root":"ش.ك.م","root_slug":"ش-ك-م","root_link":"/words/roots/ش-ك-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n22867","n22868"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8F%D9%83%D9%8F%D9%85%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bit, to stop the mouth"},{"pos":"verb","gloss":"to requit, to remunerate, to compensate"},{"pos":"noun","gloss":"verbal noun of شَكَمَ (šakama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"remuneration, compensation"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22867","headword_ar":"شُكْمٌ","root":"$km","body":[{"kind":"text","text":"(S, K, &c.) and ↓"},{"kind":"arabic","text_bw":"$ukomaY","text_ar":"شُكْمَى","orth_type":"arrow"},{"kind":"text","text":"; (K;) of the latter, ISd says, “ I think it to be a dial. var., but I am not certain of it; ” (TA;)"},{"kind":"italic_en","text":"A repayment, requital,"},{"kind":"page_break","n":1589},{"kind":"italic_en","text":"compensation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompense;"},{"kind":"text","text":"(El-Umawee, A' Obeyd, S, K;) and"},{"kind":"arabic","text_bw":"$ukobN","text_ar":"شُكْبٌ"},{"kind":"text","text":"is a dial. var. thereof: (TA:) when the gift is initial, it is termed"},{"kind":"arabic","text_bw":"$ukodN","text_ar":"شُكْدٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"a substitute;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing given, received, put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"done, by way of replacement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exchange:"},{"kind":"text","text":"(Ks, TA:) and