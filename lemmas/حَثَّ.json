ext":"or"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard, and coarse, of sand."},{"kind":"text","text":"(K, TA.) ―         -b4-"},{"kind":"italic_en","text":"Bread without any seasoning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condiment, to render it pleasant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"savoury."},{"kind":"text","text":"(A'Obeyd, S, K.) ―         -b5-"},{"kind":"arabic","text_bw":"sawiyqN Huv~N","text_ar":"سَوِيقٌ حُثٌّ"},{"kind":"text","text":", (S, K,) as also"},{"kind":"arabic","text_bw":"Euv~N","text_ar":"عُثٌّ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"Ev","text_ar":"عث"},{"kind":"text","text":",) ["},{"kind":"italic_en","text":"Meal of parched barley"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wheat"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not moistened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stirred about, with water &c.;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"gayoru malotuwtK","text_ar":"غَيْرُ مَلْتُوتٍ"},{"kind":"text","text":"; (S, and in a similar manner in the K;) and in like manner"},{"kind":"arabic","text_bw":"Huv~N","text_ar":"حُثٌّ"},{"kind":"text","text":"is applied to collyrium ("},{"kind":"arabic","text_bw":"kuHol","text_ar":"كُحْل"},{"kind":"text","text":"), and to musk: or"},{"kind":"arabic","text_bw":"swyq","text_ar":"سويق"},{"kind":"italic_en","text":"not finely ground."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"Huv~N","text_ar":"حُثٌّ"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"tamorN Huv~N","text_ar":"تَمْرٌ حُثٌّ"},{"kind":"italic_en","text":"Dates not sticking together."},{"kind":"text","text":"(IAar, TA.) [See also"},{"kind":"arabic","text_bw":"Hav~N","text_ar":"حَثٌّ"},{"kind":"text","text":".]"}],"source_refs":["As","S","K"]}]},"classical_definitions":null}