{"lemma":"غُرْمُ","slug":"غُرْمُ","root":"غ.ر.م","root_slug":"غ-ر-م","root_link":"/words/roots/غ-ر-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n31744","n31749"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8F%D8%B1%D9%92%D9%85%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31744","headword_ar":"غَرِمَ","root":"grm","body":[{"kind":"text","text":", (JK, S, Msb, K,) aor."},{"kind":"text","text":", (JK, K,) inf. n."},{"kind":"arabic","text_bw":"guromN","text_ar":"غُرْمٌ"},{"kind":"text","text":"(JK, Msb, TA) and"},{"kind":"arabic","text_bw":"garaAmapN","text_ar":"غَرَامَةٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He paid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discharged"},{"kind":"text","text":"(A K, S, * Msb, K, *) a thing that was obligatory upon him, (JK,) or a bloodwit, (S, Msb, K,) and a responsibility, and the like thereof,"},{"kind":"italic_en","text":"after it had become obligatory upon him:"},{"kind":"text","text":"(Msb:) (or, accord. to an explanation of"},{"kind":"arabic","text_bw":"AlgaraAmapu","text_ar":"الغَرَامَةُ"},{"kind":"text","text":"in Har p. 36,"},{"kind":"italic_en","text":"he gave"},{"kind":"text","text":"property"},{"kind":"italic_en","text":"against his will:"},{"kind":"text","text":"or the meaning intended in the S and K (in both of which it is very vaguely indicated) may be,"},{"kind":"italic_en","text":"he took upon himself to pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discharge,"},{"kind":"text","text":"a blood wit, &c.: for, sometimes,]"},{"kind":"arabic","text_bw":"guromN","text_ar":"غُرْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"garaAmapN","text_ar":"غَرَامَةٌ"},{"kind":"text","text":"signify the"},{"kind":"italic_en","text":"taking upon oneself that which is not obligatory upon him:"},{"kind":"text","text":"(Mgh; and the Ksh gives this explanation of"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ"},{"kind":"text","text":"in lii. 40:) [or"},{"kind":"italic_en","text":"the taking upon oneself a fine"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"for, sometimes,]"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AilotizaAmu guromK","text_ar":"اِلْتِزَامُ غُرْمٍ"},{"kind":"text","text":". (Bd in lii. 40. [See also 5, and 8.]) And you say,"},{"kind":"arabic","text_bw":"garimotu Eanohu maA lazimahu mina","text_ar":"غَرِمْتُ عَنْهُ مَا لَزِمَهُ مِنَ"},{"kind":"arabic","text_bw":"Ald~iyapi","text_ar":"الدِّيَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I paid for him,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"in his stead, what was obligatory upon him, of the bloodwit"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"Eql","text_ar":"عقل"},{"kind":"text","text":".) ―         -b2-  And"},{"kind":"arabic","text_bw":"garima fiY tijaAratihi","text_ar":"غَرِمَ فِى تِجَارَتِهِ"},{"kind":"italic_en","text":"He lost,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffered loss, in his traffic; i. q."},{"kind":"arabic","text_bw":"xasira","text_ar":"خَسِرَ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"rabiHa","text_ar":"رَبِحَ"},{"kind":"text","text":". (Msb.)       -A2-"},{"kind":"arabic","text_bw":"gurima A^anofFA","text_ar":"غُرِمَ اَنْفًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rugima","text_ar":"رُغِمَ"},{"kind":"text","text":"[from which it is app. formed by transposition]."}],"source_refs":["JK","S","Msb","K","TA"]},{"entry_id":"n31749","headword_ar":"غُرْمٌ","root":"grm","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"garima","text_ar":"غَرِمَ"},{"kind":"text","text":"[q. v.]. (JK, Msb, TA.) ―         -b2-  And"},{"kind":"italic_en","text":"A thing that must be paid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discharged;"},{"kind":"text","text":"(K, TA;) and so ↓"},{"kind":"arabic","text_bw":"garaAmapN","text_ar":"غَرَامَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"mugoramN","text_ar":"مُغْرَمٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K, TA,) and ↓"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ","orth_type":"arrow"},{"kind":"text","text":": (S, TA:) accord. to Er-Rághib,"},{"kind":"italic_en","text":"a damage, detriment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loss, that befalls a man, in his property, not for an injurious action, of his, requiring punishment"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"a debt,"},{"kind":"text","text":"(S, TA:)"},{"kind":"italic_en","text":"a fine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mulet:"},{"kind":"text","text":"(MA:) the pl. of ↓"},{"kind":"arabic","text_bw":"magoramN","text_ar":"مَغْرَمٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"magaArimu","text_ar":"مَغَارِمُ"},{"kind":"text","text":", agreeably with analogy; or this is pl. of"},{"kind":"arabic","text_bw":"guromN","text_ar":"غُرْمٌ"},{"kind":"text","text":", anomalously, like as"},{"kind":"arabic","text_bw":"maHaAsinu","text_ar":"مَحَاسِنُ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"HusonN","text_ar":"حُسْنٌ"},{"kind":"text","text":". (TA.) [See exs. voce"},{"kind":"arabic","text_bw":"galiqa","text_ar":"غَلِقَ"},{"kind":"text","text":": and see also"},{"kind":"arabic","text_bw":"gunomN","text_ar":"غُنْمٌ"},{"kind":"text","text":".]"}],"source_refs":["S","K","TA","MA"]}]}}