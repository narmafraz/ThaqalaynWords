ا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَخَيَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَخَيَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَخَيَّل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَخَيَّل","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَخَيَّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَخَيَّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَخَيَّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَخَيَّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَخَيَّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَخَيَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَخَيَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"تَخَيَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَخَيَّلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَخَيَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَخَيَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n11868"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AE%D9%8E%D9%8A%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to imagine, to take into one's head, to fancy"},{"pos":"verb","gloss":"to be conceived, be imagined"},{"pos":"verb","gloss":"to appear probable, to exhibit verisimilitude"},{"pos":"verb","gloss":"to suppose good or evil of someone"},{"pos":"verb","gloss":"to be haughty, to be self-conceited"},{"pos":"verb","gloss":"to be variegated, to grow covered in abundance"},{"pos":"noun","gloss":"verbal noun of تَخَيَّلَ (taḵayyala) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare خَالَ (ḵāla, “to imagine”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11868","headword_ar":"تخيّل","root":"xyl","body":[{"kind":"text","text":", as a trans. v., syn. with"},{"kind":"arabic","text_bw":"xay~ala","text_ar":"خَيَّلَ"},{"kind":"text","text":"; and its inf. n., syn. with"},{"kind":"arabic","text_bw":"taxoyiylN","text_ar":"تَخْيِيلٌ"},{"kind":"text","text":": see 2, first two sentences, in two places. ―         -b2-"},{"kind":"arabic","text_bw":"txy~l fiyhi Alxayori","text_ar":"تخيّل فِيهِ الخَيْرِ"},{"kind":"text","text":", as syn. with"},{"kind":"arabic","text_bw":"xay~ala","text_ar":"خَيَّلَ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"taxay~alotu Ealayohi","text_ar":"تَخَيَّلْتُ عَلَيْهِ"},{"kind":"text","text":": see 2, in the latter half of the paragraph.       -A2-  Also, as a quasipass. v., similar in signification to"},{"kind":"arabic","text_bw":"xuy~ila","text_ar":"خُيِّلَ"},{"kind":"text","text":"; and its inf. n.: see 2, first three sentences, in five places. ―         -b2-  And"},{"kind":"arabic","text_bw":"taxy~ulN","text_ar":"تَخيُّلٌ"},{"kind":"text","text":"used as an inf. n. of"},{"kind":"arabic","text_bw":"xay~ala Ealayohi","text_ar":"خَيَّلَ عَلَيْهِ"},{"kind":"text","text":": and app. as an inf. n. of"},{"kind":"arabic","text_bw":"xay~alato EalayonaA Als~amaA='u","text_ar":"خَيَّلَتْ عَلَيْنَا السَّمَا=ءُ"},{"kind":"text","text":": see 2, latter half, in two places. ―         -b3-"},{"kind":"arabic","text_bw":"txy~lt Als~amaA='u","text_ar":"تخيّلت السَّمَا=ءُ"},{"kind":"text","text":": see 2, latter half, in three places. ―         -b4-"},{"kind":"arabic","text_bw":"txy~l","text_ar":"تخيّل"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"AxtAl","text_ar":"اختال"},{"kind":"text","text":": see the latter verb. ―         -b5-  [Hence, app.,]"},{"kind":"arabic","text_bw":"txy~lt AlA^aroDu","text_ar":"تخيّلت الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land became abundant in its plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"(JK:) [and, (as is shown by an explanation of the part. n. of the verb, below,) (assumed tropical:)"},{"kind":"italic_en","text":"the land had its plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, in a state of full maturity, and in blossom;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"txAylt","text_ar":"تخايلت","orth_type":"arrow"},{"kind":"text","text":"; whence,] a poet says,"},{"kind":"quote","text":"taA^az~ara fiyhi Aln~ayotu Hat~aY taxaAyalato\n                      \n                     \n                        rubaAhu waHat~aY maA turaY Al$~aA='u nuw~amaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The herbage in it became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had become, tangled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"luxuriant, and strong, so that its hills were clad with plants in full maturity, and in blossom, and so that the sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, were seen sleeping"},{"kind":"text","text":"]. (S, TA. [In both, the meaning of the verb in this ex. is indicated by the context. See also 4, where a similar meaning is assigned to"},{"kind":"arabic","text_bw":"AxAlt","text_ar":"اخالت"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"AxtAlt","text_ar":"اختالت"},{"kind":"text","text":".]) ―         -b6-"},{"kind":"arabic","text_bw":"taxay~ulN","text_ar":"تَخَيُّلٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, of various colours."},{"kind":"text","text":"(JK, Ham p. 39. *) [Hence the saying,]"},{"kind":"arabic","text_bw":"taxay~ala Algaroqu","text_ar":"تَخَيَّلَ الغَرْقُ"},{"kind":"arabic","text_bw":"biAls~afori","text_ar":"بِالسَّفْرِ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"The desert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"far-extending desert] became of various colours with the travellers,"},{"kind":"text","text":"by reason of the"},{"kind":"arabic","text_bw":"A=l","text_ar":"ا=ل"},{"kind":"text","text":"[or mirage]. (JK.) ―         -b7-  Also The"},{"kind":"italic_en","text":"going on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acting with a penetrative energy;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"being quick."},{"kind":"text","text":"(JK, Ham p. 39.) ―         -b8-  See also 2, last sentence but one."}],"source_refs":["JK"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D8%AE%D9%8A%D9%84/","headword_ar":"تخيلات العرب","entries":[{"lexicon_id":"dictionary_50","lexicon_en":"Kâtip Çelebi / Ḥājī Khalīfa, Kashf al-Ẓunūn ʿan Asāmī al-Kutub wa-l-Funūn (d. 1657)","lexicon_ar":"كشف الظنون عن أسامي الكتب والفنون لحاجي خليفة","permalink":"https://arabiclexicon.hawramani.com/?p=134501#59425f","body_html":"تخيلات العرب<br>للحسين بن محمد، المعروف: بالخالع.<br>ألفه: في حدود سنة ثمان وثلاثمائة.<br>ذكره: ابن قاضي شهبة."}]}}