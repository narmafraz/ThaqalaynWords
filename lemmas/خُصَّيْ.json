{"lemma":"خُصَّيْ","slug":"خُصَّيْ","root":"خ.ص.ص","root_slug":"خ-ص-ص","root_link":"/words/roots/خ-ص-ص","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n10829","n10830","n10833"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D8%B5%D9%8E%D9%91%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to single out, to distinguish"},{"pos":"verb","gloss":"to favor, to endow"},{"pos":"verb","gloss":"to concern, to touch, to belong to, to pertain to, to be about"},{"pos":"verb","gloss":"to be characteristic for, to be peculiar for"},{"pos":"noun","gloss":"booth, shack, hut"},{"pos":"noun","gloss":"alternative form of خَسّ (ḵass, “lettuce”)","tags":["alt-of","alternative","collective"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10829","headword_ar":"خُصْىٌ","root":"xSY","body":[{"kind":"text","text":"; and the dual"},{"kind":"arabic","text_bw":"xuSoyaAni","text_ar":"خُصْيَانِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xuSoyapN","text_ar":"خُصْيَةٌ"},{"kind":"text","text":", in five places."}],"source_refs":[]},{"entry_id":"n10830","headword_ar":"خِصْىٌ","root":"xSY","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n10833","headword_ar":"خَصِىٌّ","root":"xSY","body":[{"kind":"italic_en","text":"Whose testicles have been drawn forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extracted;"},{"kind":"text","text":"(S, Mgh, Msb, K;) ["},{"kind":"italic_en","text":"gelded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"castrated; a eunuch;"},{"kind":"text","text":"] applied to a sheep or goat, and a horse or similar beast, (TA,) and a man (S, TA) or boy, (TA,) or a slave; (Msb;) as also ↓"},{"kind":"arabic","text_bw":"maxoSiY~N","text_ar":"مَخْصِىٌّ","orth_type":"arrow"},{"kind":"text","text":": (K:) pl."},{"kind":"arabic","text_bw":"xiSoyaAnN","text_ar":"خِصْيَانٌ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"xiSoyapN","text_ar":"خِصْيَةٌ"},{"kind":"text","text":": (S, K:) in giving it the former pl., they liken it to a subst., like"},{"kind":"arabic","text_bw":"ZaliymN","text_ar":"ظَلِيمٌ"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"ZilomaAnN","text_ar":"ظِلْمَانٌ"},{"kind":"text","text":": so says Sb; meaning that"},{"kind":"arabic","text_bw":"fiEolaAnN","text_ar":"فِعْلَانٌ"},{"kind":"text","text":"is generally the pl. of"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":"as a subst. (TA.) One says also"},{"kind":"arabic","text_bw":"xaSiY~N naSiY~N","text_ar":"خَصِىٌّ نَصِىٌّ"},{"kind":"text","text":"; using the latter word as an imitative sequent. (Lh, TA.) ―         -b2-  Also (tropical:)  Poetry"},{"kind":"italic_en","text":"in which is no amatory effusion."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["TA","S","K","Mgh"]}]}}