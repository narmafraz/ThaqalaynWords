d":"text","text":"or"},{"kind":"italic_en","text":"glad, tidings; good news"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"tabaA$iyru","text_ar":"تَبَاشِيرُ","orth_type":"arrow"},{"kind":"text","text":"[q. v. infrà] signifies the same as"},{"kind":"arabic","text_bw":"bu$oraY","text_ar":"بُشْرَى"},{"kind":"text","text":": (S, K:) ↓"},{"kind":"arabic","text_bw":"bi$aArapN","text_ar":"بِشَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", when used absolutely, relates only to good; (S, Msb;) not to evil unless when expressly restricted thereto by an adjunct: [see 2:] (S:) its pl. is"},{"kind":"arabic","text_bw":"bi$aAraAtN","text_ar":"بِشَارَاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ba$aAy^iru","text_ar":"بَشَايِرُ"},{"kind":"text","text":". (A.)"}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}