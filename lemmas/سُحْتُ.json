d_ar":"سَحْتٌ","root":"sHt","body":[{"kind":"text","text":"inf. n. of 1 [q. v.]. (L, TA.) ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"Vehemence of eating and drinking."},{"kind":"text","text":"(TA.) ―         -b3-  And (assumed tropical:)"},{"kind":"italic_en","text":"Punishment, castigation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chastisement."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"barodN saHotN","text_ar":"بَرْدٌ سَحْتٌ"},{"kind":"text","text":", (K,) [as also"},{"kind":"arabic","text_bw":"saxotN","text_ar":"سَخْتٌ"},{"kind":"text","text":", q. v.,] and"},{"kind":"arabic","text_bw":"baHotN","text_ar":"بَحْتٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"laHotN","text_ar":"لَحْتٌ"},{"kind":"text","text":", (TA,) [and"},{"kind":"arabic","text_bw":"laxotN","text_ar":"لَخْتٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SaAdiqN","text_ar":"صَادِقٌ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"Vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intense, cold:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"baHotN","text_ar":"بَحْتٌ"},{"kind":"text","text":"&c.]. (K.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"suHotuwtN","text_ar":"سُحْتُوتٌ"},{"kind":"text","text":": ―         -b6-  and"},{"kind":"arabic","text_bw":"masoHuwtN","text_ar":"مَسْحُوتٌ"},{"kind":"text","text":": ―         -b7-  and see the paragraph here following, in two places."}],"source_refs":["K","TA"]},{"entry_id":"n19046","headword_ar":"سُحْتٌ","root":"sHt","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"suHutN","text_ar":"سُحُتٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) the former a contraction of the latter, (Msb,)"},{"kind":"italic_en","text":"A thing that is forbidden, prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlawful;"},{"kind":"text","text":"(S, A, K;) and (so in the A, but in the K “ or ”)"},{"kind":"italic_en","text":"what is disapproved, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul, of gains,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"that occasions disgrace"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"and bad repute;"},{"kind":"text","text":"as the price of a dog, and of wine, and of a pig; (TA;)"},{"kind":"italic_en","text":"any pro-  perty that is forbidden, not lawful to be gained"},{"kind":"text","text":"(Msb, TA)"},{"kind":"italic_en","text":"nor to be eaten;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"anything forbidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlawful, and of bad repute:"},{"kind":"text","text":"sometimes it means what is disapproved; and sometimes, what is unlawful; the context showing in which sense it is used: and it is also applied to signify"},{"kind":"italic_en","text":"a bribe that is given to a judge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"so called because it cuts off blessing: (TA:) in the Kur v. 46, some read"},{"kind":"arabic","text_bw":"lils~uHoti","text_ar":"لِلسُّحْتِ"},{"kind":"text","text":"; and some,"},{"kind":"arabic","text_bw":"lils~uHuti","text_ar":"لِلسُّحُتِ"},{"kind":"text","text":"; (Bd, TA;) and it has also been read as the inf. n., ↓"},{"kind":"arabic","text_bw":"lils~aHoti","text_ar":"لِلسَّحْتِ","orth_type":"arrow"},{"kind":"text","text":": (Bd:) the pl. is"},{"kind":"arabic","text_bw":"A^asoHaAtN","text_ar":"اَسْحَاتٌ"},{"kind":"text","text":". (K.) ―         -b2-  Also"},{"kind":"italic_en","text":"Little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small, in quantity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"number; paltry, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"maAluhu suHotN","text_ar":"مَالُهُ سُحْتٌ"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"saHotN","text_ar":"سَحْتٌ","orth_type":"arrow"},{"kind":"text","text":"(accord. to different copies of the K [the former the better known])"},{"kind":"italic_en","text":"His property may be taken and destroyed with impunity:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"damuhu sHt","text_ar":"دَمُهُ سحت"},{"kind":"italic_en","text":"His blood may be shed with impunity."},{"kind":"text","text":"(K, * TA.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"masoHuwtN","text_ar":"مَسْحُوتٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","Msb","K","TA","Bd"]},{"entry_id":"n19047","headword_ar":"سُحُتٌ","root":"sHt","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]}}