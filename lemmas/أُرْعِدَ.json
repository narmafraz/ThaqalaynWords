led,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected, by thunder;"},{"kind":"text","text":"(Lh, S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"ruEida","text_ar":"رُعِدَ","orth_type":"arrow"},{"kind":"text","text":": and the former,"},{"kind":"italic_en","text":"he heard thunder."},{"kind":"text","text":"(TA.) ―         -b2-  See also 1, in seven places.       -A2-"},{"kind":"arabic","text_bw":"ArEdhu","text_ar":"ارعدهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(fear, [or cold, see"},{"kind":"arabic","text_bw":"riEodapN","text_ar":"رِعْدَةٌ"},{"kind":"text","text":",] &c., L,)"},{"kind":"italic_en","text":"caused him to tremble, quiver, quake, shiver,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be in a state of commotion."},{"kind":"text","text":"(S, * L.) ―         -b2-  See also 8, in two places. ―         -b3-  Also"},{"kind":"arabic","text_bw":"A^uroEida","text_ar":"اُرْعِدَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a hill, or heap, of sand)"},{"kind":"italic_en","text":"poured down;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shaken, and consequently"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"poured down."},{"kind":"text","text":"(IAar, K, TA.)"}],"source_refs":[]}]},"classical_definitions":null}