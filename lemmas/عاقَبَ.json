"gen":"m","num":"p"},{"role":"present_3mp","form":"يُعاقَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعاقِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعاقَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُعاقِب","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعاقِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عاقَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عاقَبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُعاقَب","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعاقَب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عُوقِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عُوقِبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":21,"cross_references":{"qac":{"found":true,"lemma_key":"عاقَبَ","root":"عقب","pos":"V","occurrence_count":6},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n29852"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%82%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to punish","tags":["transitive"],"examples":[{"text":"عُوقِبْتُ فِي ذَنْبِي","english":"I was punished for my crime."},{"text":"وَإِنْ عَاقَبْتُمْ فَعَاقِبُوا بِمِثْلِ مَا عُوقِبْتُم بِهِ ۖ وَلَئِن صَبَرْتُمْ لَهُوَ خَيْرٌ لِلصَّابِرِينَ"}]},{"pos":"verb","gloss":"to do a thing alternately with (someone)"},{"pos":"verb","gloss":"to alternate, make an interchange (بَيْنَ (bayna) between two things)"},{"pos":"verb","gloss":"to come or use alternately, relieve (e.g. a guard)"},{"pos":"verb","gloss":"to follow at one's heels"},{"pos":"verb","gloss":"to move the legs alternately"},{"pos":"verb","gloss":"be alternately used or employed"},{"pos":"verb","gloss":"to carry off (booty or gain)"}]},"etymology":null,"ipa":["/ʕaː.qa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29852","headword_ar":"عَاقِبٌ","root":"Eqb","body":[{"kind":"text","text":"[act. part. n. of"},{"kind":"arabic","text_bw":"Eaqaba","text_ar":"عَقَبَ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"Coming after"},{"kind":"text","text":"[&c.]. (Msb.)"},{"kind":"arabic","text_bw":"EaAqibu $aYo'K","text_ar":"عَاقِبُ شَىْءٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Any person"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"thing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that comes after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succeeds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comes in the place of, a thing."},{"kind":"text","text":"(S, O, TA.)"},{"kind":"arabic","text_bw":"AlEaAqibu","text_ar":"العَاقِبُ"},{"kind":"text","text":"is an appellation applied to the Prophet (S, O, Msb) by himself (S, O) because he came after other prophets, (Msb,) meaning"},{"kind":"italic_en","text":"The last of the prophets,"},{"kind":"text","text":"(S, O.) And"},{"kind":"arabic","text_bw":"EaAqibN liA@moraA^apK","text_ar":"عَاقِبٌ لِا@مْرَاَةٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"One who is the last of the husbands of a woman."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"EaAqibapN mino TayorK","text_ar":"عَاقِبَةٌ مِنْ طَيْرٍ"},{"kind":"italic_en","text":"Birds succeeding one another, this alighting and flying, and then another alighting in the place where the former alighted."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A_ibilN EaAqibapN","text_ar":"اـِبِلٌ عَاقِبَةٌ"},{"kind":"italic_en","text":"Camels that betake themselves to plentiful pasture where they feed freely, after eating of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of plants called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"HamoD","text_ar":"حَمْض"},{"kind":"text","text":": [or] they are not so called unless they be"},{"kind":"italic_en","text":"camels that, in a severe year, eat of trees, and then of the"},{"kind":"arabic","text_bw":"HmD","text_ar":"حمض"},{"kind":"text","text":"; not when they pasture upon fresh, juicy, or tender, herbage. (IAar, TA.) And"},{"kind":"arabic","text_bw":"A_ibilN EawaAqibu","text_ar":"اـِبِلٌ عَوَاقِبُ"},{"kind":"italic_en","text":"Camels that drink water, and then return to the place where they lie down by the water, and then go to the water again."},{"kind":"text","text":"(IAar, S, O, K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EaAqibN","text_ar":"عَاقِبٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"A successor"},{"kind":"text","text":"of another"},{"kind":"italic_en","text":"in goodness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beneficence;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"EaquwbN","text_ar":"عَقُوبٌ","orth_type":"arrow"},{"kind":"text","text":". (O, K.) ―         -b4-  And"},{"kind":"italic_en","text":"A chief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lord:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one who is below the chief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lord:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"successor of the chief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lord."},{"kind":"text","text":"(S, K.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"EaqibN","text_ar":"عَقِبٌ"},{"kind":"text","text":", in two places."}],"source_refs":["S","O","Msb","TA"]}]},"classical_definitions":null}