 country"}, {"kind": "text", "text": "by his bravery]. (A.) ―         -b4-  See also"}, {"kind": "arabic", "text_bw": "vugorapN", "text_ar": "ثُغْرَةٌ"}, {"kind": "text", "text": ", in two places. ―         -b5-"}, {"kind": "arabic", "text_bw": "A^amosuwA vuguwrFA", "text_ar": "اَمْسُوا ثُغُورًا"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "They became dispersed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "scattered,"}, {"kind": "text", "text": "(JK, A, K,)"}, {"kind": "italic_en", "text": "and lost,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in a state of perdition:"}, {"kind": "text", "text": "(A, K:) sing."}, {"kind": "arabic", "text_bw": "vagorN", "text_ar": "ثَغْرٌ"}, {"kind": "text", "text": ". (JK, K.)"}], "source_refs": ["TA", "Msb", "K", "M", "T", "IAth", "JK", "A"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}