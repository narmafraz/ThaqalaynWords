{"lemma":"تَزَوُّدٌ","slug":"تَزَوُّدٌ","root":"ز.#.د","root_slug":"ز-_-د","root_link":"/words/roots/ز-_-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"تَزَوُّدٌ","root":"زود","pos":"V","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n18371"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B2%D9%8E%D9%88%D9%8F%D9%91%D8%AF%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18371","headword_ar":"تزوّد","root":"zwd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He became furnished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he furnished himself, with provisions for travelling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for a fixed residence;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared, for himself provisions"},{"kind":"text","text":"(S, * KL, TA)"},{"kind":"italic_en","text":"for travelling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for a fixed residence:"},{"kind":"text","text":"(TA: [Golius makes it to be trans. by means of"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"as on the authority of the KL; in which the only explanation, as that of the inf. n., is"},{"kind":"arabic","text_bw":"tw$h brGrftn","text_ar":"توشه برگرفتن"},{"kind":"text","text":":]) and"},{"kind":"italic_en","text":"he chose"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"as"},{"kind":"arabic","text_bw":"zaAd","text_ar":"زَاد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"provision"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for himself."},{"kind":"text","text":"(Har p. 92.) You say,"},{"kind":"arabic","text_bw":"tazaw~ada min~aA fulaAnN","text_ar":"تَزَوَّدَ مِنَّا فُلَانٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one was furnished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such a one furnished himself, with provisions from us"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"tzw~d lisafarihi","text_ar":"تزوّد لِسَفَرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was furnished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he furnished himself, with provisions for his journey"},{"kind":"text","text":"]. (Msb.) And see another ex. voce"},{"kind":"arabic","text_bw":"zaAdN","text_ar":"زَادٌ"},{"kind":"text","text":". You say also,"},{"kind":"arabic","text_bw":"tazaw~ada mina","text_ar":"تَزَوَّدَ مِنَ"},{"kind":"arabic","text_bw":"Ald~unoyaA liloA=xirapi","text_ar":"الدُّنْيَا لِلْا=خِرَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Take thou provisions from the present world,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"make thou provision in it, for the world to come"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"tazaw~ada","text_ar":"تَزَوَّدَ"},{"kind":"arabic","text_bw":"mina AlA^amiyri kitaAbFA liEaAmilihi","text_ar":"مِنَ الاَمِيرِ كِتَابًا لِعَامِلِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He provided himself with a letter from the commander,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"governor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prince, to his prefect"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"tazaw~ada","text_ar":"تَزَوَّدَ"},{"kind":"arabic","text_bw":"min~iY TaEonapF bayona A^u*unayohi","text_ar":"مِنِّى طَعْنَةً بَيْنَ اُذُنَيْهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He got from me a stab,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spear-wound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, between his ears"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":[]}]},"classical_definitions":null}