_2mp","form":"تَقَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَقَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَقَع","in_corpus":true,"count":108,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَقَع","in_corpus":true,"count":73,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقَعُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَقَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"وَقَعْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَقَعْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":519,"cross_references":{"qac":{"found":true,"lemma_key":"وَقَعَ","root":"وقع","pos":"V","occurrence_count":12},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":29},"lanes":{"found":true,"entry_ids":["n9739"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%82%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fall down, to fall"},{"pos":"verb","gloss":"to occur to the mind"},{"pos":"verb","gloss":"to alight [with عَلَى (ʕalā) ‘on a perch’] (of a bird)"},{"pos":"verb","gloss":"to kneel down"},{"pos":"verb","gloss":"to lie down"},{"pos":"verb","gloss":"to happen, to occur","examples":[{"text":"إِنَّمَا تُوعَدُونَ لَوَاقِعٌ","english":"Surely what you are promised will happen."}]},{"pos":"verb","gloss":"to be firm, solid, fortified"},{"pos":"verb","gloss":"to be necessary, incumbent, indispensable"},{"pos":"verb","gloss":"to run across, to meet with"},{"pos":"verb","gloss":"to arrive"},{"pos":"verb","gloss":"to consist"},{"pos":"verb","gloss":"to have sexual intercourse [with عَلَى (ʕalā) ‘with someone’] (of a man)"},{"pos":"verb","gloss":"to be located"},{"pos":"verb","gloss":"to hurry away, to depart"},{"pos":"verb","gloss":"to rush upon, to attack and fight"},{"pos":"verb","gloss":"to desist"},{"pos":"verb","gloss":"to intercede in favor of"},{"pos":"verb","gloss":"to sharpen"},{"pos":"verb","gloss":"to slander, to insult, to blacken the character of"},{"pos":"verb","gloss":"to apply"},{"pos":"verb","gloss":"to adjust, arrange"},{"pos":"verb","gloss":"to sign (put a signature onto) (عَن (ʕan) on behalf of)"},{"pos":"verb","gloss":"to seal (sign with a seal)"},{"pos":"verb","gloss":"to register"},{"pos":"verb","gloss":"to write down, put into writing"},{"pos":"noun","gloss":"verbal noun of وَقَعَ (waqaʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"falling, fall, blow, stroke"},{"pos":"noun","gloss":"event"},{"pos":"noun","gloss":"gravity of bearing or manners"}]},"etymology":null,"ipa":["/wa.qa.ʕa/","/waq.qa.ʕa/","/waqʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9739","headword_ar":"وَقَعَ","root":"HyS","body":[{"kind":"text","text":", (AA, S, A, and K in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"waqaEuwA","text_ar":"وَقَعُوا"},{"kind":"text","text":", (S,)"},{"kind":"arabic","text_bw":"fiY HayoSa bayoSa","text_ar":"فِى حَيْصَ بَيْصَ"},{"kind":"text","text":", (S, A, and K ubi suprà,) and"},{"kind":"arabic","text_bw":"HyS biySa","text_ar":"حيص بِيصَ"},{"kind":"text","text":", (S in this art. and in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":"; and so in the CK ubi suprà, and in a MS. copy of the K, [though app. contradicted by what follows in that work, as will be seen below,] or"},{"kind":"arabic","text_bw":"HiySi biySi","text_ar":"حِيصِ بِيصِ"},{"kind":"text","text":", (K ubi suprà, accord. to some copies, and so in the TA,) and"},{"kind":"arabic","text_bw":"HayoS bayoSi","text_ar":"حَيْص بَيْصِ"},{"kind":"text","text":", (K ubi suprà,) with fet-h to the first [letter] of each and to the last of each, (K ubi suprà,) and with kesr to the first of each, (S in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":",) or to both, and with fet-h to the first of each and kesr to the last of each; and sometimes each of the two [vars., namely,"},{"kind":"arabic","text_bw":"HayoS bayoS","text_ar":"حَيْص بَيْص"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HiyS biyS","text_ar":"حِيص بِيص"},{"kind":"text","text":",] is made perfectly decl. in the second [word], (K ubi suprà,) [so that you say also"},{"kind":"arabic","text_bw":"HayoSa bayoSK","text_ar":"حَيْصَ بَيْصٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HiySi biySK","text_ar":"حِيصِ بِيصٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HayoSi bayoSK","text_ar":"حَيْصِ بَيْصٍ"},{"kind":"text","text":"; (though the copies of the K differ in respect of these forms, two, for instance, giving one form, which is written"},{"kind":"arabic","text_bw":"HayoSK bayoSK","text_ar":"حَيْصٍ بَيْصٍ"},{"kind":"text","text":", and one adding"},{"kind":"arabic","text_bw":"HiySK biySK","text_ar":"حِيصٍ بِيصٍ"},{"kind":"text","text":";) for it is said,] the whole make six dial. vars.; and, accord. to MF, each of the two [vars.] is sometimes made perfectly decl. in the first [word] also, [so that you say"},{"kind":"arabic","text_bw":"HayoSK bayoSK","text_ar":"حَيْصٍ بَيْصٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HySK biySK","text_ar":"حيصٍ بِيصٍ"},{"kind":"text","text":",] but this he may have inferred from what will be afterwards mentioned on the authority of ISk, (TA in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"baASi","text_ar":"بَاصِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fiY HaASi","text_ar":"فِى حَاصِ","orth_type":"arrow"},{"kind":"text","text":", (K ubi suprà,) indecl., with kesr for the termination, the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"being [originally]"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; (TA ubi suprà;)"},{"kind":"italic_en","text":"He fell,"},{"kind":"text","text":"(S, K,) and"},{"kind":"italic_en","text":"they fell,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"into confusion in respect of their case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, from which there was no escape for them:"},{"kind":"text","text":"(S and K ubi suprà:) or"},{"kind":"italic_en","text":"into straitness and difficulty:"},{"kind":"text","text":"(S:)"},{"kind":"arabic","text_bw":"HayoSa bayoSa","text_ar":"حَيْصَ بَيْصَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HiySa biySa","text_ar":"حِيصَ بِيصَ"},{"kind":"text","text":"are each two nouns made into one, and made indecl. with fet-h for their termination, as in the instance of"},{"kind":"arabic","text_bw":"jaAriY bayota bayota","text_ar":"جَارِى بَيْتَ بَيْتَ"},{"kind":"text","text":": or, as some assert, they are two nouns, from"},{"kind":"arabic","text_bw":"HayoSN","text_ar":"حَيْصٌ"},{"kind":"text","text":"meaning the “ turning away, ” and “ retiring, ” or “ going back, ” and"},{"kind":"arabic","text_bw":"bawoSN","text_ar":"بَوْصٌ"},{"kind":"text","text":"meaning the “ outstripping, ” and “ fleeing; ” and"},{"kind":"arabic","text_bw":"bwS","text_ar":"بوص"},{"kind":"text","text":"is altered to assimilate it to"},{"kind":"arabic","text_bw":"HyS","text_ar":"حيص"},{"kind":"text","text":"; and the meaning is,"},{"kind":"italic_en","text":"an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a case,"},{"kind":"text","text":"of any kind,"},{"kind":"italic_en","text":"from which one retires,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goes back, and flees."},{"kind":"text","text":"(S.) You say also,"},{"kind":"arabic","text_bw":"jaEalotumu AlA^aroDa Ealayohi HayoSa bayoSa","text_ar":"جَعَلْتُمُ الاَرْضَ عَلَيْهِ حَيْصَ بَيْصَ"},{"kind":"text","text":", (S and K, both in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":",) or"},{"kind":"arabic","text_bw":"HiySa biySa","text_ar":"حِيصَ بِيصَ"},{"kind":"text","text":", (S ubi suprà,) and"},{"kind":"arabic","text_bw":"HayoSFA bayoSFA","text_ar":"حَيْصًا بَيْصًا"},{"kind":"text","text":", (ISk, and K ubi suprà,) with fet-h to each, and"},{"kind":"arabic","text_bw":"HiySFA biySFA","text_ar":"حِيصًا بِيصًا"},{"kind":"text","text":", with kesr to each, not compounded, (ISk, and TA ubi suprà,)"},{"kind":"italic_en","text":"Ye have straitened"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"(S and K ubi suprà,)"},{"kind":"italic_en","text":"so that he may not act as he pleases therein:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"so that he may not travel therein in search of sustenance, nor employ himself as he would to make gain."},{"kind":"text","text":"(Nh.) And"},{"kind":"arabic","text_bw":"A_in~aka lataHosibu EalaY~a AlA^aroDa HayoSFA bayoSFA","text_ar":"اـِنَّكَ لَتَحْسِبُ عَلَىَّ الاَرْضَ حَيْصًا بَيْصًا"},{"kind":"text","text":", or, as some say,"},{"kind":"arabic","text_bw":"HySi bySi","text_ar":"حيصِ بيصِ"},{"kind":"text","text":", [i. e.,"},{"kind":"arabic","text_bw":"HayoSi bayoSi","text_ar":"حَيْصِ بَيْصِ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"HiySi biySi","text_ar":"حِيصِ بِيصِ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"Verily thou thinkest the earth to be straitened to me, so that I may not act as I please therein:"},{"kind":"text","text":"&c.] (S.) ―         -b2-"},{"kind":"arabic","text_bw":"HayoSa bayoSa","text_ar":"حَيْصَ بَيْصَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"The hole of the rat"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mouse."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"byS","text_ar":"بيص"},{"kind":"text","text":".)"}],"source_refs":["S","K"]}]}}