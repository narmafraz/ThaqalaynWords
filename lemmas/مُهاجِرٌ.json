{"lemma":"مُهاجِرٌ","slug":"مُهاجِرٌ","root":"ه.ج.ر","root_slug":"ه-ج-ر","root_link":"/words/roots/ه-ج-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُهاجِر","root":"هجر","pos":"N","occurrence_count":7},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n40955","n40956"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%87%D8%A7%D8%AC%D9%90%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"migrant, immigrant"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of هَاجَرَ (hājara)."},"ipa":["/mu.haː.d͡ʒir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40955","headword_ar":"مُهَاجَرٌ","root":"hjr","body":[{"kind":"italic_en","text":"A place to which one emigrates."},{"kind":"text","text":"(Msb.)"}],"source_refs":[]},{"entry_id":"n40956","headword_ar":"مُهَاجِرٌ","root":"hjr","body":[{"kind":"text","text":"Any one, whether an inhabitant of the desert [as in the primary acceptation of the epithet] or an inhabitant of a town or village or cultivated district,"},{"kind":"italic_en","text":"who emigrates;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who forsakes his country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and takes up his abode in another country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"district"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"Hence"},{"kind":"arabic","text_bw":"AlmuhaAjiruwna","text_ar":"المُهَاجِرُونَ"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"The emigrants"},{"kind":"text","text":"to El-Medeeneh: because they forsook their places of abode in which they were reared, for the sake of God, and attached themselves to an abode in which they had neither family nor property, when they emigrated to El-Medeeneh. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}