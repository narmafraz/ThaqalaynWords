oss_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n11834","n11835"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%B7%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11834","headword_ar":"خَاطَ","root":"xyT","body":[{"kind":"text","text":", (Msb, TA,) first pers."},{"kind":"arabic","text_bw":"xiTotu","text_ar":"خِطْتُ"},{"kind":"text","text":", (S,) aor."},{"kind":"arabic","text_bw":"yaxiyTu","text_ar":"يَخِيطُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xiyaATapN","text_ar":"خِيَاطَةٌ"},{"kind":"text","text":", (S, TA,) or this is a simple subst., (Msb, TK,) and the inf. n. is"},{"kind":"arabic","text_bw":"xayoTN","text_ar":"خَيْطٌ"},{"kind":"text","text":", (TK,) which is said in the K to be syn. with"},{"kind":"arabic","text_bw":"xiyaATapN","text_ar":"خِيَاطَةٌ"},{"kind":"text","text":", but this last is a mistake for"},{"kind":"arabic","text_bw":"xiyaATN","text_ar":"خِيَاطٌ"},{"kind":"text","text":"as signifying “thread,” (TA,) or “a thread,” (AZ, TA,) though"},{"kind":"arabic","text_bw":"xiyaATN","text_ar":"خِيَاطٌ"},{"kind":"text","text":"is also syn. with"},{"kind":"arabic","text_bw":"xiyaATapN","text_ar":"خِيَاطَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He sewed, sewed together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sewed up,"},{"kind":"text","text":"a garment, or piece of cloth; (S, Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"xy~Thu","text_ar":"خيّطهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoyiyTN","text_ar":"تَخْيِيطٌ"},{"kind":"text","text":". (TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"xaATa baEiyrFA","text_ar":"خَاطَ بَعِيرًا"},{"kind":"arabic","text_bw":"bibaEiyrK","text_ar":"بِبَعِيرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He coupled a camel with a camel"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by tying the end of the halter of one to the tail of the other"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"xaATati AlHay~apu","text_ar":"خَاطَتِ الحَيَّةُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"xayoTN","text_ar":"خَيْطٌ"},{"kind":"text","text":", (K, TA,) (tropical:)"},{"kind":"italic_en","text":"The serpent ran along upon the ground."},{"kind":"text","text":"(K, * TA.) ―         -b4-  ↓"},{"kind":"arabic","text_bw":"xAT A_ilayohi xayoTapF","text_ar":"خاط اـِلَيْهِ خَيْطَةً","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He passed by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"once:"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"xAT xayoTapF","text_ar":"خاط خَيْطَةً","orth_type":"arrow"},{"kind":"italic_en","text":"he passed along quickly:"},{"kind":"text","text":"(K, * TA:) and so ↓"},{"kind":"arabic","text_bw":"AxtAT","text_ar":"اختاط","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AixotaTaY","text_ar":"اِخْتَطَى"},{"kind":"text","text":". (K.) It is said by Kr to be formed by transposition from"},{"kind":"arabic","text_bw":"AlxaTowu","text_ar":"الخَطْوُ"},{"kind":"text","text":": but this is a mistake; for, were it so, they would have said,"},{"kind":"arabic","text_bw":"xAT xawoTapF","text_ar":"خاط خَوْطَةً"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"xayoTapF","text_ar":"خَيْطَةً"},{"kind":"text","text":". (ISd.) Accord. to Lth,"},{"kind":"arabic","text_bw":"waAHidapF","text_ar":"وَاحِدَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xAT xayoTapF","text_ar":"خاط خَيْطَةً","orth_type":"arrow"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"He made his journey"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a journey"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without interruption."},{"kind":"text","text":"(TA.) In the A it is said that ↓"},{"kind":"arabic","text_bw":"xAT fulaAnN xayoTapF","text_ar":"خاط فُلَانٌ خَيْطَةً","orth_type":"arrow"},{"kind":"text","text":"means (tropical:)"},{"kind":"italic_en","text":"Such a one journeyed on, not pausing for anything:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"xAT A_ilaY maqoSidihi","text_ar":"خاط اـِلَى مَقْصِدِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He journeyed on, not pausing for anything, to his place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"object, of aim"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb","TA","S","TK","AZ","K"]},{"entry_id":"n11835","headword_ar":"خَاطٌ","root":"xyT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xay~aATN","text_ar":"خَيَّاطٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}