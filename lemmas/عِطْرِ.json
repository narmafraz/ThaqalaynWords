 A, O, K:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEoTaArN","text_ar":"اَعْطَارٌ"},{"kind":"text","text":"(A) and [of mult.]"},{"kind":"arabic","text_bw":"EuTuwrN","text_ar":"عُطُورٌ"},{"kind":"text","text":". (A, O, K.) [And ↓"},{"kind":"arabic","text_bw":"EiTaArapN","text_ar":"عِطَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", as used in the present day, and in medical books, signifies"},{"kind":"italic_en","text":"Perfumes"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"drugs:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"SiyodalapN","text_ar":"صِيْدَلَةٌ"},{"kind":"text","text":".] ―         -b2-  ["},{"kind":"arabic","text_bw":"EiToru AlA^amapi","text_ar":"عِطْرُ الاَمَةِ"},{"kind":"italic_en","text":"A certain berb:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"*afirN","text_ar":"ذَفِرٌ"},{"kind":"text","text":".]"}],"source_refs":["S","A","O","K"]},{"entry_id":"n29531","headword_ar":"عَطِرٌ","root":"ETr","body":[{"kind":"text","text":", applied to a man, (K, TA,) and"},{"kind":"arabic","text_bw":"EaTirapN","text_ar":"عَطِرَةٌ"},{"kind":"text","text":", applied to a woman, (S, A, O, Msb, K,)"},{"kind":"italic_en","text":"Having perfume upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"using perfume for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfuming,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"himself,"},{"kind":"text","text":"and]"},{"kind":"italic_en","text":"herself;"},{"kind":"text","text":"(S, O;) and ↓"},{"kind":"arabic","text_bw":"mutaEaT~irapN","text_ar":"مُتَعَطِّرَةٌ","orth_type":"arrow"},{"kind":"text","text":", applied to a woman, (S, K,) signifies the same. (S) [See also"},{"kind":"arabic","text_bw":"EaATirN","text_ar":"عَاطِرٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"muEaT~arapN","text_ar":"مُعَطَّرَةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"miEoTiyrN","text_ar":"مِعْطِيرٌ"},{"kind":"text","text":