esent_3fd","form":"تُصْحَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْحُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصْحَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَصْحُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصْح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُصْحَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصْحَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْحُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْحُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَحَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَحَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":49,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n23842"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AD%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wake up, to awake","examples":[{"text":"أَصْحُو مُبَكِّرًا.","english":"I wake up early."}]},{"pos":"verb","gloss":"to come to, to regain consciousness"},{"pos":"verb","gloss":"to sober up, to regain sobriety"},{"pos":"verb","gloss":"to be alerted (to), to become aware (of)"},{"pos":"verb","gloss":"to be clear, bright, sunny"},{"pos":"verb","gloss":"to clear up, to become clear, bright, sunny"}]},"etymology":null,"ipa":["/sˤa.ħaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23842","headword_ar":"صَحَا","root":"SHw","body":[{"kind":"text","text":", said of a day, [aor."},{"kind":"arabic","text_bw":"yaSoHuw","text_ar":"يَصْحُو"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cloudless:"},{"kind":"text","text":"(TA:) and so ↓"},{"kind":"arabic","text_bw":"A^aSoHaY","text_ar":"اَصْحَى","orth_type":"arrow"},{"kind":"text","text":": (Msb, K, TA, but not in the CK:) [it is said that]"},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"departing of the clouds:"},{"kind":"text","text":"(S, Mgh, K:) [but] Es-Sijistánee says that the vulgar think it to have this meaning, whereas it only means the dispersing of the clouds with the departing of the cold. (Msb, TA.) And"},{"kind":"arabic","text_bw":"Als~amaA='u","text_ar":"السَّمَا=ءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aSoHati","text_ar":"اَصْحَتِ","orth_type":"arrow"},{"kind":"italic_en","text":"The sky became cloudless."},{"kind":"text","text":"(Ks, S, Mgh, Msb, K, TA, but not in the CK.) ―         -b2-  And"},{"kind":"arabic","text_bw":"SaHaA mino sukorihi","text_ar":"صَحَا مِنْ سُكْرِهِ"},{"kind":"text","text":", (S, Msb,) aor."},{"kind":"arabic","text_bw":"yaSoHuw","text_ar":"يَصْحُو"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"SuHuw~N","text_ar":"صُحُوٌّ"},{"kind":"text","text":", (Msb,) ["},{"kind":"italic_en","text":"He recovered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became free, from his intoxication;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"his intoxication ceased;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"ASHY","text_ar":"اصحى","orth_type":"arrow"},{"kind":"text","text":": (Msb:) and"},{"kind":"arabic","text_bw":"SaHiYa","text_ar":"صَحِىَ"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"SaHFA","text_ar":"صَحًا"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"ASHY","text_ar":"اصحى","orth_type":"arrow"},{"kind":"text","text":"; (IKtt, K, TA;) is [likewise] said of one intoxicated; (K, TA;) both meaning"},{"kind":"italic_en","text":"he recovered from his state of insensibility;"},{"kind":"text","text":"(TA;) and in like manner both are said of one affected with desire, or yearning or longing in the soul; (K, TA;) [and also of one sleeping, meaning"},{"kind":"italic_en","text":"he awoke:"},{"kind":"text","text":"see an ex. of the former of these two verbs in this last sense in the latter part of the second paragraph of art."},{"kind":"arabic","text_bw":"frT","text_ar":"فرط"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"signifies also (tropical:)  The"},{"kind":"italic_en","text":"relinquishing of youthful folly, and amorous dalliance, and of what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"futile."},{"kind":"text","text":"(K, TA.) Hence the saying of a poet,"},{"kind":"quote","text":"SaHaA Alqalobu Eano salomaY waA^aqoSara baATiluho"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The heart relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has relinquished, youthful folly and amorousness by becoming rid of Selmà, and its vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"futile, occupation ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has ceased"},{"kind":"text","text":"]. (TA.) ―         -b4-  And one says,"},{"kind":"arabic","text_bw":"SaHati AlEaA*ilapu","text_ar":"صَحَتِ العَاذِلَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The censuring female relinquished censuring."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","S","Mgh","K","Msb"]}]}}