esent_3fd","form":"تُصْحَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْحُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُصْحَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَصْحُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَصْح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْح","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصْحَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصْحَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْحُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْحُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"صَحَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَحَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":49,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n23842"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AD%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wake up, to awake","examples":[{"text":"أَصْحُو مُبَكِّرًا.","english":"I wake up early."}]},{"pos":"verb","gloss":"to come to, to regain consciousness"},{"pos":"verb","gloss":"to sober up, to regain sobriety"},{"pos":"verb","gloss":"to be alerted (to), to become aware (of)"},{"pos":"verb","gloss":"to be clear, bright, sunny"},{"pos":"verb","gloss":"to clear up, to become clear, bright, sunny"}]},"etymology":null,"ipa":["/sˤa.ħaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23842","headword_ar":"صَحَا","root":"SHw","body":[{"kind":"text","text":", said of a day, [aor."},{"kind":"arabic","text_bw":"yaSoHuw","text_ar":"يَصْحُو"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cloudless:"},{"kind":"text","text":"(TA:) and so ↓"},{"kind":"arabic","text_bw":"A^aSoHaY","text_ar":"اَصْحَى","orth_type":"arrow"},{"kind":"text","text":": (Msb, K, TA, but not in the CK:) [it is said that]"},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"departing of the clouds:"},{"kind":"text","text":"(S, Mgh, K:) [but] Es-Sijistánee says that the vulgar think it to have this meaning, whereas it only means the dispersing of the clouds with the departing of the cold. (Msb, TA.) And"},{"kind":"arabic","text_bw":"Als~amaA='u","text_ar":"السَّمَا=ءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aSoHati","text_ar":"اَصْحَتِ","orth_type":"arrow"},{"kind":"italic_en","text":"The sky became cloudless."},{"kind":"text","text":"(Ks, S, Mgh, Msb, K, TA, but not in the CK.) ―         -b2-  And"},{"kind":"arabic","text_bw":"SaHaA mino sukorihi","text_ar":"صَحَا مِنْ سُكْرِهِ"},{"kind":"text","text":", (S, Msb,) aor."},{"kind":"arabic","text_bw":"yaSoHuw","text_ar":"يَصْحُو"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"SuHuw~N","text_ar":"صُحُوٌّ"},{"kind":"text","text":", (Msb,) ["},{"kind":"italic_en","text":"He recovered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became free, from his intoxication;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"his intoxication ceased;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"ASHY","text_ar":"اصحى","orth_type":"arrow"},{"kind":"text","text":": (Msb:) and"},{"kind":"arabic","text_bw":"SaHiYa","text_ar":"صَحِىَ"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"SaHFA","text_ar":"صَحًا"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"ASHY","text_ar":"اصحى","orth_type":"arrow"},{"kind":"text","text":"; (IKtt, K, TA;) is [likewise] said of one intoxicated; (K, TA;) both meaning"},{"kind":"italic_en","text":"he recovered from his state of insensibility;"},{"kind":"text","text":"(TA;) and in like manner both are said of one affected with desire, or yearning or longing in the soul; (K, TA;) [and also of one sleeping, meaning"},{"kind":"italic_en","text":"he awoke:"},{"kind":"text","text":"see an ex. of the former of these two verbs in this last sense in the latter part of the second paragraph of art."},{"kind":"arabic","text_bw":"frT","text_ar":"فرط"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"SaHowN","text_ar":"صَحْوٌ"},{"kind":"text","text":"signifies also (tropical:)  The"},{"kind":"italic_en","text":"relinquishing of youthful folly, and amorous dalliance, and of what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"futile."},{"kind":"text","text":"(K, TA.) Hence the saying of a poet,"},{"kind":"quote","text":"SaHaA Alqalobu Eano salomaY waA^aqoSara baATiluho"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The heart relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has relinquished, youthful folly and amorousness by becoming rid of Selmà, and its vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"futile, occupation ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has ceased"},{"kind":"text","text":"]. (TA.) ―         -b4-  And one says,"},{"kind":"arabic","text_bw":"SaHati AlEaA*ilapu","text_ar":"صَحَتِ العَاذِلَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The censuring female relinquished censuring."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","S","Mgh","K","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B5%D8%AD%D8%A7/","headword_ar":"صحا","entries":[{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=9115#222281","body_html":"<span class=\"title1\">ص ح ا</span><span>: (صَحَا) مِنْ سُكْرِهِ مِنْ بَابِ عَدَا فَهُوَ (صَاحٍ) . وَ (الصَّحْوُ) أَيْضًا ذَهَابُ الْغَيْمِ وَالْيَوْمُ صَاحٍ. وَ (أَصْحَتِ) السَّمَاءُ انْقَشَعَ عَنْهَا الْغَيْمُ فَهِيَ (مُصْحِيَةٌ) ، وَقَالَ الْكِسَائِيُّ: فَهِيَ (صَحْوٌ) وَلَا تَقُلْ: مُصْحِيَةٌ. وَ (أَصْحَيْنَا) أَيْ أَصْحَتْ لَنَا السَّمَاءُ. </span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=9115#cdda89","body_html":"<span class=\"title1\">[صحا]</span><span> المصحاة: إناء. قال الاصمعي: لا أدرى من أي شئ هو. قال الاعشى: بكأسٍ وإبريقٍ كَأَنَّ شَرابَهُ * إذا صُبَّ في المِصْحاةِ خالَطَ بَقَّما </span><a></a><span>وصحا من سكره صحوا ; والسكران صاح. والصَحْوُ أيضاً: ذَهاب الغيم. واليومُ صاحٍ. وأَصْحَتِ السماءُ، أي انقشع عنها الغَيْم، فهي مُصْحِيَةٌ. وقال الكسائي: فهي صَحْوٌ، ولا تقل مُصْحِيَةٌ. وأَصْحَيْنا، أي أَصْحَتِ لنا السماء.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=9115#72fc89","body_html":"<p>صحا: الصَّحْوُ: ذهابُ الغَيْم، يومٌ صحوٌ وسَماءٌ صحوٌ، واليومُ</p><p>صاحٍ. وقد أَصْحَيا وأَصْحَيْنا أَي أَصْحتْ لنا السماء. وأَصحَت</p><p>السماءُ، فهي مُصْحِيةٌ: انْقَشَع عنها الغَيْم، وقال الكسائي: فهي صَحْوٌ قال:</p><p>ولا تَقُلْ مُصْحِيةٌ، قال ابن بري: يقال أَصْحَت السماء، فهي</p><p>مُصحِيَةٌ، ويقال: يومٌ مُصْحٍ. وصحا السَّكْرانُ لا غَيْرُ. قال: وأَما العاذِلة</p><p>فيقال فيها أَصحَت وصحَتْ، فيُشبَّه ذهابُ العَقْل عنْها تارةً بذهاب</p><p>الغَيم وتارة بذهاب السُّكْر، وأَما الإِفاقة عن الحُبِّ فلم يُسمَع فيه</p><p>إِلاَّ صحَا مثل السُّكْر؛ قال جرير:</p><p>أَتَصحُو أَم فؤَادُكَ غيرُ صاحِ؟</p><p>ويقال: صَحْوان مثلُ سكْران؛ قال الرحَّال وهو عمرو بن النعمان بنِ</p><p>البراء:</p><p>بان الخَليطُ، ولم أَكُنْ صَحْوانا</p><p>دَنفاً بزَيْنَبَ، لو تُريدُ هَوانا</p><p>والصَّحْوُ: ارْتِفاعُ النهارِ؛ قال سُوَيْد:</p><p>تَمْنَحُ المِرْآةَ وَجْهاً واضِحاً،</p><p>مثلَ قَرْنِ الشمس في الصَّحْوِ ارْتَفَعْ</p><p>والصَّحْوُ: ذَهابُ السُّكْرِ وتَرْكُ الصِّبا والباطلِ. يقال: صَحَا</p><p>قلبهُ. وصَحا السكرانُ من سُكْرِه يَصْحُو صَحْواً وصُحُوّاً، فهو صاحٍ،</p><p>وأَصْحَى: ذَهَب سُكْرُه، وكذلك المُشْتاقُ؛ قال:</p><p>صُحُوَّ ناشِي الشَّوْقِ مُسْتَبِلِّ</p><p>والعرب تقول: ذَهَبَ بين الصَّحْوِ والسَّكْرَةِ أَي بين أَنْ يَعْقِلَ</p><p>ولا يَعْقِلَ. ابن بُزُرْج: من أَمثالهم يريدُ أَن يأْخذَها بين</p><p>السَّكْرَةِ والصَّحْوَةِ، مَثلٌ لطالبِ الأَمْرِ يَتجاهَلُ وهو يعلم.</p><p>والمِصْحاة: جامٌ يُشْرَبُ فيه. وقال أَبو عبيدة: المِصْحاة إناءٌ، قال:</p><p>ولا أَدرِي من أَيِّ شيءٍ هو؛ قال الأَعشى:</p><p>بكَأْسٍ وإبْرِيقٍ كأَنّ شَرابَهُ،</p><p>إذا صُبَّ في المِصْحاةِ، خالَطَ بَقَّمَا</p><p>وقيل: هو الطاسُ. ابن الأَعرابي: المِصْحاةُ الكَأْسُ، وقيل: هو القَدَح</p><p>من الفِضةِ؛ واحْتَجَّ بقول أَوْسٍ:</p><p>إذا سُلّ مِن جَفْنٍ تَأَكَّلَ أَثْرُه،</p><p>على مِثل مِصْحاةِ اللُّجَين، تأَكُّلا</p><p>قال: شَبَّهَ نَقاءَ حَديدة السيفِ بنَقاءِ الفِضةِ. قال ابن بري:</p><p>المِصْحاةُ إناءٌ مِن فِضةٍ قد صَحَا من الأَدْناسِ والأَكْدارِ لِنقاءِ</p><p>الفِضةِ؛ وقي النهاية في تَرْجَمَة مَصَحَ: دَخَلَتْ عليه أُم حَبيبةَ وهو</p><p>مَحْضُورٌ كأَنَّ وجهَه مِصحاةٌ.</p>"}]}}