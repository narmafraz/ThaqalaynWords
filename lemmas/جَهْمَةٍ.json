{"lemma":"جَهْمَةٍ","slug":"جَهْمَةٍ","root":"ج.ه.م","root_slug":"ج-ه-م","root_link":"/words/roots/ج-ه-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n6600","n6601"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%87%D9%92%D9%85%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6600","headword_ar":"جَهْمَةٌ","root":"jhm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"juhomapN","text_ar":"جُهْمَةٌ"},{"kind":"text","text":", in two places.       -A2-  Also"},{"kind":"italic_en","text":"A big cooking-pot."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n6601","headword_ar":"جُهْمَةٌ","root":"jhm","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jahomapN","text_ar":"جَهْمَةٌ","orth_type":"arrow"},{"kind":"text","text":", (JK, S, K,) both mentioned by Fr, (S,)"},{"kind":"italic_en","text":"A portion of the night:"},{"kind":"text","text":"(JK:) the"},{"kind":"italic_en","text":"first of the last portions of the night,"},{"kind":"text","text":"(JK, S, K, TA,)"},{"kind":"italic_en","text":"extending"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"from midnight"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to near the period a little before daybreak:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"remaining portion of the darkness of the last part of the night:"},{"kind":"text","text":"(K:) or the former signifies, [or each,] the"},{"kind":"italic_en","text":"beginning of the night, extending to a fourth part:"},{"kind":"text","text":"or, as some say, the"},{"kind":"italic_en","text":"middle of the night:"},{"kind":"text","text":"(KL:) pl. of the former"},{"kind":"arabic","text_bw":"juhamN","text_ar":"جُهَمٌ"},{"kind":"text","text":". (JK.) You say,"},{"kind":"arabic","text_bw":"maDaY mina All~ayoli juhomapN","text_ar":"مَضَى مِنَ اللَّيْلِ جُهْمَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jahomapN","text_ar":"جَهْمَةٌ","orth_type":"arrow"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"A portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a portion at the commencement of the latter part, of the night passed"},{"kind":"text","text":"]. (A'Obeyd, TA.)       -A2-  Also the former,"},{"kind":"italic_en","text":"Eighty camels:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(K.)"}],"source_refs":["JK","S","K","TA","KL"]}]},"classical_definitions":null}