thers in going round."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"italic_en","text":"Want:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty, of life;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"HawofN","text_ar":"حَوْفٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["TA","S","Msb","K"]}]},"classical_definitions":null}