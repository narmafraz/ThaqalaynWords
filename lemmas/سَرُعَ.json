tions":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be quick, to hurry"},{"pos":"verb","gloss":"to hasten, to quicken (e.g. a pace)","tags":["transitive"]},{"pos":"verb","gloss":"to urge on"},{"pos":"verb","gloss":"to speed up, cause to hurry","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of سَرُعَ (saruʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"haste, hurry"},{"pos":"noun","gloss":"verbal noun of سَرُعَ (saruʕa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"haste, hurry"}]},"etymology":{"source":"wiktextract","text":"Causative of سَرُعَ (saruʕa, “to be quick, to hurry”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19582","headword_ar":"سَرُعَ","root":"srE","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"siraEN","text_ar":"سِرَعٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"saraEN","text_ar":"سَرَعٌ"},{"kind":"text","text":"(TA [and mentioned in the K, but app. as a simple subst.,]) and"},{"kind":"arabic","text_bw":"siroEN","text_ar":"سِرْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saroEN","text_ar":"سَرْعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"saraAEapN","text_ar":"سَرَاعَةٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"suroEapN","text_ar":"سُرْعَةٌ"},{"kind":"text","text":", (K,) or this last is a simple subst. from"},{"kind":"arabic","text_bw":"A^asoraEa","text_ar":"اَسْرَعَ"},{"kind":"text","text":", (Msb,) [but it is also generally used as syn. with the inf. ns. before mentioned when they are employed as simple substs., and is more common than any of them,]"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was quick, expeditious, hasty, speedy, rapid, swift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fleet:"},{"kind":"text","text":"[in course, tendency, action, speech, &c.:] (S, K:) or, said of a man,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^asoraEa","text_ar":"اَسْرَعَ"},{"kind":"text","text":"[which may mean as above, or"},{"kind":"italic_en","text":"he hastened, made haste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sped,"},{"kind":"text","text":"] in his speech and in his actions: (IAar, TA:) but Sb makes a difference between"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^asoraEa","text_ar":"اَسْرَعَ"},{"kind":"text","text":": see the latter below: (TA:) one says also"},{"kind":"arabic","text_bw":"sariEa","text_ar":"سَرِعَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; a dial. var. of"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"tsr~E","text_ar":"تسرّع","orth_type":"arrow"},{"kind":"text","text":", said of an affair, or event, signifies the same as"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"Als~iraEa Als~iraEa","text_ar":"السِّرَعَ السِّرَعَ"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"AlwaHaA='a","text_ar":"الوَحَا=ءَ"},{"kind":"arabic","text_bw":"AlwaHaA='a","text_ar":"الوَحَا=ءَ"},{"kind":"text","text":", (S, K,) i. e. [Make thou]"},{"kind":"italic_en","text":"haste;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"haste to be first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beforehand: haste;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"haste to be first,"},{"kind":"text","text":"&c. (S and TA in art."},{"kind":"arabic","text_bw":"wHY","text_ar":"وحى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"saruEa maA faEalota *aAka","text_ar":"سَرُعَ مَا فَعَلْتَ ذَاكَ"},{"kind":"text","text":", (S, * TA,) and"},{"kind":"arabic","text_bw":"saroEa","text_ar":"سَرْعَ"},{"kind":"text","text":", which is a contraction of the former; for the Arabs contract by the suppression of dammeh and kesreh because they are difficult of pronunciation, saying"},{"kind":"arabic","text_bw":"faxo*N","text_ar":"فَخْذٌ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"faxi*N","text_ar":"فَخِذٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaDodN","text_ar":"عَضْدٌ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"EaDodN","text_ar":"عَضْدٌ"},{"kind":"text","text":", but one should not say"},{"kind":"arabic","text_bw":"HajorN","text_ar":"حَجْرٌ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"HajarN","text_ar":"حَجَرٌ"},{"kind":"text","text":", (S, TA,) or the like, accord. to the Basrees, though the Koofees allow the contraction in the case of fet-hah also, as in"},{"kind":"arabic","text_bw":"salofa","text_ar":"سَلْفَ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"salafa","text_ar":"سَلَفَ"},{"kind":"text","text":"; (M in art."},{"kind":"arabic","text_bw":"slf","text_ar":"سلف"},{"kind":"text","text":";) and one says also"},{"kind":"arabic","text_bw":"suroEa","text_ar":"سُرْعَ"},{"kind":"text","text":", as a contraction of"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":"; all meaning"},{"kind":"arabic","text_bw":"saroEaAna","text_ar":"سَرْعَانَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Quick was thy doing that:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"how quick was thy doing that!"},{"kind":"text","text":"or, which is nearly the same,"},{"kind":"italic_en","text":"excellently quick was thy doing that;"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"saruEa","text_ar":"سَرُعَ"},{"kind":"text","text":"is similar to"},{"kind":"arabic","text_bw":"qaDuwa","text_ar":"قَضُوَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ramuwa","text_ar":"رَمُوَ"},{"kind":"text","text":", denoting excellence]. (TA.)"}],"source_refs":["S","Msb","K","TA","IAar"]}]}}