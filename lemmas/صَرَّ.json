{"role":"present_2mp","form":"تَصِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصِرُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصِرّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَصْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصِرّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَصْرِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصِرّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصِرّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصِرُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصِرُّوا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْرِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصِرّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصِرّ","in_corpus":true,"count":303,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَرَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَرَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":333,"cross_references":{"qac":{"found":true,"lemma_key":"صَرَّ","root":"صرر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n24064"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tie up, to bind, to pack"},{"pos":"verb","gloss":"to screech, to squeak, to chirp","examples":[{"text":"صَرَّ أَسْنَانَهُ","english":"to grit one's teeth"}]}]},"etymology":null,"ipa":["/sˤar.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24064","headword_ar":"صَرَّ","root":"Sr","body":[{"kind":"text","text":", (S, A, TA,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"SariyrN","text_ar":"صَرِيرٌ"},{"kind":"text","text":", said of the"},{"kind":"arabic","text_bw":"junodab","text_ar":"جُنْدَب"},{"kind":"text","text":"[which is app. a species of locust], and of a writing-reed, and of a door, (S, A, TA,) or of a dog-tooth, ("},{"kind":"arabic","text_bw":"nAb","text_ar":"ناب"},{"kind":"text","text":", so in a copy of the S in the place of"},{"kind":"arabic","text_bw":"bAb","text_ar":"باب"},{"kind":"text","text":"in other copies as in the A and TA,)"},{"kind":"italic_en","text":"It made a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noise;"},{"kind":"text","text":"(S, A, TA;) or"},{"kind":"italic_en","text":"a prolonged sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noise;"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"it creaked;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a creaking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grating, sound;"},{"kind":"text","text":"] and so anything that makes a similar prolonged sound: and [in like manner] ↓"},{"kind":"arabic","text_bw":"AiSoTar~at","text_ar":"اِصْطَرَّت","orth_type":"arrow"},{"kind":"text","text":"said of a mast ("},{"kind":"arabic","text_bw":"saAriyap","text_ar":"سَارِيَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"it creaked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made a creaking sound:"},{"kind":"text","text":"(TA:) but when there is a lightness, or slightness, and reiteration, of the sound, they use the reduplicative form, ↓"},{"kind":"arabic","text_bw":"SaroSara","text_ar":"صَرْصَرَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SaroSarapN","text_ar":"صَرْصَرَةٌ"},{"kind":"text","text":", (S, * TA,) signifying"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(the bird called"},{"kind":"arabic","text_bw":"A^axoTab","text_ar":"اَخْطَب"},{"kind":"text","text":", S, A, TA, and the hawk, or falcon, S, M, TA, or other bird, or flying thing, M)"},{"kind":"italic_en","text":"uttered his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"reiterated quavering"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"cry;"},{"kind":"text","text":"(S, M, A, TA;) as though they imitated prolongation in the cry of the"},{"kind":"arabic","text_bw":"junodab","text_ar":"جُنْدَب"},{"kind":"text","text":"[and the like], and reiteration in the cry of the"},{"kind":"arabic","text_bw":"A^axoTab","text_ar":"اَخْطَب"},{"kind":"text","text":"[and the like thereof]. (S, TA.)"},{"kind":"arabic","text_bw":"Sar~a Aljunodabu","text_ar":"صَرَّ الجُنْدَبُ"},{"kind":"text","text":"is a prov., expl. in art."},{"kind":"arabic","text_bw":"jdb","text_ar":"جدب"},{"kind":"text","text":"[q. v.]. (TA in that art.) ―         -b2-  Also"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a sparrow) ["},{"kind":"italic_en","text":"chirped,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"uttered a cry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SariyrN","text_ar":"صَرِيرٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"SaroSara","text_ar":"صَرْصَرَ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He cried, called out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raised a cry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clamour,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"with vehemence,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"with the utmost vehemence:"},{"kind":"text","text":"(M:) and [in like manner] one says, ↓"},{"kind":"arabic","text_bw":"jaA='a yaSoTar~u","text_ar":"جَا=ءَ يَصْطَرُّ","orth_type":"arrow"},{"kind":"italic_en","text":"He came"},{"kind":"text","text":"["},{"kind":"italic_en","text":"making a clamour,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"in clamour."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"arabic","text_bw":"SimaAxuhu","text_ar":"صِمَاخُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SariyrN","text_ar":"صَرِيرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"His ear-hole sounded,"},{"kind":"text","text":"(M, K,) or"},{"kind":"italic_en","text":"tingled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rang,"},{"kind":"text","text":"(A,) by reason of thirst. (M, A, K.) And"},{"kind":"arabic","text_bw":"Sar~ati AlA^u*unu","text_ar":"صَرَّتِ الاُذُنُ"},{"kind":"italic_en","text":"The ear tingled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rang."},{"kind":"text","text":"(ISk, A.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"text","text":", aor. as above,"},{"kind":"italic_en","text":"He thirsted"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"so as to hear a ringing in his ears"},{"kind":"text","text":"]. (IAar.)       -A2-"},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":"[as inf. n. of"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"text","text":"] also signifies The act of"},{"kind":"italic_en","text":"binding"},{"kind":"text","text":"[a captive, &c.: see the pass. part. n.,"},{"kind":"arabic","text_bw":"maSoruwrN","text_ar":"مَصْرُورٌ"},{"kind":"text","text":"]. (Mgh.) ―         -b2-  You say,"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] (S, M, A,) inf. n."},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":", (M, TA,)"},{"kind":"italic_en","text":"He tied up"},{"kind":"text","text":"a purse, (S, M, * TA,) and money in a purse. (A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Sar~aAln~aAqapa","text_ar":"صَرَّالنَّاقَةَ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"biAln~aAqapi","text_ar":"بِالنَّاقَةِ"},{"kind":"text","text":", (M, K,) or"},{"kind":"arabic","text_bw":"Sar~a Aln~aAqapa biAlS~iraAri","text_ar":"صَرَّ النَّاقَةَ بِالصِّرَارِ"},{"kind":"text","text":", (Msb,) aor."},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":"; (M, K;) [and app. ↓"},{"kind":"arabic","text_bw":"Sar~arahaA","text_ar":"صَرَّرَهَا","orth_type":"arrow"},{"kind":"text","text":"; (see the pass. part. n., voce"},{"kind":"arabic","text_bw":"maSoruwrN","text_ar":"مَصْرُورٌ"},{"kind":"text","text":";)]"},{"kind":"italic_en","text":"He bound the"},{"kind":"arabic","text_bw":"SiraAr","text_ar":"صِرَار"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"upon the she-camel;"},{"kind":"text","text":"(S;) [i. e.]"},{"kind":"italic_en","text":"he bound the she-camel's udder with the"},{"kind":"arabic","text_bw":"SiraAri","text_ar":"صِرَارِ"},{"kind":"text","text":": (M, Msb, K, * TA:) and"},{"kind":"arabic","text_bw":"Sar~a AlA^aTobaA='a biAlS~iraAri","text_ar":"صَرَّ الاَطْبَا=ءَ بِالصِّرَارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He bound the teats with the"},{"kind":"arabic","text_bw":"SrAr","text_ar":"صرار"},{"kind":"text","text":"]. (A.) [See a verse of ElKumeyt cited voce"},{"kind":"arabic","text_bw":"rijolN","text_ar":"رِجْلٌ"},{"kind":"text","text":": and see also what there follows it.] ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"Sar~ahaA","text_ar":"صَرَّهَا"},{"kind":"text","text":"means also (assumed tropical:)"},{"kind":"italic_en","text":"He left off milking her"},{"kind":"text","text":"[i. e. the camel]. (Msb.) ―         -b5-  And"},{"kind":"arabic","text_bw":"tuSar~u","text_ar":"تُصَرُّ"},{"kind":"text","text":", [aor. of"},{"kind":"arabic","text_bw":"Sur~at","text_ar":"صُرَّت"},{"kind":"text","text":",] said of a leathern bucket ("},{"kind":"arabic","text_bw":"dalow","text_ar":"دَلْو"},{"kind":"text","text":") that has become flaccid,"},{"kind":"italic_en","text":"It is tied, and has a loop-shaped handle affixed within it, having another such opposite to it."},{"kind":"text","text":"(K, * TA.) ―         -b6-  And one says,"},{"kind":"arabic","text_bw":"Sar~a EalaY~a AlT~ariyqa qalaA","text_ar":"صَرَّ عَلَىَّ الطَّرِيقَ قَلَا"},{"kind":"arabic","text_bw":"A^ajidu masolakFA","text_ar":"اَجِدُ مَسْلَكًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He closed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has closed, against me the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way, so that I find not any passage"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Sur~ato EalaY~a h`*ihi Albalodapu falaA A^ajidu minohaA maxolaSFA","text_ar":"صُرَّتْ عَلَىَّ هٰذِهِ البَلْدَةُ فَلَا اَجِدُ مِنْهَا مَخْلَصًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This town has become closed against me so that I find not any way of escape from it"},{"kind":"text","text":"]. (A.) ―         -b7-  And"},{"kind":"arabic","text_bw":"Sar~a A^u*unayohi","text_ar":"صَرَّ اُذُنَيْهِ"},{"kind":"text","text":", [aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"contracted his ears to his head:"},{"kind":"text","text":"(ISk, S:) or"},{"kind":"italic_en","text":"pointed and raised his ears;"},{"kind":"text","text":"which a horse does only when he exerts himself and hastens in his pace: (TA:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(an ass)"},{"kind":"italic_en","text":"straightened and erected his ears to listen;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^aSar~ahumaA","text_ar":"اَصَرَّهُمَا","orth_type":"arrow"},{"kind":"text","text":": (A:) and ↓"},{"kind":"arabic","text_bw":"A^aSar~a","text_ar":"اَصَرَّ","orth_type":"arrow"},{"kind":"text","text":"used intransitively, (ISk, S,) without the mention of the ears, (A,) signifies the same as"},{"kind":"arabic","text_bw":"Sar~a A^u*unayohi","text_ar":"صَرَّ اُذُنَيْهِ"},{"kind":"text","text":": (ISk, S, A:) and"},{"kind":"arabic","text_bw":"Sar~a biA^u*unihi","text_ar":"صَرَّ بِاُذُنِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Sar~a A^u*unahu","text_ar":"صَرَّ اُذُنَهُ"},{"kind":"text","text":", aor. and inf. n. as above; and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aSar~a","text_ar":"اَصَرَّ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a horse, and an ass,)"},{"kind":"italic_en","text":"straightened and erected his ear to listen;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"Sar~arahaA","text_ar":"صَرَّرَهَا","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b8-  [The inf. n.]"},{"kind":"arabic","text_bw":"Sar~N","text_ar":"صَرٌّ"},{"kind":"text","text":"signifies also The act of"},{"kind":"italic_en","text":"confining, withholding, hindering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preventing."},{"kind":"text","text":"(TA.) ―         -b9-  And"},{"kind":"arabic","text_bw":"Sur~a","text_ar":"صُرَّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He had an iron collar put upon his neck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"round his neck and hands together."},{"kind":"text","text":"(A.) ―         -b10-  And"},{"kind":"arabic","text_bw":"Sar~a","text_ar":"صَرَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He collected together"},{"kind":"text","text":"a thing, or things, (IAar,) or anything. (TA.) And"},{"kind":"arabic","text_bw":"kalaAmFA","text_ar":"كَلَامًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sar~ara","text_ar":"صَرَّرَ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He collected something to be said in his bosom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind."},{"kind":"text","text":"(L and TA, from a trad.) And"},{"kind":"arabic","text_bw":"AlmaAla","text_ar":"المَالَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaroSara","text_ar":"صَرْصَرَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SaroSarapN","text_ar":"صَرْصَرَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He collected together the property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the camels"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, and put back what had become scattered of the extreme portions thereof."},{"kind":"text","text":"(T, TA.)       -A3-  And"},{"kind":"arabic","text_bw":"Sur~a","text_ar":"صُرَّ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant, or herbage,)"},{"kind":"italic_en","text":"became smitten by cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by intense cold."},{"kind":"text","text":"(M, K.)"}],"source_refs":["S","A","TA","M","K","Msb","ISk","IAar"]}]}}