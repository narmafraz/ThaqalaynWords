441"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D9%8A%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"fetter, chain, bond"},{"pos":"noun","gloss":"restriction"},{"pos":"noun","gloss":"strap"},{"pos":"noun","gloss":"registration"},{"pos":"noun","gloss":"contract"},{"pos":"noun","gloss":"deed, document"},{"pos":"noun","gloss":"diligence, effort"},{"pos":"noun","gloss":"rule, norm"},{"pos":"prep","gloss":"under"},{"pos":"prep","gloss":"currently being, in progress, in the stage or process of"},{"pos":"prep","gloss":"subject to"},{"pos":"prep","gloss":"bound to, bound by"},{"pos":"verb","gloss":"to restrict","tags":["transitive"]},{"pos":"verb","gloss":"to chain","tags":["transitive"]},{"pos":"verb","gloss":"to register","tags":["transitive"]}]},"etymology":null,"ipa":["/qajd/","/qaj.da/","/qaj.ja.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36374","headword_ar":"قَيْدٌ","root":"qwd","body":[{"kind":"text","text":", contr. from"},{"kind":"arabic","text_bw":"qay~idN","text_ar":"قَيِّدٌ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"munoqaAdN","text_ar":"مُنْقَادٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n36438","headword_ar":"قَيْدٌ","root":"qyd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A shackle;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fetter:"},{"kind":"text","text":"or, generally,"},{"kind":"italic_en","text":"a pair of shackles for the fore-legs of a beast,"},{"kind":"text","text":"and generally made of rope, but some are of iron;"},{"kind":"italic_en","text":"a pair of hobbles; a pair of fetters"},{"kind":"text","text":"]: (S, K, &c.:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aqoyaAdN","text_ar":"اَقْيَادٌ"},{"kind":"text","text":"(L, Msb, K) and [of mult.]"},{"kind":"arabic","text_bw":"quyuwdN","text_ar":"قُيُودٌ"},{"kind":"text","text":". (S, L, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A_in~ quyuwda AlA^ayaAdo A^awovaqu AlA^aqoyaAdo","text_ar":"اـِنّ قُيُودَ الاَيَادْ اَوْثَقُ الاَقْيَادْ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily the shackles of benefactions are the firmest of shackles"},{"kind":"text","text":"]. (A.) ["},{"kind":"arabic","text_bw":"AlA^ayaAdo","text_ar":"الاَيَادْ"},{"kind":"text","text":"is for"},{"kind":"arabic","text_bw":"AlA^ayaAdiY","text_ar":"الاَيَادِى"},{"kind":"text","text":".] ―         -b3-"},{"kind":"italic_en","text":"What binds together"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the two pieces of wood in a camel's saddle which are called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"EaDudaAni","text_ar":"عَضُدَانِ"},{"kind":"italic_en","text":"of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the two broad pieces of wood called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"muw^ax~arataAni","text_ar":"مُوَخَّرَتَانِ"},{"kind":"text","text":", (L, K [in the former of which, however, instead of"},{"kind":"arabic","text_bw":"mA Dm~ AlEDdyn mn Almwx~rtyn","text_ar":"ما ضمّ العضدين من الموخّرتين"},{"kind":"text","text":", the reading in the K, is put"},{"kind":"arabic","text_bw":"mA Dm~ AlEDdtyn Almw^x~rtyn","text_ar":"ما ضمّ العضدتين الموخّرتين"},{"kind":"text","text":", which I suppose to be a mistake])"},{"kind":"italic_en","text":"at their upper part, being a thong."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"italic_en","text":"A plaited thong between"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the two pieces of wood called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"HinowaAni","text_ar":"حِنْوَانِ"},{"kind":"text","text":"of a camel's saddle of the kind called"},{"kind":"arabic","text_bw":"raHol","text_ar":"رَحْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"at the upper part;"},{"kind":"text","text":"and sometimes, of a horse's saddle. (L.) ―         -b5-  The"},{"kind":"italic_en","text":"thong that binds together"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the two pieces of wood called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"EaroquwataAni","text_ar":"عَرْقُوَتَانِ"},{"kind":"text","text":"of a camel's saddle of the kind called"},{"kind":"arabic","text_bw":"qatab","text_ar":"قَتَب"},{"kind":"text","text":". (S, L, K.) ―         -b6-"},{"kind":"italic_en","text":"Anything that binds one part of a thing to another part."},{"kind":"text","text":"(L.) ―         -b7-  The"},{"kind":"italic_en","text":"extended thing at the lower extremities of the suspensory cords or strings"},{"kind":"text","text":"of a sword,"},{"kind":"italic_en","text":"which is held by"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the rings called"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"bakaraAt","text_ar":"بَكَرَات"},{"kind":"text","text":". (L, K.) ―         -b8-"},{"kind":"arabic","text_bw":"qayodaA AlbaAziY","text_ar":"قَيْدَا البَازِى"},{"kind":"italic_en","text":"The jesses of the hawk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falcon;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sibaAqaAhu","text_ar":"سِبَاقَاهُ"},{"kind":"text","text":"(S, O, K, all in art."},{"kind":"arabic","text_bw":"sbq","text_ar":"سبق"},{"kind":"text","text":".) ―         -b9-"},{"kind":"arabic","text_bw":"qayodu AlA^asonaAni","text_ar":"قَيْدُ الاَسْنَانِ"},{"kind":"italic_en","text":"The gum wherein the teeth are set:"},{"kind":"text","text":"(K:)"},{"kind":"arabic","text_bw":"quyuwdu AlAsnAn","text_ar":"قُيُودُ الاسنان"},{"kind":"italic_en","text":"the gums:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"the portions of the flesh of the gums that rise between the teeth;"},{"kind":"text","text":"likened to the red"},{"kind":"arabic","text_bw":"quyuwd","text_ar":"قُيُود"},{"kind":"text","text":"which are marks upon camels, made with a hot iron. (ISd, L.) ―         -b10-"},{"kind":"arabic","text_bw":"qayodu Alfarasi","text_ar":"قَيْدُ الفَرَسِ"},{"kind":"italic_en","text":"A certain mark made with a hot iron upon the neck of a camel,"},{"kind":"text","text":"(S, ISd, L, K,)"},{"kind":"italic_en","text":"and upon its face, and thigh, of an oblong shape,"},{"kind":"text","text":"(ISd, L,)"},{"kind":"italic_en","text":"in the form of a"},{"kind":"arabic","text_bw":"qayod","text_ar":"قَيْد"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the legs"},{"kind":"text","text":"], (S, L,)"},{"kind":"italic_en","text":"or of two rings with a line extending between them."},{"kind":"text","text":"(Nh, L.) ―         -b11-"},{"kind":"page_break","n":2577},{"kind":"arabic","text_bw":"qayodu AlA^awaAbidi","text_ar":"قَيْدُ الاَوَابِدِ"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"Shackles upon the legs of the wild animals which shun, and take fright at, mankind &c.; or,"},{"kind":"text","text":"accord. to the L,"},{"kind":"italic_en","text":"of the wild asses"},{"kind":"text","text":"]: indeterminate in signification, though determinate in its grammatical form: (Sb, L:) an appellation given to a horse, (K,) or to"},{"kind":"italic_en","text":"a fleet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift, and excellent horse,"},{"kind":"text","text":"because, by its swiftness, it overtakes the wild beasts, (T, K,) and prevents their escaping. (T, S.)"},{"kind":"arabic","text_bw":"qyd","text_ar":"قيد"},{"kind":"text","text":"is here a proper subst. used as an epithet because it imports the attribute of a verb; or it is for"},{"kind":"arabic","text_bw":"taqoyid","text_ar":"تَقْيِد"},{"kind":"text","text":". (IJ, L.) [See also art."},{"kind":"arabic","text_bw":"Abd","text_ar":"ابد"},{"kind":"text","text":"and Ham, p. 455.] ―         -b12-  (tropical:)"},{"kind":"italic_en","text":"A wife:"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"gul~N","text_ar":"غُلٌّ"},{"kind":"text","text":". (TA.) ―         -b13-"},{"kind":"arabic","text_bw":"maA EalaY h`*aA","text_ar":"مَا عَلَى هٰذَا"},{"kind":"arabic","text_bw":"AlHarofi qyado","text_ar":"الحَرْفِ قيَدْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"There is not upon this letter a syllabical sign, or sign which points out the pronunciation, or the division of syllables."},{"kind":"text","text":"(A.) ―         -b14-"},{"kind":"arabic","text_bw":"Alqayodu waAlr~atoEapu","text_ar":"القَيْدُ وَالرَّتْعَةُ"},{"kind":"text","text":", a prov.: see art."},{"kind":"arabic","text_bw":"rtE","text_ar":"رتع"},{"kind":"text","text":".       -A2-  See also"},{"kind":"arabic","text_bw":"qiydN","text_ar":"قِيدٌ"},{"kind":"text","text":"."}],"source_refs":["L","Msb","K","S","ISd","Sb","T"]},{"entry_id":"n36375","headword_ar":"قِيدٌ","root":"qwd","body":[{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"qiwodN","text_ar":"قِوْدٌ"},{"kind":"text","text":", if belonging to this art.,] and ↓"},{"kind":"arabic","text_bw":"qaAdN","text_ar":"قَادٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"Measure;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qadorN","text_ar":"قَدْرٌ"},{"kind":"text","text":". (L, art."},{"kind":"arabic","text_bw":"qyd","text_ar":"قيد"},{"kind":"text","text":"; and K in the present art.) Ex."},{"kind":"arabic","text_bw":"huwa min~iY qiyda rumoHK","text_ar":"هُوَ مِنِّى قِيدَ رُمْحٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rmH","text_ar":"رمح"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qaAda","text_ar":"قَادَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"distant"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from me the measure of a spear."},{"kind":"text","text":"(L, art."},{"kind":"arabic","text_bw":"qyd","text_ar":"قيد"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n36439","headword_ar":"قِيدٌ","root":"qyd","body":[{"kind":"italic_en","text":"A whip made of skin."},{"kind":"text","text":"(MF.)       -A2-"},{"kind":"arabic","text_bw":"qiydN","text_ar":"قِيدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qaAdN","text_ar":"قَادٌ","orth_type":"arrow"},{"kind":"text","text":"(S, L, K) and ↓"},{"kind":"arabic","text_bw":"qayodN","text_ar":"قَيْدٌ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Measure."},{"kind":"text","text":"(S, L, K.) Ex."},{"kind":"arabic","text_bw":"bayonahumaA qiydu rumoHK","text_ar":"بَيْنَهُمَا قِيدُ رُمْحٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qaAdu rmH","text_ar":"قَادُ رمح"},{"kind":"text","text":","},{"kind":"italic_en","text":"Between them two is the measure of a spear."},{"kind":"text","text":"(S.) See also art."},{"kind":"arabic","text_bw":"qwd","text_ar":"قود"},{"kind":"text","text":"."}],"source_refs":["S","L","K"]},{"entry_id":"n36381","headword_ar":"قِيِّدٌ","root":"qwd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"munoqaAdN","text_ar":"مُنْقَادٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n36434","headword_ar":"قِيدَ","root":"qyd","body":[{"kind":"text","text":": see 2."}],"source_refs":[]},{"entry_id":"n36441","headword_ar":"قَيِّدٌ","root":"qyd","body":[{"kind":"italic_en","text":"Tractable; easy to be led."},{"kind":"text","text":"(S, K.) [But this belongs to art."},{"kind":"arabic","text_bw":"qwd","text_ar":"قود"},{"kind":"text","text":", q. v.]"}],"source_refs":[]}]}}