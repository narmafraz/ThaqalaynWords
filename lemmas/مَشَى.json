:"walked; went along, marched; travelled; trod; paced; stepped."},{"kind":"text","text":"See 5. ―         -b2-"},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He went on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, in his course of action,"},{"kind":"text","text":"&c. (Mughnee voce"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":", in explanation of this verb as used in Kur xxxviii. 5.) ―         -b3-  ["},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(money)"},{"kind":"italic_en","text":"passed; was,"},{"kind":"page_break","n":3021},{"kind":"italic_en","text":"or became, current."},{"kind":"text","text":"―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a calumny)"},{"kind":"italic_en","text":"was, or became, current."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"miy^obarN","text_ar":"مِيْبَرٌ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"ma$aY banoTuhu","text_ar":"مَشَى بَنْطُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His belly became moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in motion; it discharged itself."},{"kind":"text","text":"] (S, K, art."},{"kind":"arabic","text_bw":"Tlq","text_ar":"طلق"},{"kind":"text","text":"; &c.)"}],"source_refs":["Mgh","Msb"]}]}}