{"lemma":"مُتَصَرِّفٌ","slug":"مُتَصَرِّفٌ","root":"ص.ر.ف","root_slug":"ص-ر-ف","root_link":"/words/roots/ص-ر-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n24242"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AA%D9%8E%D8%B5%D9%8E%D8%B1%D9%90%D9%91%D9%81%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24242","headword_ar":"مُتَصَرِّفٌ","root":"Srf","body":[{"kind":"text","text":"is an epithet applied to a verb [as meaning"},{"kind":"italic_en","text":"That is perfectly inflected"},{"kind":"text","text":"], opposed to"},{"kind":"arabic","text_bw":"jaAmidN","text_ar":"جَامِدٌ"},{"kind":"text","text":"[q. v.]. (TA, voce"},{"kind":"arabic","text_bw":"qado","text_ar":"قَدْ"},{"kind":"text","text":".) ―         -b2-  ["},{"kind":"arabic","text_bw":"ZarofN mutaSar~ifN","text_ar":"ظَرْفٌ مُتَصَرِّفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TarofN gayoru mutaSar~ifK","text_ar":"طَرْفٌ غَيْرُ مُتَصَرِّفٍ"},{"kind":"text","text":"signify the same, respectively, as"},{"kind":"arabic","text_bw":"ZarofN mutamak~inN","text_ar":"ظَرْفٌ مُتَمَكِّنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ZarofN gayoru mutamak~inK","text_ar":"ظَرْفٌ غَيْرُ مُتَمَكِّنٍ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"mkn","text_ar":"مكن"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"wakiylN mutaSar~ifN","text_ar":"وَكِيلٌ مُتَصَرِّفٌ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"A factor, an agent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a deputy, who acts according to his own free will in the disposal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"management, of an affair."},{"kind":"text","text":"]"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%AA%D8%B5%D8%B1%D9%81/","headword_ar":"متصرفة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23560#ff8c82","body_html":"<span>المتصرفة: هي قوة محلها مقدم التجويف الأوسط من الدماغ، من شأنها التصرف في الصور والمعاني بالتركيب والتفصيل، تركب الصور بعضها ببعض، مثل أن يتصور إنسانًا ذا رأسين أو جناحين، وهذه القوة يستعملها العقل تارةً والوخم أخرى، فباعتبار الأول تسمى: مفكرة؛ لتصرفها في المواد الفكرية، وباعتبار الثاني تسمى: متخيلة؛ لتصرفها منها في الصور الخيالية.</span>"}]}}