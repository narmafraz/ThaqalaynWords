{"lemma":"قُمُطِ","slug":"قُمُطِ","root":"ق.م.ط","root_slug":"ق-م-ط","root_link":"/words/roots/ق-م-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n36237","","n36238"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8F%D9%85%D9%8F%D8%B7%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"swaddle"}]},"etymology":{"source":"wiktextract","text":"From قِمْط (qimṭ)."},"ipa":["/qi.maːtˤ/","/ɡmaːtˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36237","headword_ar":"قَمَطَ","root":"qmT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, M, Mgh, Msb, K) and"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"qamoTN","text_ar":"قَمْطٌ"},{"kind":"text","text":", (S, M, Mgh, Msb,)"},{"kind":"italic_en","text":"He bound"},{"kind":"text","text":"a child (S, Msb) in the cradle, and a sheep or goat on the occasion of slaughtering it, (S,) with the"},{"kind":"arabic","text_bw":"qimaAT","text_ar":"قِمَاط"},{"kind":"text","text":"[q. v.]: (S, Msb:) or"},{"kind":"arabic","text_bw":"qamaTahu","text_ar":"قَمَطَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he bound his arms and legs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands and feet, together, like as is done with a child in the cradle,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and elsewhere, putting his limbs"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"arms"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"next to the body, and then winding upon him the"},{"kind":"arabic","text_bw":"qimaAT","text_ar":"قِمَاط"},{"kind":"text","text":": (TA:) and"},{"kind":"italic_en","text":"he bound his"},{"kind":"text","text":"(a captive's, Mgh, Msb, K, or others', Mgh)"},{"kind":"italic_en","text":"arms and legs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hands and feet, together,"},{"kind":"text","text":"(Mgh, Msb, K, *)"},{"kind":"italic_en","text":"with a rope;"},{"kind":"text","text":"(Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"qm~Thu","text_ar":"قمّطهُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"taqomiyTN","text_ar":"تَقْمِيطٌ"},{"kind":"text","text":": (M, TA:) and"},{"kind":"arabic","text_bw":"qumiTa","text_ar":"قُمِطَ"},{"kind":"text","text":"he (a captive) was thus bound. (S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"qamaTa AlA_ibila","text_ar":"قَمَطَ الاـِبِلَ"},{"kind":"text","text":", (TA,) inf. n. as above, (K,)"},{"kind":"italic_en","text":"He disposed the camels in a file, string,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"series."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","M","Mgh","Msb","K","TA"]},{"entry_id":"n36238","headword_ar":"قِمْطٌ","root":"qmT","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qimaATN","text_ar":"قِمَاطٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}