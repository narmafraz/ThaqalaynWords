{"lemma":"بَهَتَ","slug":"بَهَتَ","root":"ب.ه.ت","root_slug":"ب-ه-ت","root_link":"/words/roots/ب-ه-ت","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَهَتَّ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَهَتِّ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَهَتُّما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَهَتُّم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَهَتُّنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَهَتَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَهَتَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَهَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَهَتَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَهَتُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَهَتْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْهَت","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْهَتِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْهَتِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْهَتا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْهَتانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْهَتُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْهَتُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْهَتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْهَت","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْهَت","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْهَتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْهَتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْهَتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْهَتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْهَتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْهَتُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْهَتْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"بَهَتُّ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"بَهَتْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَبْهَت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبْهَت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"بَهَتَ","root":"بهت","pos":"V","occurrence_count":2},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n3385","","n3387","n3388"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%87%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3385","headword_ar":"بُهِتَ","root":"bht","body":[{"kind":"text","text":", (S, Msb, K, &c.,) the most chaste form of the verb in the sense here following, (S, TA,) and that which most commonly obtains, and the only form allowed by Th and IKt; (TA;) and"},{"kind":"arabic","text_bw":"bahita","text_ar":"بَهِتَ"},{"kind":"text","text":", (S, L, Msb, K,) aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"bahuta","text_ar":"بَهُتَ"},{"kind":"text","text":", (S, L, Msb, K,) in which the dammeh is said to give intensiveness to the signification, as in"},{"kind":"arabic","text_bw":"qaDuwa Alr~ajulu","text_ar":"قَضُوَ الرَّجُلُ"},{"kind":"text","text":", (TA,) aor."},{"kind":"text","text":"; (Msb, K;) and"},{"kind":"arabic","text_bw":"bahata","text_ar":"بَهَتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"(K) and"},{"kind":"text","text":"; (TA;) inf. n."},{"kind":"arabic","text_bw":"bahotN","text_ar":"بَهْتٌ"},{"kind":"text","text":"; (JK, K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed, and unable to see his right course;"},{"kind":"text","text":"(JK, S, Msb, K;)"},{"kind":"italic_en","text":"not knowing what to prefer nor what to postpone:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"A$r","text_ar":"اشر"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"he looked"},{"kind":"text","text":"at a thing that he saw"},{"kind":"italic_en","text":"with a look of wonder:"},{"kind":"text","text":"(A, TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with wonder:"},{"kind":"text","text":"(JK:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cut short,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AnoqaTaEa","text_ar":"انْقَطَعَ"},{"kind":"text","text":", K, TA,)"},{"kind":"italic_en","text":"and was silent, being confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(an adversary in a dispute or litigation)"},{"kind":"italic_en","text":"was overcome by an argument, an allegation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plea."},{"kind":"text","text":"(L.) All these forms occur in different readings of the saying in the Kur [ii. 260],"},{"kind":"arabic","text_bw":"fabuhita A@l~a*iY kafara","text_ar":"فَبُهِتَ ا@لَّذِى كَفَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fabahita","text_ar":"فَبَهِتَ"},{"kind":"text","text":"&c., (IJ, TA,) explained in the Wá'ee as meaning,"},{"kind":"italic_en","text":"And he who disbelieved remained in confusion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexity, not seeing his right course, looking as one in wonder:"},{"kind":"text","text":"(Lb, TA:) but accord. to him who reads"},{"kind":"arabic","text_bw":"fabahata","text_ar":"فَبَهَتَ"},{"kind":"text","text":", the word"},{"kind":"arabic","text_bw":"Al*Y","text_ar":"الذى"},{"kind":"text","text":"may hold the place of a noun in the accus. case [as will be seen from what follows]. (IJ, TA.)       -A2-"},{"kind":"arabic","text_bw":"bahatahu","text_ar":"بَهَتَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"bahotN","text_ar":"بَهْتٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, caused him to become confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed, not seeing his right course:"},{"kind":"text","text":"(Zj, Msb: [Golius, on the authority of Ibn-Maaroof, assigns this meaning to ↓"},{"kind":"arabic","text_bw":"bh~thu","text_ar":"بهّتهُ","orth_type":"arrow"},{"kind":"text","text":":]) or"},{"kind":"italic_en","text":"took him unawares,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by surprise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unexpectedly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suddenly."},{"kind":"text","text":"(S, K.) Zj cites as an ex. of the former meaning the saying in the Kur [xxi. 41],"},{"kind":"arabic","text_bw":"taA^otiyhimo bagotapF fatabohatuhumo","text_ar":"تَاْتِيهِمْ بَغْتَةً فَتَبْهَتُهُمْ"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"It shall come upon them suddenly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unawares, and cause them to become confounded,"},{"kind":"text","text":"&c.: (TA: and so Bd and Jel explain it:) or,"},{"kind":"italic_en","text":"and shall overcome them:"},{"kind":"text","text":"(Bd:) J cites the same as an ex. of the latter of the two meanings in the preceding sentence; but his doing so requires consideration; for the meaning which he gives is taken from the word"},{"kind":"arabic","text_bw":"bgtp","text_ar":"بغتة"},{"kind":"text","text":"; not from"},{"kind":"arabic","text_bw":"Albahotu","text_ar":"البَهْتُ"},{"kind":"text","text":". (MF, TA.) [But it is said also that]"},{"kind":"arabic","text_bw":"mubaAhatapN","text_ar":"مُبَاهَتَةٌ"},{"kind":"text","text":"[inf. n. of ↓"},{"kind":"arabic","text_bw":"bAhthu","text_ar":"باهتهُ","orth_type":"arrow"},{"kind":"text","text":"] signifies The"},{"kind":"italic_en","text":"taking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coming upon,"},{"kind":"text","text":"[one]"},{"kind":"italic_en","text":"unawares, by surprise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unexpectedly."},{"kind":"text","text":"(JK.) ―         -b2-"},{"kind":"arabic","text_bw":"bahatahu","text_ar":"بَهَتَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, A, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"bahotN","text_ar":"بَهْتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bahatN","text_ar":"بَهَتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buhotaAnN","text_ar":"بُهْتَانٌ"},{"kind":"text","text":", (S, K,) or the last is a simple subst., (Msb,)"},{"kind":"italic_en","text":"He calumniated him; slandered him; accused him falsely; said against him that which he had not done:"},{"kind":"text","text":"(S, A, K:) [or"},{"kind":"italic_en","text":"he did so in such a manner as to make one to be confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed, at the falsity"},{"kind":"page_break","n":264},{"kind":"italic_en","text":"of the charge, and not to see his right course:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"buhotaAnN","text_ar":"بُهْتَانٌ"},{"kind":"text","text":", below:)]"},{"kind":"italic_en","text":"he lied against him; forged a lie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lies, against him;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaAbalahu biAlka*ibi","text_ar":"قَابَلَهُ بِالكَذِبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he accused him to his face falsely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with falsehood"},{"kind":"text","text":"]; (TA;)"},{"kind":"arabic","text_bw":"Albahotu","text_ar":"البَهْتُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AisotiqobaAluka A^axaAka bimaA","text_ar":"اِسْتِقْبَالُكَ اَخَاكَ بِمَا"},{"kind":"arabic","text_bw":"layosa fiyhi","text_ar":"لَيْسَ فِيهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thy accusing thy brother,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fellow, to his face, of that which is not in him"},{"kind":"text","text":"]: (JK:) and"},{"kind":"arabic","text_bw":"bahatahaA","text_ar":"بَهَتَهَا"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"bahotN","text_ar":"بَهْتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he accused her falsely of adultery; and forged a lie against her."},{"kind":"text","text":"(Msb.) [See also"},{"kind":"arabic","text_bw":"AigotaAbahu","text_ar":"اِغْتَابَهُ"},{"kind":"text","text":".]"},{"kind":"italic_en","text":"In the saying of Abu-n-Nejm,"},{"kind":"quote","text":"sub~iY AlHamaApa waA@bohatiY EalayohaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Revile thou the mother-in-law, and calumniate her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forge lies against her"},{"kind":"text","text":"],"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"text","text":"is [said by J to be] redundant, or pleonastic; for one does not say,"},{"kind":"arabic","text_bw":"baEata Ealayohi","text_ar":"بَعَتَ عَلَيْهِ"},{"kind":"text","text":", but only"},{"kind":"arabic","text_bw":"bahatahu","text_ar":"بَهَتَهُ"},{"kind":"text","text":". (S.) Upon this, F says, in the K, that"},{"kind":"arabic","text_bw":"faA@bohatiY ElyhA","text_ar":"فَا@بْهَتِى عليها"},{"kind":"text","text":"[thus in the K] is a mistake; that J is in error, and that the right reading is"},{"kind":"arabic","text_bw":"faA@nohatiY ElyhA","text_ar":"فَا@نْهَتِى عليها"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":": but this assertion made by F depends upon the authority of relaters of the verse in which the word in question occurs. (MF.) IB says that"},{"kind":"arabic","text_bw":"AbhtY","text_ar":"ابهتى"},{"kind":"text","text":"may be here rendered trans. by means of"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"text","text":"because it is syn. with"},{"kind":"arabic","text_bw":"AifotariY","text_ar":"اِفْتَرِى"},{"kind":"text","text":", which is so rendered trans., in like manner as is done in other instances, of which he gives an ex. from the Kur [xxiv. 63],"},{"kind":"arabic","text_bw":"yuxaAlifuwna Eano A^amorihi","text_ar":"يُخَالِفُونَ عَنْ اَمْرِهِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"yaxorujuwna En Amrh","text_ar":"يَخْرُجُونَ عن امره"},{"kind":"text","text":": he adds that, accord. to J,"},{"kind":"arabic","text_bw":"En","text_ar":"عن"},{"kind":"text","text":"in this ex. should be considered redundant; but that"},{"kind":"arabic","text_bw":"En","text_ar":"عن"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"text","text":"are not used redundantly like"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"bahata AlfaHola Eani Aln~aAqapi","text_ar":"بَهَتَ الفَحْلَ عَنِ النَّاقَةِ"},{"kind":"italic_en","text":"He removed the stallion from the she-camel in order that a stallion of more generous race might cover her."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","TA","L","Msb","K","A","JK","IJ","Lb","Bd"]},{"entry_id":"n3387","headword_ar":"بَهْتٌ","root":"bht","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buhotaAnN","text_ar":"بُهْتَانٌ"},{"kind":"text","text":".       -A2-"},{"kind":"italic_en","text":"A certain well-known kind of stone."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n3388","headword_ar":"بُهْتٌ","root":"bht","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"buhotaAnN","text_ar":"بُهْتَانٌ"},{"kind":"text","text":", in two places.       -A2-"},{"kind":"italic_en","text":"A certain sidereal computation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calculation;"},{"kind":"text","text":"being [that of]"},{"kind":"italic_en","text":"the direct course of stars in a day:"},{"kind":"text","text":"[in Persian,"},{"kind":"italic_en","text":"a planet's motion in any given time:"},{"kind":"text","text":"(Johnson's Pers. Arab. and Engl. Dict.:)] thought by Az to be not Arabic. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}