{"lemma":"مَصّاصُو","slug":"مَصّاصُو","root":"م.ص.ص","root_slug":"م-ص-ص","root_link":"/words/roots/م-ص-ص","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n38625","n38629"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B5%D9%91%D8%A7%D8%B5%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"the desert papyrus Cyperus conglomeratus","tags":["collective"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38625","headword_ar":"مُصَاصٌ","root":"mS","body":[{"kind":"italic_en","text":"What is sucked"},{"kind":"text","text":"from, or of, a thing; (M, TA;) as also ↓"},{"kind":"arabic","text_bw":"muSaASapN","text_ar":"مُصَاصَةٌ","orth_type":"arrow"},{"kind":"text","text":". (M, A, TA.) You say,"},{"kind":"arabic","text_bw":"TaAbato muSaASatuhu fiY famiY","text_ar":"طَابَتْ مُصَاصَتُهُ فِى فَمِى"},{"kind":"italic_en","text":"What was sucked from it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of it, was good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sweet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasant, in my mouth."},{"kind":"text","text":"(A.) ―         -b2-  [And hence,] The"},{"kind":"italic_en","text":"pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice, part"},{"kind":"text","text":"of anything; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"muSaAmiSN","text_ar":"مُصَامِصٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) and (S) the"},{"kind":"italic_en","text":"purest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choicest,"},{"kind":"text","text":"(S, M,) of a thing; as also ↓"},{"kind":"arabic","text_bw":"muSaASapN","text_ar":"مُصَاصَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muSaAmiSN","text_ar":"مُصَامِصٌ","orth_type":"arrow"},{"kind":"text","text":". (M.) And"},{"kind":"arabic","text_bw":"AlmaAli","text_ar":"المَالِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"muS~apu","text_ar":"مُصَّةُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"muSaASuhu","text_ar":"مُصَاصُهُ"},{"kind":"text","text":", (K, TA,) i. e."},{"kind":"italic_en","text":"The pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice part of property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the property."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN muSaASu qawomihi","text_ar":"فُلَانٌ مُصَاصُ قَوْمِهِ"},{"kind":"text","text":", (S, M,) and ↓"},{"kind":"arabic","text_bw":"muSaASatuhu","text_ar":"مُصَاصَتُهُ","orth_type":"arrow"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"Such a one is the purest in race,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage, of his people:"},{"kind":"text","text":"and in like manner you say of two, and of more, and of a female. (S, M.) And"},{"kind":"arabic","text_bw":"huwa","text_ar":"هُوَ"},{"kind":"arabic","text_bw":"mino muSaASi qawomihi","text_ar":"مِنْ مُصَاصِ قَوْمِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is of the purest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choicest, of his people"},{"kind":"text","text":"]. (A.) ―         -b3-  Also,"},{"kind":"italic_en","text":"Pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice,"},{"kind":"text","text":"applied to"},{"kind":"arabic","text_bw":"Hasab","text_ar":"حَسَب"},{"kind":"text","text":"[or grounds of pretension to respect, &c.]; as also ↓"},{"kind":"arabic","text_bw":"muSaAmiSN","text_ar":"مُصَامِصٌ","orth_type":"arrow"},{"kind":"text","text":". (A.) You say also,"},{"kind":"arabic","text_bw":"A_in~ahu lamuSaAmiSN fiY qawomihi","text_ar":"اـِنَّهُ لَمُصَامِصٌ فِى قَوْمِهِ"},{"kind":"italic_en","text":"Verily he is distinguished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"characterized, by pure grounds of respect among his people."},{"kind":"text","text":"(K, * TA.) ―         -b4-  Also, The"},{"kind":"italic_en","text":"origin, source,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of origination,"},{"kind":"text","text":"of a thing. (M, TA.) You say,"},{"kind":"arabic","text_bw":"huwa kariymu AlmuSaASi","text_ar":"هُوَ كَرِيمُ المُصَاصِ"},{"kind":"italic_en","text":"He is generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noble, in respect of origin."},{"kind":"text","text":"(TA.) Accord. to Lth,"},{"kind":"arabic","text_bw":"muSaASu Alqawomi","text_ar":"مُصَاصُ القَوْمِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The original source of the people:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the most excellent of their middle class."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","S","M","TA"]},{"entry_id":"n38629","headword_ar":"مَصَّاصٌ","root":"mS","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]}]},"classical_definitions":null}