dword_ar":"اِسْتَقْصَى","root":"qSY","body":[{"kind":"italic_en","text":"He went to the utmost length,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point,"},{"kind":"text","text":"in a question, (K,) and in like manner you say,"},{"kind":"arabic","text_bw":"AisotaqoSaY AlA^amora","text_ar":"اِسْتَقْصَى الاَمْرَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taqaS~aAhu","text_ar":"تَقَصَّاهُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b2-  ["},{"kind":"italic_en","text":"He exhausted"},{"kind":"text","text":"a subject. ―         -b3-"},{"kind":"italic_en","text":"He proceeded to extremities. He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, extreme,"},{"kind":"text","text":"in an action, &c.] ―         -b4-"},{"kind":"arabic","text_bw":"AisotaqoSaY masoA^alatahu","text_ar":"اِسْتَقْصَى مَسْاَلَتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went to the utmost point in questioning him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asking him,"},{"kind":"text","text":"] respecting a thing, so as to draw forth the utmost that he possessed [of information respecting it]. (S, art."},{"kind":"arabic","text_bw":"nS","text_ar":"نص"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"AisotaqoSaY fiY AlmasoA^alapi","text_ar":"اِسْتَقْصَى فِى المَسْاَلَةِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"taqaS~aY","text_ar":"تَقَصَّى","orth_type":"arrow"},{"kind":"text","text":"(S, K) both signify the same; (S;) (tropical:)"},{"kind":"italic_en","text":"He reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and elicited,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"investigated,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the utmost"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that was to be reached,"},{"kind":"text","text":"&c.]"},{"kind":"italic_en","text":"in the question:"},{"kind":"text","text":"(K, TA:) and in like manner"},{"kind":"arabic","text_bw":"AstqSY","text_ar":"استقصى"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tqS~Ahu","text_ar":"تقصّاهُ","orth_type":"arrow"},{"kind":"text","text":"(TA) (tropical:)  ["},{"kind":"italic_en","text":"He investigated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"searched, to the utmost the case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, the utmost of the case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, in investigating it."},{"kind":"text","text":"(MA in explanation of the former phrase.) ―         -b6-"},{"kind":"arabic","text_bw":"AisotaqoSaY Eilomahu","text_ar":"اِسْتَقْصَى عِلْمَهُ"},{"kind":"italic_en","text":"He attained the utmost knowledge of it."},{"kind":"text","text":"―         -b7-"},{"kind":"arabic","text_bw":"AisotaqoSaY maA Einoda naAqatihi mina Als~ayori","text_ar":"اِسْتَقْصَى مَا عِنْدَ نَاقَتِهِ مِنَ السَّيْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He elicited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exacted, the utmost of his she-camel's pace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power of going on"},{"kind":"text","text":"]. (TA, art."},{"kind":"arabic","text_bw":"nS","text_ar":"نص"},{"kind":"text","text":".) ―         -b8-"},{"kind":"arabic","text_bw":"AisotiqoSaA='N","text_ar":"اِسْتِقْصَا=ءٌ"},{"kind":"text","text":", metonymically, signifies (tropical:)  The"},{"kind":"italic_en","text":"being niggardly, stingy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious."},{"kind":"text","text":"(Az, TA in art."},{"kind":"arabic","text_bw":"dnq","text_ar":"دنق"},{"kind":"text","text":".) ―         -b9-"},{"kind":"arabic","text_bw":"AisotaqoSayotu AlmakaAna","text_ar":"اِسْتَقْصَيْتُ المَكَانَ"},{"kind":"text","text":"[?]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AisotaEo*ayotuhu","text_ar":"اِسْتَعْذَيْتُهُ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"E*Y","text_ar":"عذى"},{"kind":"text","text":".)"}],"source_refs":["K","S","TA"]}]},"classical_definitions":null}