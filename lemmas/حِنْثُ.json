{"lemma":"حِنْثُ","slug":"حِنْثُ","root":"ح.ن.ث","root_slug":"ح-ن-ث","root_link":"/words/roots/ح-ن-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"حِنْثُ","root":"حنث","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n9276"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%90%D9%86%D9%92%D8%AB%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9276","headword_ar":"حِنْثٌ","root":"Hnv","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"violation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"failure of performance, of an oath:"},{"kind":"text","text":"(S, A, K, TA:) [an inf. n. used as a simple subst.:] pl."},{"kind":"arabic","text_bw":"A^aHonaAvN","text_ar":"اَحْنَاثٌ"},{"kind":"text","text":"; as in the saying,"},{"kind":"arabic","text_bw":"Ealayohi A^aHonaAvN kaviyrapN","text_ar":"عَلَيْهِ اَحْنَاثٌ كَثِيرَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is accountable for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chargeable with, many violations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"failures of performance, of oaths"},{"kind":"text","text":"]. (TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"A sin, a crime, an offence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an act of disobedience."},{"kind":"text","text":"(S, A, Msb, K.) So in the saying [in the Kur lvi. 45],"},{"kind":"arabic","text_bw":"wakaAnuwA yuSir~uwna EalaY AlHinovi AlEaZiymi","text_ar":"وَكَانُوا يُصِرُّونَ عَلَى الحِنْثِ العَظِيمِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"And they persisted in great sin"},{"kind":"text","text":"]; (A;) meaning belief in a plurality of gods. (Bd, Jel.) And hence, (Bd in lvi. 45,)"},{"kind":"arabic","text_bw":"balaga AlHinova","text_ar":"بَلَغَ الحِنْثَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a boy)"},{"kind":"italic_en","text":"attained to the age when he was punishable for sin:"},{"kind":"text","text":"(A, * Bd:) or"},{"kind":"italic_en","text":"attained to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the age when he became punishable for"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"disobedience and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"rewardable for"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"obedience:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"attained to the age when the pen"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the recording angels"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"began to register his acts of obedience and of disobedience: attained to the age of puberty: attained to manhood."},{"kind":"text","text":"(TA.) [Hence also,]"},{"kind":"arabic","text_bw":"A^awolaAdu AlHinovi","text_ar":"اَوْلَادُ الحِنْثِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The children of adultery"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fornication:"},{"kind":"text","text":"occurring in a trad., accord. to one reading: accord. to another reading,"},{"kind":"arabic","text_bw":"AwlAd Alxubovi","text_ar":"اولاد الخُبْثِ"},{"kind":"text","text":". (L.)"}],"source_refs":["S","A","K","TA"]}]}}