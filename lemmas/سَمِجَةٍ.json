{"lemma":"سَمِجَةٍ","slug":"سَمِجَةٍ","root":"س.م.ج","root_slug":"س-م-ج","root_link":"/words/roots/س-م-ج","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n20632"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%85%D9%90%D8%AC%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be unseemly, to be awkward, to be sick or disgusting, to be loathsome"},{"pos":"verb","gloss":"to render unseemly, to render awkward, to make sick or disgusting, to let be loathsome"},{"pos":"adj","gloss":"unseemly, awkward, sick or disgusting, loathsome, deform"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20632","headword_ar":"سمّجهُ","root":"smj","body":[{"kind":"text","text":", (A, O, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"tasomiyjN","text_ar":"تَسْمِيجٌ"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, rendered it foul, unseemly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugly;"},{"kind":"text","text":"(O, Msb, * K;) or"},{"kind":"italic_en","text":"devoid of beauty."},{"kind":"text","text":"(L, Msb.) One says,"},{"kind":"arabic","text_bw":"maA sam~ajahu EinodiY A_il~aA ka*aA","text_ar":"مَا سَمَّجَهُ عِنْدِى اـِلَّا كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nothing rendered it foul, unseemly,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in my estimation, but such a thing"},{"kind":"text","text":"]. (A.)"}],"source_refs":["A","O","L","Msb","K"]}]},"classical_definitions":null}