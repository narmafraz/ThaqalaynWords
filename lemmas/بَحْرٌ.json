h, K:) whence blood of a pure red colour, (S,) or intensely red, (Mgh,) is termed"}, {"kind": "arabic", "text_bw": "baHoraAniY~N", "text_ar": "بَحْرَانِىٌّ"}, {"kind": "text", "text": "(S, Mgh) and"}, {"kind": "arabic", "text_bw": "baAHirN", "text_ar": "بَاحِرٌ"}, {"kind": "text", "text": ". (S.)"}], "source_refs": ["K", "TA", "S", "T", "A", "Mgh"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}