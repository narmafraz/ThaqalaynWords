{"lemma":"حَدَبِ","slug":"حَدَبِ","root":"ح.د.ب","root_slug":"ح-د-ب","root_link":"/words/roots/ح-د-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"حَدَب","root":"حدب","pos":"N","occurrence_count":1},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n7299","n7302","n7303"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AF%D9%8E%D8%A8%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7299","headword_ar":"حَدِبَ","root":"Hdb","body":[{"kind":"text","text":", aor"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadabN","text_ar":"حَدَبٌ"},{"kind":"text","text":"; (S, * A, Mgh, * Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AHdb~","text_ar":"احدبّ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tHAdb","text_ar":"تحادب","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AHdwdb","text_ar":"احدودب","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, humpbaked;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"italic_en","text":"he had a prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant, back, and a hollow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receding, chest"},{"kind":"text","text":"(A, * K)"},{"kind":"italic_en","text":"and belly:"},{"kind":"text","text":"(K:) [accord. to the Msb, from"},{"kind":"arabic","text_bw":"HadabN","text_ar":"حَدَبٌ"},{"kind":"text","text":"signifying “ elevated ground; ” but the reverse is indicated in the A:] and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the back)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, humped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant;"},{"kind":"text","text":"(S, A; *) as also ↓"},{"kind":"arabic","text_bw":"AnHdb","text_ar":"انحدب","orth_type":"arrow"},{"kind":"text","text":". (KL.) ―         -b2-  And the first, (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"rose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grew up"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out, high:"},{"kind":"text","text":"(KL:) ["},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, gibbous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"convex;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHdwdb","text_ar":"احدودب","orth_type":"arrow"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"Hadiba Ealyohi","text_ar":"حَدِبَ عَليْهِ"},{"kind":"text","text":", (S, A, K,) inf. n. as above; (KL, TA;) and ↓"},{"kind":"arabic","text_bw":"tHd~b","text_ar":"تحدّب","orth_type":"arrow"},{"kind":"text","text":"; (S, A, K;) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affectionate, favourable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind, to him."},{"kind":"text","text":"(S, A, * K, KL, TA.) And"},{"kind":"arabic","text_bw":"Hadibato EalaY waladihaA","text_ar":"حَدِبَتْ عَلَى وَلَدِهَا"},{"kind":"text","text":", (K, * TA,) inf. n. as above; (TA;) and ↓"},{"kind":"arabic","text_bw":"tHd~bt","text_ar":"تحدّبت","orth_type":"arrow"},{"kind":"text","text":"; (K;) (tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"applied herself constantly to the care of her child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"children, after the loss of her husband, not marrying again."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"Hadaba","text_ar":"حَدَبَ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadobN","text_ar":"حَدْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He repelled from him, and defended him."},{"kind":"text","text":"(MF, TA.)"}],"source_refs":["K","KL","S","A"]},{"entry_id":"n7302","headword_ar":"حَدَبٌ","root":"Hdb","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"High,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, ground;"},{"kind":"text","text":"so in the Kur xxi. 96; (S, A, Msb;) as also ↓"},{"kind":"arabic","text_bw":"HadabapN","text_ar":"حَدَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and so"},{"kind":"arabic","text_bw":"HadabN mina AlA^aroDi","text_ar":"حَدَبٌ مِنَ الاَرْضِ"},{"kind":"text","text":": (A:) or"},{"kind":"italic_en","text":"rugged and high ground:"},{"kind":"text","text":"(T, K:) pl."},{"kind":"arabic","text_bw":"HidaAbN","text_ar":"حِدَابٌ"},{"kind":"text","text":"(S) [and app., accord. to the TA,"},{"kind":"arabic","text_bw":"A^aHodaAbN","text_ar":"اَحْدَابٌ"},{"kind":"text","text":"also, a pl. of pauc.]. And"},{"kind":"arabic","text_bw":"Hadabu Alr~amoli","text_ar":"حَدَبُ الرَّمْلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Sand brought by the wind,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"blown together,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and elevated."},{"kind":"text","text":"(A, TA.) And hence, as being likened to such sand, (IAar, TA,)"},{"kind":"arabic","text_bw":"Hadabu AlbuhomaY","text_ar":"حَدَبُ البُهْمَى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"What is scattered, and heaped up, of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the species of barley-grass called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"bhmY","text_ar":"بهمى"},{"kind":"text","text":". (IAar, K, TA.) And"},{"kind":"arabic","text_bw":"Hadabu AlmaA='i","text_ar":"حَدَبُ المَا=ءِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The elevated waves of water:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"the rolling over of water, volume over volume:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"the rolling of water in waves."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Hadabu Algadiyri","text_ar":"حَدَبُ الغَدِيرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The motion and waves of the pool of water left by a torrent."},{"kind":"text","text":"(IAar, TA.) And"},{"kind":"arabic","text_bw":"Hadabu Als~ayol","text_ar":"حَدَبُ السَّيْل"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The rise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swell, and abundance, of the torrent."},{"kind":"text","text":"(A, TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"A slope in a declivity;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"HaduwrN fiY SababK","text_ar":"حَدُورٌ فِى صَبَبٍ"},{"kind":"text","text":", as in the correct copies of the K, and in the L; in some copies of the K"},{"kind":"arabic","text_bw":"Hdwb","text_ar":"حدوب"},{"kind":"text","text":"; (TA;) [in the CK"},{"kind":"arabic","text_bw":"HuduwrN","text_ar":"حُدُورٌ"},{"kind":"text","text":";] as the"},{"kind":"arabic","text_bw":"Hadab","text_ar":"حَدَب"},{"kind":"text","text":"of waves (in some copies of the K, of the wind, TA, [an evident mistranscription,"},{"kind":"arabic","text_bw":"AlryH","text_ar":"الريح"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"Almwj","text_ar":"الموج"},{"kind":"text","text":",]) and of sand. (K.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"A mark left upon the skin;"},{"kind":"text","text":"(As, K;) such as the ["},{"kind":"italic_en","text":"weal"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"swelling and thickness produced by beating."},{"kind":"text","text":"(As, TA.) ―         -b4-  (tropical:)  The"},{"kind":"italic_en","text":"intenseness of the cold"},{"kind":"text","text":"of winter. (A, K.)       -A2-"},{"kind":"italic_en","text":"A certain plant:"},{"kind":"text","text":"or the ["},{"kind":"italic_en","text":"plant called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"naSiY~","text_ar":"نَصِىّ"},{"kind":"text","text":". (K.)"}],"source_refs":["A","T","K","S","IAar","TA"]},{"entry_id":"n7303","headword_ar":"حَدِبٌ","root":"Hdb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aHodabu","text_ar":"اَحْدَبُ"},{"kind":"text","text":". ―         -b2-  Also (tropical:)"},{"kind":"italic_en","text":"Affectionate, favourable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind."},{"kind":"text","text":"(A, TA.) You say,"},{"kind":"arabic","text_bw":"huwa HadibN","text_ar":"هُوَ حَدِبٌ"},{"kind":"arabic","text_bw":"EalaY A^axiyhi","text_ar":"عَلَى اَخِيهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is affectionate,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to his brother."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"A^aroDN HadibapN","text_ar":"اَرْضٌ حَدِبَةٌ"},{"kind":"italic_en","text":"A land abounding with the plant called"},{"kind":"arabic","text_bw":"Hadab","text_ar":"حَدَب"},{"kind":"text","text":". (K.)"}],"source_refs":[]}]},"classical_definitions":null}