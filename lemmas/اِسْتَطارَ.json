ll,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْتَطار","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27453"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D8%AA%D9%8E%D8%B7%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause to fly","tags":["transitive"]},{"pos":"verb","gloss":"to knock out of one's hand","tags":["transitive"]},{"pos":"verb","gloss":"to agitate, to alarm, to upset, to disturb","tags":["transitive"],"examples":[{"text":"وبهذا الشكل تخلصت الأندلس العربية من هذا الشرّ المستطير الذي كان يهدد بالقضاء على الدولة الأموية الناشئة لولا أن الظروف حالفت العرب.","english":"And thus Arab Andalusia freed herself of this disturbing malignancy which threatened the rising Ummayad state with elimination, were it not for the circumstances that favored the Arabs."}]},{"pos":"verb","gloss":"to disperse, to diffuse, to be scattered, to spread","tags":["intransitive"],"examples":[{"text":"يُوفُونَ بِالنَّذْرِ وَيَخَافُونَ يَوْمًا كَانَ شَرُّهُ مُسْتَطِيرًا","english":"They fulfil their vows and fear a Day where evil will spread."}]},{"pos":"verb","gloss":"to permeate, to be exuded (of a fragrance)","tags":["intransitive"]},{"pos":"verb","gloss":"to fly in all directions (of sparks)","tags":["intransitive"]},{"pos":"verb","gloss":"to vanish, to disappear","tags":["intransitive"]}]},"etymology":null,"ipa":["/is.ta.tˤaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27453","headword_ar":"استطار","root":"Tyr","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"to fly."},{"kind":"text","text":"See also 2. ―         -b2-  Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"He drew forth"},{"kind":"text","text":"a sword"},{"kind":"italic_en","text":"quickly from its scabbard."},{"kind":"text","text":"(K, * TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AusotuTiyra","text_ar":"اُسْتُطِيرَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(for ex., dust, S)"},{"kind":"italic_en","text":"was made to fly."},{"kind":"text","text":"(S, K.) You say,"},{"kind":"arabic","text_bw":"kaAda yusotaTaAru mino $id~api Eadowihi","text_ar":"كَادَ يُسْتَطَارُ مِنْ شِدَّةِ عَدْوِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He was almost made to fly by reason of the vehemence of his running"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"AusotuTiyra fuw^aAduhu mina AlfazaEi","text_ar":"اُسْتُطِيرَ فُوَادُهُ مِنَ الفَزَعِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"was made to fly away by reason of fright"},{"kind":"text","text":"]. (A.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"He was taken away quickly, as though the birds carried him away."},{"kind":"text","text":"(TA.) ―         -b5-  (assumed tropical:)"},{"kind":"italic_en","text":"He hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick, in running;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"he ran quickly;"},{"kind":"text","text":"(O, L;) said of a horse. (O, L, K.) [A signification of the pass. form; as though meaning he was made to fly.] ―         -b6-  (assumed tropical:)"},{"kind":"italic_en","text":"He was"},{"kind":"text","text":"["},{"kind":"italic_en","text":"flurried,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"frightened."},{"kind":"text","text":"(O, K.) [As though meaning originally he was made to fly by reason of fright.]       -A2-"},{"kind":"arabic","text_bw":"AstTAr","text_ar":"استطار"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the dawn)"},{"kind":"italic_en","text":"spread;"},{"kind":"text","text":"(S, A, Msb, K;)"},{"kind":"italic_en","text":"its light spread in the horizon:"},{"kind":"text","text":"(TA:) [see"},{"kind":"arabic","text_bw":"musotaTiyrN","text_ar":"مُسْتَطِيرٌ"},{"kind":"text","text":":] and the verb is used in the same sense in relation to other things: (S:) said of lightning,"},{"kind":"italic_en","text":"it spread in the horizon:"},{"kind":"text","text":"and of dust,"},{"kind":"italic_en","text":"it spread in the air:"},{"kind":"text","text":"and of evil,"},{"kind":"italic_en","text":"it spread."},{"kind":"text","text":"(TA.) See also 6. ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a crack in a wall)"},{"kind":"italic_en","text":"appeared and spread."},{"kind":"text","text":"(A. [See also"},{"kind":"arabic","text_bw":"AstTAl","text_ar":"استطال"},{"kind":"text","text":".])"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a slit, or crack, for"},{"kind":"arabic","text_bw":"Als~uwqu","text_ar":"السُّوقُ"},{"kind":"text","text":"in the K is a mistake for"},{"kind":"arabic","text_bw":"Al$~aq~u","text_ar":"الشَّقُّ"},{"kind":"text","text":", or, accord. to the L, a crack in a wall, TA)"},{"kind":"italic_en","text":"rose,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and appeared."},{"kind":"text","text":"(TA.) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a crack in a glass vessel, and wear in a garment,)"},{"kind":"italic_en","text":"became apparent in the parts thereof."},{"kind":"text","text":"(TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wall)"},{"kind":"italic_en","text":"cracked"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"from the beginning thereof to the end."},{"kind":"text","text":"(TA.) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a glass vessel)"},{"kind":"italic_en","text":"showed a crack in it from beginning to end."},{"kind":"text","text":"(TA.) [See also 7.]       -A3-"},{"kind":"arabic","text_bw":"AstTArt","text_ar":"استطارت"},{"kind":"text","text":"said of a bitch,"},{"kind":"italic_en","text":"She desired the male."},{"kind":"text","text":"(O, K.)"}],"source_refs":["TA","S","K"]}]},"classical_definitions":null}