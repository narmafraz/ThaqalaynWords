:"يَطِيحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِيحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطُحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَطِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طِحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طِحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طُحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طُحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطُوح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطُوح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n26453","n27246","n27431"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fall (of an object, a government, etc.)"},{"pos":"verb","gloss":"to become disturbed (of one's mind)"},{"pos":"verb","gloss":"to miss (of an arrow)"},{"pos":"verb","gloss":"to get lost (of a person, of wealth, etc.)"},{"pos":"verb","gloss":"to drown and perish"},{"pos":"verb","gloss":"to carry away"}]},"etymology":null,"ipa":["/tˤaː.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26453","headword_ar":"طَاحٍ","root":"THw and THY","body":[{"kind":"italic_en","text":"Spread; spread out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth; expanded;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended."},{"kind":"text","text":"(S, * K. [See also"},{"kind":"arabic","text_bw":"muTaH~K","text_ar":"مُطَحٍّ"},{"kind":"text","text":".]) And"},{"kind":"italic_en","text":"That has filled everything by its multitude:"},{"kind":"text","text":"(K, TA:) in this sense [or in the former sense as is implied in the S] applied to an army. (TA.) And one says"},{"kind":"arabic","text_bw":"miZal~apN TaAHiyapN","text_ar":"مِظَلَّةٌ طَاحِيَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maToHuw~apN","text_ar":"مَطْحُوَّةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maToHiy~apN","text_ar":"مَطْحِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A great"},{"kind":"text","text":"(T, K, TA)"},{"kind":"italic_en","text":"spreading"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(T, K, * TA.) And"},{"kind":"arabic","text_bw":"Almudaw~imapu AlT~awaAHiY","text_ar":"المُدَوِّمَةُ الطَّوَاحِى"},{"kind":"text","text":"The vultures"},{"kind":"italic_en","text":"that circle"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the sky"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"around"},{"kind":"italic_en","text":"the bodies of the slain."},{"kind":"text","text":"(S, TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"High, elevated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lofty:"},{"kind":"text","text":"so in the phrase"},{"kind":"arabic","text_bw":"laA waAlqamari","text_ar":"لَا وَالقَمَرِ"},{"kind":"arabic","text_bw":"AlT~aAHiY","text_ar":"الطَّاحِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"No, by the high moon"},{"kind":"text","text":"]; an oath of some of the Arabs. (TA.) [And"},{"kind":"italic_en","text":"Tall"},{"kind":"text","text":"as applied to a horse: so"},{"kind":"arabic","text_bw":"TAHY","text_ar":"طاحى"},{"kind":"text","text":"is expl. in the TA; but this, being without the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", is a mistake for"},{"kind":"arabic","text_bw":"TaAHK","text_ar":"طَاحٍ"},{"kind":"text","text":".] ―         -b3-  And"},{"kind":"italic_en","text":"A great congregated body of men."},{"kind":"text","text":"(IAar, K.)"}],"source_refs":["K","TA","T"]},{"entry_id":"n27246","headword_ar":"طَاحَ","root":"TwH","body":[{"kind":"text","text":", (S, A, L, K,) aor."},{"kind":"arabic","text_bw":"yaTuwHu","text_ar":"يَطُوحُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaTiyHu","text_ar":"يَطِيحُ"},{"kind":"text","text":", (S, L, K,) inf. n. of the former"},{"kind":"arabic","text_bw":"TawoHN","text_ar":"طَوْحٌ"},{"kind":"text","text":", and of the latter"},{"kind":"arabic","text_bw":"TayoHN","text_ar":"طَيْحٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to nought;"},{"kind":"text","text":"(S, A, K;) as also ↓"},{"kind":"arabic","text_bw":"tTw~H","text_ar":"تطوّح","orth_type":"arrow"},{"kind":"text","text":": (A:) or"},{"kind":"page_break","n":1889},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, at the point of perishing:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(i. e. anything, TA,)"},{"kind":"italic_en","text":"went away; passed away;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"came to nought."},{"kind":"text","text":"(TA.) ―         -b2-  And (as some say, TA)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, fell;"},{"kind":"text","text":"(S, A, K;) and so ↓"},{"kind":"arabic","text_bw":"tTw~H","text_ar":"تطوّح","orth_type":"arrow"},{"kind":"text","text":", as in the phrase"},{"kind":"arabic","text_bw":"tTw~H","text_ar":"تطوّح"},{"kind":"arabic","text_bw":"fiY Albiy^ori","text_ar":"فِى البِيْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It fell into the well"},{"kind":"text","text":"], said of a bucket. (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"He lost his way,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taAha","text_ar":"تَاهَ"},{"kind":"text","text":", (S, A, K,) in the land, (S, K,) or in the desert; as also ↓"},{"kind":"arabic","text_bw":"tT~wH","text_ar":"تطّوح","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tTy~H","text_ar":"تطيّح","orth_type":"arrow"},{"kind":"text","text":". (TA.) And, said of an arrow,"},{"kind":"italic_en","text":"It missed its aim."},{"kind":"text","text":"(Har p. 126.)       -A2-  And"},{"kind":"arabic","text_bw":"A^ayona TiyHa bika","text_ar":"اَيْنَ طِيحَ بِكَ"},{"kind":"italic_en","text":"Whither hast thou been taken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried, away?"},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"TAH bihi farasuhu","text_ar":"طاح بِهِ فَرَسُهُ"},{"kind":"italic_en","text":"His horse went away with him"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"carried him away"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like an arrow."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"maA kaAnato A_il~aA mazoHapF","text_ar":"مَا كَانَتْ اـِلَّا مَزْحَةً"},{"kind":"arabic","text_bw":"TaAHa bihaA lisaAniY","text_ar":"طَاحَ بِهَا لِسَانِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was nought but a jest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joke, which my tongue hastily uttered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"which my tongue let full"},{"kind":"text","text":"]. (A.) ―         -b2-  See also the next paragraph."}],"source_refs":["S","A","L","K"]},{"entry_id":"n27431","headword_ar":"طَاحَ","root":"TyH","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTiyHu","text_ar":"يَطِيحُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"TayoHN","text_ar":"طَيْحٌ"},{"kind":"text","text":": see 1 in art."},{"kind":"arabic","text_bw":"TwH","text_ar":"طوح"},{"kind":"text","text":". Sb says that this verb is [originally"},{"kind":"arabic","text_bw":"TawiHa","text_ar":"طَوِحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTowiHu","text_ar":"يَطْوِحُ"},{"kind":"text","text":", i. e.,] of the measure"},{"kind":"arabic","text_bw":"faEila","text_ar":"فَعِلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoEilu","text_ar":"يَفْعِلُ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"waliYa","text_ar":"وَلِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaliY","text_ar":"يَلِى"},{"kind":"text","text":"; accord. to those who say"},{"kind":"arabic","text_bw":"Taw~aHahu","text_ar":"طَوَّحَهُ"},{"kind":"text","text":", and not"},{"kind":"arabic","text_bw":"Tay~aHahu","text_ar":"طَيَّحَهُ"},{"kind":"text","text":": but accord. to those who say"},{"kind":"arabic","text_bw":"Tay~aHahu","text_ar":"طَيَّحَهُ"},{"kind":"text","text":", it is [originally"},{"kind":"arabic","text_bw":"TayaHa","text_ar":"طَيَحَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaToyiHu","text_ar":"يَطْيِحُ"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoEilu","text_ar":"يَفْعِلُ"},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"baAEa","text_ar":"بَاعَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yabiyEu","text_ar":"يَبِيعُ"},{"kind":"text","text":". (L, TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D8%A7%D8%AD/","headword_ar":"طاحَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=25716#50e73e","body_html":"<span>طاحَ يَطوحُ ويَطيحُ: هَلَكَ، أو أشْرَفَ على الهَلاكِ، وذَهَبَ، وسَقَطَ، وتاهَ في الأرضِ.</span><br><span>وطَوَّحَهُ فَتَطَوَّحَ: تَوَّهَه فَرَمى هو بِنَفْسِه هاهنا وهاهنا.</span><br><span>وطَوَّحَتْهُ الطَّوائِحُ: قَذَفَتْهُ القَواذِفُ، ولا يقالُ: المُطَوِّحاتُ، وهو نادِرٌ.</span><br><span>وطَوَّحَه: ضَرَبَه بالعَصا، أوبَعَثَه إلى أرضٍ لا يَجيءُ منها،</span><br><span>وـ به: ألْقاه في الهواءِ،</span><br><span>وـ بزَيْدٍ: حَمَلَه على رُكوبِ مَفازَةٍ مُهْلِكَةٍ.</span><br><span>والمِطْواحُ: العَصا،</span><br><span>ونِيَّةٌ طَوَحٌ، محرَّكةً: بَعيدةٌ.</span><br><span>والمَطاوِحُ: المقاذِفُ.</span><br><span>وتَطاوَحَتْ بهم النَّوَى: تَرامَتْ.</span><br><span>وأطاحَ شَعْرَه: أسْقَطَه،</span><br><span>وـ الشيءَ: أفْناه، وأذْهَبَه.</span><br><span>وطاوَحَه: رَاماه.</span>"}]}}