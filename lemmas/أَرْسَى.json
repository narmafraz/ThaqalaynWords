m","num":"s"},{"role":"present_1mp","form":"نَرْسُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَسَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَسَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْسَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":true,"lemma_key":"أَرْسَى","root":"رسو","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15536"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D9%92%D8%B3%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to anchor","examples":[{"text":".ميناء بنغازي البحري قد أعيد افتتاحه في الأول من أكتوبر الجاري، بعد أن شهد دخول باخرة “ليدي حلوم” التي كانت أول سفينة شحن ترسو في الميناء، منذ أكتوبر 2014","english":"The port of Banġāzī has been reopened in the 1st of the ongoing October after it has witnessed the entry of the steamer “Lady of Dreams” that has been the first freight ship that has anchored in the harbor, since October 2014."}]},{"pos":"verb","gloss":"to obtain something; to receive the knock down on something","tags":["figuratively"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15536","headword_ar":"ارسى","root":"rsw","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_irosaA='N","text_ar":"اـِرْسَا=ءٌ"},{"kind":"text","text":": see 1, in two places.       -A2-"},{"kind":"arabic","text_bw":"ArsAhu","text_ar":"ارساهُ"},{"kind":"italic_en","text":"He made it"},{"kind":"text","text":"(a thing, M, Msb)"},{"kind":"italic_en","text":"to become stationary, at rest, fixed, fast, firm, steady, steadfast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stable."},{"kind":"text","text":"(M, Msb, K.) And"},{"kind":"arabic","text_bw":"ArsY Als~afiynapa","text_ar":"ارسى السَّفِينَةَ"},{"kind":"text","text":", [inf. n. as above and also (as is shown by what follows)"},{"kind":"arabic","text_bw":"murosFY","text_ar":"مُرْسًى"},{"kind":"text","text":","},{"kind":"italic_en","text":"He anchored the ship;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he made the ship to rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become stationary, upon the anchor:"},{"kind":"text","text":"(TA:) or the meaning is, [in some instances,"},{"kind":"italic_en","text":"he grounded the ship;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"he made the lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part of the ship to reach the bottom of the water, so that she remained stationary."},{"kind":"text","text":"(M, TA.) You say also of a ship,"},{"kind":"arabic","text_bw":"turosaY baAlA^anojari","text_ar":"تُرْسَى بَالاَنْجَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She is made fast by means of the anchor"},{"kind":"text","text":"]: (M:) and of the anchor,"},{"kind":"arabic","text_bw":"yurosiY Als~afiynapa","text_ar":"يُرْسِى السَّفِينَةَ"},{"kind":"italic_en","text":"It makes fast the ship, so that it does not go on."},{"kind":"text","text":"(T, TA.) For the words of the Kur [xi. 43],"},{"kind":"arabic","text_bw":"bisomi A@ll~`hi mujoraAhaA wamurosaAhaA","text_ar":"بِسْمِ ا@للّٰهِ مُجْرَاهَا وَمُرْسَاهَا"},{"kind":"text","text":", (S, M, * K, *) meaning"},{"kind":"arabic","text_bw":"A_ijoraAw^uhaA waA_irosaAw^uhaA","text_ar":"اـِجْرَاوُهَا وَاـِرْسَاوُهَا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"In the name of God"},{"kind":"text","text":"be"},{"kind":"italic_en","text":"the making it to run and the making it to rest"},{"kind":"text","text":"], (Aboo-Is-hák, TA,) from"},{"kind":"arabic","text_bw":"A^ajorayotu","text_ar":"اَجْرَيْتُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^arosayotu","text_ar":"اَرْسَيْتُ"},{"kind":"text","text":", (so in one copy of the S,) or ["},{"kind":"italic_en","text":"its being made to run and its being made to rest,"},{"kind":"text","text":"] from"},{"kind":"arabic","text_bw":"A^ujoriyato","text_ar":"اُجْرِيَتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^urosiyoto","text_ar":"اُرْسِيْتْ"},{"kind":"text","text":", (so in another copy of the S,) some say"},{"kind":"arabic","text_bw":"majoraAhaA wamarosaAhaA","text_ar":"مَجْرَاهَا وَمَرْسَاهَا"},{"kind":"text","text":", (S, K,) meaning"},{"kind":"italic_en","text":"its running and its resting,"},{"kind":"text","text":"(Aboo-Is-hák, TA,) from"},{"kind":"arabic","text_bw":"jarato","text_ar":"جَرَتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rasato","text_ar":"رَسَتْ"},{"kind":"text","text":", (S, K,) [though] Az says that the readers agree in pronouncing the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"mrsAhA","text_ar":"مرساها"},{"kind":"text","text":"with damm, but differ as to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"mjrAhA","text_ar":"مجراها"},{"kind":"text","text":", the Koofees pro-"},{"kind":"page_break","n":1087},{"kind":"text","text":"nouncing this with fet-h, (TA,) or the latter reading may have the same meaning as the former, (Aboo-Is-hák, TA,) or the former reading may mean"},{"kind":"italic_en","text":"in the time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the place, of making it to run, and that of making it to rest,"},{"kind":"text","text":"and the latter reading may mean"},{"kind":"italic_en","text":"in the time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the place, of its running, and that of its resting,"},{"kind":"text","text":"for in each case each noun may be a n. of time or a n. of place or an inf. n.; (Bd, q. v.;) and some read"},{"kind":"arabic","text_bw":"mujoriyhaA","text_ar":"مُجْرِيهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"wamurosiyhaA","text_ar":"وَمُرْسِيهَا","orth_type":"arrow"},{"kind":"text","text":", as epithets applied to God, (M, K,)"},{"kind":"italic_en","text":"who maketh it to run and who maketh it to rest."},{"kind":"text","text":"(TA.) Accord. to Zj, (M,)"},{"kind":"arabic","text_bw":"yasoA^aluwnaka Eani A@ls~aAEapi","text_ar":"يَسْاَلُونَكَ عَنِ ا@لسَّاعَةِ"},{"kind":"arabic","text_bw":"A^ay~aAna murosaAhaA","text_ar":"اَيَّانَ مُرْسَاهَا"},{"kind":"text","text":", in the Kur [vii. 186 and lxxix. 42], means ["},{"kind":"italic_en","text":"They will ask thee respecting the"},{"kind":"arabic","text_bw":"sAEp","text_ar":"ساعة"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"when will be its taking place?"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"when will be the time of its being made to take place?"},{"kind":"text","text":"]; (M, K; *) by the"},{"kind":"arabic","text_bw":"sAEp","text_ar":"ساعة"},{"kind":"text","text":"being meant the time in which all created beings shall die. (M.)"}],"source_refs":["TA","M","S","K"]}]},"classical_definitions":null}