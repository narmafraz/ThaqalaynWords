{"lemma":"مُعْتَدِلٌ","slug":"مُعْتَدِلٌ","root":"ع.د.ل","root_slug":"ع-د-ل","root_link":"/words/roots/ع-د-ل","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n28339"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D9%92%D8%AA%D9%8E%D8%AF%D9%90%D9%84%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"straight, even, proportionate"},{"pos":"adj","gloss":"temperate, mild, moderate"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of اِعْتَدَلَ (iʕtadala, “to straighten up”)."},"ipa":["/muʕ.ta.dil/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28339","headword_ar":"مُعْتَدِل","root":"Edl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having a right direction; straight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"even; equal; equable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uniform; symmetrical, proportionate; suitable in itself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in its parts:"},{"kind":"text","text":"see its verb]."},{"kind":"arabic","text_bw":"muEotadilapN","text_ar":"مُعْتَدِلَةٌ"},{"kind":"text","text":"applied to a she-camel means"},{"kind":"italic_en","text":"Whose limbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members, are rendered even, one with another,"},{"kind":"text","text":"(Lth, Az, TA,)"},{"kind":"italic_en","text":"including her hump and other parts;"},{"kind":"text","text":"as is the case when she becomes fat: erroneously said by Sh, on the authority of Mohárib, to be"},{"kind":"arabic","text_bw":"muEanodalap","text_ar":"مُعَنْدَلَة"},{"kind":"text","text":", belonging to art."},{"kind":"arabic","text_bw":"Endl","text_ar":"عندل"},{"kind":"text","text":". (Az, TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Of a middling sort, in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality;"},{"kind":"text","text":"as a body between tallness and shortness, and water between the hot and the cold; and ["},{"kind":"italic_en","text":"moderate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"temperate,"},{"kind":"text","text":"] as a day of which the air is pleasant; contr. of"},{"kind":"arabic","text_bw":"muEota*ilN","text_ar":"مُعْتَذِلٌ"},{"kind":"text","text":", with the pointed"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"farasN muEotadilu Alfrqi","text_ar":"فَرَسٌ مُعْتَدِلُ الفرقِ"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"Alfaroqi","text_ar":"الفَرْقِ"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"A horse whose"},{"kind":"arabic","text_bw":"gur~ap","text_ar":"غُرَّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"blaze"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"occupies the middle of his forehead, not reaching to one of the eyes nor inclining upon one of the cheeks."},{"kind":"text","text":"(AO, TA.)"},{"kind":"arabic","text_bw":"A^ay~aAmN muEotadilaAtN","text_ar":"اَيَّامٌ مُعْتَدِلَاتٌ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"Days moderate in temperature;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"pleasant, not hot, days."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlmuEotadilaAtu","text_ar":"المُعْتَدِلَاتُ"},{"kind":"text","text":"is applied to"},{"kind":"italic_en","text":"Forty nights of varying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alternating, heat and cold, commencing from the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"auroral"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"rising of Suheyl"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Canopus,"},{"kind":"text","text":"which, in Central Arabia, at the commencement of the era of the Flight, was about the 4th of August, O. S.]: (AZ, TA in art."},{"kind":"arabic","text_bw":"Sfr","text_ar":"صفر"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SafariY~N","text_ar":"صَفَرِىٌّ"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"the days of heat known by the appel-lation of"},{"kind":"arabic","text_bw":"waqadaAtu suhayolK","text_ar":"وَقَدَاتُ سُهَيْلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the most vehement heats of Canopus"},{"kind":"text","text":"]; as also"},{"kind":"arabic","text_bw":"AlmuEota*ilaAtu","text_ar":"المُعْتَذِلَاتُ"},{"kind":"text","text":"[q. v.]. (El- Hareeree's Durrat-el-Ghowwás, in De Sacy's Anthol. Gramm. Arabe, p. 37 of the Arabic text.)"}],"source_refs":["Lth","Az","TA"]}]},"classical_definitions":null}