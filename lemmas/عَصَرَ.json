{"lemma":"عَصَرَ","slug":"عَصَرَ","root":"ع.ص.ر","root_slug":"ع-ص-ر","root_link":"/words/roots/ع-ص-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَصَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَصَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَصَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَصَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَصَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَصَرَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَصَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَصَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَصَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَصَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَصَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْصِر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْصِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْصِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْصِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْصِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْصِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْصِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْصِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْصِر","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْصِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْصِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْصِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْصِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْصِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْصِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْصِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْصِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"عَصَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"عَصَرْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَعْصِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْصِر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"عَصَرَ","root":"عصر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["","n29311","n29312","n29313","n29314","n29315"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B5%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to press, to squeeze, to wring"},{"pos":"verb","gloss":"to press, to squeeze, to wring; to extract juice from, to juice"},{"pos":"verb","gloss":"to modernize, revamp, to renovate, to fit to the age"},{"pos":"noun","gloss":"period of time; season; age, century, era; reign"},{"pos":"noun","gloss":"late afternoon"},{"pos":"noun","gloss":"late afternoon; ellipsis of صَلَاة الْعَصْر (ṣalā(t) al-ʕaṣr, “late afternoon prayer”)","tags":["abbreviation","alt-of","ellipsis"]},{"pos":"noun","gloss":"verbal noun of عَصَرَ (ʕaṣara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of عُصُر (ʕuṣur), عَصْر (ʕaṣr), عِصْر (ʕiṣr), and عُصْر (ʕuṣr)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Compare Aramaic עצר (“to squeeze, press”)."},"ipa":["/ʕa.sˤa.ra/","/ʕasˤ.sˤa.ra/","/ʕasˤr/","/ʕisˤr/","/ʕusˤr/","/ʕu.sˤur/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29311","headword_ar":"عَصْرٌ","root":"ESr","body":[{"kind":"text","text":"[which is the most common form] and ↓"},{"kind":"arabic","text_bw":"EuSurN","text_ar":"عُصُرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EuSorN","text_ar":"عُصْرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, O, K) and ↓"},{"kind":"arabic","text_bw":"EiSorN","text_ar":"عِصْرٌ","orth_type":"arrow"},{"kind":"text","text":"(A, O, K)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"dahorN","text_ar":"دَهْرٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"Time;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a time;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a space"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period of time"},{"kind":"text","text":"]; (S, A, O, Msb, K;) or"},{"kind":"italic_en","text":"any unlimited extent of time, during which peoples pass away and become extinct;"},{"kind":"text","text":"(Esh-Shiháb, in the “ Sharh esh-Shifè; ”) ["},{"kind":"italic_en","text":"a succession of ages:"},{"kind":"text","text":"] such is said by Fr to be its meaning in the Kur ciii. l: (TA:) pl. (of pauc., O)"},{"kind":"arabic","text_bw":"A^aEoSurN","text_ar":"اَعْصُرٌ"},{"kind":"text","text":"(O, K) and"},{"kind":"arabic","text_bw":"A^aEoSaArN","text_ar":"اَعْصَارٌ"},{"kind":"text","text":"; (K;) and [of mult.]"},{"kind":"arabic","text_bw":"EuSuwrN","text_ar":"عُصُورٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"EuSurN","text_ar":"عُصُرٌ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"maA faEalotuhu EaSorFA","text_ar":"مَا فَعَلْتُهُ عَصْرًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biEaSorK","text_ar":"بِعَصْرٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I did it not in its time."},{"kind":"text","text":"(A.) And ↓"},{"kind":"arabic","text_bw":"jaA='u l`kin~a lamo yajiy^o liEuSorK","text_ar":"جَا=ءُ لٰكِنَّ لَمْ يَجِيْ لِعُصْرٍ","orth_type":"arrow"},{"kind":"italic_en","text":"He came, but he came not at the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"proper"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"time of coming."},{"kind":"text","text":"(AZ, O, K: but AZ relates it without"},{"kind":"arabic","text_bw":"lkn~","text_ar":"لكنّ"},{"kind":"text","text":". TA.) And ↓"},{"kind":"arabic","text_bw":"naAma wamaA naAma liEuSorK","text_ar":"نَامَ وَمَا نَامَ لِعُصْرٍ","orth_type":"arrow"},{"kind":"text","text":", (K,) or, accord. to AZ and Sgh and the author of the L and others,"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"nAm EuSorFA","text_ar":"نام عُصْرًا","orth_type":"arrow"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He slept, but hardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scarcely, slept."},{"kind":"text","text":"(AZ, K, &c.) And"},{"kind":"arabic","text_bw":"naAma fulaAnN walamo yanamo EaSorFA","text_ar":"نَامَ فُلَانٌ وَلَمْ يَنَمْ عَصْرًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biEaSorK","text_ar":"بِعَصْرٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a one slept, but slept not during a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"considerable period of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"day;"},{"kind":"text","text":"(A;) agreeably with other significations, here following. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a time,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEapN","text_ar":"سَاعَةٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of the day."},{"kind":"text","text":"(Katádeh, O.) ―         -b3-"},{"kind":"italic_en","text":"A day:"},{"kind":"text","text":"(K:) [or"},{"kind":"italic_en","text":"day, as opposed to night:"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"a night:"},{"kind":"text","text":"(K:) [or"},{"kind":"italic_en","text":"night, as opposed to day:"},{"kind":"text","text":"] also the"},{"kind":"italic_en","text":"morning, before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, sunrise;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gadaApN","text_ar":"غَدَاةٌ"},{"kind":"text","text":": and the"},{"kind":"italic_en","text":"afternoon;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evening;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"last part of the day; until the sun becomes red;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaSarN","text_ar":"عَصَرٌ","orth_type":"arrow"},{"kind":"text","text":", (IDrd, K.) Hence,"},{"kind":"arabic","text_bw":"AlEaSoraAni","text_ar":"العَصْرَانِ"},{"kind":"italic_en","text":"The night and the day:"},{"kind":"text","text":"(O, TA:) or"},{"kind":"italic_en","text":"night and day:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"the morning, before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, sunrise, and the afternoon"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evening;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the first part of the day and the last part thereof:"},{"kind":"arabic","text_bw":"AlgadaApu waAlEa$iY~u","text_ar":"الغَدَاةُ وَالعَشِىُّ"},{"kind":"text","text":". (ISk, S, O, Msb.) [See also"},{"kind":"arabic","text_bw":"AlA^aboradaAni","text_ar":"الاَبْرَدَانِ"},{"kind":"text","text":".] A poet says,"},{"kind":"quote","text":"waA^amoTuluhu AlEaSorayoni Hat~aY yamal~uniY\n                      \n                     \n                        wayaroDaY biniSofi Ald~ayoni waAlA^anofu raAgimu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I put him off, delaying the payment of his debt, morning and evening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from morning to evening, so that he loathes me, and is content with half of the debt, though unwilling"},{"kind":"text","text":"]: meaning, when he comes to me in the first part of the day, I promise to pay him in the last part of it: (ISk, S:) or, accord. to Sgh, the right reading (instead of"},{"kind":"arabic","text_bw":"wAlAnf rAgm","text_ar":"والانف راغم"},{"kind":"text","text":") is"},{"kind":"arabic","text_bw":"fiY gayori naAy^ili","text_ar":"فِى غَيْرِ نَايِلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"without liberality"},{"kind":"text","text":"]: and the verse is by 'Abd-Allah Ibn-Ez-Zubeyr El-Asadee. (TA.) ―         -b4-  Hence also (S, O)"},{"kind":"arabic","text_bw":"SalaApu","text_ar":"صَلَاةُ"},{"kind":"arabic","text_bw":"AlEaSori","text_ar":"العَصْرِ"},{"kind":"text","text":", (S, O, Msb,) and ↓"},{"kind":"arabic","text_bw":"SlAp AlEaSari","text_ar":"صلاة العَصَرِ","orth_type":"arrow"},{"kind":"text","text":", (O, TA,) fem. only, and simply"},{"kind":"arabic","text_bw":"AlEaSoru","text_ar":"العَصْرُ"},{"kind":"text","text":", [and ↓"},{"kind":"arabic","text_bw":"AlEaSaru","text_ar":"العَصَرُ","orth_type":"arrow"},{"kind":"text","text":",] mase. and fem., (Msb,) ["},{"kind":"italic_en","text":"The prayer of afternoon;"},{"kind":"text","text":"the time of which commences about mid-time between noon and nightfall; or accord. to the Shá- fi'ees, Málikees, and Hambelees, when the shade of an object, cast by the sun, is equal to the length of that object, added to the length of the shade which the same object casts at noon; and accord. to the Hanafees, when the shadow is equal to twice the length of the object added to the length of its mid-day shadow: its end being sunset, or the time when the sun becomes red:] so called because performed in one of the"},{"kind":"arabic","text_bw":"EaSoraAni","text_ar":"عَصْرَانِ"},{"kind":"text","text":", i. e., in the last portion of the day: (O:) also called"},{"kind":"arabic","text_bw":"AlS~alaApu AlwasoTaY","text_ar":"الصَّلَاةُ الوَسْطَى"},{"kind":"text","text":"[accord. to some], because it is between the two prayers of the day [that of daybreak and that of noon] and the two prayers of the night [that of sunset and that of nightfall]: (Abu-l-'Abbás:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEoSurN","text_ar":"اَعْصُرٌ"},{"kind":"text","text":"; and [of mult.]"},{"kind":"arabic","text_bw":"EuSuwrN","text_ar":"عُصُورٌ"},{"kind":"text","text":". (Msb.) [And hence likewise,]"},{"kind":"arabic","text_bw":"AlEaSoraAni","text_ar":"العَصْرَانِ"},{"kind":"text","text":"is applied in a trad. to"},{"kind":"italic_en","text":"The prayer of daybreak and that of the"},{"kind":"arabic","text_bw":"EaSor","text_ar":"عَصْر"},{"kind":"text","text":"; one being made predominant over the other; (Msb, TA;) as is the case in"},{"kind":"arabic","text_bw":"AlqamaraAni","text_ar":"القَمَرَانِ"},{"kind":"text","text":"applied to the sun and the moon; (TA;) or they are so called because they are performed at the two extremities of the"},{"kind":"arabic","text_bw":"EaSoraAni","text_ar":"عَصْرَانِ"},{"kind":"text","text":", meaning the night and the day; (Msb, TA;) but the former is the more likely. (TA.) [See an ex. of the dim.,"},{"kind":"arabic","text_bw":"AlEuSayoru","text_ar":"العُصَيْرُ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"murohiqap","text_ar":"مُرْهِقَة"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"rhq","text_ar":"رهق"},{"kind":"text","text":".] ―         -b5-  You say also,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN EaSorFA","text_ar":"جَا=ءَ فُلَانٌ عَصْرًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Such a one came late."},{"kind":"text","text":"(Ks, S, O.)       -A2-  See also"},{"kind":"arabic","text_bw":"EaSiyrN","text_ar":"عَصِيرٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"Rain from the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"clouds called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"muEoSiraAt","text_ar":"مُعْصِرَات"},{"kind":"text","text":". (K.)       -A3-  Also A man's ["},{"kind":"italic_en","text":"near kinsfolk such as are termed his"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rahoT","text_ar":"رَهْط"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ea$iyrap","text_ar":"عَشِيرَة"},{"kind":"text","text":": (O, K, * TA:) or his"},{"kind":"arabic","text_bw":"EaSabap","text_ar":"عَصَبَة"},{"kind":"text","text":"[q. v.]. (TA.)"}],"source_refs":["S","A","O","Msb","K","TA","ISk"]},{"entry_id":"n29312","headword_ar":"عُصْرٌ","root":"ESr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":", in four places.       -A2-  And see also"},{"kind":"arabic","text_bw":"EaSarN","text_ar":"عَصَرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n29313","headword_ar":"عِصْرٌ","root":"ESr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n29314","headword_ar":"عَصَرٌ","root":"ESr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":", in three places.       -A2-  Also"},{"kind":"italic_en","text":"A place to which one has recourse for refuge, protection, preservation, concealment, covert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lodging; a place of refuge; an asylum; a refuge:"},{"kind":"text","text":"(S, O, K:) and"},{"kind":"italic_en","text":"a cause,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"means, of safety;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"manojaApN","text_ar":"مَنْجَاةٌ"},{"kind":"text","text":": (S, K:) as also ↓"},{"kind":"arabic","text_bw":"EuSorN","text_ar":"عُصْرٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"EuSorapN","text_ar":"عُصْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O, TA) and ↓"},{"kind":"arabic","text_bw":"muEaS~arN","text_ar":"مُعَصَّرٌ","orth_type":"arrow"},{"kind":"text","text":"(O, K) and ↓"},{"kind":"arabic","text_bw":"muEotaSarN","text_ar":"مُعْتَصَرٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"EuSurN","text_ar":"عُصُرٌ","orth_type":"arrow"},{"kind":"text","text":", from which"},{"kind":"arabic","text_bw":"EuSorN","text_ar":"عُصْرٌ"},{"kind":"text","text":"is said to be contracted, (TA,) [and ↓"},{"kind":"arabic","text_bw":"EaSiyrapN","text_ar":"عَصِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":".] You say, ↓"},{"kind":"arabic","text_bw":"zayodN EuSoratiY","text_ar":"زَيْدٌ عُصْرَتِى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaSiyratiY","text_ar":"عَصِيرَتِى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEotaSariY","text_ar":"مَعْتَصَرِى","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Zeyd is my refuge"},{"kind":"text","text":"]. (A.)       -A3-  Also Dust; or"},{"kind":"italic_en","text":"dust raised and spreading;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gubaArN","text_ar":"غُبَارٌ"},{"kind":"text","text":": (S, O, K:) or"},{"kind":"italic_en","text":"vehement dust;"},{"kind":"text","text":"(TA;) which latter is also the signification of ↓"},{"kind":"arabic","text_bw":"EiSaArN","text_ar":"عِصَارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaSarapN","text_ar":"عَصَرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (O, K, TA:) or this last, or, accord. to some, ↓"},{"kind":"arabic","text_bw":"EuSorapN","text_ar":"عُصْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", has the former signification. (L.) It is said in a trad.,"},{"kind":"arabic","text_bw":"mar~ati A@moraA^apN mutaTay~ibapN li*ayolihaA EaSarN","text_ar":"مَرَّتِ ا@مْرَاَةٌ مُتَطَيِّبَةٌ لِذَيْلِهَا عَصَرٌ"},{"kind":"text","text":", (S, O,) or ↓"},{"kind":"arabic","text_bw":"EuSorapN","text_ar":"عُصْرَةٌ","orth_type":"arrow"},{"kind":"text","text":". or, as some relate it, ↓"},{"kind":"arabic","text_bw":"EaSarapN","text_ar":"عَصَرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (l.,)"},{"kind":"italic_en","text":"A perfumed woman passed by, her skirt having a dust"},{"kind":"text","text":"proceeding from it, (S, A, L,) occasioned by her dragging it along [upon the ground], (l.,) or occasioned by the abundance of the perfume: (A:) or ↓"},{"kind":"arabic","text_bw":"EaSarapN","text_ar":"عَصَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"may mean (tropical:)"},{"kind":"italic_en","text":"an exhalation of perfume:"},{"kind":"text","text":"(L, TA: *) [for] it has this meaning also: (IDrd, O:) but accord. to one relation, it is"},{"kind":"arabic","text_bw":"A_iEoSaArN","text_ar":"اـِعْصَارٌ"},{"kind":"text","text":", (L,) which also signifies"},{"kind":"italic_en","text":"dust raised by wind."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","O","K","TA","A","L","IDrd"]},{"entry_id":"n29315","headword_ar":"عُصُرٌ","root":"ESr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaSorN","text_ar":"عَصْرٌ"},{"kind":"text","text":":       -A2-  and see"},{"kind":"arabic","text_bw":"EaSarN","text_ar":"عَصَرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}