{"lemma":"عَرَجُ","slug":"عَرَجُ","root":"ع.ر.ج","root_slug":"ع-ر-ج","root_link":"/words/roots/ع-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28588","n28589","n28595","n28596","n28597","n28598","n28599"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B1%D9%8E%D8%AC%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ascend, to climb"},{"pos":"verb","gloss":"to be lame, to hobble, to limp"},{"pos":"verb","gloss":"to swerve, to turn"},{"pos":"verb","gloss":"to make lame, to make zigzag"},{"pos":"noun","gloss":"verbal noun of عَرِجَ (ʕarija)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of أَعْرَج (ʔaʕraj)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28588","headword_ar":"عَرَجَ","root":"Erj","body":[{"kind":"text","text":", (S, A, O, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"EuruwjN","text_ar":"عُرُوجٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"maEorajN","text_ar":"مَعْرَجٌ"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"page_break","n":1996},{"kind":"italic_en","text":"mounted."},{"kind":"text","text":"(S, A, O, K.) So in the saying"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"arabic","text_bw":"fiY Ald~arajapi","text_ar":"فِى الدَّرَجَةِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fY Als~ul~ami","text_ar":"فى السُّلَّمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted, the stair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the series of steps,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the ladder"},{"kind":"text","text":"]. (S, O.) And"},{"kind":"arabic","text_bw":"Earaja fiY Al$~aYo'K","text_ar":"عَرَجَ فِى الشَّىْءٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuruwjN","text_ar":"عُرُوجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted, upon the thing"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eurija bihi","text_ar":"عُرِجَ بِهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He was taken up"},{"kind":"text","text":"to a high place; as, for instance,"},{"kind":"arabic","text_bw":"A_ilaY EanaAni Als~amaA='i","text_ar":"اـِلَى عَنَانِ السَّمَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the clouds of Heaven"},{"kind":"text","text":"]. (Ham p. 87.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Earaja Al$~aYo'u","text_ar":"عَرَجَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing became high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":", (S, O, Msb, K,) with fet-h to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (O,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EarojN","text_ar":"عَرْجٌ"},{"kind":"text","text":"; (Msb; [accord. to the O"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":";]) or"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earuja","text_ar":"عَرُجَ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He limped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a slight lameness,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"and walked like the lame,"},{"kind":"text","text":"(S, O,)"},{"kind":"italic_en","text":"by reason of some accident that had befallen him"},{"kind":"text","text":"(S, O, Msb, K)"},{"kind":"italic_en","text":"in his leg"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot,"},{"kind":"text","text":"(S, O, K.)"},{"kind":"italic_en","text":"not naturally,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"not by reason of a chronic ailment:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earuja","text_ar":"عَرُجَ"},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"EarajaAnN","text_ar":"عَرَجَانٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"he walked like the lame, with a limping gait, by reason of some accident."},{"kind":"text","text":"(L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"(S, * O, * Msb, K, * TA) and"},{"kind":"arabic","text_bw":"EurojapN","text_ar":"عُرْجَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was lame, walked lamely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limped,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"naturally,"},{"kind":"text","text":"(S, O, K,) or"},{"kind":"italic_en","text":"by reason of a chronic ailment:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he became lame."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"below.] ―         -b3-"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"setting"},{"kind":"text","text":"of the sun: or its"},{"kind":"italic_en","text":"inclining towards the place of setting:"},{"kind":"text","text":"(S, O, K:) inf. n. of"},{"kind":"arabic","text_bw":"Earijato","text_ar":"عَرِجَتْ"},{"kind":"text","text":". (TK.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"emitted his urine indirectly:"},{"kind":"text","text":"said of the male only, when the hind girth is bound upon him [so as to press upon his sheath]: like"},{"kind":"arabic","text_bw":"Hqiba","text_ar":"حقِبَ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","A","O","K","Msb","TA"]},{"entry_id":"n28589","headword_ar":"عرّج","root":"Erj","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEoriyjN","text_ar":"تَعْرِيجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"(a building, or structure, S, O, and a river, or rivulet, TA)"},{"kind":"italic_en","text":"to incline."},{"kind":"text","text":"(S, O, K, TA.)       -A2-"},{"kind":"arabic","text_bw":"Ear~ajotu Eanohu","text_ar":"عَرَّجْتُ عَنْهُ"},{"kind":"italic_en","text":"I turned from it, and left it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsook it;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Enh","text_ar":"عنه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnErjt","text_ar":"انعرجت","orth_type":"arrow"},{"kind":"text","text":". (Msb.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Er~j Ealayohi","text_ar":"عرّج عَلَيْهِ"},{"kind":"italic_en","text":"He bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towards, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"mar~a bihi famaA Ear~aja Ealayohi","text_ar":"مَرَّ بِهِ فَمَا عَرَّجَ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He passed by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and did not bend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incline, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(A.) [But this may be otherwise rendered, as is shown by what follows.] ―         -b3-"},{"kind":"arabic","text_bw":"Er~j","text_ar":"عرّج"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He remained, stayed, abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelt;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"tEr~j","text_ar":"تعرّج","orth_type":"arrow"},{"kind":"text","text":". (T, TA.) You say,"},{"kind":"arabic","text_bw":"Er~j biAlmakaAni","text_ar":"عرّج بِالمَكَانِ"},{"kind":"italic_en","text":"He remained, stayed,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in the place."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Er~j EalaY Al$~aYo'i","text_ar":"عرّج عَلَى الشَّىْءِ"},{"kind":"text","text":", (O,) inf. n. as above, (S, A,)"},{"kind":"italic_en","text":"He remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, intent upon the thing;"},{"kind":"text","text":"(S, A, O;) as also"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tEr~j","text_ar":"تعرّج","orth_type":"arrow"},{"kind":"text","text":". (O.) See also"},{"kind":"arabic","text_bw":"EurojapN","text_ar":"عُرْجَةٌ"},{"kind":"text","text":", in two places: and see 2 in art."},{"kind":"arabic","text_bw":"Ewj","text_ar":"عوج"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"maA Ear~ajotu EalaY Al$~aYo'i","text_ar":"مَا عَرَّجْتُ عَلَى الشَّىْءِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I did not pause,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stop, at the thing:"},{"kind":"text","text":"(Msb: [and the like is said in the Mgh:]) or"},{"kind":"italic_en","text":"I did not care for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regard it."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"wbr","text_ar":"وبر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Er~j EalaY Almanozili","text_ar":"عرّج عَلَى المَنْزِلِ"},{"kind":"text","text":", (S, O, K,) and ↓"},{"kind":"arabic","text_bw":"tEr~j","text_ar":"تعرّج","orth_type":"arrow"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He confined his camel that he rode at the place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"and remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed:"},{"kind":"text","text":"(S, O:) or"},{"kind":"arabic","text_bw":"taEoriyjN","text_ar":"تَعْرِيجٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"confining the camel that one rides, remaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"staying, for one's travelling-companions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for some object of want:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eruj Aln~aAqapa","text_ar":"عرُج النَّاقَةَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he confined the she-camel."},{"kind":"text","text":"(TA.)       -A3-  See also 4."}],"source_refs":["O","S","A","K"]},{"entry_id":"n28595","headword_ar":"عَرْجٌ","root":"Erj","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EirojN","text_ar":"عِرْجٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A herd of camels consisting of about eighty:"},{"kind":"text","text":"(S, O, K:) or"},{"kind":"italic_en","text":"from seventy to eighty:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"from eighty to ninety:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a hundred and fifty and a little above that number:"},{"kind":"text","text":"(AO, S, O, K:) or"},{"kind":"italic_en","text":"from five hundred to a thousand:"},{"kind":"text","text":"(As, S, O, K:) or"},{"kind":"italic_en","text":"more than two hundred,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"near a thousand:"},{"kind":"text","text":"(AHát, TA:) or"},{"kind":"italic_en","text":"a thousand:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"many camels:"},{"kind":"text","text":"(AZ, TA:) pl."},{"kind":"arabic","text_bw":"A^aEoraAjN","text_ar":"اَعْرَاجٌ"},{"kind":"text","text":"[a pl. of pauc.] (S, O, K) and"},{"kind":"arabic","text_bw":"EuruwjN","text_ar":"عُرُوجٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","O","K","TA","AO","As","AZ"]},{"entry_id":"n28596","headword_ar":"عُرْجُ","root":"Erj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aEoraju","text_ar":"اَعْرَجُ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n28597","headword_ar":"عِرْجٌ","root":"Erj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EarojN","text_ar":"عَرْجٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28598","headword_ar":"عَرَجٌ","root":"Erj","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":": (Msb, TA:) [as a simple subst.,]"},{"kind":"italic_en","text":"Natural lameness;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"EurojapN","text_ar":"عُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", which is likewise an inf. n. of"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"maA A^a$ad~a Earajahu","text_ar":"مَا اَشَدَّ عَرَجَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How great is his natural lameness!"},{"kind":"text","text":"]: not"},{"kind":"arabic","text_bw":"maA A^aEorajahu","text_ar":"مَا اَعْرَجَهُ"},{"kind":"text","text":"; for from that which signifies a colour, or a quality in the body, one does not derive the form"},{"kind":"arabic","text_bw":"maA A^afoEalahu","text_ar":"مَا اَفْعَلَهُ"},{"kind":"text","text":". (S, O.)       -A2-  Also"},{"kind":"italic_en","text":"A river,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rivulet:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a valley:"},{"kind":"text","text":"because of their bending, or inclining. (TA.)"}],"source_refs":["Msb","TA"]},{"entry_id":"n28599","headword_ar":"عَرِجٌ","root":"Erj","body":[{"kind":"text","text":"A camel"},{"kind":"italic_en","text":"that emits his urine indirectly:"},{"kind":"text","text":"(O, K, TA:) an epithet applied to the male only. (TA. [See 1, last sentence.])"}],"source_refs":["O","K","TA"]}]}}