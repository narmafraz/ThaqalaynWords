{"lemma":"عَذَرَ","slug":"عَذَرَ","root":"ع.ذ.ر","root_slug":"ع-ذ-ر","root_link":"/words/roots/ع-ذ-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَذَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَذَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَذَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَذَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَذَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَذَرَ","in_corpus":true,"count":18,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَذَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَذَرا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَذَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَذَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَذَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْذِر","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْذِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْذِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْذِر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْذِر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْذِر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْذِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَذَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَذَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":32,"cross_references":{"qac":{"found":true,"lemma_key":"عَذَرَ","root":"عذر","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n28429","n28434","n28435","n28436"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B0%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to excuse","tags":["transitive"],"examples":[{"text":"اِعْذِرْنِي.","english":"Excuse me."}]},{"pos":"noun","gloss":"excuse","examples":[{"text":"عُذْرٌ أَقْبَحُ مِنْ ذَنْب","english":"An excuse that is worse than the offence itself."}]},{"pos":"noun","gloss":"plural of عِذَار (ʕiḏār)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-West Semitic *ʕaḏr- m (“help”, verbal noun). Cognates with Sabaean 𐩲𐩹𐩧 (ʿḏr, “excuse, pardon”) and Hebrew עזרה (ʿezrá, “help”)."},"ipa":["/ʕa.ða.ra/","/ʕuðr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28429","headword_ar":"عذّر","root":"E*r","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEo*iyrN","text_ar":"تَعْذِيرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was without excuse;"},{"kind":"text","text":"(K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"EA*r","text_ar":"عاذر","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"muEaA*arapN","text_ar":"مُعَاذَرَةٌ"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"he affected to excuse himself, but had no excuse: he excused himself, but did not adduce an excuse"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that was valid"},{"kind":"text","text":"]. (TA.) [See also 8.] ―         -b2-  And"},{"kind":"italic_en","text":"He was remiss, wanting, deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective,"},{"kind":"text","text":"(S, O, Msb, TA,) in an affair, (S, Msb,)"},{"kind":"italic_en","text":"setting up an excuse"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for being so"},{"kind":"text","text":"]; (O;)"},{"kind":"italic_en","text":"fell short,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did less than was incumbent on him,"},{"kind":"text","text":"(S, O, Msb, TA,) in it; (S, Msb;)"},{"kind":"italic_en","text":"did not exert himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"act vigorously,"},{"kind":"text","text":"in it; (Msb, TA;)"},{"kind":"italic_en","text":"causing it to be imagined that he had an excuse when he had none."},{"kind":"text","text":"(Bd in ix. 91.) You say,"},{"kind":"arabic","text_bw":"qaAma fulaAnN qiyaAma taEo*iyrK","text_ar":"قَامَ فُلَانٌ قِيَامَ تَعْذِيرٍ"},{"kind":"italic_en","text":"Such a one acted remissly, falling short,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doing less than was incumbent on him."},{"kind":"text","text":"(TA.) And it is said in a story of the Children of Israel,"},{"kind":"arabic","text_bw":"nahaAhumo A^aHobaAruhumo taEo*iyrFA","text_ar":"نَهَاهُمْ اَحْبَارُهُمْ تَعْذِيرًا"},{"kind":"italic_en","text":"Their learned men forbade them remissly:"},{"kind":"text","text":"the inf. n. being here put in the place of the act. part. n. as a denotative of state; as it is in"},{"kind":"arabic","text_bw":"jaA='a ma$oyFA","text_ar":"جَا=ءَ مَشْيًا"},{"kind":"text","text":". (O, TA.) [See also 4.]       -A2-  Also (tropical:)"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared, a feast,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"such as is termed"},{"kind":"arabic","text_bw":"A_iEo*aAr","text_ar":"اـِعْذَار"},{"kind":"text","text":"[q. v.] (O) or"},{"kind":"arabic","text_bw":"Ei*aAr","text_ar":"عِذَار"},{"kind":"text","text":": (K:) and"},{"kind":"italic_en","text":"he invited to a feast such as is thus termed."},{"kind":"text","text":"(K. [Accord. to the TA, these are two distinct significations of the verb. See, again, 4.])       -A3-"},{"kind":"arabic","text_bw":"E*~r Alfarasa","text_ar":"عذّر الفَرَسَ"},{"kind":"text","text":": see 1, latter half, in two places. ―         -b2-"},{"kind":"arabic","text_bw":"Ea*~iro Ean~iY baEiyraka","text_ar":"عَذِّرْ عَنِّى بَعِيرَكَ"},{"kind":"text","text":", (S, O,) and"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEo*irohu","text_ar":"اَعْذِرْهُ","orth_type":"arrow"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"Brand thy camel with a brand different from that of mine, in order that our camels may be known, one from the other."},{"kind":"text","text":"(S, O.) ―         -b3-"},{"kind":"arabic","text_bw":"E*~r AlgulaAmu","text_ar":"عذّر الغُلَامُ"},{"kind":"italic_en","text":"The hair of the boy's"},{"kind":"arabic","text_bw":"Ei*aAr","text_ar":"عِذَار"},{"kind":"text","text":"(K, TA) i. e. of his"},{"kind":"italic_en","text":"cheek"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"grew."},{"kind":"text","text":"(K, TA.)       -A4-"},{"kind":"arabic","text_bw":"E*~r Ald~aAra","text_ar":"عذّر الدَّارَ"},{"kind":"text","text":"(inf. n. as above, TA)"},{"kind":"italic_en","text":"He effaced the traces of the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling."},{"kind":"text","text":"(K, TA.)       -A5-"},{"kind":"arabic","text_bw":"E*~rhu","text_ar":"عذّرهُ"},{"kind":"text","text":", (S, O, K,) inf. n. as above, (S, O,)"},{"kind":"italic_en","text":"He defiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"besmeared, it"},{"kind":"text","text":"(a thing, K)"},{"kind":"italic_en","text":"with"},{"kind":"arabic","text_bw":"Ea*irap","text_ar":"عَذِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"human dung"},{"kind":"text","text":"]. (S, O, K.)"}],"source_refs":["K","TA","S","O","Msb"]},{"entry_id":"n28434","headword_ar":"عُذْرٌ","root":"E*r","body":[{"kind":"text","text":"(Msb, K) and ↓"},{"kind":"arabic","text_bw":"Eu*urN","text_ar":"عُذُرٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb) and ↓"},{"kind":"arabic","text_bw":"Ei*orapN","text_ar":"عِذْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O, K) and ↓"},{"kind":"arabic","text_bw":"Eu*oraY","text_ar":"عُذْرَى","orth_type":"arrow"},{"kind":"text","text":"(S, Msb) and ↓"},{"kind":"arabic","text_bw":"maEo*irapN","text_ar":"مَعْذِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"maEo*urapN","text_ar":"مَعْذُرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEo*arapN","text_ar":"مَعْذَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) [all as simple substs., but all except the third and the last mentioned also as inf. ns.,]"},{"kind":"italic_en","text":"An excuse; an apology; a plea whereby one excuses himself"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"another"},{"kind":"text","text":"]: accord. to the B,"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":"[as a subst. from"},{"kind":"arabic","text_bw":"AiEota*ara","text_ar":"اِعْتَذَرَ"},{"kind":"text","text":"or from"},{"kind":"arabic","text_bw":"A^aEo*ara","text_ar":"اَعْذَرَ"},{"kind":"text","text":"] is of three kinds;"},{"kind":"page_break","n":1985},{"kind":"text","text":"the saying “ I did it not; ” and the saying “ I did it for such a cause, ” mentioning what might exempt him from being culpable; and the saying “ I did it, but will not do it again, ” or the like; which third kind is the same as"},{"kind":"arabic","text_bw":"tawobapN","text_ar":"تَوْبَةٌ"},{"kind":"text","text":": (TA:) the pl. of"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^aEo*aArN","text_ar":"اَعْذَارٌ"},{"kind":"text","text":"; (Msb, K;) and that of ↓"},{"kind":"arabic","text_bw":"Ei*orapN","text_ar":"عِذْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"Ei*arN","text_ar":"عِذَرٌ"},{"kind":"text","text":"; (O;) and that of ↓"},{"kind":"arabic","text_bw":"mE*rp","text_ar":"معذرة","orth_type":"arrow"},{"kind":"text","text":"is ["},{"kind":"arabic","text_bw":"maEaA*iru","text_ar":"مَعَاذِرُ"},{"kind":"text","text":", and, irregularly,]"},{"kind":"arabic","text_bw":"maEaA*iyru","text_ar":"مَعَاذِيرُ"},{"kind":"text","text":": (TA:) and ↓"},{"kind":"arabic","text_bw":"Ea*iyrN","text_ar":"عَذِيرٌ","orth_type":"arrow"},{"kind":"text","text":", of which"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":", (Ksh,) or ↓"},{"kind":"arabic","text_bw":"Eu*urN","text_ar":"عُذُرٌ","orth_type":"arrow"},{"kind":"text","text":", (Bd,) may be pl., is syn. with ["},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"mE*rp","text_ar":"معذرة"},{"kind":"text","text":"; (Ksh and Bd in lxxvii. 6;) and ↓"},{"kind":"arabic","text_bw":"miEo*aArN","text_ar":"مِعْذَارٌ","orth_type":"arrow"},{"kind":"text","text":"is [likewise] syn. with"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":". (Bd in lxxv. 15.) It is said in a prov.,"},{"kind":"arabic","text_bw":"makaA*ibu","text_ar":"مَكَاذِبُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlmaEaA*iru","text_ar":"المَعَاذِرُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Excuses are lies"},{"kind":"text","text":"]. (TA.) And it was said by Ibráheem En-Nakha'ee,"},{"kind":"arabic","text_bw":"ya$uwbuhaA","text_ar":"يَشُوبُهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_in~a AlmaEaA*iyra","text_ar":"اـِنَّ المَعَاذِيرَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Alka*ibu","text_ar":"الكَذِبُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily excuses, lying mixes therewith"},{"kind":"text","text":"]. (S, O.) ―         -b2-"},{"kind":"arabic","text_bw":"Eu*orFA A^awo nu*orFA","text_ar":"عُذْرًا اَوْ نُذْرًا"},{"kind":"text","text":", in the Kur [lxxvii. 6], or"},{"kind":"arabic","text_bw":"A^awo nu*urFA","text_ar":"اَوْ نُذُرًا"},{"kind":"text","text":", ↓"},{"kind":"arabic","text_bw":"Eu*urFA","text_ar":"عُذُرًا","orth_type":"arrow"},{"kind":"text","text":", (Bd,) means"},{"kind":"italic_en","text":"For excusing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrifying;"},{"kind":"text","text":"the two ns. being inf. ns.: or"},{"kind":"italic_en","text":"for excuses"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"warnings;"},{"kind":"text","text":"the two ns. being pls., of ↓"},{"kind":"arabic","text_bw":"Ea*iyrN","text_ar":"عَذِيرٌ","orth_type":"arrow"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"mE*rp","text_ar":"معذرة"},{"kind":"text","text":"and of"},{"kind":"arabic","text_bw":"na*iyrN","text_ar":"نَذِيرٌ"},{"kind":"text","text":"in the sense"},{"kind":"arabic","text_bw":"A_ino*aArN","text_ar":"اـِنْذَارٌ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"such as excuse and such as warn;"},{"kind":"text","text":"the two ns. being pls. of ↓"},{"kind":"arabic","text_bw":"EaA*irN","text_ar":"عَاذِرٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muno*irN","text_ar":"مُنْذِرٌ"},{"kind":"text","text":": (Ksh, Bd:) or, accord. to Th, both mean the same. (TA.) [See also"},{"kind":"arabic","text_bw":"nu*orN","text_ar":"نُذْرٌ"},{"kind":"text","text":".] ―         -b3-  And the Arabs say,"},{"kind":"arabic","text_bw":"laA nu*oraAka","text_ar":"لَا نُذْرَاكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Eu*oraAka","text_ar":"عُذْرَاكَ","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"A^aEo*iro walaA tuno*iro","text_ar":"اَعْذِرْ وَلَا تُنْذِرْ"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"Do that for which thou wilt be excused,"},{"kind":"text","text":"by inflicting punishment when it is deserved,"},{"kind":"italic_en","text":"and do not"},{"kind":"text","text":"merely"},{"kind":"italic_en","text":"warn, and put in fear"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"n*r","text_ar":"نذر"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Success;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"attainment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplishment, of one's wants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a thing:"},{"kind":"text","text":"(IAar, O, K:) and"},{"kind":"italic_en","text":"victory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"success in a contest."},{"kind":"text","text":"(O, K.) One says, with respect to a war or a battle,"},{"kind":"arabic","text_bw":"limana AlEu*oru","text_ar":"لِمَنَ العُذْرُ"},{"kind":"italic_en","text":"Whose is the success,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"victory?"},{"kind":"text","text":"(O.)       -A3-  See also"},{"kind":"arabic","text_bw":"Eu*orapN","text_ar":"عُذْرَةٌ"},{"kind":"text","text":", in five places: and see"},{"kind":"arabic","text_bw":"Ei*aArN","text_ar":"عِذَارٌ"},{"kind":"text","text":", last quarter."}],"source_refs":["Msb","K","S","O","TA","Ksh","Bd","IAar"]},{"entry_id":"n28435","headword_ar":"عَذِرٌ","root":"E*r","body":[{"kind":"text","text":"[an epithet of which I find only the fem., with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", mentioned]."},{"kind":"arabic","text_bw":"daArN Ea*irapN","text_ar":"دَارٌ عَذِرَةٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"A house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling, of which there are many traces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relics."},{"kind":"text","text":"(O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"A^aroDN Ea*irapN","text_ar":"اَرْضٌ عَذِرَةٌ"},{"kind":"italic_en","text":"Land that does not yield herbage freely, and if it give growth to anything, this soon becomes blighted."},{"kind":"text","text":"(O and TA in art."},{"kind":"arabic","text_bw":"Evr","text_ar":"عثر"},{"kind":"text","text":".)"}],"source_refs":[]},{"entry_id":"n28436","headword_ar":"عُذُرٌ","root":"E*r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":", in three places.       -A2-  Also pl. of"},{"kind":"arabic","text_bw":"Ei*aArN","text_ar":"عِذَارٌ"},{"kind":"text","text":"[q. v.]. (S, O, Msb, K.)"}],"source_refs":[]}]}}