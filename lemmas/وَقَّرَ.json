{"lemma":"وَقَّرَ","slug":"وَقَّرَ","root":"#.ق.ر","root_slug":"_-ق-ر","root_link":"/words/roots/_-ق-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"وَقَّرْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"وَقَّرْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"وَقَّرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"وَقَّرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"وَقَّرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"وَقَّرَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"وَقَّرَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"وَقَّرا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"وَقَّرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"وَقَّرُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"وَقَّرْنَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُوَقِّر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُوَقِّرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُوَقِّرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُوَقِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُوَقِّرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُوَقِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُوَقِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُوَقِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُوَقِّر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُوَقِّر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُوَقِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُوَقِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوَقِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَقِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَقِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَقِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَقِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"وَقَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَقَّرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَقِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَقِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":true,"lemma_key":"وَقَّرَ","root":"وقر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n42236","n42240","n42241","n42242"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%82%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to treat with honor, deference, respect"}]},"etymology":null,"ipa":["/waq.qa.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42236","headword_ar":"وَقَرَ","root":"wqr","body":[{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"A^awoqara","text_ar":"اَوْقَرَ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"wuqirati Aln~axolapu","text_ar":"وُقِرَتِ النَّخْلَةُ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"A^awoqarat","text_ar":"اَوْقَرَت"},{"kind":"text","text":": see 4.       -A2-  [Hence,]"},{"kind":"arabic","text_bw":"waqara A@ll~`hu A^u*unahu","text_ar":"وَقَرَ ا@للّٰهُ اُذُنَهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqiruhaA","text_ar":"يَقِرُهَا"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"waqorN","text_ar":"وَقْرٌ"},{"kind":"text","text":", (S, Msb,) (tropical:)"},{"kind":"italic_en","text":"God made his ear heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull of hearing:"},{"kind":"text","text":"(Msb, K: *) or"},{"kind":"italic_en","text":"deaf."},{"kind":"text","text":"(S, K.) You say,"},{"kind":"arabic","text_bw":"A^all~`hum~a","text_ar":"اَللّٰهُمَّ"},{"kind":"arabic","text_bw":"qiro A^a*uhahu","text_ar":"قِرْ اَذُهَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"O God, make his ear heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull of hearing:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"deaf."},{"kind":"text","text":"(S.) ―         -b2-  [Hence also,]"},{"kind":"arabic","text_bw":"waqirato A^u*unuhu","text_ar":"وَقِرَتْ اُذُنُهُ"},{"kind":"text","text":", (ISk, S, TA,) aor."},{"kind":"arabic","text_bw":"tuwqaru","text_ar":"تُوقَرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"waqorN","text_ar":"وَقْرٌ"},{"kind":"text","text":"; (ISk, TA;) and"},{"kind":"arabic","text_bw":"waqirato","text_ar":"وَقِرَتْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tawoqaru","text_ar":"تَوْقَرُ"},{"kind":"text","text":"; (S, Msb, TA;) and"},{"kind":"arabic","text_bw":"waqarato","text_ar":"وَقَرَتْ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taqiru","text_ar":"تَقِرُ"},{"kind":"text","text":"; (Msb, TA;) inf. n."},{"kind":"arabic","text_bw":"waqorN","text_ar":"وَقْرٌ"},{"kind":"text","text":", (S, Msb, TA,) which by rule should be"},{"kind":"arabic","text_bw":"waqarN","text_ar":"وَقَرٌ"},{"kind":"text","text":", as inf. n. of"},{"kind":"arabic","text_bw":"waqirato","text_ar":"وَقِرَتْ"},{"kind":"text","text":", (S, TA,) but which is regular as inf. n. of"},{"kind":"arabic","text_bw":"waqarato","text_ar":"وَقَرَتْ"},{"kind":"text","text":"; (TA;) (tropical:)"},{"kind":"italic_en","text":"His ear was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull of hearing:"},{"kind":"text","text":"(Msb, TA: *) or"},{"kind":"italic_en","text":"deaf:"},{"kind":"text","text":"(S, TA:) but in the K we find, less properly,"},{"kind":"arabic","text_bw":"waqara","text_ar":"وَقَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waqira","text_ar":"وَقِرَ"},{"kind":"text","text":", [as though signifying"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dull of hearing:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deaf:"},{"kind":"text","text":"] inf. n."},{"kind":"arabic","text_bw":"waqorN","text_ar":"وَقْرٌ"},{"kind":"text","text":", which by rule should be"},{"kind":"arabic","text_bw":"waqarN","text_ar":"وَقَرٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"wuqira","text_ar":"وُقِرَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":". (TA.) You say also,"},{"kind":"arabic","text_bw":"waqarato A^u*uniY Eanohu","text_ar":"وَقَرَتْ اُذُنِى عَنْهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"My ear was dull of hearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deaf, to"},{"kind":"text","text":"(lit. from)"},{"kind":"italic_en","text":"him"},{"kind":"text","text":"]: (A:) and"},{"kind":"arabic","text_bw":"wuqirato Eani A@sotimaAEi kalaAmihi","text_ar":"وُقِرَتْ عَنِ ا@سْتِمَاعِ كَلَامِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"it was dull of hearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deaf, to"},{"kind":"text","text":"(lit. from)"},{"kind":"italic_en","text":"the hearing of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listening to, his speech"},{"kind":"text","text":"]. (A, TA: but in the latter,"},{"kind":"arabic","text_bw":"waqirato","text_ar":"وَقِرَتْ"},{"kind":"text","text":".) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"waqara","text_ar":"وَقَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqiru","text_ar":"يَقِرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"waqArN","text_ar":"وَقارٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless; rested;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":". (TA.) So in the phrase"},{"kind":"arabic","text_bw":"waqara fiY Alqalobi","text_ar":"وَقَرَ فِى القَلْبِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"rested in the heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waqarafiY","text_ar":"وَقَرَفِى"},{"kind":"arabic","text_bw":"Sadorihi","text_ar":"صَدْرِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a secret)"},{"kind":"italic_en","text":"rested in his bosom:"},{"kind":"text","text":"occurring in a trad., accord. to different relations. (TA.) You say also,"},{"kind":"arabic","text_bw":"kal~amotuhu kalimapF waqarato fiY A^u*unihi","text_ar":"كَلَّمْتُهُ كَلِمَةً وَقَرَتْ فِى اُذُنِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I spoke to him a speech which rested"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"vabatato","text_ar":"ثَبَتَتْ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in his ear."},{"kind":"text","text":"(As, A.) And"},{"kind":"arabic","text_bw":"waqara fiY Als~amoEi wawaEaAhu Alqalobu","text_ar":"وَقَرَ فِى السَّمْعِ وَوَعَاهُ القَلْبُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It rested in the ear; and the heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, kept it in memory"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"waqara fiY qalobihi ka*aA","text_ar":"وَقَرَ فِى قَلْبِهِ كَذَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a thing came into his mind and left its impression remaining."},{"kind":"text","text":"(A.) ―         -b4-  [And hence,]"},{"kind":"arabic","text_bw":"waqara","text_ar":"وَقَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqiru","text_ar":"يَقِرُ"},{"kind":"text","text":"; (Msb, K, TA;) and"},{"kind":"arabic","text_bw":"waqira","text_ar":"وَقِرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yawoqaru","text_ar":"يَوْقَرُ"},{"kind":"text","text":"; (TA;) inf. n."},{"kind":"arabic","text_bw":"waqorN","text_ar":"وَقْرٌ"},{"kind":"text","text":", (K, TA,) of the former, (TA,) and"},{"kind":"arabic","text_bw":"wuquwrapN","text_ar":"وُقُورَةٌ"},{"kind":"text","text":", (K, TA,) of the latter; (TA;) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"sat:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"he sat with"},{"kind":"arabic","text_bw":"waqaAr","text_ar":"وَقَار"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"gravity,"},{"kind":"text","text":"&c.]. (Msb.) ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"waqara","text_ar":"وَقَرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqiru","text_ar":"يَقِرُ"},{"kind":"text","text":"; (S, K;) and"},{"kind":"arabic","text_bw":"waqura","text_ar":"وَقُرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yawaquru","text_ar":"يَوَقُرُ"},{"kind":"text","text":"; (Msb, K;) inf. n."},{"kind":"arabic","text_bw":"waqaArN","text_ar":"وَقَارٌ"},{"kind":"text","text":", (S, Msb, K,) of the former, (S,) or of the latter, (Msb, K,) and"},{"kind":"arabic","text_bw":"qirapN","text_ar":"قِرَةٌ"},{"kind":"text","text":", of the former, (S, K,) and"},{"kind":"arabic","text_bw":"waqaArapN","text_ar":"وَقَارَةٌ"},{"kind":"text","text":", of the latter; (K;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, grave, staid, steady, sedate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calm;"},{"kind":"text","text":"(S, Msb, K;) [see"},{"kind":"arabic","text_bw":"waqaArN","text_ar":"وَقَارٌ"},{"kind":"text","text":", below;] as also ↓"},{"kind":"arabic","text_bw":"A_it~aqara","text_ar":"اـِتَّقَرَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tawaq~ara","text_ar":"تَوَقَّرَ","orth_type":"arrow"},{"kind":"text","text":": (K:) or this last, signifies"},{"kind":"italic_en","text":"he showed, exhibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifested, gravity, staidness, steadiness, sedateness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calmness:"},{"kind":"text","text":"(KL:) [and also, agreeably with analogy,"},{"kind":"italic_en","text":"he endeavoured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he constrained himself, to be grave,"},{"kind":"text","text":"&c.] It is said in the Kur. [xxxiii. 33,]"},{"kind":"arabic","text_bw":"waqirona fiY buyuwtikun~a","text_ar":"وَقِرْنَ فِى بُيُوتِكُنَّ"},{"kind":"text","text":"[meaning, accord. to some,"},{"kind":"italic_en","text":"And be ye grave,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in your houses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chambers"},{"kind":"text","text":"]: (S, A:) or the meaning is,"},{"kind":"italic_en","text":"and sit ye,"},{"kind":"text","text":"&c.: (TA:) and so another reading,"},{"kind":"arabic","text_bw":"waqazona","text_ar":"وَقَزْنَ"},{"kind":"text","text":": (TA:) or this latter, (S,) or each of these two readings, (TA,) is from"},{"kind":"arabic","text_bw":"AlqaraAru","text_ar":"القَرَارُ"},{"kind":"text","text":", (S,) [i. e.,] from"},{"kind":"arabic","text_bw":"qar~a","text_ar":"قَرَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqar~u","text_ar":"يَقَرُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaqir~u","text_ar":"يَقِرُّ"},{"kind":"text","text":"; (TA;) and is a contraction of"},{"kind":"arabic","text_bw":"A_iqorarona","text_ar":"اـِقْرَرْنَ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"A_iqorirona","text_ar":"اـِقْرِرْنَ"},{"kind":"text","text":"]. (S.)"}],"source_refs":["S","Msb","K","A","ISk","TA","KL"]},{"entry_id":"n42240","headword_ar":"وَقْرٌ","root":"wqr","body":[{"kind":"italic_en","text":"A heaviness in the ear;"},{"kind":"text","text":"(S, A, K;)"},{"kind":"italic_en","text":"a"},{"kind":"page_break","n":2961},{"kind":"italic_en","text":"heaviness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dulness, of hearing:"},{"kind":"text","text":"(Msb, TA:) or"},{"kind":"italic_en","text":"deafness; entire loss of hearing."},{"kind":"text","text":"(K, TA.) See 1."}],"source_refs":["Msb","TA"]},{"entry_id":"n42241","headword_ar":"وِقْرٌ","root":"wqr","body":[{"kind":"italic_en","text":"A load,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"in a general sense,"},{"kind":"text","text":"(A, K, TA,)"},{"kind":"italic_en","text":"whether heavy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moderate,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"of a mule"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of an ass"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a camel;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"mostly of a mule"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of an ass;"},{"kind":"text","text":"that of a camel being mostly termed"},{"kind":"arabic","text_bw":"wasoqN","text_ar":"وَسْقٌ"},{"kind":"text","text":": (S, TA:) or"},{"kind":"italic_en","text":"a heavy load:"},{"kind":"text","text":"(A, K:) or"},{"kind":"italic_en","text":"a weight that is carried upon the back"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"head:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^awoqaArN","text_ar":"اَوْقَارٌ"},{"kind":"text","text":". (A, K.) You say,"},{"kind":"arabic","text_bw":"jaA='a yaHomilu wiqorahu","text_ar":"جَا=ءَ يَحْمِلُ وِقْرَهُ"},{"kind":"italic_en","text":"He came carrying his load"},{"kind":"text","text":"[&c.]. (S.)"}],"source_refs":["S","A","Msb","K","TA"]},{"entry_id":"n42242","headword_ar":"وَقَرٌ","root":"wqr","body":[{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"waqurN","text_ar":"وَقُرٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"waquwrN","text_ar":"وَقُورٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}