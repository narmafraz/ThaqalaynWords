{"lemma":"مُبارَكُو","slug":"مُبارَكُو","root":"ب.ر.ك","root_slug":"ب-ر-ك","root_link":"/words/roots/ب-ر-ك","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُبارَك","root":"برك","pos":"N","occurrence_count":8},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n2380"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%A8%D8%A7%D8%B1%D9%8E%D9%83%D9%8F%D9%88"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of بَارَكَ (bāraka).","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"blesser"},{"pos":"adj","gloss":"passive participle of بَارَكَ (bāraka)","tags":["form-of","participle","passive"]},{"pos":"adj","gloss":"blessed"},{"pos":"adj","gloss":"fortunate, lucky"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of بَارَكَ (bāraka, “to bless”).\n\nDerived from the passive participle of بَارَكَ (bāraka, “to bless”). Compare Hebrew מְבֹרָךְ (məḇōrāḵ)"},"ipa":["/mu.baː.rik/","/mu.baː.rak/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2380","headword_ar":"مُبَارَكٌ","root":"brk","body":[{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"mubaArakN fiyhi","text_ar":"مُبَارَكٌ فِيهِ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", accord. to those who know not, or disallow,"},{"kind":"arabic","text_bw":"baAraka","text_ar":"بَارَكَ"},{"kind":"text","text":"as trans. without a preposition; and signifies"},{"kind":"italic_en","text":"Blessed, beatified, felicitated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prospered; gifted with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to possess,"},{"kind":"arabic","text_bw":"barakp","text_ar":"بَرَكة"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a blessing, any good that is bestowed by God, prosperity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good fortune, increase,"},{"kind":"text","text":"&c.]; (Msb;)"},{"kind":"italic_en","text":"abounding in good;"},{"kind":"text","text":"(Ksh and Bd in iii. 90;)"},{"kind":"italic_en","text":"abounding in advantage"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utility:"},{"kind":"text","text":"(Bd in vi. 92 and 156, and xxxviii. 28, and 1. 9:) the pl. applied to irrational things is"},{"kind":"arabic","text_bw":"mubaArakaAtN","text_ar":"مُبَارَكَاتٌ"},{"kind":"text","text":". (Msb.) You say also ↓"},{"kind":"arabic","text_bw":"bariykN","text_ar":"بَرِيكٌ","orth_type":"arrow"},{"kind":"text","text":"as meaning"},{"kind":"arabic","text_bw":"mubaAraka fiyhi","text_ar":"مُبَارَكَ فِيهِ"},{"kind":"text","text":": (K:) or"},{"kind":"arabic","text_bw":"TaEaAmN bariykN","text_ar":"طَعَامٌ بَرِيكٌ"},{"kind":"text","text":"is as though meaning"},{"kind":"arabic","text_bw":"mubaArakN","text_ar":"مُبَارَكٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Blessed food;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"food in which is a blessing,"},{"kind":"text","text":"&c.]. (S.)"}],"source_refs":["K"]}]},"classical_definitions":null}