{"role":"present_2mp","form":"تَرْهَنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْهَنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْهَن","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْهَن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْهَنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْهَنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْهَنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْهَنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْهَنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْهَنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْهَنَّ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرْهَن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْهَن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَهَنّا","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَهَنْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":64,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","prep","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n16910"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%87%D9%8E%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to mortgage, to pawn"},{"pos":"prep","gloss":"subject to, depending or conditional on, pending, liable to"},{"pos":"noun","gloss":"mortgage"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16910","headword_ar":"رَهَنَ","root":"rhn","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":", (S, TA,) or"},{"kind":"arabic","text_bw":"ruhuwnN","text_ar":"رُهُونٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb, TA)"},{"kind":"italic_en","text":"continued, subsisted, lasted, endured, remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remained fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, permanent, constant, firm, steady, stead fast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established."},{"kind":"text","text":"(S, Mgh, Msb, K, TA.) This is the primary signification. (Mgh, TA. *) ―         -b2-  Hence, (Mgh,)"},{"kind":"arabic","text_bw":"rahana biAlmakaAni","text_ar":"رَهَنَ بِالمَكَانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place."},{"kind":"text","text":"(A, Mgh, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"rahana","text_ar":"رَهَنَ"},{"kind":"text","text":", (JK, S, K,) aor."},{"kind":"text","text":", (K, TA,) or"},{"kind":"text","text":", (JK, [but this I think to be a mis take,]) inf. n."},{"kind":"arabic","text_bw":"ruhuwnN","text_ar":"رُهُونٌ"},{"kind":"text","text":", (K,) said of a man, and of a camel, (JK, S, * TA,) and of any beast (TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated;"},{"kind":"text","text":"(JK, S, K, TA;) and"},{"kind":"italic_en","text":"fatigued, tired, weary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded."},{"kind":"text","text":"(JK, TA.) You say,"},{"kind":"arabic","text_bw":"rakiba Hat~aY rahana","text_ar":"رَكِبَ حَتَّى رَهَنَ"},{"kind":"italic_en","text":"He rode until he became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated."},{"kind":"text","text":"(ISh, TA. [See"},{"kind":"arabic","text_bw":"raAhinN","text_ar":"رَاهِنٌ"},{"kind":"text","text":".])       -A2-  As trans., see 4, first signification. ―         -b2-  [Hence,] as a law term,"},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"putting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"placing,"},{"kind":"text","text":"an article of real property ["},{"kind":"italic_en","text":"to remain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"as a pledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"security,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"to be such, for a debt that is obligatory"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that will become obligatory."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"rahanahu Al$~aYo'a","text_ar":"رَهَنَهُ الشَّىْءَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rahanahu Einodahu","text_ar":"رَهَنَهُ عِنْدَهُ"},{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":"(Msb, TA) [and"},{"kind":"arabic","text_bw":"rahiynapN","text_ar":"رَهِينَةٌ"},{"kind":"text","text":", q. v. voce"},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"Arhnhu","text_ar":"ارهنهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"; (S, K;) all signify the same; (S;) i. e."},{"kind":"italic_en","text":"He deposited the thing with him"},{"kind":"text","text":"(Msb, K) ["},{"kind":"italic_en","text":"as a pledge"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to be in lieu of that which he had taken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received, from him:"},{"kind":"text","text":"(K:) [i. e."},{"kind":"italic_en","text":"he pledged the thing to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with him:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"rahanotu AlmataAEa","text_ar":"رَهَنْتُ المَتَاعَ"},{"kind":"arabic","text_bw":"biAld~ayoni","text_ar":"بِالدَّيْنِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I restricted the commodity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"placed it in custody, for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by reason of, the debt;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bAldyn","text_ar":"بالدين"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Arhnthu","text_ar":"ارهنتهُ","orth_type":"arrow"},{"kind":"text","text":"is a dial. var. thereof, but of rare occurrence, and disallowed by those who are held in esteem: (Msb:) for, properly, they say, (Msb,)"},{"kind":"arabic","text_bw":"zayodFA Alv~awoba","text_ar":"زَيْدًا الثَّوْبَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^arohanotu","text_ar":"اَرْهَنْتُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I gave to Zeyd the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, in order that he should deposit it as a pledge"},{"kind":"text","text":"(Msb, K *)"},{"kind":"italic_en","text":"with some one."},{"kind":"text","text":"(Msb.) 'Abd-Allah Ibn Hemmám Es-Saloolee says, (S,) or Hemmám Ibn-Murrah, (TA,)"},{"kind":"quote","text":"maAlikaA ↓ \n      najawotu wa A^arohanotuhumo \n                      \n                     \n                        falam~aA xa$iytu A^aZaAfiyrahumo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And when I dreaded their nails, I escaped, and gave them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left with them, as a pledge, Málik"},{"kind":"text","text":"]: thus, says Th, all relate the verse, except As, who says"},{"kind":"arabic","text_bw":"wa A^arohanuhumo mAlkA","text_ar":"وَ اَرْهَنُهُمْ مالكا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"leaving with them, as a pledge, Málik"},{"kind":"text","text":"]: he likens this phrase to the say ing"},{"kind":"arabic","text_bw":"qumotu wa A^aSuk~u wajohahu","text_ar":"قُمْتُ وَ اَصُكُّ وَجْهَهُ"},{"kind":"text","text":"; and this is a good way of explaining it; for the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is that which is a deno tative of state; the meaning being"},{"kind":"arabic","text_bw":"SaAk~FA wajohahu","text_ar":"صَاكًّا وَجْهَهُ"},{"kind":"text","text":": [accord. to the former reading, in the opinion of Th,] the poet means"},{"kind":"italic_en","text":"I left Málik remaining with them;"},{"kind":"text","text":"not as a pledge; because [when the leaving a thing as a pledge is meant, in his opinion,] one does not say,"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^arohanotu","text_ar":"اَرْهَنْتُ","orth_type":"arrow"},{"kind":"text","text":", but only"},{"kind":"arabic","text_bw":"rahanotuhu","text_ar":"رَهَنْتُهُ"},{"kind":"text","text":". (S, TA.) [See, however, 4.] You say also,"},{"kind":"arabic","text_bw":"rahanahu Eanohu","text_ar":"رَهَنَهُ عَنْهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, to be a pledge in lieu of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"a poet, asserted by IJ to be a pagan, says,"},{"kind":"quote","text":"Airohano baniyka Eanohumu A^arohano baniYo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Make thou thy sons to be pledges in lieu of them:"},{"kind":"text","text":"in that case"},{"kind":"italic_en","text":"I will make my sons to be pledges:"},{"kind":"arabic","text_bw":"baniY","text_ar":"بَنِى"},{"kind":"text","text":"being for"},{"kind":"arabic","text_bw":"baniY~a","text_ar":"بَنِىَّ"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"rahanotuhu lisaAniY","text_ar":"رَهَنْتُهُ لِسَانِى"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I made my tongue to be as though it were a pledge to him, to be restrained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to be used, for his sake"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefit"},{"kind":"text","text":"]: in this case one should not say ↓"},{"kind":"arabic","text_bw":"A^arohanotuhu","text_ar":"اَرْهَنْتُهُ","orth_type":"arrow"},{"kind":"text","text":"; (IAar, K;) though one says thus of a garment, or piece of cloth, [&c.,] as well as"},{"kind":"arabic","text_bw":"rahanotuhu","text_ar":"رَهَنْتُهُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Mgh","Msb","K","TA","JK"]}]}}