{"lemma":"شِرَى","slug":"شِرَى","root":"ش.ر.#","root_slug":"ش-ر-_","root_link":"/words/roots/ش-ر-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["","n22266","n22267","n22269","n22272"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%90%D8%B1%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22266","headword_ar":"شَرْىٌ","root":"$rY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"colocynth:"},{"kind":"text","text":"(S, K:) or it signifies, (K,) or signifies also, (S,) the"},{"kind":"italic_en","text":"plant thereof:"},{"kind":"text","text":"(S, K:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S:) and ↓"},{"kind":"arabic","text_bw":"$aroyaAnN","text_ar":"شَرْيَانٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies the"},{"kind":"italic_en","text":"colocynth;"},{"kind":"text","text":"as a dial. var. of"},{"kind":"arabic","text_bw":"$aroYN","text_ar":"شَرْىٌ"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"leaves thereof."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"huwa A^aHolaY mina","text_ar":"هُوَ اَحْلَى مِنَ"},{"kind":"arabic","text_bw":"AlA^aroYi waA^amar~u mina Al$~aroYi","text_ar":"الاَرْىِ وَاَمَرُّ مِنَ الشَّرْىِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, is sweeter than honey and more bitter than colocynth"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"fulaAnN lahu TaEomaAni A^aroYN wa$aroYN","text_ar":"فُلَانٌ لَهُ طَعْمَانِ اَرْىٌ وَشَرْىٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one has two flavours,"},{"kind":"text","text":"that of"},{"kind":"italic_en","text":"honey and"},{"kind":"text","text":"that of"},{"kind":"italic_en","text":"colocynth"},{"kind":"text","text":"]. (S, TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Any kind of plant that spreads upon the ground, running"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"creeping"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and extending; such as the melon and the cucumber."},{"kind":"text","text":"(AHn, O voce"},{"kind":"arabic","text_bw":"suT~aAHN","text_ar":"سُطَّاحٌ"},{"kind":"text","text":", q. v., and TA * in the present art.) ―         -b3-  And"},{"kind":"italic_en","text":"Palm-trees that grow from the datestones:"},{"kind":"text","text":"(K:) and with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"[as the n. un.]"},{"kind":"italic_en","text":"one of such palm-trees."},{"kind":"text","text":"(S.) ―         -b4-  And, accord. to IJ,"},{"kind":"italic_en","text":"A kind of tree of which bows are made."},{"kind":"text","text":"(L voce"},{"kind":"arabic","text_bw":"Hat~N","text_ar":"حَتٌّ"},{"kind":"text","text":", q. v. [See also"},{"kind":"arabic","text_bw":"$iroyaAnN","text_ar":"شِرْيَانٌ"},{"kind":"text","text":".])       -A2-  See also"},{"kind":"arabic","text_bw":"$arFY","text_ar":"شَرًى"},{"kind":"text","text":".       -A3-  And see"},{"kind":"arabic","text_bw":"$arowaY","text_ar":"شَرْوَى"},{"kind":"text","text":"."}],"source_refs":["S","K"]},{"entry_id":"n22267","headword_ar":"شَرًى","root":"$rY","body":[{"kind":"italic_en","text":"A road,"},{"kind":"text","text":"(K, TA,) in a general sense. (TA.) And, (K,) with the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", [particularly]"},{"kind":"italic_en","text":"A road of Selmà,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"the mountain so called,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"abounding with lions:"},{"kind":"text","text":"(S, K, TA:) whence they say of courageous men,"},{"kind":"arabic","text_bw":"maA humo","text_ar":"مَا هُمْ"},{"kind":"arabic","text_bw":"A_il~aA A^usuwdu Al$~araY","text_ar":"اـِلَّا اُسُودُ الشَّرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They are no other than the lions of Esh-Sharà"},{"kind":"text","text":"]. (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"naAHiyapN","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"An adjacent tract"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region"},{"kind":"text","text":"]; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"$araA='N","text_ar":"شَرَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) accord. to some,"},{"kind":"italic_en","text":"of the right hand:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^a$oraA='N","text_ar":"اَشْرَا=ءٌ"},{"kind":"text","text":". (S, K.) Hence,"},{"kind":"arabic","text_bw":"$araY","text_ar":"شَرَى"},{"kind":"arabic","text_bw":"AlfuraAti","text_ar":"الفُرَاتِ"},{"kind":"italic_en","text":"The adjacent tract"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"naAHiyap","text_ar":"نَاحِيَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the Euphrates:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"A^a$oraA='u AlHarami","text_ar":"اَشْرَا=ءُ الحَرَمِ"},{"kind":"italic_en","text":"the adjacent tracts of the Sacred Territory;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nawaAHiyhi","text_ar":"نَوَاحِيهِ"},{"kind":"text","text":". (S.) ―         -b3-  And"},{"kind":"italic_en","text":"A mountain."},{"kind":"text","text":"(K.)       -A2-  Also The"},{"kind":"italic_en","text":"bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worst, of cattle:"},{"kind":"text","text":"accord. to J, [in the S,] ↓"},{"kind":"arabic","text_bw":"$aroYN","text_ar":"شَرْىٌ","orth_type":"arrow"},{"kind":"text","text":", [said in the S to be like"},{"kind":"arabic","text_bw":"$awaY AlmaAli","text_ar":"شَوَى المَالِ"},{"kind":"text","text":",] which is [said to be] a mistake: (K:) but ElBedr El-Karáfee questions it being so: (TA:) and the"},{"kind":"italic_en","text":"good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"better,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"best, thereof;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"$araApN","text_ar":"شَرَاةٌ","orth_type":"arrow"},{"kind":"text","text":": thus having two contr. significations: (K:) and so says ISk: but ISd says that"},{"kind":"arabic","text_bw":"A_ibilN","text_ar":"اـِبِلٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$araApN","text_ar":"شَرَاةٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"saraApN","text_ar":"سَرَاةٌ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"choice camels."},{"kind":"text","text":"(TA.)       -A3-  And"},{"kind":"italic_en","text":"A certain eruption upon the body, resembling dirhems:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"small pimples"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purulent pustules, having a burning property:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"small pimples"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purulent pustules, red, itching, and distressing, generally originating at once,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"but sometimes gradually,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and becoming"},{"kind":"text","text":"["},{"kind":"italic_en","text":"more"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"severe by night in consequence of a hot vapour breaking forth at once upon the body:"},{"kind":"text","text":"(K, TA:) thus in the “ Kánoon ” of Ibn-Seenà [or Avicenna]. (TA.)       -A4-"},{"kind":"arabic","text_bw":"*uw Al$~araY","text_ar":"ذُو الشَّرَى"},{"kind":"italic_en","text":"A certain idol of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the tribe of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Dows"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dawos","text_ar":"دَوْس"},{"kind":"text","text":"), (K, TA,)"},{"kind":"italic_en","text":"in the Saráh"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Als~araAp","text_ar":"السَّرَاة"},{"kind":"text","text":"): so says Nasr. (TA.)"}],"source_refs":["K","TA","S"]},{"entry_id":"n22269","headword_ar":"شِرًى","root":"$rY","body":[{"kind":"text","text":", (S, TA,) an inf. n. of"},{"kind":"arabic","text_bw":"$araY","text_ar":"شَرَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"ya$oriY","text_ar":"يَشْرِى"},{"kind":"text","text":", (TA,) [when used as a simple subst., signifying"},{"kind":"italic_en","text":"A sale"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"a purchase,"},{"kind":"text","text":"] has"},{"kind":"arabic","text_bw":"A^a$oriyapN","text_ar":"اَشْرِيَةٌ"},{"kind":"text","text":"for its pl., which, as pl. of a sing. of the measure"},{"kind":"arabic","text_bw":"fiEalN","text_ar":"فِعَلٌ"},{"kind":"text","text":", is anomalous. (S, TA.)"}],"source_refs":["S","TA"]},{"entry_id":"n22272","headword_ar":"شَرِىٌّ","root":"$rY","body":[{"kind":"italic_en","text":"Sold:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"bought:"},{"kind":"text","text":"applied in this sense to a male slave; and"},{"kind":"arabic","text_bw":"$ariy~apN","text_ar":"شَرِيَّةٌ"},{"kind":"text","text":"to a female slave. (Msb.) ―         -b2-  Also A horse"},{"kind":"italic_en","text":"that persists,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perseveres, in his pace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"that exceeds the usual bounds therein,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and goes on without languor:"},{"kind":"text","text":"(TA:) or a"},{"kind":"italic_en","text":"choice"},{"kind":"text","text":"horse: (A, TA:) or an"},{"kind":"italic_en","text":"excellent, choice"},{"kind":"text","text":"horse. (TA.)"}],"source_refs":["S","K","TA","A"]}]}}