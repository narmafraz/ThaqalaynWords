{"lemma":"ذَمِيم","slug":"ذَمِيم","root":"ذ.م.م","root_slug":"ذ-م-م","root_link":"/words/roots/ذ-م-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n14023"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D9%85%D9%90%D9%8A%D9%85"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"obnoxious"}]},"etymology":null,"ipa":["/ða.miːm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14023","headword_ar":"ذَمِيمٌ","root":"*m","body":[{"kind":"italic_en","text":"Blamed, dispraised, discommended, found fault with, censured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reprehended;"},{"kind":"text","text":"(S, M, Mgh, Msb, K;)"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ma*omuwmN","text_ar":"مَذْمُومٌ","orth_type":"arrow"},{"kind":"text","text":"; (T, M, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"*im~N","text_ar":"ذِمٌّ","orth_type":"arrow"},{"kind":"text","text":"(T, K, TA) and ↓"},{"kind":"arabic","text_bw":"*am~N","text_ar":"ذَمٌّ","orth_type":"arrow"},{"kind":"text","text":", (M, K, TA,) which last is an inf. n. used as an epithet, and, like [its contr.]"},{"kind":"arabic","text_bw":"HamodN","text_ar":"حَمْدٌ"},{"kind":"text","text":", is applied to a man and to a place of alighting or sojourning or abiding. (TA.) [See"},{"kind":"arabic","text_bw":"mu*im~N","text_ar":"مُذِمٌّ"},{"kind":"text","text":"] ―         -b2-  See also"},{"kind":"arabic","text_bw":"*am~apN","text_ar":"ذَمَّةٌ"},{"kind":"text","text":". ―         -b3-  Also, applied to water,"},{"kind":"italic_en","text":"Disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproved."},{"kind":"text","text":"(S, K. *)       -A2-  [As a subst.,]"},{"kind":"italic_en","text":"Urine and mucus,"},{"kind":"text","text":"(K,) so in the copies of the K, but correctly, (TA,)"},{"kind":"italic_en","text":"mucus,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"urine"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"that flows from the penis of the goat:"},{"kind":"text","text":"(S, K, TA:) or"},{"kind":"italic_en","text":"a fluid that flows from the nose."},{"kind":"text","text":"(IAar, T.) ―         -b2-  And in like manner,"},{"kind":"italic_en","text":"Milk"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that flows"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the teats of sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats;"},{"kind":"text","text":"(K;) or, as in some copies of the S,"},{"kind":"italic_en","text":"form the teats of the she-camel;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"from the teats of the sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat:"},{"kind":"text","text":"(so in one of my copies of the S: in the other of those copies omitted:) or"},{"kind":"italic_en","text":"milk that becomes sprinkled upon the udders:"},{"kind":"text","text":"(Th, M:) or"},{"kind":"italic_en","text":"milk that flows upon the thighs and udders of camels and sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats."},{"kind":"text","text":"(M.) ―         -b3-  Also"},{"kind":"italic_en","text":"Dew,"},{"kind":"text","text":"(M, K,) absolutely; (TA;) accord. to IDrd: (M:) or"},{"kind":"italic_en","text":"dew that falls in the night upon the trees, and upon which dust lights, so that it becomes like bits of clay"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mud."},{"kind":"text","text":"(M, K.) ―         -b4-  And"},{"kind":"italic_en","text":"A thing"},{"kind":"text","text":"[meaning the"},{"kind":"italic_en","text":"sebaceous matter"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that comes forth from the pores of the soft part of the nose, like the eggs of ants:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"pimples,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small pustules,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bavorN","text_ar":"بَثْرٌ"},{"kind":"text","text":", T, K,) or"},{"kind":"italic_en","text":"a thing resembling"},{"kind":"arabic","text_bw":"bavor","text_ar":"بَثْر"},{"kind":"text","text":","},{"kind":"italic_en","text":"black,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"red,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"like the eggs of ants,"},{"kind":"text","text":"(T, M,)"},{"kind":"italic_en","text":"coming forth upon the nose,"},{"kind":"text","text":"(T,) or"},{"kind":"italic_en","text":"arising upon the faces"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"and the noses,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"from heat"},{"kind":"text","text":"(T, M, K) or"},{"kind":"italic_en","text":"from the scab:"},{"kind":"text","text":"(M, K:) or the"},{"kind":"italic_en","text":"dirty matter that comes forth upon the nose:"},{"kind":"text","text":"n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (TA.) ―         -b5-  And"},{"kind":"italic_en","text":"Whiteness upon the nose of a kid."},{"kind":"text","text":"(Kr, M, K.)"}],"source_refs":["T","K","TA","M","S","Th"]}]}}