le":"present_2mp","form":"تَسْكَتُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْكَتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْكَت","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْكَت","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْكَتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْكَتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْكَتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْكَتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْكَتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْكَتُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْكَتْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْكَت","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْكَت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَكُتُّ","in_corpus":true,"count":33,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَكُتْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":155,"cross_references":{"qac":{"found":true,"lemma_key":"سَكُتَ","root":"سكت","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n20192","","n20194"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%83%D9%8F%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be silent"},{"pos":"verb","gloss":"to subside"},{"pos":"verb","gloss":"to die"},{"pos":"verb","gloss":"to scare into silence"},{"pos":"verb","gloss":"to accuse of silence"},{"pos":"noun","gloss":"verbal noun of سَكَتَ (sakata) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew שָׁקַט (shakát, “rest, be in peace”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20192","headword_ar":"سَكَتَ","root":"skt","body":[{"kind":"text","text":", (S, Msb, TA,) aor."},{"kind":"text","text":", (Lth, TA,) inf. n."},{"kind":"arabic","text_bw":"sukuwtN","text_ar":"سُكُوتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sakotN","text_ar":"سَكْتٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"sukaAtN","text_ar":"سُكَاتٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"saAkuwtapN","text_ar":"سَاكُوتَةٌ"},{"kind":"text","text":", (K,) [all these ns. said in the K to signify the same, but this is not exactly the case, for the last is of an intensive form,]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent, mute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speechless; contr. of"},{"kind":"arabic","text_bw":"naTaqa","text_ar":"نَطَقَ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Samata","text_ar":"صَمَتَ"},{"kind":"text","text":": (Lth, Msb, TA:) or"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":"is said of him who has the power, or faculty, of speech, but abstains from making use of it; whereas"},{"kind":"arabic","text_bw":"Samata","text_ar":"صَمَتَ"},{"kind":"text","text":"is sometimes said of that which has not the power, or faculty, of speech: (Er-Rághib, MF, TA:) or"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sukuwtN","text_ar":"سُكُوتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sakotN","text_ar":"سَكْتٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped, speaking;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sakotN","text_ar":"سَكْتٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quiet;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":": (Zj, TA:) [it is said that] ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":", also, is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"Samata","text_ar":"صَمَتَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":"; (Msb;) accord. to AZ, one says of a man,"},{"kind":"arabic","text_bw":"Samata","text_ar":"صَمَتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aSamata","text_ar":"اَصَمَتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^asokata","text_ar":"اَسْكَتَ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or, as some say, ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he spoke not;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he ceased"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from speech"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"broke off"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therefrom"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"became cut short"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therein"},{"kind":"text","text":"]: (Msb:) or"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent intentionally;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, silent by reason of thought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disease"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fear:"},{"kind":"text","text":"(TA:) or you say"},{"kind":"arabic","text_bw":"takal~ama vum~a sakata","text_ar":"تَكَلَّمَ ثُمَّ سَكَتَ"},{"kind":"text","text":"without"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"[when you mean"},{"kind":"italic_en","text":"he spoke"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"then became silent,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"intentionally"},{"kind":"text","text":"]; (S) but you say ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":"when you mean"},{"kind":"italic_en","text":"his speech became broken off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut short, and so he spoke not."},{"kind":"text","text":"(S, K.) It is said in a prov.,"},{"kind":"arabic","text_bw":"sakata A^alofFA wnaTaqa xalofFA","text_ar":"سَكَتَ اَلْفًا ونَطَقَ خَلْفًا"},{"kind":"italic_en","text":"He held his tongue from a thousand words"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"sakata Eano A^alofi kalimapK","text_ar":"سَكَتَ عَنْ اَلْفِ كَلِمَةٍ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"and then uttered what was wrong."},{"kind":"text","text":"(ISk, S and Msb in art."},{"kind":"arabic","text_bw":"xlf","text_ar":"خلف"},{"kind":"text","text":".) And you say [of the quiescent"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":"that is sometimes added at the end of a word, after a vowel or a letter of prolongation, as in"},{"kind":"arabic","text_bw":"lamo yaroDaho","text_ar":"لَمْ يَرْضَهْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waA zayodaAho","text_ar":"وَا زَيْدَاهْ"},{"kind":"text","text":"],"},{"kind":"arabic","text_bw":"h`*ihi haA='u Als~akoti","text_ar":"هٰذِهِ هَا=ءُ السَّكْتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is the"},{"kind":"arabic","text_bw":"hA'","text_ar":"هاء"},{"kind":"italic_en","text":"of pausation"},{"kind":"text","text":"]. (A, TA.) One says also, of a she-camel,"},{"kind":"arabic","text_bw":"sakatato","text_ar":"سَكَتَتْ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"sukuwtN","text_ar":"سُكُوتٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"She uttered not the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"grumbling"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"cry termed"},{"kind":"arabic","text_bw":"rugaA='","text_ar":"رُغَا=ء"},{"kind":"italic_en","text":"when the saddle was put upon her."},{"kind":"text","text":"(ISd, TA.) ―         -b2-  [Hence"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"sakotN","text_ar":"سَكْتٌ"},{"kind":"text","text":", as syn. with"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":", meaning as expl. above; and also (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still, quiet, motionless, at rest, stilled, quieted, appeased, tranquillized, calm, allayed, assuaged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quelled; it remitted; it subsided;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"Darabahu Hat~aY sakatato Harakatuhu","text_ar":"ضَرَبَهُ حَتَّى سَكَتَتْ حَرَكَتُهُ"},{"kind":"text","text":"(A) or"},{"kind":"arabic","text_bw":"Hrkth","text_ar":"حركته"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asokatato","text_ar":"اَسْكَتَتْ","orth_type":"arrow"},{"kind":"text","text":"(TA) (tropical:)  ["},{"kind":"italic_en","text":"He beat him until his motion became stilled"},{"kind":"text","text":"]; and ↓"},{"kind":"arabic","text_bw":"Ht~Y A^asokata","text_ar":"حتّى اَسْكَتَ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"until he became still"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"sakata AlgaDabu","text_ar":"سَكَتَ الغَضَبُ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":", (S, Msb, TA,) meaning"},{"kind":"arabic","text_bw":"fatara","text_ar":"فَتَرَ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"The anger remitted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became stilled, appeased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"allayed"},{"kind":"text","text":"]; (TA:) as also ↓"},{"kind":"arabic","text_bw":"Askt","text_ar":"اسكت","orth_type":"arrow"},{"kind":"text","text":": (Msb:) and"},{"kind":"arabic","text_bw":"sakata Eanohu AlgaDabu","text_ar":"سَكَتَ عَنْهُ الغَضَبُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Anger,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the anger, became stilled so that it departed from him"},{"kind":"text","text":"]. (A.) Hence, in the Kur [vii. 153],"},{"kind":"arabic","text_bw":"walam~aA sakata Eano muwsaY","text_ar":"وَلَمَّا سَكَتَ عَنْ مُوسَى"},{"kind":"arabic","text_bw":"AlgaDabu","text_ar":"الغَضَبُ"},{"kind":"text","text":", (S,) meaning, accord. to Zj,"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":"[i. e. (assumed tropical:)"},{"kind":"italic_en","text":"And when the anger became stilled so that it departed from Moses"},{"kind":"text","text":"]: or, as some say, the phrase is inverted, the meaning being"},{"kind":"arabic","text_bw":"walam~aA sakata","text_ar":"وَلَمَّا سَكَتَ"},{"kind":"arabic","text_bw":"muwsaY Eani AlgaDabi","text_ar":"مُوسَى عَنِ الغَضَبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And when Moses was silent, ceasing from anger"},{"kind":"text","text":"]: but the former is the explanation of those skilled in the Arabic language. (TA. [See also 4.]) You say also,"},{"kind":"arabic","text_bw":"sakata AlHar~u","text_ar":"سَكَتَ الحَرُّ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"The heat became vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intense, the wind being still."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence also,] (assumed tropical:)"},{"kind":"italic_en","text":"He died:"},{"kind":"text","text":"(K:) occurring in this sense in a trad. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"saAkataniY fasakat~u","text_ar":"سَاكَتَنِى فَسَكَتُّ"},{"kind":"text","text":": see 3.       -A2-"},{"kind":"arabic","text_bw":"sakata","text_ar":"سَكَتَ"},{"kind":"text","text":"said of a horse, [from"},{"kind":"arabic","text_bw":"Als~ukayotu","text_ar":"السُّكَيْتُ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He came in tenth in a race."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","TA","Lth","A","K","Zj"]},{"entry_id":"n20194","headword_ar":"سَكْتٌ","root":"skt","body":[{"kind":"text","text":"an inf. n. of 1 [q. v.]. (S, &c.) ―         -b2-  And [hence,]"},{"kind":"italic_en","text":"A division"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pause"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between two musical sounds,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notes, without breathing;"},{"kind":"text","text":"(T, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"sakotapN","text_ar":"سَكْتَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"sik~iytN","text_ar":"سِكِّيتٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}