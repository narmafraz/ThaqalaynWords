m":"s"},{"role":"past_1mp","form":"غَفَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَفَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32148"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%81%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to doze off, to fall asleep"},{"pos":"verb","gloss":"to slumber"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32148","headword_ar":"غَفَا","root":"gfw and gfY","body":[{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"gafiYa","text_ar":"غَفِىَ"},{"kind":"text","text":": see 4. ―         -b2-"},{"kind":"arabic","text_bw":"gafaA","text_ar":"غَفَا"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"gafowN","text_ar":"غَفْوٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gufuw~N","text_ar":"غُفُوٌّ"},{"kind":"text","text":", (TA,) also signifies"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, TA)"},{"kind":"italic_en","text":"floated upon the water"},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"gafaY AlT~aEaAma","text_ar":"غَفَى الطَّعَامَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"gafoYN","text_ar":"غَفْىٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He cleared the wheat of what is termed"},{"kind":"arabic","text_bw":"gafFY","text_ar":"غَفًى"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a thing such as"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the noxious weed called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"zuw^aAn","text_ar":"زُوَان"},{"kind":"text","text":"[q. v.], (K, TA,)"},{"kind":"italic_en","text":"and other refuse;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"the straw;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AgfY","text_ar":"اغفى","orth_type":"arrow"},{"kind":"text","text":". (K, TA,)"}],"source_refs":["K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%BA%D9%81%D8%A7/","headword_ar":"غفا","entries":[{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=2792#44b50a","body_html":"<span class=\"title1\">غ ف ا</span><span>: (أَغْفَى) نَامَ. قَالَ ابْنُ السِّكِّيتِ: وَلَا تَقُلْ: غَفَا. </span>"},{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=2792#5d1e50","body_html":"<span class=\"title1\">[غفا]</span><span> نه: فيه: \"فغفوت غفوة\"، أي نمت نومة خفيفة، أغفى إغفاء وإغفاءة- إذا نام، وغفا- قليل. بي: الإغفاء السنة، وهي حالة الوحي غالبًا، ويحتمل أن يريد به الإعراض عما كان فيه.</span>"},{"lexicon_id":"dictionary_6","lexicon_en":"Ismāʿīl bin Ḥammād al-Jawharī, Tāj al-Lugha wa Ṣiḥāḥ al-ʿArabīya (d. 1003 CE)","lexicon_ar":"تاج اللغة وصِحاح العربية للجوهري","permalink":"https://arabiclexicon.hawramani.com/?p=2792#2d5ead","body_html":"<span class=\"title1\">[غفا]</span><span> أغْفَيْتُ إغْفاءً، أي نمت. قال ابن السكيت: ولا تقل غَفَوْتُ. والغَفا مقصورٌ: ما يخرج من الطعام فيُرمى به كالزُوان. والغَفا أيضاً: آفةٌ تصيب النخل، وهو شبه الغُبار يقع على البُسر فيمنعه من الإدراك والنُضج ويمسخ طعمه.</span>"},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=2792#0536cd","body_html":"<p>غفا: الأَزهري: غَفَا الرجل وغيره غفوة إِذا نامَ نومَةً خَفيفة. وفي</p><p>الحديث: فَغَفَوْتُ غَفْوةً أَي نِمْتُ نَوْمةً خفيفة. قال: وكلام العرب</p><p>أَغْفى. وقلَّما يقال غَفا.ابن سيده: غَفَى الرجلُ غَفْيَةً وأَغْفى نَعَس.</p><p>وأَغْفَيتُ إِغفاءً نِمْتُ. قال ابن السكيت: ولا تقُلْ غَفَوْتُ. ويقال:</p><p>أَغْفى إِغْفاءً وإِغْفاءَةً إِذا نامَ. أَبو عمرو: وأَغْفى نامَ على</p><p>الغَفا، وهو التِّبْنُ في بَيْدَرِه.</p><p>والغَفْيَةُ: الحُفْرة التي يَكْمُن فيها الصائد، وقال اللحياني: هي</p><p>الزُّبيْة.</p><p>والغَفى: ما يَنْفونَه من إِبِلهم. والغَفى، منقوصٌ: ما يُخْرَج من</p><p>الطعام فيُرْمى به كالزُّؤان والقَصَل، وقيل: غفى الحِنْطةِ عيدانُها، وقيل:</p><p>الغَفى حُطامُ البُرِّ وما تَكَسَّر منه، وقيل: هو كلُّ ما يُخْرَجُ منه</p><p>فيُرْمى به. ابن الأَعرابي: يقال في الطَّعامِ حَصَلَة وغَفاءَةٌ، ممدود،</p><p>وفَغاةٌ وحُثالَةٌ كل ذلك الرَّديءُ الذي يُرْمى به. قال ابن بري:</p><p>والغَفا قِشْرُ الحنْطة، وتَثْنِيَتُه غَفَوان، والجمع أَغْفاءٌ، وهو سَقَطُ</p><p>الطَّعام من عِيدانِه وقصبِه؛ وقول أَوس:</p><p>حَسِبْتُمُ وَلَدَ البَرْشاءِ قاطِبَةً</p><p>نَقْلَ السِّمادِ وتَسْلِيكاً غَفى الغِيَرِ</p><p>(* قوله« الغير» هكذا في الأصل، وفي المحكم: العبر بالعين المهملة</p><p>والياء المثناة.)</p><p>يجوز أَن يُعْنى به هذا، ويجوز أَن يُعنى به السَّفِلة، والواحِدة من</p><p>كلِّ ذلك غَفاةٌ. وحِنْطة غَفِيَةٌ: فيها غَفًى على النَّسَب. وغَفّى</p><p>الطعامَ وأَغْفاه: نَقَّاه من غفاه. والغَفى: قِشْرٌ صغِيرٌ يَعْلُو البُسْر،</p><p>وقيل: هو التَّمْر الفاسِدُ الذي يَغْلُظ ويَصِيرُ فيه مثلُ أَجْنِحَة</p><p>الجَرادِ، وقيل: الغفى آفةٌ تصيبُ النَّخْلَ، وهو شِبْهُ الغُبارِ يَقَع</p><p>على البُسْر فيمْنعُه من الإِدْراك والنُّضْجِ ويَمْسَخ طَعْمَه. والغَفَى:</p><p>حُسافةُ التَّمْرِ ودُقاقُ التمر. والغَفى: داءٌ يقع في التِّينِ</p><p>فيُفْسِدُه؛ وقول الأَغلب:</p><p>قَدْ سَرَّني الشيخُ الذي ساءَ الفَتى،</p><p>إِذْ لم يَكُنْ ما ضَمَّ أَمْساد الغفى</p><p>أَمْسادُ الغَفى: مُشاقَه الكَتَّانِ وما أَشْبَهَه. ابن سيده في غَفا</p><p>بالأَلف: غَفا الشيءُ غَفْواً وغُفُوّاً طَفا فَوْقَ الماءِ. والغَفْوُ</p><p>والغَفْوَةُ جميعاً: الزُّبْيَة؛ عن اللحياني.</p>"}]}}