{"lemma":"صِعابُ","slug":"صِعابُ","root":"ص.ع.ب","root_slug":"ص-ع-ب","root_link":"/words/roots/ص-ع-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n24296","n24301"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%90%D8%B9%D8%A7%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be hard, difficult"},{"pos":"adj","gloss":"laborious, hard, trying, awkward, difficult, complex"},{"pos":"verb","gloss":"to impede"}]},"etymology":null,"ipa":["/sˤa.ʕu.ba/","/sˤaʕb/","/sˤaʕ.ʕa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24296","headword_ar":"صَعُبَ","root":"SEb","body":[{"kind":"text","text":", (S, A, MA, Msb, K,) aor."},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"SuEuwbapN","text_ar":"صُعُوبَةٌ"},{"kind":"text","text":"; (S, MA, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AstSEb","text_ar":"استصعب","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"page_break","n":1687},{"kind":"text","text":"(S, A, MA, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"ASEb","text_ar":"اصعب","orth_type":"arrow"},{"kind":"text","text":", (IAar, K,) inf. n."},{"kind":"arabic","text_bw":"A_iSoEaAbN","text_ar":"اـِصْعَابٌ"},{"kind":"text","text":"; (IAar, TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb, or an affair, or event, S, MA, Msb, K)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"SaEob","text_ar":"صَعْب"},{"kind":"text","text":", (S, A, &c.,) i. e."},{"kind":"italic_en","text":"difficult, hard, hard to be done"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished, hard to be borne"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing."},{"kind":"text","text":"(A, MA, K.) One says,"},{"kind":"arabic","text_bw":"Ealayohi AlA^amoru","text_ar":"عَلَيْهِ الاَمْرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstSEb","text_ar":"استصعب","orth_type":"arrow"},{"kind":"text","text":", (S, MA, Msb,) like"},{"kind":"arabic","text_bw":"SaEuba","text_ar":"صَعُبَ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him."},{"kind":"text","text":"(MA.)"}],"source_refs":["S","A","MA","Msb","K","IAar"]},{"entry_id":"n24301","headword_ar":"صَعْبٌ","root":"SEb","body":[{"kind":"italic_en","text":"Difficult, hard, hard to be done"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished, hard to be borne"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing;"},{"kind":"text","text":"(A, MA, K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"saholN","text_ar":"سَهْلٌ"},{"kind":"text","text":"; (Mgh, TA;) as also ↓"},{"kind":"arabic","text_bw":"SuEobuwbN","text_ar":"صُعْبُوبٌ","orth_type":"arrow"},{"kind":"text","text":": (T, O, K, TA:) pl. of the former"},{"kind":"arabic","text_bw":"SiEaAbN","text_ar":"صِعَابٌ"},{"kind":"text","text":"; (Msb;) and of ↓ the latter,"},{"kind":"arabic","text_bw":"SaEaAbiybu","text_ar":"صَعَابِيبُ"},{"kind":"text","text":". (T, TA.) One says"},{"kind":"arabic","text_bw":"A^amorN SaEobN","text_ar":"اَمْرٌ صَعْبٌ"},{"kind":"italic_en","text":"A difficult, hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, affair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"EaqabapN SaEobapN","text_ar":"عَقَبَةٌ صَعْبَةٌ"},{"kind":"text","text":"(thus in the A, but in the Msb and TA without any syll. signs,) ["},{"kind":"italic_en","text":"A mountainroad"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"difficult, hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"EiqaAbN SiEaAbN","text_ar":"عِقَابٌ صِعَابٌ"},{"kind":"text","text":"(A, Msb *) and"},{"kind":"arabic","text_bw":"SaEobaAtN","text_ar":"صَعْبَاتٌ"},{"kind":"text","text":"with sukoon [to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"because the word is an epithet; for if it were a subst., it would be"},{"kind":"arabic","text_bw":"SaEabaAtN","text_ar":"صَعَبَاتٌ"},{"kind":"text","text":"]. (Msb.) [Or"},{"kind":"arabic","text_bw":"EuqobapN SaEobapN","text_ar":"عُقْبَةٌ صَعْبَةٌ"},{"kind":"text","text":"may perhaps be meant in the TA, i. e."},{"kind":"italic_en","text":"A difficult, hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, stage of a journey."},{"kind":"text","text":"] ―         -b2-  Also"},{"kind":"italic_en","text":"Refractory, untractable, incompliant, obstinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stubborn;"},{"kind":"text","text":"(K, * TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"*aluwlN","text_ar":"ذَلُولٌ"},{"kind":"text","text":"; (S, A, TA;) applied to a camel, (S, A,) or to a beast; (TA;) [and to a man;] fem."},{"kind":"arabic","text_bw":"SaEobapN","text_ar":"صَعْبَةٌ"},{"kind":"text","text":", (S, TA,) which is applied to a woman: (S:) and the pl. of this is"},{"kind":"arabic","text_bw":"SiEaAbN","text_ar":"صِعَابٌ"},{"kind":"text","text":", [as of the masc.,] (TA,) and"},{"kind":"arabic","text_bw":"SaEobaAtN","text_ar":"صَعْبَاتٌ"},{"kind":"text","text":", applied to women, with sukoon [to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"because the word is an epithet]. (S, TA.)"},{"kind":"arabic","text_bw":"rakiba Aln~aAsu AlS~aEobapa waAl*~aluwla","text_ar":"رَكِبَ النَّاسُ الصَّعْبَةَ وَالذَّلُولَ"},{"kind":"text","text":", occurring in a trad. of I'Ab, [lit."},{"kind":"italic_en","text":"The people rode the refractory and the tractable"},{"kind":"text","text":"she-camel,] means (assumed tropical:)"},{"kind":"italic_en","text":"the people entered upon difficult and easy affairs;"},{"kind":"text","text":"i. e. they cared not for things, nor were cautious respecting what they said and did. (L, TA.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"AlS~aEobu","text_ar":"الصَّعْبُ"},{"kind":"italic_en","text":"The lion;"},{"kind":"text","text":"(O, K;) because of his untractableness. (TA.)"}],"source_refs":["T","O","K","TA","S","A"]}]}}