um":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31916"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B5%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to choke, to be oppressed, to be full of anxiety"}]},"etymology":null,"ipa":["/ɣasˤ.sˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31916","headword_ar":"غَصَّ","root":"gS","body":[{"kind":"text","text":", (Msb, MF,) sec. pers."},{"kind":"arabic","text_bw":"gaSiSota","text_ar":"غَصِصْتَ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"gaSaSota","text_ar":"غَصَصْتَ"},{"kind":"text","text":", (Msb, K,) the latter extr.,"},{"kind":"page_break","n":2263},{"kind":"text","text":"(TA, [see 1 in art."},{"kind":"arabic","text_bw":"ED","text_ar":"عض"},{"kind":"text","text":",]) aor."},{"kind":"arabic","text_bw":"yagaS~u","text_ar":"يَغَصُّ"},{"kind":"text","text":", (S, Msb, K,) when the sec. pers. of the pret. is"},{"kind":"arabic","text_bw":"gaSiSota","text_ar":"غَصِصْتَ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"yaguS~u","text_ar":"يَغُصُّ"},{"kind":"text","text":", (Msb, TA,) when the sec. pers. of the pret. is of the other form mentioned above, (Msb,) inf. n."},{"kind":"arabic","text_bw":"gaSaSN","text_ar":"غَصَصٌ"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"gaS~N","text_ar":"غَصٌّ"},{"kind":"text","text":", (Msb,) or the former when the aor. is"},{"kind":"arabic","text_bw":"yagaS~u","text_ar":"يَغَصُّ"},{"kind":"text","text":", and the latter when the aor. is"},{"kind":"arabic","text_bw":"yaguS~u","text_ar":"يَغُصُّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"His throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructed,"},{"kind":"text","text":"(S, K, MF,) by food: (S, Msb, MF:) [as also, app., ↓"},{"kind":"arabic","text_bw":"AigotaS~a","text_ar":"اِغْتَصَّ","orth_type":"arrow"},{"kind":"text","text":":] accord. to some of those skilled in the science of lexicology, you say"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"text","text":"when it is by food, and"},{"kind":"arabic","text_bw":"$ariqa","text_ar":"شَرِقَ"},{"kind":"text","text":"when it is by beverage, [or by the spittle, and water, and the like, (see art."},{"kind":"arabic","text_bw":"$rq","text_ar":"شرق"},{"kind":"text","text":",)] and"},{"kind":"arabic","text_bw":"$ajiYa","text_ar":"شَجِىَ"},{"kind":"text","text":"when it is by a bone, and"},{"kind":"arabic","text_bw":"jariDa","text_ar":"جَرِضَ"},{"kind":"text","text":"when it is with spittle; but every one of these is sometimes used in the place of any other: (MF:) and [thus] you say also,"},{"kind":"arabic","text_bw":"gaS~a biAlmaA='i","text_ar":"غَصَّ بِالمَا=ءِ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"his throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructed, by the water;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the water stopped therein, and he was hardly able to swallow it."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"gaS~a biriyqihi","text_ar":"غَصَّ بِرِيقِهِ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"His throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked by his spittle;"},{"kind":"text","text":"] meaning, (tropical:)"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(TA.) ―         -b3-  Hence, also,"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"arabic","text_bw":"biAlgayoZi","text_ar":"بِالغَيْظِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, choked with wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage"},{"kind":"text","text":"]. (Msb.) ―         -b4-  [And"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"text","text":", alone, seems to signify (assumed tropical:)"},{"kind":"italic_en","text":"He became grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted in mind;"},{"kind":"text","text":"like as does"},{"kind":"arabic","text_bw":"$ajiYa","text_ar":"شَجِىَ"},{"kind":"text","text":"(q. v.): and it seems to be indicated in the CK that ↓"},{"kind":"arabic","text_bw":"AgtS~","text_ar":"اغتصّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: see"},{"kind":"arabic","text_bw":"guS~apN","text_ar":"غُصَّةٌ"},{"kind":"text","text":".] ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"gaS~ato binaA","text_ar":"غَصَّتْ بِنَا"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land became straitened"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it were choked"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by us."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"gaS~a Almajolisu","text_ar":"غَصَّ المَجْلِسُ"},{"kind":"arabic","text_bw":"biA^aholihi","text_ar":"بِاَهْلِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The sitting-place became straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choked up, by its people"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"AgtS~","text_ar":"اغتصّ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb","MF","S","K","TA"]}]},"classical_definitions":null}