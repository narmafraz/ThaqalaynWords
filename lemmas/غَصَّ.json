"},{"role":"present_2mp","form":"تَغَصُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَغَصُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَغْصَصْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَغَصّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَغْصَص","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَغَصّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَغْصَص","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَغَصّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَغَصّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَغَصّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَغَصّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَغَصُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَغَصُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَغْصَصْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَغَصّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَغَصّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"غَصِصْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غَصِصْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31916"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D8%B5%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to choke, to be oppressed, to be full of anxiety"}]},"etymology":null,"ipa":["/ɣasˤ.sˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31916","headword_ar":"غَصَّ","root":"gS","body":[{"kind":"text","text":", (Msb, MF,) sec. pers."},{"kind":"arabic","text_bw":"gaSiSota","text_ar":"غَصِصْتَ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"gaSaSota","text_ar":"غَصَصْتَ"},{"kind":"text","text":", (Msb, K,) the latter extr.,"},{"kind":"page_break","n":2263},{"kind":"text","text":"(TA, [see 1 in art."},{"kind":"arabic","text_bw":"ED","text_ar":"عض"},{"kind":"text","text":",]) aor."},{"kind":"arabic","text_bw":"yagaS~u","text_ar":"يَغَصُّ"},{"kind":"text","text":", (S, Msb, K,) when the sec. pers. of the pret. is"},{"kind":"arabic","text_bw":"gaSiSota","text_ar":"غَصِصْتَ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"yaguS~u","text_ar":"يَغُصُّ"},{"kind":"text","text":", (Msb, TA,) when the sec. pers. of the pret. is of the other form mentioned above, (Msb,) inf. n."},{"kind":"arabic","text_bw":"gaSaSN","text_ar":"غَصَصٌ"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"gaS~N","text_ar":"غَصٌّ"},{"kind":"text","text":", (Msb,) or the former when the aor. is"},{"kind":"arabic","text_bw":"yagaS~u","text_ar":"يَغَصُّ"},{"kind":"text","text":", and the latter when the aor. is"},{"kind":"arabic","text_bw":"yaguS~u","text_ar":"يَغُصُّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"His throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructed,"},{"kind":"text","text":"(S, K, MF,) by food: (S, Msb, MF:) [as also, app., ↓"},{"kind":"arabic","text_bw":"AigotaS~a","text_ar":"اِغْتَصَّ","orth_type":"arrow"},{"kind":"text","text":":] accord. to some of those skilled in the science of lexicology, you say"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"text","text":"when it is by food, and"},{"kind":"arabic","text_bw":"$ariqa","text_ar":"شَرِقَ"},{"kind":"text","text":"when it is by beverage, [or by the spittle, and water, and the like, (see art."},{"kind":"arabic","text_bw":"$rq","text_ar":"شرق"},{"kind":"text","text":",)] and"},{"kind":"arabic","text_bw":"$ajiYa","text_ar":"شَجِىَ"},{"kind":"text","text":"when it is by a bone, and"},{"kind":"arabic","text_bw":"jariDa","text_ar":"جَرِضَ"},{"kind":"text","text":"when it is with spittle; but every one of these is sometimes used in the place of any other: (MF:) and [thus] you say also,"},{"kind":"arabic","text_bw":"gaS~a biAlmaA='i","text_ar":"غَصَّ بِالمَا=ءِ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"his throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obstructed, by the water;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the water stopped therein, and he was hardly able to swallow it."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"gaS~a biriyqihi","text_ar":"غَصَّ بِرِيقِهِ"},{"kind":"text","text":"[lit.,"},{"kind":"italic_en","text":"His throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces, became choked by his spittle;"},{"kind":"text","text":"] meaning, (tropical:)"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(TA.) ―         -b3-  Hence, also,"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"arabic","text_bw":"biAlgayoZi","text_ar":"بِالغَيْظِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, choked with wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage"},{"kind":"text","text":"]. (Msb.) ―         -b4-  [And"},{"kind":"arabic","text_bw":"gaS~a","text_ar":"غَصَّ"},{"kind":"text","text":", alone, seems to signify (assumed tropical:)"},{"kind":"italic_en","text":"He became grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquieted in mind;"},{"kind":"text","text":"like as does"},{"kind":"arabic","text_bw":"$ajiYa","text_ar":"شَجِىَ"},{"kind":"text","text":"(q. v.): and it seems to be indicated in the CK that ↓"},{"kind":"arabic","text_bw":"AgtS~","text_ar":"اغتصّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: see"},{"kind":"arabic","text_bw":"guS~apN","text_ar":"غُصَّةٌ"},{"kind":"text","text":".] ―         -b5-  [Hence also,]"},{"kind":"arabic","text_bw":"gaS~ato binaA","text_ar":"غَصَّتْ بِنَا"},{"kind":"arabic","text_bw":"AlA^aroDu","text_ar":"الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land became straitened"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it were choked"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by us."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"gaS~a Almajolisu","text_ar":"غَصَّ المَجْلِسُ"},{"kind":"arabic","text_bw":"biA^aholihi","text_ar":"بِاَهْلِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The sitting-place became straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choked up, by its people"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"AgtS~","text_ar":"اغتصّ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb","MF","S","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%BA%D8%B5/","headword_ar":"غص","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10491#bdc5eb","body_html":"غص<br>الغُصئةُ: شَجىً يُغَصن به في الحَلْق.<br>والغُصْغُصُ: زَعَمَ أبو مالكٍ أنه ضُرُوبٌ من النَّبْت."},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=10491#d579a6","body_html":"<span class=\"title1\">غص</span><br><span>الغُصَّةُ: الشّجاة التي يُغَصُّ بها الحلق. قال تعالى: وَطَعاماً ذا غُصَّةٍ</span><br><span>[المزمل/ 13] .</span>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10491#dd9d43","body_html":"<span class=\"title1\">باب الغين والصاد غ ص مستعمل فقط</span><br><br><span>غص: الغُصَّةُ: شجا يُغَصَّ به في الحرقدة، قال عدي بن زيد:</span><span> </span><a></a><a></a><span>كنت كالغصان بالماء اعتصاري </span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=10491#2ac149","body_html":"<span class=\"title1\">الْغَيْن وَالصَّاد</span><br><br><span>غصصْت باللُّقمة وَالْمَاء.</span><br><br><span>وغَصَصْتُ أغَص وأغُصّ، غَصاًّ وغَصَصاً: شَجِيتُ.</span><br><br><span>وخَص بعضُهم بِهِ المَاء.</span><br><br><span>ورجلٌ غصَانُ: غاصُّ، قَالَ عَديّ بن زيد:</span><br><br><span>لَو بغَير المَاء حَلْقي شَرِقٌ كنتُ كالغَصّان بِالْمَاءِ اعْتصارِي</span><br><br><span>والغُصَّة: مَا غَصِصتَ بِهِ.</span><br><br><span>وغُصَصُ الْمَوْت، مِنْهُ.</span><br><br><span>وغَصَّ المكانُ بأَهْله: ضَاقَ.</span><br><br><span>وَذُو الغُصّة: لقب رجل من فُرسان الْعَرَب.</span><br><br><span>والغَصْغَصُ: ضَرب من النَّبَات. </span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10491#65bfae","body_html":"<h3>غص</h3><span class=\"sense\">1</span> غَصَّ, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr>,) sec. <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> غَصِصْتَ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and غَصَصْتَ, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) the latter <abbr title=\"extraordinary (with respect to analogy or rule, with respect to usage), نَادِرٌ.\">extr.</abbr>, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, [see 1 in art. عض,]) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـَ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) when the sec. <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> of the <abbr title=\"preterite, مَاضٍ\">pret.</abbr> is غَصِصْتَ, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) and يَغُصُّ, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) when the sec. <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> of the <abbr title=\"preterite, مَاضٍ\">pret.</abbr> is of the other form mentioned above, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> غَصَصٌ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or غَصٌّ, (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) or the former when the <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> is يَغَصُّ, and the latter when the <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> is يَغُصُّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) His throat, or fauces, became choked, or obstructed, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr>,) by food: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr>:) [as also, <abbr title=\"apparently\">app.</abbr>, ↓ اِغْتَصَّ:] <abbr title=\"according\">accord.</abbr> to some of those skilled in the science of lexicology, you say غَصَّ when it is by food, and شَرِقَ when it is by beverage, [or by the spittle, and water, and the like, (see art. شرق,)] and شَجِىَ when it is by a bone, and جَرِضَ when it is with spittle; but every one of these is sometimes used in the place of any other: (<abbr title=\"Muḥammad ibn al-Ṭayyib al-Sharqī al-Fāsī, author of Annotations on the Qāmūs al-Muḥīṭ of Firuzabadi\">MF</abbr>:) and [thus] you say also, غَصَّ بِالمَآءِ, meaning, his throat, or fauces, became choked, or obstructed, by the water; or the water stopped therein, and he was hardly able to swallow it. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> [Hence,] غَصَّ بِرِيقِهِ [<abbr title=\"literally\">lit.</abbr>, His throat, or fauces, became choked by his spittle;] meaning, (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) he died. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> Hence, also, غَصَّ بِالغَيْظِ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [He was, or became, choked with wrath, or rage]. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b4:</span> [And غَصَّ, alone, seems to signify (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He became grieved, or disquieted in mind; like as does شَجِىَ (<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr>): and it seems to be indicated in the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr> that ↓ اغتصّ signifies the same: see غُصَّةٌ.] <span class=\"sub-sense\">b5:</span> [Hence also,] غَصَّتْ بِنَا الأَرْضُ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The land became straitened [as though it were choked] by us. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And غَصَّ المَجْلِسُ بِأَهْلِهِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [The sitting-place became straitened, or choked, or choked up, by its people]; as also ↓ اغتصّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 4 اغصّهُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> إِغْصَاصٌ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) He (a man, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>) caused his throat, or fauces, to be choked, or obstructed, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) by food; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) <abbr title=\"synonym and synonymous, مَرَادفٌ and مَتَرَادِفٌ\">syn.</abbr> أَشْجَاهُ [which has the above-mentioned meaning and also another to he found below]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [And It (food &amp;c.) choked him.] <span class=\"sub-sense\">b2:</span> Hence, اغصّهُ بِالغَيْظِ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [He (a man) caused him to become choked with wrath, or rage]. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b3:</span> [Hence also,] اغصّهُ بِرِيقِهِ [<abbr title=\"literally\">lit.</abbr>, He caused his throat, or fauces, to become choked by his spittle;] meaning, (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He caused him to become grieved, or disquieted in mind; (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) [like أَشْجَاهُ: and it seems to be indicated in the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr> that اغصّهُ without any addition signifies the same: see غُصَّةٌ.] <span class=\"sub-sense\">b4:</span> [Hence also,] اغصّ عَلَيْنَا الأَرْضَ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He made strait to us the land. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 8 إِغْتَصَ3َ see 1, in three places.<br><br>غُصَّةٌ A thing lying across in the throat, or fauces, so as to cause a choking, or an obstruction, thereof; (<abbr title=\"Abū Durayd, author of the Jamhara\">IDrd</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) a thing by which one has his throat, or fauces, choked, or obstructed; (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) food by which one has his throat, or fauces, choked, or obstructed; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> شَجًا; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) [which has another meaning that will be found below; and both these meanings may be intended by it in the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>; but in the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, the latter only seems to be intended; for there, between it and the explanation which is here first given, we find intervening the <abbr title=\"plural, جَمْعٌ\">pl.</abbr>, and also, in the <abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr>, the words وَقَدْ اَغْصَصْتُهُ فاغْتَصَّ;] a thing by which one is choked (شَجًا يُغَصُّ بِهِ, <abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) in the حَرْقَدَة [meaning the head of the windpipe], (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) or in the throat, or fauces: (<abbr title=\"A manuscript supposed to be the Jāmiʿ of al-Karmanī: a lexicon founded upon the ʿAyn (of al-Khalil) with additions from the Takmilat al-ʿAyn of ِal-Khārzanjī.\">JK</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> غُصَصٌ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) It is said in the <abbr title=\"The Quran\">Kur</abbr> [lxxiii. 13], وَطَعَامًا ذَا غُصَّةٍ (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) And food that sticks fast, (<abbr title=\"Al-Bayḍāwī's Exposition of the Quran (Anwār al-Tanzīl)\">Bd</abbr>,) or by which one is choked, (<abbr title=\"Tafsīr al-Jalālayn by al-Suyūṭī\">Jel</abbr>,) in the throat, or fauces. (<abbr title=\"Al-Bayḍāwī's Exposition of the Quran (Anwār al-Tanzīl)\">Bd</abbr>, <abbr title=\"Tafsīr al-Jalālayn by al-Suyūṭī\">Jel</abbr>.) <span class=\"sub-sense\">b2:</span> And hence, (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Choking wrath or rage. (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>.) <span class=\"sub-sense\">b3:</span> [and (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Grief, or disquietude of mind; a signification often occurring; and <abbr title=\"apparently\">app.</abbr> intended by the explanation شَجًا in the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>. See what is said on this point above.] <span class=\"sub-sense\">b4:</span> Hence also, غُصَصُ المَوْتِ [The chokings, or strangulations, of death: the deathrattles: or (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) the agonies of death]. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) غَصَّان: see what next follows.<br><br>غَاصٌّ A man having his throat, or fauces, choked, or obstructed, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, * <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) by food; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) as also ↓ غَصَّان. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr> [in two copies of which it is written غَصَّانُ], <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> [in two copies of which it is written غَصَّانٌ], <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr> [in my copy of which, as well as in the <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>, it is without any final syll. sign].) <span class=\"sub-sense\">b2:</span> And [hence,] غَاصٌّ بِالقَوْمِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) An abode, or a place of alighting, filled [and as it were choked up] with the company of men; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and in like manner a mosque; as also ↓ مُغْتَصٌّ. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) مُغْتَصٌّ: see what next precedes."}]}}