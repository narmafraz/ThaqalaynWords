{"lemma":"مَثْوَيانِ","slug":"مَثْوَيانِ","root":"ث.#.#","root_slug":"ث-_-_","root_link":"/words/roots/ث-_-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَثْوَى","root":"ثوي","pos":"N","occurrence_count":13},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n4858"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AB%D9%92%D9%88%D9%8E%D9%8A%D8%A7%D9%86%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4858","headword_ar":"مَثْوًى","root":"vwY","body":[{"kind":"italic_en","text":"A place where one remains, stays, dwells,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abides;"},{"kind":"text","text":"(T;)"},{"kind":"italic_en","text":"a place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, an abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a dwelling,"},{"kind":"text","text":"(T, M, Mgh, Msb,) of a man: (T:) pl."},{"kind":"arabic","text_bw":"mavaAwK","text_ar":"مَثَاوٍ"},{"kind":"text","text":"(T, M, Mgh, Msb, K.) Hence,"},{"kind":"arabic","text_bw":"A^abuw AlmavowaY","text_ar":"اَبُو المَثْوَى"},{"kind":"italic_en","text":"The master"},{"kind":"text","text":"(M, K)"},{"kind":"italic_en","text":"of the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"of the place where one alights"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the abode"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"A^um~u AlmavowaY","text_ar":"اُمُّ المَثْوَى"},{"kind":"italic_en","text":"The mistress of the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"A^abuw mavowaY Alr~ajuli","text_ar":"اَبُو مَثْوَى الرَّجُلِ"},{"kind":"italic_en","text":"The master of the place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the abode, of the man:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"the host who entertains the man; to whom he betakes himself for lodging, and at whose abode he stays:"},{"kind":"text","text":"(Har p. 595:) and"},{"kind":"italic_en","text":"the guest whom the man entertains."},{"kind":"text","text":"(M, K. * [See also"},{"kind":"arabic","text_bw":"vawiY~N","text_ar":"ثَوِىٌّ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"A^um~u mavowaY Alr~ajuli","text_ar":"اُمُّ مَثْوَى الرَّجُلِ"},{"kind":"italic_en","text":"The mistress of the place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the abode, of the man:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"the mistress of the man's place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in which he passes the night;"},{"kind":"italic_en","text":"occurring in this sense in a trad., not meaning his wife."},{"kind":"text","text":"(TA.) ―         -b2-  It is also an inf. n. of"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"text","text":". (T, M.)"}],"source_refs":["T","M","Mgh","Msb","K","S"]}]}}