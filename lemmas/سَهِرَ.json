s":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stay up late, to be wakeful by night","examples":[{"text":"أَنَامُ مِلْءَ جُفُونِي عَنْ شَوارِدِهَا / وَيَسْهَرُ الْخَلْقُ جَرَّاهَا وَيَخْتَصِمُ","english":"(please add an English translation of this quotation)"}]},{"pos":"verb","gloss":"to look after, to guard"},{"pos":"verb","gloss":"to gleam at night"},{"pos":"noun","gloss":"verbal noun of سَهِرَ (sahira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"awakeness; sleeplessness"}]},"etymology":null,"ipa":["/sa.hi.ra/","/sa.har/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21041","headword_ar":"سَهِرَ","root":"shr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saharN","text_ar":"سَهَرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He waked, was sleepless"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wakeful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did not sleep, by night;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he abstained from sleep by night;"},{"kind":"text","text":"(Lth;)"},{"kind":"italic_en","text":"he remained awake"},{"kind":"text","text":"all the night or a part thereof: you say"},{"kind":"arabic","text_bw":"sahira All~ayola","text_ar":"سَهِرَ اللَّيْلَ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"baEoDa All~ayoli","text_ar":"بَعْضَ اللَّيْلِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He remained awake during the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of the night:"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"he passed the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of the night, sleepless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without sleeping:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"sahirotu","text_ar":"سَهِرْتُ"},{"kind":"arabic","text_bw":"AlbaAriHapa","text_ar":"البَارِحَةَ"},{"kind":"italic_en","text":"I remained awake last night."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"maAlahu sahira waEahira","text_ar":"مَالَهُ سَهِرَ وَعَهِرَ"},{"kind":"italic_en","text":"What aileth him? May he be"},{"kind":"page_break","n":1452},{"kind":"italic_en","text":"sleepless by night, and may he grieve,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mourn,"},{"kind":"text","text":"is an imprecation of the Arabs. (AZ, TA in this art. and art."},{"kind":"arabic","text_bw":"Ebr","text_ar":"عبر"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"sahira Albaroqu","text_ar":"سَهِرَ البَرْقُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The lightning gleamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened, during the night."},{"kind":"text","text":"(A.)"}],"source_refs":["Msb"]}]}}