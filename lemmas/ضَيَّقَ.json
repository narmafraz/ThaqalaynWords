"m","num":"p"},{"role":"present_2mp","form":"تُضَيِّقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُضَيِّقْنَ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُضَيِّق","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُضَيِّق","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُضَيِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُضَيِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُضَيِّقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُضَيِّقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُضَيِّقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُضَيِّقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُضَيِّقْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"ضَيَّقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَيَّقْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُضَيِّق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُضَيِّق","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":58,"cross_references":{"qac":{"found":true,"lemma_key":"ضَيَّقَ","root":"ضيق","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n26235","n26236","n26237","n26243"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D9%8A%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"narrow, strait"},{"pos":"adj","gloss":"restrained, pressed"},{"pos":"adj","gloss":"thronged"},{"pos":"adj","gloss":"severe"},{"pos":"adj","gloss":"avaricious, miserly"},{"pos":"noun","gloss":"strait, distress, poverty"},{"pos":"noun","gloss":"anxiety"},{"pos":"noun","gloss":"doubt"},{"pos":"verb","gloss":"to narrow, to tighten, to narrow down"}]},"etymology":null,"ipa":["/dˤaj.jiq/","/dˤajq/","/dˤiːq/","/dˤaj.ja.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26235","headword_ar":"ضَيْقٌ","root":"Dyq","body":[{"kind":"text","text":"an inf. n. of 1, (S, O, Msb, K,) as also ↓"},{"kind":"arabic","text_bw":"DiyqN","text_ar":"ضِيقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) or the latter is a simple subst.: (Msb:) [both, used as simple substs., signify"},{"kind":"italic_en","text":"Narrowness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straitness:"},{"kind":"text","text":"] accord. to Fr, [both seem to signify thus; but the latter, properly; and the former, tropically; for he says that]"},{"kind":"arabic","text_bw":"AlD~ayoqu","text_ar":"الضَّيْقُ"},{"kind":"text","text":"is in that which does not [really] become wide, like the mind ("},{"kind":"arabic","text_bw":"AlS~ador","text_ar":"الصَّدْر"},{"kind":"text","text":"): (O:) or it is"},{"kind":"arabic","text_bw":"maA DaAqa Eanohu Sadoruka","text_ar":"مَا ضَاقَ عَنْهُ صَدْرُكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that of which the mind by its being contracted is incapable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from which the mind shrinks;"},{"kind":"text","text":"an explanation not given in the K as on the authority of Fr, and deviating from his words as given in the O; whence it appears that, for"},{"kind":"arabic","text_bw":"maA","text_ar":"مَا"},{"kind":"text","text":", we should perhaps read"},{"kind":"arabic","text_bw":"fiymaA","text_ar":"فِيمَا"},{"kind":"text","text":"]: (K:) but ↓"},{"kind":"arabic","text_bw":"AlD~iyqu","text_ar":"الضِّيقُ","orth_type":"arrow"},{"kind":"text","text":"is in that which may be [really] wide, like the house and the garment: (O, K:) and the former [is also used as an epithet, being a contraction of"},{"kind":"arabic","text_bw":"Day~iqN","text_ar":"ضَيِّقٌ"},{"kind":"text","text":"in this case, and as such] has a dual and a plural and a feminine; but the latter has not: (O:) or ↓ both are alike [in signification]: (K:) and ↓"},{"kind":"arabic","text_bw":"DayoqapN","text_ar":"ضَيْقَةٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"DiyqN","text_ar":"ضِيقٌ"},{"kind":"text","text":". (S.) ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"DayaqN","text_ar":"ضَيَقٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to AA, (O, [the latter there expressly said to be"},{"kind":"arabic","text_bw":"biAlt~aHoriyki","text_ar":"بِالتَّحْرِيكِ"},{"kind":"text","text":",]) or the former and ↓"},{"kind":"arabic","text_bw":"DiyqN","text_ar":"ضِيقٌ","orth_type":"arrow"},{"kind":"text","text":", (K, [said in the TA to"},{"kind":"page_break","n":1816},{"kind":"text","text":"be a mistake for"},{"kind":"arabic","text_bw":"DayaqN","text_ar":"ضَيَقٌ"},{"kind":"text","text":", but see what follows,])"},{"kind":"italic_en","text":"Doubt"},{"kind":"text","text":"(AA, O, K)"},{"kind":"italic_en","text":"in the heart:"},{"kind":"text","text":"(K) the first is more common than the second, in this sense; and occurs in the Kur in xvi. last verse and xxvii. 72: (O:) [but] Ibn-Ketheer read, in both of these instances, ↓"},{"kind":"arabic","text_bw":"Diyq","text_ar":"ضِيق","orth_type":"arrow"},{"kind":"text","text":"; and this and"},{"kind":"arabic","text_bw":"Dayoq","text_ar":"ضَيْق"},{"kind":"text","text":"are dial. vars. signifying"},{"kind":"italic_en","text":"straitness of mind."},{"kind":"text","text":"(Bd.)       -A2-  See also"},{"kind":"arabic","text_bw":"Day~iqN","text_ar":"ضَيِّقٌ"},{"kind":"text","text":", in two places: ―         -b2-  and"},{"kind":"arabic","text_bw":"DayoqapN","text_ar":"ضَيْقَةٌ"},{"kind":"text","text":", second sentence, in two places."}],"source_refs":["S","O","Msb","K","AA"]},{"entry_id":"n26236","headword_ar":"ضِيقٌ","root":"Dyq","body":[{"kind":"text","text":": see the next preceding paragraph, in five places."}],"source_refs":[]},{"entry_id":"n26237","headword_ar":"ضَيَقٌ","root":"Dyq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"DayoqN","text_ar":"ضَيْقٌ"},{"kind":"text","text":", latter part."}],"source_refs":[]},{"entry_id":"n26243","headword_ar":"ضَيِّقٌ","root":"Dyq","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"DayoqN","text_ar":"ضَيْقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) the latter a contraction of the former, (S,) the two being like"},{"kind":"arabic","text_bw":"hay~inN","text_ar":"هَيِّنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hayonN","text_ar":"هَيْنٌ"},{"kind":"text","text":"[&c.], (O,) and ↓"},{"kind":"arabic","text_bw":"DaAy^iqN","text_ar":"ضَايِقٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait:"},{"kind":"text","text":"(S, * O, * K:) or"},{"kind":"arabic","text_bw":"Day~iqN","text_ar":"ضَيِّقٌ"},{"kind":"text","text":"is an epithet used in this sense when permanence [of the attribute] is meant [and so therefore is its contracted form]; and ↓"},{"kind":"arabic","text_bw":"DaAy^iqN","text_ar":"ضَايِقٌ","orth_type":"arrow"},{"kind":"text","text":"as meaning ["},{"kind":"italic_en","text":"being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming, narrow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"temporarily narrow"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait:"},{"kind":"text","text":"(Msb:) the fem. of the first (TA) and of the second (S, O, TA) [as well as of the third] is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, O, TA:) see also"},{"kind":"arabic","text_bw":"DuwqaY","text_ar":"ضُوقَى"},{"kind":"text","text":": [the pls. of the first and second, applied to rational beings, is"},{"kind":"arabic","text_bw":"Day~iquwna","text_ar":"ضَيِّقُونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Dayoquwna","text_ar":"ضَيْقُونَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"may~ituwna","text_ar":"مَيِّتُونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mayotuwna","text_ar":"مَيْتُونَ"},{"kind":"text","text":": and] the pl. of ↓"},{"kind":"arabic","text_bw":"DaAy^iqN","text_ar":"ضَايِقٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"DaAqapF","text_ar":"ضَاقَةً"},{"kind":"text","text":". (TA.) You say"},{"kind":"arabic","text_bw":"$aYo'N Day~iqN","text_ar":"شَىْءٌ ضَيِّقٌ"},{"kind":"text","text":"(O, Msb) and ↓"},{"kind":"arabic","text_bw":"DayoqN","text_ar":"ضَيْقٌ","orth_type":"arrow"},{"kind":"text","text":"(O)"},{"kind":"italic_en","text":"A narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait, thing."},{"kind":"text","text":"(O, * Msb.) And"},{"kind":"arabic","text_bw":"SadorN Day~iqN","text_ar":"صَدْرٌ ضَيِّقٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted, mind;"},{"kind":"text","text":"(Msb;) and"},{"kind":"arabic","text_bw":"nafosN Day~iqapN","text_ar":"نَفْسٌ ضَيِّقَةٌ"},{"kind":"text","text":"[meaning the same]. (TA.) And"},{"kind":"arabic","text_bw":"bihi Sadoruka","text_ar":"بِهِ صَدْرُكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waDaAy^qN","text_ar":"وَضَايقٌ","orth_type":"arrow"},{"kind":"text","text":", in the Kur [xi. 15], means (assumed tropical:)"},{"kind":"italic_en","text":"And thy mind is temporarily strait"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted thereby."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"Day~iqN","text_ar":"ضَيِّقٌ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"Niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious."},{"kind":"text","text":"(KL.) [And"},{"kind":"arabic","text_bw":"Day~iqu Alxuluqi","text_ar":"ضَيِّقُ الخُلُقِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illiberal, in disposition."},{"kind":"text","text":"]"}],"source_refs":["S","O","K","Msb","TA"]}]}}