{"lemma":"صَعْرٌ","slug":"صَعْرٌ","root":"ص.ع.ر","root_slug":"ص-ع-ر","root_link":"/words/roots/ص-ع-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n24334","n24341"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%B9%D9%92%D8%B1%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24334","headword_ar":"صَعِرَ","root":"SEr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":"; (S, A, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"tSE~r","text_ar":"تصعّر","orth_type":"arrow"},{"kind":"text","text":"; (A, K;)"},{"kind":"italic_en","text":"He had a wryness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distortion, in the cheek,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"in the face,"},{"kind":"text","text":"(A, K,) or"},{"kind":"italic_en","text":"in either side"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"], (K,) or"},{"kind":"italic_en","text":"in the neck,"},{"kind":"text","text":"(Lth, A, Mgh, Msb,)"},{"kind":"italic_en","text":"by reason of pride,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"with a turning of the face on one side:"},{"kind":"text","text":"(Lth, Mgh, Msb:) [see also 5:] or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"had a disorder by reason of which he twisted his neck,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and distorted it."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"fiY Eunuqihi waxad~ihi SaEarN","text_ar":"فِى عُنُقِهِ وَخَدِّهِ صَعَرٌ"},{"kind":"italic_en","text":"In his neck, and in his cheek, is a wryness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distortion, arising from pride."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"laA^uqiyman~a SaEaraka","text_ar":"لَاُقِيمَنَّ صَعَرَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will assuredly straighten thy wryness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distortion, of the neck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheek"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^aSaAba AlbaEiyra SaEarN","text_ar":"اَصَابَ البَعِيرَ صَعَرٌ"},{"kind":"italic_en","text":"A disease which made him to twist his neck befell the camel."},{"kind":"text","text":"(Mgh, TA.) ―         -b2-  [See also"},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":"below.]       -A2-  Also"},{"kind":"arabic","text_bw":"SaEira","text_ar":"صَعِرَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":", (K, TK,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"("},{"kind":"italic_en","text":"a man,"},{"kind":"text","text":"TK)"},{"kind":"italic_en","text":"ate"},{"kind":"arabic","text_bw":"SaEaAriyr","text_ar":"صَعَارِير"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"SuEoruwrN","text_ar":"صُعْرُورٌ"},{"kind":"text","text":", q. v.], (K, * TK,) i. e.,"},{"kind":"italic_en","text":"gum."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","K","S","A","Lth","Mgh","TK"]},{"entry_id":"n24341","headword_ar":"صَعَرٌ","root":"SEr","body":[{"kind":"text","text":"inf. n. of 1 [q. v.]. ―         -b2-  The saying"},{"kind":"arabic","text_bw":"fiY AlS~aEari","text_ar":"فِى الصَّعَرِ"},{"kind":"arabic","text_bw":"Ald~iyapu","text_ar":"الدِّيَةُ"},{"kind":"text","text":"is expl. as meaning"},{"kind":"italic_en","text":"In"},{"kind":"text","text":"[the case of]"},{"kind":"italic_en","text":"the distorting of the face"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the"},{"kind":"text","text":"whole"},{"kind":"italic_en","text":"bloodwit"},{"kind":"text","text":"shall be exacted: as though the verb of which"},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":"is the inf. n. were trans.; but this is obviously a loose rendering]. (Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Pride:"},{"kind":"text","text":"(Mgh:) or the"},{"kind":"italic_en","text":"being proud."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"italic_en","text":"Smallness of the head:"},{"kind":"text","text":"(K:) or the"},{"kind":"italic_en","text":"being small,"},{"kind":"text","text":"said of a man's head: (K, * TA:) one says,"},{"kind":"arabic","text_bw":"SaEira","text_ar":"صَعِرَ"},{"kind":"arabic","text_bw":"raA^osuhu","text_ar":"رَاْسُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SaEarN","text_ar":"صَعَرٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"his head was small."},{"kind":"text","text":"(TK.)"}],"source_refs":["Mgh","K"]}]},"classical_definitions":null}