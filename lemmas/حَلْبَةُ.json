:"italic_en","text":"when they have become harsh and dry, and dusty"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dustcoloured, and when its branches and thorns have become thick:"},{"kind":"text","text":"(TA:) or it is ["},{"kind":"italic_en","text":"what is in a similar state"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the fruit of the"},{"kind":"arabic","text_bw":"EDAh","text_ar":"عضاه"},{"kind":"text","text":": (IAth, TA:) the word is sometimes pronounced ↓"},{"kind":"arabic","text_bw":"HulubapN","text_ar":"حُلُبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b5-  The"},{"kind":"italic_en","text":"kind of food called"},{"kind":"arabic","text_bw":"fariyqap","text_ar":"فَرِيقَة"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"which is given to women when childbearing;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"HulubapN","text_ar":"حُلُبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)       -A2-"},{"kind":"italic_en","text":"A pure black colour."},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"HulobuwbN","text_ar":"حُلْبُوبٌ"},{"kind":"text","text":".]"}],"source_refs":["S","Mgh","Msb","AHn","K","TA","IAth"]},{"entry_id":"n8795","headword_ar":"حُلُبَةٌ","root":"Hlb","body":[{"kind":"text","text":": see the next preceding paragraph, in three places."}],"source_refs":[]}]},"classical_definitions":null}