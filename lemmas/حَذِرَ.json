xicon.com/?s=%D8%AD%D9%8E%D8%B0%D9%90%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to watch out"},{"pos":"verb","gloss":"to warn, to admonish","tags":["ditransitive"],"examples":[{"text":"وَحَذَّرَهُمَا أَنَّ خَطِيَّتَهُمَا سَتُؤَدِّي إِلَى الْمَوْتِ","english":"And he warned them both that their sin would lead to death"},{"text":"وَيُحَذِّرُكُمُ ٱللّٰهُ نَفْسَهُ","english":"And Allah warns you about Himself"}]},{"pos":"noun","gloss":"verbal noun of حَذِرَ (ḥaḏira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"caution, care, precaution","examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا خُذُوا حِذْرَكُمْ فَٱنْفِرُوا ثُبَاتٍ أَوِ ٱنْفِرُوا جَمِيعًا"}]},{"pos":"adj","gloss":"cautious, careful"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7411","headword_ar":"حَذِرَ","root":"H*r","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ha*arN","text_ar":"حَذَرٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"He was cautious, wary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant; was on his guard; took care;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"was in a state of preparation;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"was in fear; feared."},{"kind":"text","text":"(TA.) [You say,"},{"kind":"arabic","text_bw":"Ha*ira mino A^amorK","text_ar":"حَذِرَ مِنْ اَمْرٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"italic_en","text":"He was cautious,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an event."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"Ha*ira Ealayohi mino ka*aA","text_ar":"حَذِرَ عَلَيْهِ مِنْ كَذَا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"italic_en","text":"He was cautious,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for him, of such a thing."},{"kind":"text","text":"And both verbs are also trans.: for you say,]"},{"kind":"arabic","text_bw":"Ha*irahu","text_ar":"حَذِرَهُ"},{"kind":"text","text":", (S, A, Msb,) aor. and inf. n. as above; (S;) and ↓"},{"kind":"arabic","text_bw":"AHt*rhu","text_ar":"احتذرهُ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"HA*rhu","text_ar":"حاذرهُ","orth_type":"arrow"},{"kind":"text","text":"; (A;)"},{"kind":"italic_en","text":"He was cautious of it; guarded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was on his guard, against it;"},{"kind":"text","text":"(S, A;)"},{"kind":"italic_en","text":"prepared, prepared himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was in a state of preparation, against it;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"feared it."},{"kind":"text","text":"(Msb, TA.) [And"},{"kind":"arabic","text_bw":"Ha*ira","text_ar":"حَذِرَ"},{"kind":"arabic","text_bw":"A^ano yafoEalahu","text_ar":"اَنْ يَفْعَلَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"italic_en","text":"He was cautious of doing it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he feared doing it."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"Hu*ira Al$~aYo'u faHa*irahu","text_ar":"حُذِرَ الشَّىْءُ فَحَذِرَهُ"},{"kind":"italic_en","text":"The thing was an object of fear, and so he feared it."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Hu*ira Almawoti","text_ar":"حُذِرَ المَوْتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Death was an object of fear"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Almawota","text_ar":"المَوْتَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"HA*r","text_ar":"حاذر","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He feared death"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","A","Msb","TA"]}]}}