{"lemma":"لُبانِ","slug":"لُبانِ","root":"ل.ب.ن","root_slug":"ل-ب-ن","root_link":"/words/roots/ل-ب-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n43215","n43216"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8F%D8%A8%D8%A7%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"olibanum, frankincense"},{"pos":"noun","gloss":"any kind of gum or resin"},{"pos":"noun","gloss":"chewing gum"},{"pos":"noun","gloss":"plural of لَبَن (laban)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of لَبَن (laban)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":["/lu.baːn/","/law.baːn/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43215","headword_ar":"لُبَانٌ","root":"lbn","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"frankincense-tree"},{"kind":"text","text":"] is"},{"kind":"italic_en","text":"a tree of the kind called"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":","},{"kind":"italic_en","text":"having a fruit resembling the pistachio-nut, and a resin like the"},{"kind":"arabic","text_bw":"kunodur","text_ar":"كُنْدُر"},{"kind":"text","text":", [which is said in the S and TA to be the same as the"},{"kind":"arabic","text_bw":"lubaAn","text_ar":"لُبَان"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"when it concretes:"},{"kind":"text","text":"(O and TA in art."},{"kind":"arabic","text_bw":"syE","text_ar":"سيع"},{"kind":"text","text":":) it is also, and more commonly, applied to the"},{"kind":"italic_en","text":"resin itself,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"frankincense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"olibanum:"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"tree that produces it is now known to be of the genus Boswellia,"},{"kind":"text","text":"found in Hadramowt and other parts of Southern Arabia, and also in the opposite (eastern) region of Africa, and in India: it was formerly erroneously supposed to be the Juniperus Lycia. ―         -b2-"},{"kind":"arabic","text_bw":"HaSaY lubaAnK","text_ar":"حَصَى لُبَانٍ"},{"kind":"text","text":": see K, voce"},{"kind":"arabic","text_bw":"EasalN","text_ar":"عَسَلٌ"},{"kind":"text","text":"; and see art."},{"kind":"arabic","text_bw":"HSY","text_ar":"حصى"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n43216","headword_ar":"لِبَانٌ","root":"lbn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"sucking of milk"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the breast:"},{"kind":"text","text":"(S, Msb, K:) see an ex. in a verse of El-Aashà cited voce"},{"kind":"arabic","text_bw":"A^asoHamu","text_ar":"اَسْحَمُ"},{"kind":"text","text":": and see 1 in art."},{"kind":"arabic","text_bw":"g*w","text_ar":"غذو"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}