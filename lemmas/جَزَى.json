"تَجْزِيانِ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْزُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْزُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْزِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْز","in_corpus":true,"count":44,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْزِي","in_corpus":true,"count":8,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُجْزَى","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْز","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْزِي","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُجْزَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْزِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْزِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْزِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْزِيانِ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْزُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْزِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْز","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْز","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْزِي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْزِي","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُجْزَى","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْزَى","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَزَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَزَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":121,"cross_references":{"qac":{"found":true,"lemma_key":"جَزَى","root":"جزي","pos":"V","occurrence_count":73},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5756"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B2%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plural of جِزْيَة (jizya)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5756","headword_ar":"جَزَى","root":"jzY","body":[{"kind":"text","text":", aor"},{"kind":"text","text":"(Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jazaA='N","text_ar":"جَزَا=ءٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"paid; gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, as a satisfaction;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made, gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, satisfaction:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"satisfied; sufficed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jazayotu Ald~ayona","text_ar":"جَزَيْتُ الدَّيْنَ"},{"kind":"italic_en","text":"I paid the debt."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jazayotu fulaAnFA Haq~ahu","text_ar":"جَزَيْتُ فُلَانًا حَقَّهُ"},{"kind":"italic_en","text":"I paid such a one his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA yajoziyniY h`*aA Alv~awobu","text_ar":"مَا يَجْزِينِى هٰذَا الثَّوْبُ"},{"kind":"italic_en","text":"This garment does not suffice me."},{"kind":"text","text":"(TA.)―         -b2-  And hence, (TA,)"},{"kind":"arabic","text_bw":"jazaY Eanohu","text_ar":"جَزَى عَنْهُ"},{"kind":"text","text":", (S, Mgh, Msb, K,) [aor. and] inf. n. as above, (Mgh,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"paid for him; gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered,"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"as a satisfaction for him; made, gave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered, satisfaction for him;"},{"kind":"text","text":"(S, Mgh, Msb,* K;) and some of the lawyers use ↓"},{"kind":"arabic","text_bw":"AjzY","text_ar":"اجزى"},{"kind":"text","text":"in this sense, like"},{"kind":"arabic","text_bw":"AjzA^","text_ar":"اجزا"},{"kind":"text","text":": (Az, Mgh, Msb:)"},{"kind":"arabic","text_bw":"jazaY","text_ar":"جَزَى"},{"kind":"text","text":"is of the dial. of El-Hijáz, and"},{"kind":"arabic","text_bw":"AjzA^","text_ar":"اجزا"},{"kind":"text","text":"of the dial. of Temeem. (Akh, Msb.) Hence, in the Kur [ii. 45],"},{"kind":"arabic","text_bw":"laA tajoziY nafosN Eano nafosK","text_ar":"لَا تَجْزِى نَفْسٌ عَنْ نَفْسٍ"},{"kind":"arabic","text_bw":"$ayoy^FA","text_ar":"شَيْيًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A soul shall not give anything as a satisfaction for a soul, i. e. for another soul:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a soul shall not make satisfaction for a soul at all;"},{"kind":"text","text":"accord. to the latter rendering,"},{"kind":"arabic","text_bw":"$yy^A","text_ar":"شييا"},{"kind":"text","text":"being put in the accus. case after the manner of an inf. n.]. (S, Msb.) You say also,"},{"kind":"arabic","text_bw":"jazato Eanoka $aApN","text_ar":"جَزَتْ عَنْكَ شَاةٌ"},{"kind":"italic_en","text":"A sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat, made satisfaction for thee"},{"kind":"text","text":"[as a sacrifice]; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"A^ajozato","text_ar":"اَجْزَتْ"},{"kind":"text","text":": (TA:) Benoo-Temeem say"},{"kind":"arabic","text_bw":"A^ajozaA^ato","text_ar":"اَجْزَاَتْ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (S, TA:) this last, thus explained, is a dial, var. mentioned by IKtt (Msb.) And"},{"kind":"arabic","text_bw":"ka*aA Eano ka*aA","text_ar":"كَذَا عَنْ كَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjzY","text_ar":"اجزى"},{"kind":"italic_en","text":"Such a thing stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"served, in lieu, in the place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in stead, of such a thing, without sufficing."},{"kind":"text","text":"(Zj, K.) And"},{"kind":"arabic","text_bw":"qaliylN mino kaviyrK","text_ar":"قَلِيلٌ مِنْ كَثِيرٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yujoziY","text_ar":"يُجْزِى"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"h`*aAmino h`*aA","text_ar":"هٰذَامِنْ هٰذَا"},{"kind":"text","text":";"},{"kind":"italic_en","text":"A little stands,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"serves, in lieu of much;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"this, of this."},{"kind":"text","text":"(IAar, TA.) And"},{"kind":"arabic","text_bw":"Eanohu mujozaY","text_ar":"عَنْهُ مُجْزَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjzY","text_ar":"اجزى","orth_type":"arrow"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mujozaApa fulaAnK","text_ar":"مُجْزَاةَ فُلَانٍ"},{"kind":"text","text":"and (as though the augmentative letter ["},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"AjzY","text_ar":"اجزى"},{"kind":"text","text":"] were imagined to be rejected, TA)"},{"kind":"arabic","text_bw":"majozaY flAn","text_ar":"مَجْزَى فلان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"majozaApa flAn","text_ar":"مَجْزَاةَ فلان"},{"kind":"italic_en","text":"He satisfied, sufficed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented, him as such a one; he stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"served, him in stead of such a one;"},{"kind":"text","text":"a dial. var. of"},{"kind":"arabic","text_bw":"AjzA^","text_ar":"اجزا"},{"kind":"text","text":". (K.) And ↓"},{"kind":"arabic","text_bw":"AjzY","text_ar":"اجزى","orth_type":"arrow"},{"kind":"arabic","text_bw":"mujozaY gayorihi","text_ar":"مُجْزَى غَيْرِهِ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"satisfied, sufficed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contented, as another thing; it stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"served, in stead of another thing."},{"kind":"text","text":"(Msb.) And ↓"},{"kind":"arabic","text_bw":"AjzAka","text_ar":"اجزاكَ"},{"kind":"text","text":", with the [second] objective complement suppressed,"},{"kind":"italic_en","text":"It was sufficient for thee."},{"kind":"text","text":"(Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"jazaAha ka*aA","text_ar":"جَزَاهَ كَذَا"},{"kind":"text","text":"(Msb,* TA,) and"},{"kind":"arabic","text_bw":"jazaAhu bihi","text_ar":"جَزَاهُ بِهِ"},{"kind":"text","text":"(K,) or"},{"kind":"arabic","text_bw":"bimaA SanaEa","text_ar":"بِمَا صَنَعَ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (K,) [aor. and] inf. n. as above, (S, K,)"},{"kind":"italic_en","text":"He repaid, requited, compensated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompensed, him"},{"kind":"text","text":"(Msb, K TA) ["},{"kind":"italic_en","text":"for such a thing, for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for what he had done"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"jAzAhu","text_ar":"جازاهُ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"mujaAzaApN","text_ar":"مُجَازَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jizaA='N","text_ar":"جِزَا=ءٌ"},{"kind":"text","text":": (K:) or, accord. to Fr, [contr. to many instances in the Kur,] the former verb relates only to good; and the latter, to good and to evil: but accord. to others, the former may relate to good and to evil; and the latter, to evil. (TA.) [See also"},{"kind":"arabic","text_bw":"jazaA='N","text_ar":"جَزَا=ءٌ"},{"kind":"text","text":", below.] One says, in praying for another,"},{"kind":"arabic","text_bw":"jazaAhu A@ll~`hu xayorFA","text_ar":"جَزَاهُ ا@للّٰهُ خَيْرًا"},{"kind":"italic_en","text":"May God repay him good:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"requite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompense, him for good"},{"kind":"text","text":"[that he has done]. (Msb.) And"},{"kind":"arabic","text_bw":"bi*anobihi","text_ar":"بِذَنْبِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jaAzayotuhu","text_ar":"جَازَيْتُهُ","orth_type":"arrow"},{"kind":"italic_en","text":"I punished him for his crime, or sin, or act of disobedience."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jazaY Eanohu fulaAnFA","text_ar":"جَزَى عَنْهُ فُلَانًا"},{"kind":"italic_en","text":"He requited, compensated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recompensed, for him, such a one."},{"kind":"text","text":"(TA.)―         -b4-"},{"kind":"arabic","text_bw":"jaAzayotuhu fajazayotuhu","text_ar":"جَازَيْتُهُ فَجَزَيْتُهُ"},{"kind":"text","text":": see 3."}],"source_refs":["Msb","K","TA","S","Mgh","Az"]}]}}