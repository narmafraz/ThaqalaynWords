":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُرَسِّخُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرَسِّخْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرَسِّخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرَسِّخ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرَسِّخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرَسِّخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرَسِّخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرَسِّخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرَسِّخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرَسِّخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرَسِّخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رَسَّخْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَسَّخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرَسِّخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُرَسِّخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15465"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B3%D9%8E%D9%91%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be firmly anchored, to be deeply rooted, to be established"},{"pos":"verb","gloss":"to entrench, to establish, to embed, to cement, to inculcate, to enshrine, to consolidate"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15465","headword_ar":"رَسَخَ","root":"rsx","body":[{"kind":"text","text":", (S, A, L, &c.,) aor."},{"kind":"text","text":", (A, Msb, JM, &c.,) inf. n."},{"kind":"arabic","text_bw":"rusuwxN","text_ar":"رُسُوخٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm, steady, steadfast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established,"},{"kind":"text","text":"(S, A, L, Msb, K,)"},{"kind":"italic_en","text":"in its place."},{"kind":"text","text":"(L.) [Hence,]"},{"kind":"arabic","text_bw":"rasaxa AlHiboru fiY AlS~aHiyfapi","text_ar":"رَسَخَ الحِبْرُ فِى الصَّحِيفَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The ink became fixed upon the piece of paper"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]. (A, L.) And"},{"kind":"arabic","text_bw":"Alr~aq~u Ald~ahiynu laA yurosaxu","text_ar":"الرَّقُّ الدَّهِينُ لَا يُرْسَخُ"},{"kind":"arabic","text_bw":"fiyhi AlHiboru","text_ar":"فِيهِ الحِبْرُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Ink will not become fixed upon oiled parchment"},{"kind":"text","text":"]: (A:) or"},{"kind":"arabic","text_bw":"Alwaraqu Ald~ahiynu","text_ar":"الوَرَقُ الدَّهِينُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"oiled paper"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"rasaxa fiY AlEilomi","text_ar":"رَسَخَ فِى العِلْمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became firmly rooted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established, in science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"AlEilomu yarosaxu fiY qalobi AlA_inosaAni","text_ar":"العِلْمُ يَرْسَخُ فِى قَلْبِ الاـِنْسَانِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge, becomes firmly rooted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed, in the heart of man."},{"kind":"text","text":"(L, A. *) And"},{"kind":"arabic","text_bw":"rasaxa Hub~uhu fiY qalobihi","text_ar":"رَسَخَ حُبُّهُ فِى قَلْبِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The love of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became fixed in his heart"},{"kind":"text","text":"]. (A.) ―         -b2-  [Hence also,] said of a pool of water left by a torrent, (tropical:)"},{"kind":"italic_en","text":"It sank into the earth, and disappeared:"},{"kind":"text","text":"(JK, A, K:) inf. n. as above. (JK, TA.) And, said of rain, (tropical:)"},{"kind":"italic_en","text":"It sank into the earth so that the two moistures"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"that of the rain and that of the soil beneath"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"met together."},{"kind":"text","text":"(A, K.) ―         -b3-"},{"kind":"arabic","text_bw":"rasoxN","text_ar":"رَسْخٌ"},{"kind":"text","text":"[as an inf. n.] signifies (assumed tropical:)  The"},{"kind":"italic_en","text":"connexion of the soul of a human being, after its departure from the body, with an inanimate, not increasing, body:"},{"kind":"text","text":"distinguished from"},{"kind":"arabic","text_bw":"nasoxN","text_ar":"نَسْخٌ"},{"kind":"text","text":", which is with the body of another human being: and from"},{"kind":"arabic","text_bw":"masoxN","text_ar":"مَسْخٌ"},{"kind":"text","text":", which is with the body of a beast: and from"},{"kind":"arabic","text_bw":"fasoxN","text_ar":"فَسْخٌ"},{"kind":"text","text":", which is with a plant. (Marginal note in a copy of the KT.) But see 1 (last sentence) in art."},{"kind":"arabic","text_bw":"fsx","text_ar":"فسخ"}],"source_refs":["S","A","L","Msb","K","JK"]}]},"classical_definitions":null}