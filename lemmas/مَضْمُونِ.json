ic_en","text":"The contents of a writing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"letter;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is infolded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"included, in a writing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"letter; what is implied therein;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"what is indicated therein"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"maDaAmiynu","text_ar":"مَضَامِينُ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlmaDaAmiynu","text_ar":"المَضَامِينُ"},{"kind":"text","text":", (A 'Obeyd, S, Msb, K,) of which the sing. is"},{"kind":"arabic","text_bw":"maDomuwnN","text_ar":"مَضْمُونٌ"},{"kind":"text","text":", (A 'Obeyd, Msb, K,) and one may also say"},{"kind":"arabic","text_bw":"maDomuwnapN","text_ar":"مَضْمُونَةٌ"},{"kind":"text","text":", as meaning"},{"kind":"arabic","text_bw":"nasamapN","text_ar":"نَسَمَةٌ"},{"kind":"text","text":", (Msb,) signifies"},{"kind":"italic_en","text":"What are"},{"kind":"text","text":"["},{"kind":"italic_en","text":"comprised"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the loins of the stallions;"},{"kind":"text","text":"(A 'Obeyd, S, Msb, K;) i. e."},{"kind":"italic_en","text":"the progeny"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof, in the elemental state"},{"kind":"text","text":"]: (Msb:) or, accord. to Aboo-Sa'eed, [though the reverse is generally held to be the case,]"},{"kind":"arabic","text_bw":"AlmalaAqiyHu","text_ar":"المَلَاقِيحُ"},{"kind":"text","text":"signifies what are in the backs of the he-camels, and"},{"kind":"arabic","text_bw":"AlmaDaAmiynu","text_ar":"المَضَامِينُ"},{"kind":"italic_en","text":"what are in the bellies of the females."},{"kind":"text","text":"(L in art."},{"kind":"arabic","text_bw":"lqH","text_ar":"لقح"},{"kind":"text","text":".) The selling of the"},{"kind":"arabic","text_bw":"mDAmyn","text_ar":"مضامين"},{"kind":"text","text":"and the"},{"kind":"arabic","text_bw":"mlAqyH","text_ar":"ملاقيح"},{"kind":"text","text":"is forbidden. (S.) ["},{"kind":"arabic","text_bw":"maDaAmiynu","text_ar":"مَضَامِينُ"},{"kind":"text","text":"is also pl. of"},{"kind":"arabic","text_bw":"miDomaAnN","text_ar":"مِضْمَانٌ"},{"kind":"text","text":", q. v.] ―         -b4-"},{"kind":"arabic","text_bw":"maDomuwnu Alyadi","text_ar":"مَضْمُونُ اليَدِ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"maxobuwnuhaA","text_ar":"مَخْبُونُهَا"},{"kind":"text","text":", (K,) meaning"},{"kind":"arabic","text_bw":"maEoluwluhaA","text_ar":"مَعْلُولُهَا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Diseased in the arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand"},{"kind":"text","text":"]; (TK;) applied to a man. (TA. [See 1, last sentence, which indicates a more particular meaning.])"}],"source_refs":["Msb","K"]}]},"classical_definitions":null}