{"lemma":"بَكَمِ","slug":"بَكَمِ","root":"ب.ك.م","root_slug":"ب-ك-م","root_link":"/words/roots/ب-ك-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n3088"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%83%D9%8E%D9%85%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3088","headword_ar":"بَكِمَ","root":"bkm","body":[{"kind":"text","text":"aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"bakamN","text_ar":"بَكَمٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He was"},{"kind":"arabic","text_bw":"A^axorasN","text_ar":"اَخْرَسٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"dumb,"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"by natural conformation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from inability to find words to express what he would say"},{"kind":"text","text":"]; (S, Msb, K; *)"},{"kind":"arabic","text_bw":"bakamN","text_ar":"بَكَمٌ"},{"kind":"text","text":"being"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xarasN","text_ar":"خَرَسٌ"},{"kind":"text","text":", as is also"},{"kind":"arabic","text_bw":"bakaAmapN","text_ar":"بَكَامَةٌ"},{"kind":"text","text":"[accord. to rule an inf. n. of"},{"kind":"arabic","text_bw":"bakuma","text_ar":"بَكُمَ"},{"kind":"text","text":", which may also have the same signification as"},{"kind":"arabic","text_bw":"bakima","text_ar":"بَكِمَ"},{"kind":"text","text":", as well as another to be explained below]: (K:) or"},{"kind":"italic_en","text":"he had not understanding to reply,"},{"kind":"text","text":"(T, Msb, TA,)"},{"kind":"italic_en","text":"nor ability to frame speech well,"},{"kind":"text","text":"(T, TA,)"},{"kind":"italic_en","text":"though possessing the faculty of speech:"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"A^abokamu","text_ar":"اَبْكَمُ"},{"kind":"text","text":":] (T, Msb, TA:) or"},{"kind":"italic_en","text":"he was dumb, and moreover unable to find words to express what he would say, and weak in understanding, silly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupid:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he was dumb and deaf and blind by birth."},{"kind":"text","text":"(Th, K.) ―         -b2-"},{"kind":"arabic","text_bw":"bakuma","text_ar":"بَكُمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"bakaAmapN","text_ar":"بَكَامَةٌ"},{"kind":"text","text":", TK,)"},{"kind":"italic_en","text":"He refrained,"},{"kind":"text","text":"(Lth, K) or, as some say,"},{"kind":"italic_en","text":"broke off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"from speaking, intentionally,"},{"kind":"text","text":"(Lth, K, TA,) or"},{"kind":"italic_en","text":"from ignorance."},{"kind":"text","text":"(Lth, TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"He cut himself off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desisted, from marriage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sexual intercourse,"},{"kind":"text","text":"either"},{"kind":"italic_en","text":"from ignorance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intentionally."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["Msb","K","S","T","TA","Lth"]}]},"classical_definitions":null}