se,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُمَرْحِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُمَرْحِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُمَرْحِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُمَرْحِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُمَرْحِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُمَرْحِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُمَرْحِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُمَرْحِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُمَرْحِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُمَرْحِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُمَرْحِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"مَرْحَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مَرْحَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُمَرْحِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُمَرْحِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":25,"cross_references":{"qac":{"found":true,"lemma_key":"مَرْحَب","root":"رحب","pos":"N","occurrence_count":2},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n15031"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B1%D9%92%D8%AD%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15031","headword_ar":"مَرْحَبٌ","root":"rHb","body":[{"kind":"text","text":"[is an inf. n., like ↓"},{"kind":"arabic","text_bw":"ruHobN","text_ar":"رُحْبٌ","orth_type":"arrow"},{"kind":"text","text":"; or a n. of place]. You say"},{"kind":"arabic","text_bw":"maroHabFA","text_ar":"مَرْحَبًا"},{"kind":"text","text":"(T, S, Msb, TA) and"},{"kind":"arabic","text_bw":"maroHabFA bika","text_ar":"مَرْحَبًا بِكَ"},{"kind":"text","text":"(A, Msb) [and"},{"kind":"arabic","text_bw":"bika","text_ar":"بِكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ruHobFA","text_ar":"رُحْبًا","orth_type":"arrow"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"Thou hast come to,"},{"kind":"text","text":"(T, S, TA,) or"},{"kind":"italic_en","text":"found,"},{"kind":"text","text":"(T, A, TA,)"},{"kind":"italic_en","text":"ampleness, spaciousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roominess;"},{"kind":"text","text":"(T, S, A, TA;)"},{"kind":"italic_en","text":"not straitness:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"alight thou,"},{"kind":"text","text":"(Kh, Lth, TA,) or"},{"kind":"italic_en","text":"abide thou,"},{"kind":"text","text":"(Kh, TA,)"},{"kind":"italic_en","text":"in ampleness,"},{"kind":"text","text":"&c.; (Kh, Lth, TA;) for such we have for thee; (Lth, TA;) the word being put in the accus. case because of a verb understood: (Kh, TA:) or"},{"kind":"italic_en","text":"thou hast alighted in an ample, a spacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a roomy, place:"},{"kind":"text","text":"(Msb:) [or"},{"kind":"italic_en","text":"welcome to ampleness,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"to an ample, a spacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a roomy, place:"},{"kind":"text","text":"or simply"},{"kind":"italic_en","text":"welcome:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"maroHabFA waA^aholFA","text_ar":"مَرْحَبًا وَاَهْلًا"},{"kind":"italic_en","text":"Thou hast come to"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"found,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"ampleness, spaciousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roominess, and"},{"kind":"text","text":"[such as thine own]"},{"kind":"italic_en","text":"kinsfolk;"},{"kind":"text","text":"therefore be cheerful, and be not sad: (S:) and"},{"kind":"arabic","text_bw":"maroHabFA wasaholFA","text_ar":"مَرْحَبًا وَسَهْلًا"},{"kind":"italic_en","text":"Thou hast found ampleness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and ease"},{"kind":"text","text":"]: (K:) or"},{"kind":"arabic","text_bw":"saholFA","text_ar":"سَهْلًا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"thou hast alighted in a plain, smooth, not rugged, district:"},{"kind":"text","text":"(T, TA:) and"},{"kind":"arabic","text_bw":"maroHabaka A@ll~`hu wamasohalaka","text_ar":"مَرْحَبَكَ ا@للّٰهُ وَمَسْهَلَكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maroHabFA bika A@ll~`hu wamasohalFA","text_ar":"مَرْحَبًا بِكَ ا@للّٰهُ وَمَسْهَلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God grant ampleness to thee, and ease"},{"kind":"text","text":"]: (K:) Sh says, thus I heard IAar say: and the Arabs also say,"},{"kind":"arabic","text_bw":"laA maroHabFA bika","text_ar":"لَا مَرْحَبًا بِكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"May it"},{"kind":"text","text":"[the land or country]"},{"kind":"italic_en","text":"not be ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spacious, to thee:"},{"kind":"arabic","text_bw":"maroHabFA","text_ar":"مَرْحَبًا"},{"kind":"text","text":", he says, is one of the inf. ns. that are used in calling down blessings or curses on a man; as"},{"kind":"arabic","text_bw":"saqoyFA","text_ar":"سَقْيًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raEoyFA","text_ar":"رَعْيًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jadoEFA","text_ar":"جَدْعًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaqorFA","text_ar":"عَقْرًا"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"saqaAka A@ll~`hu","text_ar":"سَقَاكَ ا@للّٰهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raEaAka A@ll~`hu","text_ar":"رَعَاكَ ا@للّٰهُ"},{"kind":"text","text":"&c.: and Fr says that the meaning [of"},{"kind":"arabic","text_bw":"maroHabFA","text_ar":"مَرْحَبًا"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"maroHabFA bika","text_ar":"مَرْحَبًا بِكَ"},{"kind":"text","text":"] is"},{"kind":"arabic","text_bw":"A@ll~`hu bika maroHabFA","text_ar":"ا@للّٰهُ بِكَ مَرْحَبًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raH~aba","text_ar":"رَحَّبَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God invite thee to ampleness,"},{"kind":"text","text":"&c.]; as though the last word were put in the place of"},{"kind":"arabic","text_bw":"taroHiybFA","text_ar":"تَرْحِيبًا"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^abuw maroHabK","text_ar":"اَبُو مَرْحَبٍ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The shade:"},{"kind":"text","text":"so in the saying of a poet, (S,) namely, En-Nábighah El-Jaadee, (TA,)"},{"kind":"quote","text":"wakayofa tuwaASilu mano A^aSobaHato\n                      \n                     \n                        xulaAlatuhu kaA^abiY maroHabi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And how wilt thou hold loving communion with him whose friendship has become like the shade?"},{"kind":"text","text":"]. (S, TA.) It is also a surname of 'Orkoob, the man notorious for lying promises. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"maroHabN","text_ar":"مَرْحَبٌ"},{"kind":"text","text":"is the name of"},{"kind":"italic_en","text":"An idol that was in Hadramowt."},{"kind":"text","text":"(K.)"}],"source_refs":["T","S","Msb","TA","A","Kh","Lth","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%B1%D8%AD%D8%A8/","headword_ar":"مَرْحَبٌ","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=146897#5f2dfc","body_html":"مَرْحَبٌ:<br>هو صنم كان بحضرموت وكان سادنه ذا مرحب وبه سمي ذا مرحب. ومرحب: طريق بين المدينة وخيبر ذكره في المغازي، قال الراوي في غزوة خيبر: إن الدليل انتهى برسول الله، صلّى الله عليه وسلّم، إلى موضع له طريق إلى خيبر فقال: يا رسول الله إن لها طرقا تؤتى منها كلها، فقال، صلى الله عليه وسلّم: سمّها لي، وكان، صلّى الله عليه وسلّم، يحبّ الفأل والاسم الحسن ويكره الطيرة والاسم القبيح، فقال الدليل: لها طريق يقال له حزن، قال: لا نسلكها، قال: لها طريق يقال له شاس، قال: لا نسلكها، فقال: لها طريق يقال له حاطب، قال: لا نسلكها، قال بعض رفقائهم: ما رأيت كالليلة أسماء أقبح من أسماء سمّيت لرسول الله، قال: لها طريق واحدة ولم يبق غيرها يقال لها مرحب، قال، صلى الله عليه وسلّم: نعم أسلكها، فقال عمر، رضي الله عنه: ألا سمّيت هذه الطريق أول مرّة!"}]}}