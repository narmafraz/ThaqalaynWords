to be in pain, to ache","examples":[{"text":"If you are suffering, [know that] they are suffering as you suffer."}]},{"pos":"noun","gloss":"verbal noun of أَلِمَ (ʔalima, “to be in pain, to ache”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"pain"},{"pos":"noun","gloss":"grief"},{"pos":"noun","gloss":"passion"}]},"etymology":null,"ipa":["/ʔa.lam/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1098","headword_ar":"اَلِمَ","root":"Alm","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^alamN","text_ar":"اَلَمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"(as, for instance, the belly, T, S, or the head, Msb,) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a man, T, S, Msb,)"},{"kind":"italic_en","text":"was in pain; had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffered, pain; ached."},{"kind":"text","text":"(T, S, M, Msb, K.)"},{"kind":"arabic","text_bw":"A^alima baTonahu","text_ar":"اَلِمَ بَطْنَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was in pain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had pain, in his belly"},{"kind":"text","text":"] (M) and"},{"kind":"arabic","text_bw":"A^alimota baTonaka","text_ar":"اَلِمْتَ بَطْنَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thou wast in pain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hadst pain, in thy belly"},{"kind":"text","text":"] (T, S) or"},{"kind":"arabic","text_bw":"raA^osaka","text_ar":"رَاْسَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in thy head"},{"kind":"text","text":"] (Msb) are like"},{"kind":"arabic","text_bw":"safiha raA^oyahu","text_ar":"سَفِهَ رَاْيَهُ"},{"kind":"text","text":"(M) and"},{"kind":"arabic","text_bw":"ra$idota A^amoraka","text_ar":"رَشِدْتَ اَمْرَكَ"},{"kind":"text","text":"(S, T) and"},{"kind":"arabic","text_bw":"wajiEota raA^osaka","text_ar":"وَجِعْتَ رَاْسَكَ"},{"kind":"text","text":"; (Msb;) the noun being in the accus. case accord. to Ks as an explicative, though explicatives are [by rule] indeterminate, as in"},{"kind":"arabic","text_bw":"qarirotu bihi EayonFA","text_ar":"قَرِرْتُ بِهِ عَيْنًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Daqotu bihi *aroEFA","text_ar":"ضَقْتُ بِهِ ذَرْعًا"},{"kind":"text","text":"; (T;) the regular form being ["},{"kind":"arabic","text_bw":"A^alima baTonuhu","text_ar":"اَلِمَ بَطْنُهُ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"A^alima baTonuka","text_ar":"اَلِمَ بَطْنُكَ"},{"kind":"text","text":", (T, S,) as the verb is intrans. (T.)"}],"source_refs":["M","T","S","Msb"]},{"entry_id":"n1101","headword_ar":"اَلَمٌ","root":"Alm","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"lamo","text_ar":"لَمْ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1102","headword_ar":"اَلَمٌ","root":"Alm","body":[{"kind":"italic_en","text":"Pain; ache;"},{"kind":"text","text":"(T, S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^ayolamapN","text_ar":"اَيْلَمَةٌ","orth_type":"arrow"},{"kind":"text","text":": (T, M, K:) pl. (of the former, T, M)"},{"kind":"arabic","text_bw":"A=laAmN","text_ar":"ا=لَامٌ"},{"kind":"text","text":". (T, M, K.) You say,"},{"kind":"arabic","text_bw":"walaA A^alamFA","text_ar":"وَلَا اَلَمًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^ajidu A^ayolamapF","text_ar":"مَا اَجِدُ اَيْلَمَةً","orth_type":"arrow"},{"kind":"italic_en","text":"I do not find pain nor ache;"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"wajaEFA","text_ar":"وَجَعًا"},{"kind":"text","text":": so says AZ: and IAar says, ↓"},{"kind":"arabic","text_bw":"A^ayolamapF walaA A^alamapF","text_ar":"اَيْلَمَةً وَلَا اَلَمَةً","orth_type":"arrow"},{"kind":"text","text":"as meaning the same. (T.) And the Arabs say,"},{"kind":"arabic","text_bw":"laA^ubiytan~aka EalaY","text_ar":"لَاُبِيتَنَّكَ عَلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ayolamapK","text_ar":"اَيْلَمَةٍ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I will assuredly bring upon thee"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"make thee to pass the night in"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"distress,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficulty."},{"kind":"text","text":"(Sh.)"}],"source_refs":["T","M","K"]},{"entry_id":"n1103","headword_ar":"اَلِمٌ","root":"Alm","body":[{"kind":"italic_en","text":"Being in pain; having,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffering, pain; aching."},{"kind":"text","text":"(M, K.)"}],"source_refs":[]}]}}