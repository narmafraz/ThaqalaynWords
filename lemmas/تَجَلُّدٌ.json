lf to behave with hardiness,"}, {"kind": "text", "text": "&c.,"}, {"kind": "italic_en", "text": "to those who rejoiced at his misfortune"}, {"kind": "text", "text": "]. (A, TA.) In the phrase"}, {"kind": "arabic", "text_bw": "tjl~d Eanohu", "text_ar": "تجلّد عَنْهُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He constrained himself to endure with hardiness and patience the loss,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "want, of him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "], the verb is made trans. by means of"}, {"kind": "arabic", "text_bw": "En", "text_ar": "عن"}, {"kind": "text", "text": "because it implies the meaning of"}, {"kind": "arabic", "text_bw": "taSab~ara", "text_ar": "تَصَبَّرَ"}, {"kind": "text", "text": ". (L.) ―         -b2-  Also"}, {"kind": "italic_en", "text": "He feigned,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "made a show of, hardiness, strength, sturdiness, and endurance,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "patience."}, {"kind": "text", "text": "(L.)"}], "source_refs": []}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}