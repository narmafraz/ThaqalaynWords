nd":"text","text":": (S, K, TA:) or"},{"kind":"italic_en","text":"he was long diseased"},{"kind":"text","text":"&c. (Msb.) [See also"},{"kind":"arabic","text_bw":"suqomN","text_ar":"سُقْمٌ"},{"kind":"text","text":"below.]"}],"source_refs":["S","Msb","TA","K"]},{"entry_id":"n20124","headword_ar":"سُقْمٌ","root":"sqm","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saqamN","text_ar":"سَقَمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"saqaAmN","text_ar":"سَقَامٌ","orth_type":"arrow"},{"kind":"text","text":"[are all inf. ns.; or the last, accord. to the Msb, is a simple subst.; and all are used as substs., signifying]"},{"kind":"italic_en","text":"A disease, disorder, distemper, malady, sickness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an illness;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":": (S, K, TA:)"},{"kind":"arabic","text_bw":"suqomN","text_ar":"سُقْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maraDN","text_ar":"مَرَضٌ"},{"kind":"text","text":"are both said to be in the body, and also (assumed tropical:)  in religion [&c., as is implied by phrases mentioned below, voce"},{"kind":"arabic","text_bw":"saqiymN","text_ar":"سَقِيمٌ"},{"kind":"text","text":"]: (Aboo-Is-hák, TA in art."},{"kind":"arabic","text_bw":"mrD","text_ar":"مرض"},{"kind":"text","text":":) pl. [of the first]"},{"kind":"arabic","text_bw":"A^asoqaAmN","text_ar":"اَسْقَامٌ"},{"kind":"text","text":". (TA.) ↓"},{"kind":"arabic","text_bw":"saqamu","text_ar":"سَقَمُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Aljufuwni","text_ar":"الجُفُونِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Languidness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"slowness in motion, of the eyelids."},{"kind":"text","text":"(Har p. 113.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n20125","headword_ar":"سَقَمٌ","roo