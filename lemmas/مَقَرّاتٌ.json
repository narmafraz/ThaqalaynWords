{"lemma":"مَقَرّاتٌ","slug":"مَقَرّاتٌ","root":"ق.ر.ر","root_slug":"ق-ر-ر","root_link":"/words/roots/ق-ر-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n38793","n38794","n38795","n35362","n35363"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D9%82%D9%8E%D8%B1%D9%91%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"abode, dwelling, sojourn"},{"pos":"noun","gloss":"firm stand or seat"},{"pos":"noun","gloss":"chair"},{"pos":"adj","gloss":"confessing, acknowledging"},{"pos":"verb","gloss":"to strike with a stick","tags":["obsolete"]},{"pos":"verb","gloss":"to marinate, to confect","tags":["obsolete"],"examples":[{"text":"الرُبَيْثَاء وَالصَِحْنَاء والصِير والسُمَيْكَات تعمل من السمك الصغار والملح والسَمَك المَمْقُور المالح الذي ينقع في الخل نحوِه.","english":"Rubayṯaʾ and ṣiḥnāʾ and ṣīr and sumaykāt are made from small fish and salt and marinated salty fish that has staled in vinegar and the like."}]},{"pos":"verb","gloss":"to be acid or acrid or bitter","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of مَقَرَ (maqara) (form I)","tags":["form-of","noun-from-verb","obsolete"]},{"pos":"noun","gloss":"anything acrid or bitter","tags":["obsolete"]},{"pos":"noun","gloss":"aloe","tags":["obsolete"]},{"pos":"noun","gloss":"poison","tags":["obsolete"]}]},"etymology":{"source":"wiktextract","text":"Noun of place from قَرَّ (qarra, “to abide”).\n\nDerived from the active participle of the verb أَقَرَّ (ʔaqarra, “to confess”)."},"ipa":["/ma.qarr/","/mu.qirr/","/ma.qa.ra/","/ma.qi.ra/","/maqr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38793","headword_ar":"مَقِرَ","root":"mqr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"maqarN","text_ar":"مَقَرٌ"},{"kind":"text","text":", (S, A, Msb, K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bitter;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Amqr","text_ar":"امقر","orth_type":"arrow"},{"kind":"text","text":", (ISk, IKtt, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_imoqaArN","text_ar":"اـِمْقَارٌ"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"sour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acid:"},{"kind":"text","text":"(K:) and ↓"},{"kind":"arabic","text_bw":"Amqr","text_ar":"امقر","orth_type":"arrow"},{"kind":"text","text":", said of milk, (AZ, A, K,)"},{"kind":"italic_en","text":"it became almost bitter, by reason of its quality of biting the tongue:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"lost its"},{"kind":"text","text":"["},{"kind":"italic_en","text":"proper"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"flavour"},{"kind":"text","text":"(AZ, K)"},{"kind":"italic_en","text":"by becoming intensely sour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acid."},{"kind":"text","text":"(AZ, TA.)       -A2-"},{"kind":"arabic","text_bw":"maqara Eunuqaha","text_ar":"مَقَرَ عُنُقَهَ"},{"kind":"text","text":", (ISk, S, A, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maqorN","text_ar":"مَقْرٌ"},{"kind":"text","text":", (ISk, S,)"},{"kind":"italic_en","text":"He bruised his neck:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"beat it with a staff"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick, so as to break the bone in pieces, leaving the skin whole."},{"kind":"text","text":"(A, K.) ―         -b2-  And hence, (A,)"},{"kind":"arabic","text_bw":"maqara Als~amakapa AlmaAliHapa","text_ar":"مَقَرَ السَّمَكَةَ المَالِحَةَ"},{"kind":"italic_en","text":"He macerated the salt fish in vinegar;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"Amqr","text_ar":"امقر","orth_type":"arrow"},{"kind":"text","text":". (K.) And in like manner you say of anything that you macerate. (TA.)"}],"source_refs":["S","Msb","A","K","ISk","IKtt","AZ"]},{"entry_id":"n38794","headword_ar":"مَقْرٌ","root":"mqr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maqirN","text_ar":"مَقِرٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]},{"entry_id":"n38795","headword_ar":"مَقِرٌ","root":"mqr","body":[{"kind":"italic_en","text":"Bitter;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"maqorN","text_ar":"مَقْرٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"mumoqirN","text_ar":"مُمْقِرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"yamoquwrN","text_ar":"يَمْقُورٌ","orth_type":"arrow"},{"kind":"text","text":": (Sgh, K:) or"},{"kind":"italic_en","text":"sour; acid;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mumoqirN","text_ar":"مُمْقِرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) which last also signifies"},{"kind":"italic_en","text":"intensely sour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acid;"},{"kind":"text","text":"(AZ, Aboo-Málik, S; *) applied to milk: (the same, and K:) or"},{"kind":"italic_en","text":"sour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acid,"},{"kind":"text","text":"milk. (Msb.) ―         -b2-"},{"kind":"italic_en","text":"Aloes;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SabirN","text_ar":"صَبِرٌ"},{"kind":"text","text":": (As, S, A, Msb, K:) as also ↓"},{"kind":"arabic","text_bw":"maqorN","text_ar":"مَقْرٌ","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"a certain thing resembling it:"},{"kind":"text","text":"(IKt, Msb, K:) or"},{"kind":"italic_en","text":"poison:"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"maqorN","text_ar":"مَقْرٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) which is said by some to be a form used by poetic license: (TA:) or, accord. to AA,"},{"kind":"italic_en","text":"a certain bitter kind of tree:"},{"kind":"text","text":"and accord. to AHn,"},{"kind":"italic_en","text":"a certain plant, which grows in leaves without branches."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"SaqirN","text_ar":"صَقِرٌ"},{"kind":"text","text":".]"}],"source_refs":["TA","S","A","K","Sgh","As","Msb","IKt"]},{"entry_id":"n35362","headword_ar":"مَقَرٌّ","root":"qr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaraArN","text_ar":"قَرَارٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]},{"entry_id":"n35363","headword_ar":"مُقِرٌّ","root":"qr","body":[{"kind":"text","text":"A she-camel"},{"kind":"italic_en","text":"whose pregnancy is established:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"that has condensed and retained the seed of the stallion in her womb,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"and not ejected it:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"that has conceived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become pregnant."},{"kind":"text","text":"(IAar.) See 4."}],"source_refs":["TA","M","K"]}]},"classical_definitions":null}