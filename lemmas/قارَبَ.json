us": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نُقارِب", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 12, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["noun", "verb"], "has_etymology": true, "sense_count": 4}, "lanes": {"found": true, "entry_ids": ["n35413"], "search_url": "https://lanelexicon.com/?s=%D9%82%D8%A7%D8%B1%D9%8E%D8%A8%D9%8E"}}, "translations": {"en": "to approach", "fa": "نزدیک شدن", "ur": "قریب ہونا", "tr": "yaklaşmak", "id": "mendekati", "bn": "নিকটবর্তী হওয়া", "es": "acercarse", "fr": "s'approcher", "de": "sich nähern", "ru": "приближаться", "zh": "接近"}, "definition": {"source": "wiktextract", "senses": [{"pos": "noun", "gloss": "small boat, skiff, dinghy"}, {"pos": "verb", "gloss": "to be one coming near or close to something, to be an approacher, to be almost at a point", "examples": [{"text": "يدفع ثمن ما يقارب ١٥٠ رحلة في طائرات خاصة."}]}, {"pos": "verb", "gloss": "to try to get closer, to attempt or strive to make something nearer, to attempt to reach or gain access"}, {"pos": "verb", "gloss": "to raise the legs of a woman for the purpose of coitus"}]}, "etymology": {"source": "wiktextract", "text": "Derived from the active participle of قَرِبَ (qariba, “to approach, to come near or be near, to be connecting or adjacent”). Originally referring to a small boat used by a seaman as a convenient means to approach shore rather than bringing a larger vessel to port.\nAlternatively a loan from Latin carabus or Ancient Greek κάραβος (kárabos) – also found as Classical Syriac ܩܪܒܝܢ – with an uncertain etymology related to beetles and crabs, perhaps originally Semitic; for more see caravel, عَقْرَب (ʕaqrab) and its cognates."}, "ipa": ["/qaː.rib/", "/ʔaː.rib/", "/ɡaː.rib/", "[ɡaː.rɪb]", "[qaː.rɪb]", "/qaː.ra.ba/", "/ɡaː.rab/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n35413", "headword_ar": "قَارِبٌ", "root": "qrb", "body": [{"kind": "text", "text": "[part. n. of"}, {"kind": "arabic", "text_bw": "qaraba", "text_ar": "قَرَبَ"}, {"kind": "text", "text": "said of a man journeying to water: and accord. to As and A'Obeyd, part. n. of"}, {"kind": "arabic", "text_bw": "A^aqoraba", "text_ar": "اَقْرَبَ"}, {"kind": "text", "text": "used in a similar sense; as such anomalous]. One"}, {"kind": "italic_en", "text": "seeking,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "seeking to attain,"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "journeying to,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "water:"}, {"kind": "text", "text": "so says Az, without specifying any time: (TA:) or, accord. to Kh, (S, O, TA,) one"}, {"kind": "italic_en", "text": "doing so by night;"}, {"kind": "text", "text": "(S, O, K, TA;) not applied to one doing so by day. (S, O, TA.) And its pl."}, {"kind": "arabic", "text_bw": "qawaAribuwna", "text_ar": "قَوَارِبُونَ"}, {"kind": "text", "text": "signifies Persons"}, {"kind": "italic_en", "text": "whose camels are performing a journey such as is termed"}, {"kind": "arabic", "text_bw": "qarabN", "text_ar": "قَرَبٌ"}, {"kind": "text", "text": ": (As, S, O:) see 4, latter half. The epithet applied to camels in this case is"}, {"kind": "arabic", "text_bw": "qawaAribu", "text_ar": "قَوَارِبُ"}, {"kind": "text", "text": "; (S, O;) [of which see another explanation voce"}, {"kind": "arabic", "text_bw": "TalaqN", "text_ar": "طَلَقٌ"}, {"kind": "text", "text": ";] and this epithet is also used in relation to birds. (IAar, TA.)"}, {"kind": "arabic", "text_bw": "maA liY", "text_ar": "مَا لِى"}, {"kind": "arabic", "text_bw": "qaAribN walaA haAribN", "text_ar": "قَارِبٌ وَلَا هَارِبٌ"}, {"kind": "text", "text": "occurs in a trad., meaning"}, {"kind": "italic_en", "text": "I have not any that goes to water nor any that returns from it."}, {"kind": "text", "text": "(L, TA. [See also"}, {"kind": "arabic", "text_bw": "haAribN", "text_ar": "هَارِبٌ"}, {"kind": "text", "text": ".]) And"}, {"kind": "arabic", "text_bw": "HimaArN qaAribN", "text_ar": "حِمَارٌ قَارِبٌ"}, {"kind": "text", "text": "means"}, {"kind": "italic_en", "text": "An ass hastening on in the night of arriving at the water."}, {"kind": "text", "text": "(Lth, TA.)       -A2-  Also"}, {"kind": "italic_en", "text": "A small"}, {"kind": "arabic", "text_bw": "safiynap", "text_ar": "سَفِينَة"}, {"kind": "text", "text": "; (A, K;) i. e. (A,) ["}, {"kind": "italic_en", "text": "a skiff;"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "a ship's boat, used by the seamen as a convenient means af accomplishing their needful affairs;"}, {"kind": "text", "text": "(S, A, O;) also called"}, {"kind": "arabic", "text_bw": "sunobuwkN", "text_ar": "سُنْبُوكٌ"}, {"kind": "text", "text": "[or"}, {"kind": "arabic", "text_bw": "sunobuwqN", "text_ar": "سُنْبُوقٌ"}, {"kind": "text", "text": "]: (A:) pl."}, {"kind": "arabic", "text_bw": "qawaAribu", "text_ar": "قَوَارِبُ"}, {"kind": "text", "text": ": and"}, {"kind": "arabic", "text_bw": "A^aqorubN", "text_ar": "اَقْرُبٌ"}, {"kind": "text", "text": "occurs in a trad., and is said to be also a pl. of"}, {"kind": "arabic", "text_bw": "qaAribN", "text_ar": "قَارِبٌ"}, {"kind": "text", "text": "; but IAth says that this is not known as a pl."}, {"kind": "arabic", "text_bw": "qArb", "text_ar": "قارب"}, {"kind": "text", "text": ", unless as anomalous; and it is said that"}, {"kind": "arabic", "text_bw": "A^aforubu Als~afiynapi", "text_ar": "اَفْرُبُ السَّفِينَةِ"}, {"kind": "text", "text": "means"}, {"kind": "italic_en", "text": "the nearest parts of the ship;"}, {"kind": "text", "text": "i. e., the parts near [or next] to the land. (TA.)"}], "source_refs": ["TA", "S", "O", "As", "A"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}