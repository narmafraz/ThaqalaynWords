n":"m","num":"p"},{"role":"present_2mp","form":"تُغادِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُغادِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُغادِر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُغادِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُغادِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُغادِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُغادِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُغادِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُغادِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُغادِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُغادِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"غادَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"غادَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُغادِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُغادِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31508"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D8%A7%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to leave","examples":[{"text":"وَيَوْمَ نُسَيِّرُ الْجِبَالَ وَتَرَى الْأَرْضَ بَارِزَةً وَحَشَرْنَاهُمْ فَلَمْ نُغَادِرْ مِنْهُمْ أَحَدًا / وَعُرِضُوا عَلَىٰ رَبِّكَ صَفًّا لَّقَدْ جِئْتُمُونَا كَمَا خَلَقْنَاكُمْ أَوَّلَ مَرَّةٍ ۚ بَلْ زَعَمْتُمْ أَلَّن نَّجْعَلَ لَكُم مَّوْعِدًا / وَوُضِعَ الْكِتَابُ فَتَرَى الْمُجْرِمِينَ مُشْفِقِينَ مِمَّا فِيهِ وَيَقُولُونَ يَا وَيْلَتَنَا مَالِ هَٰذَا الْكِتَابِ لَا يُغَادِرُ صَغِيرَةً وَلَا كَبِيرَةً إِلَّا أَحْصَاهَا ۚ وَوَجَدُوا مَا عَمِلُوا حَاضِرًا ۗ وَلَا يَظْلِمُ رَبُّكَ أَحَدًا","english":"˹Beware of˺ the Day We will blow the mountains away, and you will see the earth laid bare. And We will gather all ˹humankind˺, leaving none behind. They will be presented before your Lord in rows, ˹and the deniers will be told,˺ “You have surely returned to Us ˹all alone˺ as We created you the first time, although you ˹always˺ claimed that We would never appoint a time for your return.” And the record ˹of deeds˺ will be laid ˹open˺, and you will see the wicked in fear of what is ˹written˺ in it. They will cry, “Woe to us! What kind of record is this that does not leave any sin, small or large, unlisted?” They will find whatever they did present ˹before them˺. And your Lord will never wrong anyone."},{"text":".رئيس أركان الجيش الإسرائيلي غادي آيزنكوت سيغادر الليلة إلى العاصمة الأميركية واشنطن للمشاركة في اجتماع","english":"The Chief of Staff of the Israeli army Gadi Eizenkot is going to use the night to travel to the American capital Washington for participation in a meeting."}]}]},"etymology":null,"ipa":["/ɣaː.da.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31508","headword_ar":"غَادِرٌ","root":"gdr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gudarN","text_ar":"غُدَرٌ","orth_type":"arrow"},{"kind":"text","text":"[respecting which see below] (S, K) and ↓"},{"kind":"arabic","text_bw":"gaduwrN","text_ar":"غَدُورٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gad~aArN","text_ar":"غَدَّارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gid~iyrN","text_ar":"غِدِّيرٌ","orth_type":"arrow"},{"kind":"text","text":"(K) are epithets applied to a man [and signifying, the first,"},{"kind":"italic_en","text":"Perfidious, unfaithful, faithless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"treacherous;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acting perfidiously,"},{"kind":"text","text":"&c.; and the rest,"},{"kind":"italic_en","text":"very perfidious,"},{"kind":"text","text":"&c.]: (S, K:) and ↓"},{"kind":"arabic","text_bw":"gaduwrN","text_ar":"غَدُورٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gad~aArN","text_ar":"غَدَّارٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"gad~aArapN","text_ar":"غَدَّارَةٌ","orth_type":"arrow"},{"kind":"text","text":"are epithets applied to a woman [and signifying as above]: (K:) but ↓"},{"kind":"arabic","text_bw":"gudar","text_ar":"غُدَر","orth_type":"arrow"},{"kind":"text","text":"is mostly used in calling to a man and reviling him: (S:) you say to a man,"},{"kind":"arabic","text_bw":"yaA gu*aru","text_ar":"يَا غُذَرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O very perfidious"},{"kind":"text","text":"man]; (S, K;) and in like manner, ↓"},{"kind":"arabic","text_bw":"yaA magodaru","text_ar":"يَا مَغْدَرُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yA magodiru","text_ar":"يا مَغْدِرُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yaA A@bona magodarK","text_ar":"يَا ا@بْنَ مَغْدَرٍ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"yA Abn magodirK","text_ar":"يا ابن مَغْدِرٍ","orth_type":"arrow"},{"kind":"text","text":", all determinate; (K, TA;) and to a woman, ↓"},{"kind":"arabic","text_bw":"yA gadaAri","text_ar":"يا غَدَارِ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qaTaAmi","text_ar":"قَطَامِ"},{"kind":"text","text":": (K:) [accord. to some, ↓"},{"kind":"arabic","text_bw":"gudar","text_ar":"غُدَر","orth_type":"arrow"},{"kind":"text","text":"is only used in this manner, and is therefore without tenween; for] it is said that"},{"kind":"arabic","text_bw":"rajulN gudaru","text_ar":"رَجُلٌ غُدَرُ"},{"kind":"text","text":"is not allowable, because"},{"kind":"arabic","text_bw":"gudaru","text_ar":"غُدَرُ"},{"kind":"text","text":"is determinate: but Sh says"},{"kind":"arabic","text_bw":"rajulN gudarN","text_ar":"رَجُلٌ غُدَرٌ"},{"kind":"text","text":", writing it, says Az, with tenween, contr. to what Lth says; and this is correct; a word of the measure"},{"kind":"arabic","text_bw":"fuEal","text_ar":"فُعَل"},{"kind":"text","text":"being imperfectly decl. [only] when it is a determinate subst., like"},{"kind":"arabic","text_bw":"Eumaru","text_ar":"عُمَرُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zufaru","text_ar":"زُفَرُ"},{"kind":"text","text":": and IAth says that"},{"kind":"arabic","text_bw":"gudaru","text_ar":"غُدَرُ"},{"kind":"text","text":"is altered from its original form, which is"},{"kind":"arabic","text_bw":"gaAdirN","text_ar":"غَادِرٌ"},{"kind":"text","text":", for the sake of intensiveness: (TA:) in the pl. [sense] you say"},{"kind":"arabic","text_bw":"yaAla gudara","text_ar":"يَالَ غُدَرَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"yaA lagudara","text_ar":"يَا لَغُدَرَ"},{"kind":"text","text":", [for"},{"kind":"arabic","text_bw":"yaA A=la gudara","text_ar":"يَا ا=لَ غُدَرَ"},{"kind":"text","text":", (see the letter"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":", and see"},{"kind":"arabic","text_bw":"A=lN","text_ar":"ا=لٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Awl","text_ar":"اول"},{"kind":"text","text":",)] like"},{"kind":"arabic","text_bw":"yaA lafujara","text_ar":"يَا لَفُجَرَ"},{"kind":"text","text":". (TA.) It is said in a trad., ↓"},{"kind":"arabic","text_bw":"yaA gudaru","text_ar":"يَا غُدَرُ","orth_type":"arrow"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^alasotu A^asoEaY fiY gadoratika","text_ar":"اَلَسْتُ اَسْعَى فِى غَدْرَتِكَ","orth_type":"arrow"},{"kind":"text","text":"[app. meaning,"},{"kind":"italic_en","text":"O thou very perfidious: am I not striving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"labouring, in respect of thine act of perfidy, to rectify it?"},{"kind":"text","text":"]. (S: but in one copy,"},{"kind":"arabic","text_bw":"gudoratika","text_ar":"غُدْرَتِكَ"},{"kind":"text","text":".) And in another trad., relating to El-Hodeybiyeh,"},{"kind":"arabic","text_bw":"wahalo","text_ar":"وَهَلْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yaA gudaru","text_ar":"يَا غُدَرُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"A_il~aA biA@loA^amosi","text_ar":"اـِلَّا بِا@لْاَمْسِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"gasalota gadorataka","text_ar":"غَسَلْتَ غَدْرَتَكَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O thou very perfidious: and didst thou wash away thine act of perfidy save yesterday?"},{"kind":"text","text":"]: said by 'Orweh Ibn-Mes'ood to El-Mugheereh. (TA.) And in another trad., ↓"},{"kind":"arabic","text_bw":"Aijoliso gudaru","text_ar":"اِجْلِسْ غُدَرُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Sit thou, O very perfidious"},{"kind":"text","text":"]; for"},{"kind":"arabic","text_bw":"yaA gudaru","text_ar":"يَا غُدَرُ"},{"kind":"text","text":": said by 'Áïsheh to El-Kásim. (TA.) ―         -b2-  [Hence,] ↓"},{"kind":"arabic","text_bw":"sinuwna gad~aArapN","text_ar":"سِنُونَ غَدَّارَةٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Years in which is much rain and little herbage;"},{"kind":"text","text":"from [the inf. n.]"},{"kind":"arabic","text_bw":"Algadoru","text_ar":"الغَدْرُ"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"that excite people's eager desire for abundance of herbage, by the rain, and then fail to fulfil their promise."},{"kind":"text","text":"(TA.) ―         -b3-  [And ↓"},{"kind":"arabic","text_bw":"gadirN","text_ar":"غَدِرٌ","orth_type":"arrow"},{"kind":"text","text":"is app. syn. with"},{"kind":"arabic","text_bw":"gaAdirN","text_ar":"غَادِرٌ"},{"kind":"text","text":"; for]"},{"kind":"arabic","text_bw":"gadirapN","text_ar":"غَدِرَةٌ"},{"kind":"text","text":"occurs in a trad. applied to land ("},{"kind":"arabic","text_bw":"A^aroD","text_ar":"اَرْض"},{"kind":"text","text":"), as though meaning (assumed tropical:)"},{"kind":"italic_en","text":"Not producing herbage bountifully;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"giving growth to herbage, and then soon becoming blighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blasted;"},{"kind":"text","text":"wherefore it is likened to the"},{"kind":"arabic","text_bw":"gaAdir","text_ar":"غَادِر"},{"kind":"text","text":", who acts unfaithfully. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"gudorapN","text_ar":"غُدْرَةٌ"},{"kind":"text","text":", last sentence."}],"source_refs":["S","K","TA"]}]},"classical_definitions":null}