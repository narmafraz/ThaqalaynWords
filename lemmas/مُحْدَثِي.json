دَثُونَ"},{"kind":"italic_en","text":"The moderns;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people of later times;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"AlqudamaA='u","text_ar":"القُدَمَا=ءُ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n7331","headword_ar":"مُحْدِثٌ","root":"Hdv","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HadavN","text_ar":"حَدَثٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7332","headword_ar":"مُحَدَّثٌ","root":"Hdv","body":[{"kind":"italic_en","text":"A true,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veracious,"},{"kind":"text","text":"man: (K:) a man"},{"kind":"italic_en","text":"of true opinion:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"of true conjecture:"},{"kind":"text","text":"(A, TA:)"},{"kind":"italic_en","text":"inspired; into whose mind a thing is put, and who tells it conjecturally and with sagacity; as though he were told a thing, and said it:"},{"kind":"text","text":"occurring in a trad.: (TA:) such was 'Omar. (A, TA.)"}],"source_refs":["K","S","A","TA"]},{"entry_id":"n7333","headword_ar":"مُحَدِّثٌ","root":"Hdv","body":[{"kind":"italic_en","text":"A teller,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relater, of stories, narratives,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"traditions:"},{"kind":"text","text":"[and particularly"},{"kind":"italic_en","text":"a relater of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one skilled in, the traditions of Mohammad:"},{"kind":"text","text":"] ↓"},{"kind":"arabic","text_bw":"Hud~aAvN","text_ar":"حُدَّاثٌ","orth_type":"arrow"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"muHad~ivuwna","text_ar":"مُحَدِّثُونَ"},{"kind":"text","text":", signifying a company of men"},{"kind":"italic_en","text":"telling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating, stories"},{"kind":"text","text":"&c., is an anomalous pl., formed by assigning it to the same predicament as words of similar meaning, of which"},{"kind":"arabic","text_bw":"sum~aArN","text_ar":"سُمَّارٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"saAmirN","text_ar":"سَامِرٌ"},{"kind":"text","text":", is an ex. (L.) See also"},{"kind":"arabic","text_bw":"HidovN","text_ar":"حِدْثٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}