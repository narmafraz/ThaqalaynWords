ons":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"burden"},{"pos":"noun","gloss":"crime, sin, fault"},{"pos":"noun","gloss":"arms or armour carried on the body"}]},"etymology":null,"ipa":["/wizr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41900","headword_ar":"وَزَرَ","root":"wzr","body":[{"kind":"text","text":", (A, Mgh, K,) aor."},{"kind":"arabic","text_bw":"yaziru","text_ar":"يَزِرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wizorN","text_ar":"وِزْرٌ"},{"kind":"text","text":", with kesr, (K,)"},{"kind":"italic_en","text":"He bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried,"},{"kind":"text","text":"a heavy load, or burden. (A, Mgh, K.) It is said in the Kur, [vi. 164, &c.,]"},{"kind":"arabic","text_bw":"walaA taziru waAzirapN wizora A^uxoraY","text_ar":"وَلَا تَزِرُ وَازِرَةٌ وِزْرَ اُخْرَى"},{"kind":"italic_en","text":"Nor shall any"},{"kind":"text","text":"[soul]"},{"kind":"italic_en","text":"bearing"},{"kind":"text","text":"[a heavy burden]"},{"kind":"italic_en","text":"bear the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"heavy"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"burden of another"},{"kind":"text","text":"soul; (S;) i. e., its burden of sin: (Mgh, Msb:) meaning, that no one shall be punished for the sin of another;"},{"kind":"italic_en","text":"nor shall any sinning"},{"kind":"text","text":"soul"},{"kind":"italic_en","text":"bear the heavy burden of another"},{"kind":"text","text":"soul; every one shall be requited for his [own] deeds: (TA:) or"},{"kind":"italic_en","text":"nor shall any sinning"},{"kind":"text","text":"[soul]"},{"kind":"italic_en","text":"sin by the sin of another."},{"kind":"text","text":"(Akh, S, TA.) ―         -b2-  Hence, (Akh, S,)"},{"kind":"arabic","text_bw":"wazara","text_ar":"وَزَرَ"},{"kind":"text","text":", (Akh, S, A, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaziru","text_ar":"يَزِرُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"wazira","text_ar":"وَزِرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yawozaru","text_ar":"يَوْزَرُ"},{"kind":"text","text":"; (Akh, S, A, Msb, K;) and"},{"kind":"arabic","text_bw":"wuzira","text_ar":"وُزِرَ"},{"kind":"text","text":"(the same and A,) aor."},{"kind":"arabic","text_bw":"yuwzaru","text_ar":"يُوزَرُ"},{"kind":"text","text":"; (Akh, S, K;) inf. n."},{"kind":"arabic","text_bw":"wizorN","text_ar":"وِزْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wazorN","text_ar":"وَزْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zirapN","text_ar":"زِرَةٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"wizorapN","text_ar":"وِزْرَةٌ"},{"kind":"text","text":", accord. to Zj, as I have seen it [says IM] pointed and well written; (L;) (tropical:)"},{"kind":"italic_en","text":"He sinned:"},{"kind":"text","text":"(Akh, S, A, K:) or"},{"kind":"italic_en","text":"he bore"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a burden of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sin-"},{"kind":"text","text":"(Msb.) See also 8. ―         -b3-"},{"kind":"arabic","text_bw":"wuzira","text_ar":"وُزِرَ"},{"kind":"text","text":"also signifies (tropical:)"},{"kind":"italic_en","text":"He was charged with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accused of, a sin."},{"kind":"text","text":"(K, * TA.) ―         -b4-"},{"kind":"arabic","text_bw":"wazara liloA^amiyri","text_ar":"وَزَرَ لِلْاَمِيرِ"},{"kind":"text","text":", (A,) and"},{"kind":"arabic","text_bw":"lilos~uloTaAni","text_ar":"لِلْسُّلْطَانِ"},{"kind":"text","text":", (Msb, [this I believe to be the right reading; but in the only copy of the Msb, that I have, I find it written"},{"kind":"arabic","text_bw":"AlslTAn","text_ar":"السلطان"},{"kind":"text","text":";]) aor."},{"kind":"arabic","text_bw":"yaziru","text_ar":"يَزِرُ"},{"kind":"text","text":"; (A, Msb;) inf. n."},{"kind":"arabic","text_bw":"wazaArapN","text_ar":"وَزَارَةٌ"},{"kind":"text","text":"; (A;) and"},{"kind":"arabic","text_bw":"liloA^amiyri","text_ar":"لِلْاَمِيرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"twz~r","text_ar":"توزّر","orth_type":"arrow"},{"kind":"text","text":", (S.) or"},{"kind":"arabic","text_bw":"lalomaliki","text_ar":"لَلْمَلِكِ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"waAzrhu","text_ar":"وَازرهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"waziyr","text_ar":"وَزِير"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vicegerent"},{"kind":"text","text":"] (S, A, Msb, K)"},{"kind":"italic_en","text":"to the governor,"},{"kind":"text","text":"(S, A,) or"},{"kind":"italic_en","text":"sultán,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"king."},{"kind":"text","text":"(K.)"},{"kind":"page_break","n":2939}],"source_refs":["A","Mgh","K","Msb","TA","Akh","S"]}]}}