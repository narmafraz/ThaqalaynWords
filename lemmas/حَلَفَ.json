81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to swear"},{"pos":"verb","gloss":"to make swear, to put to oath, to swear in"},{"pos":"verb","gloss":"to adjure, to entreat earnestly"},{"pos":"noun","gloss":"oath"},{"pos":"noun","gloss":"alliance; federation, pact","examples":[{"text":"حِلْف وَارْسَو","english":"Warsaw Pact"},{"text":"حِلْفُ شِمَالِ الْأَطْلَنْطِيِّ","english":"North Atlantic Alliance (NATO)"}]},{"pos":"noun","gloss":"ally"}]},"etymology":null,"ipa":["/ħa.la.fa/","/ħal.la.fa/","/ħalf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8843","headword_ar":"حَلَفَ","root":"Hlf","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HalifN","text_ar":"حَلِفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HalofN","text_ar":"حَلْفٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"HilofN","text_ar":"حِلْفٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"maHoluwfN","text_ar":"مَحْلُوفٌ"},{"kind":"text","text":", (S, K,) like"},{"kind":"arabic","text_bw":"majoluwdN","text_ar":"مَجْلُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEoquwlN","text_ar":"مَعْقُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"maHoluwfapN","text_ar":"مَحْلُوفَةٌ"},{"kind":"text","text":"(Lth, K) [and"},{"kind":"arabic","text_bw":"maHoluwfaA='u","text_ar":"مَحْلُوفَا=ءُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"ma$oEuwraA='u","text_ar":"مَشْعُورَا=ءُ"},{"kind":"text","text":", as will be seen from what follows],"},{"kind":"italic_en","text":"He swore."},{"kind":"text","text":"(S.) You say,"},{"kind":"arabic","text_bw":"Halaba biA@ll~`hi","text_ar":"حَلَبَ بِا@للّٰهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He swore by God"},{"kind":"text","text":"]. (Msb.) [And"},{"kind":"arabic","text_bw":"Halafa A_in~hu ka*aA","text_ar":"حَلَفَ اـِنّهُ كَذَا"},{"kind":"italic_en","text":"He swore it was so."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"Halafa lahu EalaY ka*aA","text_ar":"حَلَفَ لَهُ عَلَى كَذَا"},{"kind":"italic_en","text":"He swore to him to do such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"Halafa yamiynFA","text_ar":"حَلَفَ يَمِينًا"},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"vnY","text_ar":"ثنى"},{"kind":"text","text":", &c.) and"},{"kind":"arabic","text_bw":"EalaY yamiynK","text_ar":"عَلَى يَمِينٍ"},{"kind":"text","text":"(El-Jámi' es Sagheer voce"},{"kind":"arabic","text_bw":"mano","text_ar":"مَنْ"},{"kind":"text","text":", &c.) ["},{"kind":"italic_en","text":"He swore an oath"},{"kind":"text","text":"]. And"},{"kind":"arabic","text_bw":"laA wamaHoluwfaAy^ihi laA A^afoEalu","text_ar":"لَا وَمَحْلُوفَايِهِ لَا اَفْعَلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"No, by the swearing it,"},{"kind":"text","text":"(meaning"},{"kind":"italic_en","text":"no, I swear it,"},{"kind":"text","text":")"},{"kind":"italic_en","text":"I will not do"},{"kind":"text","text":"such a thing]. (Ibn-Buzurj, K. *) And"},{"kind":"arabic","text_bw":"maHoluwfapF biA@ll~`hi","text_ar":"مَحْلُوفَةً بِا@للّٰهِ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"A^aHolifu maHoluwfapF","text_ar":"اَحْلِفُ مَحْلُوفَةً"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"I swear"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"an oath"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by God"},{"kind":"text","text":"]. (Lth, K.) Accord. to IAth, the primary signification of"},{"kind":"arabic","text_bw":"HalifN","text_ar":"حَلِفٌ"},{"kind":"text","text":"is The act of"},{"kind":"italic_en","text":"confederating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making a compact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confederacy, to aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assist;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"making an agreement:"},{"kind":"text","text":"[but this meaning is afterwards said in the TA to be tropical:] when the object of this, in the time of paganism, was to aid in sedition or the like, and in fighting, and incursions into the territories of enemies, it was forbidden by Mohammad: when the object was to aid the wronged, and for making close the ties of relationship, and the like, he confirmed it. (TA.)"}],"source_refs":["S","Msb","K","Lth"]}]}}