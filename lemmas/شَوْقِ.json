xt":". (K.) One says,"},{"kind":"arabic","text_bw":"bar~aHa","text_ar":"بَرَّحَ"},{"kind":"arabic","text_bw":"biY Al$~awoqu","text_ar":"بِى الشَّوْقُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Desire,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"distressed me"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"balagato","text_ar":"بَلَغَتْ"},{"kind":"arabic","text_bw":"min~iY AlA^a$owaAqu","text_ar":"مِنِّى الاَشْوَاقُ"},{"kind":"text","text":"[meaning in like manner"},{"kind":"italic_en","text":"Desires,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"distressed me"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"banaAtu Al$~awoqi","text_ar":"بَنَاتُ الشَّوْقِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The effects of"},{"kind":"arabic","text_bw":"Al$wq","text_ar":"الشوق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"desire,"},{"kind":"text","text":"&c.]. (Ham p. 539.)       -A2-  Also inf. n. of 1 [q. v.]. (Msb, TA.)"}],"source_refs":["S","O","Msb","K","IAar"]}]},"classical_definitions":null}