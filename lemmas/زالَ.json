t_3mp","form":"يَزُولُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَزَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَزُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"زِلْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زِلْتُ","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"زُلْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زُلْتُ","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَزال","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَزال","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَزُول","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَزُول","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":871,"cross_references":{"qac":{"found":true,"lemma_key":"زالَ","root":"زول","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n17966","n18419"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D8%A7%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to go away, withdraw"},{"pos":"verb","gloss":"to leave, abandon"},{"pos":"verb","gloss":"to disappear"},{"pos":"verb","gloss":"to die down","examples":[{"text":"عَلَى نِطَاقٍ وَقْتِيٍّ فَلَكِيٍّ، النُّجُومُ مِثْلُ شَمْسِنَا سَتَزُولُ فِي وَقْتٍ قَصِيرٍ.","english":"On an astronomical timescale, stars like our sun will die down in a short time."}]},{"pos":"verb","gloss":"to not still do, to cease doing","tags":["copulative"],"examples":[{"text":"أَلَا يَزَالُ أَذْكَى شَابٍّ فِي كُلِّ دِمَشْقَ؟","english":"Is he still the smartest guy in the whole of Damascus?"},{"text":"وَلَا يَزَالُونَ يُقَاتِلُونَكُمْ حَتَّى يَرُدُّوكُمْ عَنْ دِينِكُمْ إِنِ ٱسْتَطَاعُوا","english":"And they still will fight you until they turn you back from your religion if they are able."}]},{"pos":"verb","gloss":"to (cause to) move away","tags":["obsolete","transitive"]},{"pos":"verb","gloss":"to separate","tags":["obsolete","transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17966","headword_ar":"زَالٌّ","root":"zl","body":[{"kind":"italic_en","text":"Deficient in weight;"},{"kind":"text","text":"applied to a dirhem, (S, Msb, K, TA,) and to a deenár: (TA:) pl."},{"kind":"arabic","text_bw":"zawaAl~N","text_ar":"زَوَالٌّ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"zul~alN","text_ar":"زُلَّلٌ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"danaAniyrika zil~alN waminohaA wuz~anN","text_ar":"دَنَانِيرِكَ زِلَّلٌ وَمِنْهَا وُزَّنٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Of thy deenárs are such as are deficient in weight, and of them are such as are of full weight"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n18419","headword_ar":"زَالَ","root":"zwl","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazuwlu","text_ar":"يَزُولُ"},{"kind":"text","text":", (K,) and, accord. to the K, also"},{"kind":"arabic","text_bw":"yazaAlu","text_ar":"يَزَالُ"},{"kind":"text","text":", which is rare, on the authority of Aboo- 'Alee, but this is the aor. of"},{"kind":"arabic","text_bw":"zaAla","text_ar":"زَالَ"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"xaAfa","text_ar":"خَافَ"},{"kind":"text","text":", [which has a different meaning from the former verb,] (MF, TA,) inf. n."},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"zuwuwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":"(Lh, K) [which in all its senses except one mentioned below may app. be pronounced also"},{"kind":"arabic","text_bw":"zuw^uwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Huw^uwlN","text_ar":"حُوُولٌ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"HuwuwlN","text_ar":"حُوُولٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"HawolN","text_ar":"حَوْلٌ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"zawiylN","text_ar":"زَوِيلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawolN","text_ar":"زَوْلٌ"},{"kind":"text","text":", (K, TA,) the last thus, with fet-h, accord. to a rule of the K, but in some of the copies"},{"kind":"arabic","text_bw":"zuwlN","text_ar":"زُولٌ"},{"kind":"text","text":", with damm, (TA,) and"},{"kind":"arabic","text_bw":"zawalaAnN","text_ar":"زَوَلَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It went away; passed away; departed; removed; shifted;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, remote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"absent; ceased to be"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exist,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to nought;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Aizowal~a","text_ar":"اِزْوَلَّ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AizowilaAlN","text_ar":"اِزْوِلَالٌ"},{"kind":"text","text":"; (K;) or, accord. to the O, ↓"},{"kind":"arabic","text_bw":"AizowaA^al~a","text_ar":"اِزْوَاَلَّ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"AiTomaA^an~a","text_ar":"اِطْمَاَنَّ"},{"kind":"text","text":". (TA.) [See also 7.] Hence,"},{"kind":"page_break","n":1271},{"kind":"arabic","text_bw":"Ald~unoyaA wa$iykapu Alz~awaAli","text_ar":"الدُّنْيَا وَشِيكَةُ الزَّوَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The world,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worldly enjoyment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, is quick in passing away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coming to nought"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"zAl zawaAluhu","text_ar":"زال زَوَالُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"zawaAluhaA","text_ar":"زَوَالُهَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":": and for the former see also"},{"kind":"arabic","text_bw":"zawiylN","text_ar":"زَوِيلٌ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"zAl zawiyluhu","text_ar":"زال زَوِيلُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"zawiyluhaA","text_ar":"زَوِيلُهَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zawiylN","text_ar":"زَوِيلٌ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"zAl Al$~aYo'u","text_ar":"زال الشَّىْءُ"},{"kind":"arabic","text_bw":"Eano makaAnihi","text_ar":"عَنْ مَكَانِهِ"},{"kind":"text","text":", (S, TA,) or"},{"kind":"arabic","text_bw":"mawoDiEihi","text_ar":"مَوْضِعِهِ"},{"kind":"text","text":", (Msb,) aor."},{"kind":"arabic","text_bw":"yazuwlu","text_ar":"يَزُولُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"(S, Msb, TA) &c., as above, (TA,)"},{"kind":"italic_en","text":"The thing removed, went away,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from its place; it left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted, its place."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"zulotu Eano makaAniY","text_ar":"زُلْتُ عَنْ مَكَانِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zuwuwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I went away,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from my place."},{"kind":"text","text":"] (K.) [And"},{"kind":"arabic","text_bw":"zAl Eanohu","text_ar":"زال عَنْهُ"},{"kind":"text","text":", said of any affection of the mind or body,"},{"kind":"italic_en","text":"It went away, passed away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased, from him; it left him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted him."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"zaAluwA Eano makaAnihimo","text_ar":"زَالُوا عَنْ مَكَانِهِمْ"},{"kind":"italic_en","text":"They turned away from their place;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went back, and fled, from it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"zAl Eani Alr~aA^oYi","text_ar":"زال عَنِ الرَّاْىِ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazuwlu","text_ar":"يَزُولُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zuwuwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swerved, from the opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentiment."},{"kind":"text","text":"] (Lh, TA.) And"},{"kind":"arabic","text_bw":"zAl","text_ar":"زال"},{"kind":"text","text":"alone, aor."},{"kind":"arabic","text_bw":"yazuwlu","text_ar":"يَزُولُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, quitted his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, place."},{"kind":"text","text":"(AHeyth, TA.) And"},{"kind":"italic_en","text":"He removed from one town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country, to another."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"zAlt","text_ar":"زالت"},{"kind":"arabic","text_bw":"Alxayolu birukobaAnihaA","text_ar":"الخَيْلُ بِرُكْبَانِهَا"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"ziyaAlN","text_ar":"زِيَالٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The horses removed from their place with their riders."},{"kind":"text","text":"(K, TA. [Said in the TA to be tropical; but I see not why.]) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"zAlt Al$~amosu","text_ar":"زالت الشَّمْسُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zuwuwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (K,) as Th says, (TA,) and"},{"kind":"arabic","text_bw":"ziyaAlN","text_ar":"زِيَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawalaAnN","text_ar":"زَوَلَانٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The sun declined from the meridian."},{"kind":"text","text":"(K, TA.) [And sometimes it signifies (assumed tropical:)"},{"kind":"italic_en","text":"The sun set:"},{"kind":"text","text":"see 1 in art."},{"kind":"arabic","text_bw":"dlk","text_ar":"دلك"},{"kind":"text","text":".] ―         -b3-  And hence, but not with"},{"kind":"arabic","text_bw":"zuwuwlN","text_ar":"زُوُولٌ"},{"kind":"text","text":"for an inf. n. in the senses expl. in this sentence and the next following it, (TA,)"},{"kind":"arabic","text_bw":"zAl Aln~ahaAru","text_ar":"زال النَّهَارُ"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"(TA) [and app."},{"kind":"arabic","text_bw":"ziyaAlN","text_ar":"زِيَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawalaAnN","text_ar":"زَوَلَانٌ"},{"kind":"text","text":"], (tropical:)  (tropical:)"},{"kind":"italic_en","text":"The day became advanced, the sun being somewhat high;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AirotafaEa","text_ar":"اِرْتَفَعَ"},{"kind":"text","text":": (K, TA:) or, as some say,"},{"kind":"italic_en","text":"went away;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"zAl AlZ~il~u","text_ar":"زال الظِّلُّ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"AlZ~il~i","text_ar":"الظِّلِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"zAl zaAy^ilu","text_ar":"زال زَايِلُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) (tropical:)  (tropical:)"},{"kind":"italic_en","text":"The sun became high, and the shade contracted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decreased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away, at midday."},{"kind":"text","text":"(K, * TA.) ―         -b4-"},{"kind":"arabic","text_bw":"zAl ZEnhm","text_ar":"زال ظعنهم"},{"kind":"text","text":", [thus in the TK (ed. of Boolák), i. e."},{"kind":"arabic","text_bw":"ZaEonuhumo","text_ar":"ظَعْنُهُمْ"},{"kind":"text","text":", thus in the K, and thus only, the verb being indicated by a preceding phrase; in the TA"},{"kind":"arabic","text_bw":"zAlt ZEnhm","text_ar":"زالت ظعنهم"},{"kind":"text","text":". which is an evident mistranscription;] inf. n."},{"kind":"arabic","text_bw":"zayoluwlapN","text_ar":"زَيْلُولَةٌ"},{"kind":"text","text":", (K,) like"},{"kind":"arabic","text_bw":"qayoluwlapN","text_ar":"قَيْلُولَةٌ"},{"kind":"text","text":"[an inf. n. of"},{"kind":"arabic","text_bw":"qaAla","text_ar":"قَالَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaqiylu","text_ar":"يَقِيلُ"},{"kind":"text","text":"; but more properly compared to"},{"kind":"arabic","text_bw":"dayomuwmapN","text_ar":"دَيْمُومَةٌ"},{"kind":"text","text":", an inf. n. of"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaduwmu","text_ar":"يَدُومُ"},{"kind":"text","text":"]; (TA;) [a phrase which may be rendered"},{"kind":"italic_en","text":"Their journeying ceased"},{"kind":"text","text":"for a while;] expl. as meaning"},{"kind":"arabic","text_bw":"Aiy^otawawoA makaAnahumo vum~a badaA lahumo","text_ar":"اِيْتَوَوْا مَكَانَهُمْ ثُمَّ بَدَا لَهُمْ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"they abode in their place: then an opinion occurred to them different from their former opinion, so that it turned them therefrom,"},{"kind":"text","text":"inducing them to remove]: (K:) in the K is added"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"; but this should be omitted: the passage is taken from the M; in which"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"refers to Lh as the authority. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"zAl","text_ar":"زال"},{"kind":"text","text":"[having for its inf. n., app.,"},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawiylN","text_ar":"زَوِيلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawolN","text_ar":"زَوْلٌ"},{"kind":"text","text":"(see the first of these below)] signifies also"},{"kind":"italic_en","text":"It moved;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of motion, commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taHar~aka","text_ar":"تَحَرَّكَ"},{"kind":"text","text":": so in the saying,"},{"kind":"arabic","text_bw":"raA^ayotu $abaHFA vum~a zaAla","text_ar":"رَاَيْتُ شَبَحًا ثُمَّ زَالَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw a bodily form"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figure: then it moved,"},{"kind":"text","text":"&c.]. (TA.) And one says,"},{"kind":"arabic","text_bw":"huwa yazuwlu fiYAln~aAsi","text_ar":"هُوَ يَزُولُ فِىالنَّاسِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He moves much among men,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the people, and does not remain still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"zaAlato lahu","text_ar":"زَالَتْ لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"zaAy^ilapN","text_ar":"زَايِلَةٌ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"$axaSa lahu $axoSN","text_ar":"شَخَصَ لَهُ شَخْصٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A figure seen from a distance rose to his view"},{"kind":"text","text":"]. (TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"zAl bihi Als~araAbu","text_ar":"زال بِهِ السَّرَابُ"},{"kind":"italic_en","text":"The mirage raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"rafaEa","text_ar":"رَفَعَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and made apparent, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"maA zaAla yafoEalu ka*aA","text_ar":"مَا زَالَ يَفْعَلُ كَذَا"},{"kind":"text","text":"&c.: see in art."},{"kind":"arabic","text_bw":"zyl","text_ar":"زيل"},{"kind":"text","text":".       -A3-"},{"kind":"arabic","text_bw":"zAl","text_ar":"زال"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yazuwlu","text_ar":"يَزُولُ"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"He affected acuteness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quickness of intellect, cleverness, ingeniousness, skilfulness, knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did so, not having it:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taZar~afa","text_ar":"تَظَرَّفَ"},{"kind":"text","text":". (IAar, TA.) [See also 5.]       -A4-  [As a trans. verb, it belongs to art."},{"kind":"arabic","text_bw":"zyl","text_ar":"زيل"},{"kind":"text","text":", and app. to the present art. also.] See 4. You say,"},{"kind":"arabic","text_bw":"zAl zawaAlahu","text_ar":"زال زَوَالَهُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"zAl A@ll~`hu zawalahu","text_ar":"زال ا@للّٰهُ زَوَلَهُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"zAl zawaAlahaA","text_ar":"زال زَوَالَهَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"ziyla zawiyluhu","text_ar":"زِيلَ زَوِيلُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawiyluhaA","text_ar":"زَوِيلُهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawaAluhu","text_ar":"زَوَالُهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"zawiylN","text_ar":"زَوِيلٌ"},{"kind":"text","text":": and for the first, see also"},{"kind":"arabic","text_bw":"zawaAlN","text_ar":"زَوَالٌ"},{"kind":"text","text":". ―         -b2-  And"},{"kind":"arabic","text_bw":"zAlhu","text_ar":"زالهُ"},{"kind":"italic_en","text":"He separated himself from him;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"zAylhu","text_ar":"زايلهُ"},{"kind":"text","text":". (S and K in art"},{"kind":"arabic","text_bw":"zyl","text_ar":"زيل"},{"kind":"text","text":"[to which the latter exclusively belongs.])"}],"source_refs":["K","MF","TA","Lh","S","Msb"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B2%D8%A7%D9%84/","headword_ar":"زال","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=61771#c543a2","body_html":"زال<br>عن الفارسية زال اسم أبي البطل الفارسي رستم ويطلق على الشيخ أو المسن."},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61771#af86b6","body_html":"<span class=\"title1\">زال</span><br><span>زَالَ الشيء يَزُولُ زَوَالًا: فارق طريقته جانحا عنه، وقيل: أَزَلْتُهُ، وزَوَّلْتُهُ، قال: إِنَّ اللَّهَ يُمْسِكُ السَّماواتِ وَالْأَرْضَ أَنْ تَزُولا [فاطر/ 41] ، وَلَئِنْ زالَتا [فاطر/ 41] ، لِتَزُولَ مِنْهُ الْجِبالُ [إبراهيم/ 46] ، والزَّوَالُ يقال في شيء قد كان ثابتا قبل، فإن قيل: قد قالوا: زوال الشمس، ومعلوم أن لا ثبات للشمس بوجه، قيل: إنّ ذلك قالوه لاعتقادهم في الظّهيرة أنّ لها</span><span>ثباتا في كبد السماء، ولهذا قالوا: قام قائم الظّهيرة، وسار النهار، وقيل: زَالَهُ يَزِيلُهُ زَيْلًا، قال الشاعر:</span><br><span>زَالَ زوالها</span><br><span>أي: أذهب الله حركتها، والزَّوَالُ: التّصرّف. وقيل:</span><br><span>هو نحو قولهم: أسكت الله نأمته ، وقال الشاعر:</span><br><span>إذا ما رأتنا زال منها زويلها</span><br><span>ومن قال: زال لا يتعدّى، قال: (زوالها) نصب على المصدر، وتَزَيَّلُوا</span><br><span>[الفتح/ 25] ، تفرّقوا، قال فَزَيَّلْنا بَيْنَهُمْ</span><br><span>[يونس/ 28] ، وذلك على التّكثير فيمن قال: زلت متعدّ، نحو: مزته وميّزته، وقولهم: مَا زَالَ ولا يزال خصّا بالعبارة، وأجريا مجرى كان في رفع الاسم ونصب الخبر، وأصله من الياء، لقولهم:</span><br><span>زَيَّلْتُ، ومعناه معنى ما برحت، وعلى ذلك:</span><br><span>وَلا يَزالُونَ مُخْتَلِفِينَ [هود/ 118] ، وقوله:</span><br><span>لا يَزالُ بُنْيانُهُمُ [التوبة/ 110] ، وَلا يَزالُ الَّذِينَ كَفَرُوا [الرعد/ 31] ، فَما زِلْتُمْ فِي شَكٍّ [غافر/ 34] ، ولا يصحّ أن يقال: ما زال زيد إلّا منطلقا، كما يقال: ما كان زيد إلّا منطلقا، وذلك أنّ زَالَ يقتضي معنى النّفي، إذ هو ضدّ الثّبات، وما ولا: يقتضيان النّفي، والنّفيان إذا اجتمعا اقتضيا الإثبات، فصار قولهم: ما زَالَ يجري مجرى (كان) في كونه إثباتا فكما لا يقال: كان زيد إلا منطلقا لا يقال: ما زال زيد إلا منطلقا.</span>"}]}}