2","n33373","n33374","n33375","n33376"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%8E%D9%91%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to open, to part, to separate"},{"pos":"verb","gloss":"to cleave, to split, to breach"},{"pos":"verb","gloss":"to dispel"},{"pos":"verb","gloss":"to comfort, to relieve"},{"pos":"verb","gloss":"to open, to part, to separate"},{"pos":"verb","gloss":"to cleave, to split, to breach"},{"pos":"verb","gloss":"to dispel"},{"pos":"verb","gloss":"to comfort, to relieve"},{"pos":"noun","gloss":"verbal noun of فَرَجَ (faraja) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"opening, aperture, gap, breach"},{"pos":"noun","gloss":"vulva"},{"pos":"noun","gloss":"chastity, modesty","examples":[{"text":"وَالَّذِينَ هُمْ لِفُرُوجِهِمْ حَافِظُونَ","english":"and those who are keepers of their chastities"}]},{"pos":"noun","gloss":"relief, release from suffering, freedom from grief and sorrow, repose, pleasure, comfort, relaxation"},{"pos":"noun","gloss":"happy ending"},{"pos":"name","gloss":"a male given name, Faraj"},{"pos":"noun","gloss":"plural of فُرْجَة (furja)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33367","headword_ar":"فرّج","root":"frj","body":[{"kind":"text","text":": see the preceding paragraph, first sentence: ―         -b2-  and again, in the latter half, in three places.       -A2-  Also, (O, K,) inf. n."},{"kind":"arabic","text_bw":"taforiyjN","text_ar":"تَفْرِيجٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, extremely aged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"old and weak."},{"kind":"text","text":"(O, K.) [From"},{"kind":"arabic","text_bw":"fr~j laHoyayohi","text_ar":"فرّج لَحْيَيْهِ"},{"kind":"text","text":", which see expl. voce"},{"kind":"arabic","text_bw":"fak~a","text_ar":"فَكَّ"},{"kind":"text","text":".]"}],"source_refs":["O","K"]},{"entry_id":"n33371","headword_ar":"فَرْجٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ"},{"kind":"text","text":". ―         -b2-  The"},{"kind":"italic_en","text":"space between the hind legs"},{"kind":"text","text":"of a horse or mare: (S, O, K:) so in the saying of Imra-el-Keys,"},{"kind":"quote","text":"lahaA *anabN mivolu *ayoli AlEaruwsi\n                      \n                     \n                        tasud~u bihi farojahaA mino duburN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She has a tail like the skirt of the bride, with which she fills up the space between her hind legs, from behind"},{"kind":"text","text":"]. (S, O.) And The"},{"kind":"italic_en","text":"space between the fore and hind legs"},{"kind":"text","text":"of a horse or the like. (L.) [Hence, app.,] one says,"},{"kind":"arabic","text_bw":"malaA^a farojahu","text_ar":"مَلَاَ فَرْجَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"furuwjahu","text_ar":"فُرُوجَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"sd~a furuwjahu","text_ar":"سدَّ فُرُوجَهُ"},{"kind":"text","text":"[in which phrase"},{"kind":"arabic","text_bw":"mad~a","text_ar":"مَدَّ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"sad~a","text_ar":"سَدَّ"},{"kind":"text","text":"in one place in the TA], and"},{"kind":"arabic","text_bw":"jaraY milo'a","text_ar":"جَرَى مِلْءَ"},{"kind":"arabic","text_bw":"furuwjihi","text_ar":"فُرُوجِهِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"ran swiftly."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"malaA^a furuwja farasihi","text_ar":"مَلَاَ فُرُوجَ فَرَسِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made his horse to run at the utmost rate of the pace termed"},{"kind":"arabic","text_bw":"HuDor","text_ar":"حُضْر"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"mlA^","text_ar":"ملا"},{"kind":"text","text":".) ―         -b3-  The"},{"kind":"italic_en","text":"pudendum,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pudenda;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, of the person, which it is indecent to expose;"},{"kind":"text","text":"(S, O, Msb, K, &c.;) applied to the"},{"kind":"italic_en","text":"pudenda of men"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of women"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of youths, with what is around them;"},{"kind":"text","text":"and so"},{"kind":"italic_en","text":"of horses"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"anterior pudendum"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"external portion of the organs of generation"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a man"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a woman,"},{"kind":"text","text":"by common consent of the lexicologists; and applied to"},{"kind":"italic_en","text":"this"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"posterior pudendum"},{"kind":"text","text":"[in the conventional language of the"},{"kind":"page_break","n":2360},{"kind":"text","text":"law] because both belong to the same [legal] predicament [in certain cases]; (Mgh, Msb;) or because each of them is a place of opening; (Msb;) or because between the legs: (TA:) but in common parlance it is mostly applied to the"},{"kind":"italic_en","text":"anterior pudendum:"},{"kind":"text","text":"(Msb:) or peculiarly, accord. to some, the"},{"kind":"italic_en","text":"anterior pudendum of a woman"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"vulva,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"external portion of the organs of generation of a woman:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"vagina"},{"kind":"text","text":"]: (MF, TA:) pl."},{"kind":"arabic","text_bw":"furuwjN","text_ar":"فُرُوجٌ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"fulaAnN A@bonu farojihi","text_ar":"فُلَانٌ ا@بْنُ فَرْجِهِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"Such a one is solicitous for his"},{"kind":"arabic","text_bw":"faroj","text_ar":"فَرْج"},{"kind":"text","text":". (Er-Rághib, TA in art."},{"kind":"arabic","text_bw":"bnY","text_ar":"بنى"},{"kind":"text","text":".) ―         -b4-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"fatoqN","text_ar":"فَتْقٌ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"An open, wide, place"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"furuwjN","text_ar":"فُرُوجٌ"},{"kind":"text","text":": (Msb:) which latter also signifies The"},{"kind":"italic_en","text":"sides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lateral parts, quarters,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tracts,"},{"kind":"text","text":"of a land. (TA.) And The"},{"kind":"italic_en","text":"part between the two sides,"},{"kind":"text","text":"i. e. the"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"text","text":", of a valley: and hence used in relation to a road, as meaning its"},{"kind":"italic_en","text":"entrance:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"faj~","text_ar":"فَجّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, road,"},{"kind":"text","text":"] of a mountain. (ISh, TA.) And"},{"kind":"italic_en","text":"A frontier-way of acces to a country;"},{"kind":"text","text":"and [particularly"},{"kind":"italic_en","text":"such as is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a place of fear;"},{"kind":"text","text":"(S, O, K, TA;) so called because not obstructed; (TA;) and so ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) [pl."},{"kind":"arabic","text_bw":"furajN","text_ar":"فُرَجٌ"},{"kind":"text","text":", whence] one says,"},{"kind":"arabic","text_bw":"fulaAnN tusad~u bihi Alfuraju","text_ar":"فُلَانٌ تُسَدُّ بِهِ الفُرَجُ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"AlfuruwjN","text_ar":"الفُرُوجٌ"},{"kind":"text","text":", which is the pl. of"},{"kind":"arabic","text_bw":"farojN","text_ar":"فَرْجٌ"},{"kind":"text","text":", (TA,) meaning ["},{"kind":"italic_en","text":"Such a one, by him are obstructed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the frontier-ways of access"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the enemy's country"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","O","K","TA","Msb","MF","A"]},{"entry_id":"n33372","headword_ar":"فُرْجٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"furujN","text_ar":"فُرُجٌ"},{"kind":"text","text":"; the latter in two places."}],"source_refs":[]},{"entry_id":"n33373","headword_ar":"فِرْجٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"furujN","text_ar":"فُرُجٌ"},{"kind":"text","text":"; the latter in two places."}],"source_refs":[]},{"entry_id":"n33374","headword_ar":"فَرَجٌ","root":"frj","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"farija","text_ar":"فَرِجَ"},{"kind":"text","text":"[q. v.]. (S, TA.) ―         -b2-  And [app. as such also, or] as a simple subst., The"},{"kind":"italic_en","text":"having the pudendum"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Alfaroj","text_ar":"الفَرْج"},{"kind":"text","text":")"},{"kind":"italic_en","text":"constantly uncovered,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"when sitting."},{"kind":"text","text":"(TA.) ―         -b3-  Also a subst. [or quasi-inf. n.] from"},{"kind":"arabic","text_bw":"faraja Algam~a","text_ar":"فَرَجَ الغَمَّ"},{"kind":"text","text":"; (Msb;) [as such signifying] The"},{"kind":"italic_en","text":"removal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clearing away, of grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freedom from grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow:"},{"kind":"text","text":"(S, * O, * KL:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"raAHapN","text_ar":"رَاحَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"rest, repose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ease;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cessation of trouble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconvenience, and of toil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"freedom therefrom"},{"kind":"text","text":"]: (MA:) and ↓"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"accord. to ISk, and ↓"},{"kind":"arabic","text_bw":"firojapN","text_ar":"فِرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":": also accord. to Az, signify the same as"},{"kind":"arabic","text_bw":"farajN","text_ar":"فَرَجٌ"},{"kind":"text","text":": (Msb:) one says,"},{"kind":"arabic","text_bw":"maA lih`*aA Algam~i mino","text_ar":"مَا لِهٰذَا الغَمِّ مِنْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"farojapK","text_ar":"فَرْجَةٍ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"furojapK","text_ar":"فُرْجَةٍ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"firojapK","text_ar":"فِرْجَةٍ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is not for this grief any removal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clearing away"},{"kind":"text","text":"]: (T, TA:) and ↓"},{"kind":"arabic","text_bw":"likul~i gam~i furojapN","text_ar":"لِكُلِّ غَمِّ فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"ka$ofapN","text_ar":"كَشْفَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"For every grief there is a removal, clearing away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispel-ling"},{"kind":"text","text":"]: (A:) or ↓"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", of which"},{"kind":"arabic","text_bw":"furuwjN","text_ar":"فُرُوجٌ"},{"kind":"text","text":"may be a pl., (see 7, in two places,) signifies"},{"kind":"italic_en","text":"rest from grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mourning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from disease:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"freedom from difficulty, distress,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straitness;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"freedom from anxiety;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"firojapN","text_ar":"فِرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":": (O, K:) or ↓"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", with fet-h, is an inf. n. [app. of unity]; and ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", with damm, is a simple subst.: (IAar, Msb:) or ↓"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"relates to an affair or event; and ↓"},{"kind":"arabic","text_bw":"furojapN","text_ar":"فُرْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", [which see expl. below,] to a wall, and a door; but the two [primary] significations are nearly the same: the authority for the three [syn.] forms of the word is taken by the author of the K from the statement in the T, cited above, that one says,"},{"kind":"arabic","text_bw":"maA lih`*aA Algam~i mino farojapK","text_ar":"مَا لِهٰذَا الغَمِّ مِنْ فَرْجَةٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"furjapK","text_ar":"فُرجَةٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"firojapK","text_ar":"فِرْجَةٍ"},{"kind":"text","text":". (TA.) ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"A^um~u Alfaraji","text_ar":"اُمُّ الفَرَجِ"},{"kind":"text","text":"is a name of"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"juw*aAbap","text_ar":"جُوذَابَة"},{"kind":"text","text":"[n. un. of"},{"kind":"arabic","text_bw":"juw*aAbN","text_ar":"جُوذَابٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"j*b","text_ar":"جذب"},{"kind":"text","text":"]. (Har p. 227.)"}],"source_refs":["K","TA","MA","Msb","T","A","O","IAar"]},{"entry_id":"n33375","headword_ar":"فَرِجٌ","root":"frj","body":[{"kind":"text","text":"(S, O, TA) and ↓"},{"kind":"arabic","text_bw":"A^aforaju","text_ar":"اَفْرَجُ","orth_type":"arrow"},{"kind":"text","text":"(K, TA) A man"},{"kind":"italic_en","text":"whose pudendum"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"faroj","text_ar":"فَرْج"},{"kind":"text","text":")"},{"kind":"italic_en","text":"is constantly uncovered"},{"kind":"text","text":"(S, O, K, TA)"},{"kind":"italic_en","text":"when he sits."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"makaAnN farijN","text_ar":"مَكَانٌ فَرِجٌ"},{"kind":"italic_en","text":"A place in which is"},{"kind":"arabic","text_bw":"tafar~uj","text_ar":"تَفَرُّج"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"diversion, amusement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheering pastime; such a place as is termed in Pers."},{"kind":"arabic","text_bw":"tafar~uj GaAho","text_ar":"تَفَرُّج گَاهْ"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","O","TA","K"]},{"entry_id":"n33376","headword_ar":"فُرُجٌ","root":"frj","body":[{"kind":"text","text":"(S, O, K) and ↓"},{"kind":"arabic","text_bw":"firojN","text_ar":"فِرْجٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr, (O,) or ↓"},{"kind":"arabic","text_bw":"furojN","text_ar":"فُرْجٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"faArijN","text_ar":"فَارِجٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fariyjN","text_ar":"فَرِيجٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, K,) [like"},{"kind":"arabic","text_bw":"faruwjN","text_ar":"فَرُوجٌ"},{"kind":"text","text":"(see 7) and"},{"kind":"arabic","text_bw":"faj~aA='u","text_ar":"فَجَّا=ءُ"},{"kind":"text","text":",] A bow"},{"kind":"italic_en","text":"wide apart from the string;"},{"kind":"text","text":"(S, O, K;) or"},{"kind":"italic_en","text":"of which the string is distant from its"},{"kind":"arabic","text_bw":"kabid","text_ar":"كَبِد"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b2-  And the first, A woman"},{"kind":"italic_en","text":"wearing a single garment;"},{"kind":"text","text":"(O, L, K;) of the dial. of El-Yemen; (O, L;) like"},{"kind":"arabic","text_bw":"fuDulN","text_ar":"فُضُلٌ"},{"kind":"text","text":"in the dial. of Nejd; (L;) as also ↓"},{"kind":"arabic","text_bw":"furojN","text_ar":"فُرْجٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b3-  And, as also ↓"},{"kind":"arabic","text_bw":"firojN","text_ar":"فِرْجٌ","orth_type":"arrow"},{"kind":"text","text":", One"},{"kind":"italic_en","text":"who will not conceal a secret:"},{"kind":"text","text":"(O, K:) and ↓"},{"kind":"arabic","text_bw":"furajapN","text_ar":"فُرَجَةٌ","orth_type":"arrow"},{"kind":"text","text":"a man"},{"kind":"italic_en","text":"wont to reveal his secrets."},{"kind":"text","text":"(Ham p. 49.)"}],"source_refs":["S","O","K"]}]}}