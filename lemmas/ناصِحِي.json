{"lemma":"ناصِحِي","slug":"ناصِحِي","root":"ن.ص.ح","root_slug":"ن-ص-ح","root_link":"/words/roots/ن-ص-ح","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"ناصِح","root":"نصح","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n39904"],"search_url":"https://lanelexicon.com/?s=%D9%86%D8%A7%D8%B5%D9%90%D8%AD%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"advisor, counselor"},{"pos":"adj","gloss":"active participle of نَصَحَ (naṣaḥa)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"active participle of نَصَحَ (naṣaḥa); advising"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb form I from the root ن ص ح (n ṣ ḥ)."},"ipa":["/naː.sˤiħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39904","headword_ar":"نَاصِحٌ","root":"nSH","body":[{"kind":"text","text":"(act. part. n. of"},{"kind":"arabic","text_bw":"naSaiHa","text_ar":"نَصَِحَ"},{"kind":"text","text":") and ↓"},{"kind":"arabic","text_bw":"naSiyHN","text_ar":"نَصِيحٌ","orth_type":"arrow"},{"kind":"text","text":"are syn., (S, K,) signifying One"},{"kind":"italic_en","text":"who advises,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsels, sincerely, honestly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faithfully:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"who so acts;"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"who directs another to that which is for the good of the latter, by words,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speech;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who gives good advice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsel:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who advises,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"counsels, sedulously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earnestly:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who acts sincerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honestly:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benevolent; who desires what is good for another:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"naSaH luha","text_ar":"نَصَح لُهَ"},{"kind":"text","text":";] pl. of the former"},{"kind":"arabic","text_bw":"nuS~aHN","text_ar":"نُصَّحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nuS~aAHN","text_ar":"نُصَّاحٌ"},{"kind":"text","text":"; (K;) and of the latter,"},{"kind":"arabic","text_bw":"nuSaHaA='u","text_ar":"نُصَحَا=ءُ"},{"kind":"text","text":". (S.) ―         -b2-"},{"kind":"arabic","text_bw":"rajulN naASiHu Aljayobi","text_ar":"رَجُلٌ نَاصِحُ الجَيْبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A man pare,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sincere, of heart;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"in whom is no deceit, dishonesty, insincerity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissimulation:"},{"kind":"text","text":"(K:) said to be an expression similar to"},{"kind":"arabic","text_bw":"TaAhiru Alv~awobi","text_ar":"طَاهِرُ الثَّوْبِ"},{"kind":"text","text":"[q. v.]. (TA.) [See also art."},{"kind":"arabic","text_bw":"jyb","text_ar":"جيب"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"naASiHN","text_ar":"نَاصِحٌ"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"naS~aAHN","text_ar":"نَصَّاحٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"naASiHiY~N","text_ar":"نَاصِحِىٌّ"},{"kind":"text","text":"(K) (tropical:)"},{"kind":"italic_en","text":"A sewer; a worker with the needle; a tailor."},{"kind":"text","text":"(S, K.)       -A3-"},{"kind":"arabic","text_bw":"naASiHN","text_ar":"نَاصِحٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clear,"},{"kind":"text","text":"honey, (As, S, K,) &c., like"},{"kind":"arabic","text_bw":"naASiEN","text_ar":"نَاصِعٌ"},{"kind":"text","text":"(As, S)."},{"kind":"arabic","text_bw":"saqaAniY naASiHa AlEasali","text_ar":"سَقَانِى نَاصِحَ العَسَلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He gave me to drink white honey;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thin, white honey."},{"kind":"text","text":"(A.)       -A4-"},{"kind":"arabic","text_bw":"guyuwtN nawaASiHu","text_ar":"غُيُوتٌ نَوَاصِحُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Rains succeeding one another."},{"kind":"text","text":"(A.)"}],"source_refs":["S","K","Msb","As"]}]},"classical_definitions":null}