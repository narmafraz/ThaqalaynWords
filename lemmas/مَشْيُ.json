{"lemma":"مَشْيُ","slug":"مَشْيُ","root":"م.ش.#","root_slug":"م-ش-_","root_link":"/words/roots/م-ش-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَشْي","root":"مشي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n43617",""],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B4%D9%92%D9%8A%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of مَشَى (mašā) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43617","headword_ar":"مَشَى","root":"m$Y","body":[{"kind":"italic_en","text":"He walked, went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went along;"},{"kind":"text","text":"(MA, KL;) [in its primary sense]"},{"kind":"italic_en","text":"He went any pace upon his feet, afoot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on foot; he footed;"},{"kind":"text","text":"whether"},{"kind":"italic_en","text":"quickly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slowly:"},{"kind":"text","text":"(Mgh, Msb:)"},{"kind":"italic_en","text":"he removed from place to place at pleasure:"},{"kind":"text","text":"(Er-Rághib:)"},{"kind":"italic_en","text":"walked; went along, marched; travelled; trod; paced; stepped."},{"kind":"text","text":"See 5. ―         -b2-"},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He went on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, in his course of action,"},{"kind":"text","text":"&c. (Mughnee voce"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":", in explanation of this verb as used in Kur xxxviii. 5.) ―         -b3-  ["},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(money)"},{"kind":"italic_en","text":"passed; was,"},{"kind":"page_break","n":3021},{"kind":"italic_en","text":"or became, current."},{"kind":"text","text":"―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a calumny)"},{"kind":"italic_en","text":"was, or became, current."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"miy^obarN","text_ar":"مِيْبَرٌ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"ma$aY banoTuhu","text_ar":"مَشَى بَنْطُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His belly became moved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in motion; it discharged itself."},{"kind":"text","text":"] (S, K, art."},{"kind":"arabic","text_bw":"Tlq","text_ar":"طلق"},{"kind":"text","text":"; &c.)"}],"source_refs":["Mgh","Msb"]}]}}