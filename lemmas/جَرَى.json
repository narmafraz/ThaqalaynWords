2md","form":"تَجْرِيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْرِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْر","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُجْرَى","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْرِي","in_corpus":true,"count":60,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُجْرَى","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْرِي","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْرِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْرِيانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْرِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْرِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْرُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْرِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْر","in_corpus":true,"count":88,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُجْرَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْرَى","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْرِي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْرِي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَرَيْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَرَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":338,"cross_references":{"qac":{"found":true,"lemma_key":"جَرَى","root":"جري","pos":"V","occurrence_count":57},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n5622"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B1%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of جَرَى (jarā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"course, run"},{"pos":"noun","gloss":"watercourse"},{"pos":"noun","gloss":"diarrhea, dysentery"},{"pos":"noun","gloss":"alternative form of جِرِّيث (jirrīṯ, “slime eel”)","tags":["alt-of","alternative"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5622","headword_ar":"جَرَى","root":"jrY","body":[{"kind":"text","text":", said of water (S, Mgh, Msb) &c., (S,) or of water and the like, (K,) more properly thus, as in the K, aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"jaroYN","text_ar":"جَرْىٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"jarayaAnN","text_ar":"جَرَيَانٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"jiroyapN","text_ar":"جِرْيَةٌ"},{"kind":"text","text":", (S, * Msb, K,) [which last see below,]"},{"kind":"italic_en","text":"It ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed along quickly;"},{"kind":"text","text":"originally said of water: (Er-Rághib, TA:) or"},{"kind":"italic_en","text":"it flowed;;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"saAla","text_ar":"سَالَ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"waqafa","text_ar":"وَقَفَ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"sakana","text_ar":"سَكَنَ"},{"kind":"text","text":". (Msb.) ―         -b2-  Said also of farina, in the phrase"},{"kind":"arabic","text_bw":"jaraY Ald~aqiyqu fiY Als~unobuli","text_ar":"جَرَى الدَّقِيقُ فِى السُّنْبُلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The farina pervaded the ears of wheat"},{"kind":"text","text":"]. (L in art."},{"kind":"arabic","text_bw":"qmH","text_ar":"قمح"},{"kind":"text","text":".) ―         -b3-  And of a horse (Mgh, Msb, K) and the like, (Msb, K,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"jaroYN","text_ar":"جَرْىٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"jarayaAnN","text_ar":"جَرَيَانٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"jiraA='N","text_ar":"جِرَا=ءٌ"},{"kind":"text","text":"(Lth, K) and"},{"kind":"arabic","text_bw":"majorFY","text_ar":"مَجْرًى"},{"kind":"text","text":", (S,) ["},{"kind":"italic_en","text":"He ran;"},{"kind":"text","text":"] from the same verb said of water. (Mgh) ―         -b4-  And of a ship: you say,"},{"kind":"arabic","text_bw":"jarati Als~afiynapN","text_ar":"جَرَتِ السَّفِينَةٌ"},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"jaroYN","text_ar":"جَرْىٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"majorFY","text_ar":"مَجْرًى"},{"kind":"text","text":", (S, K,) ["},{"kind":"italic_en","text":"The ship ran."},{"kind":"text","text":"] ―         -b5-  And of the sun, and a star: you say,"},{"kind":"arabic","text_bw":"jarati Al$~amosu","text_ar":"جَرَتِ الشَّمْسُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaroYN","text_ar":"جَرْىٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"The sun pursued its course:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"jarati Aln~ujuwmu","text_ar":"جَرَتِ النُّجُومُ"},{"kind":"italic_en","text":"The stars travelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed along, from east to west."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"jaraY A_ilaY ka*aA","text_ar":"جَرَى اـِلَى كَذَا"},{"kind":"text","text":", (Msb, and Har p. 152,) inf. n."},{"kind":"arabic","text_bw":"jaroYN","text_ar":"جَرْىٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jiraA='N","text_ar":"جِرَا=ءٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjrY","text_ar":"اجرى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ijoraA='N","text_ar":"اـِجْرَا=ءٌ"},{"kind":"text","text":"; (Ham p. 224, and Har p. 152;)"},{"kind":"italic_en","text":"He betook,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"directed, himself to such a thing; made it his object; aimed at it; intended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed, it:"},{"kind":"text","text":"(Msb, and Har ubi suprà:) and"},{"kind":"italic_en","text":"he hastened to it:"},{"kind":"text","text":"(Msb:) but in the latter phrase, an objective complement is understood; and it is used in relation to something disapproved, or disliked; (Ham and Har;) properly,"},{"kind":"arabic","text_bw":"AjrY fiEolahu A_ilayoh","text_ar":"اجرى فِعْلَهُ اـِلَيْه"},{"kind":"text","text":", (Ham,) or"},{"kind":"arabic","text_bw":"AjrY fiEolahu biAlqaSodi A_ilayohi","text_ar":"اجرى فِعْلَهُ بِالقَصْدِ اـِلَيْهِ"},{"kind":"text","text":". (Har.) ―         -b7-  Hence, perhaps, the saying,"},{"kind":"arabic","text_bw":"jaraY AlxilaAfu fiY ka*aA","text_ar":"جَرَى الخِلَافُ فِى كَذَا"},{"kind":"text","text":"(tropical:)  [frequently used as meaning"},{"kind":"italic_en","text":"A controversy ran,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ran on, respecting such a thing"},{"kind":"text","text":"between such and such persons]. (Msb.) ―         -b8-"},{"kind":"arabic","text_bw":"jaraY lahu Al$~aYo'u","text_ar":"جَرَى لَهُ الشَّىْءُ"},{"kind":"text","text":", (Sh, TA,) and"},{"kind":"arabic","text_bw":"jaraY Ealayohi","text_ar":"جَرَى عَلَيْهِ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The thing was permanent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued, to him."},{"kind":"text","text":"(Sh, TA.) [And, more commonly, (assumed tropical:)"},{"kind":"italic_en","text":"The thing happened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurred, to him."},{"kind":"text","text":"Whence, ↓"},{"kind":"arabic","text_bw":"maAjarayaAtN","text_ar":"مَاجَرَيَاتٌ","orth_type":"arrow"},{"kind":"text","text":", as pl. of"},{"kind":"arabic","text_bw":"maAjaraY","text_ar":"مَاجَرَى"},{"kind":"text","text":", used as a single word, by late writers, meaning (assumed tropical:)"},{"kind":"italic_en","text":"Events,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occurrences."},{"kind":"text","text":"] ―         -b9-"},{"kind":"arabic","text_bw":"huwa yajoriY","text_ar":"هُوَ يَجْرِى"},{"kind":"arabic","text_bw":"majoraAhu","text_ar":"مَجْرَاهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It is like it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar to it, in state, condition, case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"predicament."},{"kind":"text","text":"(TA.) ["},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a word or phrase)"},{"kind":"italic_en","text":"follows the same rule"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rules,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupies the same grammatical place, as it"},{"kind":"text","text":"(another word or phrase). And similar to this is the saying,]"},{"kind":"arabic","text_bw":"mujaAraApa AlmabiyEi","text_ar":"مُجَارَاةَ المَبِيعِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ald~ayonu waAlr~ahonu yatajaArayaAni","text_ar":"الدَّيْنُ وَالرَّهْنُ يَتَجَارَيَانِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"wAlv~amani","text_ar":"والثَّمَنِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The debt and the pledge are subject to the same laws as the thing sold and the price"},{"kind":"text","text":"]. (Mgh.) ―         -b10-  [Also (assumed tropical:)"},{"kind":"italic_en","text":"It acts as,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a similar manner to, it:"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"he acts in his stead:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"jariY~N","text_ar":"جَرِىٌّ"},{"kind":"text","text":". Hence the phrase,"},{"kind":"arabic","text_bw":"jaraY minohu majoraY ka*aA","text_ar":"جَرَى مِنْهُ مَجْرَى كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It acted upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected him, like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a similar manner to, such a thing:"},{"kind":"text","text":"as in the prov.,]"},{"kind":"arabic","text_bw":"jaraY minohu majoraY All~aduwdi","text_ar":"جَرَى مِنْهُ مَجْرَى اللَّدُودِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"It acted upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected him, like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similarly to, the medicine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"draught, called"},{"kind":"arabic","text_bw":"ldwd","text_ar":"لدود"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"mnh","text_ar":"منه"},{"kind":"text","text":"here having the meaning of"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"text","text":"]. (ISk, S in art."},{"kind":"arabic","text_bw":"ld","text_ar":"لد"},{"kind":"text","text":".) ―         -b11-  [One says, also, of an inf. n., and of a part. n., that is regularly formed,"},{"kind":"arabic","text_bw":"yajoriY EalaY AlfiEoli","text_ar":"يَجْرِى عَلَى الفِعْلِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"It is conformable to the verb."},{"kind":"text","text":"]"}],"source_refs":["S","Mgh","Msb","K","TA","Lth","Ham","Sh"]}]}}