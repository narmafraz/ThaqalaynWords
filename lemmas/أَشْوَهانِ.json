,{"kind":"italic_en","text":"morose, in face;"},{"kind":"text","text":"(K, * TA;)"},{"kind":"italic_en","text":"foul, unseemly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugly, in make:"},{"kind":"text","text":"(TA:) and also"},{"kind":"italic_en","text":"beautiful, goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comely;"},{"kind":"text","text":"(K, * TA;)"},{"kind":"italic_en","text":"that excites admiration and approval by her beauty:"},{"kind":"text","text":"(TA:) thus having two contr. meanings. (K, TA.) Also, the fem.,"},{"kind":"italic_en","text":"Unlucky, or inauspicious."},{"kind":"text","text":"(K.) ―         -b2-  And the masc. applied to a man, (Lth, S, TA,) and the fem. applied to a woman, (Lth, TA,)"},{"kind":"italic_en","text":"That smites quickly with the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"evil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"eye:"},{"kind":"text","text":"(Lth, S, TA:) or"},{"kind":"italic_en","text":"that smites people effectually with his,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"her,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"evil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"eye."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^a$owahu AlEayon","text_ar":"اَشْوَهُ العَيْن"},{"kind":"italic_en","text":"Having an evil eye."},{"kind":"text","text":"(Fr, TA in art."},{"kind":"arabic","text_bw":"$zr","text_ar":"شزر"},{"kind":"text","text":".) ―         -b3-  The fem. is also applied to a mare, (JK, T, S, K,) as an epithet of commendation, but not the masc. to a horse, meaning, it is said,"},{"kind":"italic_en","text":"Wide in the"},{"kind":"arabic","text_bw":"$idoqaAni","text_ar":"شِدْقَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"two sides of the mouth"},{"kind":"text","text":"]: (S:) or"},{"kind":"italic_en","text":"long in the head, and wide in the nostrils:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"tall, and such as excites admiration and approval by her beauty"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellence:"},{"kind":"text","text":"(K, * TA:) or"},{"kind":"italic_en","text":"exceedingly wide in the"},{"kind":"arabic","text_bw":"$idoqaAni","text_ar":"شِدْقَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"two sides of the mouth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the nostrils:"},{"kind":"text","text":"(K, TA:) or, as some say,"},{"kind":"italic_en","text":"wide in the mouth:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"small in the mouth:"},{"kind":"text","text":"thus having two contr. meanings: (K, TA:) or"},{"kind":"italic_en","text":"sharpsighted:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"sharp in spirit:"},{"kind":"text","text":"(TA:) see also 1. ―         -b4-  Also, the masc.,"},{"kind":"italic_en","text":"Proud, and self-conceited."},{"kind":"text","text":"(K.) ―         -b5-  And"},{"kind":"arabic","text_bw":"xuTobapN $awohaA='u","text_ar":"خُطْبَةٌ شَوْهَا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An oration from the pulpit"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in which a blessing is not invoked on the Prophet."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","JK","K","Mgh","TA","Lth","S","T"]}]},"classical_definitions":null}