:"s"}],"frequency_in_corpus":18,"cross_references":{"qac":{"found":true,"lemma_key":"عَضَّ","root":"عضض","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":14},"lanes":{"found":true,"entry_ids":["n29405","n29406"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B6%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bite"},{"pos":"verb","gloss":"to treat badly"},{"pos":"verb","gloss":"to taunt"},{"pos":"verb","gloss":"to bear patiently"},{"pos":"verb","gloss":"to bite upon one's self (in expression of remorse or anger)","tags":["idiomatic"]},{"pos":"noun","gloss":"verbal noun of عَضَّ (ʕaḍḍa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"biting"},{"pos":"noun","gloss":"bite"},{"pos":"noun","gloss":"lock that does not open; stuck piece of wood, wooden bolt or door barricade; man who keeps his possession's locked away, being miserly or stingy, being of an evil disposition"},{"pos":"noun","gloss":"lock that does not open; stuck piece of wood, wooden bolt or door barricade; man strong or cunning enough to defend himself or obtain and keep his interests, knowing tricks or how to best secure"},{"pos":"noun","gloss":"small prickly brambles, thorny trees, shrubs"},{"pos":"noun","gloss":"provender, fodder"},{"pos":"noun","gloss":"thick coarse trees or shrubs"},{"pos":"noun","gloss":"thick bulky or large collected firewood"}]},"etymology":null,"ipa":["/ʕadˤ.dˤa/","/ʕadˤdˤ/","/ʕidˤdˤ/","/ʕudˤdˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29405","headword_ar":"عُضٌّ","root":"ED","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"provender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fodder, of the people of the cities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"towns; such as the dregs of sesamegrain from which the oil has been expressed, and crushed date-stones:"},{"kind":"text","text":"(S, O, TA:) or"},{"kind":"italic_en","text":"dough with which camels are fed:"},{"kind":"text","text":"(AHn, O, K:) and [the"},{"kind":"italic_en","text":"trefoil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qat~","text_ar":"قَتّ"},{"kind":"text","text":", (AHn, O, K,) i. e."},{"kind":"arabic","text_bw":"fiSofiSap","text_ar":"فِصْفِصَة"},{"kind":"text","text":": (AHn, O:) and"},{"kind":"italic_en","text":"barley and wheat, not mixed with any other thing:"},{"kind":"text","text":"(AA, O, K:) or"},{"kind":"italic_en","text":"date-stones"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"crushed,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"qat~","text_ar":"قَتّ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"with which camels are fed:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course, trees"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"shrubs"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"remaining in the earth:"},{"kind":"text","text":"(AA, O, K;) as also ↓"},{"kind":"arabic","text_bw":"EaDaADN","text_ar":"عَضَاضٌ","orth_type":"arrow"},{"kind":"text","text":": (AA, O:) or"},{"kind":"italic_en","text":"date-stones"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"crushed,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and dough:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"italic_en","text":"barley"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"with one of those two things;"},{"kind":"text","text":"(TA;) but 'Alee Ibn-Hamzeh disallows its application to date-stones: (IB, TA:) or"},{"kind":"italic_en","text":"thick, large firewood, collected:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"italic_en","text":"dry herbage"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"with which beasts are fed."},{"kind":"text","text":"(TA.) [See an ex. in a verse cited in art."},{"kind":"arabic","text_bw":"Slb","text_ar":"صلب"},{"kind":"text","text":", conj. 2.] ―         -b2-  See also the next paragraph, last sentence, in two places."}],"source_refs":["S","O","TA","AHn","K","AA","IB"]},{"entry_id":"n29406","headword_ar":"عِضٌّ","root":"ED","body":[{"kind":"text","text":"[is of the measure"},{"kind":"arabic","text_bw":"fiEolN","text_ar":"فِعْلٌ"},{"kind":"text","text":", in the sense of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":"in some cases, and in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":"in other cases; but appears to have only tropical significations]. ―         -b2-  (tropical:)  A lock"},{"kind":"italic_en","text":"that will scarcely open;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that is not near to opening;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"laA yakaAdu yanofatiHu","text_ar":"لَا يَكَادُ يَنْفَتِحُ"},{"kind":"text","text":": (S, A, O, K:) or"},{"kind":"italic_en","text":"that will not open."},{"kind":"text","text":"(TA.) ―         -b3-  (tropical:)  One"},{"kind":"italic_en","text":"who keeps close to his property:"},{"kind":"text","text":"(TA:) a man"},{"kind":"italic_en","text":"who improves his means of subsistence and his property, attends closely to it, and manages it well:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"a manager of property:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"EiD~u maAlK","text_ar":"عِضُّ مَالٍ"},{"kind":"text","text":"signifies one"},{"kind":"italic_en","text":"who manages property well:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"who manages property rigorously."},{"kind":"text","text":"(S, O.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"Niggardly, tenacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious:"},{"kind":"text","text":"(K, TA:) for a man's keeping close to his property generally courses him to fall into niggardliness: or such a person is likened to a lock that will not open. (TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"Evil in disposition;"},{"kind":"text","text":"(Lth, O, K, TA;)"},{"kind":"italic_en","text":"bad, wicked"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"malignant."},{"kind":"text","text":"(TA.) ―         -b6-  (tropical:)  A"},{"kind":"italic_en","text":"strong"},{"kind":"text","text":"man; (IAar, T, A, K;) as also ↓"},{"kind":"arabic","text_bw":"EaDoEaDN","text_ar":"عَضْعَضٌ","orth_type":"arrow"},{"kind":"text","text":". (IAar, T, TA.) It is said in the A that"},{"kind":"arabic","text_bw":"AlEaDiyDu","text_ar":"العَضِيضُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlEiD~u","text_ar":"العِضُّ"},{"kind":"text","text":"signify"},{"kind":"arabic","text_bw":"Al$~adiydu","text_ar":"الشَّدِيدُ"},{"kind":"text","text":": and in one place in the K, that"},{"kind":"arabic","text_bw":"AlEaDiyDu","text_ar":"العَضِيضُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AlEaD~u Al$~adiydu","text_ar":"العَضُّ الشَّدِيدُ"},{"kind":"text","text":": and by Sgh, in his two books, [the O and TS,] as on the authority of IAar, that"},{"kind":"arabic","text_bw":"AlEaDoEaDu","text_ar":"العَضْعَضُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AlEaD~u","text_ar":"العَضُّ"},{"kind":"arabic","text_bw":"Al$~adiydu","text_ar":"الشَّدِيدُ"},{"kind":"text","text":": but the correct reading is that which is given in the T, with which other lexicons agree. (TA.) ―         -b7-  (tropical:)"},{"kind":"italic_en","text":"Having strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, sufficient for a thing."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"huwa EiD~u safarK","text_ar":"هُوَ عِضُّ سَفَرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He has strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, sufficient for travel:"},{"kind":"text","text":"(S, A, O:)"},{"kind":"italic_en","text":"he is rendered experienced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expert, by travels:"},{"kind":"text","text":"of the measure"},{"kind":"arabic","text_bw":"fiEolN","text_ar":"فِعْلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":". (A, TA.) And"},{"kind":"arabic","text_bw":"EiD~u qitaAlK","text_ar":"عِضُّ قِتَالٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Having strength,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power, sufficient for fight."},{"kind":"text","text":"(TA.) ―         -b8-  (assumed tropical:)"},{"kind":"italic_en","text":"An equal in courage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generally;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an opponent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversary;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qironN","text_ar":"قِرْنٌ"},{"kind":"text","text":": (O, K:) of another; (TA;) as also ↓"},{"kind":"arabic","text_bw":"EaDiyDN","text_ar":"عَضِيضٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) [See the latter, below.] ―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"Cunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intel-ligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful and knowing, and contentious;"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"faAEilN","text_ar":"فَاعِلٌ"},{"kind":"text","text":", because such a person defames, or speaks evil of, or backbites, others: (A, TA:) (tropical:)"},{"kind":"italic_en","text":"understanding and knowing obscure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstruse, things:"},{"kind":"text","text":"(A, TA:) (assumed tropical:)"},{"kind":"italic_en","text":"eloquent, and cunning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful and knowing:"},{"kind":"text","text":"(S, O, K:) and [simply] (assumed tropical:)"},{"kind":"italic_en","text":"cunning;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAhK","text_ar":"دَاهٍ"},{"kind":"text","text":"; applied to a man: (S, O:) or (assumed tropical:)"},{"kind":"italic_en","text":"very cunning;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAhiyapN","text_ar":"دَاهِيَةٌ"},{"kind":"text","text":": (K:) pl. [of mult.]"},{"kind":"arabic","text_bw":"guDuwDN","text_ar":"غُضُوضٌ"},{"kind":"text","text":"(O, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^aEoDaADN","text_ar":"اَعْضَاضٌ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$irosN","text_ar":"شِرْسٌ"},{"kind":"text","text":", i. e. (AZ, S, O)"},{"kind":"italic_en","text":"Such as are small, of thorny trees,"},{"kind":"text","text":"(AZ, S, O, K,)"},{"kind":"italic_en","text":"as the"},{"kind":"arabic","text_bw":"$uborum","text_ar":"شُبْرُم"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"HaAj","text_ar":"حَاج"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"$iboriq","text_ar":"شِبْرِق"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"laSaf","text_ar":"لَصَف"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"Eitor","text_ar":"عِتْر"},{"kind":"italic_en","text":"and the smaller"},{"kind":"arabic","text_bw":"qataAd","text_ar":"قَتَاد"},{"kind":"text","text":"(AZ, S, O)"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"kalobap","text_ar":"كَلْبَة"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"nugor","text_ar":"نُغْر"},{"kind":"text","text":"[app. a mistranscription]; (AZ, TA;) as also ↓"},{"kind":"arabic","text_bw":"EuD~N","text_ar":"عُضٌّ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) accord. to AHn: (TA:) or the"},{"kind":"arabic","text_bw":"TaloH","text_ar":"طَلْح"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"Eawosaj","text_ar":"عَوْسَج"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"sayaAl","text_ar":"سَيَال"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"saroH","text_ar":"سَرْح"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"EurofuT","text_ar":"عُرْفُط"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"samur","text_ar":"سَمُر"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"$abahaAn","text_ar":"شَبَهَان"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"kanahobal","text_ar":"كَنَهْبَل"},{"kind":"text","text":"; (K, TA;) as also ↓"},{"kind":"arabic","text_bw":"EuD~N","text_ar":"عُضٌّ","orth_type":"arrow"},{"kind":"text","text":": (CK:) or the"},{"kind":"arabic","text_bw":"Ewsj","text_ar":"عوسج"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"syAl","text_ar":"سيال"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ErfT","text_ar":"عرفط"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"smr","text_ar":"سمر"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"knhbl","text_ar":"كنهبل"},{"kind":"text","text":"are of the trees called"},{"kind":"arabic","text_bw":"EiDaAh","text_ar":"عِضَاه"},{"kind":"text","text":"[q. v.]. (AZ, TA.)"}],"source_refs":["S","A","O","K","TA","L","AZ","CK"]}]}}