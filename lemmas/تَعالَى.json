:"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَتَعالُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَعالُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَعالَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَعالَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَتَعال","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَعالَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَتَعال","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَعالَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَعالَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَعالَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَعالَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَعالُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَعالُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَعالَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"imperative_2ms","form":"تَعالَىْ","in_corpus":true,"count":1235,"asp":"c","per":"2","gen":"m","num":"s"},{"role":"imperative_2fs","form":"تَعالِي","in_corpus":true,"count":1235,"asp":"c","per":"2","gen":"f","num":"s"},{"role":"imperative_2mp","form":"تَعالُوا","in_corpus":true,"count":5,"asp":"c","per":"2","gen":"m","num":"p"},{"role":"past_1mp","form":"تَعالَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَعالَيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتَعالَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَعالَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَعال","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَعال","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":3719,"cross_references":{"qac":{"found":true,"lemma_key":"تَعالَى","root":"علو","pos":"V","occurrence_count":14},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n30396"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D8%A7%D9%84%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30396","headword_ar":"تعالى","root":"Elw","body":[{"kind":"text","text":": see 1, first sentence. ―         -b2-  Addressing a man, (S, Msb,) using the imperative form, you say,"},{"kind":"arabic","text_bw":"taEaAla","text_ar":"تَعَالَ"},{"kind":"text","text":", (S, Msb, K,) with fet-h to the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":", (S, K,) originally meaning"},{"kind":"italic_en","text":"Be thou elevated,"},{"kind":"text","text":"(S, Msb,) and said by a man in a high place in calling a man in a low place; (Msb;) then, by reason of frequency of usage, employed in the sense of"},{"kind":"arabic","text_bw":"halum~a","text_ar":"هَلُمَّ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"Come thou"},{"kind":"text","text":"], (S, Msb,) absolutely, whether the place of the person called be high or low or on the same level; so that it is originally applied to denote a particular meaning, and then used in a general meaning: (Msb:) and to a woman one says,"},{"kind":"arabic","text_bw":"taEaAlaYo","text_ar":"تَعَالَىْ"},{"kind":"text","text":"; (S, K;) and to two women, (S,) or two persons, (TA,)"},{"kind":"arabic","text_bw":"taEaAlayaA","text_ar":"تَعَالَيَا"},{"kind":"text","text":"; (S, TA;) and to a pl. number of men,"},{"kind":"arabic","text_bw":"taEaAlawoA","text_ar":"تَعَالَوْا"},{"kind":"text","text":"; (Msb, TA;) and to a pl. number of women,"},{"kind":"arabic","text_bw":"taEaAlayona","text_ar":"تَعَالَيْنَ"},{"kind":"text","text":"; (S, Msb, TA;) and sometimes the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is pronounced with damm in the pl. masc., and with kesr in the fem.; whence El-Hasan El-Basree read, [in the Kur iii. 57,]"},{"kind":"arabic","text_bw":"qulo yaA A^ahola A@lokitaAbi taEaAluwA","text_ar":"قُلْ يَا اَهْلَ ا@لْكِتَابِ تَعَالُوا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Say thou, O people of the Scripture, come ye,"},{"kind":"text","text":"the usual reading being"},{"kind":"arabic","text_bw":"taEaAlawoA","text_ar":"تَعَالَوْا"},{"kind":"text","text":"], for the sake of congeniality with the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":": (Msb, TA:) it is not allowable to say"},{"kind":"arabic","text_bw":"taEaAlayotu","text_ar":"تَعَالَيْتُ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"I came"},{"kind":"text","text":"], nor to use the prohibitive form; (S;) but one"},{"kind":"page_break","n":2144},{"kind":"text","text":"says, (thus accord. to several copies of the S,) or nor does one say, (thus accord. to one of my copies of the S, [and accord. to the TA, in which it is said that the verb is not used otherwise than in the imperative form,])"},{"kind":"arabic","text_bw":"qado taEaAlayotu","text_ar":"قَدْ تَعَالَيْتُ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"I have come"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"A_ilaY A^aY~i $aYo'K A^ataEaAlaY","text_ar":"اـِلَى اَىِّ شَىْءٍ اَتَعَالَى"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"To what thing shall I come?"},{"kind":"text","text":"like as one says,"},{"kind":"arabic","text_bw":"A_ilaAma A^ahalum~a","text_ar":"اـِلَامَ اَهَلُمَّ"},{"kind":"text","text":"]. (S.) ―         -b3-  ["},{"kind":"arabic","text_bw":"tEAlY","text_ar":"تعالى"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled:"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"he exalted himself:"},{"kind":"text","text":"and in both of these senses it is often followed by"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":", denoting superiority: you say,"},{"kind":"arabic","text_bw":"tEAlY fulaAnN Eano ka*aA","text_ar":"تعالى فُلَانٌ عَنْ كَذَا"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, exalted above such a thing;"},{"kind":"text","text":"or simply,"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, above it,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"too elevated in character for it:"},{"kind":"text","text":"and also,"},{"kind":"italic_en","text":"exalted himself above such a thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held himself above it."},{"kind":"text","text":"] Said of God, in the Kur xx. 113 [and in other instances therein], it means [(assumed tropical:)"},{"kind":"italic_en","text":"Exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supremely exalted, is He"},{"kind":"text","text":"] in his essence and his attributes, above the created beings. (Bd.) [But in common speech, it is generally used as an ejaculation of praise, meaning (assumed tropical:)"},{"kind":"italic_en","text":"Exalted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supremely exalted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled, be He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his greatness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"majesty"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his name;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acknowledged be his absolute supremacy."},{"kind":"text","text":"And the common expression (used in citing words of the Kur-án)"},{"kind":"arabic","text_bw":"qaAla taEaAlaY","text_ar":"قَالَ تَعَالَى"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"He saith,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hath said, exalted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supremely exalted"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extolled, be He;"},{"kind":"text","text":"&c.] ―         -b4-  See also 5."}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}