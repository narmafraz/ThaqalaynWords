:"m","num":"p"},{"role":"present_2mp","form":"تَخْبِزُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْبِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْبِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْبِز","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْبِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْبِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْبِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْبِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْبِزُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْبِزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْبِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَبَزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَبَزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْبِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْبِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":true,"lemma_key":"خَبَزَ","root":"خبز","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n9913"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%A8%D9%8E%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bake"},{"pos":"noun","gloss":"bread","tags":["uncountable"]},{"pos":"noun","gloss":"verbal noun of خَبَزَ (ḵabaza) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"baking"}]},"etymology":{"source":"wiktextract","text":"Often suspected a loan, presuming an Aksumite or Old South Arabian predecessor of the Ge'ez ኅብስት (ḫəbəst, formally feminine passive participle with assimilation of the last radical to the feminine suffix), the formations within the root خ ب ز (ḵ b z) having been secondarily derived from the “loaf of bread” singulative noun خُبْزَة (ḵubza). Maybe instead both hail via an Old Aramaic term from Old Georgian ჴუეზაჲ (quezay, “loaf of bread”), Georgian ხვეზა (xveza)."},"ipa":["/xa.ba.za/","/xubz/","/xabz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9913","headword_ar":"خُبْزٌ","root":"xbz","body":[{"kind":"text","text":"a word of well-known meaning; (K;) ["},{"kind":"italic_en","text":"Bread;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that which is eaten."},{"kind":"text","text":"(S.) It is said in a prov.,"},{"kind":"arabic","text_bw":"kul~u A^adaApi Alxubozi EinodiY gayoruhu","text_ar":"كُلُّ اَدَاةِ الخُبْزِ عِنْدِى غَيْرُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"All the apparatus of bread is in my possession except it,"},{"kind":"text","text":"namely, the bread itself]: the origin of which was this: a company of men demanded hospitality of a certain man; and when they sat down, he threw down a [piece of leather such as is called]"},{"kind":"arabic","text_bw":"niToE","text_ar":"نِطْع"},{"kind":"text","text":", and put upon it a mill-stone, and adjusted its pivot, and covered it [with the upper stone]: and the presence of his apparatus made the company to wonder: then he took the handle of the mill, ("},{"kind":"arabic","text_bw":"haAdiY Alr~aHaY","text_ar":"هَادِى الرَّحَى"},{"kind":"text","text":",) and began to turn it: whereupon they said to him, What dost thou? and he answered in the words of this proverb. (K.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Alxul~apu xubozu AlA_ibili","text_ar":"الخُلَّةُ خُبْزُ الاـِبِلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Sweet herbage is the bread of camels:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlHamoDu faAkihatuhaA","text_ar":"الحَمْضُ فَاكِهَتُهَا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"AaHomuhaA","text_ar":"اَحْمُهَا"},{"kind":"text","text":","},{"kind":"italic_en","text":"sour herbage is their fruit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flesh-meat"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":[]}]}}