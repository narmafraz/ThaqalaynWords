{"lemma":"أَصَحَّيْ","slug":"أَصَحَّيْ","root":"ص.ح.ح","root_slug":"ص-ح-ح","root_link":"/words/roots/ص-ح-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n23843"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B5%D9%8E%D8%AD%D9%8E%D9%91%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"elative degree of صَحِيح (ṣaḥīḥ):; truer; truest"},{"pos":"adj","gloss":"elative degree of صَحِيح (ṣaḥīḥ):; more right, more correct; most right, most correct"},{"pos":"adj","gloss":"elative degree of صَحِيح (ṣaḥīḥ):; more genuine; most genuine"},{"pos":"adj","gloss":"elative degree of صَحِيح (ṣaḥīḥ):; sounder, healthier; soundest, healthiest"}]},"etymology":{"source":"wiktextract","text":"Elative of صَحِيح (ṣaḥīḥ, “true; right, correct; genuine; sound, healthy”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23843","headword_ar":"اصحى","root":"SHw","body":[{"kind":"text","text":": see 1, in four places. ―         -b2-"},{"kind":"arabic","text_bw":"A^aSoHayonaA","text_ar":"اَصْحَيْنَا"},{"kind":"italic_en","text":"We became in a case of cloudlessness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the sky"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"day"},{"kind":"text","text":"]; (Msb, TA;)"},{"kind":"italic_en","text":"the sky became cloudless to us."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"arabic","text_bw":"A^aSoHayotuhu mino sukorihi","text_ar":"اَصْحَيْتُهُ مِنْ سُكْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I recovered him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roused him, from his intoxication"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"arabic","text_bw":"nawomihi","text_ar":"نَوْمِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from his sleep"},{"kind":"text","text":"]. (TA.) ―         -b2-  And sometimes"},{"kind":"arabic","text_bw":"A_iSoHaA='N","text_ar":"اـِصْحَا=ءٌ"},{"kind":"text","text":"is used as meaning The act of"},{"kind":"italic_en","text":"rousing,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"recalling to mindfulness, from a state of heedlessness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inadvertence."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]}}