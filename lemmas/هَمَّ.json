{"lemma":"هَمَّ","slug":"هَمَّ","root":"ه.م.م","root_slug":"ه-م-م","root_link":"/words/roots/ه-م-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"هَمَّ","root":"همم","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","pron","verb"],"has_etymology":false,"sense_count":13},"lanes":{"found":true,"entry_ids":["n44340"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"pron","gloss":"they (masculine plural subject pronoun)"},{"pos":"pron","gloss":"them, their (masculine plural bound object pronoun)","tags":["enclitic","form-of"]},{"pos":"verb","gloss":"to disquiet, to make uneasy, to distress"},{"pos":"verb","gloss":"to grieve"},{"pos":"verb","gloss":"to preoccupy, to concern, to affect"},{"pos":"verb","gloss":"to be of interest"},{"pos":"verb","gloss":"to plan, to be about to, to start doing, to become determined","examples":[{"text":"هَمُّوا بِٱلْفِرَارِ","english":"They started running away."}]},{"pos":"noun","gloss":"verbal noun of هَمَّ (hamma) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"anxiety, concern, worry, care"},{"pos":"noun","gloss":"sorrow, grief, affliction, distress"},{"pos":"noun","gloss":"weight, moment, importance"},{"pos":"adj","gloss":"decrepit, senile"},{"pos":"noun","gloss":"old man"}]},"etymology":null,"ipa":["/hum/","/him/","/ham.ma/","/hamm/","/himm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44340","headword_ar":"هَمَّ","root":"hm","body":[{"kind":"italic_en","text":"He purposed, or intended,"},{"kind":"text","text":"a thing."},{"kind":"arabic","text_bw":"ham~N","text_ar":"هَمٌّ"},{"kind":"text","text":"denotes more than"},{"kind":"arabic","text_bw":"A_iraAdapN","text_ar":"اـِرَادَةٌ"},{"kind":"text","text":", and less than"},{"kind":"arabic","text_bw":"EazomN","text_ar":"عَزْمٌ"},{"kind":"text","text":". (Kull, p. 382.) ―         -b2-"},{"kind":"arabic","text_bw":"laA maham~apa walaA makaAdapa","text_ar":"لَا مَهَمَّةَ وَلَا مَكَادَةَ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"kwd","text_ar":"كود"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"ham~a biAl$~aYo'i","text_ar":"هَمَّ بِالشَّىْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He meditated, proposed to himself, purposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intended, to do the thing:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he desired to do the thing,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"without doing it;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he endeavoured to do the thing."},{"kind":"text","text":"(S.) ―         -b4-"},{"kind":"arabic","text_bw":"ham~a biAlA^amori","text_ar":"هَمَّ بِالاَمْرِ"},{"kind":"italic_en","text":"He intended the affair."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposed it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he desired it."},{"kind":"text","text":"(Mgh.) ―         -b5-"},{"kind":"arabic","text_bw":"ham~a bihi fiY nafosihi","text_ar":"هَمَّ بِهِ فِى نَفْسِهِ"},{"kind":"text","text":"[aor."},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He intended it, meant it, desired it."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determined upon it, in his mind."},{"kind":"text","text":"(TA.) See also a verse cited voce"},{"kind":"arabic","text_bw":"rutamN","text_ar":"رُتَمٌ"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"hm","text_ar":"هم"},{"kind":"arabic","text_bw":"biAlbakaA='i","text_ar":"بِالبَكَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready, to weep;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"A^araAda AlbukaA='a","text_ar":"اَرَادَ البُكَا=ءَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"tahay~aA^a lilbukaA='i","text_ar":"تَهَيَّاَ لِلبُكَا=ءِ"},{"kind":"text","text":"q. v.]. (A, art."},{"kind":"arabic","text_bw":"jh$","text_ar":"جهش"},{"kind":"text","text":", &c.) ―         -b7-"},{"kind":"arabic","text_bw":"ham~a bAls~uquwT","text_ar":"هَمَّ بالسُّقُوط"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It threatened to fall"},{"kind":"text","text":"], said of a"},{"kind":"page_break","n":3045},{"kind":"text","text":"wall. (S, in art."},{"kind":"arabic","text_bw":"whY","text_ar":"وهى"},{"kind":"text","text":", &c.) ―         -b8-"},{"kind":"arabic","text_bw":"ham~ahu","text_ar":"هَمَّهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^aham~ahu","text_ar":"اَهَمَّهُ","orth_type":"arrow"},{"kind":"italic_en","text":"It disquieted him;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"caused him care,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety."},{"kind":"text","text":"―         -b9-"},{"kind":"arabic","text_bw":"laA yuhim~uhu A_il~aA baTonuhu","text_ar":"لَا يُهِمُّهُ اـِلَّا بَطْنُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nothing causes him care,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety, but his belly"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"bTn","text_ar":"بطن"},{"kind":"text","text":".)"}],"source_refs":["S","Msb"]}]}}