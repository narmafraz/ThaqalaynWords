{"lemma":"طالَ","slug":"طالَ","root":"ط.#.ل","root_slug":"ط-_-ل","root_link":"/words/roots/ط-_-ل","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"طُلْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"طُلْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"طُلْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"طُلْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"طُلْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"طالَ","in_corpus":true,"count":18,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"طالَت","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"طالا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"طالَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"طالُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"طُلْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَطُل","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَطُول","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَطُولِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَطُولِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَطُولانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطُولا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَطُولُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطُولُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطُل","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَطُول","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطُل","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطُول","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطُولانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطُولا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطُولانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطُولا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطُولُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطُولُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طُلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طُلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَطُول","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطُول","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":true,"lemma_key":"طالَ","root":"طول","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n27038","n27337"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be long, last long, stretch to a great extent","examples":[{"text":"طَالَ بِهِ ٱلزَّمَنُ.","english":"The time was long to him."},{"text":"طَالَ بِهِمُ ٱلْوُقُوفُ.","english":"They stood for a long time."}]},{"pos":"verb","gloss":"to be or last too long"},{"pos":"verb","gloss":"to be tall"},{"pos":"verb","gloss":"to benefit, to bestow favors on"},{"pos":"verb","gloss":"to reach (an area) (e.g. of bombs)","tags":["transitive"]},{"pos":"verb","gloss":"to surpass in length or tallness","tags":["transitive"]},{"pos":"verb","gloss":"to overcome, to be superior to"}]},"etymology":null,"ipa":["/tˤaː.la/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27038","headword_ar":"طَالٍ","root":"Tlw and TlY","body":[{"kind":"text","text":"A water to which camels come to drink"},{"kind":"italic_en","text":"overspread with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the green substance called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TuHolub","text_ar":"طُحْلُب"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"TulawaA='","text_ar":"طُلَوَا=ء"},{"kind":"text","text":"]. (K, TA.) ―         -b2-  And (tropical:)  A"},{"kind":"italic_en","text":"dark"},{"kind":"text","text":"night: (AA, K, TA:) as though it smeared [with tar] the forms, or persons, of men, and obscured them. (AA, TA.)"}],"source_refs":["AA","K","TA"]},{"entry_id":"n27337","headword_ar":"طَالَ","root":"Twl","body":[{"kind":"text","text":", (S, O, Msb, K,) said by some to be of the class of"},{"kind":"arabic","text_bw":"qaruba","text_ar":"قَرُبَ"},{"kind":"text","text":", being made by them to accord in from with its contr., which is"},{"kind":"arabic","text_bw":"qaSura","text_ar":"قَصُرَ"},{"kind":"text","text":", and by others said to be of the class of"},{"kind":"arabic","text_bw":"qaAla","text_ar":"قَالَ"},{"kind":"text","text":", (Msb,) first pers."},{"kind":"arabic","text_bw":"Tulotu","text_ar":"طُلْتُ"},{"kind":"text","text":", [said to be] originally"},{"kind":"arabic","text_bw":"Tawulotu","text_ar":"طَوُلْتُ"},{"kind":"text","text":", because one says"},{"kind":"arabic","text_bw":"TawiylN","text_ar":"طَوِيلٌ"},{"kind":"text","text":", [not"},{"kind":"arabic","text_bw":"TaAy^ilN","text_ar":"طَايِلٌ"},{"kind":"text","text":", when using it as an intrans. v.,] (S, O,) aor."},{"kind":"arabic","text_bw":"yaTuwlu","text_ar":"يَطُولُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"TuwlN","text_ar":"طُولٌ"},{"kind":"text","text":", (S, * O, * Msb, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, O, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, elongated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended;"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tall,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"high;"},{"kind":"text","text":"which meanings are sometimes more explicitly denoted in order to avoid ambiguity, as when one says"},{"kind":"arabic","text_bw":"TaAla EalaY wajohi AlA^aroDi","text_ar":"طَالَ عَلَى وَجْهِ الاَرْضِ"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, elongated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended, upon the surface of the earth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TaAla fiY Als~amaA='i","text_ar":"طَالَ فِى السَّمَا=ءِ"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, elongated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended, towards"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"into"},{"kind":"text","text":")"},{"kind":"italic_en","text":"the sky;"},{"kind":"text","text":"] (S, O, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AstTAl","text_ar":"استطال","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (S, O, K.) It is also said of any time that is extended; and of anxiety that cleaves to one continually; and the like: [see"},{"kind":"arabic","text_bw":"TuwlN","text_ar":"طُولٌ"},{"kind":"text","text":", below:] thus one says"},{"kind":"arabic","text_bw":"TaAla All~ayolu","text_ar":"طَالَ اللَّيْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The night became long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protracted"},{"kind":"text","text":"]: (TA:) [and thus"},{"kind":"arabic","text_bw":"TaAla Ealayohimu AlA^amadu","text_ar":"طَالَ عَلَيْهِمُ الاَمَدُ"},{"kind":"text","text":", in the Kur lvii. 15, means"},{"kind":"italic_en","text":"The time became extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prolonged, unto them:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Ealayohimu AlEumuru","text_ar":"عَلَيْهِمُ العُمُرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taTaAwala","text_ar":"تَطَاوَلَ","orth_type":"arrow"},{"kind":"text","text":", in the Kur xxviii. 45, means, in like manner, ["},{"kind":"italic_en","text":"Life was prolonged unto them;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"their lives became long,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prolonged:"},{"kind":"text","text":"(Jel:) and"},{"kind":"arabic","text_bw":"TAl Almajolisu","text_ar":"طال المَجْلِسُ"},{"kind":"italic_en","text":"The time of the assembly was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prolonged:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"TAl Alham~u","text_ar":"طال الهَمُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Anxiety became protracted"},{"kind":"text","text":"]. (TA.) [One says also"},{"kind":"arabic","text_bw":"TaAlamaA faEala ka*aA","text_ar":"طَالَمَا فَعَلَ كَذَا"},{"kind":"italic_en","text":"Long time did he thus;"},{"kind":"text","text":"and the like; with the restrictive"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":": see Har p. 17.]       -A2-  When trans. [without a particle it is of the class"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":"; not"},{"kind":"arabic","text_bw":"faEula","text_ar":"فَعُلَ"},{"kind":"text","text":", because this is not trans.: (TA:) one says"},{"kind":"arabic","text_bw":"Tulotuhu","text_ar":"طُلْتُهُ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"I exceeded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpassed him, in"},{"kind":"arabic","text_bw":"AlT~uwl","text_ar":"الطُّول"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"tallness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I overtopped him"},{"kind":"text","text":"]: and also"},{"kind":"italic_en","text":"in"},{"kind":"arabic","text_bw":"AlT~awol","text_ar":"الطَّوْل"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"beneficence,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"excellence,"},{"kind":"text","text":"&c.]. (S, O, K.) See 3. A poet says,"},{"kind":"quote","text":"A_in~a Alfarazodaqa SaxorapN EaAriyapN\n                      \n                     \n                        TaAlato falayosa tanaAluhaA AlA^awoEaAlu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily El-Farezdak is a bare rock that has exceeded in height"},{"kind":"text","text":"the mountain-goats"},{"kind":"italic_en","text":"so that the mountain-goats do not reach it"},{"kind":"text","text":"]: he means"},{"kind":"arabic","text_bw":"TaAlati","text_ar":"طَالَتِ"},{"kind":"arabic","text_bw":"AlA^awoEaAla","text_ar":"الاَوْعَالَ"},{"kind":"text","text":". (TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"faTaAla","text_ar":"فَطَالَ"},{"kind":"arabic","text_bw":"AlEab~aAsu Eumara","text_ar":"العَبَّاسُ عُمَرَ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"And El-'Abbás exceeded 'Omar in tallness of stature."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"TaAlahu","text_ar":"طَالَهُ"},{"kind":"arabic","text_bw":"fiY AlHasabi","text_ar":"فِى الحَسَبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He excelled him in the grounds of pretension to respect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honour"},{"kind":"text","text":"]. (K and TA in explanation of"},{"kind":"arabic","text_bw":"$arafahu","text_ar":"شَرَفَهُ"},{"kind":"text","text":": in the CK [erroneously]"},{"kind":"arabic","text_bw":"TAwalahu","text_ar":"طاوَلَهُ"},{"kind":"text","text":".)       -A3-  One says also,"},{"kind":"arabic","text_bw":"TAl Ealayohi","text_ar":"طال عَلَيْهِ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Ealayohimo","text_ar":"عَلَيْهِمْ"},{"kind":"text","text":", (Msb, K,) the verb in this case being of the class of"},{"kind":"arabic","text_bw":"qaAla","text_ar":"قَالَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTuwlu","text_ar":"يَطُولُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"TawolN","text_ar":"طَوْلٌ"},{"kind":"text","text":"; (S, * Msb;) and ↓"},{"kind":"arabic","text_bw":"tTw~l","text_ar":"تطوّل","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"ATAl","text_ar":"اطال","orth_type":"arrow"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"He bestowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conferred, a benefit"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benefits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a favour"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favours,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"upon him,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"upon them."},{"kind":"text","text":"(Msb, K.) And"},{"kind":"arabic","text_bw":"EalayonaA bi$aYo'K","text_ar":"عَلَيْنَا بِشَىْءٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tTw~l","text_ar":"تطوّل","orth_type":"arrow"},{"kind":"italic_en","text":"He gave to us a thing;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"tanaw~ala","text_ar":"تَنَوَّلَ"},{"kind":"text","text":"; but the latter is said by Aboo-Mihjen to be used only in relation to good; and the former, sometimes, in relation to good and to evil. (TA in art."},{"kind":"arabic","text_bw":"nwl","text_ar":"نول"},{"kind":"text","text":".)"}],"source_refs":["S","O","Msb","K","TA","Jel"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D8%A7%D9%84/","headword_ar":"طال","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=94028#038823","body_html":"<span class=\"title1\">طال</span><br><span>طالَ الشيْءُ يَطُوْلُ طُوْلاً. والأطْوَلُ: نَقِيْضُ الأقْصَرِ. والطوَالُ: الأهْوَجُ الطُوْلِ، وامْرَأةٌ طُوَالَةٌ. والطُوَلُ: جَمَاعَةُ الطَّوِيْلِ. والطِّيَالُ: لُغَةٌ في الطِّوَالِ. وطالَ فلان فلاناً: فاقَه في الطُوْل. والطِّوَلُ: الطَّوِيْلُ. والطَوَلُ: الحَبْلُ الطَّوِيْلُ جِدّاً. والمِطْوَلُ: الحَبْلُ يُقَيدُ به البَعِيْرُ فَيُرْخى. والطوِيْلَةُ: اسْمُ حَبْلٍ يُشَد بقائِمَةِ الدّابَةِ، ويقولونَ: طَوِّلْ لفَرَسِكَ: أي أرْخِ له. وهو - أيضاً -: قَلَنْسُوَةٌ طَوِيْلَة.</span><br><span>والكَعْبَانِ من العاجِ يُقال لهما: الطَّوِيْلَتَانِ. وطالَ طُوْلُكَ: أي تَمَادِيْكَ في الأمْرِ، ويُقال: طِيْلُكَ وطِيَلُكَ وطِوَلُكَ. وطالَ طِيْلُه: أي دَأبُه وأمْرُه. وطُوَلُه - بضَم الطاءِ - وطِوَالُه وطِيَالُه وطِيْلَتُه وطَوْلَتُه: أي عُمْرُه. </span><span>والطوْلُ: القُدْرَةُ. والفَضْلُ، إنَه لَذُوْ طَوْلٍ يَتَطَولُ عَلَي بفَضْلِهِ. والطَّوَلُ: طُوْلٌ في المِشْفَرِ الأعْلى على الأسْفَلِ، جَمَلٌ أطْوَلُ، وبه طَوَلٌ. والمُطَاوَلَةُ في الأمْرِ: مَعْرُوْفَةٌ، وهو التَّطْوِيلُ. والتطَاوُلُ: بمعنى الاسْتِطَالَةِ على النّاسِ. ويُقال للشيْءِ الخَسِيْسِ: ما فيه طائلٌ، واشْتِقَاقُه من الطوْلَ. ولا آتِيْكَ طَوَالَ الدهْرِ: أي مَدَى الدَّهْرِ. والطَّوَائلُ: الذُّحُوْلُ والترَاتُ، الواحِدَةُ طائلَة. والطُوَّلُ: طائرٌ طَويلُ الرجْلَيْنِ من طَيْرِ الماءِ، والجَمِيْعُ الطَوَاوِلُ. والطالَةُ: الأتَانُ من حُمُرِ الوَحْشِ. والطيلَةُ من الريَاحِ: التي تُنَاوِحُ الأخْرى طُوْلاً، والشَّمَالُ طَيلَةُ الدهْنَاءِ. ومن أسْمَاء الذكَرِ: المِطْوَلُ.</span>"}]}}