, "entries": [{"entry_id": "n11767", "headword_ar": "خَانٌ", "root": "xwn", "body": [{"kind": "italic_en", "text": "A place in which travellers lodge:"}, {"kind": "text", "text": "(Msb:)"}, {"kind": "italic_en", "text": "a place in which travellers pass the night:"}, {"kind": "text", "text": "and the"}, {"kind": "arabic", "text_bw": "dayor", "text_ar": "دَيْر"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "monastery,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "convent,"}, {"kind": "text", "text": "] is the"}, {"kind": "arabic", "text_bw": "xAn", "text_ar": "خان"}, {"kind": "text", "text": "of the Christians: (Kull pp. 96 and 97:) or the"}, {"kind": "arabic", "text_bw": "xAn", "text_ar": "خان"}, {"kind": "text", "text": "is"}, {"kind": "italic_en", "text": "for merchants;"}, {"kind": "text", "text": "(S, K;)"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "funoduqN", "text_ar": "فُنْدُقٌ"}, {"kind": "text", "text": "; (Har p. 325;) ["}, {"kind": "italic_en", "text": "a building for the reception of mer chants and travellers and their goods, generally surrounding a square or an oblong court, having, on the ground-floor, vaulted magazines for mer chandise, which face the court, and lodgings, or other magazines, above:"}, {"kind": "text", "text": "a Persian word, arabi cized:] pl."}, {"kind": "arabic", "text_bw": "xaAnaAtN", "text_ar": "خَانَاتٌ"}, {"kind": "text", "text": "(Msb.) ―         -b2-  Also"}, {"kind": "italic_en", "text": "A shop:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a shop-keeper:"}, {"kind": "text", "text": "(K:) a Persian word, arabicised. (TA.)       -A2-  [It is also a title of honour, used by the Tartars (who apply it to their Emperor), the"}, {"kind": "page_break", "n": 827}, {"kind": "text", "text": "Turks (who apply it to the reigning and to a deceased Sultán), and the Persians (who apply it to the governor of a province, and to a man of rank).]"}], "source_refs": ["Msb", "K"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%AE%D8%A7%D9%86/", "headword_ar": "خان", "entries": [{"lexicon_id": "dictionary_48", "lexicon_en": "Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)", "lexicon_ar": "موسوعة السلطان قابوس لأسماء العرب", "permalink": "https://arabiclexicon.hawramani.com/?p=60796#bcf9f8", "body_html": "خان<br>من(خ و ن) الفندق والحانوت والمتجر والحاكم والأمير.<br>خان<br>عن الفارسية بمعنى منزل وعش، ولقب لملوك بلاد تركستان، ولقب احترام يضاف في إيران قبل الاسم أو بعده. يستخدم للذكور."}, {"lexicon_id": "dictionary_52", "lexicon_en": "Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)", "lexicon_ar": "معجم البلدان لياقوت الحموي", "permalink": "https://arabiclexicon.hawramani.com/?p=60796#427ef8", "body_html": "خان:<br>موضع بأصبهان، وهي عجمية في الأصل، وهي المنازل التي يسكنها التجار، ينسب إليها أبو أحمد محمد بن عبد كويه الخاني الأصبهاني، ينسب إلى خان لنجان فنسب إلى شطر هذا الاسم، وهي مدينة هذا القطر كما ذكرنا قبل، وكان رجلا صالحا من وجوه هذه البلدة، ورد أصبهان وحدث بها عن البغداديين والأصبهانيين، ومات سنة 406."}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}