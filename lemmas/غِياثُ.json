"text":"or"},{"kind":"italic_en","text":"adverse circumstances."},{"kind":"text","text":"(MF.) In the T,"},{"kind":"arabic","text_bw":"AlgiyaAvu","text_ar":"الغِيَاثُ"},{"kind":"text","text":"is expl. as signifying"},{"kind":"italic_en","text":"That with which God aids,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succours, one."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"giyaAvN","text_ar":"غِيَاثٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"An aider,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a succourer:"},{"kind":"text","text":"you say,"},{"kind":"arabic","text_bw":"fulaAnN giyaAvunaA","text_ar":"فُلَانٌ غِيَاثُنَا"},{"kind":"italic_en","text":"Such a one is our aider,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succourer; i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mugiyvunaA","text_ar":"مُغِيثُنَا","orth_type":"arrow"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"nwr","text_ar":"نور"},{"kind":"text","text":":) and God is said to be"},{"kind":"arabic","text_bw":"giyaAvu Almusotagiyviyna","text_ar":"غِيَاثُ المُسْتَغِيثِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The Aider of the seekers of aid"},{"kind":"text","text":"]. (O.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"A^um~u giyaAvK","text_ar":"اُمُّ غِيَاثٍ"},{"kind":"text","text":"is a name for (assumed tropical:)"},{"kind":"italic_en","text":"The cooking-pot."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":".)"}],"source_refs":["S","MF"]},{"entry_id":"n32701","headword_ar":"غِيَاثٌ","root":"gyv","body":[{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"giwaAvN","text_ar":"غِوَاثٌ"},{"kind":"text","text":", see in art."},{"kind":"arabic","text_bw":"gwv","text_ar":"غوث"},{"kind":"text","text":"."}],"source_refs":[]}]}}