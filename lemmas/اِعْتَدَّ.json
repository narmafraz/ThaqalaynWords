reckoned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"esteemed, as of any account,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"importance:"},{"kind":"text","text":"a phrase of frequent occurrence.]       -A3-  ["},{"kind":"italic_en","text":"He made it ready, prepared it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"provided it:"},{"kind":"text","text":"] see 4. ―         -b2-  See also"},{"kind":"page_break","n":1970},{"kind":"text","text":"10.       -A4-"},{"kind":"arabic","text_bw":"AiEotad~ato","text_ar":"اِعْتَدَّتْ"},{"kind":"text","text":", said of a woman,"},{"kind":"italic_en","text":"She observed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kept, the period of her"},{"kind":"arabic","text_bw":"Eid~ap","text_ar":"عِدَّة"},{"kind":"text","text":"[q. v.]. (S, O.)"}],"source_refs":["S","O","Msb"]}]},"classical_definitions":null}