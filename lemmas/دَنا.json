role":"present_3fd","form":"تَدْنُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدْنَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدْنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدْنُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدْنُوْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُدْنَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"دَنَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَنَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَدْنُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدْنُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدْن","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدْن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُدْنَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُدْنَى","in_corpus":true,"count":72,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":98,"cross_references":{"qac":{"found":true,"lemma_key":"دَنا","root":"دنو","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n13185","n13220","n13227"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%86%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be near, be close"},{"pos":"verb","gloss":"to approach (مِن (min))","examples":[{"text":"لَا تَدْنُ مِنَ الْأَسَدِ فَيَأْكُلَكَ.","english":"Do not approach the lion lest he eat you."}]},{"pos":"verb","gloss":"to bring near (بِ (bi) someone مِن (min))"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13185","headword_ar":"دَنَاَ","root":"dnA^","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"danuw^a","text_ar":"دَنُوَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"danaA='apN","text_ar":"دَنَا=ءَةٌ"},{"kind":"text","text":", (AZ, Lh, T, S, M, Msb, K,) of the former verb, and of the latter also, (AZ, Lh, T, M,) and"},{"kind":"arabic","text_bw":"dunuwo'N","text_ar":"دُنُوْءٌ"},{"kind":"text","text":", of the former, (Fr, T,) or of the latter, (AZ, T,) and [of the latter]"},{"kind":"arabic","text_bw":"dunuwo'apN","text_ar":"دُنُوْءَةٌ"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, ignoble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean, in his actions;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"cared not for what he did, nor for what was said to him:"},{"kind":"text","text":"(ISk and T in explanation of the former verb, and S in explanation of both verbs:) or the former verb, (AZ, T,) or each, (Lh, T, M, K,)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul, in respect of the belly and the genital member"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"in respect of appetite for food and for sexual enjoyment"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"not caring for what he did, nor for what was said to him:"},{"kind":"text","text":"(AZ, Lh, T, M, K:) and the former verb, (S) or each, (M, K,) [accord. to some,]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"arabic","text_bw":"daniYo'N","text_ar":"دَنِىْءٌ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"xasiysN","text_ar":"خَسِيسٌ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"contemptible"},{"kind":"text","text":"]; (S, M, K;) like"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yadonuw","text_ar":"يَدْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"danaAwapN","text_ar":"دَنَاوَةٌ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"and destitute of good:"},{"kind":"text","text":"(S:) but some make a distinction between the verbs with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"and the verb without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; saying that the meaning “ he was, or became,"},{"kind":"arabic","text_bw":"xsys","text_ar":"خسيس"},{"kind":"text","text":"” is that of"},{"kind":"arabic","text_bw":"dnA","text_ar":"دنا"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"; (T, Msb;) and the truth is, that the verbs with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"have the meanings assigned to them by AZ and Lh; (T;) or signify"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, ignoble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean:"},{"kind":"text","text":"(Msb:) or these two verbs also signify, (K,) or signify as some say, (M,)"},{"kind":"italic_en","text":"he was one in whom was little or no good; contemned"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contemptible, mean, paltry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no weight"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worth."},{"kind":"text","text":"(M, K.)       -A2-"},{"kind":"arabic","text_bw":"daniy^a","text_ar":"دَنِيَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"danaA^o","text_ar":"دَنَاْ"},{"kind":"text","text":", (S, M,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hump-backed."},{"kind":"text","text":"(S, M, K. *)"}],"source_refs":["AZ","Lh","T","S","M","Msb","K","Fr"]},{"entry_id":"n13220","headword_ar":"دَنَا","root":"dnw","body":[{"kind":"text","text":", (T, M, Mgh, Msb, K, &c.,) first pers."},{"kind":"arabic","text_bw":"danawotu","text_ar":"دَنَوْتُ"},{"kind":"text","text":", (T, S,) aor."},{"kind":"arabic","text_bw":"yadonuw","text_ar":"يَدْنُو"},{"kind":"text","text":", (T, Msb,) inf. n."},{"kind":"arabic","text_bw":"dunuw~N","text_ar":"دُنُوٌّ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"danaAwapN","text_ar":"دَنَاوَةٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near; drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached;"},{"kind":"text","text":"(T, M, Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"AdnY","text_ar":"ادنى","orth_type":"arrow"},{"kind":"text","text":"; (IAar, T, K;) and ↓"},{"kind":"arabic","text_bw":"dn~Y","text_ar":"دنّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tadoniyapN","text_ar":"تَدْنِيَةٌ"},{"kind":"text","text":"; (IAar, T;) and ↓"},{"kind":"arabic","text_bw":"dAnY","text_ar":"دانى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mudaAnaApN","text_ar":"مُدَانَاةٌ"},{"kind":"text","text":"; (KL, but only the inf. n. is there mentioned;) and ↓"},{"kind":"arabic","text_bw":"Aid~anaY","text_ar":"اِدَّنَى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Aid~inaA='N","text_ar":"اِدِّنَا=ءٌ"},{"kind":"text","text":": (TA:) it is either"},{"kind":"italic_en","text":"in person,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"substance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in respect of predicament,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in place,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in time:"},{"kind":"text","text":"(El-Harállee, TA:) you say,"},{"kind":"arabic","text_bw":"danaA minohu","text_ar":"دَنَا مِنْهُ"},{"kind":"text","text":", (M, Mgh, Msb,) and"},{"kind":"arabic","text_bw":"danawotu minohu","text_ar":"دَنَوْتُ مِنْهُ"},{"kind":"text","text":", (T, S,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (M, Msb,) and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"occurs in a verse of Sá'ideh as meaning"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(T, M, Mgh, Msb:) [and in like manner you use the other verbs mentioned above, except ↓"},{"kind":"arabic","text_bw":"dAnY","text_ar":"دانى","orth_type":"arrow"},{"kind":"text","text":", which is immediately trans.: or"},{"kind":"arabic","text_bw":"danaA minohu","text_ar":"دَنَا مِنْهُ"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"danaAwapN","text_ar":"دَنَاوَةٌ"},{"kind":"text","text":"for its inf. n. means, or means also,"},{"kind":"italic_en","text":"He was near to him in respect of kindred; was related to him:"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"danaAwapN","text_ar":"دَنَاوَةٌ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"qurobaY","text_ar":"قُرْبَى"},{"kind":"text","text":": (M, K:) you say,"},{"kind":"arabic","text_bw":"bayonahumaA danaAwapN","text_ar":"بَيْنَهُمَا دَنَاوَةٌ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Between them two is relationship"},{"kind":"text","text":"]; (S;) and"},{"kind":"arabic","text_bw":"maA tazodaAdu min~aA A_il~aA qurobFA wadanaAwapK","text_ar":"مَا تَزْدَادُ مِنَّا اـِلَّا قُرْبًا وَدَنَاوَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou increasest not save in nearness and relationship to us"},{"kind":"text","text":"]. (ISk, T, S.) A rájiz says,"},{"kind":"quote","text":"maA liY A^araAhu daAlifFA qadodunoYa lahu"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"duniYa lahu","text_ar":"دُنِىَ لَهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"What hath happened to me"},{"kind":"text","text":"that"},{"kind":"italic_en","text":"I see him walking gently"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with short steps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered lowly by age, having been approached"},{"kind":"text","text":"by death?]: it is from"},{"kind":"arabic","text_bw":"danawotu","text_ar":"دَنَوْتُ"},{"kind":"text","text":", but the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"because of the kesreh before it, and then the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"is made quiescent: and there are similar instances of contraction of verbs: but [ISd says,] I know not"},{"kind":"arabic","text_bw":"dunoYa","text_ar":"دُنْىَ"},{"kind":"text","text":"except in this instance; and As used to say of the poem in which this occurs, This rejez is not ancient: it is app. of Khalaf ElAhmar or some other of the Muwelleds. (M.) One says also,"},{"kind":"arabic","text_bw":"danati Al$~amosu lilomaguruwbi","text_ar":"دَنَتِ الشَّمْسُ لِلْمَغُرُوبِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^adonat","text_ar":"اَدْنَت","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The sun was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, near to setting"},{"kind":"text","text":"]. (M.)       -A2-"},{"kind":"arabic","text_bw":"daniYa","text_ar":"دَنِىَ"},{"kind":"text","text":", (T, M, K, TA, [in the CK,"},{"kind":"arabic","text_bw":"mA kAna danoyaA","text_ar":"ما كانَ دَنْيَا"},{"kind":"arabic","text_bw":"wlqd danA","text_ar":"ولقد دَنا"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"maA kaAna daniyFA walaqado","text_ar":"مَا كَانَ دَنِيًا وَلَقَدْ"},{"kind":"arabic","text_bw":"daniYa","text_ar":"دَنِىَ"},{"kind":"text","text":",]) like"},{"kind":"arabic","text_bw":"raDiYa","text_ar":"رَضِىَ"},{"kind":"text","text":", (TA,) aor."},{"kind":"arabic","text_bw":"yadonaY","text_ar":"يَدْنَى"},{"kind":"text","text":", (T,) inf. n."},{"kind":"arabic","text_bw":"danFA","text_ar":"دَنًا"},{"kind":"text","text":"(T, M, K) and"},{"kind":"arabic","text_bw":"danaAyapN","text_ar":"دَنَايَةٌ"},{"kind":"text","text":", (T, K, TA,) or"},{"kind":"arabic","text_bw":"dinaAyapN","text_ar":"دِنَايَةٌ"},{"kind":"text","text":"; (M, accord. to the TT; and so in the CK; [app. a mistranscription occasioned by a misunderstanding of what here follows;]) the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"[in"},{"kind":"arabic","text_bw":"daniYa","text_ar":"دَنِىَ"},{"kind":"text","text":"] being substituted for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"because of the nearness of the kesreh; all on the authority of Lh; (M;) and"},{"kind":"arabic","text_bw":"danuwa","text_ar":"دَنُوَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yadonuw","text_ar":"يَدْنُو"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"danaA='apN","text_ar":"دَنَا=ءَةٌ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", (ISk, T,) and"},{"kind":"arabic","text_bw":"dunuw~N","text_ar":"دُنُوٌّ"},{"kind":"text","text":"; (T;) or"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yadonuw","text_ar":"يَدْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"danaAwapN","text_ar":"دَنَاوَةٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"danaA^a","text_ar":"دَنَاَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"danuw^a","text_ar":"دَنُوَ"},{"kind":"text","text":"; (Msb;) [i. e.]"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, T, M)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, such as is termed"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"daniY~N","text_ar":"دَنِىٌّ","orth_type":"arrow"},{"kind":"text","text":"; (T, M, Msb, K;) and"},{"kind":"arabic","text_bw":"daniYo'N","text_ar":"دَنِىْءٌ"},{"kind":"text","text":"; (Msb;) meaning"},{"kind":"italic_en","text":"weak; contemptible"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xasiysN","text_ar":"خَسِيسٌ"},{"kind":"text","text":");"},{"kind":"italic_en","text":"not profitable to any one; who falls short in everything upon which he enters:"},{"kind":"text","text":"(T: [like"},{"kind":"arabic","text_bw":"mudan~K","text_ar":"مُدَنٍّ"},{"kind":"text","text":":]) or"},{"kind":"italic_en","text":"low, ignoble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean;"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAqiTN","text_ar":"سَاقِطٌ"},{"kind":"text","text":";)"},{"kind":"italic_en","text":"weak;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"such as, when night affords him covert, will not quit his place, by reason of weakness:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"low, ignoble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"lay^iymN","text_ar":"لَيِيمٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in his actions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conduct; bad, evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foul;"},{"kind":"text","text":"accord. to the explanation of"},{"kind":"arabic","text_bw":"danaA","text_ar":"دَنَا"},{"kind":"text","text":"by Es-Sarakustee: but some distinguish between"},{"kind":"arabic","text_bw":"daniYo'N","text_ar":"دَنِىْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daniY~N","text_ar":"دَنِىٌّ"},{"kind":"text","text":"; making the former to signify “ low, ignoble, or mean; ” ("},{"kind":"arabic","text_bw":"lay^iymN","text_ar":"لَيِيمٌ"},{"kind":"text","text":";) and the latter,"},{"kind":"arabic","text_bw":"xasiysN","text_ar":"خَسِيسٌ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"contemptible"},{"kind":"text","text":"]. (Msb, and so the latter is explained in the Mgh.)"},{"kind":"page_break","n":921}],"source_refs":["T","S","Msb","M","K","TA","Mgh","ISk"]},{"entry_id":"n13227","headword_ar":"دَنًا","root":"dnw","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"daniYa","text_ar":"دَنِىَ"},{"kind":"text","text":", q. v. (T, M, K.)       -A2-"},{"kind":"arabic","text_bw":"A^adonaY danFA","text_ar":"اَدْنَى دَنًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"AdnY","text_ar":"ادنى"},{"kind":"text","text":"."}],"source_refs":[]}]}}