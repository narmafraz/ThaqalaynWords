gen":"f","num":"s"},{"role":"present_2md","form":"تُجْمِعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُجْمِعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُجْمَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُجْمَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُجْمِعُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجْمِعُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجْمَعُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجْمَعُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجْمِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُجْمَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجْمِع","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُجْمَع","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجْمِع","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُجْمَع","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجْمِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجْمِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجْمَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجْمَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجْمِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْمِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْمَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْمَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجْمِعُونَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجْمِعُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجْمَعُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجْمَعُونَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجْمِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُجْمَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُجْمِع","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْمِع","in_corpus":true,"count":35,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجْمَع","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْمَع","in_corpus":true,"count":35,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَجْمَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَجْمَعْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":249,"cross_references":{"qac":{"found":true,"lemma_key":"أَجْمَع","root":"جمع","pos":"N","occurrence_count":26},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n6307","n6325"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AC%D9%92%D9%85%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6307","headword_ar":"اجمع","root":"jmE","body":[{"kind":"text","text":": see 1."},{"kind":"arabic","text_bw":"A^ajomaEotu Al$~aYo'a","text_ar":"اَجْمَعْتُ الشَّىْءَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I put the thing together;"},{"kind":"text","text":"such, for instance, as spoil, or plunder. (S.) You say,"},{"kind":"arabic","text_bw":"A^ajomaEotu Aln~ahobi","text_ar":"اَجْمَعْتُ النَّهْبِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I collected together from every quarter the camels taken as spoil from the people to whom they belonged, and drove them away:"},{"kind":"text","text":"(AHeyth:) or"},{"kind":"arabic","text_bw":"A_ijomaAEN","text_ar":"اـِجْمَاعٌ"},{"kind":"text","text":"signifies [simply] the"},{"kind":"italic_en","text":"driving"},{"kind":"text","text":"of camels"},{"kind":"italic_en","text":"together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collectively."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"AlA_ijomaAEu","text_ar":"الاـِجْمَاعُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"The composing and settling a thing which has been discomposed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and unsettled"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"as an opinion upon which one determines, resolves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decides:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"jaEolu AlA^amori jamiyEFA baEoda tafar~uqihi","text_ar":"جَعْلُ الاَمْرِ جَمِيعًا بَعْدَ تَفَرُّقِهِ"},{"kind":"text","text":", (AHeyth, K,) i. e."},{"kind":"italic_en","text":"the determining, resolving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deciding, upon an affair, so as to make it firmly settled,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after it had been unsettled in the mind,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"after considering what might be its issues, or results, and saying at one time, I will do thus, and at another time, I will do thus."},{"kind":"text","text":"(AHeyth.) You say,"},{"kind":"arabic","text_bw":"A^ajomaEotu AlA^amora","text_ar":"اَجْمَعْتُ الاَمْرَ"},{"kind":"text","text":", (Ks, S, Mgh, * Msb, K,) and"},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"text","text":", (Mgh, * Msb, K,)"},{"kind":"italic_en","text":"I determined, resolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decided, upon the affair;"},{"kind":"text","text":"(Ks, S, Mgh, * Msb, K;) as though I collected myself, or my mind, for it; (TA;) as, for instance, a journeying, and a fasting, (Mgh, Msb,) and a going forth, and a tarrying or an abiding; (TA;) and in like manner,"},{"kind":"arabic","text_bw":"A^amorahu","text_ar":"اَمْرَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jamaEa","text_ar":"جَمَعَ","orth_type":"arrow"},{"kind":"italic_en","text":"He determined, resolved, or decided, upon his affair;"},{"kind":"text","text":"as, for instance, a fasting: (TA:) and"},{"kind":"arabic","text_bw":"A^ajomaEotu Alr~aA^oYi","text_ar":"اَجْمَعْتُ الرَّاْىِ"},{"kind":"italic_en","text":"I determined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled, the opinion."},{"kind":"text","text":"(TA.) You say also,"},{"kind":"arabic","text_bw":"A^ajomiEo A^amoraka walaA tadaEohu munota$irFA","text_ar":"اَجْمِعْ اَمْرَكَ وَلَا تَدَعْهُ مُنْتَشِرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Determine thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decide, upon thine affair, and do not leave it unsettled"},{"kind":"text","text":"]. (S.) The saying, in the Kur [x. 72],"},{"kind":"arabic","text_bw":"faA^ajomaEuwA A^amorakumo wa$urakaA='a kumo","text_ar":"فَاَجْمَعُوا اَمْرَكُمْ وَشُرَكَا=ءَ كُمْ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Then determine ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resolve,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decide, upon your affair,"},{"kind":"text","text":"(Fr, Ibn-'Arafeh, Bd,)"},{"kind":"italic_en","text":"and prepare for it,"},{"kind":"text","text":"(Fr,) or"},{"kind":"arabic","text_bw":"AijoEaluwhu jamiyEFA","text_ar":"اِجْعَلُوهُ جَمِيعًا"},{"kind":"text","text":", [which has the former of these meanings, as shown above,] (AHeyth,)"},{"kind":"italic_en","text":"and call ye your companions,"},{"kind":"text","text":"(Fr, S, Bd, K,)"},{"kind":"arabic","text_bw":"$rkA'km","text_ar":"شركاءكم"},{"kind":"text","text":"being governed in the accus. case by the verb understood, (Bd, TA,) becanse the verb in the text is not used with"},{"kind":"arabic","text_bw":"$rkA'","text_ar":"شركاء"},{"kind":"text","text":"for its object, (S, K,) but only the unaugmented verb: (S:) or the meaning is"},{"kind":"italic_en","text":"then determine ye, with your companions, upon your affair;"},{"kind":"text","text":"(Bd, K;) so says Aboo-Is-hák, adding that what Fr says is erroneous: (TA:) or"},{"kind":"italic_en","text":"then determine ye upon your affair and"},{"kind":"text","text":"the affair of"},{"kind":"italic_en","text":"your companions,"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"waA^amora","text_ar":"وَاَمْرَ"},{"kind":"arabic","text_bw":"$urakaAy^ikumo","text_ar":"شُرَكَايِكُمْ"},{"kind":"text","text":". (Bd.) It is also said that the phrase, in the Kur [xx. 67],"},{"kind":"arabic","text_bw":"faA^ajomiEuwA kayodakumo","text_ar":"فَاَجْمِعُوا كَيْدَكُمْ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Therefore determine ye, or resolve, or decide, upon your artifice, or stratagem:"},{"kind":"text","text":"(TA:) but some read"},{"kind":"arabic","text_bw":"kayodakumo","text_ar":"كَيْدَكُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"faA@jomaEuwA","text_ar":"فَا@جْمَعُوا","orth_type":"arrow"},{"kind":"text","text":", (Bd, TA,) meaning"},{"kind":"italic_en","text":"therefore combine ye all your artifice; leave nothing thereof unexerted;"},{"kind":"text","text":"(TA;) and this latter reading is favoured by the phrase"},{"kind":"arabic","text_bw":"kayodahu","text_ar":"كَيْدَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fajamaE","text_ar":"فَجَمَع","orth_type":"arrow"},{"kind":"text","text":"[in verse 62 of the same ch.]. (Bd.) ―         -b3-  Also"},{"kind":"italic_en","text":"The agreeing, or uniting, in opinion."},{"kind":"text","text":"(K, * TA.) You say,"},{"kind":"arabic","text_bw":"A^ajomaEuwA EalaY AlA^amori","text_ar":"اَجْمَعُوا عَلَى الاَمْرِ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"They agreed, or were of one mind"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting, the affair;"},{"kind":"text","text":"(Mgh, Msb;) [and so"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjtmEwA","text_ar":"اجتمعوا","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"page_break","n":456},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjm~EwA","text_ar":"تجمّعوا","orth_type":"arrow"},{"kind":"text","text":".] ―         -b4-  Also"},{"kind":"italic_en","text":"The preparing"},{"kind":"text","text":"[a thing], or"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"[it]"},{"kind":"italic_en","text":"ready;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AlA_iEodaAdu","text_ar":"الاـِعْدَادُ"},{"kind":"text","text":". (K, TA. [In the CK, erroneously,"},{"kind":"arabic","text_bw":"AlAaEodaAdu","text_ar":"الاَعْدَادُ"},{"kind":"text","text":".]) You say,"},{"kind":"arabic","text_bw":"A^ajomaEotu ka*aA","text_ar":"اَجْمَعْتُ كَذَا"},{"kind":"italic_en","text":"I prepared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made ready, such a thing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^ajomiEuwA A^amorakumo","text_ar":"اَجْمِعُوا اَمْرَكُمْ"},{"kind":"italic_en","text":"Prepare ye for your affair."},{"kind":"text","text":"(Fr.) ―         -b5-  Also"},{"kind":"italic_en","text":"The binding the teats of a she-camel all together with"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"SiraAr","text_ar":"صِرَار"},{"kind":"text","text":", q. v. (K.) You say,"},{"kind":"arabic","text_bw":"AjmE biAln~aAqapi","text_ar":"اجمع بِالنَّاقَةِ"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"AjmE Aln~aAqapi","text_ar":"اجمع النَّاقَةِ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He so bound the teats of the she-camel;"},{"kind":"text","text":"(S, TA;) and so"},{"kind":"arabic","text_bw":"A^akoma$a bihaA","text_ar":"اَكْمَشَ بِهَا"},{"kind":"text","text":". (TA.) ―         -b6-  Also"},{"kind":"italic_en","text":"The drying"},{"kind":"text","text":"[a thing];"},{"kind":"italic_en","text":"drying"},{"kind":"text","text":"[it]"},{"kind":"italic_en","text":"up; making"},{"kind":"text","text":"[it]"},{"kind":"italic_en","text":"dry;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Alt~ajofiyfu waAlA_iybaAsu","text_ar":"التَّجْفِيفُ وَالاـِيبَاسُ"},{"kind":"text","text":". (K TA. [In the CK, erroneously,"},{"kind":"arabic","text_bw":"Altaxofuyfu wAlAiyonAsu","text_ar":"التَخْفُيفُ والاِيْناسُ"},{"kind":"text","text":".]) Hence the saying of Aboo-Wejzeh Es-Saadee,"},{"kind":"quote","text":"waA^ajomaEati AlhawaAjiru kul~a rajoEK\n                      \n                     \n                        mina AlA^ajomaAdi waAld~amivi AlbavaA='i"},{"kind":"text","text":"i.e. ["},{"kind":"italic_en","text":"And the vehement mid-day-heats"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"dried up every pool left by a torrent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the hard and elevated grounds and of the soft and even ground"},{"kind":"text","text":"]. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"AjmE AlmaTaru AlA^aroDi","text_ar":"اجمع المَطَرُ الاَرْضِ"},{"kind":"italic_en","text":"The rain made the whole of the land, both its soft tracts and its hard tracts, to flow:"},{"kind":"text","text":"(K:) and in like manner you say,"},{"kind":"arabic","text_bw":"A^ajomaEati AlA^aroDu saAy^ilapF","text_ar":"اَجْمَعَتِ الاَرْضُ سَايِلَةً"},{"kind":"italic_en","text":"The land flowed in its soft tracts"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as well as in its hard tracts;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"in every part"},{"kind":"text","text":"]. (TA.) [See also 10.]"}],"source_refs":["AHeyth","TA","K","Mgh","Msb","Fr","S","Bd"]},{"entry_id":"n6325","headword_ar":"اَجْمَعُ","root":"jmE","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Collecting, comprising,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"containing, a greater,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the greatest, number"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quantity; more,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, comprehensive."},{"kind":"text","text":"Of its usage in a superlative sense, the following are exs.]."},{"kind":"arabic","text_bw":"A_i*aA A^axa*a","text_ar":"اـِذَا اَخَذَ"},{"kind":"arabic","text_bw":"$aAhida zuwrK baEava bihi A_ilaY Als~uwqi A^ajomaEa maA kaAna","text_ar":"شَاهِدَ زُورٍ بَعَثَ بِهِ اـِلَى السُّوقِ اَجْمَعَ مَا كَانَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When he took a false witness, he sent him to the market when it comprised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contained, the greatest number"},{"kind":"text","text":"of people]:"},{"kind":"arabic","text_bw":"AjmE","text_ar":"اجمع"},{"kind":"text","text":"being here in the accus. case as a denotative of state with respect to the"},{"kind":"arabic","text_bw":"swq","text_ar":"سوق"},{"kind":"text","text":": and the reason why"},{"kind":"arabic","text_bw":"kAnt","text_ar":"كانت"},{"kind":"text","text":"is not here said [instead of"},{"kind":"arabic","text_bw":"kAn","text_ar":"كان"},{"kind":"text","text":"] is that"},{"kind":"arabic","text_bw":"swq","text_ar":"سوق"},{"kind":"text","text":"is sometimes masc. (Mgh.) And"},{"kind":"arabic","text_bw":"AifoEalo maA huwa A^ajomaEu liA^uSuwli AlA^aHokaAmi","text_ar":"اِفْعَلْ مَا هُوَ اَجْمَعُ لِاُصُولِ الاَحْكَامِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Do thou that which is most comprehensive in relation to the principles of the ordinances"},{"kind":"text","text":"applying to the case]. (Msb in art."},{"kind":"arabic","text_bw":"HwT","text_ar":"حوط"},{"kind":"text","text":".)       -A2-  [As a simple epithet,"},{"kind":"italic_en","text":"Entire, complete,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whole:"},{"kind":"text","text":"fem."},{"kind":"arabic","text_bw":"jamoEaA='u","text_ar":"جَمْعَا=ءُ"},{"kind":"text","text":". You say,]"},{"kind":"arabic","text_bw":"bahiymapN jamoEaA='u","text_ar":"بَهِيمَةٌ جَمْعَا=ءُ"},{"kind":"italic_en","text":"A beast free from defects, entire in all its limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members, without mutilation, and without cauterization;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"a beast from the body of which nothing has gone."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"naAqapN jamoEaA='u","text_ar":"نَاقَةٌ جَمْعَا=ءُ"},{"kind":"text","text":"[may sometimes have the like meaning: or,] accord. to IAar, (TA,)"},{"kind":"italic_en","text":"A she-camel extremely aged,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"so that her teeth have become short, and almost gone."},{"kind":"text","text":"(TA.)       -A3-  It is also a sing. having the meaning of a pl., (S, K,) without any proper sing. of its own: (S:) its pl. is"},{"kind":"arabic","text_bw":"A^ajomaEuwna","text_ar":"اَجْمَعُونَ"},{"kind":"text","text":": and its fem. is"},{"kind":"arabic","text_bw":"jamoEaA='u","text_ar":"جَمْعَا=ءُ"},{"kind":"text","text":": (S, K:) and the pl. of this last is"},{"kind":"arabic","text_bw":"jumaEu","text_ar":"جُمَعُ"},{"kind":"text","text":", though by rule it should be formed by the addition of"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"to the sing., like as the pl. of"},{"kind":"arabic","text_bw":"A^ajomaEu","text_ar":"اَجْمَعُ"},{"kind":"text","text":"is formed by the addition of"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"; (S;) the original form from which"},{"kind":"arabic","text_bw":"jumaEu","text_ar":"جُمَعُ"},{"kind":"text","text":"is changed being"},{"kind":"arabic","text_bw":"jamoEaAwaAtN","text_ar":"جَمْعَاوَاتٌ"},{"kind":"text","text":"; or it is"},{"kind":"arabic","text_bw":"jamaAEaY","text_ar":"جَمَاعَى"},{"kind":"text","text":"; it is not"},{"kind":"arabic","text_bw":"jumoEN","text_ar":"جُمْعٌ"},{"kind":"text","text":", because"},{"kind":"arabic","text_bw":"A^ajomaEu","text_ar":"اَجْمَعُ"},{"kind":"text","text":"is not an epithet, like as"},{"kind":"arabic","text_bw":"A^aHomaru","text_ar":"اَحْمَرُ"},{"kind":"text","text":"is, of which the pl. is"},{"kind":"arabic","text_bw":"HumorN","text_ar":"حُمْرٌ"},{"kind":"text","text":"; (L;) for it is determinate, though of the measure of an epithet, which is indeterminate; (AAF;) and though it is in concordance with the noun which precedes it, like an epithet, it is shown to be not an epithet by its not having a broken pl.: (L:) it is a simple corroborative; (S, K;) and so are"},{"kind":"arabic","text_bw":"A^ajomaEuwna","text_ar":"اَجْمَعُونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jamoEaA='u","text_ar":"جَمْعَا=ءُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jumaEu","text_ar":"جُمَعُ"},{"kind":"text","text":"; not used as an inchoative nor as an enunciative nor as the agent of a verb nor as the objective complement of a verb, like as are some other corroboratives, such as"},{"kind":"arabic","text_bw":"nafosuhu","text_ar":"نَفْسُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eayonuhu","text_ar":"عَيْنُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kul~uhu","text_ar":"كُلُّهُ"},{"kind":"text","text":". (S.) You say,"},{"kind":"arabic","text_bw":"A^axa*otu Haq~iY A^ajomaEa","text_ar":"اَخَذْتُ حَقِّى اَجْمَعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I took my right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, all of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altogether"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"rA^ayotu","text_ar":"راَيْتُ"},{"kind":"arabic","text_bw":"Aln~isowapa jumaEa","text_ar":"النِّسْوَةَ جُمَعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw the women, all of them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]: the last word in this and similar cases being imperfectly declinable, and determinate word: (Sudot;, TA:) and"},{"kind":"arabic","text_bw":"jaAw^uwA A^ajomaEuwna","text_ar":"جَاوُوا اَجْمَعُونَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They came, all of them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"raA^ayotuhumo A^ajomaEiyna","text_ar":"رَاَيْتُهُمْ اَجْمَعِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I saw them, all of them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"mararotu bihimo A^ajomaEiyna","text_ar":"مَرَرْتُ بِهِمْ اَجْمَعِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I passed by them, all of them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]. (Msb.) Fr mentions the phrases,"},{"kind":"arabic","text_bw":"A^aEojabaniY AlqaSoru A^ajomaEa","text_ar":"اَعْجَبَنِى القَصْرُ اَجْمَعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The palace pleased me, all of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altogether"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"Ald~aAru jamoEaA='a","text_ar":"الدَّارُ جَمْعَا=ءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The house,"},{"kind":"page_break","n":459},{"kind":"italic_en","text":"all of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altogether"},{"kind":"text","text":"], with the accus. case, as denotative of state; but does not allow"},{"kind":"arabic","text_bw":"A^ajomaEuwna","text_ar":"اَجْمَعُونَ"},{"kind":"text","text":"nor"},{"kind":"arabic","text_bw":"jumaEu","text_ar":"جُمَعُ"},{"kind":"text","text":"to be used otherwise than as corroboratives: IDrst, however, allows"},{"kind":"arabic","text_bw":"A^ajomaEiyna","text_ar":"اَجْمَعِينَ"},{"kind":"text","text":"to be used as a denotative of state; and this is correct; and accord. to both these ways is related the trad.,"},{"kind":"arabic","text_bw":"faSal~uwA juluwsFA A^ajomaEiyna","text_ar":"فَصَلُّوا جُلُوسًا اَجْمَعِينَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ajomaEuwna","text_ar":"اَجْمَعُونَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And pray ye sitting, all of you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]; though some make"},{"kind":"arabic","text_bw":"AjmEyn","text_ar":"اجمعين"},{"kind":"text","text":"[here] to be a corroborative of a pronoun understood in the accus. case, as though the speaker said,"},{"kind":"arabic","text_bw":"A^aEoniykumo A^ajomaEiyna","text_ar":"اَعْنِيكُمْ اَجْمَعِينَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I mean you, all of you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together"},{"kind":"text","text":"]: (K"},{"kind":"italic_en","text":"in art."},{"kind":"arabic","text_bw":"btE","text_ar":"بتع"},{"kind":"text","text":":) or"},{"kind":"arabic","text_bw":"AjmEyn","text_ar":"اجمعين"},{"kind":"text","text":"in this case is a corruption committed by the relaters in the first age; and he is in error who says that it is in the accus. case as a denotative of state, for corroboratives are determinate, and the denotative of state is literally or virtually indeterminate. (Msb.) [Respecting the usage of this corroborative together with others similar to it, see"},{"kind":"arabic","text_bw":"A^abotaEu","text_ar":"اَبْتَعُ"},{"kind":"text","text":".] You say also,"},{"kind":"arabic","text_bw":"jaAw^uwA","text_ar":"جَاوُوا"},{"kind":"arabic","text_bw":"biA^ajomaEihimo","text_ar":"بِاَجْمَعِهِمْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biA^ajomuEihimo","text_ar":"بِاَجْمُعِهِمْ"},{"kind":"text","text":", with damm to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"They came, all of them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"all together,"},{"kind":"text","text":"] (S, Msb, K,) the latter mentioned by ISk. (Msb.) And you say,"},{"kind":"arabic","text_bw":"qabaDotu AlmaAla A^ajomaEahu","text_ar":"قَبَضْتُ المَالَ اَجْمَعَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I took,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received, the property, all of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"altogether"},{"kind":"text","text":"]. (Msb.) And ↓"},{"kind":"arabic","text_bw":"jamiyEN","text_ar":"جَمِيعٌ","orth_type":"arrow"},{"kind":"text","text":", also, is used as a corroborative: (S, Msb:) as in the saying"},{"kind":"arabic","text_bw":"jaAw^uwA jamiyEFA","text_ar":"جَاوُوا جَمِيعًا"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"They came, all of them:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"qabaDotu AlmaAla jamiyEahu","text_ar":"قَبَضْتُ المَالَ جَمِيعَهُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A^ajomaEahu","text_ar":"اَجْمَعَهُ"},{"kind":"text","text":"[explained above]: (Msb:) and"},{"kind":"arabic","text_bw":"jamiyEapF","text_ar":"جَمِيعَةً"},{"kind":"text","text":"occurs as its fem.; but this is extr. (TA.)"}],"source_refs":["TA","K","S","L","Msb"]}]}}