gy":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n36065"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D9%82%D9%8E%D9%84%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36065","headword_ar":"انقلب","root":"qlb","body":[{"kind":"text","text":", of which"},{"kind":"arabic","text_bw":"munoqalabN","text_ar":"مُنْقَلَبٌ"},{"kind":"text","text":"is an inf. n., (S, O, K, TA,) syn. with"},{"kind":"arabic","text_bw":"AinqilaAbN","text_ar":"اِنقِلَابٌ"},{"kind":"text","text":", (TA,) and also a n. of place, (S, O, K, TA,) like"},{"kind":"arabic","text_bw":"munoSarafN","text_ar":"مُنْصَرَفٌ"},{"kind":"text","text":", (S, O, TA,) is quasi-pass. of"},{"kind":"arabic","text_bw":"qalabotuhu","text_ar":"قَلَبْتُهُ"},{"kind":"text","text":": (S, O:) it signifies"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, altered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"changed, from its,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his, mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of being:"},{"kind":"text","text":"(TA:) [and hence,]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became inverted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned upside-down"},{"kind":"text","text":"[&c.: see 1]. (S.) ―         -b2-  And [hence]"},{"kind":"arabic","text_bw":"AlAinoqilaAbu A_ilaY A@ll~`hi","text_ar":"الاِنْقِلَابُ اـِلَى ا@للّٰهِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The transition,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the being translated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, to God, by death:"},{"kind":"text","text":"and [in like manner]"},{"kind":"arabic","text_bw":"Almunoqalabu","text_ar":"المُنْقَلَبُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the transition"},{"kind":"text","text":"[&c.], of men, to the final abode. (TA. [See an ex. in p. 132, sec. col., from the Kur xxvi. last verse.]) ―         -b3-  And"},{"kind":"arabic","text_bw":"AlAinoqilaAbu","text_ar":"الاِنْقِلَابُ"},{"kind":"text","text":"means also (assumed tropical:)"},{"kind":"italic_en","text":"The returning,"},{"kind":"text","text":"in an absolute sense: and, as also"},{"kind":"arabic","text_bw":"Almunoqalabu","text_ar":"المُنْقَلَبُ"},{"kind":"text","text":", particularly, from a journey, and to one's home: thus, in a trad., in the prayer relating to journeying,"},{"kind":"arabic","text_bw":"A^uEuw*u bika mino","text_ar":"اُعُوذُ بِكَ مِنْ"},{"kind":"arabic","text_bw":"kaA=bapi Almunoqalabi","text_ar":"كَا=بَةِ المُنْقَلَبِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I seek protection by Thee from the being in an evil state in respect of the returning"},{"kind":"text","text":"from my journeying to my home]; i. e., from my returning to my dwelling and seeing what may grieve me. (TA.) The saying in the Kur xxii. 11"},{"kind":"arabic","text_bw":"waA_ino A^aSaAbatohu fitonapN A@noqalaba EalaY wajohihi","text_ar":"وَاـِنْ اَصَابَتْهُ فِتْنَةٌ ا@نْقَلَبَ عَلَى وَجْهِهِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"And if trial befall him,"},{"kind":"text","text":"and [particularly such as] disease in himself and his cattle,"},{"kind":"italic_en","text":"he returns"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to his former way,"},{"kind":"text","text":"i. e., in this case,]"},{"kind":"italic_en","text":"to infidelity."},{"kind":"text","text":"(Jel. [See also other exs. in the Kur in ii. 138 and iii. 138.]) And one says,"},{"kind":"arabic","text_bw":"Anqlb Eani AlEahodi","text_ar":"انقلب عَنِ العَهْدِ"},{"kind":"text","text":"[meaning (assumed tropical:)"},{"kind":"italic_en","text":"He withdrew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receded, from the covenant, compact, agreement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"engagement"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"Hwl","text_ar":"حول"},{"kind":"text","text":".) [See also an ex. from the Kur-án (lxvii. 4) voce"},{"kind":"arabic","text_bw":"xaAsiy^N","text_ar":"خَاسِيٌ"},{"kind":"text","text":".]"}],"source_refs":["S","O","K","TA"]}]},"classical_definitions":null}