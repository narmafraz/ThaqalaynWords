n":"m","num":"p"},{"role":"present_2mp","form":"تَصْهَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْهَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْهَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْهَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْهَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"صَهَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَهَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْهَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْهَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"صَهَرَ","root":"صهر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n25066"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%87%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to smelt"},{"pos":"verb","gloss":"to cook thoroughly, to broil"},{"pos":"noun","gloss":"verbal noun of صَهَرَ (ṣahara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"relatedness by marriage, affinity","tags":["uncountable"]},{"pos":"noun","gloss":"a relative through marriage, an in-law","tags":["countable"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25066","headword_ar":"صَهَرَ","root":"Shr","body":[{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SahorN","text_ar":"صَهْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He melted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liquefied,"},{"kind":"text","text":"a thing, (S, A, K,) such as fat, (A, TA,) and the like; (TA;) as also ↓"},{"kind":"arabic","text_bw":"ASThr","text_ar":"اصطهر","orth_type":"arrow"},{"kind":"text","text":". (K.) The saying"},{"kind":"arabic","text_bw":"laA^aSoharan~aka biyamiynK mur~apK","text_ar":"لَاَصْهَرَنَّكَ بِيَمِينٍ مُرَّةٍ"},{"kind":"text","text":"app. means (assumed tropical:)"},{"kind":"italic_en","text":"I will assuredly melt thee"},{"kind":"text","text":"[in the fire of Hell"},{"kind":"italic_en","text":"by"},{"kind":"text","text":"making thee to swear"},{"kind":"italic_en","text":"a bitter oath"},{"kind":"text","text":"]: (S:) or (tropical:)"},{"kind":"italic_en","text":"I will assuredly make thee to swear a hard oath."},{"kind":"text","text":"(A.) One says also,"},{"kind":"arabic","text_bw":"Saharotu fulaAnFA biyamiynK kaA*ibapK","text_ar":"صَهَرْتُ فُلَانًا بِيَمِينٍ كَاذِبَةٍ"},{"kind":"arabic","text_bw":"tuwojibu lahu Aln~aAra","text_ar":"تُوْجِبُ لَهُ النَّارَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I caused such a one to melt, by"},{"kind":"text","text":"making him to swear"},{"kind":"italic_en","text":"a false oath that would procure for him, as a consequence thereof, the fire"},{"kind":"text","text":"of Hell]. (AO.) ―         -b2-  Also, inf. n. as above,"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, burned: he thoroughly cooked"},{"kind":"text","text":"with fire. (TA.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(heat)"},{"kind":"italic_en","text":"affected him severely."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"Saharatohu Al$~amosu","text_ar":"صَهَرَتْهُ الشَّمْسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The sun affected him severely by its heat,"},{"kind":"text","text":"(S, * A, K, * TA,)"},{"kind":"italic_en","text":"so that it pained his brain."},{"kind":"text","text":"(TA.) Ibn-Ahmar says, describing the young one of a"},{"kind":"arabic","text_bw":"qaTaAp","text_ar":"قَطَاة"},{"kind":"text","text":", (S, O,) which was bearing water to it, (O,)"},{"kind":"quote","text":"tarowiY laqFY A^uloqiYa fiY SafoSafK\n                      \n                     ↓ \n      taSoharuhu Al$~amosu famaA yanoSahiro"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"She bearing water to a castaway, cast upon a plain,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which the sun was melting,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"severely affecting,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which did not melt,"},{"kind":"text","text":"meaning]"},{"kind":"italic_en","text":"which endured the sun's melting it."},{"kind":"text","text":"(S, * O. [In both of my copies of the S, and in the O and TA, the first word is"},{"kind":"arabic","text_bw":"tarowiY","text_ar":"تَرْوِى"},{"kind":"text","text":", as above; not"},{"kind":"arabic","text_bw":"turowiY","text_ar":"تُرْوِى"},{"kind":"text","text":".]) And you say,"},{"kind":"arabic","text_bw":"Sahara AlHar~u AlHirobaA='a","text_ar":"صَهَرَ الحَرُّ الحِرْبَا=ءَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The heat made the chameleon's back to glisten."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Sahara xubozahu","text_ar":"صَهَرَ خُبْزَهُ"},{"kind":"italic_en","text":"He seasoned his bread with"},{"kind":"arabic","text_bw":"SuhaArap","text_ar":"صُهَارَة"},{"kind":"text","text":", (AZ, A, TA,) i. e."},{"kind":"italic_en","text":"melted fat."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"Sahara raA^osahu","text_ar":"صَهَرَ رَاْسَهُ"},{"kind":"italic_en","text":"He anointed his head with"},{"kind":"arabic","text_bw":"SuhaArap","text_ar":"صُهَارَة"},{"kind":"text","text":". (A, K.) And"},{"kind":"arabic","text_bw":"Sahara badanahu","text_ar":"صَهَرَ بَدَنَهُ"},{"kind":"italic_en","text":"He anointed his body with"},{"kind":"arabic","text_bw":"Sahiyr","text_ar":"صَهِير"},{"kind":"text","text":"[which is like"},{"kind":"arabic","text_bw":"SuhaArap","text_ar":"صُهَارَة"},{"kind":"text","text":"]. (L, TA.)       -A2-"},{"kind":"arabic","text_bw":"Saharahu","text_ar":"صَهَرَهُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He brought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, it"},{"kind":"text","text":"(i. e. a thing, O)"},{"kind":"italic_en","text":"near,"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"AShrhu","text_ar":"اصهرهُ","orth_type":"arrow"},{"kind":"text","text":". (O, TA.)"}],"source_refs":["S","A","K","TA","O","AZ"]}]},"classical_definitions":null}