"form":"تَرْمِم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرْمُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرِمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرِمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرُمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرُمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرِمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرِمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرُمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرُمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرِمُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِمُّونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرُمُّونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرُمُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْمِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرْمُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرِمّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرِمّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرُمّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُمّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَمَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَمَمْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":44,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["","n16565","n16566","n16567"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fix, to repair, to correct","tags":["transitive"]},{"pos":"verb","gloss":"to be cut","tags":["intransitive","usually"]},{"pos":"verb","gloss":"to decay, to rot, to decompose","tags":["intransitive"]},{"pos":"verb","gloss":"to eat, to consume","tags":["transitive"]},{"pos":"verb","gloss":"to take with one's lips"}]},"etymology":null,"ipa":["/ram.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16565","headword_ar":"رَمٌّ","root":"rm","body":[{"kind":"text","text":"an inf. n. of 1 [q. v.]. (Lth, T, S, &c.) ―         -b2-  One says,"},{"kind":"arabic","text_bw":"maAliY minohu Ham~N walaA ram~N","text_ar":"مَالِى مِنْهُ حَمٌّ وَلَا رَمٌّ"},{"kind":"italic_en","text":"There is not for me any avoiding it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaping it:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"maA lahu Eano *`lika AlA^amori Ham~N walaA ram~N","text_ar":"مَا لَهُ عَنْ ذٰلِكَ الاَمْرِ حَمٌّ وَلَا رَمٌّ"},{"kind":"text","text":"(T, TA)"},{"kind":"italic_en","text":"There is not for him any avoiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaping, that thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"(TA:) and some say ↓"},{"kind":"arabic","text_bw":"Hum~N walaA rum~N","text_ar":"حُمٌّ وَلَا رُمٌّ","orth_type":"arrow"},{"kind":"text","text":": (S:) so says Lth: (T:) [accord. to ISd,] in the saying ↓"},{"kind":"arabic","text_bw":"maA Eano *`lika Hum~N walaA rum~N","text_ar":"مَا عَنْ ذٰلِكَ حُمٌّ وَلَا رُمٌّ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"There is no avoiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaping, that,"},{"kind":"arabic","text_bw":"rum~N","text_ar":"رُمٌّ"},{"kind":"text","text":"is an imitative sequent; (M;) and so says Lth. (T. [But see the next paragraph.]) ―         -b3-  See also another signification assigned to"},{"kind":"arabic","text_bw":"ram~N","text_ar":"رَمٌّ"},{"kind":"text","text":"in the last sentence but one of the next paragraph. ―         -b4-  [And see the last sentence also of that paragraph.]"}],"source_refs":["S","T","TA"]},{"entry_id":"n16566","headword_ar":"رُمٌّ","root":"rm","body":[{"kind":"text","text":": see 1, second sentence: ―         -b2-  and see also the paragraph next preceding this, in two places. ―         -b3-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"bayotK","text_ar":"بَيْتٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maram~apu","text_ar":"مَرَمَّةُ","orth_type":"arrow"},{"kind":"text","text":", (ISk, T, S, M,) i. e."},{"kind":"italic_en","text":"Household-goods;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"utensils and furniture of a house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(M. [This explanation, from the M, I have found, in the TT, since I composed art."},{"kind":"arabic","text_bw":"vm","text_ar":"ثم"},{"kind":"text","text":"; in which I have said that, accord. to analogy,"},{"kind":"arabic","text_bw":"maram~apu Albayoti","text_ar":"مَرَمَّةُ البَيْتِ"},{"kind":"text","text":"app. signifies"},{"kind":"italic_en","text":"the means by which a house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, is put into a good state;"},{"kind":"text","text":"and therefore"},{"kind":"italic_en","text":"good furniture and utensils."},{"kind":"text","text":"]) So in the saying,"},{"kind":"arabic","text_bw":"maA lahu vum~N walaA rum~N","text_ar":"مَا لَهُ ثُمٌّ وَلَا رُمٌّ"},{"kind":"text","text":", (ISk, T, S, M,) and"},{"kind":"arabic","text_bw":"maA yamoliku vum~FA walaA rum~FA","text_ar":"مَا يَمْلِكُ ثُمًّا وَلَا رُمًّا"},{"kind":"text","text":", (ISk, T, S,) i. e."},{"kind":"italic_en","text":"He has not,"},{"kind":"page_break","n":1151},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he possesses not, such household-goods as water-skins,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"milk-skins, and vessels,"},{"kind":"text","text":"(ISk, T, M,)"},{"kind":"italic_en","text":"nor any of the utensils and furniture of the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(ISk, * T, * M.) This explanation is better than the saying of Lth [that"},{"kind":"arabic","text_bw":"rum~N","text_ar":"رُمٌّ"},{"kind":"text","text":"is an imitative sequent: see the next preceding paragraph]. (T.) One says also,"},{"kind":"arabic","text_bw":"maA lahu Hum~N walaA rum~N","text_ar":"مَا لَهُ حُمٌّ وَلَا رُمٌّ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He has not anything:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he has neither little nor much."},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":"[q. v.]) [See also"},{"kind":"arabic","text_bw":"vum~N","text_ar":"ثُمٌّ"},{"kind":"text","text":".] ―         -b4-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"ham~N","text_ar":"هَمٌّ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"An object,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thing intended"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determined upon"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, in the mind:"},{"kind":"text","text":"and perhaps also"},{"kind":"italic_en","text":"anxiety;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disquietude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trouble, of mind"},{"kind":"text","text":"]. (M, K. [This signification,"},{"kind":"arabic","text_bw":"ham~N","text_ar":"هَمٌّ"},{"kind":"text","text":", Freytag has assigned to"},{"kind":"arabic","text_bw":"ram~N","text_ar":"رَمٌّ"},{"kind":"text","text":", not to"},{"kind":"arabic","text_bw":"rum~N","text_ar":"رُمٌّ"},{"kind":"text","text":"; rendering it “ cura, sollicitudo; ” as from the K; in which the word bearing it is expressly said to be “ with damm. ”]) So in the saying,"},{"kind":"arabic","text_bw":"maA lahu rum~N gayoru ka*aA","text_ar":"مَا لَهُ رُمٌّ غَيْرُ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has not any object in his mind except such a thing"},{"kind":"text","text":"]. (M.) And so in the saying,"},{"kind":"arabic","text_bw":"maA lahu Hum~N walaA rum~N gayoruka","text_ar":"مَا لَهُ حُمٌّ وَلَا رُمٌّ غَيْرُكَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ham~N walaA ram~N","text_ar":"حَمٌّ وَلَا رَمٌّ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has not any object in his mind except thee"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"Hm","text_ar":"حم"},{"kind":"text","text":".)       -A2-  Also"},{"kind":"italic_en","text":"A company"},{"kind":"text","text":"of men: occurring in a trad. applied to"},{"kind":"italic_en","text":"a company"},{"kind":"text","text":"of [the people called]"},{"kind":"arabic","text_bw":"A^akoraAd","text_ar":"اَكْرَاد"},{"kind":"text","text":","},{"kind":"italic_en","text":"abiding"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a place"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like a"},{"kind":"arabic","text_bw":"HaY","text_ar":"حَى"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tribe"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the Arabs of the desert:"},{"kind":"text","text":"[perhaps correctly"},{"kind":"arabic","text_bw":"ram~N","text_ar":"رَمٌّ"},{"kind":"text","text":", from the Pers."},{"kind":"arabic","text_bw":"ramo","text_ar":"رَمْ"},{"kind":"text","text":":] said by Aboo-Moosà to be app. a Pers. word. (TA.)"}],"source_refs":["ISk","T","S","M"]},{"entry_id":"n16567","headword_ar":"رِمٌّ","root":"rm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"herbage and other things that are upon the land:"},{"kind":"text","text":"whence the current saying,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN","text_ar":"جَا=ءَ فُلَانٌ"},{"kind":"arabic","text_bw":"biAlT~im~i waAlr~im~i","text_ar":"بِالطِّمِّ وَالرِّمِّ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Such a one brought everything of what is on the land and in the sea:"},{"kind":"text","text":"[or,"},{"kind":"italic_en","text":"of what is in the sea and on the land;"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"AlT~im~u","text_ar":"الطِّمُّ"},{"kind":"text","text":"means “ the sea; ” and is originally"},{"kind":"arabic","text_bw":"AlT~m~u","text_ar":"الطّمُّ"},{"kind":"text","text":", but is pronounced [in this case]"},{"kind":"arabic","text_bw":"AlT~im~","text_ar":"الطِّمّ"},{"kind":"text","text":"to assimilate it to"},{"kind":"arabic","text_bw":"Alr~im~","text_ar":"الرِّمّ"},{"kind":"text","text":". (T.) [Or]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"varFY","text_ar":"ثَرًى"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"Good of any kind;"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"wealth;"},{"kind":"text","text":"as appears from what immediately follows]: one says,"},{"kind":"arabic","text_bw":"jaA='ahu biAlT~im~i waAlr~im~","text_ar":"جَا=ءَهُ بِالطِّمِّ وَالرِّمّ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He brought him much wealth."},{"kind":"text","text":"(S.) [Or]"},{"kind":"arabic","text_bw":"jaA='a biAlT~im~i waAlr~im~i","text_ar":"جَا=ءَ بِالطِّمِّ وَالرِّمِّ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He brought what was of the sea and what was of the land:"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"biAlbaHoriY~i waAlbar~iY~","text_ar":"بِالبَحْرِىِّ وَالبَرِّىّ"},{"kind":"text","text":", K: [so in MS. copies and in the CK: in the copy of the K followed in the TA, and in like manner in the M,"},{"kind":"arabic","text_bw":"bAlbHr","text_ar":"بالبحر"},{"kind":"arabic","text_bw":"wAlvrY","text_ar":"والثرى"},{"kind":"text","text":", which, I think, is evidently a false reading:]) or"},{"kind":"italic_en","text":"moist and dry:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth and water:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"much wealth;"},{"kind":"text","text":"(K;) as in the S: (TA:) and it is said in the copies of the K, [and in the M,] that"},{"kind":"arabic","text_bw":"Alr~im~u","text_ar":"الرِّمُّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"what is borne"},{"kind":"text","text":"["},{"kind":"italic_en","text":"on its surface"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the water;"},{"kind":"text","text":"but this is a signification of"},{"kind":"arabic","text_bw":"AlT~im~u","text_ar":"الطِّمُّ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Alr~im~u","text_ar":"الرِّمُّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"what is borne by the wind:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"what is upon the ground, of fragments of dry herbage."},{"kind":"text","text":"(M, K.) [See also art."},{"kind":"arabic","text_bw":"Tm","text_ar":"طم"},{"kind":"text","text":".] ―         -b2-  Also"},{"kind":"italic_en","text":"Marrow."},{"kind":"text","text":"(T, S, M, K.)"}],"source_refs":["M","K","TA"]}]}}