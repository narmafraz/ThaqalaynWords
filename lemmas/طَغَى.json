"},{"role":"present_2mp","form":"تَطْغَُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطْغَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطْغَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطْغَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَطْغَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطْغَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطْغَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطْغَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطْغَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطْغَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطْغَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطْغَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْغَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْغَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَطْغَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطْغَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْغَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطْغَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طَغَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَغَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"طَغَى","root":"طغي","pos":"V","occurrence_count":12},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n26772"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%BA%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to go beyond limit, overstep the bounds, be excessive","examples":[{"text":"كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰ","english":"But man exceeds all bounds."}]},{"pos":"verb","gloss":"rage, be tumultuous"},{"pos":"verb","gloss":"overflow, flood, inundate, deluge (with على)"},{"pos":"verb","gloss":"overcome, befall (with على)"},{"pos":"verb","gloss":"be tyrannical, oppress, terrorise, ride roughshod over (with على)"}]},"etymology":null,"ipa":["/tˤa.ɣaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26772","headword_ar":"طَغَى","root":"Tgw and TgY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTogaY","text_ar":"يَطْغَى"},{"kind":"text","text":"; (S, M, Msb, TA, &c.;) not mentioned in the K [in art."},{"kind":"arabic","text_bw":"TgY","text_ar":"طغى"},{"kind":"text","text":", but in some copies thereof mentioned in art"},{"kind":"arabic","text_bw":"Tgw","text_ar":"طغو"},{"kind":"text","text":"]; perhaps dropped by the copyist; (TA;) and"},{"kind":"arabic","text_bw":"TagaA","text_ar":"طَغَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaToguw","text_ar":"يَطْغُو"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"TagiYa","text_ar":"طَغِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTogaY","text_ar":"يَطْغَى"},{"kind":"text","text":"; (S, Msb, K;) inf. n."},{"kind":"arabic","text_bw":"TagoYN","text_ar":"طَغْىٌ"},{"kind":"text","text":", which is of the first, though mentioned in the K as being of the last; (TA;) and"},{"kind":"arabic","text_bw":"TugoyaAnN","text_ar":"طُغْيَانٌ"},{"kind":"text","text":", (S, K,) which is also of the first, and second, (S,) or of the last, as also"},{"kind":"arabic","text_bw":"TigoyaAnN","text_ar":"طِغْيَانٌ"},{"kind":"text","text":", (K,) mentioned by Ks as from some of the tribe of Kelb; (TA;) or"},{"kind":"arabic","text_bw":"TugoyaAnN","text_ar":"طُغْيَانٌ"},{"kind":"text","text":"is a simple subst.; (Msb;) and"},{"kind":"arabic","text_bw":"TagoyaA","text_ar":"طَغْيَا"},{"kind":"text","text":", mentioned by Az as an inf. n. [app. of the first]; (TA;) and the inf. n. of the second is"},{"kind":"arabic","text_bw":"TagowN","text_ar":"طَغْوٌ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"Tuguw~N","text_ar":"طُغُوٌّ"},{"kind":"text","text":", (K accord. to the TA,) like"},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"TagowaY","text_ar":"طَغْوَى"},{"kind":"text","text":", (so in some copies of the K,) and"},{"kind":"arabic","text_bw":"TagowaY","text_ar":"طَغْوَى"},{"kind":"text","text":", mentioned as an inf. n. by Az, (TA,) and"},{"kind":"arabic","text_bw":"TugowaAnN","text_ar":"طُغْوَانٌ"},{"kind":"text","text":"; (K, and mentioned in the S as syn. with"},{"kind":"arabic","text_bw":"TugoyaAnN","text_ar":"طُغْيَانٌ"},{"kind":"text","text":";) and the inf. n. of"},{"kind":"arabic","text_bw":"TagiYa","text_ar":"طَغِىَ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"TagFY","text_ar":"طَغًى"},{"kind":"text","text":"; (Msb, TA;)"},{"kind":"italic_en","text":"He exceeded the just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"common, limit"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"measure; was excessive, immoderate, inordinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitant;"},{"kind":"text","text":"(S, Msb, K, TA;) [and particularly]"},{"kind":"italic_en","text":"in disobedience:"},{"kind":"text","text":"(S, * Msb, * TA:)"},{"kind":"italic_en","text":"he exalted himself, and was inordinate in infidelity: he was extravagant in acts of disobedience and in wrongdoing:"},{"kind":"text","text":"(K:) accord. to El-Harállee,"},{"kind":"arabic","text_bw":"AlT~ugoyaAnu","text_ar":"الطُّغْيَانُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the acting wrongfully in respect of the limits of things"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the measures thereof."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"TagaY","text_ar":"طَغَى"},{"kind":"text","text":", in the K"},{"kind":"arabic","text_bw":"TagiYa","text_ar":"طَغِىَ"},{"kind":"text","text":", but the former is the right, (TA,) or"},{"kind":"arabic","text_bw":"TagaA","text_ar":"طَغَا"},{"kind":"text","text":", (Msb,) said of a torrent, (Msb,) or of water, (K, TA,) (tropical:)"},{"kind":"italic_en","text":"It rose high,"},{"kind":"text","text":"(Msb, K, TA,)"},{"kind":"italic_en","text":"so as to exceed the ordinary limit in copiousness:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"TagaY","text_ar":"طَغَى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"TagaA","text_ar":"طَغَا"},{"kind":"text","text":", (accord. to different copies of the S,) said of a torrent, (assumed tropical:)"},{"kind":"italic_en","text":"it brought much water:"},{"kind":"text","text":"and, said of the sea, (assumed tropical:)"},{"kind":"italic_en","text":"its waves became raised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of commotion:"},{"kind":"text","text":"and, said of the blood, (assumed tropical:)"},{"kind":"italic_en","text":"it became roused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excited."},{"kind":"text","text":"(S.) [Hence also the phrase"},{"kind":"arabic","text_bw":"TagaA miroqamuka","text_ar":"طَغَا مِرْقَمُكَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Thy pen has exceeded its due limit:"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"rqm","text_ar":"رقم"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"Tagati Albaqarapu","text_ar":"طَغَتِ البَقَرَةُ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) means"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"baqarap","text_ar":"بَقَرَة"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"bovine antelope called"},{"kind":"arabic","text_bw":"baqarapu AlwaHo$i","text_ar":"بَقَرَةُ الوَحْشِ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"TagoyaA","text_ar":"طَغْيَا"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"uttered a cry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cries."},{"kind":"text","text":"(K.)"}],"source_refs":["S","K","Msb","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D8%BA%D9%89/","headword_ar":"طغى","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61784#b78440","body_html":"<span class=\"title1\">طغى</span><br><span>طَغَوْتُ وطَغَيْتُ طَغَوَاناً وطُغْيَاناً، وأَطْغَاهُ كذا: حمله على الطُّغْيَانِ، وذلك تجاوز الحدّ في العصيان. قال تعالى: اذْهَبْ إِلى فِرْعَوْنَ إِنَّهُ طَغى</span><br><span>[النازعات/ 17] ، إِنَّ الْإِنْسانَ لَيَطْغى</span><br><span>[العلق/ 6] ، وقال: قالا رَبَّنا إِنَّنا نَخافُ أَنْ يَفْرُطَ عَلَيْنا أَوْ أَنْ يَطْغى [طه/ 45] ، وَلا تَطْغَوْا فِيهِ فَيَحِلَّ عَلَيْكُمْ غَضَبِي</span><br><span>[طه/ 81] ، وقال تعالى: فَخَشِينا أَنْ يُرْهِقَهُما طُغْياناً وَكُفْراً [الكهف/ 80] ، فِي طُغْيانِهِمْ يَعْمَهُونَ</span><br><span>[البقرة/ 15] ، إِلَّا طُغْياناً كَبِيراً [الإسراء/ 60] ، وَإِنَّ لِلطَّاغِينَ لَشَرَّ مَآبٍ</span><br><span>[ص/ 55] ، قالَ قَرِينُهُ رَبَّنا ما أَطْغَيْتُهُ</span><br><span>[ق/ 27] ، والطَّغْوَى الاسمُ منه. قال تعالى:</span><br><span>كَذَّبَتْ ثَمُودُ بِطَغْواها</span><br><span>[الشمس/ 11] ، تنبيها أنهم لم يصدّقوا إذا خوّفوا بعقوبة طُغْيَانِهِمْ.</span><br><span>وقوله: هُمْ أَظْلَمَ وَأَطْغى</span><br><span>[النجم/ 52] ، تنبيها أنّ الطُّغْيَان لا يخلّص الإنسان، فقد كان قوم نوح أَطْغَى منهم فأهلكوا. وقوله: إِنَّا لَمَّا طَغَى الْماءُ</span><br><span>[الحاقة/ 11] ، فاستعير الطُّغْيَانُ فيه لتجاوز الماء الحدّ، وقوله: فَأُهْلِكُوا بِالطَّاغِيَةِ</span><br><span>[الحاقة/ 5] ، فإشارة إلى الطّوفان المعبّر عنه بقوله: إِنَّا لَمَّا طَغَى الْماءُ [الحاقة/ 11] ، والطَّاغُوتُ عبارةٌ عن كلِّ متعدٍّ، وكلِّ معبود من دون الله، ويستعمل في الواحد والجمع. قال تعالى: فَمَنْ يَكْفُرْ بِالطَّاغُوتِ [البقرة/ 256] ، وَالَّذِينَ اجْتَنَبُوا الطَّاغُوتَ</span><br><span>[الزمر/ 17] ، أَوْلِياؤُهُمُ الطَّاغُوتُ [البقرة/ 257] ، يُرِيدُونَ أَنْ يَتَحاكَمُوا إِلَى الطَّاغُوتِ</span><br><span>[النساء/ 60] ، فعبارة عن كلّ متعدّ، ولما تقدّم سمّي السّاحر، والكاهن، والمارد من الجنّ، والصارف عن طريق الخير طاغوتا، ووزنه فيما قيل: فعلوت، نحو: جبروت وملكوت، وقيل:</span><br><span>أصله: طَغَوُوتُ، ولكن قلب لام الفعل نحو صاعقة وصاقعة، ثم قلب الواو ألفا لتحرّكه وانفتاح ما قبله.</span>"}]}}