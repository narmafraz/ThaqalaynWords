8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"close, make dark"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32444","headword_ar":"غَمَضَ","root":"gmD","body":[{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"gamuDa","text_ar":"غَمُضَ"},{"kind":"text","text":", aor. of each"},{"kind":"text","text":", and inf. n. of each"},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unperceived, unapparent, hidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"gamaDa AlHaq~u","text_ar":"غَمَضَ الحَقُّ"},{"kind":"text","text":", aor. and inf. n. as above; and"},{"kind":"arabic","text_bw":"gamuDa","text_ar":"غَمُضَ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The way of attaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtaining, the right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unapparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hidden."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"gamuDa AlkalaAmu","text_ar":"غَمُضَ الكَلَامُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDapN","text_ar":"غُمُوضَةٌ"},{"kind":"text","text":"; (S, Sgh, K;) and"},{"kind":"arabic","text_bw":"gamaDa","text_ar":"غَمَضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":"; (IB, K; [but IB seems to express a doubt of the correctness of the latter form of the verb in this case;])"},{"kind":"italic_en","text":"The speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, was unapparent to the mind, not plain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuous, obscure, recondite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstruse."},{"kind":"text","text":"(S, IB, Sgh, K.) ―         -b4-"},{"kind":"arabic","text_bw":"gamuDa Ealayohi AlA^amoru","text_ar":"غَمُضَ عَلَيْهِ الاَمْرُ"},{"kind":"italic_en","text":"The affair was not easy to him;"},{"kind":"text","text":"(L, TA; *) and you say also,"},{"kind":"arabic","text_bw":"gamaDa AlA^amoru","text_ar":"غَمَضَ الاَمْرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"fiyhi gumuwDN","text_ar":"فِيهِ غُمُوضٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In it is a want of easiness"},{"kind":"text","text":"]: but, Lh says, they scarcely ever, or never, say"},{"kind":"arabic","text_bw":"fiyhi gumuwDapN","text_ar":"فِيهِ غُمُوضَةٌ"},{"kind":"text","text":". (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"gamaDa AlmakaAnu","text_ar":"غَمَضَ المَكَانُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"gamuDa","text_ar":"غَمُضَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDapN","text_ar":"غُمُوضَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gamaADapN","text_ar":"غَمَاضَةٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The place was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed;"},{"kind":"text","text":"(S, K;) [because a place that is so is unseen from a distance.] ―         -b6-"},{"kind":"arabic","text_bw":"gamaDa AlxaloxaAlu fiY","text_ar":"غَمَضَ الخَلْخَالُ فِى"},{"kind":"arabic","text_bw":"Als~aAqi","text_ar":"السَّاقِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The anklet was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, depressed in the leg;"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"choked therein."},{"kind":"text","text":"(A, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"gamaDati Ald~aAru","text_ar":"غَمَضَتِ الدَّارُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"The house was not upon a common thoroughfare-road"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"street."},{"kind":"text","text":"(Lth, L.) ―         -b8-"},{"kind":"arabic","text_bw":"gamaDa Als~ayofu fiY All~aHomi","text_ar":"غَمَضَ السَّيْفُ فِى اللَّحْمِ"},{"kind":"text","text":", (Ibn-'Abbád, A, K,) aor."},{"kind":"text","text":", (Ibn-'Abbád,)"},{"kind":"italic_en","text":"The sword became hidden in the flesh."},{"kind":"text","text":"(Ibn-'Abbád, K.) ―         -b9-"},{"kind":"arabic","text_bw":"gamaDa fiY AlA^aroDi","text_ar":"غَمَضَ فِى الاَرْضِ"},{"kind":"text","text":", (Lh, A, K,) in [some of] the copies of the K,"},{"kind":"arabic","text_bw":"fY AlA^amori","text_ar":"فى الاَمْرِ"},{"kind":"text","text":", which is a mistake, (TA,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"gumuwDN","text_ar":"غُمُوضٌ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He went away in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into, the land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country:"},{"kind":"text","text":"(Lh:) or"},{"kind":"italic_en","text":"he went away and disappeared therein:"},{"kind":"text","text":"(A, L:) or"},{"kind":"italic_en","text":"he went away and journeyed therein."},{"kind":"text","text":"(K.) ―         -b10-  And"},{"kind":"arabic","text_bw":"gamaDa","text_ar":"غَمَضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, small."},{"kind":"text","text":"(IKtt.)       -A2-  See also 4, under"},{"kind":"arabic","text_bw":"AgmS Enh","text_ar":"اغمص عنه"},{"kind":"text","text":", in four places."}],"source_refs":["Lh","A","K","TA","L"]},{"entry_id":"n32449","headword_ar":"غَمْضٌ","root":"gmD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"gaAmiDN","text_ar":"غَامِضٌ"},{"kind":"text","text":", in four places: ―         -b2-  See also 4, in the third sentence, in two places."}],"source_refs":[]},{"entry_id":"n32450","headword_ar":"غُمْضٌ","root":"gmD","body":[{"kind":"text","text":": see 4, in the third sentence; the first and second in two places."}],"source_refs":[]}]},"classical_definitions":null}