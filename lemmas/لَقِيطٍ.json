{"lemma":"لَقِيطٍ","slug":"لَقِيطٍ","root":"ل.ق.ط","root_slug":"ل-ق-ط","root_link":"/words/roots/ل-ق-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n37923"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D9%82%D9%90%D9%8A%D8%B7%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"foundling (abandoned child, left by its parent)"}]},"etymology":{"source":"wiktextract","text":"فَعِيل (faʕīl)-type stative-verb derived from the active participle from the verb لَقَطَ (laqaṭa, “to pick up”)."},"ipa":["/la.qiːtˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37923","headword_ar":"لَقِيطٌ","root":"lqT","body":[{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maloquwTN","text_ar":"مَلْقُوطٌ","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;) i. e. A thing that is"},{"kind":"italic_en","text":"picked up, taken up, raised,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"taken,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"from the ground,"},{"kind":"text","text":"(Mgh, K,) or"},{"kind":"italic_en","text":"from a place where it was not thought to be."},{"kind":"text","text":"(Msb.) ―         -b2-  And, generally, (Mgh,)"},{"kind":"italic_en","text":"A foundling;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"child that is cast out,"},{"kind":"text","text":"(Az, S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"and found by a man,"},{"kind":"text","text":"(Az, TA,) or"},{"kind":"italic_en","text":"picked up;"},{"kind":"text","text":"(S;) or because it is cast out with the object of its being picked up: (Mgh:) not what Lth asserts it to be; i. e."},{"kind":"italic_en","text":"a child that is cast out in the roads, and there found, whose father and mother are unknown:"},{"kind":"text","text":"of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":": (Az, TA:) and ↓"},{"kind":"arabic","text_bw":"maloquwTN","text_ar":"مَلْقُوطٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K:) [pl. of the former,"},{"kind":"arabic","text_bw":"luqaTaA='u","text_ar":"لُقَطَا=ءُ"},{"kind":"text","text":".] ―         -b3-  Also,"},{"kind":"italic_en","text":"A well upon which one lights unexpectedly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unawares,"},{"kind":"text","text":"(Lth, K,)"},{"kind":"italic_en","text":"without seeking it."},{"kind":"text","text":"(Lth.)"}],"source_refs":["Mgh","Msb","K","Az","S","TA","Lth"]}]},"classical_definitions":null}