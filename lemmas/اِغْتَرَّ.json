s","form":"أَغْتَرّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31581"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%BA%D9%92%D8%AA%D9%8E%D8%B1%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be/get deceived, deluded","examples":[{"text":"فَمَنْ يَغْتَرُّ بِٱلدُّنْيَا فَإِنِّي\n لَبِسْتُ بِهَا فَأَبْلَيْتُ ٱلثِّيَابَا","english":"Ask my heart"}]}]},"etymology":null,"ipa":["/iɣ.tar.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31581","headword_ar":"اغترّ","root":"gr","body":[{"kind":"italic_en","text":"He became deceived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beguiled;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"made to desire what was vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false;"},{"kind":"text","text":"(K;)"},{"kind":"arabic","text_bw":"bi$aYo'K","text_ar":"بِشَىْءٍ"},{"kind":"italic_en","text":"by a thing."},{"kind":"text","text":"(S.) [See also 10.] ―         -b2-"},{"kind":"italic_en","text":"He was negligent, inattentive, inadvertent, inconsiderate, heedless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprepared;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"he thought himself secure, and therefore was not on his guard."},{"kind":"text","text":"(Msb.) [See again 10.]       -A2-"},{"kind":"arabic","text_bw":"Agtrahu","text_ar":"اغترَهُ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came to him when he was negligent, inadvertent, heedless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprepared;"},{"kind":"text","text":"(T, S, TA;) as also ↓"},{"kind":"arabic","text_bw":"Astgr~hu","text_ar":"استغرّهُ","orth_type":"arrow"},{"kind":"text","text":": (T, K, TA:) or"},{"kind":"italic_en","text":"he sought to avail himself of his negligence, inadvertence, heedlessness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unpreparedness;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Agtr~bihi","text_ar":"اغترّبِهِ"},{"kind":"text","text":". (TA.)"},{"kind":"page_break","n":2238}],"source_refs":["T","K","TA"]}]},"classical_definitions":null}