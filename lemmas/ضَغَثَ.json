"m","num":"p"},{"role":"present_2mp","form":"تَضْغَثُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضْغَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضْغَث","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضْغَث","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضْغَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضْغَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضْغَثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضْغَثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضْغَثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضْغَثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضْغَثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَضْغَث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَضْغَث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ضَغَثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَغَثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"ضَغَثَ","root":"ضغث","pos":"N","occurrence_count":3},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n25866","n25867"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%BA%D9%8E%D8%AB%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25866","headword_ar":"ضَغْثٌ","root":"Dgv","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"state of"},{"kind":"text","text":"a thing's"},{"kind":"italic_en","text":"being confused, one part with another."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n25867","headword_ar":"ضِغْثٌ","root":"Dgv","body":[{"kind":"italic_en","text":"A handful of herbs,"},{"kind":"text","text":"(AHn, S, A, Mgh, Msb, K,)"},{"kind":"italic_en","text":"mixed together,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"fresh and dry:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"a handful of twigs of trees"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shrubs;"},{"kind":"text","text":"(Mgh, * Msb;) or"},{"kind":"italic_en","text":"of fruit-stalks of the raceme of a palm-tree:"},{"kind":"text","text":"(Mgh, Msb:) originally,"},{"kind":"italic_en","text":"a number of twigs all having one root"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stem:"},{"kind":"text","text":"and afterwards applied to"},{"kind":"italic_en","text":"what is collected together:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a thing that one collects together, such as a bundle of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the species of trefoil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raTobap","text_ar":"رَطْبَة"},{"kind":"text","text":"; and"},{"kind":"italic_en","text":"of what has a stem, and grows tall:"},{"kind":"text","text":"(Fr, TA:) or"},{"kind":"italic_en","text":"whatever is collected together, and grasped with the hand:"},{"kind":"text","text":"(AHeyth, TA:) or"},{"kind":"italic_en","text":"a bundle of herbs mixed together;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of firewood:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aDogaAvN","text_ar":"اَضْغَاثٌ"},{"kind":"text","text":". (TA.) In the Kur xxxviii. 43, it is said to mean"},{"kind":"italic_en","text":"A bundle of rushes"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^asal","text_ar":"اَسَل"},{"kind":"text","text":", so in the Mgh and the O, in my copy of the Msb"},{"kind":"arabic","text_bw":"Avl","text_ar":"اثل"},{"kind":"text","text":"[which I think a mistranscription, on account of what follows]),"},{"kind":"italic_en","text":"a hundred in number,"},{"kind":"text","text":"(O, Msb,)"},{"kind":"italic_en","text":"consisting of slender stalks without leaves,"},{"kind":"text","text":"(Mgh, Msb,)"},{"kind":"italic_en","text":"whereof mats are made."},{"kind":"text","text":"(Msb.) See also a prov. cited and expl. voce"},{"kind":"arabic","text_bw":"A_ilaAlapN","text_ar":"اـِلَالَةٌ"},{"kind":"text","text":". Hence, in a trad.,"},{"kind":"arabic","text_bw":"DigovaAni mino naArK","text_ar":"ضِغْثَانِ مِنْ نَارٍ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Two bundles of lighted firewood."},{"kind":"text","text":"(TA.) And, in another trad.,"},{"kind":"arabic","text_bw":"minohumu AlA=xi*u AlD~igova","text_ar":"مِنْهُمُ الا=خِذُ الضِّغْثَ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"Among them is he who obtains somewhat of worldly goods."},{"kind":"text","text":"(TA.) ―         -b2-  Also (assumed tropical:)"},{"kind":"italic_en","text":"What is confused, and without truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reality,"},{"kind":"text","text":"[of dreams, and] of news, or tidings, and of an affair. (Sh, TA.)"},{"kind":"arabic","text_bw":"A^aDogaAvu A^aHolaAmK","text_ar":"اَضْغَاثُ اَحْلَامٍ"},{"kind":"text","text":", [occurring in the Kur xii. 44 and xxi. 5,] of which the sing. is"},{"kind":"arabic","text_bw":"Digovu HulomK","text_ar":"ضِغْثُ حُلْمٍ"},{"kind":"text","text":", (Msb,) means (tropical:)"},{"kind":"italic_en","text":"Complications of dreams;"},{"kind":"text","text":"(A;) or"},{"kind":"italic_en","text":"medleys of dreams, falsely resembling true dreams:"},{"kind":"text","text":"(O, Msb:) or"},{"kind":"italic_en","text":"a dream of which the interpretation will not prove true, because of its confusedness:"},{"kind":"text","text":"(ISh, S, K:) or"},{"kind":"italic_en","text":"a false dream;"},{"kind":"text","text":"the pl. form being used to give emphasis to the meaning of unreality, or because the phrase comprehends various things: (Bd in xii. 44:) or"},{"kind":"arabic","text_bw":"A^aDogaAvu Alr~uw^oyaA","text_ar":"اَضْغَاثُ الرُّوْيَا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the terrors,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frightful things, of the dream."},{"kind":"text","text":"(Mujáhid, O, TA.) One says also,"},{"kind":"arabic","text_bw":"A^ataAnaA biA^aDogaAvK","text_ar":"اَتَانَا بِاَضْغَاثٍ"},{"kind":"arabic","text_bw":"mina AlA^axobaAri","text_ar":"مِنَ الاَخْبَارِ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"He brought us"},{"kind":"text","text":"["},{"kind":"italic_en","text":"various"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"sorts of news,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tidings."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"DigovN","text_ar":"ضِغْثٌ"},{"kind":"text","text":"means also (assumed tropical:)"},{"kind":"italic_en","text":"A deed that is of a mixed kind, not pure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not sincere."},{"kind":"text","text":"(IAth and O, from a trad.) And"},{"kind":"arabic","text_bw":"kalaAmN DigovN","text_ar":"كَلَامٌ ضِغْثٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Speech in which is no good:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aDogaAvN","text_ar":"اَضْغَاثٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["AHn","S","A","Mgh","Msb","K","Fr","TA","AHeyth","O","ISh"]}]}}