apN","text_ar":"غَيْمَةٌ"},{"kind":"text","text":".] ―         -b2-  And"},{"kind":"italic_en","text":"Anger, wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"which is from internal heat."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"italic_en","text":"a certain disease in camels, like that called"},{"kind":"arabic","text_bw":"qulaAb","text_ar":"قُلَاب"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"except that it does not kill:"},{"kind":"text","text":"(K, TA:) it is said that the asterism of the Pleiades ("},{"kind":"arabic","text_bw":"Alv~uray~aA","text_ar":"الثُّرَيَّا"},{"kind":"text","text":", q. v.,) does not rise nor set aurorally without there being sickness, mostly in the camels, which are then affected with the disease thus called. (Az, TA.)       -A3-"},{"kind":"arabic","text_bw":"$ajarN gayomN","text_ar":"شَجَرٌ غَيْمٌ"},{"kind":"italic_en","text":"Dense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tangled, trees:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"gayonN","text_ar":"غَيْنٌ"},{"kind":"text","text":"[which is a dial. var. of"},{"kind":"arabic","text_bw":"gayomN","text_ar":"غَيْمٌ"},{"kind":"text","text":"in other senses]. (TA.)"}],"source_refs":["Msb","Kr","TA","K"]}]}}