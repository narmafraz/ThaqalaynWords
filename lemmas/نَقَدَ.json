82%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of نَقَدَ (naqada, “to pay in cash”) (form I), payment in cash","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"cash, ready money"},{"pos":"noun","gloss":"money"},{"pos":"noun","gloss":"dowry"},{"pos":"verb","gloss":"to pay in cash"},{"pos":"noun","gloss":"verbal noun of نَقَدَ (naqada, “to criticize”) (form I), criticism","tags":["form-of","noun-from-verb"],"examples":[{"text":"النَّقْد الْأَدَبِيّ","english":"literary criticism"}]},{"pos":"verb","gloss":"to cast a stealthy glance upon"},{"pos":"verb","gloss":"to separate the goods from the bads"},{"pos":"verb","gloss":"to proceed with harsh judgment against"},{"pos":"verb","gloss":"to be peeled, to be decorticated, to lose one’s outer integrity"},{"pos":"noun","gloss":"verbal noun of نَقِدَ (naqida) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"certain Asteraceae, given as Anvillea garcinii, Anvillea radiata, Asteriscus spp., Picridium, Carthamus etc.","tags":["collective"]},{"pos":"adj","gloss":"consumed, eroded"}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40360","headword_ar":"نَقْدٌ","root":"nqd","body":[{"kind":"text","text":"[properly an inf. n. used in the sense of a pass. part. n., and thus signifying “ paid, ”"},{"kind":"italic_en","text":"Cash,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready money:"},{"kind":"text","text":"or simply"},{"kind":"italic_en","text":"money"},{"kind":"text","text":"]. You say"},{"kind":"arabic","text_bw":"naqodN jay~idN","text_ar":"نَقْدٌ جَيِّدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Good cash,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready money:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good money"},{"kind":"text","text":"]: pl."},{"kind":"arabic","text_bw":"nuquwdN jiyaAdN","text_ar":"نُقُودٌ جِيَادٌ"},{"kind":"text","text":". (A.)"},{"kind":"arabic","text_bw":"Alt~aqodaAni","text_ar":"التَّقْدَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Silver and gold money; dirhems and deenárs."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"ErD","text_ar":"عرض"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"naqodN","text_ar":"نَقْدٌ"},{"kind":"italic_en","text":"Payment in cash,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready money; contr. of"},{"kind":"arabic","text_bw":"nasoyy^apN","text_ar":"نَسْييَةٌ"},{"kind":"text","text":": (L, K:) the"},{"kind":"italic_en","text":"giving of"},{"kind":"arabic","text_bw":"naqod","text_ar":"نَقْد"},{"kind":"text","text":"[i. e.,"},{"kind":"italic_en","text":"cash,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ready money"},{"kind":"text","text":"]: (K:) [an inf. n.: see 1]. ―         -b3-"},{"kind":"arabic","text_bw":"Ald~irohamu naqodN","text_ar":"الدِّرْهَمُ نَقْدٌ"},{"kind":"italic_en","text":"The piece of money is of full weight,"},{"kind":"text","text":"(S, L, K, *)"},{"kind":"italic_en","text":"and good."},{"kind":"text","text":"(S, L.) ―         -b4-"},{"kind":"arabic","text_bw":"h`*ihi miAy^apN naqodu Aln~aAsi","text_ar":"هٰذِهِ مِايَةٌ نَقْدُ النَّاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is a hundred, ready money of the people"},{"kind":"text","text":"] is a phrase used by the Arabs, in which"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is meant to be understood [before"},{"kind":"arabic","text_bw":"Aln~As","text_ar":"النّاس"},{"kind":"text","text":": i. e."},{"kind":"arabic","text_bw":"AlnAs","text_ar":"الناس"},{"kind":"text","text":"is for"},{"kind":"arabic","text_bw":"liln~aAsi","text_ar":"لِلنَّاسِ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"naqodu","text_ar":"نَقْدُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"naqodN","text_ar":"نَقْدٌ"},{"kind":"text","text":", as an epithet of"},{"kind":"arabic","text_bw":"mAy^p","text_ar":"ماية"},{"kind":"text","text":"; you may also say"},{"kind":"arabic","text_bw":"naqoda AlnaAs","text_ar":"نَقْدَ النَاس"},{"kind":"text","text":", making"},{"kind":"arabic","text_bw":"nqd","text_ar":"نقد"},{"kind":"text","text":"a denotative of state; but] the epithetic mode of construction is that which prevails in this case. (Sb, L.) ―         -b5-"},{"kind":"arabic","text_bw":"naqodN","text_ar":"نَقْدٌ"},{"kind":"text","text":". ―         -b6-  The saying of the poet,"},{"kind":"quote","text":"latunotajan~a waladFA A^awo naqodaA"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"She will certainly bring forth a she-camel, which shall be a permanent acquisition for breeding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a male, which shall be sold:"},{"kind":"text","text":"for they seldom kept the male camels. (Th, L.)"}],"source_refs":["L","K"]},{"entry_id":"n40361","headword_ar":"نُقْدٌ","root":"nqd","body":[{"kind":"text","text":"(Lh, L, K,) and ↓"},{"kind":"arabic","text_bw":"nuqudN","text_ar":"نُقُدٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"nuqadN","text_ar":"نُقَدٌ","orth_type":"arrow"},{"kind":"text","text":". (Lh, Az, L,) the form most frequently heard by Az from the Arabs, (L,) or ↓"},{"kind":"arabic","text_bw":"naqadN","text_ar":"نَقَدٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [coll. gen. n.]"},{"kind":"italic_en","text":"A certain kind of tree,"},{"kind":"text","text":"(Lh, L, K,) accord. to AA,"},{"kind":"italic_en","text":"of the description termed"},{"kind":"arabic","text_bw":"xuwSap","text_ar":"خُوصَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"having a blossom resembling the"},{"kind":"arabic","text_bw":"bahoramaAn","text_ar":"بَهْرَمَان"},{"kind":"text","text":", i. e. the"},{"kind":"arabic","text_bw":"EuSofur","text_ar":"عُصْفُر"},{"kind":"text","text":"[or bastard-saffron]; (AHn, L;)"},{"kind":"italic_en","text":"its blossom is yellow,"},{"kind":"text","text":"and it grows in plain, or soft, grounds: (Az, L:) n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (K;)"},{"kind":"arabic","text_bw":"nuqodapN","text_ar":"نُقْدَةٌ"},{"kind":"text","text":"(Lh, S, L) and"},{"kind":"arabic","text_bw":"nuqudapN","text_ar":"نُقُدَةٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"nuqadapN","text_ar":"نُقَدَةٌ"},{"kind":"text","text":"(Lh, L) and"},{"kind":"arabic","text_bw":"naqadapN","text_ar":"نَقَدَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also ↓"},{"kind":"arabic","text_bw":"nuqodapN","text_ar":"نُقْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) or ↓"},{"kind":"arabic","text_bw":"niqodapN","text_ar":"نِقْدَةٌ","orth_type":"arrow"},{"kind":"text","text":", (IAar, L, K,) The"},{"kind":"arabic","text_bw":"karawoyaA='","text_ar":"كَرَوْيَا=ء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"caraway"},{"kind":"text","text":"]. (IAar, L, K.) ―         -b3-  See"},{"kind":"arabic","text_bw":"naqidN","text_ar":"نَقِدٌ"},{"kind":"text","text":"."}],"source_refs":["Lh","L","K","Az","S","TA","IAar"]},{"entry_id":"n40362","headword_ar":"نِقْدٌ","root":"nqd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"naqidN","text_ar":"نَقِدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n40363","headword_ar":"نَقَدٌ","root":"nqd","body":[{"kind":"text","text":"[a coll. gen. n.]"},{"kind":"italic_en","text":"A kind of sheep, of ugly form;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"a kind of sheep of El-Bahreyn, having short legs and ugly faces:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"a kind of small sheep of El-Hijáz:"},{"kind":"text","text":"(L:) or, simply,"},{"kind":"italic_en","text":"lambs:"},{"kind":"text","text":"(A, L:) [see an ex. in a prov. cited voce"},{"kind":"arabic","text_bw":"$aAma","text_ar":"شَامَ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"$ym","text_ar":"شيم"},{"kind":"text","text":":] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, L:) applied alike to the male and female: (L:) pl."},{"kind":"arabic","text_bw":"niqaAdN","text_ar":"نِقَادٌ"},{"kind":"text","text":", and [quasi-pl. n.]"},{"kind":"arabic","text_bw":"niqaAdapN","text_ar":"نِقَادَةٌ"},{"kind":"text","text":". (L, K.) As says, that the best of wool is that of"},{"kind":"arabic","text_bw":"naqad","text_ar":"نَقَد"},{"kind":"text","text":". And one says,"},{"kind":"arabic","text_bw":"A^a*al~u mina Aln~aqadi","text_ar":"اَذَلُّ مِنَ النَّقَدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More abject,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile, than"},{"kind":"page_break","n":2837},{"kind":"italic_en","text":"the sheep called"},{"kind":"arabic","text_bw":"nqd","text_ar":"نقد"},{"kind":"text","text":"]. (S, L.) ―         -b2-  Also, (assumed tropical:)  The"},{"kind":"italic_en","text":"lower sort of people."},{"kind":"text","text":"(L.) ―         -b3-  See"},{"kind":"arabic","text_bw":"nuqodN","text_ar":"نُقْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"naqidN","text_ar":"نَقِدٌ"},{"kind":"text","text":"."}],"source_refs":["S","L","A"]},{"entry_id":"n40364","headword_ar":"نَقِدٌ","root":"nqd","body":[{"kind":"text","text":", (L,) or ↓"},{"kind":"arabic","text_bw":"niqodN","text_ar":"نِقْدٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Slow in growing up into manhood, and having little flesh:"},{"kind":"text","text":"(L, K:) [and so ↓"},{"kind":"arabic","text_bw":"nuqodN","text_ar":"نُقْدٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to the CK: but"},{"kind":"arabic","text_bw":"wyuDm~","text_ar":"ويُضمّ"},{"kind":"text","text":"is there put by mistake for"},{"kind":"arabic","text_bw":"wbiDam~K","text_ar":"وبِضَمٍّ"},{"kind":"text","text":": and the former, (S, L,) or ↓"},{"kind":"arabic","text_bw":"naqadN","text_ar":"نَقَدٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) a boy"},{"kind":"italic_en","text":"despised and little in the eyes of others, that scarcely grows up into manhood;"},{"kind":"text","text":"(S, L, K;) sometimes thus applied. (S, L.) ―         -b2-"},{"kind":"arabic","text_bw":"naqidN","text_ar":"نَقِدٌ"},{"kind":"text","text":"A horn"},{"kind":"italic_en","text":"eaten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eroded, at the root."},{"kind":"text","text":"(L.) See also"},{"kind":"arabic","text_bw":"naqida","text_ar":"نَقِدَ"},{"kind":"text","text":"."}],"source_refs":["L","K","S"]},{"entry_id":"n40365","headword_ar":"نُقُدٌ","root":"nqd","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nuqadN","text_ar":"نُقَدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nuqodapN","text_ar":"نُقْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"niqodahN","text_ar":"نِقْدَهٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"nuqodN","text_ar":"نُقْدٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}