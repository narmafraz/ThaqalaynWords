https://lanelexicon.com/?s=%D8%A7%D9%90%D9%85%D9%92%D8%AA%D9%8E%D9%86%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to abstain, to refrain from something, or to withhold oneself from someone"},{"pos":"verb","gloss":"to be impossible","examples":[{"text":"اَلْفِعْلُ ٱلْمَاضِي يَمْتَنِعُ تَوْكِيدُهُ بِالنُّونِ مُطْلَقًا.","english":"The past tense verb cannot be emphasized with the letter “noon” at all."}]}]},"etymology":null,"ipa":["/im.ta.na.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43731","headword_ar":"اِمْتَنَعَ","root":"mnE","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, prevented from being; it necessarily was not."},{"kind":"text","text":"You say"},{"kind":"arabic","text_bw":"yamotaniEu","text_ar":"يَمْتَنِعُ"},{"kind":"arabic","text_bw":"h`*aA liwujuwdi *aAka","text_ar":"هٰذَا لِوُجُودِ ذَاكَ"},{"kind":"italic_en","text":"This is prevented from being,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may not be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"necessarily is not, because of that's being."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"yamotaniEu A^ano takuwan h`*aA","text_ar":"يَمْتَنِعُ اَنْ تَكُوَن هٰذَا"},{"kind":"italic_en","text":"This may not be."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"italic_en","text":"He refrained, forbore, abstained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"arabic","text_bw":"mina AlA^amori","text_ar":"مِنَ الاَمْرِ"},{"kind":"italic_en","text":"from the thing."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"(Msb;) as also"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taman~aEa","text_ar":"تَمَنَّعَ","orth_type":"arrow"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"he did so voluntarily, of his own free will"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice: he refused:"},{"kind":"text","text":"you say,"},{"kind":"arabic","text_bw":"AimotnaEa Eanohu","text_ar":"اِمْتنَعَ عَنْهُ"},{"kind":"italic_en","text":"he refrained,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from it voluntarily,"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"refused it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused to do it."},{"kind":"text","text":"(MF. in art."},{"kind":"arabic","text_bw":"HSr","text_ar":"حصر"},{"kind":"text","text":".) See"},{"kind":"arabic","text_bw":"A^abaY","text_ar":"اَبَى"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, opposed him; resisted him; withstood him; repugned him; was incompliant,"},{"kind":"text","text":"or"},{"kind":"page_break","n":3025},{"kind":"italic_en","text":"unyielding, to him;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^abaY Ealayohi","text_ar":"اَبَى عَلَيْهِ"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, inaccessible,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inapproachable;"},{"kind":"text","text":"like ↓"},{"kind":"arabic","text_bw":"manuEa","text_ar":"مَنُعَ","orth_type":"arrow"},{"kind":"text","text":"; syn. with"},{"kind":"arabic","text_bw":"HaSuna","text_ar":"حَصُنَ"},{"kind":"text","text":", q. v.: and also,"},{"kind":"italic_en","text":"difficult of access,"},{"kind":"text","text":"as in an instance in art."},{"kind":"arabic","text_bw":"A^bY","text_ar":"ابى"},{"kind":"text","text":"(last sentence of 4); and also"},{"kind":"arabic","text_bw":"Earisa EalaY~a","text_ar":"عَرِسَ عَلَىَّ"},{"kind":"text","text":". ―         -b5-  See 5."}],"source_refs":["Msb","K","TA"]}]},"classical_definitions":null}