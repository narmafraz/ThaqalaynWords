{"lemma":"شَرِبَ","slug":"شَرِبَ","root":"ش.ر.ب","root_slug":"ش-ر-ب","root_link":"/words/roots/ش-ر-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَرِبْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَرِبْتِ","in_corpus":true,"count":26,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَرِبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَرِبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَرِبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَرِبَ","in_corpus":true,"count":61,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَرِبَت","in_corpus":true,"count":26,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَرِبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَرِبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَرِبُوا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَرِبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَشْرَب","in_corpus":true,"count":39,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَشْرَبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَشْرَبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَشْرَبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَشْرَبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَشْرَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَشْرَبُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْرَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْرَب","in_corpus":true,"count":90,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْرَب","in_corpus":true,"count":39,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْرَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْرَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْرَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْرَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْرَبُونَ","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْرَبُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْرَبْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَرِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَرِبْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْرَب","in_corpus":true,"count":19,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْرَب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":326,"cross_references":{"qac":{"found":true,"lemma_key":"شَرِبَ","root":"شرب","pos":"V","occurrence_count":15},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n22024"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to drink","examples":[{"text":"اِشْرَبْ هَٰذَا ٱلشَّايَ.","english":"Drink this tea."}]},{"pos":"verb","gloss":"to make drink, to drench","tags":["ditransitive"]},{"pos":"noun","gloss":"verbal noun of شَرِبَ (šariba) (form I): drinking","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare Akkadian sarāpum (“to suck”) and Ge'ez ሠረበ (śäräbä)."},"ipa":["/ʃa.ri.ba/","/ʃar.ra.ba/","/ʃurb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22024","headword_ar":"شَرِبَ","root":"$rb","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"$urobN","text_ar":"شُرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$arobN","text_ar":"شَرْبٌ"},{"kind":"text","text":"(S, A, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"$irobN","text_ar":"شِرْبٌ"},{"kind":"text","text":", (S, A, K,) agreeably with three different readings of the Kur lvi. 55, (S, TA,) the first of which (with damm) is that generally obtaining, (Fr, TA,) and is the only one admitted by Jaafar Ibn-Mohammad, notwithstanding which the second form (with fet-h) is said by MF to be the most chaste as well as the most agreeable with analogy, (TA,) or the second (with fet-h) is an inf. n., and the first is a simple subst., (AO, S, Msb, K,) and so is the third, (AO, S, K,) and"},{"kind":"arabic","text_bw":"ma$orabN","text_ar":"مَشْرَبٌ"},{"kind":"text","text":", (S, K,) which is"},{"kind":"page_break","n":1526},{"kind":"text","text":"also a n. of place [and of time], (S,) and"},{"kind":"arabic","text_bw":"ta$oraAbN","text_ar":"تَشْرَابٌ"},{"kind":"text","text":", (S K, TA,) a form used when muchness of the act is meant, (TA,) and"},{"kind":"arabic","text_bw":"ti$oraAbN","text_ar":"تِشْرَابٌ"},{"kind":"text","text":", which is anomalous, (TA voce"},{"kind":"arabic","text_bw":"bay~ana","text_ar":"بَيَّنَ"},{"kind":"text","text":", q. v.,)"},{"kind":"italic_en","text":"He drank,"},{"kind":"text","text":"(KL, PS, TK,) or"},{"kind":"italic_en","text":"he swallowed,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jariEa","text_ar":"جَرِعَ"},{"kind":"text","text":", (A, K, [but the former meaning is evidently intended by this explanation, and such I shall assume to be the case in giving the explanations of the derivatives in the A and K. &c.,]) water, &c., (S,) or a liquid, properly"},{"kind":"italic_en","text":"by sucking in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sipping;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"otherwise"},{"kind":"text","text":"tropically; (Msb;) [generally,"},{"kind":"italic_en","text":"gulping"},{"kind":"text","text":"it; for] you say,"},{"kind":"arabic","text_bw":"$ariba AlmaA='a fiY kar~apK","text_ar":"شَرِبَ المَا=ءَ فِى كَرَّةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He drank the water at once,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at a single draught"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"t$r~bhu","text_ar":"تشرّبهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"muholapK","text_ar":"مُهْلَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He drank it leisurely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slowly"},{"kind":"text","text":"]: (Mgh:)"},{"kind":"arabic","text_bw":"$urobN","text_ar":"شُرْبٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"conveying to one's inside, by means of his mouth, that in the case of which chewing is not practicable:"},{"kind":"text","text":"(KT:) [but] Es-Sarakustee says, one does not say of a bird"},{"kind":"arabic","text_bw":"$ariba AlmaA='a","text_ar":"شَرِبَ المَا=ءَ"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"HasaAhu","text_ar":"حَسَاهُ"},{"kind":"text","text":". (Msb.) In the saying of Aboo-Dhu-eyb, describing clouds,"},{"kind":"quote","text":"$aribona bimaA='i AlbaHori vum~a taraf~aEato"},{"kind":"text","text":"[which is evidently best rendered"},{"kind":"italic_en","text":"They drank of the water of the sea, then rose aloft,"},{"kind":"text","text":"agreeably with what has been stated respecting"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":"in p. 143, it is said that] the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"is redundant, or, as"},{"kind":"arabic","text_bw":"rawiyna","text_ar":"رَوِينَ"},{"kind":"text","text":"is rendered trans. by means of"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":", [though I do not think that this is the case unless"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":"be used as meaning “ by means of, ” and I do not remember to have met with an instance of it,]"},{"kind":"arabic","text_bw":"$aribona","text_ar":"شَرِبْنَ"},{"kind":"text","text":"is thus rendered trans. (TA.) [See a similar ex. in the 28th verse of the Mo'allakah of 'Antarah, EM p. 232. One says also,"},{"kind":"arabic","text_bw":"$ariba fiY A_inaA='K","text_ar":"شَرِبَ فِى اـِنَا=ءٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He drank out of a vessel;"},{"kind":"text","text":"agreeably with an explanation of"},{"kind":"arabic","text_bw":"mi$orabapN","text_ar":"مِشْرَبَةٌ"},{"kind":"text","text":", in the S and K, as meaning"},{"kind":"arabic","text_bw":"A_inaA='N yu$orabu fiyhi","text_ar":"اـِنَا=ءٌ يُشْرَبُ فِيهِ"},{"kind":"text","text":".] And one says,"},{"kind":"arabic","text_bw":"A_in~iY laA^amokuvu Alyawomayoni maA A^a$orabuhumaA maA='F","text_ar":"اـِنِّى لَاَمْكُثُ اليَوْمَيْنِ مَا اَشْرَبُهُمَا مَا=ءً"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"maA A^a$orabu fiyhimaA maA='F","text_ar":"مَا اَشْرَبُ فِيهِمَا مَا=ءً"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Verily I tarry the two days not drinking in them water"},{"kind":"text","text":"]. (O.) ―         -b2-  ["},{"kind":"arabic","text_bw":"$ariba","text_ar":"شَرِبَ"},{"kind":"arabic","text_bw":"Ald~awaA='a","text_ar":"الدَّوَا=ءَ"},{"kind":"text","text":", in the conventional language of the physicians, as is indicated in the Mgh, voce"},{"kind":"arabic","text_bw":"banojN","text_ar":"بَنْجٌ"},{"kind":"text","text":"(q. v.), on the phrase"},{"kind":"arabic","text_bw":"$ariba Albanoja","text_ar":"شَرِبَ البَنْجَ"},{"kind":"text","text":", and as is shown in many instances in the K &c., means"},{"kind":"italic_en","text":"He took,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"swallowed, the medicine,"},{"kind":"text","text":"whether fluid or solid. ―         -b3-  And in the present day, they say,"},{"kind":"arabic","text_bw":"$ariba","text_ar":"شَرِبَ"},{"kind":"arabic","text_bw":"Ald~uxaAna","text_ar":"الدُّخَانَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He inhaled,"},{"kind":"text","text":"properly"},{"kind":"italic_en","text":"imbibed, smoke"},{"kind":"text","text":"of tobacco; or"},{"kind":"italic_en","text":"he smoked tobacco,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the tobacco."},{"kind":"text","text":"] ―         -b4-  One says of seed-produce, or corn, when its culms have come forth,"},{"kind":"arabic","text_bw":"qado $ariba Alz~aroEu","text_ar":"قَدْ شَرِبَ الزَّرْعُ"},{"kind":"arabic","text_bw":"fiY AlqaSabi","text_ar":"فِى القَصَبِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, has imbibed into the culms"},{"kind":"text","text":"]: (O, TA:) and when the sap ("},{"kind":"arabic","text_bw":"AlmaA='","text_ar":"المَا=ء"},{"kind":"text","text":") has come into it,"},{"kind":"arabic","text_bw":"$ariba qaSabu Alz~aroEi","text_ar":"شَرِبَ قَصَبُ الزَّرْعِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The culms of the seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, have imbibed"},{"kind":"text","text":"]. (TA.) And one says,"},{"kind":"arabic","text_bw":"$ariba Als~unobulu","text_ar":"شَرِبَ السُّنْبُلُ"},{"kind":"arabic","text_bw":"Ald~aqiyqa","text_ar":"الدَّقِيقَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The ears of corn imbibed the farina;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"became pervaded by the farina;"},{"kind":"text","text":"(En-Nadr, A, O;) or"},{"kind":"italic_en","text":"had in them the alimentary substance;"},{"kind":"text","text":"as though the farina were water which they drank. (TA.) And"},{"kind":"arabic","text_bw":"waqado $ariba Alz~aroEu Ald~aqiyqa","text_ar":"وَقَدْ شَرِبَ الزَّرْعُ الدَّقِيقَ"},{"kind":"text","text":", occurring in the story of Ohod, (O, TA,) as some relate it, or ↓"},{"kind":"arabic","text_bw":"$ur~iba","text_ar":"شُرِّبَ","orth_type":"arrow"},{"kind":"text","text":"as others relate it, means (tropical:)  ["},{"kind":"italic_en","text":"And the seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, had imbibed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had been made to imbibe, the farina,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"had become hardened in its grain, and near to maturity."},{"kind":"text","text":"(TA.) [And ↓"},{"kind":"arabic","text_bw":"A^u$oriba","text_ar":"اُشْرِبَ","orth_type":"arrow"},{"kind":"text","text":"means the same: for one says,]"},{"kind":"arabic","text_bw":"A^u$oriba Alz~aroEu","text_ar":"اُشْرِبَ الزَّرْعُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, was made to imbibe"},{"kind":"text","text":"the farina; or]"},{"kind":"italic_en","text":"became pervaded by the farina:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"A^u$oriba Alz~aroEu Ald~aqiyqa","text_ar":"اُشْرِبَ الزَّرْعُ الدَّقِيقَ"},{"kind":"text","text":", i. e. (tropical:)  ["},{"kind":"italic_en","text":"The seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corn, was made to imbibe the farina,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"its alimentary substance."},{"kind":"text","text":"(TA.) ―         -b5-  One also says,"},{"kind":"arabic","text_bw":"A^akala ganamiY wa$aribahaA","text_ar":"اَكَلَ غَنَمِى وَشَرِبَهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He ate"},{"kind":"text","text":"the flesh of"},{"kind":"italic_en","text":"my sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, and drank"},{"kind":"text","text":"the milk of"},{"kind":"italic_en","text":"them"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"Akl","text_ar":"اكل"},{"kind":"text","text":".) And [in like manner]"},{"kind":"arabic","text_bw":"A^akala fulaAnN maAliY","text_ar":"اَكَلَ فُلَانٌ مَالِى"},{"kind":"arabic","text_bw":"wa$aribahu","text_ar":"وَشَرِبَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one fed upon, devoured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consumed, my property"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^akala Ealayohi Ald~ahoru wa$ariba","text_ar":"اَكَلَ عَلَيْهِ الدَّهْرُ وَشَرِبَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Time wasted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wore him away;"},{"kind":"text","text":"as though it fed upon him]. (A.) ―         -b6-  And"},{"kind":"arabic","text_bw":"maA lamo","text_ar":"مَا لَمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^a$orabotaniY","text_ar":"اَشْرَبْتَنِى","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^a$orabo","text_ar":"اَشْرَبْ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Thou hast made me to drink what I have not drunk,"},{"kind":"text","text":"] meaning (tropical:)"},{"kind":"italic_en","text":"thou hast charged against me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accused me of doing, what I have not done;"},{"kind":"text","text":"(S, A, K;) like"},{"kind":"arabic","text_bw":"A^ak~alotaniY maA lamo A=kulo","text_ar":"اَكَّلْتَنِى مَا لَمْ ا=كُلْ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"Akl","text_ar":"اكل"},{"kind":"text","text":".) ―         -b7-"},{"kind":"arabic","text_bw":"$ariba","text_ar":"شَرِبَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, satisfied with drinking:"},{"kind":"text","text":"(TA:) and in like manner"},{"kind":"arabic","text_bw":"$aribat","text_ar":"شَرِبَت"},{"kind":"text","text":"is said of camels. (A 'Obeyd, S, TA.) And"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thirsty;"},{"kind":"text","text":"(K, TA;) thus having two contr. significations; (TA;) as also ↓"},{"kind":"arabic","text_bw":"A^a$oraba","text_ar":"اَشْرَبَ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) ―         -b8-  Also, and ↓"},{"kind":"arabic","text_bw":"A^a$oraba","text_ar":"اَشْرَبَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"His camels were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, satisfied with drinking:"},{"kind":"text","text":"and, i. e. both these verbs,"},{"kind":"italic_en","text":"his camels were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thirsty:"},{"kind":"text","text":"(K, TA:) or the former verb signifies, or signifies also, (accord. to different copies of the K,)"},{"kind":"italic_en","text":"his camel was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weak."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"$ariba bihi","text_ar":"شَرِبَ بِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^a$oraba","text_ar":"اَشْرَبَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He lied against him."},{"kind":"text","text":"(K.)       -A3-"},{"kind":"arabic","text_bw":"$araba","text_ar":"شَرَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (O, K, TA,) inf. n."},{"kind":"arabic","text_bw":"$arobN","text_ar":"شَرْبٌ"},{"kind":"text","text":", (O, TA,)"},{"kind":"italic_en","text":"He understood:"},{"kind":"text","text":"(O, K, TA:) on the authority of AA. (TA.) [In a copy of the A, the verb in this sense is written"},{"kind":"arabic","text_bw":"$ariba","text_ar":"شَرِبَ"},{"kind":"text","text":"; and app. not through the fault of the transcriber, for it is there mentioned as tropical: but in the O, it is said to be like"},{"kind":"arabic","text_bw":"kataba","text_ar":"كَتَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"katobN","text_ar":"كَتْبٌ"},{"kind":"text","text":"; and in the K, to be like"},{"kind":"arabic","text_bw":"naSara","text_ar":"نَصَرَ"},{"kind":"text","text":".] One says,"},{"kind":"arabic","text_bw":"$araba maA A^uloqiYa A_ilayohi","text_ar":"شَرَبَ مَا اُلْقِىَ اـِلَيْهِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He understood"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what was told to him"},{"kind":"text","text":"]. (TA.) And one says to a stupid person,"},{"kind":"arabic","text_bw":"AuHolubo vum~a A@$orubo","text_ar":"اُحْلُبْ ثُمَّ ا@شْرُبْ"},{"kind":"italic_en","text":"Kneel thou; then understand."},{"kind":"text","text":"(O, TA. See also 1 in art."},{"kind":"arabic","text_bw":"Hlb","text_ar":"حلب"},{"kind":"text","text":".)"}],"source_refs":["A","K","S","TA","Fr","AO","Msb","KL","PS","TK","Mgh","KT","O"]}]}}