ttps://lanelexicon.com/?s=%D8%B5%D9%8E%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise","tags":["intransitive"],"examples":[{"text":"يَوْمَئِذٍ يَصْدُرُ النَّاسُ أَشْتَاتًا لِّيُرَوْا أَعْمَالَهُمْ","english":"On that Day people will proceed in separate groups to be shown [the consequences of] their deeds."}]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to materialize, to happen, to occur","tags":["intransitive"]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to emerge as if from a source, to proceed, to emanate, to arise, to originate, to stem, to spring","tags":["intransitive"]},{"pos":"verb","gloss":"to emerge; to come up; to spring; to issue; to rise; to be released; to be public or available, to be out; to come out; to circulate","tags":["intransitive"],"examples":[{"text":"صَدَرَ الْكِتَابُ مِنْ دَارِ النَّشْرِ يَوْمَ الْأَرْبِعَاء.","english":"The book issued from the publisher on Wednesday."}]},{"pos":"verb","gloss":"to send, to send off, to send out; to export","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to send, to send off, to send out; to dispatch; to forward; to transport","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to send, to send off, to send out; to publish, to issue, to promulgate","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to preface; to introduce","tags":["intransitive","transitive"]},{"pos":"noun","gloss":"verbal noun of صَدَرَ (ṣadara, “to emerge; to materialize; to be released publicly”) (form I)","tags":["form-of","intransitive","noun-from-verb","transitive","uncountable"]},{"pos":"noun","gloss":"verbal noun of صَدَرَ (ṣadara, “to hit in the chest”) (form I)","tags":["form-of","intransitive","noun-from-verb","transitive","uncountable"]},{"pos":"noun","gloss":"a chest, a breast; a bust, a bosom","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a chest, a breast; something resembling, likened to, or related to chests (such as a center, a core, a heart, and so on)","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a front","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a front; a person at the front, a leader, a commander","tags":["countable","intransitive","transitive"]},{"pos":"noun","gloss":"a beginning, a start, an outset, a commencement; an inception; a dawn, a rise","tags":["countable","intransitive","transitive"]},{"pos":"verb","gloss":"to hurt the chest of; to hit in the chest","tags":["intransitive","transitive"]},{"pos":"verb","gloss":"to have a chest complaint","tags":["intransitive","transitive"]}]},"etymology":null,"ipa":["/sˤa.da.ra/","/sˤad.da.ra/","/sˤadr/","/sˤu.di.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23929","headword_ar":"صَدَرَ","root":"Sdr","body":[{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":"(S, M, Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":"(S, M, A, Msb, K) and"},{"kind":"arabic","text_bw":"SuduwrN","text_ar":"صُدُورٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"maSodarN","text_ar":"مَصْدَرٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"mazodarN","text_ar":"مَزْدَرٌ"},{"kind":"text","text":"because of the similarity [of the letters"},{"kind":"arabic","text_bw":"S","text_ar":"ص"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":"], (M,)"},{"kind":"italic_en","text":"He returned, went back;"},{"kind":"text","text":"(S, M, A, Msb, K;) and"},{"kind":"italic_en","text":"went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned, away;"},{"kind":"text","text":"(Msb;) from ("},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":") water, (S, M, A,) and a country, (S, M,) or a place, (Msb,) and (assumed tropical:)  any affair. (Lth.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"Sadara Alqawolu","text_ar":"صَدَرَ القَوْلُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SuduwrN","text_ar":"صُدُورٌ"},{"kind":"text","text":", (assumed tropical:)  ["},{"kind":"italic_en","text":"The saying issued, proceeded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emanated,"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"italic_en","text":"from him."},{"kind":"text","text":"] (Msb.) [And"},{"kind":"arabic","text_bw":"Sadara Eanohu AlfiEolu","text_ar":"صَدَرَ عَنْهُ الفِعْلُ"},{"kind":"text","text":", with the same aor. and inf. n., (assumed tropical:)"},{"kind":"italic_en","text":"The action proceeded from him."},{"kind":"text","text":"] ―         -b3-  And"},{"kind":"arabic","text_bw":"Sadara A_ilayohi","text_ar":"صَدَرَ اـِلَيْهِ"},{"kind":"italic_en","text":"He went to it;"},{"kind":"text","text":"namely, a place: (TA:)"},{"kind":"italic_en","text":"he came to it."},{"kind":"text","text":"(Kull. p. 228.)       -A2-"},{"kind":"arabic","text_bw":"Sadarahu","text_ar":"صَدَرَهُ"},{"kind":"text","text":": see 4.       -A3-  Also, (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He hit, struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, his"},{"kind":"arabic","text_bw":"Sador","text_ar":"صَدْر"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"breast"},{"kind":"text","text":"]. (M, K.) You say,"},{"kind":"arabic","text_bw":"Darabotuhu faSadarotuhu","text_ar":"ضَرَبْتُهُ فَصَدَرْتُهُ"},{"kind":"italic_en","text":"I struck him and hit his breast."},{"kind":"text","text":"(A.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Sadira","text_ar":"صَدِرَ"},{"kind":"italic_en","text":"He had a complaint of the"},{"kind":"arabic","text_bw":"Sador","text_ar":"صَدْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"chest"},{"kind":"text","text":"]. (M, K.) [See its part. n., below.]"}],"source_refs":["S","M","A","Msb","K","TA"]}]}}