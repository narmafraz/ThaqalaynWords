"role":"present_2md","form":"تُثَنَّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُثَنِّيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُثَنِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُثَنُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُثَنُّونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُثَنَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُثَنِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُثَنّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُثَنَّى","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُثَنِّي","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُثَنّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُثَنَّى","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُثَنِّي","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُثَنَّيانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُثَنَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُثَنِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُثَنِّيانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُثَنَّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُثَنَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُثَنِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُثَنِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُثَنُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُثَنُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُثَنَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُثَنِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُثَنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُثَنَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُثَنَّى","in_corpus":true,"count":36,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ثَنَّيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ثَنَّيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُثَنِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُثَنِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":68,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n4758","n4759","n4760","n4761","n4771"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D9%86%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of ثَنَى (ṯanā) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"folding, bending"},{"pos":"noun","gloss":"flexing (bending a joint)"},{"pos":"noun","gloss":"duplicature, tuck, pleat, fold, twist"},{"pos":"noun","gloss":"a single repetition of a thing; time"}]},"etymology":null,"ipa":["/θanj/","/θinj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4758","headword_ar":"ثِنْىٌ","root":"vnY","body":[{"kind":"italic_en","text":"A duplication,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubling,"},{"kind":"text","text":"of a thing: (T, * S, Msb:) pl."},{"kind":"arabic","text_bw":"A^avonaA='N","text_ar":"اَثْنَا=ءٌ"},{"kind":"text","text":"; (S, Msb;) or the sing. may be ↓"},{"kind":"arabic","text_bw":"vanFY","text_ar":"ثَنًى","orth_type":"arrow"},{"kind":"text","text":". (Msb.) ―         -b2-"},{"kind":"italic_en","text":"A folding:"},{"kind":"text","text":"so in the saying,"},{"kind":"arabic","text_bw":"A^anofa*otu ka*aA vinoYa kitaAbiY","text_ar":"اَنْفَذْتُ كَذَا ثِنْىَ كِتَابِى"},{"kind":"text","text":", (S, TA,) or"},{"kind":"arabic","text_bw":"fiY vinoYi kitaAbiYi","text_ar":"فِى ثِنْىِ كِتَابِىِ"},{"kind":"text","text":"(so in a copy of the S,) i. e.,"},{"kind":"arabic","text_bw":"fiY Tay~ihi","text_ar":"فِى طَيِّهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"I sent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transmitted, such a thing within the folding of my writing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"letter;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"infolded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enclosed, in it;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"included in it"},{"kind":"text","text":"]. (S, TA.) ―         -b3-"},{"kind":"italic_en","text":"A duplicature,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fold,"},{"kind":"text","text":"of a garment, or piece of cloth: (TA:) or"},{"kind":"italic_en","text":"what is turned back"},{"kind":"text","text":"of the extremities thereof: (T:) pl. as above: whence, in a trad. of Aboo-Hureyreh,"},{"kind":"arabic","text_bw":"kaAna yavoniyhi Ealayohi A^avonaA='F mino saEatihi","text_ar":"كَانَ يَثْنِيهِ عَلَيْهِ اَثْنَا=ءً مِنْ سَعَتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He used to fold it upon him in folds by reason of its width"},{"kind":"text","text":"]; meaning the garment. (TA.) [Hence the saying,]"},{"kind":"arabic","text_bw":"wakaAna *`lika fiY A^avonaA='i ka*aA","text_ar":"وَكَانَ ذٰلِكَ فِى اَثْنَا=ءِ كَذَا"},{"kind":"text","text":", i. e.,"},{"kind":"arabic","text_bw":"fY guDuwnihi","text_ar":"فى غُضُونِهِ"},{"kind":"text","text":"[lit"},{"kind":"italic_en","text":"And that was in the folds,"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"in the midst, of such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"jaAw^uwA fiY A^avonaA='i AlA^amori","text_ar":"جَاوُوا فِى اَثْنَا=ءِ الاَمْرِ"},{"kind":"italic_en","text":"They came in the midst of the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event."},{"kind":"text","text":"(Msb.) [And hence, app.,]"},{"kind":"arabic","text_bw":"maDaY vinoYN mina All~ayol","text_ar":"مَضَى ثِنْىٌ مِنَ اللَّيْل"},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a period,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short portion, of the night passed;"},{"kind":"text","text":"(M, K; *) syn."},{"kind":"arabic","text_bw":"saAEapN","text_ar":"سَاعَةٌ"},{"kind":"text","text":", (Th, M, K,) or"},{"kind":"arabic","text_bw":"waqotN","text_ar":"وَقْتٌ"},{"kind":"text","text":". (Lh, M, K.) [See also what is said below respecting its pl. in relation to a night.] ―         -b4-  Also sing. of"},{"kind":"arabic","text_bw":"A^avonaA='N","text_ar":"اَثْنَا=ءٌ"},{"kind":"text","text":"meaning The"},{"kind":"italic_en","text":"parts"},{"kind":"text","text":"of a thing"},{"kind":"italic_en","text":"that are laid together like the strands of a rope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that are laid one upon another as layers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strata,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"side by side as the things that compose a bundle;"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"quwaAhu","text_ar":"قُوَاهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"TaAqaAtuhu","text_ar":"طَاقَاتُهُ"},{"kind":"text","text":"; [rendered by Freytag “ virtutes, facultates rei; ”]) and ↓"},{"kind":"arabic","text_bw":"mavaAnK","text_ar":"مَثَانٍ","orth_type":"arrow"},{"kind":"text","text":", of which the sing. is ↓"},{"kind":"arabic","text_bw":"mavonaApN","text_ar":"مَثْنَاةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mivonaApN","text_ar":"مِثْنَاةٌ","orth_type":"arrow"},{"kind":"text","text":", signifies the same. (M, K.) ―         -b5-  Also"},{"kind":"italic_en","text":"A bending of the neck"},{"kind":"text","text":"of a sheep, or goat,"},{"kind":"italic_en","text":"not in consequence of disease:"},{"kind":"text","text":"(K: but in the M,"},{"kind":"arabic","text_bw":"vanoYN","text_ar":"ثَنْىٌ"},{"kind":"text","text":"[inf. n. of 1]:) and a serpent's"},{"kind":"italic_en","text":"bending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"folding, of itself:"},{"kind":"text","text":"(M, K:) and also (thus in the M, but in the K “or”)"},{"kind":"italic_en","text":"a curved part"},{"kind":"text","text":"of a serpent that has folded itself; (M, K;) pl."},{"kind":"arabic","text_bw":"A^avonaA='N","text_ar":"اَثْنَا=ءٌ"},{"kind":"text","text":", (M,) i. e. the"},{"kind":"italic_en","text":"folds"},{"kind":"text","text":"of a coiled serpent. (T.) The pl. is used metaphorically [as though meaning (tropical:)  The"},{"kind":"italic_en","text":"turns"},{"kind":"text","text":"] of a night. (M. [But see explanations of the sing. as used in relation to a night in what precedes.] ―         -b6-"},{"kind":"italic_en","text":"A part that is bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"folded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubled,"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"wi$aAH","text_ar":"وِشَاح"},{"kind":"text","text":"[q. v.]; (TA;) pl. as above: (T, TA:) and so of a rope: (S:) or"},{"kind":"italic_en","text":"a portion of the extremity"},{"kind":"text","text":"of a rope"},{"kind":"italic_en","text":"folded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubled,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to form a loop,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for binding therewith the pastern of the fore leg of a beast, to serve as a tether."},{"kind":"text","text":"(T.) Tarafeh says,"},{"kind":"quote","text":"laEamoruka A_in~a Almawota maA A^axoTaA^a AlfataY\n                      \n                     \n                        lakaAlT~iwali AlmuroxaY wavinoyaAhu biAloyadi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By thy life, death, while missing the strong young man, is like the tether that is slackened while the two folded extremities thereof are upon the fore leg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the hand:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"TiwalN","text_ar":"طِوَلٌ"},{"kind":"text","text":"]: (T, S:) he means that the young man must inevitably die, though his term of life be protracted; like as the beast, though his tether be lengthened and slackened, cannot escape, being withheld by its two extremities: (so in a copy of the T:) or by"},{"kind":"arabic","text_bw":"vnyAh","text_ar":"ثنياه"},{"kind":"text","text":"he means"},{"kind":"italic_en","text":"its extremity;"},{"kind":"text","text":"using the dual form because it is folded, or doubled, upon the pastern, and tied with a double tie: (so in another copy of the T:) or he means,"},{"kind":"italic_en","text":"while its two extremities are in the hand"},{"kind":"text","text":"of its owner: (EM p. 91:) by"},{"kind":"arabic","text_bw":"mA AxTA^","text_ar":"ما اخطا"},{"kind":"text","text":", he means"},{"kind":"arabic","text_bw":"fiY A_ixoTaAy^ihi","text_ar":"فِى اـِخْطَايِهِ"},{"kind":"text","text":", (S in art."},{"kind":"arabic","text_bw":"Twl","text_ar":"طول"},{"kind":"text","text":",) or"},{"kind":"arabic","text_bw":"mud~apa A_ixoTaAy^ihi","text_ar":"مُدَّةَ اـِخْطَايِهِ"},{"kind":"text","text":": and the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"[prefixed to the"},{"kind":"arabic","text_bw":"k","text_ar":"ك"},{"kind":"text","text":"of comparison] is for corroboration. (EM ubi suprá.) You say also,"},{"kind":"arabic","text_bw":"rab~aqa A^avonaA='a AlHaboli","text_ar":"رَبَّقَ اَثْنَا=ءَ الحَبْلِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He made loops in the middle of the rope to put upon the necks of the young lambs or kids."},{"kind":"text","text":"(T.) ―         -b7-  Also"},{"kind":"italic_en","text":"A bend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of bending,"},{"kind":"text","text":"of a valley, (S, M, * K,) and of a mountain: (S:) pl. as above: (M,"},{"kind":"page_break","n":358},{"kind":"text","text":"K:) and ↓"},{"kind":"arabic","text_bw":"mavaAnK","text_ar":"مَثَانٍ","orth_type":"arrow"},{"kind":"text","text":"[likewise] signifies the"},{"kind":"italic_en","text":"bends"},{"kind":"text","text":"of a valley. (T, K.)       -A2-  A she-camel"},{"kind":"italic_en","text":"that has brought forth twice,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"two,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"a second time:"},{"kind":"text","text":"(K:) or, as some say,"},{"kind":"italic_en","text":"that has brought forth once:"},{"kind":"text","text":"but the former is more analogical: (M:) one does not say"},{"kind":"arabic","text_bw":"vilovN","text_ar":"ثِلْثٌ"},{"kind":"text","text":"[as meaning “ that has brought forth thrice ”], nor use any similar epithet above this: (S, TA:) pl."},{"kind":"arabic","text_bw":"vunaA='N","text_ar":"ثُنَا=ءٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"Zuw^aArN","text_ar":"ظُوَارٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"Ziy^orN","text_ar":"ظِيْرٌ"},{"kind":"text","text":", accord. to Sb, (M, TA,) and"},{"kind":"arabic","text_bw":"A^avonaA='N","text_ar":"اَثْنَا=ءٌ"},{"kind":"text","text":"accord. to others: (TA:) in like manner it is applied to a woman, (S, M,) metaphorically: (M:) and to the she-camel's"},{"kind":"italic_en","text":"second young one:"},{"kind":"text","text":"(S, M:) accord. to As, as related by A'Obeyd, a she-camel that has brought forth once: also that has brought forth twice: [so says Az, but he adds,] but what I have heard from the Arabs is this; that they term a she-camel that has brought forth her first young one"},{"kind":"arabic","text_bw":"bikor","text_ar":"بِكْر"},{"kind":"text","text":"; and her first young one, her"},{"kind":"arabic","text_bw":"bikor","text_ar":"بِكْر"},{"kind":"text","text":"; and when she brought forth a second, she is termed"},{"kind":"arabic","text_bw":"vinoYN","text_ar":"ثِنْىٌ"},{"kind":"text","text":"; and her young one, her"},{"kind":"arabic","text_bw":"vinoY","text_ar":"ثِنْى"},{"kind":"text","text":": and this is what is correct. (T.) [Hence the saying,]"},{"kind":"arabic","text_bw":"maA h`*aA AlA^amoru minoka bikorFA walaA vinoyFA","text_ar":"مَا هٰذَا الاَمْرُ مِنْكَ بِكْرًا وَلَا ثِنْيًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"This thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, is not thy first nor thy second."},{"kind":"text","text":"(A and TA in art."},{"kind":"arabic","text_bw":"bkr","text_ar":"بكر"},{"kind":"text","text":".) ―         -b2-  See also"},{"kind":"arabic","text_bw":"vunoyaAnN","text_ar":"ثُنْيَانٌ"},{"kind":"text","text":"."}],"source_refs":["S","TA","T","Th","M","K"]},{"entry_id":"n4759","headword_ar":"ثَنًى","root":"vnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"vinoYN","text_ar":"ثِنْىٌ"},{"kind":"text","text":", first sentence."}],"source_refs":[]},{"entry_id":"n4760","headword_ar":"ثُنًى","root":"vnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"vinFY","text_ar":"ثِنًى"},{"kind":"text","text":": ―         -b2-  and see also"},{"kind":"arabic","text_bw":"vunoyaAnN","text_ar":"ثُنْيَانٌ"},{"kind":"text","text":": ―         -b3-  and"},{"kind":"arabic","text_bw":"AivonaAni","text_ar":"اِثْنَانِ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n4761","headword_ar":"ثِنًى","root":"vnY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"repetition of a thing; doing it one time after another:"},{"kind":"text","text":"(Aboo-Sa'eed, TA:) or"},{"kind":"italic_en","text":"a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair, done twice:"},{"kind":"text","text":"(S, Msb, TA:) this is the primary signification: (TA:) and ↓"},{"kind":"arabic","text_bw":"vunFY","text_ar":"ثُنًى","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (IB, TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA vinaY fiY AlS~adaqapi","text_ar":"لَا ثِنَى فِى الصَّدَقَةِ"},{"kind":"italic_en","text":"There shall be no repetition in the taking of the poor-rate;"},{"kind":"text","text":"(IAth, TA;) [i. e.]"},{"kind":"italic_en","text":"the poor-rate shall not be taken twice in one year:"},{"kind":"text","text":"(As, Ks, T, S, M, Mgh, K:) or"},{"kind":"italic_en","text":"two she-camels shall not be taken in the place of one for the poor-rate:"},{"kind":"text","text":"(M, IAth, K: *) or"},{"kind":"italic_en","text":"there shall be no retracting of an alms;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"no revoking it:"},{"kind":"text","text":"(Mgh, K, * TA:) this last is the meaning accord. to Aboo-Sa'eed, (Mgh, TA,) i. e. Ed-Dareeree, (Mgh,) who, in explaining this trad., as relating to the giving an alms to a man and then desiring to take it back, says he does not deny that"},{"kind":"arabic","text_bw":"vinFY","text_ar":"ثِنًى"},{"kind":"text","text":"has the meaning first assigned to it above in this paragraph. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"vunoyAnN","text_ar":"ثُنْيانٌ"},{"kind":"text","text":": ―         -b3-  and"},{"kind":"arabic","text_bw":"AivonaAni","text_ar":"اِثْنَانِ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","TA","As","Ks","T","M","Mgh","K"]},{"entry_id":"n4771","headword_ar":"ثَنِىٌّ","root":"vnY","body":[{"kind":"italic_en","text":"Shedding his tooth called the"},{"kind":"arabic","text_bw":"vaniy~ap","text_ar":"ثَنِيَّة"},{"kind":"text","text":"[q. v.]: (S, M, Msb:) or"},{"kind":"italic_en","text":"that has shed the tooth so called:"},{"kind":"text","text":"(T, Mgh:) applied to a camel &c., as follows: (T, S, M, &c.:) or, as some say, to any animal that has shed that tooth, except man: (M:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (T, S, M, Msb, K:) a camel"},{"kind":"italic_en","text":"in the sixth year;"},{"kind":"text","text":"(T, S, M, IAth, Mgh, Msb, K;) the least"},{"kind":"page_break","n":359},{"kind":"text","text":"age at which he may be sacrificed: (T:) and a horse"},{"kind":"italic_en","text":"in the fourth year;"},{"kind":"text","text":"(IAar, T, Mgh, K;) or"},{"kind":"italic_en","text":"in the third year:"},{"kind":"text","text":"(S, Msb:) and a cloven-hoofed animal, (S, Mgh, Msb,) or a sheep or goat and an animal of the bovine kind, [respecting which last see"},{"kind":"arabic","text_bw":"EaDobN","text_ar":"عَضْبٌ"},{"kind":"text","text":",] (T, IAth, K,)"},{"kind":"italic_en","text":"in the third year:"},{"kind":"text","text":"(T, S, IAth, Mgh, Msb, K:) or a sheep and a goat, (M,) the latter accord. to the persuasion of Ahmad [Ibn-Hambal], (TA,)"},{"kind":"italic_en","text":"in the second year:"},{"kind":"text","text":"(M:) and a gazelle"},{"kind":"italic_en","text":"after the age at which he is termed"},{"kind":"arabic","text_bw":"ja*aEN","text_ar":"جَذَعٌ"},{"kind":"text","text":": (M: [see"},{"kind":"arabic","text_bw":"$aSarN","text_ar":"شَصَرٌ"},{"kind":"text","text":":]) in all cases,"},{"kind":"italic_en","text":"after what is termed"},{"kind":"arabic","text_bw":"ja*aEN","text_ar":"جَذَعٌ"},{"kind":"italic_en","text":"and before what is termed"},{"kind":"arabic","text_bw":"rabaAEK","text_ar":"رَبَاعٍ"},{"kind":"text","text":": (Mgh:) pl. (masc., S, TA)"},{"kind":"arabic","text_bw":"vunoyaAnN","text_ar":"ثُنْيَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vinaA='N","text_ar":"ثِنَا=ءٌ"},{"kind":"text","text":"(S, M, Mgh, Msb) and"},{"kind":"arabic","text_bw":"vunaA='N","text_ar":"ثُنَا=ءٌ"},{"kind":"text","text":", and, accord. to Sb,"},{"kind":"arabic","text_bw":"vunK","text_ar":"ثُنٍ"},{"kind":"text","text":"; (M;) and pl. fem."},{"kind":"arabic","text_bw":"vaniy~aAtN","text_ar":"ثَنِيَّاتٌ"},{"kind":"text","text":". (S.)"}],"source_refs":["S","M","Msb","T","Mgh","K","IAth","TA"]}]}}