"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n39952"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%92%D8%B6%D9%8E%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bring to maturity"},{"pos":"verb","gloss":"to make well-done, to cook to the end"}]},"etymology":null,"ipa":["/ʔan.dˤa.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39952","headword_ar":"انضج","root":"nDj","body":[{"kind":"italic_en","text":"He rendered"},{"kind":"text","text":"fruit, or flesh-meat, (whether dried in the sun or roasted, TA, [or cooked in any way],)"},{"kind":"italic_en","text":"perfectly fit for being used,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for being eaten: rendered ripe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mature: thoroughly cooked:"},{"kind":"text","text":"(S, K:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the proper time)"},{"kind":"italic_en","text":"rendered"},{"kind":"text","text":"fruit"},{"kind":"italic_en","text":"ripe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mature; ripened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"matured it."},{"kind":"text","text":"(TA.) ―         -b2-  AHn uses this verb in a strange manner, explaining the expression"},{"kind":"arabic","text_bw":"nabaAtN mahoruwo'N","text_ar":"نَبَاتٌ مَهْرُوْءٌ"},{"kind":"text","text":"by the words"},{"kind":"arabic","text_bw":"A^al~a*iY qado","text_ar":"اَلَّذِى قَدْ"},{"kind":"arabic","text_bw":"A^anoDajahu Albarodu","text_ar":"اَنْضَجَهُ البَرْدُ"},{"kind":"text","text":"[meaning,"},{"kind":"italic_en","text":"a plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, that is nipped, shrunk, shrivelled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blasted, by the cold"},{"kind":"text","text":"]: this is strange because"},{"kind":"arabic","text_bw":"A_inoDaAj","text_ar":"اـِنْضَاج"},{"kind":"text","text":"is an effect"},{"kind":"page_break","n":2806},{"kind":"text","text":"of heat; not of cold. (M.) [See"},{"kind":"arabic","text_bw":"A^aHoraqa","text_ar":"اَحْرَقَ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"A^anoDijo raA^oyaka","text_ar":"اَنْضِجْ رَاْيَكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Mature thy judgment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thine opinion"},{"kind":"text","text":"]. (A.) ―         -b4-"},{"kind":"arabic","text_bw":"laA yunoDiju AlskuraAEa","text_ar":"لَا يُنْضِجُ السكُرَاعَ"},{"kind":"text","text":", (L,) or"},{"kind":"arabic","text_bw":"kuraAEFA","text_ar":"كُرَاعًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"laA yasotanoDiju","text_ar":"لَا يَسْتَنْضِجُ","orth_type":"arrow"},{"kind":"text","text":", (A,) ["},{"kind":"italic_en","text":"He does not thoroughly cook the slender part of the leg of a sheep,"},{"kind":"text","text":"or the like]: i. e., he is weak, and of no use, or does not possess a competence. (L.) ―         -b5-  ["},{"kind":"arabic","text_bw":"AnDj","text_ar":"انضج"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It matured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused to suppurate,"},{"kind":"text","text":"an ulcer or the like; as also ↓"},{"kind":"arabic","text_bw":"nD~j","text_ar":"نضّج","orth_type":"arrow"},{"kind":"text","text":".]"}],"source_refs":["S","K","L","A"]}]},"classical_definitions":null}