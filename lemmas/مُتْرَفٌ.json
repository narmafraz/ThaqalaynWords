{"lemma":"مُتْرَفٌ","slug":"مُتْرَفٌ","root":"ت.ر.ف","root_slug":"ت-ر-ف","root_link":"/words/roots/ت-ر-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُتْرَف","root":"ترف","pos":"N","occurrence_count":5},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n3899"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AA%D9%92%D8%B1%D9%8E%D9%81%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3899","headword_ar":"مُتْرَفٌ","root":"trf","body":[{"kind":"text","text":"[pass. part. n. of 4, q. v.] One"},{"kind":"italic_en","text":"left to do what he will; not prevented from doing so."},{"kind":"text","text":"(Ibn- 'Arafeh, K.) ―         -b2-  And hence, (Ibn-'Arafeh, TA,) One"},{"kind":"italic_en","text":"enjoying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leading, a plentiful; and a pleasant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an easy, and a soft"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate, life;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a life of ease and plenty:"},{"kind":"text","text":"(Ibn-'Arafeh, M, K, TA:)"},{"kind":"italic_en","text":"luxurious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indulging himself largely in the pleasures,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delights, of the present life, and in its appetites,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eager desires:"},{"kind":"text","text":"(Ibn-'Arafeh, TA:) one"},{"kind":"italic_en","text":"who is not prevented from enjoying himself:"},{"kind":"text","text":"(K, TA:) and one"},{"kind":"italic_en","text":"whose means of subsistence are made ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plentiful;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mutar~afN","text_ar":"مُتَرَّفٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) one"},{"kind":"italic_en","text":"whom plentifulness, and pleasantness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easiness, and softness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicacy, of life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whom a life of ease and plenty,"},{"kind":"text","text":"(T,) or"},{"kind":"italic_en","text":"whom wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what God has bestowed upon him, and plentifulness and easiness of life,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"causes to exult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to exult greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and to behave insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"(T, Mgh:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jab~aArN","text_ar":"جَبَّارٌ"},{"kind":"text","text":"[i. e. one"},{"kind":"italic_en","text":"who magnifies himself;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaves proudly, haughtily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insolently;"},{"kind":"text","text":"&c.]: (K:) so says Katádeh, in explaining the phrase"},{"kind":"arabic","text_bw":"A^amaronaA mutorafiyhaA","text_ar":"اَمَرْنَا مُتْرَفِيهَا"},{"kind":"text","text":", in the Kur [xvii. 17: see"},{"kind":"arabic","text_bw":"A^amara","text_ar":"اَمَرَ"},{"kind":"text","text":"]: or, accord. to some,"},{"kind":"arabic","text_bw":"mtrfyhA","text_ar":"مترفيها"},{"kind":"text","text":"here means"},{"kind":"italic_en","text":"the worst of its chiefs; and the leaders in evil."},{"kind":"text","text":"(TA.) ―         -b3-  Also, (TA,) or ↓"},{"kind":"arabic","text_bw":"mutar~afN","text_ar":"مُتَرَّفٌ","orth_type":"arrow"},{"kind":"text","text":", (T,) A boy"},{"kind":"italic_en","text":"made soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate, in body, and rendered submissive."},{"kind":"text","text":"(T, TA.)"}],"source_refs":["K","TA","M","T","Mgh"]}]},"classical_definitions":null}