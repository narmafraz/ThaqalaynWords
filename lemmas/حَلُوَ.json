m","num":"s"},{"role":"present_1mp","form":"نَحْلَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":399,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","name"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n8953","n8954","n8959"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%84%D9%8F%D9%88%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"sweet"},{"pos":"adj","gloss":"nice, charming, pretty, pleasant"},{"pos":"name","gloss":"a surname"}]},"etymology":null,"ipa":["/ħulw/","/ħi.luː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8953","headword_ar":"حُلْوٌ","root":"Hlw","body":[{"kind":"italic_en","text":"Sweet; contr. of"},{"kind":"arabic","text_bw":"mur~N","text_ar":"مُرٌّ"},{"kind":"text","text":"; (S, K;) i. e., in the mouth: and in like manner, in the eye [meaning"},{"kind":"italic_en","text":"pleasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful:"},{"kind":"text","text":"see 1]: (TA:) applied also to a saying, and to an action: (K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"AlHulowu AlHalaAlu","text_ar":"الحُلْوُ الحَلَالُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Language in which is nothing that induces doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion:"},{"kind":"text","text":"(K and TA in art."},{"kind":"arabic","text_bw":"Hl","text_ar":"حل"},{"kind":"text","text":":) and"},{"kind":"italic_en","text":"the man in whom is nothing that induces doubt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspicion."},{"kind":"text","text":"(TA in the present art.) And"},{"kind":"arabic","text_bw":"HulowN","text_ar":"حُلْوٌ"},{"kind":"text","text":", also, applied to a man, (assumed tropical:)  One"},{"kind":"italic_en","text":"who is excited to briskness, liveliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightliness,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yusotaxaf~N","text_ar":"يُسْتَخَفٌّ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and is esteemed pleasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful, in the eye;"},{"kind":"text","text":"(K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"Haluw~N","text_ar":"حَلُوٌّ","orth_type":"arrow"},{"kind":"text","text":": (IAar, K:) the fem. is"},{"kind":"arabic","text_bw":"HulowapN","text_ar":"حُلْوَةٌ"},{"kind":"text","text":": the pl. masc."},{"kind":"arabic","text_bw":"Hulowuwna","text_ar":"حُلْوُونَ"},{"kind":"text","text":", and pl. fem."},{"kind":"arabic","text_bw":"HilowN","text_ar":"حِلْوٌ"},{"kind":"text","text":": (K:) there is no broken pl., masc. or fem. (TA.)"}],"source_refs":["TA","K","IAar"]},{"entry_id":"n8954","headword_ar":"حُلْوٌ","root":"Hlw","body":[{"kind":"italic_en","text":"A small"},{"kind":"arabic","text_bw":"Haf~","text_ar":"حَفّ"},{"kind":"text","text":"[q. v., in the CK, erroneously,"},{"kind":"arabic","text_bw":"xuf~","text_ar":"خُفّ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"with which one weaves:"},{"kind":"text","text":"(K, TA:) or the"},{"kind":"italic_en","text":"wooden thing which the weaver turns round:"},{"kind":"text","text":"[app. meaning the"},{"kind":"italic_en","text":"yarn-beam, upon which the yarn is rolled;"},{"kind":"text","text":"termed"},{"kind":"arabic","text_bw":"Haf~apN","text_ar":"حَفَّةٌ"},{"kind":"text","text":":] the poet Shemmákh likens the tongue of a braying [wild] ass to a"},{"kind":"arabic","text_bw":"Hilow","text_ar":"حِلْو"},{"kind":"text","text":"that has slipped from the back of a loom. (TA.)"}],"source_refs":["K","TA"]},{"entry_id":"n8959","headword_ar":"حَلُوٌّ","root":"Hlw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HulowN","text_ar":"حُلْوٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"naAqapN Haluw~apN","text_ar":"نَاقَةٌ حَلُوَّةٌ"},{"kind":"text","text":": see the next paragraph."}],"source_refs":[]}]}}