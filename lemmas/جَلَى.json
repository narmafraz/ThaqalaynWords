ody":[{"kind":"text","text":": see 1, in six places.       -A2-  Also, inf. n."},{"kind":"arabic","text_bw":"tajoliyapN","text_ar":"تَجْلِيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tajoliY~N","text_ar":"تَجْلِىٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a hawk, or falcon,)"},{"kind":"italic_en","text":"raised his head, and looked,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"seeing the prey:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a hawk)"},{"kind":"italic_en","text":"closed his eyes, and then opened them, in order to see more clearly."},{"kind":"text","text":"(Ibn- Hamzeh, TA.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"jl~Y bibaSarihi","text_ar":"جلّى بِبَصَرِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajoliyapN","text_ar":"تَجْلِيَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He cast his eyes"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"like the hawk looking at the prey."},{"kind":"text","text":"(S.)       -A3-  ["},{"kind":"arabic","text_bw":"jl~Y","text_ar":"جلّى"},{"kind":"text","text":"is also mentioned (in Har p. 161), on the authority of Mtr, as signifying"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, outstripped;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Almujal~iY","text_ar":"المُجَلِّى"},{"kind":"text","text":"meaning “ the first of the horses in a race; ” but as being not known in this sense on any other authority.]"}],"source_refs":["K","TA","S"]},{"entry_id":"n6202","headword_ar":"جَلِىٌّ","root":"jlw","body":[{"kind":"italic_en","text":"Clear, unobscured, exposed to view, displayed, laid open, disclosed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncovered: apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly apparent, overt, conspicuous, manifest, notorious, plain, obvious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident:"},{"kind":"text","text":"(S, Msb, K, TA:)"},{"kind":"arabic","text_bw":"jaAlK","text_ar":"جَالٍ"},{"kind":"text","text":"thus used has not been heard. (Er-Rághib, TA.) It is applied as an epithet to information, or tidings, (Msb, TA,)"},{"kind":"page_break","n":448},{"kind":"text","text":"and to analogy, or rule. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"EayonN jaliy~apN","text_ar":"عَيْنٌ جَلِيَّةٌ"},{"kind":"italic_en","text":"A seeing eye."},{"kind":"text","text":"(IB, TA.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AC%D9%84%D9%89/","headword_ar":"جلى","entries":[{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=65626#fd94b1","body_html":"<h3>جل</h3>ى<br><br>Some words are mentioned in the <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> under this head belonging to art. جلو, <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">q.</abbr> v."}]}}