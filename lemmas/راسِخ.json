{"lemma":"راسِخ","slug":"راسِخ","root":"ر.س.خ","root_slug":"ر-س-خ","root_link":"/words/roots/ر-س-خ","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"راسِخ","root":"رسخ","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n15467"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%B3%D9%90%D8%AE"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of رَسَخَ (rasaḵa)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"active participle of رَسَخَ (rasaḵa); firmly planted, enshrined, steadfast, established, unwavering"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb form I from the root ر س خ (r s ḵ)."},"ipa":["/raː.six/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15467","headword_ar":"رَاسِخٌ","root":"rsx","body":[{"kind":"text","text":"Anything"},{"kind":"italic_en","text":"firm, steady, steadfast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in its place"},{"kind":"text","text":"(see 1)]. (S, A, Msb.) You say"},{"kind":"arabic","text_bw":"jabalN raAsixN","text_ar":"جَبَلٌ رَاسِخٌ"},{"kind":"italic_en","text":"A firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steadfast, mountain."},{"kind":"text","text":"(A.) And in like manner"},{"kind":"arabic","text_bw":"dimonapN raAsixapN","text_ar":"دِمْنَةٌ رَاسِخَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A black,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dark, patch of compacted dung and urine of cattle sticking fast upon the ground"},{"kind":"text","text":"]. (A.) And [hence,]"},{"kind":"arabic","text_bw":"lahu qadamN","text_ar":"لَهُ قَدَمٌ"},{"kind":"arabic","text_bw":"raAsixapN fiY AlEilomi","text_ar":"رَاسِخَةٌ فِى العِلْمِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He has a firm footing in science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he possesses excellence, and large acquirements, in science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"Alr~aAsixuwna fiY AlEilomi","text_ar":"الرَّاسِخُونَ فِى العِلْمِ"},{"kind":"text","text":"[in the Kur iii. 5 and iv. 160] means (tropical:)"},{"kind":"italic_en","text":"Those who are firmly rooted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established, in science,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge:"},{"kind":"text","text":"(S, Bd, L, Jel, TA:) or"},{"kind":"italic_en","text":"who have made a firm advance therein:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"who are far advanced therein:"},{"kind":"text","text":"(Khálid Ibn-Jembeh:) or"},{"kind":"italic_en","text":"those who study the Book of God:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"those who have committed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to memory, and who call to mind"},{"kind":"text","text":"["},{"kind":"italic_en","text":"its doctrines and precepts"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one with another."},{"kind":"text","text":"(IAar.)"}],"source_refs":["S","Bd","L","Jel","TA"]}]}}