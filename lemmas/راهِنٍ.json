{"lemma":"راهِنٍ","slug":"راهِنٍ","root":"ر.ه.ن","root_slug":"ر-ه-ن","root_link":"/words/roots/ر-ه-ن","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n16920"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D9%87%D9%90%D9%86%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16920","headword_ar":"رَاهِنٌ","root":"rhn","body":[{"kind":"italic_en","text":"Continuing, subsisting, lasting, enduring, remaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary, permanent, constant, firm, steady, steadfast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established."},{"kind":"text","text":"(S, * Mgh, Msb.) You say"},{"kind":"arabic","text_bw":"TaEaAmN raAhinN","text_ar":"طَعَامٌ رَاهِنٌ"},{"kind":"text","text":"(S, Mgh)"},{"kind":"italic_en","text":"Food that continues,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is permanent,"},{"kind":"text","text":"&c. (Mgh.) And"},{"kind":"arabic","text_bw":"xamorN raAhinapN","text_ar":"خَمْرٌ رَاهِنَةٌ"},{"kind":"italic_en","text":"Wine of which there is a con tinual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, supply; uninterrupted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unfailing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"niEomapu A@ll~`hi raAhinapN","text_ar":"نِعْمَةُ ا@للّٰهِ رَاهِنَةٌ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"The bounty of God is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"continual, permanent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"HaAlapN raAhinapN","text_ar":"حَالَةٌ رَاهِنَةٌ"},{"kind":"italic_en","text":"A state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, continuing; remaining to the present time."},{"kind":"text","text":"(Es-Semeen, TA.) And"},{"kind":"arabic","text_bw":"h`*aA raAhinN laka","text_ar":"هٰذَا رَاهِنٌ لَكَ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"This is continual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"permanent, to thee; beloved by thee;"},{"kind":"text","text":"and also as explained below. (TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"Remaining, staying, dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abid ing, in a place."},{"kind":"text","text":"(JK.) ―         -b3-"},{"kind":"italic_en","text":"Prepared."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"h`*aA raAhinN laka","text_ar":"هٰذَا رَاهِنٌ لَكَ"},{"kind":"text","text":"meaning as explained above, and also"},{"kind":"italic_en","text":"This is prepared for thee."},{"kind":"text","text":"(TA.) ―         -b4-  As an epithet applied to a man, and a camel, (JK, S, TA,) and any beast, (TA,)"},{"kind":"italic_en","text":"Lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated;"},{"kind":"text","text":"(JK, S, K, TA;) accord. to ISh, in consequence of riding, or disease, or some [other] accident: (TA:) and"},{"kind":"italic_en","text":"fatigued, tired, weary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded."},{"kind":"text","text":"(JK, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"A_ibilN raAhinapN","text_ar":"اـِبِلٌ رَاهِنَةٌ"},{"kind":"italic_en","text":"Camels that will not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"do not, pasture upon the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tress, termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"HamoD","text_ar":"حَمْض"},{"kind":"text","text":". (JK.)"}],"source_refs":["S","Mgh","JK","TA"]}]},"classical_definitions":null}