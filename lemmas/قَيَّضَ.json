2%D9%8E%D9%8A%D9%8E%D9%91%D8%B6%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36475","headword_ar":"قَيْضٌ","root":"qyD","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"An egg-shell;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"upper hard covering that is upon an egg:"},{"kind":"text","text":"(K:) or ["},{"kind":"italic_en","text":"an egg-shell cracked in pieces;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what is cracked in pieces of the upper covering of an egg:"},{"kind":"text","text":"(S, * IB:) or"},{"kind":"italic_en","text":"one from which the young bird,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the fluid, has gone forth."},{"kind":"text","text":"(Lth, K.)       -A2-"},{"kind":"italic_en","text":"A compensation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"substitute; a thing given,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"received,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"done, instead of, in the place of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in exchange for, another thing."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"baAEahu farasF","text_ar":"بَاعَهُ فَرَسً"},{"kind":"arabic","text_bw":"bifarasayon qayoDayoni","text_ar":"بِفَرَسَيْن قَيْضَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He sold to him a horse for two horses as substitutes"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"humaA qayoDaAni","text_ar":"هُمَا قَيْضَانِ"},{"kind":"italic_en","text":"They two are likes; they two are like each other;"},{"kind":"text","text":"(A' Obeyd, A;)"},{"kind":"italic_en","text":"each of them is fit to be a substitute for the other."},{"kind":"text","text":"(A, TA.) [See also"},{"kind":"arabic","text_bw":"humaA","text_ar":"هُمَا"},{"kind":"arabic","text_bw":"qawoDaAni","text_ar":"قَوْضَانِ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"h`*aA qayoDN lahu","text_ar":"هٰذَا قَيْضٌ لَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"qiyaADN","text_ar":"قِيَاضٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"This is equal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"equivalent, to it."},{"kind":"text","text":"(O, K.)"}],"source_refs":["K"]},{"entry_id":"n36477","headword_ar":"قَيِّضٌ","root":"qyD","body":[{"kind":"italic_en","text":"A barterer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an exchanger of commodities:"},{"kind":"text","text":"(S, Msb:) of the measure"},{"kind":"arabic","text_bw":"fayoEilN","text_ar":"فَيْعِلٌ"},{"kind":"text","text":". (Msb.) You say,"},{"kind":"arabic","text_bw":"humaA qay~iDaAni","text_ar":"هُمَا قَيِّضَانِ"},{"kind":"italic_en","text":"They two are barterers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exchangers of commodities;"},{"kind":"text","text":"like as you say"},{"kind":"arabic","text_bw":"bay~iEaAni","text_ar":"بَيِّعَانِ"},{"kind":"text","text":". (S.)"}],"source_refs":["S","Msb"]}]},"classical_definitions":null}