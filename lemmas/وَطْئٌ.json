_ar": "نَشاز"}, {"kind": "text", "text": "] and"}, {"kind": "arabic", "text_bw": "A^a$oraAf", "text_ar": "اَشْرَاف"}, {"kind": "text", "text": "[in the CK"}, {"kind": "arabic", "text_bw": "A_i$orAf", "text_ar": "اـِشْراف"}, {"kind": "text", "text": "]): (K:)"}, {"kind": "arabic", "text_bw": "n$Az", "text_ar": "نشاز"}, {"kind": "text", "text": ", is pl. of"}, {"kind": "arabic", "text_bw": "na$azN", "text_ar": "نَشَزٌ"}, {"kind": "text", "text": ", and"}, {"kind": "arabic", "text_bw": "A$rAf", "text_ar": "اشراف"}, {"kind": "text", "text": "is pl. of"}, {"kind": "arabic", "text_bw": "$arafN", "text_ar": "شَرَفٌ"}, {"kind": "text", "text": "; and both signify “ eminences. ” (TA.)"}], "source_refs": ["K"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D9%88%D8%B7%D8%A6/", "headword_ar": "وطئ", "entries": [{"lexicon_id": "dictionary_9", "lexicon_en": "Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)", "lexicon_ar": "أساس البلاغة للزمخشري", "permalink": "https://arabiclexicon.hawramani.com/?p=17568#76e885", "body_html": "<span class=\"title1\">و ط ئ</span><br><br><span>وطئه برجله وطأً وطئةً، ورايت موطئ قدمه ومواطئ أقدامهم، وتوطؤوه بالأقدام حتى قتلوه. قال ذو الرمة:</span><br><br><span>وإنا لحيّ ما تزال جيادنا </span><span class=\"red\">...</span><span> توطّأ أكباد الكماة وتأسر</span><br><br><span>وأوطأته دابتي حتى وطئته. ووطّات الفراش توطئة، ووطؤ وطاءة، وفراش وطئ، وما له وطاءٌ ولا غطاء، وواطأه على الأمر مواطأة، وتواطأوا عليه، وكلّ أحد يخبر عن رسول الله صلى الله تعالى عليه وسلم من غير تواطؤ. وأوطأ في شعره إيطاء وهو اتفاق القافيتين من المواطأة.</span><br><br><span>ومن المجاز: وطئهم العدوّ وطأةً منكرة. وفي الحديث: \" اللهم اشدد وطأتك على مضر \" وثبّت الله وطأته. وفلان وطئ الخلق، وقد وطؤ وطاءة، وتقول: فيه وطاءة الخلق، ووضاءة الخلق. ويقال للمضياف: موطّأ الأكتاف إذا لم ينب جنابه عن النّزل. ودابة وطيئة: بيّنة الوطاءة. وهو في عيش وطيء، وأنا أحب وطاءة العيش.</span>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}