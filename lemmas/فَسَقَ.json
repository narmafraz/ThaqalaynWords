n":"m","num":"p"},{"role":"present_2mp","form":"تَفْسُقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْسُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْسُق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْسُق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْسُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْسُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْسُقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْسُقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْسُقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْسُقُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْسُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"فَسَقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَسَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَفْسُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفْسُق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"فَسَقَ","root":"فسق","pos":"V","occurrence_count":10},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n33865"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B3%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to deviate from the commandments of God","examples":[{"text":"فَسَجَدُوا إِلَّا إِبْلِيسَ كَانَ مِنَ الْجِنِّ فَفَسَقَ عَنْ أَمْرِ رَبِّهِ","english":"(please add an English translation of this quotation)"}]},{"pos":"verb","gloss":"to come out of the shell (of a ripe date)"},{"pos":"noun","gloss":"verbal noun of فَسَقَ (fasaqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of فَسُقَ (fasuqa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33865","headword_ar":"فَسَقَ","root":"fsq","body":[{"kind":"text","text":"is said to signify primarily"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"went forth,"},{"kind":"text","text":"from another thing,"},{"kind":"italic_en","text":"in a bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt, manner."},{"kind":"text","text":"(Msb.) One says,"},{"kind":"arabic","text_bw":"fasaqati Alr~uTabapu","text_ar":"فَسَقَتِ الرُّطَبَةُ"},{"kind":"text","text":", (S, O, Msb,) or"},{"kind":"arabic","text_bw":"fasaqati Alr~uTabapu Eano qi$orihaA","text_ar":"فَسَقَتِ الرُّطَبَةُ عَنْ قِشْرِهَا"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"The fresh ripe date came forth from its skin;"},{"kind":"text","text":"(S, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"Anfsqt","text_ar":"انفسقت","orth_type":"arrow"},{"kind":"text","text":": (IDrd, O, K:) and in like manner"},{"kind":"arabic","text_bw":"fasaqa","text_ar":"فَسَقَ"},{"kind":"text","text":"is said of anything as meaning"},{"kind":"italic_en","text":"it came forth from its integument:"},{"kind":"text","text":"so says EsSarakustee. (Msb.) ―         -b2-  [Hence]"},{"kind":"arabic","text_bw":"fasaqa","text_ar":"فَسَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, O, Msb, K) the latter aor. mentioned by Akh, (S, O, Msb,) inf. n."},{"kind":"arabic","text_bw":"fusuwqN","text_ar":"فُسُوقٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and"},{"kind":"arabic","text_bw":"fisoqN","text_ar":"فِسْقٌ"},{"kind":"text","text":", (S, O, K,) or this latter is a simple subst.; (Msb;) and likewise"},{"kind":"arabic","text_bw":"fasuqa","text_ar":"فَسُقَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"karuma","text_ar":"كَرُمَ"},{"kind":"text","text":", (K, TA,) mentioned by Lh, but not known by Ks; (TA;)"},{"kind":"italic_en","text":"He went forth from, departed from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted,"},{"kind":"text","text":"(Mgh, Msb, K,)"},{"kind":"italic_en","text":"the right way,"},{"kind":"text","text":"(Mgh, K,) or"},{"kind":"italic_en","text":"the way of truth,"},{"kind":"text","text":"(K,) and"},{"kind":"italic_en","text":"the limits of the law,"},{"kind":"text","text":"(Mgh,) [or"},{"kind":"italic_en","text":"the bounds of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"obedience;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he forsook, relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglected, the command of God; he disobeyed;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"fajara","text_ar":"فَجَرَ"},{"kind":"text","text":"[meaning"},{"kind":"page_break","n":2398},{"kind":"text","text":"as above; or"},{"kind":"italic_en","text":"he transgressed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acted unrighteously, sinfully, wickedly, vitiously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"immorally"},{"kind":"text","text":"]. (S, O, K. [See also"},{"kind":"arabic","text_bw":"fisoqN","text_ar":"فِسْقٌ"},{"kind":"text","text":"below.])"},{"kind":"arabic","text_bw":"fasaqa Eano A^amorirab~ihi","text_ar":"فَسَقَ عَنْ اَمْرِرَبِّهِ"},{"kind":"text","text":"(in the Kur [xviii. 48], O, TA) means"},{"kind":"italic_en","text":"He departed"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xaraja","text_ar":"خَرَجَ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from the command of his Lord:"},{"kind":"text","text":"(Th, S, O, K:) or"},{"kind":"italic_en","text":"from the obeying"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the command"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of his Lord:"},{"kind":"text","text":"(Fr, O, TA:) and Akh says that this phrase is like"},{"kind":"arabic","text_bw":"Ait~axama En AlT~aEAmi","text_ar":"اِتَّخَمَ عن الطَّعامِ"},{"kind":"text","text":", (S, O,) meaning"},{"kind":"arabic","text_bw":"Eano maA^okalihi","text_ar":"عَنْ مَاْكَلِهِ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Eano A^akolihi AlT~aEaAma","text_ar":"عَنْ اَكْلِهِ الطَّعَامَ"},{"kind":"text","text":"; but Th says that there is no need of this [explanation]: or, accord. to AO, it means"},{"kind":"italic_en","text":"he declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviated, from obeying the command of his Lord:"},{"kind":"text","text":"(O:) for"},{"kind":"arabic","text_bw":"fasaqa","text_ar":"فَسَقَ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"he declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deviated:"},{"kind":"text","text":"(K:) and hence the saying,"},{"kind":"arabic","text_bw":"fasaqati Alr~ikaAbu Eano qaSodi","text_ar":"فَسَقَتِ الرِّكَابُ عَنْ قَصْدِ"},{"kind":"arabic","text_bw":"Als~abiyli","text_ar":"السَّبِيلِ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"The ridden camels"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"declined"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from the right direction of the way"},{"kind":"text","text":"]. (TA.) Sometimes"},{"kind":"arabic","text_bw":"fusuwqN","text_ar":"فُسُوقٌ"},{"kind":"text","text":"may mean The"},{"kind":"italic_en","text":"believing in a plurality of gods:"},{"kind":"text","text":"and it may mean the"},{"kind":"italic_en","text":"committing sin."},{"kind":"text","text":"(A Heyth, O.) And it is said to mean The"},{"kind":"italic_en","text":"calling one another by names of reproach:"},{"kind":"text","text":"(Zj, * Mgh, TA:) or the"},{"kind":"italic_en","text":"saying"},{"kind":"text","text":"“"},{"kind":"italic_en","text":"O Jew,"},{"kind":"text","text":"” and “"},{"kind":"italic_en","text":"O Christian,"},{"kind":"text","text":"” after one has become a believer: thus in the Kur xlix. 11. (TA.) ―         -b3-  One says also,"},{"kind":"arabic","text_bw":"fasaqa fiY","text_ar":"فَسَقَ فِى"},{"kind":"arabic","text_bw":"Ald~unoyaA","text_ar":"الدُّنْيَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fisoqN","text_ar":"فِسْقٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He had a wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ample, range in respect of worldly things, and made them light and easy to himself, being without restraint in his management of them, not making them strait to him."},{"kind":"text","text":"(Ktr, Sh, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"fasaqa maAlahu","text_ar":"فَسَقَ مَالَهُ"},{"kind":"italic_en","text":"He made away with his property;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"disposed of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spent it."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","O","Msb","K","IDrd","Mgh","TA","Th","Fr"]}]},"classical_definitions":null}