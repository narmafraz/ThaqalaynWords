{"lemma":"تَصَوُّرٌ","slug":"تَصَوُّرٌ","root":"ص.#.ر","root_slug":"ص-_-ر","root_link":"/words/roots/ص-_-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n25170"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B5%D9%8E%D9%88%D9%8F%D9%91%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become formed, fashioned, figured, shaped, sculptured, pictured, portrayed, photographed"},{"pos":"verb","gloss":"to imagine, to conceive (something)","tags":["transitive"]},{"pos":"verb","gloss":"to think (something, someone) to be (something, someone)","tags":["ditransitive"]},{"pos":"verb","gloss":"to appear in one's mind as an image"},{"pos":"verb","gloss":"to seem (لِ (li) someone)"},{"pos":"verb","gloss":"to fall (as a result of being struck)"},{"pos":"verb","gloss":"to photograph oneself"},{"pos":"noun","gloss":"verbal noun of تَصَوَّرَ (taṣawwara) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"imagination"},{"pos":"noun","gloss":"idea, concept"},{"pos":"noun","gloss":"conception"}]},"etymology":{"source":"wiktextract","text":"Mediopassive of صَوَّرَ (ṣawwara, “to form, depict, to photograph”), from the root ص و ر (ṣ w r)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25170","headword_ar":"تصوّر","root":"Swr","body":[{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, formed, fashioned, figured, shaped, sculptured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pictured."},{"kind":"text","text":"(S, M, K, TA.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"tSw~r liY","text_ar":"تصوّر لِى"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"liY","text_ar":"لِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Suw~ira","text_ar":"صُوِّرَ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"taxay~ala liY","text_ar":"تَخَيَّلَ لِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuy~ila liY","text_ar":"خُيِّلَ لِى"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It appeared to my mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imagination,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"as an image,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a picture."},{"kind":"text","text":"(Msb.)       -A2-  See also 2. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"tSw~r $ayoy^FA","text_ar":"تصوّر شَيْيًا"},{"kind":"italic_en","text":"He imagined a thing; imaged it in the mind;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Sw~rhu","text_ar":"صوّرهُ","orth_type":"arrow"},{"kind":"text","text":"; [like"},{"kind":"arabic","text_bw":"taxay~alahu","text_ar":"تَخَيَّلَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xay~alahu","text_ar":"خَيَّلَهُ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"he imagined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conceived, the form of the thing."},{"kind":"text","text":"(S.) ["},{"kind":"arabic","text_bw":"taSaw~urN","text_ar":"تَصَوُّرٌ"},{"kind":"text","text":"in logic signifies The"},{"kind":"italic_en","text":"forming of an idea; conception, perception,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apprehension;"},{"kind":"text","text":"sometimes qualified by the epithet"},{"kind":"arabic","text_bw":"saA*ajN","text_ar":"سَاذَجٌ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"simple."},{"kind":"text","text":"]       -A3-  Also"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(being pierced with a spear or the like)"},{"kind":"italic_en","text":"inclined, to fall:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(being struck)"},{"kind":"italic_en","text":"fell:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, fell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alighted."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","M","K"]}]},"classical_definitions":null}