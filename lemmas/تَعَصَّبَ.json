:["n29267"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D8%B5%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be a fanatic"},{"pos":"verb","gloss":"to form an alliance"},{"pos":"noun","gloss":"verbal noun of تَعَصُّب (taʕaṣṣub) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"intolerance"},{"pos":"noun","gloss":"fanaticism"}]},"etymology":null,"ipa":["/ta.ʕasˤ.sˤa.ba/","/ta.ʕasˤ.sˤub/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29267","headword_ar":"تعصّب","root":"ESb","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$ad~a AlEiSaAbapa","text_ar":"شَدَّ العِصَابَةَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He bound the turban,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fillet, round his"},{"kind":"text","text":"(own)"},{"kind":"italic_en","text":"head;"},{"kind":"text","text":"a meaning well known, whence that explained in the next sentence: (see also 8:) and"},{"kind":"italic_en","text":"he bound a bandage of some kind round his"},{"kind":"text","text":"(own)"},{"kind":"italic_en","text":"body,"},{"kind":"text","text":"by reason of hunger: see"},{"kind":"arabic","text_bw":"muEaS~abN","text_ar":"مُعَصَّبٌ"},{"kind":"text","text":"]. (S, O, Msb, * K.) ―         -b2-  And (assumed tropical:)"},{"kind":"italic_en","text":"He was made a chief;"},{"kind":"text","text":"quasi-pass. of 2 [q. v.]. (L, TA.) ―         -b3-  And it has also another signification, from"},{"kind":"arabic","text_bw":"AlEaSabiy~ap","text_ar":"العَصَبِيَّة"},{"kind":"text","text":"; (S, O;) [i. e.] it signifies also"},{"kind":"arabic","text_bw":"A^ataY biAlEaSabiy~api","text_ar":"اَتَى بِالعَصَبِيَّةِ"},{"kind":"text","text":"; (K, TA;) which means ["},{"kind":"italic_en","text":"He aided his people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, against hostile conduct:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was angry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"zealous, for the sake of his party, and defended them:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EaSabiY~N","text_ar":"عَصَبِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaSabiy~apN","text_ar":"عَصَبِيَّةٌ"},{"kind":"text","text":":) or]"},{"kind":"italic_en","text":"he invited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"summoned, others to the aid of his party, and to combine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"league, with them against those who acted towards them with hostility, whether they were wrongdoers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wronged."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"taEaS~abuwA Ealayohimo","text_ar":"تَعَصَّبُوا عَلَيْهِمْ"},{"kind":"italic_en","text":"They leagued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collected themselves, together against them:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taEaS~abonaA lahu","text_ar":"تَعَصَّبْنَا لَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maEahu","text_ar":"مَعَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"We"},{"kind":"text","text":"["},{"kind":"italic_en","text":"leagued together for him, and with him, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"defended him."},{"kind":"text","text":"(TA.) [See also De Sacy's Chrest. Ar., see. ed., i. 445-6; where it is shown that"},{"kind":"arabic","text_bw":"Alt~aEaS~ubu","text_ar":"التَّعَصُّبُ"},{"kind":"text","text":"in religion means"},{"kind":"italic_en","text":"The being zealous,"},{"kind":"text","text":"or a"},{"kind":"italic_en","text":"zealot:"},{"kind":"text","text":"and see Har pp. 423 and 573.] ―         -b4-  And"},{"kind":"arabic","text_bw":"tES~b biAl$~aYo'i","text_ar":"تعصّب بِالشَّىْءِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, content with the thing;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AEtSb","text_ar":"اعتصب","orth_type":"arrow"},{"kind":"text","text":"."},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":". (K.)"}],"source_refs":[]}]}}