url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D9%84%D9%90%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to slip, skid, to slide"},{"pos":"verb","gloss":"to slip, skid, to slide"},{"pos":"verb","gloss":"to make slippery"},{"pos":"verb","gloss":"to make slide"},{"pos":"noun","gloss":"verbal noun of زَلِقَ (zaliqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"slippery place"},{"pos":"noun","gloss":"verbal noun of زَلَقَ (zalaqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"slippery"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18022","headword_ar":"زَلِقَ","root":"zlq","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zalaqN","text_ar":"زَلَقٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"zalaqa","text_ar":"زَلَقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaloqN","text_ar":"زَلْقٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He slipped;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"zal~a","text_ar":"زَلَّ"},{"kind":"text","text":"; (K, TA;) for which"},{"kind":"arabic","text_bw":"*al~a","text_ar":"ذَلَّ"},{"kind":"text","text":"is erroneously put in [some of] the copies of the K. (TA. [See also 5.]) And"},{"kind":"arabic","text_bw":"zaliqato rijoluhu","text_ar":"زَلِقَتْ رِجْلُهُ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Alqadamu","text_ar":"القَدَمُ"},{"kind":"text","text":", (Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zalaqN","text_ar":"زَلَقٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"His foot,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"the foot,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"slipped,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"did not remain firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed, in its place."},{"kind":"text","text":"(Msb.) The former is also said of an arrow, [app. as meaning"},{"kind":"italic_en","text":"It slid along the ground,"},{"kind":"text","text":"] like"},{"kind":"arabic","text_bw":"zahiqa","text_ar":"زَهِقَ"},{"kind":"text","text":"[q. v.]. (JK in art."},{"kind":"arabic","text_bw":"zhq","text_ar":"زهق"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"zaliqa bimakaAnihi","text_ar":"زَلِقَ بِمَكَانِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zalaqa","text_ar":"زَلَقَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, disgusted by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with, his place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he loathed it, and removed, withdrew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retired to a distance, from it."},{"kind":"text","text":"(K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"zalaqato","text_ar":"زَلَقَتْ"},{"kind":"text","text":", said of a she-camel,"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift."},{"kind":"text","text":"(O, TA.)       -A2-"},{"kind":"arabic","text_bw":"zalaqahu","text_ar":"زَلَقَهُ"},{"kind":"text","text":": see 4. ―         -b2-"},{"kind":"arabic","text_bw":"zalaqahu Eano makaAnihi","text_ar":"زَلَقَهُ عَنْ مَكَانِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaloqN","text_ar":"زَلْقٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He removed him from his place."},{"kind":"text","text":"(K, TA.) Hence the reading of Aboo-Jaafar and Náfi', [in the Kur lxviii. 51,]"},{"kind":"arabic","text_bw":"waA_ino","text_ar":"وَاـِنْ"},{"kind":"arabic","text_bw":"yakaAdu A@l~a*iyna kafaruwA layazoliquwnaka biA^aboSaArihimo","text_ar":"يَكَادُ ا@لَّذِينَ كَفَرُوا لَيَزْلِقُونَكَ بِاَبْصَارِهِمْ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"And verily they who have disbelieved almost"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"smite thee with their"},{"kind":"text","text":"evil"},{"kind":"italic_en","text":"eyes so as to remove thee from thy station in which God has placed thee, by reason of enmity to thee."},{"kind":"text","text":"(TA. [Or this reading may be rendered agreeably with the common reading: see 4.]) ―         -b3-"},{"kind":"arabic","text_bw":"zalaqa raA^osahu","text_ar":"زَلَقَ رَاْسَهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zaloqN","text_ar":"زَلْقٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He shaved his head;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Azlqhu","text_ar":"ازلقهُ","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"zl~qhu","text_ar":"زلّقهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"tazoliyqN","text_ar":"تَزْلِيقٌ"},{"kind":"text","text":": (S:) IB says that, accord. to 'Alee Ibn-Hamzeh, it is only"},{"kind":"arabic","text_bw":"zabaqahu","text_ar":"زَبَقَهُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"; and that"},{"kind":"arabic","text_bw":"Alz~aboqu","text_ar":"الزَّبْقُ"},{"kind":"text","text":"means the plucking out; not the shaving: but accord. to Fr, one says of him who has shaved his head"},{"kind":"arabic","text_bw":"qd","text_ar":"قد"},{"kind":"arabic","text_bw":"zlqh","text_ar":"زلقه"},{"kind":"text","text":", [whether with or without teshdeed is not shown,] and"},{"kind":"arabic","text_bw":"Azlqh","text_ar":"ازلقه"},{"kind":"text","text":". (TA.)"}],"source_refs":["K","S","Msb","TA"]}]}}