{"lemma":"أَنَبَة","slug":"أَنَبَة","root":"#.ن.ب","root_slug":"_-ن-ب","root_link":"/words/roots/_-ن-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n1309"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%8E%D8%A8%D9%8E%D8%A9"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1309","headword_ar":"انّبهُ","root":"Anb","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taA^oniybN","text_ar":"تَاْنِيبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He blamed, reproved, reprehended, chid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reproached, him:"},{"kind":"text","text":"(S, M, A, K:) or"},{"kind":"italic_en","text":"he did so severely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"angrily:"},{"kind":"text","text":"(ISk, T, S, M, A, K:) or,"},{"kind":"italic_en","text":"with the utmost severity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"harshness:"},{"kind":"text","text":"(T, M, TA:) or"},{"kind":"italic_en","text":"he repulsed him,"},{"kind":"text","text":"meaning a person who asked something of him,"},{"kind":"italic_en","text":"in the most abominable manner."},{"kind":"text","text":"(M, * K, * TA.)"}],"source_refs":["S","M","A","K","ISk","T","TA"]}]}}