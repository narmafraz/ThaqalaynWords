finition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5095","headword_ar":"جَحَدَ","root":"jHd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"juHuwdN","text_ar":"جُحُودٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He denied"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"disacknowledged it;"},{"kind":"text","text":"(L, MF;) in an absolute sense, whether knowing it to be otherwise than as he represented it to be or not. (MF.) [It is used by grammarians, and often by others, as relating to something past, or supposed or asserted to be past; and thus, in a more restricted sense than"},{"kind":"arabic","text_bw":"nafaY","text_ar":"نَفَى"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"jaHadahu Haq~ahu","text_ar":"جَحَدَهُ حَقَّهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biHaq~ihi","text_ar":"بِحَقِّهِ"},{"kind":"text","text":", inf. ns. as above; [and ↓"},{"kind":"arabic","text_bw":"jAHdhu","text_ar":"جاحدهُ","orth_type":"arrow"},{"kind":"text","text":"; (see 3 in art."},{"kind":"arabic","text_bw":"kbr","text_ar":"كبر"},{"kind":"text","text":", where"},{"kind":"arabic","text_bw":"jAHadahu","text_ar":"جاحَدَهُ"},{"kind":"text","text":"is used in explaining"},{"kind":"arabic","text_bw":"kaAbarahu","text_ar":"كَابَرَهُ"},{"kind":"text","text":"; and see what follows;)]"},{"kind":"italic_en","text":"He denied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disacknowledged, his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, knowing it to be such,"},{"kind":"text","text":"(S, A, * Msb, K, MF,) and also,"},{"kind":"italic_en","text":"not knowing it;"},{"kind":"text","text":"(MF;) the doing of which is also termed"},{"kind":"arabic","text_bw":"mukaAbarapN","text_ar":"مُكَابَرَةٌ"},{"kind":"text","text":": (TA:) but accord. to some, it is made trans. by means of"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"only by its being made to imply the meaning of"},{"kind":"arabic","text_bw":"kafara","text_ar":"كَفَرَ"},{"kind":"text","text":". (MF.)       -A2-  Also"},{"kind":"arabic","text_bw":"jaHadahu","text_ar":"جَحَدَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He found him to be niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he found him to possess little good;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"to be either niggardly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"poor."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"jaHida","text_ar":"جَحِدَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jaHodN","text_ar":"جَحْدٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"possessed little good;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"AjHd","text_ar":"اجحد","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"his property became dissipated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed, and passed away;"},{"kind":"text","text":"and so ↓ the latter verb. (AA, TA.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, little in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scanty."},{"kind":"text","text":"(K, TA.) ―         -b3-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a person's life, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strait, and difficult."},{"kind":"text","text":"(K, * TA.) ―         -b4-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a plant)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, scanty;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"did not grow tall."},{"kind":"text","text":"(S, K.) ―         -b5-"},{"kind":"arabic","text_bw":"jaHidati AlA^aroDu","text_ar":"جَحِدَتِ الاَرْضُ"},{"kind":"italic_en","text":"The land became dry, and of no good."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"jaHada EaAmunaA","text_ar":"جَحَدَ عَامُنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Our year was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, one of little rain:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"jaHidN","text_ar":"جَحِدٌ"},{"kind":"text","text":"]. (A.)"}],"source_refs":["TA","K","S"]}]}}