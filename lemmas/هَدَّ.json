":"present_3fs","form":"تَهْدِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَهْدُد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَهِدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَهِدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَهُدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَهُدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَهِدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهِدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهُدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَهُدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَهِدُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهِدُّونَ","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهُدُّونَ","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَهُدُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَهْدِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَهْدُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَهِدّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهِدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَهُدّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَهُدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"هَدَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"هَدَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":51,"cross_references":{"qac":{"found":true,"lemma_key":"هَدّ","root":"هدد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n40961"],"search_url":"https://lanelexicon.com/?s=%D9%87%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to break, to crush, to break down, to destroy","tags":["transitive"]}]},"etymology":null,"ipa":["/had.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40961","headword_ar":"هَدَّ","root":"hd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, Msb,) inf. n."},{"kind":"arabic","text_bw":"had~N","text_ar":"هَدٌّ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"huduwdN","text_ar":"هُدُودٌ"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"He demolished"},{"kind":"text","text":"a a building; (As, S, A, L, K: *)"},{"kind":"italic_en","text":"threw it down;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"pulled"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"down to the ground:"},{"kind":"text","text":"(As, S, A, L:)"},{"kind":"italic_en","text":"demolished"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with violence:"},{"kind":"text","text":"(L, K: *)"},{"kind":"italic_en","text":"demolished"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"at once, with a vehement noise."},{"kind":"text","text":"(Msb.)       -A2-  [Hence you say,]"},{"kind":"arabic","text_bw":"maA ha*uhu ka*aA","text_ar":"مَا هَذُهُ كَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a thing did not break him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, L.) ―         -b2-"},{"kind":"arabic","text_bw":"had~aniY AlA^amoru","text_ar":"هَدَّنِى الاَمْرُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"had~a rukonY","text_ar":"هَدَّ رُكْنى"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The thing distressed, and broke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crashed, me."},{"kind":"text","text":"And [in like manner]"},{"kind":"arabic","text_bw":"maA had~aniY mawotu A^aHadK","text_ar":"مَا هَدَّنِى مَوْتُ اَحَدٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The death of any one has not distressed, nor broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crushed, me"},{"kind":"text","text":"]. (L.) And"},{"kind":"arabic","text_bw":"had~atohu AlmuSiybapu","text_ar":"هَدَّتْهُ المُصِيبَةُ"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"calamity debilitated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enervated, him."},{"kind":"text","text":"(S, A, L.) ―         -b3-"},{"kind":"arabic","text_bw":"had~a","text_ar":"هَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"had~N","text_ar":"هَدٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weak,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"in body;"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"became extremely aged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decrepit."},{"kind":"text","text":"(TK.) ―         -b4-  See 7. ―         -b5-"},{"kind":"arabic","text_bw":"had~a","text_ar":"هَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"hadiydN","text_ar":"هَدِيدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wall or the like, S, L, or a part of a mountain, L, by its falling, S, L)"},{"kind":"italic_en","text":"made a noise;"},{"kind":"text","text":"(S;) or,"},{"kind":"italic_en","text":"a violent noise."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"had~ato","text_ar":"هَدَّتْ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the sky)"},{"kind":"italic_en","text":"sent forth a noise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, occasioned by the falling of rain."},{"kind":"text","text":"(L.) ―         -b7-"},{"kind":"arabic","text_bw":"had~a","text_ar":"هَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"hadiydN","text_ar":"هَدِيدٌ"},{"kind":"text","text":", (S, L,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the sound called"},{"kind":"arabic","text_bw":"haAd~","text_ar":"هَادّ"},{"kind":"text","text":", from the sea,)"},{"kind":"italic_en","text":"made a murmuring."},{"kind":"text","text":"(S, * L.) ―         -b8-"},{"kind":"arabic","text_bw":"had~a","text_ar":"هَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"had~N","text_ar":"هَدٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"brayed."},{"kind":"text","text":"(TK.) See also R. Q. 1.       -A3-"},{"kind":"arabic","text_bw":"mararotu birajulK had~aka mino rajulK","text_ar":"مَرَرْتُ بِرَجُلٍ هَدَّكَ مِنْ رَجُلٍ"},{"kind":"italic_en","text":"I passed by a man who is sufficient for they as a man;"},{"kind":"text","text":"(L, K:) as also"},{"kind":"arabic","text_bw":"had~ika","text_ar":"هَدِّكَ"},{"kind":"text","text":": (K.) an expression of praise (L:) or it means,"},{"kind":"italic_en","text":"the description of whose good qualities would be burdensome to thee:"},{"kind":"text","text":"there are two dial. forms used in this case: some use"},{"kind":"arabic","text_bw":"hd~","text_ar":"هدّ"},{"kind":"text","text":"as an inf. n., [in the sense of an epithet, (marginal note in a copy of the S,) saying, in such a phrase as the above,"},{"kind":"arabic","text_bw":"had~ika","text_ar":"هَدِّكَ"},{"kind":"text","text":",] in which case, it has no fem. nor dual. nor pl. form; (S, L:) the sing and dual and pl. are the same: (K:) and some make it a verb, and give it [a fem. and] a dual and a pl, and say,"},{"kind":"arabic","text_bw":"mrrt brjl","text_ar":"مررت برجل"},{"kind":"arabic","text_bw":"had~aka mn rjl","text_ar":"هَدَّكَ من رجل"},{"kind":"text","text":", as above, (S, L,) and"},{"kind":"arabic","text_bw":"bA@moraA^apK","text_ar":"با@مْرَاَةٍ"},{"kind":"arabic","text_bw":"had~anoka mni A@moraA^apK","text_ar":"هَدَّنْكَ منِ ا@مْرَاَةٍ"},{"kind":"text","text":", (S, L, K,) like as you say"},{"kind":"arabic","text_bw":"kaf~Aka","text_ar":"كَفّاكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kafayoka","text_ar":"كَفَيْكَ"},{"kind":"text","text":", (L.,) and"},{"kind":"arabic","text_bw":"birajulayoni had~aAka","text_ar":"بِرَجُلَيْنِ هَدَّاكَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"birijaAlK had~uwka","text_ar":"بِرِجَالٍ هَدُّوكَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biA@moraA^atayoni had~ataAka","text_ar":"بِا@مْرَاَتَيْنِ هَدَّتَاكَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"binisowapi","text_ar":"بِنِسْوَةِ"},{"kind":"arabic","text_bw":"hadadotaka","text_ar":"هَدَدْتَكَ"},{"kind":"text","text":". (S, L, K.) ―         -b2-  IAar also cites the following ex. [by El-Kattál El-Kilábee, (marginal note in a copy of the S)]"},{"kind":"quote","text":"waliY SaAHibN fiY AlgaAri had~aka SaAHibFA"},{"kind":"text","text":"as meaning. ["},{"kind":"italic_en","text":"And I have a companion in the race;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of how great estimation, and how ingenious, and how knowing, is he"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as a companion"},{"kind":"text","text":"] describing a wolf: (L:) in which he who reads"},{"kind":"arabic","text_bw":"had~aka","text_ar":"هَدَّكَ"},{"kind":"text","text":"makes"},{"kind":"arabic","text_bw":"had~a","text_ar":"هَدَّ"},{"kind":"text","text":"a verb; and as such it has a dual and pl. and fem. but some read"},{"kind":"arabic","text_bw":"had~uka","text_ar":"هَدُّكَ"},{"kind":"text","text":". making it an inf. n. used as an epithet; and as such it has no dual nor pl. nor fem. (Marginal note in a copy of the S.) ―         -b3-"},{"kind":"arabic","text_bw":"had~a Alr~ajulu","text_ar":"هَدَّ الرَّجُلُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Excellent is the man;"},{"kind":"text","text":"(ISd, L:) and"},{"kind":"arabic","text_bw":"A_in~hu lahad~a Alr~ajulu","text_ar":"اـِنّهُ لَهَدَّ الرَّجُلُ"},{"kind":"italic_en","text":"Verily, excellent is the man"},{"kind":"text","text":"(L, K)"},{"kind":"italic_en","text":"in hardiness and strength:"},{"kind":"text","text":"(L:) and"},{"kind":"arabic","text_bw":"lahad~a","text_ar":"لَهَدَّ"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"italic_en","text":"How hardy is the man!"},{"kind":"text","text":"(L.) ―         -b4-  In a trad., Aboo Lahab is related to have said,"},{"kind":"arabic","text_bw":"lahad~a maA saxarakumo SaAHibukumo","text_ar":"لَهَدَّ مَا سَخَرَكُمْ صَاحِبُكُمْ"},{"kind":"text","text":", [meaning"},{"kind":"italic_en","text":"How greatly hath your companion enchanted you!"},{"kind":"text","text":"):"},{"kind":"arabic","text_bw":"lahad~a","text_ar":"لَهَدَّ"},{"kind":"text","text":"is an expression of wonder. (L.) ―         -b5-"},{"kind":"arabic","text_bw":"fulaAnN yuhad~u","text_ar":"فُلَانٌ يُهَدُّ"},{"kind":"italic_en","text":"Such a one is praiseworthy for hardiness"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"and strength."},{"kind":"text","text":"(S, L.)"}],"source_refs":["S","L","Msb","K","As","A","ISd"]}]}}