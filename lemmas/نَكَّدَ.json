,"entry_ids":["n40495","n40501","n40502","n40504"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%83%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"irritable, bad-tempered, ill-humored, crabby, grumpy, morose, sulky, surly"},{"pos":"verb","gloss":"to be harsh, unhappy"},{"pos":"verb","gloss":"to give little"},{"pos":"verb","gloss":"to torment"},{"pos":"verb","gloss":"to make life difficult"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40495","headword_ar":"نَكِدَ","root":"nkd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K, &c.,) inf. n."},{"kind":"arabic","text_bw":"nakadN","text_ar":"نَكَدٌ"},{"kind":"text","text":", (S, L, Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a man's life)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait, and difficult."},{"kind":"text","text":"(S, L, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"nakida","text_ar":"نَكِدَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a she-camel's milk)"},{"kind":"italic_en","text":"became deficient."},{"kind":"text","text":"(R.) ―         -b3-"},{"kind":"arabic","text_bw":"nakida","text_ar":"نَكِدَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became exhausted."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"nakidati","text_ar":"نَكِدَتِ"},{"kind":"arabic","text_bw":"Alr~akiy~apu","text_ar":"الرَّكِيَّةُ"},{"kind":"italic_en","text":"The well came to have little water."},{"kind":"text","text":"(S, L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"nakida","text_ar":"نَكِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nakadN","text_ar":"نَكَدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unpropitious, and mean:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he became hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"he gave little:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave not at all:"},{"kind":"text","text":"you say also"},{"kind":"arabic","text_bw":"nakida biHaAjatinaA","text_ar":"نَكِدَ بِحَاجَتِنَا"},{"kind":"italic_en","text":"he was niggardly of that which we wanted."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"nakada HaAjatahu","text_ar":"نَكَدَ حَاجَتَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) or"},{"kind":"arabic","text_bw":"nakadahu HaAjatahu","text_ar":"نَكَدَهُ حَاجَتَهُ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He withheld from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused him, his want."},{"kind":"text","text":"(L, K.) ―         -b7-"},{"kind":"arabic","text_bw":"nakadahu","text_ar":"نَكَدَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He withheld from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused him, what he asked:"},{"kind":"text","text":"or [in the CK, and] the same, (K,) or"},{"kind":"arabic","text_bw":"nakadahu maA saA^alahu","text_ar":"نَكَدَهُ مَا سَاَلَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nakodN","text_ar":"نَكْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"he gave him not save the least of what he asked."},{"kind":"text","text":"(L, K.) ―         -b8-"},{"kind":"arabic","text_bw":"nukida","text_ar":"نُكِدَ"},{"kind":"text","text":", [in measure] like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He had many askers and gave little."},{"kind":"text","text":"(K.) ―         -b9-"},{"kind":"arabic","text_bw":"nakada","text_ar":"نَكَدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a raven or crow)"},{"kind":"italic_en","text":"croaked with his utmost force;"},{"kind":"text","text":"(A, K;)"},{"kind":"italic_en","text":"as though vomiting;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tnk~d","text_ar":"تنكّد","orth_type":"arrow"},{"kind":"text","text":". (A.)"}],"source_refs":["S","L","Msb","K"]},{"entry_id":"n40501","headword_ar":"نَكْدٌ","root":"nkd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"nukodN","text_ar":"نُكْدٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"nakidN","text_ar":"نَكِدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n40502","headword_ar":"نُكْدٌ","root":"nkd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nakodN","text_ar":"نَكْدٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Scantiness of a gift;"},{"kind":"text","text":"(L, K;)"},{"kind":"italic_en","text":"and its not being enjoyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"found pleasant, by the receiver."},{"kind":"text","text":"(L.) ―         -b2-  See what follows."}],"source_refs":[]},{"entry_id":"n40504","headword_ar":"نَكِدٌ","root":"nkd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult;"},{"kind":"text","text":"applied to a man's life; (see 1;) and to fortune, as in an ex. voce"},{"kind":"arabic","text_bw":"A_ibidN","text_ar":"اـِبِدٌ"},{"kind":"text","text":".] ―         -b2-  Water"},{"kind":"italic_en","text":"little in quantity."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"laA yaxoruju A_il~aA nakidFA","text_ar":"لَا يَخْرُجُ اـِلَّا نَكِدًا"},{"kind":"text","text":", in the Kur, [vii. 56,] accord. to the common reading, or ↓"},{"kind":"arabic","text_bw":"nakadFA","text_ar":"نَكَدًا","orth_type":"arrow"},{"kind":"text","text":", accord. to the reading of the people of El-Medeeneh, or, as it may be read, accord. to Zj, ↓"},{"kind":"arabic","text_bw":"nakodFA","text_ar":"نَكْدًا","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nukodFA","text_ar":"نُكْدًا","orth_type":"arrow"},{"kind":"text","text":", means, accord. to Fr,"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[the herbage]"},{"kind":"italic_en","text":"will not come forth save with difficulty:"},{"kind":"text","text":"(L:) or,"},{"kind":"italic_en","text":"scantily and unprofitably."},{"kind":"text","text":"(Beyd.) ―         -b4-"},{"kind":"arabic","text_bw":"nakidN","text_ar":"نَكِدٌ"},{"kind":"text","text":"(S, A, L, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"nakadN","text_ar":"نَكَدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"nakodN","text_ar":"نَكْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^anokadu","text_ar":"اَنْكَدُ","orth_type":"arrow"},{"kind":"text","text":"(L, K) A man who is"},{"kind":"italic_en","text":"unpropitious,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"and mean,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"and hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult:"},{"kind":"text","text":"(S, A, L, Msb, K:) and a people you term"},{"kind":"arabic","text_bw":"A^anokaAdN","text_ar":"اَنْكَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"manaAkiydu","text_ar":"مَنَاكِيدُ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"nukudN","text_ar":"نُكُدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nukodN","text_ar":"نُكْدٌ"},{"kind":"text","text":". (A.) ―         -b5-"},{"kind":"arabic","text_bw":"nakidN","text_ar":"نَكِدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^anokadu","text_ar":"اَنْكَدُ","orth_type":"arrow"},{"kind":"text","text":"A man"},{"kind":"italic_en","text":"that brings evil upon others."},{"kind":"text","text":"(L.)"}],"source_refs":["L","S","A","Msb","K"]}]}}