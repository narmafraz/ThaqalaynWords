{"lemma":"مُجَهَّز","slug":"مُجَهَّز","root":"ج.ه.ز","root_slug":"ج-ه-ز","root_link":"/words/roots/ج-ه-ز","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n6561","n6562"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AC%D9%8E%D9%87%D9%8E%D9%91%D8%B2"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"passive participle of جَهَّزَ (jahhaza)","tags":["form-of","participle","passive"]},{"pos":"adj","gloss":"equipped"},{"pos":"adj","gloss":"armed with"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of the verb جَهَّزَ (jahhaza, “to prepare”)."},"ipa":["/mu.d͡ʒah.haz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6561","headword_ar":"مُجَهَّزٌ","root":"jhz","body":[{"kind":"italic_en","text":"One for whom are prepared travellingprovisions and equipage, that he may perform the pilgrimage for another."},{"kind":"text","text":"(Mgh.)"}],"source_refs":[]},{"entry_id":"n6562","headword_ar":"مُجَهِّزٌ","root":"jhz","body":[{"kind":"italic_en","text":"One who sends forth traders with excellent goods:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who travels with such goods."},{"kind":"text","text":"(Mgh.) Hence, app., the vulgar term ↓"},{"kind":"arabic","text_bw":"mujaAhizN","text_ar":"مُجَاهِزٌ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"A rich merchant."},{"kind":"text","text":"(Mgh.) ―         -b2-  And"},{"kind":"arabic","text_bw":"mujah~izuwna","text_ar":"مُجَهِّزُونَ"},{"kind":"italic_en","text":"Travelling-companions who assist one in the loading of the beasts."},{"kind":"text","text":"(Msb.)"}],"source_refs":[]}]}}