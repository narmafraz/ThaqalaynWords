{"lemma":"سُمْعَةٍ","slug":"سُمْعَةٍ","root":"س.م.ع","root_slug":"س-م-ع","root_link":"/words/roots/س-م-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n20710","n20717","n20718","n20719","n20720"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8F%D9%85%D9%92%D8%B9%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"reputation, honor, fame"}]},"etymology":{"source":"wiktextract","text":"From the root س م ع (s m ʕ), related to hearing."},"ipa":["/sum.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20710","headword_ar":"سَمِعَهُ","root":"smE","body":[{"kind":"text","text":", (S, Msb, K, *) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":"(S Msb, K) and"},{"kind":"arabic","text_bw":"simoEN","text_ar":"سِمْعٌ"},{"kind":"text","text":", or this latter is a simple subst., (Lh, K,) and"},{"kind":"arabic","text_bw":"samaAEN","text_ar":"سَمَاعٌ"},{"kind":"text","text":", (S, K,) or this last [also] is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"samaAEapN","text_ar":"سَمَاعَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samaAEiyapN","text_ar":"سَمَاعِيَةٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"masomaEN","text_ar":"مَسْمَعٌ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"He heard it,"},{"kind":"text","text":"(namely, a thing, as in the S,) or (tropical:)"},{"kind":"italic_en","text":"him;"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"tsm~E","text_ar":"تسمّع","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) also written and pronounced"},{"kind":"arabic","text_bw":"Ais~am~aEa","text_ar":"اِسَّمَّعَ"},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"AstmE","text_ar":"استمع","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) are syn. with"},{"kind":"arabic","text_bw":"samiEa","text_ar":"سَمِعَ"},{"kind":"text","text":"(Msb,K) as trans. By itself; (Msb;) and"},{"kind":"arabic","text_bw":"AstmE","text_ar":"استمع"},{"kind":"text","text":"[also] in sys. With"},{"kind":"arabic","text_bw":"samiEa","text_ar":"سَمِعَ"},{"kind":"text","text":"[ as trans. by itself]: (Ham p. 694, where occurs a usage of its act. part. n. showing the verb to be trans. by itself:) or ↓"},{"kind":"arabic","text_bw":"AstmE","text_ar":"استمع","orth_type":"arrow"},{"kind":"text","text":"denotes what is intentional, signifying only"},{"kind":"italic_en","text":"he gave ear, hearkened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listened:"},{"kind":"text","text":"but"},{"kind":"arabic","text_bw":"samiEa","text_ar":"سَمِعَ"},{"kind":"text","text":", [as also ↓"},{"kind":"arabic","text_bw":"tmsm~E","text_ar":"تمسمّع","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AstsmE","text_ar":"استسمع","orth_type":"arrow"},{"kind":"text","text":",] what is unintentional, as well as what is intentional. (Msb.) You say,"},{"kind":"arabic","text_bw":"samiEa Al$~aYo'a","text_ar":"سَمِعَ الشَّىْءَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He heard"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listened to, the thing"},{"kind":"text","text":"] (S.) And"},{"kind":"arabic","text_bw":"AlS~awota","text_ar":"الصَّوْتَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tsm~E","text_ar":"تسمّع","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He listened to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heard, the sound"},{"kind":"text","text":"]. (TA.) [And"},{"kind":"arabic","text_bw":"samiEotu lahu SawotFA","text_ar":"سَمِعْتُ لَهُ صَوْتًا"},{"kind":"italic_en","text":"I heard him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, utter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produce, a sound;"},{"kind":"text","text":"lit."},{"kind":"italic_en","text":"I heard a sound attributable to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"samiEahu minohu","text_ar":"سَمِعَهُ مِنْهُ"},{"kind":"italic_en","text":"He heard it form him."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"samiEahu Eanohu","text_ar":"سَمِعَهُ عَنْهُ"},{"kind":"italic_en","text":"He heard it as related from him; he heard it on his authority."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"samiEahu","text_ar":"سَمِعَهُ"},{"kind":"arabic","text_bw":"yaquwlu ka*aA","text_ar":"يَقُولُ كَذَا"},{"kind":"italic_en","text":"He heard him say such a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"samiEa bihi","text_ar":"سَمِعَ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He heard of it;"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"samiEa Alt~akal~uma bihi","text_ar":"سَمِعَ التَّكَلُّمَ بِهِ"},{"kind":"text","text":", or the like]. (Kur xii. 31 and xxviii. 36 and xxxviii. 6, S, K, TA.) [When trans. by means of"},{"kind":"arabic","text_bw":"li","text_ar":"لِ"},{"kind":"text","text":"alone, or"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":", it denotes what is intentional.] You say,"},{"kind":"arabic","text_bw":"samiEotu lahu","text_ar":"سَمِعْتُ لَهُ"},{"kind":"text","text":", (S, Msb, TA,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (S, TA,) meaning"},{"kind":"italic_en","text":"I gave ear, hearkened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listened, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(S, Msb, * TA;) and"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tsm~Et","text_ar":"تسمّعت","orth_type":"arrow"},{"kind":"text","text":"(Msb,) or"},{"kind":"arabic","text_bw":"Alyh","text_ar":"اليه"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ais~am~aEotu","text_ar":"اِسَّمَّعْتُ"},{"kind":"text","text":", (S, TA,) signify the same; (S, Msb, TA;) and so"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstmEt","text_ar":"استمعت","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"Alyh","text_ar":"اليه"},{"kind":"text","text":". (K.) It is said in the Kur [xxxvii. 8], accord. to different readings,"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"arabic","text_bw":"yasomaEuwna A_ilaY AlmalaA_i AlA^aEolaY","text_ar":"يَسْمَعُونَ اـِلَى المَلَاـِ الاَعْلَى"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"laA yas~am~aEuwna","text_ar":"لَا يَسَّمَّعُونَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"They shall not listen"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the archangels"},{"kind":"text","text":"]: (S:) or the former has this signification,"},{"kind":"italic_en","text":"they shall not listen to the angels"},{"kind":"text","text":"(Bd, Jel)"},{"kind":"italic_en","text":"in heaven,"},{"kind":"text","text":"(Jel,) or"},{"kind":"italic_en","text":"the exalted angels:"},{"kind":"text","text":"(Bd:) and ↓ the latter,"},{"kind":"italic_en","text":"they shall not seek,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavour, to listen"},{"kind":"text","text":"&c. (Bd.) And in the same [xvii. 50], ↓"},{"kind":"arabic","text_bw":"naHonu A^aEolamu bimaA yasotamiEuwna","text_ar":"نَحْنُ اَعْلَمُ بِمَا يَسْتَمِعُونَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"bihi A_i*o yasotamiEuwna A_ilayoka","text_ar":"بِهِ اـِذْ يَسْتَمِعُونَ اـِلَيْكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We are cognizant of that on account of which they hearken when they hearken to thee"},{"kind":"text","text":"];"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"bisababihi","text_ar":"بِسَبَبِهِ"},{"kind":"text","text":", (Bd, Jel,) and"},{"kind":"arabic","text_bw":"liA^ajolihi","text_ar":"لِاَجْلِهِ"},{"kind":"text","text":", (Bd,) alluding to scoffing, or derision. (Bd, Jel.) [For various usages of"},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":"and other inf. ns., whether employed as inf. ns. or as simple substs., see those words below.] ―         -b2-  It also signifies"},{"kind":"italic_en","text":"He understood it;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"he understood its meaning;"},{"kind":"text","text":"i. e., the meaning of a person's speech. (Msb.) You say,"},{"kind":"arabic","text_bw":"lamo tasomaEo maA qulotu laka","text_ar":"لَمْ تَسْمَعْ مَا قُلْتُ لَكَ"},{"kind":"italic_en","text":"Thou didst not understand what I said to thee."},{"kind":"text","text":"(TA.) And such is the most obvious meaning of the verb in the saying,"},{"kind":"arabic","text_bw":"A_ino kaAna yasomaEu AlxaTiyba","text_ar":"اـِنْ كَانَ يَسْمَعُ الخَطِيبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If he understand the words of the preacher"},{"kind":"text","text":"]; for this is the proper meaning in this case: but it may be rendered tropically, (tropical:)"},{"kind":"italic_en","text":"if he hear the voice of the preacher."},{"kind":"text","text":"(Msb.) ―         -b3-  Also"},{"kind":"italic_en","text":"He knew it:"},{"kind":"text","text":"as in the saying,"},{"kind":"arabic","text_bw":"samiEa A@ll~`hu qawolaka","text_ar":"سَمِعَ ا@للّٰهُ قَوْلَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God knew thy saying"},{"kind":"text","text":"]. (Msb.) ―         -b4-  Also (assumed tropical:)"},{"kind":"italic_en","text":"He accepted it;"},{"kind":"text","text":"namely, evidence, and praise: or, said of the latter, (assumed tropical:)"},{"kind":"italic_en","text":"he recompensed it by acceptance:"},{"kind":"text","text":"(Msb:) (tropical:)"},{"kind":"italic_en","text":"he paid regard to it, and answered it;"},{"kind":"text","text":"namely, prayer: (tropical:)"},{"kind":"italic_en","text":"he answered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assented to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complied with, it;"},{"kind":"text","text":"namely, a person's speech. (TA.) The saying"},{"kind":"arabic","text_bw":"samiEa A@ll~`hu limano Hamidahu","text_ar":"سَمِعَ ا@للّٰهُ لِمَنْ حَمِدَهُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"May God accept the praise of him who praiseth Him:"},{"kind":"text","text":"or, accord. to IAmb,"},{"kind":"italic_en","text":"may God recompense by acceptance the praise of him who praiseth Him:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"may God answer the prayer of him who praiseth Him."},{"kind":"text","text":"(TA, as on the authority of IAmb.) ―         -b5-  Also (assumed tropical:)"},{"kind":"italic_en","text":"He obeyed him:"},{"kind":"text","text":"as in the saying in the Kur [xxxvi. 24],"},{"kind":"arabic","text_bw":"A_in~iY A=manotu birab~ikumo faA@somaEuwni","text_ar":"اـِنِّى ا=مَنْتُ بِرَبِّكُمْ فَا@سْمَعُونِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Verily I believe in your Lord, and do ye obey me"},{"kind":"text","text":"]. (TA.) ―         -b6-  Lth says that the phrase"},{"kind":"arabic","text_bw":"samiEato A^u*uniY","text_ar":"سَمِعَتْ اُذُنِى"},{"kind":"arabic","text_bw":"zayodFA yafoEalu ka*aA waka*aA","text_ar":"زَيْدًا يَفْعَلُ كَذَا وَكَذَا"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"My eye saw Zeyd doing such and such things:"},{"kind":"text","text":"but Az says, I know not whence Lth brought this; for it is not of the way of the Arabs to say"},{"kind":"arabic","text_bw":"smEt A*nY","text_ar":"سمعت اذنى"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"my eye saw:"},{"kind":"text","text":"it is in my judgment corrupt language, and I am not sure but that it may have been originated by those addicted to innovations and erroneous opinions. (TA.)"}],"source_refs":["K","Lh","S","Msb","TA","Bd","Jel"]},{"entry_id":"n20717","headword_ar":"سَمْعَةٌ","root":"smE","body":[{"kind":"italic_en","text":"A single hearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hearkening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listening."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"samoEapu A^u*uniY fulaAnFA yaquwlu *`lika","text_ar":"سَمْعَةُ اُذُنِى فُلَانًا يَقُولُ ذٰلِكَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":". ―         -b3-  See also"},{"kind":"arabic","text_bw":"sumoEapN","text_ar":"سُمْعَةٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"A^u*unN samoEapN","text_ar":"اُذُنٌ سَمْعَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saAmiEN","text_ar":"سَامِعٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n20718","headword_ar":"سُمْعَةٌ","root":"smE","body":[{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"tasomiyEN","text_ar":"تَسْمِيعٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"suxorapN","text_ar":"سُخْرَةٌ"},{"kind":"text","text":"is with"},{"kind":"arabic","text_bw":"tasoxiyrN","text_ar":"تَسْخِيرٌ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"faEalahu riy^aA='F wasumoEapF","text_ar":"فَعَلَهُ رِيَا=ءً وَسُمْعَةً"},{"kind":"italic_en","text":"He did it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to make men to see it and hear of it,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"in order that men might see it and hear of it."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"maAfaEalahu riy^aA='F walaAsumoEapF","text_ar":"مَافَعَلَهُ رِيَا=ءً وَلَاسُمْعَةً"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samoEapF","text_ar":"سَمْعَةً","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samaEapF","text_ar":"سَمَعَةً","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He did it not making it notorious so as to make"},{"kind":"text","text":"["},{"kind":"italic_en","text":"men"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to see and to hear"},{"kind":"text","text":"["},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (K.) And"},{"kind":"arabic","text_bw":"faEalotuhu","text_ar":"فَعَلْتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tasomiEataka","text_ar":"تَسْمِعَتَكَ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"tasomiEapF laka","text_ar":"تَسْمِعَةً لَكَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I did it in order that thou mightest hear it."},{"kind":"text","text":"(AZ, K.) [See also"},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":", where similar phrases are mentioned and explained.] ―         -b2-"},{"kind":"arabic","text_bw":"Als~umoEapu","text_ar":"السُّمْعَةُ"},{"kind":"text","text":", also, signifies"},{"kind":"italic_en","text":"What is heard, of fame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"report,"},{"kind":"text","text":"&c.: (Har p. 34:) and [particularly]"},{"kind":"italic_en","text":"good report."},{"kind":"text","text":"(Id. p. 196.)"}],"source_refs":[]},{"entry_id":"n20719","headword_ar":"سِمْعَةٌ","root":"smE","body":[{"kind":"italic_en","text":"A mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of hearing, hearkening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listening."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"samiEotuhu simoEapF","text_ar":"سَمِعْتُهُ سِمْعَةً"},{"kind":"arabic","text_bw":"HasanapF","text_ar":"حَسَنَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I heard it with a good manner of hearing"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"simoEapu A^u*uniY fulaAnFA yaquwlu *`lika","text_ar":"سِمْعَةُ اُذُنِى فُلَانًا يَقُولُ ذٰلِكَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n20720","headword_ar":"سَمَعَةٌ","root":"smE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sumoEapN","text_ar":"سُمْعَةٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"A^u*unN samaEapN","text_ar":"اُذُنٌ سَمَعَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saAmiEN","text_ar":"سَامِعٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}