mology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n16133"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D9%92%D9%81%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to finish or get finished"},{"pos":"verb","gloss":"to turn down, refuse, decline, reject"}]},"etymology":null,"ipa":["/ʔar.fa.dˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16133","headword_ar":"ارفضّ","root":"rfD","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became dispersed,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"and departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away;"},{"kind":"text","text":"(S, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"trf~D","text_ar":"ترفّض","orth_type":"arrow"},{"kind":"text","text":". (A, K, TA.)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a company of men)"},{"kind":"italic_en","text":"separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became dispersed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed themselves;"},{"kind":"text","text":"as also ↓ the latter verb. (Lth.) ―         -b2-"},{"kind":"arabic","text_bw":"ArfD~ Ald~amoEu","text_ar":"ارفضّ الدَّمْعُ"},{"kind":"text","text":", (S, TA,) or"},{"kind":"arabic","text_bw":"Ald~umuwEu","text_ar":"الدُّمُوعُ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"The tears became scattered in drops:"},{"kind":"text","text":"(S, K: [in one copy of the S,"},{"kind":"arabic","text_bw":"AirofiDaADu Ald~amoEi","text_ar":"اِرْفِضَاضُ الدَّمْعِ"},{"kind":"text","text":"is explained by"},{"kind":"arabic","text_bw":"taro$iy$uhu","text_ar":"تَرْشِيشُهُ"},{"kind":"text","text":"; but the right reading is"},{"kind":"arabic","text_bw":"tara$~u$uhu","text_ar":"تَرَشُّشُهُ"},{"kind":"text","text":", which I find in two copies; as in the K:]) or"},{"kind":"italic_en","text":"flowed and became scattered;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"flowed and dropped continuously:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flowed in a scattered manner:"},{"kind":"text","text":"(L:) and ↓"},{"kind":"arabic","text_bw":"trf~D","text_ar":"ترفّض","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (TA.) You say also,"},{"kind":"arabic","text_bw":"ArfD~ Als~ayolu","text_ar":"ارفضّ السَّيْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The torrent dispersed itself"},{"kind":"text","text":"]. (S, K.) And"},{"kind":"arabic","text_bw":"ArfD~ juroHuhu","text_ar":"ارفضّ جُرْحُهُ"},{"kind":"italic_en","text":"The thick purulent matter of his wound flowed, and became dispersed."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"ArfD~ EaraqFA","text_ar":"ارفضّ عَرَقًا"},{"kind":"italic_en","text":"His sweat ran;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"flowed."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"ArfD~ AlwajaEu","text_ar":"ارفضّ الوَجَعُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The pain ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went away."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"ArfD~ minohu SaboriY","text_ar":"ارفضّ مِنْهُ صَبْرِى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"My patience departed in consequence of it"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","A","K","TA","L"]}]},"classical_definitions":null}