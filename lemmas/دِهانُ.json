{"lemma":"دِهانُ","slug":"دِهانُ","root":"د.ه.ن","root_slug":"د-ه-ن","root_link":"/words/roots/د-ه-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"دِهان","root":"دهن","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n13312","n13314"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%90%D9%87%D8%A7%D9%86%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"cold cream, cosmetic cream, salve, ointment, unguent"},{"pos":"noun","gloss":"paint, varnish"},{"pos":"noun","gloss":"hypocrisy, dissimulation, deceit"},{"pos":"noun","gloss":"house painter, painter"}]},"etymology":{"source":"wiktextract","text":"Compare دَهَنَ (dahana, “to oil, to paint”).\n\nOccupational noun from the verb دَهَنَ (dahana, “to paint”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13312","headword_ar":"دِهَانٌ","root":"dhn","body":[{"kind":"italic_en","text":"A red hide."},{"kind":"text","text":"(S, K. [See also"},{"kind":"arabic","text_bw":"dahiynN","text_ar":"دَهِينٌ"},{"kind":"text","text":".]) Hence, in the Kur [lv. 37],"},{"kind":"arabic","text_bw":"fakaAnato warodapF kaAld~ihaAni","text_ar":"فَكَانَتْ وَرْدَةً كَالدِّهَانِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"And shall become red,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"of a rosecolour,"},{"kind":"text","text":"(Zj, L in art."},{"kind":"arabic","text_bw":"wrd","text_ar":"ورد"},{"kind":"text","text":",) or"},{"kind":"italic_en","text":"of a red colour inclining to yellow,"},{"kind":"text","text":"(L in that art.,)"},{"kind":"italic_en","text":"like the red hide:"},{"kind":"text","text":"(S, Bd, Jel:) or"},{"kind":"italic_en","text":"like the hide that is of a pure red colour:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"like that"},{"kind":"text","text":"["},{"kind":"italic_en","text":"oil"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with which one anoints;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"duhonN","text_ar":"دُهْنٌ"},{"kind":"text","text":": or it is pl. of"},{"kind":"arabic","text_bw":"duhonN","text_ar":"دُهْنٌ"},{"kind":"text","text":": (Bd:) [thus] it means, accord. to Aboo-Is-hák [Zj],"},{"kind":"italic_en","text":"and shall become"},{"kind":"text","text":"["},{"kind":"italic_en","text":"red,"},{"kind":"text","text":"&c., and] of various colours, by reason of the very great terror,"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"divers"},{"kind":"italic_en","text":"oils:"},{"kind":"text","text":"or, accord. to Er-Rághib,"},{"kind":"italic_en","text":"like the dregs of oil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of olive-oil;"},{"kind":"text","text":"for this is another signification of"},{"kind":"arabic","text_bw":"AldhAn","text_ar":"الدهان"},{"kind":"text","text":". (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"A slippery place."},{"kind":"text","text":"(JK, K.) And"},{"kind":"italic_en","text":"A smooth road:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long and smooth."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Bd","Jel","TA"]},{"entry_id":"n13314","headword_ar":"دَهَّانٌ","root":"dhn","body":[{"kind":"italic_en","text":"A seller of oil:"},{"kind":"text","text":"(MA, TA:) and"},{"kind":"italic_en","text":"a maker of oil."},{"kind":"text","text":"(MA.) [In the present day, it is applied to"},{"kind":"italic_en","text":"A painter of houses &c."},{"kind":"text","text":"]"}],"source_refs":["MA","TA"]}]}}