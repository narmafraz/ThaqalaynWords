rb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n37861"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%84%D9%92%D9%81%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37861","headword_ar":"اَلْفَتُ","root":"lft","body":[{"kind":"italic_en","text":"Strong-handed, who hoists,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrings, him who strives,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grapples, with him."},{"kind":"text","text":"(TA.) ―         -b2-  A he-goat"},{"kind":"italic_en","text":"having crooked horns."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"lafotaA'u","text_ar":"لَفْتَاءُ"},{"kind":"text","text":"A she-goat"},{"kind":"italic_en","text":"having crooked horns."},{"kind":"text","text":"(K.) ―         -b3-  A he-goat"},{"kind":"italic_en","text":"having one of his horns twisted"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over the other."},{"kind":"text","text":"(S.) ―         -b4-"},{"kind":"arabic","text_bw":"lafotaA'u","text_ar":"لَفْتَاءُ"},{"kind":"text","text":"A woman"},{"kind":"italic_en","text":"having distorted eyes;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HawolaA'u","text_ar":"حَوْلَاءُ"},{"kind":"text","text":". (K.) ―         -b5-"},{"kind":"arabic","text_bw":"A^alofatu","text_ar":"اَلْفَتُ"},{"kind":"text","text":"(in the dial. of Keys, S)"},{"kind":"italic_en","text":"Stupid; foolish; of little sense;"},{"kind":"text","text":"(S, K;) like"},{"kind":"arabic","text_bw":"A^aEofatu","text_ar":"اَعْفَتُ"},{"kind":"text","text":"(S) [and"},{"kind":"arabic","text_bw":"A^aEofaku","text_ar":"اَعْفَكُ"},{"kind":"text","text":"]: fem."},{"kind":"arabic","text_bw":"lafotaA'u","text_ar":"لَفْتَاءُ"},{"kind":"text","text":": [see also"},{"kind":"arabic","text_bw":"lifotN","text_ar":"لِفْتٌ"},{"kind":"text","text":":] so too ↓"},{"kind":"arabic","text_bw":"lafaAtN","text_ar":"لَفَاتٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or this signifies"},{"kind":"italic_en","text":"stupid, foolish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of little sense, and of difficult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stubborn disposition:"},{"kind":"text","text":"(S:) [see also"},{"kind":"arabic","text_bw":"lafuwtN","text_ar":"لَفُوتٌ"},{"kind":"text","text":":] or, accord. to A 'Obeyd, as mentioned in a marginal note in a copy of the S, ↓"},{"kind":"arabic","text_bw":"lafaAtN","text_ar":"لَفَاتٌ","orth_type":"arrow"},{"kind":"text","text":"and its syn."},{"kind":"arabic","text_bw":"hafaAtN","text_ar":"هَفَاتٌ"},{"kind":"text","text":"are correctly written"},{"kind":"arabic","text_bw":"lafaApN","text_ar":"لَفَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hafaApN","text_ar":"هَفَاةٌ"},{"kind":"text","text":", for in a case of pause they are pronounced"},{"kind":"arabic","text_bw":"lafaAho","text_ar":"لَفَاهْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hafaAho","text_ar":"هَفَاهْ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"hafaAtN","text_ar":"هَفَاتٌ"},{"kind":"text","text":". (TA.) ―         -b6-  (In the dial. of Temeem, S,)"},{"kind":"italic_en","text":"Left-handed; who works with the left hand;"},{"kind":"text","text":"(S, K;) as also"},{"kind":"arabic","text_bw":"A^alofaku","text_ar":"اَلْفَكُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}