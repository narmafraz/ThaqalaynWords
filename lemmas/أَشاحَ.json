m":"s"},{"role":"present_1mp","form":"نُشِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشِيح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n23467"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D8%A7%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to turn away, to draw into another direction (gaze, face, attention)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23467","headword_ar":"اشاح","root":"$yH","body":[{"kind":"text","text":", (S, A, K,) inf. n."},{"kind":"arabic","text_bw":"A_i$aAHapN","text_ar":"اـِشَاحَةٌ"},{"kind":"text","text":", (IAar, TA,)"},{"kind":"italic_en","text":"He was cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in fear,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of it"},{"kind":"text","text":"], (A, TA,) i. e. a thing, or an affair, (TA,) and"},{"kind":"arabic","text_bw":"EalaY HaAjatihi","text_ar":"عَلَى حَاجَتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the thing that he wanted"},{"kind":"text","text":"]; (K;) as also ↓"},{"kind":"arabic","text_bw":"$AyH","text_ar":"شايح","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) inf."},{"kind":"arabic","text_bw":"mu$aAyaHapN","text_ar":"مُشَايَحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$iyaAHN","text_ar":"شِيَاحٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"$aAHa","text_ar":"شَاحَ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"he was cautious and in fear, endeavouring to repel death."},{"kind":"text","text":"(L.) ―         -b2-  But in the dial. of Hudheyl, (S,)"},{"kind":"italic_en","text":"He strove, laboured, toiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exerted himself,"},{"kind":"arabic","text_bw":"fiY A^amorK","text_ar":"فِى اَمْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an affair"},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"$AyH","text_ar":"شايح","orth_type":"arrow"},{"kind":"text","text":". (S, A.) ―         -b3-  And"},{"kind":"italic_en","text":"He continued journeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going on."},{"kind":"text","text":"(O.) ―         -b4-"},{"kind":"arabic","text_bw":"A$AH biwajohihi","text_ar":"اشاح بِوَجْهِهِ"},{"kind":"italic_en","text":"He turned away his face,"},{"kind":"text","text":"(S, A, TA,) from a [person or] thing, or from the heat of fire, or a hot odour, and from something hurtful: (TA:) or"},{"kind":"italic_en","text":"he exerted himself in aversion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turning away."},{"kind":"text","text":"(IAar, TA.) One says,"},{"kind":"arabic","text_bw":"kal~amotuhu faA^a$aAHa biwajohihi","text_ar":"كَلَّمْتُهُ فَاَشَاحَ بِوَجْهِهِ"},{"kind":"italic_en","text":"I spoke to him, and he turned away his face."},{"kind":"text","text":"(A.) ―         -b5-"},{"kind":"arabic","text_bw":"A$AH","text_ar":"اشاح"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came forward;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aqobala","text_ar":"اَقْبَلَ"},{"kind":"text","text":". (Fr, O, TA.) [Thus it has two contr. meanings. See also the part. n.,"},{"kind":"arabic","text_bw":"mu$iyHN","text_ar":"مُشِيحٌ"},{"kind":"text","text":".] ―         -b6-  And"},{"kind":"italic_en","text":"He defended what was behind his back."},{"kind":"text","text":"(IAth, TA.) [See, again, the part. n.] ―         -b7-"},{"kind":"arabic","text_bw":"A$AH bi*anabihi","text_ar":"اشاح بِذَنَبِهِ"},{"kind":"text","text":", said of a horse,"},{"kind":"italic_en","text":"He let his tail hang down loosely."},{"kind":"text","text":"(Lth, S.) F, in the K, following Az and Sgh, says that this is a mistranscription of the verb, for"},{"kind":"arabic","text_bw":"AsAH","text_ar":"اساح"},{"kind":"text","text":"; but his assertion requires proof. (MF.) [See the latter verb, in art."},{"kind":"arabic","text_bw":"syH","text_ar":"سيح"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"A$AHt AlA^aroDu","text_ar":"اشاحت الاَرْضُ"},{"kind":"italic_en","text":"The land produced the plant called"},{"kind":"arabic","text_bw":"$iyH","text_ar":"شِيح"},{"kind":"text","text":". (AHn, O, K.)"}],"source_refs":["S","A","K","IAar","TA"]}]},"classical_definitions":null}