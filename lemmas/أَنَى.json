corpus":1511,"cross_references":{"qac":{"found":true,"lemma_key":"أَنَى","root":"أني","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n1403","n1404","n1410","","n1407","n1408","n1409","n1414","n1416"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to postpone, put off, delay, defer, retard"},{"pos":"verb","gloss":"to restrain, withold, impede"}]},"etymology":null,"ipa":["/ʔaː.naː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1403","headword_ar":"اَنَى","root":"AnY","body":[{"kind":"text","text":", (S, M, K,) aor."},{"kind":"arabic","text_bw":"yaA^oniY","text_ar":"يَاْنِى"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"A_inNY","text_ar":"اـِنٌى"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"A^anoYN","text_ar":"اَنْىٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^anaA='N","text_ar":"اَنَا=ءٌ"},{"kind":"text","text":", (M, K,) or, accord. to [some of the copies of] the M,"},{"kind":"arabic","text_bw":"A^anFY","text_ar":"اَنًى"},{"kind":"text","text":", (TA, [in which this is said to be the right form,]) or"},{"kind":"arabic","text_bw":"A^anFA","text_ar":"اَنًا"},{"kind":"text","text":", (as written in the CK,) said of a thing,"},{"kind":"italic_en","text":"Its time came;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^ataY waqotuhu","text_ar":"اَتَى وَقْتُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"jaA='a A^anaAhu","text_ar":"جَا=ءَ اَنَاهُ"},{"kind":"text","text":"; (Bd lvii. 15 [in explanation of a passage cited voce"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":"];) or"},{"kind":"arabic","text_bw":"HaAna","text_ar":"حَانَ"},{"kind":"text","text":": (S, M, K:) or"},{"kind":"arabic","text_bw":"A^anaY","text_ar":"اَنَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^oniY","text_ar":"يَاْنِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^anoYN","text_ar":"اَنْىٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present."},{"kind":"text","text":"(Msb.) You say,"},{"kind":"arabic","text_bw":"A^anaY laka","text_ar":"اَنَى لَكَ"},{"kind":"arabic","text_bw":"A^ano tafoEala","text_ar":"اَنْ تَفْعَلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^oniY","text_ar":"يَاْنِى"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"A=na","text_ar":"ا=نَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yay^iynu","text_ar":"يَيِينُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"naAla lk","text_ar":"نَالَ لك"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaniylu","text_ar":"يَنِيلُ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"A^anaAla","text_ar":"اَنَالَ"},{"kind":"text","text":"; all meaning"},{"kind":"arabic","text_bw":"HaAna laka","text_ar":"حَانَ لَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The time has come,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has drawn near, for thee that thou shouldst do"},{"kind":"text","text":"such a thing: or"},{"kind":"italic_en","text":"the time of thy doing"},{"kind":"text","text":"such a thing"},{"kind":"italic_en","text":"has come to thee:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy doing"},{"kind":"text","text":"such a thing"},{"kind":"italic_en","text":"has drawn near"},{"kind":"text","text":"]: so says Zj; and Fr says the like: but the best of these is"},{"kind":"arabic","text_bw":"A^anaY laka","text_ar":"اَنَى لَكَ"},{"kind":"text","text":". (T.) And"},{"kind":"arabic","text_bw":"A^anaY Alr~aHiylu","text_ar":"اَنَى الرَّحِيلُ"},{"kind":"italic_en","text":"The time of departure came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"HaAna","text_ar":"حَانَ"},{"kind":"arabic","text_bw":"waqotuhu","text_ar":"وَقْتُهُ"},{"kind":"text","text":". (TA, from a trad.) ―         -b2-"},{"kind":"italic_en","text":"It came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, to its time; to its full,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"final, time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state; to maturity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ripeness; it became mature,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ripe;"},{"kind":"text","text":"(T, S, M, IAmb, * Msb, * K;) or, accord. to some, only when said of a plant; (M, K;) [or it signifies also]"},{"kind":"italic_en","text":"it became thoroughly cooked."},{"kind":"text","text":"(T, Msb. *) Hence, in the Kur [xxxiii. 53],"},{"kind":"arabic","text_bw":"gayoranaAZiriyna A_inaAhu","text_ar":"غَيْرَنَاظِرِينَ اـِنَاهُ"},{"kind":"italic_en","text":"Not waiting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"watching, for its becoming thoroughly cooked;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for its cooking becoming finished."},{"kind":"text","text":"(T, S, * M.) [See also"},{"kind":"arabic","text_bw":"A_inFY","text_ar":"اـِنًى"},{"kind":"text","text":", below.] You say also,"},{"kind":"arabic","text_bw":"A^anaY AlHamiymu","text_ar":"اَنَى الحَمِيمُ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"A^anoYN","text_ar":"اَنْىٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"The hot water became heated to the utmost degree."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"A^anaY AlmaA='u","text_ar":"اَنَى المَا=ءُ"},{"kind":"italic_en","text":"The water became hot to the utmost degree."},{"kind":"text","text":"(M.)       -A2-"},{"kind":"arabic","text_bw":"A^anaY","text_ar":"اَنَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"A^uniY~N","text_ar":"اُنِىٌّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^anoYN","text_ar":"اَنْىٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, its time:"},{"kind":"text","text":"(Lth, T:) or"},{"kind":"arabic","text_bw":"A^anaY","text_ar":"اَنَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^uniY~N","text_ar":"اُنِىٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"(a man, TA,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, behind, backward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"late; it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, delayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back;"},{"kind":"text","text":"(M, K;) as also"},{"kind":"arabic","text_bw":"A^aniYa","text_ar":"اَنِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^onaY","text_ar":"يَاْنَى"},{"kind":"text","text":", inf. n."}],"source_refs":["S","M","K","Lth","T"]},{"entry_id":"n1404","headword_ar":"اـِنًى","root":"AnY","body":[{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"A^an~aY","text_ar":"اَنَّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taA^oniyapN","text_ar":"تَاْنِيَةٌ"},{"kind":"text","text":". (K.) ―         -b2-  See also 5, in two places."}],"source_refs":[]},{"entry_id":"n1410","headword_ar":"اـِنًى","root":"AnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A_iniYN","text_ar":"اـِنِىٌ"},{"kind":"text","text":", in two places: ―         -b2-  and see"},{"kind":"arabic","text_bw":"A^anFY","text_ar":"اَنًى"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1407","headword_ar":"اَنْىٌ","root":"AnY","body":[{"kind":"text","text":": see what next follows."}],"source_refs":[]},{"entry_id":"n1408","headword_ar":"اـِنْىٌ","root":"AnY","body":[{"kind":"text","text":"(AO, T, S, M, Msb, K) and ↓"},{"kind":"arabic","text_bw":"A_inFY","text_ar":"اـِنًى","orth_type":"arrow"},{"kind":"text","text":", (Akh, T, S, Msb,) the latter in [some of] the copies of the K erroneously written"},{"kind":"arabic","text_bw":"A^anaA='N","text_ar":"اَنَا=ءٌ"},{"kind":"text","text":", (TA,) [and in other copies of the same omitted,] and ↓"},{"kind":"arabic","text_bw":"A_inowN","text_ar":"اـِنْوٌ","orth_type":"arrow"},{"kind":"text","text":", (Akh, Th, T, S, M, K,) with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"substituted for"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", (AAF, M,) and ↓"},{"kind":"arabic","text_bw":"A^anoYN","text_ar":"اَنْىٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"A^anFY","text_ar":"اَنًى","orth_type":"arrow"},{"kind":"text","text":", (M, I Amb,)"},{"kind":"italic_en","text":"An hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an indefinite time,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEapN","text_ar":"سَاعَةٌ"},{"kind":"text","text":",) of the night: (Zj, T, S, M, K:) or"},{"kind":"italic_en","text":"a time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"waqotN","text_ar":"وَقْتٌ"},{"kind":"text","text":") of the night: (M in art."},{"kind":"arabic","text_bw":"Anw","text_ar":"انو"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"wahonN","text_ar":"وَهْنٌ"},{"kind":"text","text":"[the"},{"kind":"italic_en","text":"period about midnight;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"time after an hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short period, of the night;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"when the night is departing"},{"kind":"text","text":"]: (M, K:) or"},{"kind":"italic_en","text":"any"},{"kind":"arabic","text_bw":"saAEap","text_ar":"سَاعَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"short portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time,"},{"kind":"text","text":"] (M, K) of the night: (M:) [and"},{"kind":"italic_en","text":"any period of time;"},{"kind":"text","text":"as will be seen below:] or, accord. to some, (M,) ↓"},{"kind":"arabic","text_bw":"A_inFY","text_ar":"اـِنًى","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"whole day;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^anFY","text_ar":"اَنًى","orth_type":"arrow"},{"kind":"text","text":": (K:) the pl. is"},{"kind":"arabic","text_bw":"A=naA='N","text_ar":"ا=نَا=ءٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^unY~N","text_ar":"اُنىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_iniY~N","text_ar":"اـِنِىٌّ"},{"kind":"text","text":". (M, K.) You say,"},{"kind":"arabic","text_bw":"maDaY A_inoYN mina Al~ayoli","text_ar":"مَضَى اـِنْىٌ مِنَ الَّيْلِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A_inowN","text_ar":"اـِنْوٌ","orth_type":"arrow"},{"kind":"text","text":"[&c.]"},{"kind":"italic_en","text":"A time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season,"},{"kind":"text","text":"[&c.,] ("},{"kind":"arabic","text_bw":"waqotN","text_ar":"وَقْتٌ"},{"kind":"text","text":", [&c.,])"},{"kind":"italic_en","text":"of the night passed:"},{"kind":"text","text":"(M in art."},{"kind":"arabic","text_bw":"Anw","text_ar":"انو"},{"kind":"text","text":":) dual"},{"kind":"arabic","text_bw":"A_inoyaAni","text_ar":"اـِنْيَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_inowaAni","text_ar":"اـِنْوَانِ"},{"kind":"text","text":". (S.) And a poet says,"},{"kind":"quote","text":"A^atam~ato HamolahaA fiY baEoDi $ahorK\n                      \n                     \n                        waHamolu AlHaAmalaAti A_nFY Tawiylu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She completed her gestation in a portion of a month; but the gestation of the pregnant"},{"kind":"text","text":"in general"},{"kind":"italic_en","text":"is a long period of time"},{"kind":"text","text":"]. (IAar, T.) Another uses the phrase"},{"kind":"arabic","text_bw":"DaH~aAku AlA^uniYo","text_ar":"ضَحَّاكُ الاُنِىْ"},{"kind":"text","text":", occurring at the end of a verse, [for"},{"kind":"arabic","text_bw":"DH~Ak AlA^uniY~i","text_ar":"ضحّاك الاُنِىِّ"},{"kind":"text","text":",] meaning"},{"kind":"italic_en","text":"Found to be laughing whenever one comes to him."},{"kind":"text","text":"(M.)"}],"source_refs":["AO","T","S","M","Msb","K","Akh","TA","Th","AAF","Zj"]},{"entry_id":"n1409","headword_ar":"اَنًى","root":"AnY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A_inoYN","text_ar":"اـِنْىٌ"},{"kind":"text","text":", in two places. ―         -b2-  The"},{"kind":"italic_en","text":"utmost point, reach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree,"},{"kind":"text","text":"(M, K,) of a thing; (M;) as also ↓"},{"kind":"arabic","text_bw":"A_inFY","text_ar":"اـِنًى","orth_type":"arrow"},{"kind":"text","text":": so in the phrase,"},{"kind":"arabic","text_bw":"balaga A^anaAhu","text_ar":"بَلَغَ اَنَاهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_inaAhu","text_ar":"اـِنَاهُ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, M)"},{"kind":"italic_en","text":"attained its utmost point, reach,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree:"},{"kind":"text","text":"(M, K:) or this means, [or, accord. to the CK, “and” it means,]"},{"kind":"italic_en","text":"its state of being thoroughly cooked; its state of maturity;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its full,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"final, time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state."},{"kind":"text","text":"(K.) [See 1, where an ex. from the Kur xxxiii. 53 is cited. Both words are said to be inf. ns.]       -A2-  See also"},{"kind":"arabic","text_bw":"A^anaApN","text_ar":"اَنَاةٌ"},{"kind":"text","text":"."}],"source_refs":["M","K"]},{"entry_id":"n1414","headword_ar":"اَنِىٌّ","root":"AnY","body":[{"kind":"text","text":", as part. n. of 1, A thing"},{"kind":"italic_en","text":"of which the time has come,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drawn near:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"which has come,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, to its time; to its full,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"final, time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state; to maturity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ripeness:"},{"kind":"text","text":"but accord. to some, only applied to a plant. (M, K.) [Compare"},{"kind":"arabic","text_bw":"A=nK","text_ar":"ا=نٍ"},{"kind":"text","text":".]       -A2-"},{"kind":"italic_en","text":"Behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, the time; backward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"late; delayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back;"},{"kind":"text","text":"(K, TA; [but wanting in a MS. copy of the former in my possession, and in the CK;]) as also ↓"},{"kind":"arabic","text_bw":"A=nK","text_ar":"ا=نٍ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":[]},{"entry_id":"n1416","headword_ar":"اَنَّى","root":"AnY","body":[{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"Whence?"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"mino A^ayona","text_ar":"مِنْ اَيْنَ"},{"kind":"text","text":"; (T, S, M;) being an interrogative respecting the direction, or quarter, from which a thing is: (Msb:) and"},{"kind":"italic_en","text":"whence"},{"kind":"text","text":"[used to denote a condition]: (TA:) and"},{"kind":"italic_en","text":"where?"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"where"},{"kind":"text","text":"[used to denote a condition]; syn."},{"kind":"arabic","text_bw":"A^ayona","text_ar":"اَيْنَ"},{"kind":"text","text":": (T, K: [in which latter the first signification is not mentioned:]) and as one of the adverbial nouns used to denote a condition,"},{"kind":"italic_en","text":"whencesoever; from whatever direction"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter:"},{"kind":"text","text":"(S:) and"},{"kind":"italic_en","text":"wherever; wheresoever:"},{"kind":"text","text":"(Lth, T:) and"},{"kind":"italic_en","text":"when?"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"when"},{"kind":"text","text":"[used to den a condition]; syn."},{"kind":"arabic","text_bw":"mataY","text_ar":"مَتَى"},{"kind":"text","text":": (T, K: [but in the latter of these, in art."},{"kind":"arabic","text_bw":"An","text_ar":"ان"},{"kind":"text","text":", in the place of"},{"kind":"arabic","text_bw":"mataY","text_ar":"مَتَى"},{"kind":"text","text":"we find"},{"kind":"arabic","text_bw":"Hayovu","text_ar":"حَيْثُ"},{"kind":"text","text":", which I regard as a mistake:]) and"},{"kind":"italic_en","text":"how?"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kayofa","text_ar":"كَيْفَ"},{"kind":"text","text":": (Lth, T, S, M, K:) and"},{"kind":"italic_en","text":"however."},{"kind":"text","text":"(Lth, TA.) [I mention all these significations together because"},{"kind":"page_break","n":120},{"kind":"text","text":"one of them is assigned by some authorities and another by others to"},{"kind":"arabic","text_bw":"An~Y","text_ar":"انّى"},{"kind":"text","text":"in one and the same instance.] You say,"},{"kind":"arabic","text_bw":"A^an~aY yakuwnu h`*aA","text_ar":"اَنَّى يَكُونُ هٰذَا"},{"kind":"italic_en","text":"Whence, from what direction"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter, from what way, will,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"should, be this?"},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^an~aY laka h`*aA","text_ar":"اَنَّى لَكَ هٰذَا"},{"kind":"italic_en","text":"Whence"},{"kind":"text","text":"[came, or cometh,]"},{"kind":"italic_en","text":"to thee this?"},{"kind":"text","text":"(S.) It is said in the Kur [iii. 32],"},{"kind":"arabic","text_bw":"yaA maroyamu A^an~aY laki h`*aA","text_ar":"يَا مَرْيَمُ اَنَّى لَكِ هٰذَا"},{"kind":"italic_en","text":"O Mary, whence"},{"kind":"text","text":"[came]"},{"kind":"italic_en","text":"to thee this?"},{"kind":"text","text":"(T.) And in the same [xxxiv. 51],"},{"kind":"arabic","text_bw":"waA^an~aY lahumu A@lt~anaAwu$u mino","text_ar":"وَاَنَّى لَهُمُ ا@لتَّنَاوُشُ مِنْ"},{"kind":"arabic","text_bw":"makaAnK baEiydK","text_ar":"مَكَانٍ بَعِيدٍ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"But"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"whence"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shall the attaining"},{"kind":"text","text":"of belief"},{"kind":"italic_en","text":"be possible to them from a distant place,"},{"kind":"text","text":"i. e., (as explained in the S in art."}],"source_refs":["Msb","TA","S","Lth","T","M","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%86%D9%89/","headword_ar":"أنى","entries":[{"lexicon_id":"dictionary_17","lexicon_en":"Al-Fayyūmī, Al-Miṣbāḥ al-Munīr fī Gharīb al-Sharḥ al-Kabīr (d. 1368 CE)","lexicon_ar":"المصباح المنير للفيّومي","permalink":"https://arabiclexicon.hawramani.com/?p=293#7221a3","body_html":"<span class=\"title1\">أ ن ى</span><span> : أَنَّى اسْتِفْهَامٌ عَنْ الْجِهَةِ تَقُولُ أَنَّى يَكُونُ هَذَا أَيْ مِنْ أَيِّ وَجْهٍ وَطَرِيقٍ. </span>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=293#bb6f7b","body_html":"<span class=\"title1\">أنى</span><br><span>أَنَّى للبحث عن الحال والمكان، ولذلك قيل: هو بمعنى كيف وأين ، لتضمنه معناهما، قال الله عزّ وجل: أَنَّى لَكِ هذا [آل عمران/ 37] ، أي: من أين، وكيف.</span>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=293#aa69a5","body_html":"<span class=\"title1\"><span class=\"title1\">(أنى)</span></span><span> - قَولُه تَبارَكَ وتَعالَى: {وَبَيْنَ حَمِيمٍ آنٍ} .</span><br><span>يعني الذي قد انْتَهى حَرُّه وبَلَغ مُنْتَهاه، والفِعل أَنَى يَأْنِى.</span>"},{"lexicon_id":"dictionary_14","lexicon_en":"Zayn al-Dīn al-Razī, Mukhtār al-Ṣiḥāḥ (d. 1266 CE)","lexicon_ar":"مختار الصحاح للرازي","permalink":"https://arabiclexicon.hawramani.com/?p=293#4a9b7e","body_html":"أ ن ى: (أَنَّى) مَعْنَاهُ أَيْنَ تَقُولُ أَنَّى لَكَ هَذَا أَيْ مِنْ أَيْنَ لَكَ هَذَا؟ وَهِيَ مِنَ الظُّرُوفِ الَّتِي يُجَازَى بِهَا، تَقُولُ: أَنَّى تَأْتِنِي آتِكَ، مَعْنَاهُ مِنْ أَيِّ جِهَةٍ تَأْتِنِي آتِكَ. وَقَدْ تَكُونُ بِمَعْنَى كَيْفَ تَقُولُ: أَنَّى لَكَ أَنْ تَفْتَحَ الْحِصْنَ؟ أَيْ كَيْفَ لَكَ ذَلِكَ؟ وَأَمَّا أَنَّا فَقَدْ سَبَقَ فِي أن ن."},{"lexicon_id":"dictionary_1","lexicon_en":"Ibn Manẓūr, Lisān al-ʿArab (d. 1311 CE)","lexicon_ar":"لسان العرب لابن منظور","permalink":"https://arabiclexicon.hawramani.com/?p=293#1cff8c","body_html":"<p>أنى: أَنَّى: معناه أَيْنَ.تقول: أَنَّى لك هذا أَي من أَيْن لك هذا،</p><p>وهي من الظروف التي يُجازى بها، تقول: أَنَّى تَأْتِني آتِكَ؛ معناه من</p><p>أَيّ جهة تَأْتِني آتِكَ، وقد تكون بمعنى كيفَ، تقول: أَنَّى لكَ أَنْ</p><p>تَفْتَحَ الحِصْنَ أَي كَيْفَ لكَ ذلك. التهذيب: قال بعضهم أَنَّى أَداةٌ</p><p>ولها معنيان: أَحدهما أَن تكون بمعنى مَتى؛ قال الله تعالى: قُلْتُمْ</p><p>أَنَّى هذا؛ أَي مَتى هذا وكيف هذا، وتكون أَنَّى بمعنى من أَيْنَ، قال الله</p><p>تعالى: وأَنَّى لَهُمُ التَّناوُشُ من مَكانٍ بَعِيدٍ؛ يقول: من أَيْنَ</p><p>لهم ذلك؛ وقد جمعهما الشاعر تأْكيداً فقال:</p><p>أَنَّى ومّنْ أَيْنَ آبَكَ الطَّرَبُ</p><p>وفي التنزيل العزيز: قلتم أَنَّى هذا؛ يحتمل الوجهين: قلتم من أَيْنَ</p><p>هذا، ويكون قلتم كَيْفَ هذا. وقال تعالى: قال يا مَرْيَمُ أَنَّى لَكِ هذا</p><p>؛ أَيْ من أَيْنَ لك هذا. وقال الليث: أَنَّى معناها كيف ومِنْ أَيْنَ ؛</p><p>وقال في قول علقمة:</p><p>ومُطْعَمُ الغُنْمِ يَومَ الغُنْمِ مُطْعَمُهُ</p><p>أَنّى تَوَجَّه، والمَحْرُومُ مَحْرومُ</p><p>أَراد: أَينما توجه وكَيْفَما تَوَجَّه. وقال ابن الأَنباري: قرأَ</p><p>بعضهم أَنَّى صَبَبْنا الماءَ صَبّاً؛ قال: مَن قرأَ بهذه القراءَة قال</p><p>الوقف على طَعامه تامٌّ، ومعنى أَنَّى أَيْنَ إلا أَن فيها كِناية عن الوُجوه</p><p>وتأْويلها من أَيّ وجه صَبَبْنا الماء؛ وأَنشد:</p><p>أَنَّى ومن أَينَ آبَكَ الطَّرَبُ</p>"},{"lexicon_id":"dictionary_10","lexicon_en":"Abū Mūsā al-Madīnī, al-Majmūʿ al-Mughīth fī Gharībay al-Qurʾān wa-l-Ḥadīth (d. 1185 CE)","lexicon_ar":"المجموع المغيث في غريبي القرآن والحديث لأبو موسى المديني","permalink":"https://arabiclexicon.hawramani.com/?p=293#d80208","body_html":"<span class=\"title1\">(أنى)</span><span> - في حَديِث أَبِى بَرْزَة: \"أنَّ رسولَ الله، - صلى الله عليه وسلم -، أَمرَ</span><span> </span><span>رَجلا أن يُزَوِّجَ ابنَتَه جُلَيْبِيًا، فقال الرجل: حَتَّى أُشاوِرَ أُمَّها، فلما ذَكَره لها. قالت: حَلْقَى، أَلجُلَيْبِيب إِنيه؟ لا، لَعَمْرُ اللهِ\".</span><br><span>قال بَعضُ نَحوِيَّى زَمانِنا: إِنيه: لفظ يُستَعْمل في الِإنكار على وَجْهَين: أَحدُهما: أن يقول القائِل: جاءَنى زَيدٌ. فتقول أنت: أزيدُنيه، وإذا قال: رأيتُ زَيدًا فتقول أنت: أزيدَ نِيهْ، وإذا قال: مرَرتُ بزَيْد قلت: أَزيِد نِيه. فتُحرِّكُ التَّنوينَ وتَصِلُه بالياء، ثمَّ تَقِف بالهاء، ومَعْناه: إنكار مَجِىءِ زَيد فكأنّه حين قال: جاء زَيدٌ، تقول أنت: جاء زَيْد على سَبِيلِ الِإنكار! يعني ما جاءَ زَيْد. وقد يَزِيدون إن كما تَقول: أَزيدٌ إنيه، فتَزِيد إن كما زادُوها في النَّفْى المَحْضِ، قال الشاعر:</span><br><span>* ومَا إن طِبُّنا جُبْنٌ وَلِكن * </span><br><span>وقال آخر:</span><br><span>* وما إن طِبُّها إلا اللُّغوب *</span><br><span>: أي ما طِبُّها، وإن زائدة، وكذلك إذا قال: أزيدٌ إنيه، وهو على معنى أزيدٌ نِيهِ يريد إنكارَ مَجِىء زَيْد.</span><br><span>ووجه آخر: أن تقول: أزيدٌ نِيه، يعنِي تَقُول بمَجِىء زيدٍ عندي، وزيدٌ لا يُستَبْعَد مَجِيئُه عندِى، كأنه يَعنِي هو مَعروفٌ بهذا الفِعْل، قال: وقيل لأعرابى: كان إذا أَخصَبت البادِيةُ يدخُلُها فَقِيل:</span><span> </span><span>دخلتَ البادِيَة، فقال: أأنا إنيه؟ يعني، أتَقولُون لِى هذا القَوْل، وأنا مَعْروف بهذا الفِعْل، إلى هنا قوله.</span><br><span>وقد سَألتُ أبا الفَضْل بنَ نَاصِر ببَغدادَ في السَّفْرة الثانية عن هذا اللَّفْظِ، وحَكيَت له قولَ هَذا النَّحوِىِّ، فلم يرتَضِهْ وقال: إنما هو ألِجُلَيْبِيبٍ ابْنَه، تَعنِي ابنَتِى، فأَسقَط منه الياءَ ووقَف عليه بالهاءِ، وأُخْرِج إلىّ من مُسنَد الِإمام أحمد بن حَنْبَل بخَطَّ أبي الحَسَن بن الفُراتِ هَكَذا مُعْجَمًا مُقيَّدا في مواضِعَ، وقال: إنما خَطُّ ابنِ الفُرات حُجَّة، وقد كَتبَه عن القَطيعِى، عن عبدِ الله بن أحمد، عن أبيه، وهم أعلَمُ بالرواية. قلت: والرِّوَايَة إذا كانت بغَيْر عِلم لا تكون حُجَّة، فكيف وقد بلَغَنى بإسنادٍ لا أذكُرُه، عن الِإمام أحمد، أنَّه قِيل له: هل يَكُون في الحَدِيث شىءٌ لا يَعرِفون مَعْنَاه؟، فقال: كَثِير.</span><br><span>وأخبرنا به أحمدُ بنُ على الأُسْوارِىّ إذنًا عن كتاب أحمد بن جعفر الفَقِيه، عن أبي بَكْر المُقْرِى بِمِثْله، قال: سَمِعتُ أَبَا عُبَيد عَلِىَّ بنَ الحُسَيْن بن حَزْبُويَه قال: سمعتُ إبراهيمَ الحَربِى يقول: قُلتُ: لأَحمدَ ابنِ حَنْبَل: يا أَبا عَبدِ الله رُبَّما جاءَكم عن النّبِىّ الله - صلى الله عليه وسلم -. شَىءٌ لا تَعرفُوَنه؟ فقال: كَثيرٌ.</span><br><span>ووجدتُ بخَطِّ أبي نِزار قال: سَمِعتُ أبا بَكْر بنَ عاصِم يقول: سَمِعتُ أبا عُبَيْد بن حَزْبُويَه يقول: سمعت إبراهيم الحربىَّ يقول: سألتُ أحمدَ بن حنبل، فقلت: ربما جاءَكُم عن النَّبِىِّ - صلى الله عليه وسلم - شَىءٌ لم تَعرِفُوه فقال: كَثِيرٌ.</span><span>وقد تَخْتَلِف النُّسَخ لمُسْنَد أحمد بِهَذا، فرأيتُه في مواضِعَ من نسخة: ابْنَة وفي روايةَ ابْنِيَهْ. وَوَجَدْتُه في مُسنَد أَبى يَعْلَى الأَنِيه، وفي كِتاب مَعانى الأَخْبارِ لأبىِ بَكْرِ بن أبي عاصِم قالت: حَلْقَى ألِجُلَيْبِيبٍ أَلاهِيَهْ، مَرَّتَين وقيل: إنَّ أَبَا إِسحاقَ بن حَمْزة رَواه، آمنة على أَنَّها اسمُ البِنْت، وقيل في رواية: الَأَمة</span><br><span>وهذا الاخْتِلافُ يَدُلُّ على عدم مَعِرفَتِهم بَحقِيقَتهِ.</span>"},{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=293#97f690","body_html":"<span class=\"title1\">أ ن ى</span><br><br><span>انتظرنا إنى الطعام أي إدراكه. وبلغت البرمة إناها. \" غير ناظرين إناه \". يقال أنى الطعام أنًى، وحميم آن، وعين آنية: قد انتهى حرهما. وهو يقوم آناء الليل أي ساعاته. وأما أنى لك وألم يأن لك أن تفعل. وإنه لذو أناة ورفق. قال النابغة:</span><br><br><span>الرفق يمن والأناة سعادة </span><span class=\"red\">...</span><span> فتأن في رفق تلاق نجاحا</span><br><br><span>وامرأة أناة: فتور، ونساء أنوات. وتأنّى في الأمر واستأنى. يقال تأن في أمرك، واتئد. قال حارثة بن بدر:</span><br><br><span>استأن تظفر في أمورك كلها </span><span class=\"red\">...</span><span> وإذا عزمت على الهوى فتوكل</span><br><br><span>واستأنى في الطعام: انتظر إدراكه. واستأنيت </span><span>فلاناً: لم أعجله. واستأنى به: رفق به. ويستأني بالجراحة: ينتظر مآل أمرها. قال ابن مقبل:</span><br><br><span>وقوم بأيديهم رماح ردينة </span><span class=\"red\">...</span><span> شوارع تستأني دماً أو تسلف</span><br><br><span>تنتظره أو تتعجله. وآنيت الأمر: أخرته عن وقته. يقال: لا تؤن فرصتك. وقال الحطيئة:</span><br><br><span>وآنيت العشاء إلى سهيل </span><span class=\"red\">...</span><span> أو الشعرى فطال بي الأناء</span>"}]}}