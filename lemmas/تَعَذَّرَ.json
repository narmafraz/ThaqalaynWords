n28431"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B9%D9%8E%D8%B0%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to excuse oneself"},{"pos":"verb","gloss":"to be besmirched, to be soiled, to be smudged","tags":["archaic"]},{"pos":"verb","gloss":"to be impossible"},{"pos":"noun","gloss":"verbal noun of تَعَذَّرَ (taʕaḏḏara) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28431","headword_ar":"تعذّر","root":"E*r","body":[{"kind":"text","text":": see 8, in three places. ―         -b2-  Also"},{"kind":"italic_en","text":"He went backwards; drew back; remained behind;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld himself, for a cause rendering him excused."},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"tagad~ara","text_ar":"تَغَدَّرَ"},{"kind":"text","text":", q. v.) ―         -b3-  And"},{"kind":"italic_en","text":"He fled."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"tE*~rwA Ealayohi","text_ar":"تعذّروا عَلَيْهِ"},{"kind":"italic_en","text":"They fled from him, and abstained from aiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assisting, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back from him."},{"kind":"text","text":"(O.) ―         -b4-  And"},{"kind":"italic_en","text":"He resisted,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"was difficult:"},{"kind":"text","text":"it is said in a trad., [respecting Mohammad,]"},{"kind":"arabic","text_bw":"kaAna yataEa*~aru fiY maraDihi","text_ar":"كَانَ يَتَعَذَّرُ فِى مَرَضِهِ"},{"kind":"italic_en","text":"He used to resist,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"be difficult, in his malady."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"tE*~r AlA^amoru","text_ar":"تعذّر الاَمْرُ"},{"kind":"text","text":"(O, K, TA)"},{"kind":"italic_en","text":"The affair was not direct in its tendency;"},{"kind":"text","text":"(K, TA;) i. e. (TA)"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult:"},{"kind":"text","text":"one says,"},{"kind":"arabic","text_bw":"tE*~r Ealayohi","text_ar":"تعذّر عَلَيْهِ"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult to him."},{"kind":"text","text":"(O, Msb, TA.) [And"},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, impracticable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impossible."},{"kind":"text","text":"]       -A2-"},{"kind":"arabic","text_bw":"tE*~r Alr~asomu","text_ar":"تعذّر الرَّسْمُ"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"rsm","text_ar":"رسم"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"trace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relic, of an abode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of a place of sojourning,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"became effaced;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر","orth_type":"arrow"},{"kind":"text","text":": (S, *, O, * K:) or"},{"kind":"italic_en","text":"became altered and effaced:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlmanaAzilu","text_ar":"المَنَازِلُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AEt*rt","text_ar":"اعتذرت","orth_type":"arrow"},{"kind":"italic_en","text":"the places of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, had their traces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remains, effaced."},{"kind":"text","text":"(TA.)       -A3-  And"},{"kind":"arabic","text_bw":"tE*~r","text_ar":"تعذّر"},{"kind":"text","text":"(from"},{"kind":"arabic","text_bw":"AlEa*irapu","text_ar":"العَذِرَةُ"},{"kind":"text","text":", S, O)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became defiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"besmeared,"},{"kind":"text","text":"(S, O, K)"},{"kind":"italic_en","text":"with"},{"kind":"arabic","text_bw":"Ea*irap","text_ar":"عَذِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"human ordure"},{"kind":"text","text":"]. (K.)"}],"source_refs":["K","O","TA","S"]}]}}