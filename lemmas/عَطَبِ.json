{"lemma":"عَطَبِ","slug":"عَطَبِ","root":"ع.ط.ب","root_slug":"ع-ط-ب","root_link":"/words/roots/ع-ط-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n29514","n29518","n29519","n29520"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B7%D9%8E%D8%A8%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be damaged, to be ruined, to perish"},{"pos":"verb","gloss":"to damage, to ruin, to spoil"},{"pos":"noun","gloss":"verbal noun of عَطِبَ (ʕaṭiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"damage, injury, harm, injustice"},{"pos":"noun","gloss":"cotton","tags":["Classical","collective"]}]},"etymology":null,"ipa":["/ʕa.tˤi.ba/","/ʕatˤ.tˤa.ba/","/ʕa.tˤab/","/ʕutˤb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29514","headword_ar":"عَطِبَ","root":"ETb","body":[{"kind":"text","text":", (S, A, Mgh, O, Msb, K,) aor."},{"kind":"text","text":", (A, Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EaTabN","text_ar":"عَطَبٌ"},{"kind":"text","text":", (S, * Mgh, * O, * Msb,) and"},{"kind":"arabic","text_bw":"maEoTabN","text_ar":"مَعْطَبٌ"},{"kind":"text","text":"also may be an inf. n. of the same, (Har p. 196,)"},{"kind":"italic_en","text":"He perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S, A, Mgh, O, Msb, K:) [Freytag mentions"},{"kind":"arabic","text_bw":"EaTaba","text_ar":"عَطَبَ"},{"kind":"text","text":"also in the same sense, as from the K, in which I do not find it:] it is said of a man, and of other than man: in a trad. it is said of seed-produce. (TA.) ―         -b2-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel, and a horse,)"},{"kind":"italic_en","text":"flagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became powerless:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"stopped with his master"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rider"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from fatigue."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EaTiba Ealayohi","text_ar":"عَطِبَ عَلَيْهِ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, violently,"},{"kind":"text","text":"(O,) or"},{"kind":"italic_en","text":"most violently,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"angry with him."},{"kind":"text","text":"(O, K.)       -A2-"},{"kind":"arabic","text_bw":"AlEaTobu","text_ar":"العَطْبُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"liynu AlquToni","text_ar":"لِينُ القُطْنِ"},{"kind":"text","text":"(O, * K) and"},{"kind":"arabic","text_bw":"AlS~uwfi","text_ar":"الصُّوفِ"},{"kind":"text","text":", (O,) and"},{"kind":"arabic","text_bw":"nuEuwmatuhu","text_ar":"نُعُومَتُهُ"},{"kind":"text","text":": (K:) you say,"},{"kind":"arabic","text_bw":"EaTaba","text_ar":"عَطَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (A, O, K,) inf. n."},{"kind":"arabic","text_bw":"EaTobN","text_ar":"عَطْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuTuwbN","text_ar":"عُطُوبٌ"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[i. e. cotton, and wool,]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, soft."},{"kind":"text","text":"(A, O, * K. [See also"},{"kind":"arabic","text_bw":"EuTobN","text_ar":"عُطْبٌ"},{"kind":"text","text":", below.])"}],"source_refs":["S","A","Mgh","O","Msb","K","TA"]},{"entry_id":"n29518","headword_ar":"عُطْبٌ","root":"ETb","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuTubN","text_ar":"عُطُبٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Cotton:"},{"kind":"text","text":"(IAar, S, O, K:) and ↓"},{"kind":"arabic","text_bw":"EuTobapN","text_ar":"عُطْبَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a portion thereof,"},{"kind":"text","text":"(S, A, O, TA,) or"},{"kind":"italic_en","text":"of wool."},{"kind":"text","text":"(TA.) [SM says,] In the T,"},{"kind":"arabic","text_bw":"AlETb","text_ar":"العطب"},{"kind":"text","text":"is said to mean"},{"kind":"arabic","text_bw":"lyn AlquToni waAlS~uwfi","text_ar":"لين القُطْنِ وَالصُّوفِ"},{"kind":"text","text":", [and so in the O, where it is written"},{"kind":"arabic","text_bw":"AlEaTobu","text_ar":"العَطْبُ"},{"kind":"text","text":", and said to be with fet-h,] and its n. un. is"},{"kind":"arabic","text_bw":"ETbp","text_ar":"عطبة"},{"kind":"text","text":"; but I have found it written with damm [to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"]; therefore by"},{"kind":"arabic","text_bw":"lyn","text_ar":"لين"},{"kind":"text","text":"seems to be meant"},{"kind":"arabic","text_bw":"lay~in","text_ar":"لَيِّن"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Such as is soft"},{"kind":"text","text":"of cotton and of wool: which I think to be evidently a mistake: see 1]. (TA.)"}],"source_refs":["IAar","S","O","K","A","TA"]},{"entry_id":"n29519","headword_ar":"عَطِبٌ","root":"ETb","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Perishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dying"},{"kind":"text","text":"]: see an ex., from a poet, voce"},{"kind":"arabic","text_bw":"rub~a","text_ar":"رُبَّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n29520","headword_ar":"عُطُبٌ","root":"ETb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EuTobN","text_ar":"عُطْبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}