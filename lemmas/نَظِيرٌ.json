{"lemma":"نَظِيرٌ","slug":"نَظِيرٌ","root":"ن.ظ.ر","root_slug":"ن-ظ-ر","root_link":"/words/roots/ن-ظ-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n40052"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B8%D9%90%D9%8A%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"similar, alike"},{"pos":"adj","gloss":"counterpart (a person with similar functions)"},{"pos":"adj","gloss":"isotope","examples":[{"text":"نَظِير مُشِعّ","english":"radioactive isotope"}]},{"pos":"adj","gloss":"corresponding"},{"pos":"adj","gloss":"opposite, in front of, parallel"}]},"etymology":null,"ipa":["/na.ðˤiːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40052","headword_ar":"نَظِيرٌ","root":"nZr","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Looking to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facing,"},{"kind":"text","text":"another person or thing;"},{"kind":"italic_en","text":"opposite"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corresponding to"},{"kind":"text","text":"another person or thing; as also ↓"},{"kind":"arabic","text_bw":"munaAZirN","text_ar":"مُنَاظِرٌ","orth_type":"arrow"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"muqaAbilN","text_ar":"مُقَابِلٌ"},{"kind":"text","text":". (A.) [Hence,"},{"kind":"arabic","text_bw":"naZiyru Als~amoti","text_ar":"نَظِيرُ السَّمْتِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Aln~aZiyru","text_ar":"النَّظِيرُ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The nadir; the point opposite to the zenith."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"naZiyruka","text_ar":"نَظِيرُكَ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"A^al~a*iY yunaAZiruka","text_ar":"اَلَّذِى يُنَاظِرُكَ"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"Al*Y tunaAZiruhu","text_ar":"الذى تُنَاظِرُهُ"},{"kind":"arabic","text_bw":"wayunaAZiruka","text_ar":"وَيُنَاظِرُكَ"},{"kind":"text","text":", (T,) [which I suppose to mean (tropical:)"},{"kind":"italic_en","text":"He who looks towards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faces, thee; who is opposite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corresponds, to thee;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he towards whom thou lookest,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"and who looks towards thee,"},{"kind":"text","text":"&c.: though susceptible of other interpretations: see 3.] ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"Like; a like; a similar person or thing:"},{"kind":"text","text":"(AO, T, S, M, A, K;)"},{"kind":"italic_en","text":"equal; an equal:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"applied to anything:"},{"kind":"text","text":"(TA:) as also ↓"},{"kind":"arabic","text_bw":"niZorN","text_ar":"نِظْرٌ","orth_type":"arrow"},{"kind":"text","text":"; (AO, S, K;) like"},{"kind":"arabic","text_bw":"nadiydN","text_ar":"نَدِيدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nid~N","text_ar":"نِدٌّ"},{"kind":"text","text":"; (AO, S;) and ↓"},{"kind":"arabic","text_bw":"munaAZirN","text_ar":"مُنَاظِرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) fem."},{"kind":"arabic","text_bw":"naZiyrapN","text_ar":"نَظِيرَةٌ"},{"kind":"text","text":": (T, M, A:) pl. masc.,"},{"kind":"arabic","text_bw":"nuZaraA='u","text_ar":"نُظَرَا=ءُ"},{"kind":"text","text":": (M, A, Msb, K:) and pl. fem."},{"kind":"arabic","text_bw":"naZaAy^iru","text_ar":"نَظَايِرُ"},{"kind":"text","text":", (T, A,) applied to words and to all things. (T.) You say,"},{"kind":"arabic","text_bw":"fulaAnN naZiyruka","text_ar":"فُلَانٌ نَظِيرُكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one is thy like."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"h`*aA naZiyrN","text_ar":"هٰذَا نَظِيرٌ"},{"kind":"arabic","text_bw":"lih`*aA","text_ar":"لِهٰذَا"},{"kind":"text","text":", (T,) or"},{"kind":"arabic","text_bw":"naZiyru h`*aA","text_ar":"نَظِيرُ هٰذَا"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"This is the like of this,"},{"kind":"text","text":"(T,) or"},{"kind":"italic_en","text":"the equal of this."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Eadadotu A_ibila fulaAnK naZaAy^ira","text_ar":"عَدَدْتُ اـِبِلَ فُلَانٍ نَظَايِرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I counted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"numbered, the camels of such a one in pairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two by two;"},{"kind":"text","text":"(As, T, K; *) if by looking at their aggregate, you say,"},{"kind":"arabic","text_bw":"EadadotuhaA jamaArFA","text_ar":"عَدَدْتُهَا جَمَارًا"},{"kind":"text","text":". (As, T.)"}],"source_refs":["M","T","Msb","TA","K","A"]}]},"classical_definitions":null}