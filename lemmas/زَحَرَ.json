ount":1},"lanes":{"found":true,"entry_ids":["n17518"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%AD%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to groan"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17518","headword_ar":"زَحَرَ","root":"zHr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaHiyrN","text_ar":"زَحِيرٌ"},{"kind":"text","text":"(A, K) and"},{"kind":"arabic","text_bw":"zuHaArN","text_ar":"زُحَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zuHaArapN","text_ar":"زُحَارَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He emitted the voice,"},{"kind":"text","text":"(K, * TA,) or (K, TA, in the CK “ and, ”)"},{"kind":"italic_en","text":"the breath, with a moaning;"},{"kind":"text","text":"(A, K;) [or"},{"kind":"italic_en","text":"he breathed hard;"},{"kind":"text","text":"as appears from what follows;] in work, or labour, or in difficulty. (TA.) You say,"},{"kind":"arabic","text_bw":"samiEotu","text_ar":"سَمِعْتُ"},{"kind":"arabic","text_bw":"lahu zaHiyrFA","text_ar":"لَهُ زَحِيرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I heard him breathe hard;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emit the voice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the breath, with a moaning"},{"kind":"text","text":"]. (A.) And of a woman bringing forth, you say,"},{"kind":"arabic","text_bw":"zaHarato","text_ar":"زَحَرَتْ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"zaHiyrN","text_ar":"زَحِيرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"She breathed hard."},{"kind":"text","text":"(S.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"zaHara","text_ar":"زَحَرَ"},{"kind":"text","text":"said of a niggardly man, (assumed tropical:)"},{"kind":"italic_en","text":"He, being begged of, deemed the begging grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and moaned thereat."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"zaHara","text_ar":"زَحَرَ"},{"kind":"text","text":", (A, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"zaHiyrN","text_ar":"زَحِيرٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"zuHaArN","text_ar":"زُحَارٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"zuHaArapN","text_ar":"زُحَارَةٌ"},{"kind":"text","text":"; (K;) [and app."},{"kind":"arabic","text_bw":"zuHira","text_ar":"زُحِرَ"},{"kind":"text","text":"also; (see"},{"kind":"arabic","text_bw":"mazoHuwrN","text_ar":"مَزْحُورٌ"},{"kind":"text","text":";)] and ↓"},{"kind":"arabic","text_bw":"tzH~r","text_ar":"تزحّر","orth_type":"arrow"},{"kind":"text","text":"; (A, K;) and ↓"},{"kind":"arabic","text_bw":"zH~r","text_ar":"زحّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tazoHiyrN","text_ar":"تَزْحِيرٌ"},{"kind":"text","text":"; (K;) [all signify]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with a looseness of the bowels:"},{"kind":"text","text":"(S, A:) or"},{"kind":"italic_en","text":"with a violent looseness of the bowels, and with a griping pain in the belly, and a discharge of blood."},{"kind":"text","text":"(K.) ―         -b4-  And"},{"kind":"arabic","text_bw":"zaHarato bihi A^um~uhu","text_ar":"زَحَرَتْ بِهِ اُمُّهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tzH~zt","text_ar":"تزحّزت","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"His mother brought him forth."},{"kind":"text","text":"(A, K.)       -A2-"},{"kind":"arabic","text_bw":"zaHarahu biAlr~umoHi","text_ar":"زَحَرَهُ بِالرُّمْحِ"},{"kind":"text","text":", accord. to the K, signifies"},{"kind":"italic_en","text":"He broke,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clave, his head with the spear:"},{"kind":"text","text":"but IDrd says that this is not of established authority. (TA.)       -A3-"},{"kind":"arabic","text_bw":"zuHira","text_ar":"زُحِرَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tenacious."},{"kind":"text","text":"(K.)"}],"source_refs":["K","A","TA","S"]}]}}