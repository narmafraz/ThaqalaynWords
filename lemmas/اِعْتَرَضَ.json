{"lemma":"اِعْتَرَضَ","slug":"اِعْتَرَضَ","root":"ع.ر.ض","root_slug":"ع-ر-ض","root_link":"/words/roots/ع-ر-ض","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"اِعْتَرَضْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"اِعْتَرَضْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"اِعْتَرَضْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"اِعْتَرَضْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"اِعْتَرَضْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"اِعْتَرَضَ","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"اِعْتَرَضَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"اِعْتَرَضا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"اِعْتَرَضَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"اِعْتَرَضُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"اِعْتَرَضْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْتَرِض","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْتَرِضِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْتَرِضِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْتَرِضا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْتَرِضانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْتَرِضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْتَرِضُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْتَرِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْتَرِض","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْتَرِض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْتَرِضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْتَرِضانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْتَرِضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْتَرِضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْتَرِضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْتَرِضُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْتَرِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"اِعْتَرَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِعْتَرَضْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْتَرِض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْتَرِض","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":35,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["n28686"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B9%D9%92%D8%AA%D9%8E%D8%B1%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to block, to obstruct, to get in the way of","tags":["transitive"],"examples":[{"text":"اِعْتَرَضَ شَيْءٌ مَجْرَى الْمَاءِ"}]},{"pos":"verb","gloss":"to obstruct, to hinder, to impede","tags":["transitive"]},{"pos":"verb","gloss":"to happen to, to befall (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to resist, to oppose","tags":["intransitive"]},{"pos":"verb","gloss":"to protest","tags":["intransitive"]},{"pos":"verb","gloss":"to object to, to veto","tags":["intransitive"]},{"pos":"verb","gloss":"to present oneself to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to insert parenthetically (a clause, etc.)","tags":["transitive"]},{"pos":"verb","gloss":"to fade in (a move sequence, etc.)","tags":["transitive"]},{"pos":"verb","gloss":"to interrupt (a conversation)","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28686","headword_ar":"اعترض","root":"ErD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":", near the beginning, where these two verbs and"},{"kind":"arabic","text_bw":"AErD","text_ar":"اعرض"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tEr~D","text_ar":"تعرّض"},{"kind":"text","text":", are said to be used as syn., app. in the senses expl. there and in the beginning of 5. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AEtrD Ealayohi","text_ar":"اعترض عَلَيْهِ"},{"kind":"italic_en","text":"He opposed, resisted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withstood, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"text","text":". (MA.) [See 1 in art."},{"kind":"arabic","text_bw":"$nf","text_ar":"شنف"},{"kind":"text","text":", in two places.] ―         -b3-  See also 5, second sentence. ―         -b4-  And see from"},{"kind":"arabic","text_bw":"EaraDa lahu","text_ar":"عَرَضَ لَهُ"},{"kind":"text","text":"as signifying “ it happened to him ” as far as the end of the sentence explaining"},{"kind":"arabic","text_bw":"AEtrD Al$~aYo'u duwna Al$~aYo'i","text_ar":"اعترض الشَّىْءُ دُونَ الشَّىْءِ"},{"kind":"text","text":"."},{"kind":"arabic","text_bw":"AEtrD","text_ar":"اعترض"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"It lay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extended, breadthwise, across, transversely, athwart, sideways, obliquely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"horizontally:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"so as to present an obstacle:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"so intervened in any manner;"},{"kind":"text","text":"as shown in the part last referred to, above: or rather it has both of these meanings; and in the former sense it is used, in the TA, art."},{"kind":"arabic","text_bw":"Hr","text_ar":"حر"},{"kind":"text","text":", in describing the direction of an asterism, opposed to"},{"kind":"arabic","text_bw":"AinotaSaba","text_ar":"اِنْتَصَبَ"},{"kind":"text","text":": or, in other words,]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, S)"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"became an obstacle,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"SaAra EaAriDFA","text_ar":"صَارَ عَارِضًا"},{"kind":"text","text":", S, O,)"},{"kind":"italic_en","text":"like a piece of wood lying across,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"athwart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obliquely,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muEotariDapF","text_ar":"مُعْتَرِضَةً"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in a channel of running water,"},{"kind":"text","text":"(S, O, K,) or"},{"kind":"italic_en","text":"a road,"},{"kind":"text","text":"(O, L,) and"},{"kind":"italic_en","text":"the like, preventing persons from passing along it."},{"kind":"text","text":"(L.) It is also said [of a collection of clouds appearing, or presenting itself, or extending sideways, or stretching along in the horizon like a mountain; see"},{"kind":"arabic","text_bw":"EaAriDN","text_ar":"عَارِضٌ"},{"kind":"text","text":": and] of a building, or other thing, such as a trunk of a palm-tree, or a mountain, lying in a road: and as this prevents the passengers from passing along the road, it is used as signifying"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered:"},{"kind":"text","text":"(O, K:) it is quasi-pass. of"},{"kind":"arabic","text_bw":"EaraDahu","text_ar":"عَرَضَهُ"},{"kind":"text","text":". (K, * TA.) [And hence,]"},{"kind":"arabic","text_bw":"AuEoturiDa Eani A@moraA^atihi","text_ar":"اُعْتُرِضَ عَنِ ا@مْرَاَتِهِ"},{"kind":"text","text":", (O, TA,) not"},{"kind":"arabic","text_bw":"AiEotaraDa","text_ar":"اِعْتَرَضَ"},{"kind":"text","text":", as the K seems to indicate, (TA,)"},{"kind":"italic_en","text":"He was prevented from going in to his wife, by an obstacle that befell him, arising from the jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"genii,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from disease:"},{"kind":"text","text":"(O, K, TA:) occurring in a trad. (TA.) ―         -b5-  [Hence,]"},{"kind":"arabic","text_bw":"AiEotiraADN","text_ar":"اِعْتِرَاضٌ"},{"kind":"text","text":"which is forbidden in a trad. [respecting horseracing] signifies A man's"},{"kind":"italic_en","text":"coming intermediately with his horse, in a part of the course, and so entering among the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"other"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"horses."},{"kind":"text","text":"(O, L, K.) [See also"},{"kind":"arabic","text_bw":"EaAraDa AljinaAzapa","text_ar":"عَارَضَ الجِنَازَةَ"},{"kind":"text","text":".] ―         -b6-  [And hence,]"},{"kind":"arabic","text_bw":"AEtrD","text_ar":"اعترض"},{"kind":"arabic","text_bw":"Al$~ahora","text_ar":"الشَّهْرَ"},{"kind":"italic_en","text":"He commenced"},{"kind":"text","text":"[the observances of]"},{"kind":"italic_en","text":"the month not from the beginning thereof."},{"kind":"text","text":"(S, O, K.) ―         -b7-  ["},{"kind":"arabic","text_bw":"AEtrDt Aljumolapu","text_ar":"اعترضت الجُمْلَةُ"},{"kind":"italic_en","text":"The clause intervened parenthetically."},{"kind":"text","text":"―         -b8-"},{"kind":"arabic","text_bw":"AEtrD Ealayohi","text_ar":"اعترض عَلَيْهِ"},{"kind":"italic_en","text":"He interposed"},{"kind":"text","text":"in an argument, or the like,"},{"kind":"italic_en","text":"objecting against him"},{"kind":"text","text":"something, by way of confutation]. And"},{"kind":"arabic","text_bw":"AEtrD EalaY","text_ar":"اعترض عَلَى"},{"kind":"arabic","text_bw":"A^aHadK mino qawolK A^awofiEolK","text_ar":"اَحَدٍ مِنْ قَوْلٍ اَوْفِعْلٍ"},{"kind":"italic_en","text":"He attributed to any one an error in respect of a saying or an action."},{"kind":"text","text":"(Har p. 687.) ―         -b9-"},{"kind":"arabic","text_bw":"AEtrD Alfarasu fiY rasanihi","text_ar":"اعترض الفَرَسُ فِى رَسَنِهِ"},{"kind":"italic_en","text":"The horse was perverse, untoward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intractable,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his halter,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to his leader;"},{"kind":"text","text":"(S, A, O, K;) as also ↓"},{"kind":"arabic","text_bw":"tEr~D","text_ar":"تعرّض","orth_type":"arrow"},{"kind":"text","text":". (TA. [See"},{"kind":"arabic","text_bw":"muEotariDN","text_ar":"مُعْتَرِضٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"AiEotariADN","text_ar":"اِعْتَرِاضٌ"},{"kind":"text","text":"in a man is The"},{"kind":"italic_en","text":"appearing and engaging in what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false, and refusing to obey the truth."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"arabic","text_bw":"AEtrDhu","text_ar":"اعترضهُ"},{"kind":"italic_en","text":"He faced him, and advanced towards him:"},{"kind":"text","text":"(Har p. 420) and"},{"kind":"arabic","text_bw":"AEtrD EaroDahu","text_ar":"اعترض عَرْضَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuroDahu","text_ar":"عُرْضَهُ"},{"kind":"text","text":"[has nearly, if not exactly, the same signification]: see"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"AEtrAD","text_ar":"اعتراض"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"coming in upon any one:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entering upon an affair."},{"kind":"text","text":"(Har p. 687.) ―         -b11-  ["},{"kind":"arabic","text_bw":"AEtrD lahu","text_ar":"اعترض لَهُ"},{"kind":"text","text":"often means"},{"kind":"italic_en","text":"He presented himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came forward, to him:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he addressed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forward, to it;"},{"kind":"text","text":"namely, an action; like"},{"kind":"arabic","text_bw":"tEr~D","text_ar":"تعرّض"},{"kind":"arabic","text_bw":"lh","text_ar":"له"},{"kind":"text","text":": see its syns."},{"kind":"arabic","text_bw":"AinobaraY","text_ar":"اِنْبَرَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tabar~aY","text_ar":"تَبَرَّى"},{"kind":"text","text":".] ―         -b12-  See also 5, second sentence. ―         -b13-"},{"kind":"arabic","text_bw":"AEtrD lahu bisahomK","text_ar":"اعترض لَهُ بِسَهْمٍ"},{"kind":"italic_en","text":"He advanced towards him with an arrow, and shot at him, and slew him."},{"kind":"text","text":"(S, O, K.) ―         -b14-"},{"kind":"arabic","text_bw":"AEtrD lilomaEoruwfi","text_ar":"اعترض لِلْمَعْرُوفِ"},{"kind":"text","text":": see 5. ―         -b15-"},{"kind":"arabic","text_bw":"yaEotariDu fiY sayorihi","text_ar":"يَعْتَرِضُ فِى سَيْرِهِ"},{"kind":"text","text":": see 5, near the end.       -A2-"},{"kind":"arabic","text_bw":"AEtrD","text_ar":"اعترض"},{"kind":"italic_en","text":"He rode while reviewing the army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of soldiers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making them to pass by him and examining their state,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"arabic","text_bw":"EalaY Ald~aAb~api","text_ar":"عَلَى الدَّابَّةِ"},{"kind":"italic_en","text":"upon the beast."},{"kind":"text","text":"(S, O.) ―         -b2-"},{"kind":"arabic","text_bw":"AEtrD Aljunodu","text_ar":"اعترض الجُنْدُ"},{"kind":"italic_en","text":"The army,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of soldiers, was reviewed:"},{"kind":"text","text":"(Mgh, L:) quasi-pass. of"},{"kind":"arabic","text_bw":"EaraDa Aljunoda","text_ar":"عَرَضَ الجُنْدَ"},{"kind":"text","text":"[which signifies the same as the phrase next following]. (O, L, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AEtrD Aljunoda","text_ar":"اعترض الجُنْدَ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"AlmataAEa wanaHowahu","text_ar":"المَتَاعَ وَنَحْوَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AEtrDhu EalaY Eayonihi","text_ar":"اعترضهُ عَلَى عَيْنِهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":", last quarter.       -A3-"},{"kind":"arabic","text_bw":"AiEtrD EiroDahu","text_ar":"اِعترض عِرْضَهُ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"AEtrD fulaAnFA","text_ar":"اعترض فُلَانًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":", last quarter.       -A4-"},{"kind":"arabic","text_bw":"AEtrD AlbaEiyra","text_ar":"اعترض البَعِيرَ"},{"kind":"italic_en","text":"He rode the camel while refractory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"untractable,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"as yet."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"AEtrD AlEaruwDa","text_ar":"اعترض العَرُوضَ"},{"kind":"italic_en","text":"He took the untrained she-camel in her untrained state."},{"kind":"text","text":"(TA. [In the original of this explanation is a mistranscription, which I have rectified in the translation;"},{"kind":"arabic","text_bw":"Ax*EA","text_ar":"اخذعا"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"A^axa*ahaA","text_ar":"اَخَذَهَا"},{"kind":"text","text":".]) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"AEtrD fulaAnN Al$~aYo'a","text_ar":"اعترض فُلَانٌ الشَّىْءَ"},{"kind":"italic_en","text":"Such a one undertook the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself to do it, it being difficult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconvenient."},{"kind":"text","text":"(IAth.)       -A5-"},{"kind":"arabic","text_bw":"AEtrD Al$~awoka","text_ar":"اعترض الشَّوْكَ"},{"kind":"text","text":"(K, TA.)"},{"kind":"italic_en","text":"He ate the thorns:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Al$~awoka","text_ar":"الشَّوْكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he took and ate of the thorns:"},{"kind":"text","text":"both said of a sheep or goat, or rather of a camel: (TA:) and [in like manner] one says of a camel,"},{"kind":"arabic","text_bw":"Al$~ajara *aA Al$~awoki bifiyhi","text_ar":"الشَّجَرَ ذَا الشَّوْكِ بِفِيهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaAraDa","text_ar":"عَارَضَ","orth_type":"arrow"},{"kind":"text","text":": and the camel that does so is said to be"},{"kind":"arabic","text_bw":"*uw EiraADK","text_ar":"ذُو عِرَاضٍ"},{"kind":"text","text":". (S, O, K.)       -A6-  See also 10, in five places.       -A7-"},{"kind":"arabic","text_bw":"AEtrD minohu","text_ar":"اعترض مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He accepted an equivalent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a substitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compensation, for it"},{"kind":"text","text":"]. You say,"},{"kind":"arabic","text_bw":"kaAna EalaY fulaAnK naqodN faA^aEosarotuhu","text_ar":"كَانَ عَلَى فُلَانٍ نَقْدٌ فَاَعْسَرْتُهُ"},{"kind":"arabic","text_bw":"faA@EotaraDotu minohu","text_ar":"فَا@عْتَرَضْتُ مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one owed a debt of money, and I demanded it of him when it was difficult for him to pay it, and I accepted an equivalent,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for it"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"AEtrDwA minohu","text_ar":"اعترضوا مِنْهُ"},{"kind":"text","text":", referring to blood, when retaliation has been refused, means"},{"kind":"italic_en","text":"they accepted"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"qabiluwA","text_ar":"قَبِلُوا"},{"kind":"text","text":", for which"},{"kind":"arabic","text_bw":"AqblwA","text_ar":"اقبلوا"},{"kind":"text","text":"has been substituted by the copyists in the L and TA,]"},{"kind":"italic_en","text":"the bloodwit"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as a compensation for it"},{"kind":"text","text":"]. (L.)"}],"source_refs":["K","S","O","L","TA","Mgh"]}]},"classical_definitions":null}