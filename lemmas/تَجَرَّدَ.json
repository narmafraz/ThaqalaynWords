true,"entry_ids":["n5466"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AC%D9%8E%D8%B1%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be stripped, to be bared, to be divested","tags":["reflexive"]},{"pos":"verb","gloss":"to become abstract, to become absolute"},{"pos":"verb","gloss":"to run out of, to get cleaned out of"},{"pos":"noun","gloss":"verbal noun of تَجَرَّدَ (tajarrada) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ta.d͡ʒar.ra.da/","/ta.d͡ʒar.rud/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5466","headword_ar":"تجرّد","root":"jrd","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stripped, divested, bared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denuded,"},{"kind":"text","text":"(S, A, L, Msb, K,) [and"},{"kind":"italic_en","text":"he stripped, divested, bared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denuded, himself,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"mino viyaAbihi","text_ar":"مِنْ ثِيَابِهِ"},{"kind":"italic_en","text":"of his clothes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"garments,"},{"kind":"text","text":"(A, * Msb,) or"},{"kind":"arabic","text_bw":"mn vawobihi","text_ar":"من ثَوْبِهِ"},{"kind":"italic_en","text":"of his garment;"},{"kind":"text","text":"(L, K; *) as also ↓"},{"kind":"arabic","text_bw":"Anjrd","text_ar":"انجرد","orth_type":"arrow"},{"kind":"text","text":", (A, L, K,) which latter, accord. to Sb, is not a quasi-pass. verb, (L,) [but it seems that he did not know"},{"kind":"arabic","text_bw":"jarada","text_ar":"جَرَدَ"},{"kind":"text","text":", in a sense explained above, (see 2, second sentence,) of which it is the quasipass, like as"},{"kind":"arabic","text_bw":"tjr~d","text_ar":"تجرّد"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"jr~d","text_ar":"جرّد"},{"kind":"text","text":".] ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an ear of corn, A, K, and a flower, TA)"},{"kind":"italic_en","text":"came forth from its envelope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calyx."},{"kind":"text","text":"(A, K, TA.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(expressed juice)"},{"kind":"italic_en","text":"ceased to boil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estuate,"},{"kind":"text","text":"(K,) ["},{"kind":"italic_en","text":"and so became divested of its froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam."},{"kind":"text","text":"] ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone, by himself, apart from others;"},{"kind":"text","text":"as though detached from the rest of men. (Har p. 430.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"outstripped the other horses in a race;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Anjrd","text_ar":"انجرد","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Anjrd Eani Alxayoli","text_ar":"انجرد عَنِ الخَيْلِ"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"naDaA Alxayola","text_ar":"نَضَا الخَيْلَ"},{"kind":"text","text":"; as though he threw off the others from himself as a man throws off his garment. (TA.) And (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an ass)"},{"kind":"italic_en","text":"went forward from among the she-asses."},{"kind":"text","text":"(L.) ―         -b6-"},{"kind":"arabic","text_bw":"tjr~d liloA^amori","text_ar":"تجرّد لِلْاَمْرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He devoted himself to the affair,"},{"kind":"text","text":"as though throwing aside all other things;"},{"kind":"italic_en","text":"he applied himself exclusively and diligently to it;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he strove"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laboured, exerted himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, employed himself vigorously"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diligently"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with energy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took pains"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinary pains, in the affair,"},{"kind":"text","text":"(S, A, K, and Har p. 430,)"},{"kind":"italic_en","text":"not diverted therefrom by any other thing."},{"kind":"text","text":"(Har ib.) And"},{"kind":"arabic","text_bw":"tjr~d liloEibaAdapi","text_ar":"تجرّد لِلْعِبَادَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He devoted himself TO, applied himself exclusively and diligently to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strove"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"in, religious service,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worship"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"liloqiyaAmi bika*aA","text_ar":"لِلْقِيَامِ بِكَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jur~ida","text_ar":"جُرِّدَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He devoted himself to, applied himself exclusively and diligently to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strove"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"in, the performance of such a thing"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"tjr~d fiY Als~ayori","text_ar":"تجرّد فِى السَّيْرِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Anjrd","text_ar":"انجرد","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He strove"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"laboured, exerted himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efforts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavours"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, in pace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going; he hastened therein;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"$am~ara fiY sayorihi","text_ar":"شَمَّرَ فِى سَيْرِهِ"},{"kind":"text","text":". (L, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"tjr~d biAlHaj~i","text_ar":"تجرّد بِالحَجِّ"},{"kind":"text","text":": see 2. Accord. to Ahmad, as related by Is-hák Ibn-Mansoor, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He affected to be like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he imitated, the pilgrim of Mekkeh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the man performing the pilgrimage of Mekkeh."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","A","L","Msb","K","TA"]}]},"classical_definitions":null}