{"lemma":"صُوَّمٌ","slug":"صُوَّمٌ","root":"ص.#.م","root_slug":"ص-_-م","root_link":"/words/roots/ص-_-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"صائِم","root":"صوم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n25260"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8F%D9%88%D9%8E%D9%91%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of صَامَ (ṣāma)","tags":["active","form-of","participle"]},{"pos":"noun","gloss":"jejunum"},{"pos":"adj","gloss":"active participle of صَئِمَ (ṣaʔima)","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"active participle of صأم","tags":["active","form-of","participle"]},{"pos":"adj","gloss":"thirsty"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25260","headword_ar":"صَوْمٌ","root":"Swm","body":[{"kind":"text","text":"an inf. n. of 1 [q. v.]. (S, M, &c.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AlS~awomu","text_ar":"الصَّوْمُ"},{"kind":"text","text":"[app. for"},{"kind":"arabic","text_bw":"waqotu AlS~awomi","text_ar":"وَقْتُ الصَّوْمِ"},{"kind":"text","text":"] means also (tropical:)  ["},{"kind":"italic_en","text":"The month of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Ramadán:"},{"kind":"text","text":"(K, TA:) whence the saying of Aboo-Zeyd,"},{"kind":"arabic","text_bw":"A^aqamotu biAlbaSorapi Sawomayoni","text_ar":"اَقَمْتُ بِالبَصْرَةِ صَوْمَيْنِ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in El-Basrah"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"two Ramadáns."},{"kind":"text","text":"(TA.) ―         -b3-  And [in like manner]"},{"kind":"arabic","text_bw":"SawomN","text_ar":"صَوْمٌ"},{"kind":"text","text":"also means (assumed tropical:)"},{"kind":"italic_en","text":"A Christian church;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"biyEapN","text_ar":"بِيعَةٌ"},{"kind":"text","text":": (S, K, TA:) as though for"},{"kind":"arabic","text_bw":"maHal~u AlS~awomi","text_ar":"مَحَلُّ الصَّوْمِ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"Alwaqofi","text_ar":"الوَقْفِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the place of station:"},{"kind":"text","text":"for, as Hooker says, speaking of the ancient usage of the Church, “ their manner was to stand at prayer, whereupon their meetings unto that purpose had the names of stations given them ”]. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"SaAy^imN","text_ar":"صَايِمٌ"},{"kind":"text","text":".       -A3-  Also (assumed tropical:)  The"},{"kind":"italic_en","text":"dung of the ostrich."},{"kind":"text","text":"(S, M, K.)       -A4-  And, in the dial. of Hudheyl, (S,)"},{"kind":"italic_en","text":"Certain trees,"},{"kind":"text","text":"(S, M,) or"},{"kind":"italic_en","text":"a certain tree,"},{"kind":"text","text":"(K,) [but] the n. un. is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":","},{"kind":"italic_en","text":"of the form of the figure of a human being,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"ugly in appearance,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"very much so, the fruits of which are called"},{"kind":"arabic","text_bw":"ruw^uwsu Al$~ayaATiyni","text_ar":"رُوُوسُ الشَّيَاطِينِ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"the heads"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the serpents,"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"$ayoTaAnN","text_ar":"شَيْطَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zaq~uwmN","text_ar":"زَقُّومٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"not having leaves:"},{"kind":"text","text":"AHn says that"},{"kind":"italic_en","text":"they have"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hadab","text_ar":"هَدَب"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"their branches do not spread forth, they grow in the manner of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"species of tamarisk called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^avol","text_ar":"اَثْل"},{"kind":"text","text":","},{"kind":"italic_en","text":"but are not so tall, and mostly grow in the districts of Benoo-Shebábeh."},{"kind":"text","text":"(M.)"}],"source_refs":["K","TA","S","M"]}]},"classical_definitions":null}