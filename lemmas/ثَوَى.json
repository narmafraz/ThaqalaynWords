ext":"; (T, M;) and ↓"},{"kind":"arabic","text_bw":"AvwY","text_ar":"اثوى","orth_type":"arrow"},{"kind":"text","text":"(T, S, M, Msb, K)"},{"kind":"arabic","text_bw":"bAlmkAn","text_ar":"بالمكان"},{"kind":"text","text":", (S, M, K,) or"},{"kind":"arabic","text_bw":"fyh","text_ar":"فيه"},{"kind":"text","text":"; (so in the CK;)"},{"kind":"italic_en","text":"He remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"(T, S, Mgh, Msb,)"},{"kind":"italic_en","text":"in the place:"},{"kind":"text","text":"(S, Mgh, Msb:) or"},{"kind":"italic_en","text":"he remained, stayed, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, long"},{"kind":"text","text":"(Lth, T, M, K)"},{"kind":"italic_en","text":"therein:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alighted and abode, in the place:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"he alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alighted and abode,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"he settled,"},{"kind":"text","text":"(TA,)"},{"kind":"arabic","text_bw":"bAlmkAn","text_ar":"بالمكان"},{"kind":"italic_en","text":"in the place."},{"kind":"text","text":"(M.) Hence,"},{"kind":"arabic","text_bw":"A_in~aA nuTiylu Alv~uwiY~a","text_ar":"اـِنَّا نُطِيلُ الثُّوِىَّ"},{"kind":"arabic","text_bw":"fiY d~Ari AlHarobi","text_ar":"فِى دّارِ الحَرْبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily we prolong the stay in the seat of war"},{"kind":"text","text":"]. (Mgh.) [You say also,"},{"kind":"arabic","text_bw":"vaway A_ilaY","text_ar":"ثَوَي اـِلَى"},{"kind":"arabic","text_bw":"AlmaroA^api","text_ar":"المَرْاَةِ"},{"kind":"italic_en","text":"He betook himself to the woman to remain, stay, dwell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abide, with her:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"vawiy~apN","text_ar":"ثَوِيَّةٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"vawaY","text_ar":"ثَوَى"},{"kind":"text","text":", (T, M, IB, TA,) aor."},{"kind":"text","text":"; in the K, incorrectly, ↓"},{"kind":"arabic","text_bw":"vw~Y","text_ar":"ثوّى","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tavowiyapN","text_ar":"تَثْوِيَةٌ"},{"kind":"text","text":"; (TA;) signifies also"},{"kind":"italic_en","text":"He was slain,"},{"kind":"text","text":"(T, M,)"},{"kind":"italic_en","text":"and remained where he was:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"he remained in his grave:"},{"kind":"text","text":"(IB, TA:) or, as the latter verb is explained in the K,"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(TA.) [See a verse cited in art."},{"kind":"arabic","text_bw":"Hsb","text_ar":"حسب"},{"kind":"text","text":", conj. 2.]       -A2-"},{"kind":"arabic","text_bw":"vuwiYa","text_ar":"ثُوِىَ"},{"kind":"italic_en","text":"He was buried:"},{"kind":"text","text":"(M, K:) because there is no longer dwelling than that of him who is buried. (M.)"}],"source_refs":["T","S","M","Mgh","Msb","K","Lth","TA","IB"]}]},"classical_definitions":null}