{"lemma":"دُودٌ","slug":"دُودٌ","root":"د.#.د","root_slug":"د-_-د","root_link":"/words/roots/د-_-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n13373"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8F%D9%88%D8%AF%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"worms","tags":["collective"]},{"pos":"noun","gloss":"maggots","tags":["collective"]},{"pos":"noun","gloss":"larvae","tags":["collective"]},{"pos":"noun","gloss":"caterpillars","tags":["collective"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13373","headword_ar":"دُودٌ","root":"dwd","body":[{"kind":"text","text":"a word of well-known signification, ["},{"kind":"italic_en","text":"Worms, grubs, maggots,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"including"},{"kind":"italic_en","text":"molluscs;"},{"kind":"text","text":"as a coll. gen. n.: and, as a simple gen. n., the"},{"kind":"italic_en","text":"worm, grub, maggot,"},{"kind":"text","text":"&c.:] pl. of"},{"kind":"arabic","text_bw":"duwdapN","text_ar":"دُودَةٌ"},{"kind":"text","text":"[or rather, as already said, and as is implied in several of the lexicons,"},{"kind":"arabic","text_bw":"duwdN","text_ar":"دُودٌ"},{"kind":"text","text":"is a coll. gen. n.; therefore"},{"kind":"arabic","text_bw":"duwdapN","text_ar":"دُودَةٌ"},{"kind":"text","text":"is the n. un. thereof]: and the pl. of"},{"kind":"arabic","text_bw":"duwdN","text_ar":"دُودٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"diydaAnN","text_ar":"دِيدَانٌ"},{"kind":"text","text":". (T, S, L, Msb. [In the K,"},{"kind":"arabic","text_bw":"diydaAnN","text_ar":"دِيدَانٌ"},{"kind":"text","text":"is said to be pl. of"},{"kind":"arabic","text_bw":"duwdapN","text_ar":"دُودَةٌ"},{"kind":"text","text":": and in the L, as from the T,"},{"kind":"arabic","text_bw":"duwdaAnN","text_ar":"دُودَانٌ"},{"kind":"text","text":"is said to be another pl. of"},{"kind":"arabic","text_bw":"duwdN","text_ar":"دُودٌ"},{"kind":"text","text":": this, however, I regard as a mistake; for I do not find it in the T; but I there find added, after"},{"kind":"arabic","text_bw":"diydaAnN","text_ar":"دِيدَانٌ"},{"kind":"text","text":", “ and"},{"kind":"arabic","text_bw":"duwdaAnN","text_ar":"دُودَانٌ"},{"kind":"text","text":"is a tribe of Benoo-Asad. ”]) J says that the dim. is ↓"},{"kind":"arabic","text_bw":"duwayodN","text_ar":"دُوَيْدٌ","orth_type":"arrow"},{"kind":"text","text":", and that by rule it should be"},{"kind":"arabic","text_bw":"duwayodapN","text_ar":"دُوَيْدَةٌ"},{"kind":"text","text":": but this is a mistake [unless it be meant that"},{"kind":"arabic","text_bw":"duwayodapN","text_ar":"دُوَيْدَةٌ"},{"kind":"text","text":"is the regular dim. of"},{"kind":"arabic","text_bw":"duwdapN","text_ar":"دُودَةٌ"},{"kind":"text","text":"]: it is regularly"},{"kind":"arabic","text_bw":"duwayodN","text_ar":"دُوَيْدٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"tumayorN","text_ar":"تُمَيْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quyayoHN","text_ar":"قُيَيْحٌ"},{"kind":"text","text":"are"},{"kind":"page_break","n":930},{"kind":"text","text":"regular dims. of"},{"kind":"arabic","text_bw":"tamorN","text_ar":"تَمْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qamoHN","text_ar":"قَمْحٌ"},{"kind":"text","text":", which are pls. [or rather coll. gen. ns.] of"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qamoHapN","text_ar":"قَمْحَةٌ"},{"kind":"text","text":". (IB.)"}],"source_refs":[]}]},"classical_definitions":null}