{"lemma":"خَصَفَ","slug":"خَصَفَ","root":"خ.ص.ف","root_slug":"خ-ص-ف","root_link":"/words/roots/خ-ص-ف","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَصَفْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَصَفْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَصَفْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَصَفْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَصَفْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَصَفَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَصَفَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَصَفا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَصَفَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَصَفُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَصَفْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْصِف","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْصِفِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْصِفِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْصِفا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْصِفانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْصِفُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْصِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْصِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْصِف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْصِف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْصِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْصِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْصِفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْصِفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْصِفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْصِفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْصِفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَصَفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَصَفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْصِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْصِف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n10781","n10783","","n10784"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B5%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fasten"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10781","headword_ar":"خَصْفٌ","root":"xSf","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"xaSafa","text_ar":"خَصَفَ"},{"kind":"text","text":"] signifies The act of"},{"kind":"italic_en","text":"adjoining,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"putting together."},{"kind":"text","text":"(TA.) ―         -b2-  Hence, (TA,)"},{"kind":"arabic","text_bw":"xaSafa","text_ar":"خَصَفَ"},{"kind":"text","text":", (S, Msb, K, TA,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xaSofN","text_ar":"خَصْفٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He sewed"},{"kind":"text","text":"a sole (S, K, TA) ["},{"kind":"italic_en","text":"so as to make it double"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"covering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facing, one piece with another:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he patched"},{"kind":"text","text":"a sole;"},{"kind":"italic_en","text":"mended"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"by sewing on another piece."},{"kind":"text","text":"(Msb.) And"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"anything"},{"kind":"italic_en","text":"double, putting one piece upon another; he faced"},{"kind":"text","text":"it. (TA.) ―         -b3-  And [hence,]"},{"kind":"arabic","text_bw":"xaSafa EalaY nafosihi","text_ar":"خَصَفَ عَلَى نَفْسِهِ"},{"kind":"text","text":", (JK,) or"},{"kind":"arabic","text_bw":"xaSafa Alwaraqa EalaY badanihi","text_ar":"خَصَفَ الوَرَقَ عَلَى بَدَنِهِ"},{"kind":"text","text":", (S, * K,) aor. as above, (S, TA,) and so the inf. n.; (TA;) and ↓"},{"kind":"arabic","text_bw":"AxtSf","text_ar":"اختصف","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"AxSf","text_ar":"اخصف","orth_type":"arrow"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"xS~f","text_ar":"خصّف","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoSiyfN","text_ar":"تَخْصِيفٌ"},{"kind":"text","text":"; (TA;) (tropical:)"},{"kind":"italic_en","text":"He stuck"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sewed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the leaves together, one to another,"},{"kind":"text","text":"(S, K, * TA,)"},{"kind":"italic_en","text":"and covered his person with them, leaf by leaf,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"to conceal therewith his pudenda:"},{"kind":"text","text":"(S, TA:) or the first phrase, (JK,) as also ↓"},{"kind":"arabic","text_bw":"AxtSf","text_ar":"اختصف","orth_type":"arrow"},{"kind":"text","text":", (Lth, JK,) signifies"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a naked man)"},{"kind":"italic_en","text":"put upon his pudenda wide leaves,"},{"kind":"text","text":"(Lth, JK,) or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(Lth:) you say,"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxtSf","text_ar":"اختصف","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he covered his pudenda with such a thing"},{"kind":"text","text":"]. (Lth, JK.) It is said in the Kur"},{"kind":"page_break","n":750},{"kind":"text","text":"[vii. 21 and xx. 119],"},{"kind":"arabic","text_bw":"waTafiqaA yaxoSifaAni EalayohimaA mino","text_ar":"وَطَفِقَا يَخْصِفَانِ عَلَيْهِمَا مِنْ"},{"kind":"arabic","text_bw":"waraqi Aljan~api","text_ar":"وَرَقِ الجَنَّةِ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"yaxiS~ifaAni","text_ar":"يَخِصِّفَانِ","orth_type":"arrow"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"yaxotaSifaAni","text_ar":"يَخْتَصِفَانِ"},{"kind":"text","text":", by some pronounced ↓"},{"kind":"arabic","text_bw":"yaxaS~ifaAni","text_ar":"يَخَصِّفَانِ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,) and by some, ↓"},{"kind":"arabic","text_bw":"yaxoS~ifaAni","text_ar":"يَخْصِّفَانِ","orth_type":"arrow"},{"kind":"text","text":", with two quiescent letters together; (TA; [but this appears to be incorrect; see 8 in art."},{"kind":"arabic","text_bw":"xSm","text_ar":"خصم"},{"kind":"text","text":";]) and ↓"},{"kind":"arabic","text_bw":"yuxoSifaAni","text_ar":"يُخْصِفَانِ","orth_type":"arrow"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"A^axoSafa","text_ar":"اَخْصَفَ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"yuxaS~ifaAni","text_ar":"يُخَصِّفَانِ","orth_type":"arrow"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"xaS~afa","text_ar":"خَصَّفَ"},{"kind":"text","text":"; (Ksh and Bd in vii. 21, and TA;) thus accord. to different readings; i. e. (tropical:)"},{"kind":"italic_en","text":"And they betook themselves to sticking"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sewing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"together, one to another, of the leaves of Paradise, to conceal therewith their pudenda."},{"kind":"text","text":"(S, TA.) And hence, also, the saying, in a trad.,"},{"kind":"arabic","text_bw":"A_i*aA daxala A^aHadukumu AlHam~aAma faEalayohi biAln~a$iyri","text_ar":"اـِذَا دَخَلَ اَحَدُكُمُ الحَمَّامَ فَعَلَيْهِ بِالنَّشِيرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"walaA yuxaS~ifo","text_ar":"وَلَا يُخَصِّفْ","orth_type":"arrow"},{"kind":"text","text":", i. e. (tropical:)  ["},{"kind":"italic_en","text":"When any one of you enters the bath,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"let him take the waist-wrapper, and not put his hand upon his pudendum:"},{"kind":"text","text":"and like this in meaning is"},{"kind":"arabic","text_bw":"txS~fh","text_ar":"تخصّفه"},{"kind":"text","text":"[app. a mistranscription for ↓"},{"kind":"arabic","text_bw":"yataxaS~afu","text_ar":"يَتَخَصَّفُ","orth_type":"arrow"},{"kind":"text","text":", or ↓"},{"kind":"arabic","text_bw":"yaxiS~ifu","text_ar":"يَخِصِّفُ","orth_type":"arrow"},{"kind":"text","text":"or the like, for"},{"kind":"arabic","text_bw":"yaxotaSifu","text_ar":"يَخْتَصِفُ"},{"kind":"text","text":": if not, it must be ↓"},{"kind":"arabic","text_bw":"taxaS~afahu","text_ar":"تَخَصَّفَهُ","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"he put his hand upon it"},{"kind":"text","text":"]. (TA.) ―         -b4-  [Hence also the saying,]"},{"kind":"arabic","text_bw":"famaA zaAluwA yaxoSifuwna A^axofaAfa AlmaTiY~i biHawaAfiri Alxayoli","text_ar":"فَمَا زَالُوا يَخْصِفُونَ اَخْفَافَ المَطِىِّ بِحَوَافِرِ الخَيْلِ"},{"kind":"arabic","text_bw":"Hat~aY liHiquwhumo","text_ar":"حَتَّى لِحِقُوهُمْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"And they ceased not to make the prints of the feet of the camels to be covered by the prints of the hoofs of the horses"},{"kind":"text","text":"["},{"kind":"italic_en","text":"until they overtook them"},{"kind":"text","text":"]; as though they sewed these upon the others, like as one sews a sole by covering, or facing, one piece with another. (TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"xuSifati Alkatiybapu mino","text_ar":"خُصِفَتِ الكَتِيبَةُ مِنْ"},{"kind":"arabic","text_bw":"waraAy^ihaA bixayolK","text_ar":"وَرَايِهَا بِخَيْلٍ"},{"kind":"text","text":", i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"The body of troops"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was followed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by horsemen"},{"kind":"text","text":"]. (S.) ―         -b6-  And"},{"kind":"arabic","text_bw":"xaSafa","text_ar":"خَصَفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xaSofN","text_ar":"خَصْفٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He lied."},{"kind":"text","text":"(Munjid of Kr. [See"},{"kind":"arabic","text_bw":"xaS~aAfN","text_ar":"خَصَّافٌ"},{"kind":"text","text":".]) ―         -b7-  And"},{"kind":"arabic","text_bw":"xaSafotu fulaAnFA","text_ar":"خَصَفْتُ فُلَانًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I exceeded such a one in reviling"},{"kind":"text","text":"[as though adding reviling upon reviling]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"xaSafato","text_ar":"خَصَفَتْ"},{"kind":"text","text":", (AZ, S, K,) aor."},{"kind":"text","text":", (AZ, S,) inf. n."},{"kind":"arabic","text_bw":"xiSaAfN","text_ar":"خِصَافٌ"},{"kind":"text","text":", said of a she-camel,"},{"kind":"italic_en","text":"She cast her young one in the ninth month:"},{"kind":"text","text":"(AZ, S, K:) the epithet applied to her in this case is ↓"},{"kind":"arabic","text_bw":"xaSuwfN","text_ar":"خَصُوفٌ","orth_type":"arrow"},{"kind":"text","text":": (AZ, S:) or, as some say, (S,) this epithet signifies one"},{"kind":"italic_en","text":"that brings forth a year and a month,"},{"kind":"text","text":"(S, and so in some copies of the K,) in [some of] the copies of the K"},{"kind":"italic_en","text":"a year and two months,"},{"kind":"text","text":"which is wrong, (TA,)"},{"kind":"italic_en","text":"after the time when she was covered:"},{"kind":"text","text":"(S, K:)"},{"kind":"arabic","text_bw":"jaruwrN","text_ar":"جَرُورٌ"},{"kind":"text","text":"is applied to one that brings forth a year and two months after that time: (S, TA:) or ↓ the former epithet signifies one"},{"kind":"italic_en","text":"that brings forth on the completion of the year:"},{"kind":"text","text":"(IAar, TA:) or one"},{"kind":"italic_en","text":"of the camels termed"},{"kind":"arabic","text_bw":"maraAbiyE","text_ar":"مَرَابِيع"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"mirobaAEN","text_ar":"مِرْبَاعٌ"},{"kind":"text","text":"q. v.]"},{"kind":"italic_en","text":"that brings forth at the completion of the year;"},{"kind":"text","text":"or one"},{"kind":"italic_en","text":"of such camels that brings forth when she comes to the time of the year in which she was covered, completely:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"AxtSft","text_ar":"اختصفت","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"became such as is termed"},{"kind":"arabic","text_bw":"xaSuwf","text_ar":"خَصُوف"},{"kind":"text","text":". (JK, TA.)"}],"source_refs":["TA","S","Msb","K","JK","Lth","AZ","IAar"]},{"entry_id":"n10783","headword_ar":"خَصْفٌ","root":"xSf","body":[{"kind":"italic_en","text":"A sole having another sole sewed upon it;"},{"kind":"text","text":"(S, K;) and so ↓"},{"kind":"arabic","text_bw":"naEolN xaSiyfN","text_ar":"نَعْلٌ خَصِيفٌ","orth_type":"arrow"},{"kind":"text","text":", (S, * TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maxoSuwfapN","text_ar":"مَخْصُوفَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":[]},{"entry_id":"n10784","headword_ar":"خَصَفٌ","root":"xSf","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A mixed colour, black and white."},{"kind":"text","text":"(Freytag, from the Deewán of the Hudhalees.)       -A2-  See also"},{"kind":"arabic","text_bw":"xaSafapN","text_ar":"خَصَفَةٌ"},{"kind":"text","text":", in two places.       -A3-  Also a dial. var. of"},{"kind":"arabic","text_bw":"xazafN","text_ar":"خَزَفٌ"},{"kind":"text","text":"[q. v.]. (Lth, TA.)"}],"source_refs":[]}]},"classical_definitions":null}