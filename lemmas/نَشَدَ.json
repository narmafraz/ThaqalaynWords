"m","num":"p"},{"role":"present_2mp","form":"تَنْشُدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْشُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْشُد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْشُد","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْشُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْشُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْشُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْشُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْشُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْشُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْشُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْشُد","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْشُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَشَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَشَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":23,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n39795"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B4%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to seek"},{"pos":"verb","gloss":"to ask"}]},"etymology":null,"ipa":["/na.ʃa.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39795","headword_ar":"نَشَدَ","root":"n$d","body":[{"kind":"text","text":", (S, K, &c.,) aor."},{"kind":"text","text":", (S, Msb. &c.,) inf. n."},{"kind":"arabic","text_bw":"na$odN","text_ar":"نَشْدٌ"},{"kind":"text","text":"(L, Msb, K) and"},{"kind":"arabic","text_bw":"ni$odapN","text_ar":"نِشْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ni$odaAnN","text_ar":"نِشْدَانٌ"},{"kind":"text","text":", (S, M, L, K,) or these two are simple substs., (Msb,)"},{"kind":"italic_en","text":"He raised his voice in seeking for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"a stray-beast, or beast that had been lost;"},{"kind":"italic_en","text":"he called out and inquired respecting"},{"kind":"text","text":"it;"},{"kind":"italic_en","text":"he cried"},{"kind":"text","text":"it: (L:) or"},{"kind":"italic_en","text":"he sought for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"it: (Lh, A'Obeyd, S, M, L, Msb, K:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"An$d","text_ar":"انشد","orth_type":"arrow"},{"kind":"italic_en","text":"he asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, to be directed to it."},{"kind":"text","text":"(M, L, K.) ―         -b2-  Also,"},{"kind":"italic_en","text":"He made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave information of,"},{"kind":"text","text":"a stray-beast, or beast that had been lost; (Lh, A'Obeyd, M, L, Msb K;) and so ↓"},{"kind":"arabic","text_bw":"An$d","text_ar":"انشد","orth_type":"arrow"},{"kind":"text","text":": (Lh, S, M, IKtt, L, Msb, K:) thus the latter verb [as well as the former] bears two contr. significations. (M, K.) See also"},{"kind":"arabic","text_bw":"naA$idN","text_ar":"نَاشِدٌ"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"na$ada","text_ar":"نَشَدَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He sought, sought for"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, a thing."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"arabic","text_bw":"na$adahu","text_ar":"نَشَدَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He asked, begged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"besought, him."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"nu$ida","text_ar":"نُشِدَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was asked, begged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"besought."},{"kind":"text","text":"(S, L.) See 6: and 4. ―         -b6-"},{"kind":"arabic","text_bw":"na$adahu","text_ar":"نَشَدَهُ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", L,) inf. n."},{"kind":"arabic","text_bw":"ni$odapN","text_ar":"نِشْدَةٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"na$odapN","text_ar":"نَشْدَةٌ"},{"kind":"text","text":"(see below)] and"},{"kind":"arabic","text_bw":"ni$odaAnN","text_ar":"نِشْدَانٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"nA$dhu","text_ar":"ناشدهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"munaA$adapN","text_ar":"مُنَاشَدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ni$aAdN","text_ar":"نِشَادٌ"},{"kind":"text","text":"; (M, L, K;) (tropical:)"},{"kind":"italic_en","text":"He adjured him."},{"kind":"text","text":"(M, * L, * K.) ―         -b7-"},{"kind":"arabic","text_bw":"na$adahu biA@ll~`hi","text_ar":"نَشَدَهُ بِا@للّٰهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He adjured him by God;"},{"kind":"text","text":"(L, K; *) accord. to most of the grammarians and lexicologists,"},{"kind":"italic_en","text":"with a desire of conciliating him."},{"kind":"text","text":"(MF.) ―         -b8-"},{"kind":"arabic","text_bw":"na$adahu","text_ar":"نَشَدَهُ"},{"kind":"text","text":", (aor."},{"kind":"text","text":", T, S,) inf. n."},{"kind":"arabic","text_bw":"na$odN","text_ar":"نَشْدٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He said to him"},{"kind":"arabic","text_bw":"na$adotuka A@ll~`ha","text_ar":"نَشَدْتُكَ ا@للّٰهَ"},{"kind":"text","text":", (S, L, K,) which signifies"},{"kind":"italic_en","text":"I conjure, beg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beseech, thee by God;"},{"kind":"text","text":"(S, A, Mgh, L, Msb, K;) as though thou remindedst him of God, and he remembered; (S, L;) as also"},{"kind":"arabic","text_bw":"A^ano$uduka A@ll~`ha","text_ar":"اَنْشُدُكَ ا@للّٰهَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"biA@ll~`hi","text_ar":"بِا@للّٰهِ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"A@ll~`ha","text_ar":"ا@للّٰهَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"naA$adotuka","text_ar":"نَاشَدْتُكَ","orth_type":"arrow"},{"kind":"text","text":", (A, Mgh, L,) and"},{"kind":"arabic","text_bw":"bAll~`h","text_ar":"باللّٰه"},{"kind":"text","text":": (Mgh, L, Msb:) originally,"},{"kind":"italic_en","text":"I conjure thee by God, raising my voice:"},{"kind":"text","text":"(Et-Towsheeh:) or it signifies"},{"kind":"italic_en","text":"I remind thee of God, conjuring;"},{"kind":"text","text":"and originally,"},{"kind":"italic_en","text":"I beseech of thee by God;"},{"kind":"text","text":"the thing for which one conjures being preceded by"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":"or what is syn. therewith, [as"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":",] or by an interrogative or imperative or prohibitive: (MF:) or it signifies"},{"kind":"italic_en","text":"I remind thee of God, desiring to conciliate thee;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"na$adotuka biA@ll~`hi","text_ar":"نَشَدْتُكَ بِا@للّٰهِ"},{"kind":"text","text":": (Msb:) or"},{"kind":"arabic","text_bw":"n$dtk All~`h","text_ar":"نشدتك اللّٰه"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ni$odapN","text_ar":"نِشْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"na$odapN","text_ar":"نَشْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ni$odaAnN","text_ar":"نِشْدَانٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"I adjure thee by God;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^ano$adotuka","text_ar":"اَنْشَدْتُكَ","orth_type":"arrow"},{"kind":"arabic","text_bw":"biA@ll~`hi","text_ar":"بِا@للّٰهِ"},{"kind":"text","text":"; (M, L,) or this latter is erroneous: (Mgh, L:) and so signifies"},{"kind":"arabic","text_bw":"na$odaka A@ll~`ha","text_ar":"نَشْدَكَ ا@للّٰهَ"},{"kind":"text","text":"; (M, L, K;) in which"},{"kind":"arabic","text_bw":"na$od","text_ar":"نَشْد"},{"kind":"text","text":"is said to be originally"},{"kind":"arabic","text_bw":"na$odap","text_ar":"نَشْدَة"},{"kind":"text","text":", an inf. n. put in the place of the verb, or"},{"kind":"arabic","text_bw":"n$dk All~`h","text_ar":"نشدك اللّٰه"},{"kind":"text","text":"is a phrase of unpremeditated formation, like"},{"kind":"arabic","text_bw":"qaEodaka A@ll~`ha","text_ar":"قَعْدَكَ ا@للّٰهَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eamoraka A@ll~`ha","text_ar":"عَمْرَكَ ا@للّٰهَ"},{"kind":"text","text":"; or this phrase, which occurs in a trad., may be incorrectly transmitted, and should perhaps be"},{"kind":"arabic","text_bw":"A^ano$uduka A@ll~`ha","text_ar":"اَنْشُدُكَ ا@للّٰهَ"},{"kind":"text","text":": (IAth, L:) or"},{"kind":"arabic","text_bw":"na$adahu","text_ar":"نَشَدَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he said to him"},{"kind":"arabic","text_bw":"na$adotuka biA@ll~`hi","text_ar":"نَشَدْتُكَ بِا@للّٰهِ"},{"kind":"arabic","text_bw":"wAlr~aHimi","text_ar":"والرَّحِمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I conjure thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adjure thee, by God and relationship;"},{"kind":"text","text":"&c.]: (Lth, T, L:)"},{"kind":"italic_en","text":"I beg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beseech, thee by God, and by relationship, raising my voice."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"na$ada","text_ar":"نَشَدَ"},{"kind":"italic_en","text":"He remembered"},{"kind":"text","text":"God. (S, L.) ―         -b10-"},{"kind":"italic_en","text":"He knew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was acquainted with,"},{"kind":"text","text":"a person. (L, K.) ―         -b11-"},{"kind":"arabic","text_bw":"na$adahu Eahodahu","text_ar":"نَشَدَهُ عَهْدَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He reminded him of his compact, covenant, engagement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"promise."},{"kind":"text","text":"(Mgh.)"}],"source_refs":["L","Msb","K","S","M","Lh","IKtt","A","Mgh","MF","IAth","Lth","T"]}]}}