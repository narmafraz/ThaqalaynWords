{"lemma":"مُتَتابِع","slug":"مُتَتابِع","root":"ت.ب.ع","root_slug":"ت-ب-ع","root_link":"/words/roots/ت-ب-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n3746"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%AA%D9%8E%D8%AA%D8%A7%D8%A8%D9%90%D8%B9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"active participle of تَتَابَعَ (tatābaʕa): successive, consecutive","tags":["active","form-of","participle"],"examples":[{"text":"فَمَنْ لَمْ يَجِدْ فَصِيَامُ شَهْرَيْنِ مُتَتَابِعَيْنِ تَوْبَةً مِنَ اللَّهِ"}]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb تَتَابَعَ (tatābaʕa)."},"ipa":["/mu.ta.taː.biʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3746","headword_ar":"مُتَتَابِعٌ","root":"tbE","body":[{"kind":"italic_en","text":"Consecutive, successive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninterrupted, in its progressions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gradations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(TA.) You say"},{"kind":"arabic","text_bw":"luw^oluw^N mutataAbiEN","text_ar":"لُوْلُوٌ مُتَتَابِعٌ"},{"kind":"italic_en","text":"Pearls following one another,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doing so in uninterrupted order."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"SiyaAmu $ahorayoni mutataAbiEayoni","text_ar":"صِيَامُ شَهْرَيْنِ مُتَتَابِعَيْنِ"},{"kind":"italic_en","text":"The fasting of two consecutive months."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"guSonN mutataAbiEN","text_ar":"غُصْنٌ مُتَتَابِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"An even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a uniform, branch, in which are no knots."},{"kind":"text","text":"(K, * TA.) And"},{"kind":"arabic","text_bw":"farasN mutataAbiEu Alxaloqi","text_ar":"فَرَسٌ مُتَتَابِعُ الخَلْقِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A horse symmetrical in make,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"justly proportioned in his limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"rajulN mutataAbiEu AlEilomi","text_ar":"رَجُلٌ مُتَتَابِعُ العِلْمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A man whose knowledge is uniform, consistent, without incongruity."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":["A","K"]}]}}