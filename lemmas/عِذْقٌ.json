{"lemma":"عِذْقٌ","slug":"عِذْقٌ","root":"ع.ذ.ق","root_slug":"ع-ذ-ق","root_link":"/words/roots/ع-ذ-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n28475"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%90%D8%B0%D9%92%D9%82%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to mark, to make a sign on"},{"pos":"verb","gloss":"to reproach, to upbraid"},{"pos":"verb","gloss":"to sprout, to blossom, to put forth its branches (said of إِذْخِر (ʔiḏḵir) and سَخْبَر (saḵbar))"},{"pos":"verb","gloss":"to cut off the branches of"},{"pos":"verb","gloss":"synonym of عَذَقَ (ʕaḏaqa)"},{"pos":"noun","gloss":"corymb; raceme"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28475","headword_ar":"عِذْقٌ","root":"E*q","body":[{"kind":"italic_en","text":"A raceme of a palm-tree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of dates;"},{"kind":"text","text":"(S, Mgh, O, Msb, K, TA;) i. e. the"},{"kind":"italic_en","text":"base thereof,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"together with the fruit-stalks"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and fruit"},{"kind":"text","text":"]; (Msb, TA;)"},{"kind":"italic_en","text":"when ripe:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^aEo*aAqN","text_ar":"اَعْذَاقٌ"},{"kind":"text","text":"(O, Msb, K) and"},{"kind":"arabic","text_bw":"Eu*uwqN","text_ar":"عُذُوقٌ"},{"kind":"text","text":". (K.) ―         -b2-  Hence, (TA,) (tropical:)"},{"kind":"italic_en","text":"Might;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated, rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Eiz~N","text_ar":"عِزٌّ"},{"kind":"text","text":". (O, K, TA.) So in the saying,"},{"kind":"arabic","text_bw":"fiY","text_ar":"فِى"},{"kind":"arabic","text_bw":"baniY fulaAnK kaholN","text_ar":"بَنِى فُلَانٍ كَهْلٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"In the sons of such a one is might,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"that has attained its utmost point;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"E*q yaAniEN","text_ar":"عذق يَانِعٌ"},{"kind":"text","text":". (O, TA.) ―         -b3-  Also"},{"kind":"italic_en","text":"A bunch of grapes:"},{"kind":"text","text":"(Lth, O, K:) or"},{"kind":"italic_en","text":"when what was upon it has been eaten."},{"kind":"text","text":"(Ibn-'Abbád, O, K.) ―         -b4-  And"},{"kind":"italic_en","text":"A branching portion"},{"kind":"text","text":"of a plant: (Lth, O:) and"},{"kind":"italic_en","text":"any branch having branchlets."},{"kind":"text","text":"(Lth, O, K.)"}],"source_refs":["TA","O","Msb","K","Lth"]}]},"classical_definitions":null}