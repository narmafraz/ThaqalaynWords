l,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْعُسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْعُسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْعَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْعَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْعُسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْعُسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْعَسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْعَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْعُسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْعَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْعُس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْعُس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَعَسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَعَسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْعَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْعَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n40107"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B9%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be sleepy, drowsy"},{"pos":"verb","gloss":"to be inactive"},{"pos":"verb","gloss":"to cause to be sleepy","tags":["transitive"]}]},"etymology":null,"ipa":["/na.ʕa.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40107","headword_ar":"نَعَسَ","root":"nEs","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (S, M, and so in a copy of the B by the author of the K,) or"},{"kind":"text","text":", (A, K,) [the latter being agreeable with analogy,] inf. n."},{"kind":"arabic","text_bw":"nuEaAsN","text_ar":"نُعَاسٌ"},{"kind":"text","text":", (S, A, K, * TA,) or this is a simple subst., (Msb,) ["},{"kind":"italic_en","text":"He drowsed; he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, drowsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heavy with sleepiness:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he slumbered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dozed:"},{"kind":"text","text":"] the inf. n. is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"wasanN","text_ar":"وَسَنٌ"},{"kind":"text","text":": (S, A, K:) or ↓"},{"kind":"arabic","text_bw":"nuEaAsN","text_ar":"نُعَاسٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"languor in the senses,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"arising from the heaviness"},{"kind":"text","text":"["},{"kind":"italic_en","text":"which is the prevenient sign"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of sleep:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"beginning of sleep:"},{"kind":"text","text":"(M, art."},{"kind":"arabic","text_bw":"wsn","text_ar":"وسن"},{"kind":"text","text":":) or its proper signification is, accord. to Az, (Msb, TA,)"},{"kind":"arabic","text_bw":"wasanN","text_ar":"وَسَنٌ"},{"kind":"text","text":"(Msb) or"},{"kind":"arabic","text_bw":"sinapN","text_ar":"سِنَةٌ"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"without sleep:"},{"kind":"text","text":"(Msb, TA,) or"},{"kind":"arabic","text_bw":"sinapN","text_ar":"سِنَةٌ"},{"kind":"text","text":"is in the head, and"},{"kind":"arabic","text_bw":"nuEaAsN","text_ar":"نُعَاسٌ"},{"kind":"text","text":"is in the eye: or"},{"kind":"arabic","text_bw":"snp","text_ar":"سنة"},{"kind":"text","text":"is the vapour ("},{"kind":"arabic","text_bw":"ryH","text_ar":"ريح"},{"kind":"text","text":") of sleep which begins in the face, then is transmitted to the heart, and you say, of a man,"},{"kind":"arabic","text_bw":"yanoEasu","text_ar":"يَنْعَسُ"},{"kind":"text","text":", and then,"},{"kind":"arabic","text_bw":"yanaAmu","text_ar":"يَنَامُ"},{"kind":"text","text":". (Msb, art."},{"kind":"arabic","text_bw":"nwm","text_ar":"نوم"},{"kind":"text","text":".) It is said in a proverb,"},{"kind":"page_break","n":2816},{"kind":"arabic","text_bw":"maTolN kanuEaAsi Alkalobi","text_ar":"مَطْلٌ كَنُعَاسِ الكَلْبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A delaying of the payment, of a debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, like the drowsing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slumbering, of the dog:"},{"kind":"text","text":"] i. e. continual: (S, TA:) for the dog is characterized by much"},{"kind":"arabic","text_bw":"nEAs","text_ar":"نعاس"},{"kind":"text","text":", and, as is said in the B, is accustomed to open his eyes [only] sufficiently for the purpose of guarding, and this he does time after time. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"naEasa","text_ar":"نَعَسَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"naEosN","text_ar":"نَعْسٌ"},{"kind":"text","text":", (IAar, K,) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a man's judgment, and his body,)"},{"kind":"italic_en","text":"was soft,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"weak."},{"kind":"text","text":"(IAar, K, TK.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a market)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, stagnant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dull, with respect to traffic."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","A","Msb","K","TA","TK","IAar"]}]}}