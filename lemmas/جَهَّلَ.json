"m","num":"p"},{"role":"present_2mp","form":"تُجَهِّلُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجَهِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجَهِّل","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجَهِّل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجَهِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجَهِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجَهِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجَهِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجَهِّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجَهِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجَهِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"جَهَّلْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَهَّلْتُ","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجَهِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجَهِّل","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":94,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n6575","n6576","n6581"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%87%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be ignorant of, not to know (with بِ (bi) or transitive)"},{"pos":"verb","gloss":"to be foolish, to be irrational"},{"pos":"verb","gloss":"to attribute ignorance to"},{"pos":"verb","gloss":"to cause to be ignorant","tags":["ditransitive"]},{"pos":"noun","gloss":"verbal noun of جَهِلَ (jahila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"ignorance"},{"pos":"noun","gloss":"stupidity"},{"pos":"adj","gloss":"masculine/feminine plural of جَاهِل (jāhil)","tags":["feminine","form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine/feminine plural of جَهُول (jahūl)","tags":["feminine","form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6575","headword_ar":"جهل","root":"jhD","body":[{"kind":"text","text":"A she-camel"},{"kind":"italic_en","text":"that is accustomed to cast her young"},{"kind":"text","text":"(S, A)"},{"kind":"italic_en","text":"in an imperfect state."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","A"]},{"entry_id":"n6576","headword_ar":"جَهِلَ","root":"jahila","body":[{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"jahilahu","text_ar":"جَهِلَهُ"},{"kind":"text","text":", (Sh, Msb, K,) and"},{"kind":"arabic","text_bw":"jahila bihi","text_ar":"جَهِلَ بِهِ"},{"kind":"text","text":"(JK) [and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"jaAhilN","text_ar":"جَاهِلٌ"},{"kind":"text","text":")]; aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jaholN","text_ar":"جَهْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jahaAlapN","text_ar":"جَهَالَةٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"juhuwliy~ahN","text_ar":"جُهُولِيَّهٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He was ignorant;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"he was characterized by"},{"kind":"arabic","text_bw":"jahol","text_ar":"جَهْل"},{"kind":"italic_en","text":"in any of the senses assigned to this word below:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"he was ignorant of it; he did not know it;"},{"kind":"text","text":"(Sh, JK, Msb, K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"Ealimahu","text_ar":"عَلِمَهُ"},{"kind":"text","text":". (Msb, K.) You say,"},{"kind":"arabic","text_bw":"mivoliY laA yajohalu mivolaka","text_ar":"مِثْلِى لَا يَجْهَلُ مِثْلَكَ"},{"kind":"italic_en","text":"The like of me will not be ignorant of the like of thee."},{"kind":"text","text":"(Sh, TA.) And"},{"kind":"arabic","text_bw":"jahila EalaY gayorihi","text_ar":"جَهِلَ عَلَى غَيْرِهِ"},{"kind":"italic_en","text":"He acted in an ignorant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a silly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish manner towards another:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wrongly."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jahila fulaAnN raA^oyahu","text_ar":"جَهِلَ فُلَانٌ رَاْيَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"safiha","text_ar":"سَفِهَ"},{"kind":"arabic","text_bw":"raA^uyahu","text_ar":"رَاُيَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was ignorant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"silly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolish, in his opinion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judgment"},{"kind":"text","text":"]. (Sh, TA.) And"},{"kind":"arabic","text_bw":"jahila AlHaq~a","text_ar":"جَهِلَ الحَقَّ"},{"kind":"italic_en","text":"He neglected the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he ignored it;"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"A^aDaAEahu","text_ar":"اَضَاعَهُ"},{"kind":"text","text":". (Msb.) See also 6. ―         -b2-"},{"kind":"arabic","text_bw":"jahilati Alqidoru","text_ar":"جَهِلَتِ القِدْرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The cooking-pot boiled vehemently; contr. of"},{"kind":"arabic","text_bw":"taHal~amat","text_ar":"تَحَلَّمَت"},{"kind":"text","text":". (TA.)"}],"source_refs":["Sh","Msb","K","JK","S","TA"]},{"entry_id":"n6581","headword_ar":"جَهْلٌ","root":"jahila","body":[{"kind":"text","text":"an inf. n. of 1:"},{"kind":"italic_en","text":"Ignorance; contr. of"},{"kind":"arabic","text_bw":"EilomN","text_ar":"عِلْمٌ"},{"kind":"text","text":": (S, Msb, * K: *) [and"},{"kind":"italic_en","text":"silliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foolishness:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wrong conduct:"},{"kind":"text","text":"(see 1:)] it is of two kinds; namely, simple, which is the"},{"kind":"italic_en","text":"non-existence of knowledge of that which should be known;"},{"kind":"text","text":"and compound, which is"},{"kind":"italic_en","text":"a decisive belief not agreeable with the fact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reality:"},{"kind":"text","text":"so accord. to Ibn-El-Kemál: or, accord. to Er-Rághib, it is of three kinds; namely, the"},{"kind":"italic_en","text":"mind's voidness of knowledge,"},{"kind":"text","text":"which is the primary meaning; and the"},{"kind":"italic_en","text":"believing a thing to be different from what it is;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"doing a thing in a manner different from that in which it ought to be done:"},{"kind":"text","text":"or, accord. to El-Harállee, the"},{"kind":"italic_en","text":"proceeding in dubious affairs without knowledge."},{"kind":"text","text":"(TA.) It is said in a prov.,"},{"kind":"arabic","text_bw":"kafiY biAl$~ak~i juholFA","text_ar":"كَفِى بِالشَّكِّ جُهْلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Doubt is sufficient ignorance"},{"kind":"text","text":"]. (Msb.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a mina","text_ar":"اـِنَّ مِنَ"},{"kind":"arabic","text_bw":"AlEilomi jaholFA","text_ar":"العِلْمِ جَهْلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily there is,"},{"kind":"text","text":"among the kinds"},{"kind":"italic_en","text":"of knowledge, what is ignorance"},{"kind":"text","text":"]: this is one's learning what is not requisite, and neglecting what is requisite; or a learned man's affecting, or pretending, a knowledge of that which he does not know. (TA.)"}],"source_refs":[]}]}}