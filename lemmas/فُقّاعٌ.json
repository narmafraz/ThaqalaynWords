t_bw":"rubAEu","text_ar":"رُباعُ"},{"kind":"text","text":", imperfectly decl.; but see what follows;]) so says Ibn-Buzurj: (O:) or, (O, K,) accord. to AZ, (O,) ↓"},{"kind":"arabic","text_bw":"fqAEK","text_ar":"فقاعٍ","orth_type":"arrow"},{"kind":"text","text":", (O, K, *) like"},{"kind":"arabic","text_bw":"rubaAEK","text_ar":"رُبَاعٍ"},{"kind":"text","text":", (O.) [i. e.] with fet-h, like"},{"kind":"arabic","text_bw":"vamaAnK","text_ar":"ثَمَانٍ"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"kavamaAnK","text_ar":"كَثَمَانٍ"},{"kind":"text","text":"): (K:) [which suggests that"},{"kind":"arabic","text_bw":"karubaAEK","text_ar":"كَرُبَاعٍ"},{"kind":"text","text":"may be an early mistranscription for"},{"kind":"arabic","text_bw":"karbaAEK","text_ar":"كَربَاعٍ"},{"kind":"text","text":", and that"},{"kind":"arabic","text_bw":"fuqaAE","text_ar":"فُقَاع"},{"kind":"text","text":"is wrong, and only"},{"kind":"arabic","text_bw":"faqaAEK","text_ar":"فَقَاعٍ"},{"kind":"text","text":"right, though it is said in one place in the TA that"},{"kind":"arabic","text_bw":"faqaAE","text_ar":"فَقَاع"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"saHaAb","text_ar":"سَحَاب"},{"kind":"text","text":", i. e. that it is"},{"kind":"arabic","text_bw":"faqaAEN","text_ar":"فَقَاعٌ"},{"kind":"text","text":":] or it is ↓"},{"kind":"arabic","text_bw":"faqiyEN","text_ar":"فَقِيعٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A^amiyrN","text_ar":"اَمِيرٌ"},{"kind":"text","text":"; (K, TA;) so accord. to El-Jáhidh, as mentioned by Az: (TA:) applied to a man, as meaning"},{"kind":"italic_en","text":"Red;"},{"kind":"text","text":"(O, K, TA;)"},{"kind":"italic_en","text":"intensely so; by reason of"},{"kind":"arabic","text_bw":"A_igoraAb","text_ar":"اـِغْرَاب"},{"kind":"text","text":"[i. e. app.,"},{"kind":"italic_en","text":"goodliness of condition"},{"kind":"text","text":"]: (O, TA:) and ↓"},{"kind":"arabic","text_bw":"fuqaAEiy~N","text_ar":"فُقَاعِيٌّ","orth_type":"arrow"},{"kind":"text","text":", as an epithet applied to a man, signifies"},{"kind":"italic_en","text":"red."},{"kind":"text","text":"(TA.)"}],"source_refs":["O","K","TA"]},{"entry_id":"n34337","headword_ar":"فُقَّاعٌ","root":"fqE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"fuqaAEK","text_ar":"فُقَاعٍ"},{"kind":"text","text":": ―         -b2-  and see"},{"kind":"arabic","text_bw":"faAqiEN","text_ar":"فَاقِعٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n34339","headword_ar":"فُقَّاعٌ","root":"fqE","body":[{"kind":"text","text":". 1"},{"kind":"italic_en","text":"certain beverage,"},{"kind":"text","text":"(S, O, L, K,) ["},{"kind":"italic_en","text":"a sort of beer."},{"kind":"text","text":"]"},{"kind":"italic_en","text":"made from barley:"},{"kind":"text","text":"(L, TA:) [but there are several sorts thereof, perhaps peculiar to postclassical times: (see De Sacy's Chrest. Arabe, see, ed., vol. i., pp. 149-154:)] so called because of the froth that rises upon its head. (O, K. [See"},{"kind":"arabic","text_bw":"fuq~aAEapN","text_ar":"فُقَّاعَةٌ"},{"kind":"text","text":".]) ―         -b2-  And"},{"kind":"italic_en","text":"A certain plant,"},{"kind":"text","text":"(AHn, O, K.)"},{"kind":"italic_en","text":"such as is termed"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mutafaq~iEN","text_ar":"مُتَفَقِّعٌ","orth_type":"arrow"},{"kind":"text","text":", i. e., (AHn, O, K. *)"},{"kind":"italic_en","text":"which, when it dries up, becomes hard, and as though it were horns."},{"kind":"text","text":"(AHn, O, K.) [Now applied in North-Western Africa to The"},{"kind":"italic_en","text":"toadstool,"},{"kind":"text","text":"which is called in other parts"},{"kind":"arabic","text_bw":"fuTorN","text_ar":"فُطْرٌ"},{"kind":"text","text":".]"}],"source_refs":["S","O","L","K","TA"]},{"entry_id":"n34338","headword_ar":"فَقَّاعٌ","root":"fqE","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"who emits wind from the anus, with a sound, much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frequently."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wicked."},{"kind":"text","text":"(Lth, O, K.)"}],"source_refs":[]}]},"classical_definitions":null}