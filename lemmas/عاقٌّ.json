{"lemma":"عاقٌّ","slug":"عاقٌّ","root":"ع.ق.ق","root_slug":"ع-ق-ق","root_link":"/words/roots/ع-ق-ق","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n29821"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%82%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hamper, to be an obstacle to, to obstruct, to impair, to impede, to hinder"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29821","headword_ar":"عَاقٌّ","root":"Eq","body":[{"kind":"italic_en","text":"Undutiful, disobedient, refractory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illmannered, to his parent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"father;"},{"kind":"text","text":"(S, * O, * K;)"},{"kind":"italic_en","text":"breaking,"},{"kind":"text","text":"or one"},{"kind":"italic_en","text":"who breaks, his compact of obedience to his parent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"father;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"disobeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedient to, his father;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"failing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglecting, to behave to him in a good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comely, manner;"},{"kind":"text","text":"(Msb;) [and"},{"kind":"italic_en","text":"severing,"},{"kind":"text","text":"or one"},{"kind":"italic_en","text":"who severs, the tie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ties, of relationship, by unkind behaviour to his kindred;"},{"kind":"text","text":"(see its verb;)] and ↓"},{"kind":"arabic","text_bw":"Eaq~N","text_ar":"عَقٌّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (O, K;) as also ↓"},{"kind":"arabic","text_bw":"EuqaqN","text_ar":"عُقَقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, O, TA,) but in an intensive sense, altered from"},{"kind":"arabic","text_bw":"EaAq~N","text_ar":"عَاقٌّ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"gudar","text_ar":"غُدَر"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fusaq","text_ar":"فُسَق"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"gaAdir","text_ar":"غَادِر"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faAsiq","text_ar":"فَاسِق"},{"kind":"text","text":", in the K erroneously said to be"},{"kind":"arabic","text_bw":"EaqaqN","text_ar":"عَقَقٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"EuquqN","text_ar":"عُقُقٌ","orth_type":"arrow"},{"kind":"text","text":"; (L, and TA as from the K, but not in my MS. copy of the K nor in the CK;) which last signifies also [as a pl.] men"},{"kind":"italic_en","text":"severing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who sever, the ties of relationship, by unkind behaviour to their kindred;"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"remote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distant, enemies:"},{"kind":"text","text":"(TA:) [and ↓"},{"kind":"arabic","text_bw":"EaquwqN","text_ar":"عَقُوقٌ","orth_type":"arrow"},{"kind":"text","text":"is app. used (as Freytag asserts it to be) in the sense of"},{"kind":"arabic","text_bw":"EaAq~N","text_ar":"عَاقٌّ"},{"kind":"text","text":"in the Fákihet el-Khulatà, p. 55, 1. 7 from the bottom:] the pl. of"},{"kind":"arabic","text_bw":"EaAq~N","text_ar":"عَاقٌّ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EaqaqapN","text_ar":"عَقَقَةٌ"},{"kind":"text","text":", (S, O, Msb, K,) like"},{"kind":"arabic","text_bw":"kafarapN","text_ar":"كَفَرَةٌ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"Euq~aqN","text_ar":"عُقَّقٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"ruk~aEN","text_ar":"رُكَّعٌ"},{"kind":"text","text":", a form used by Ru-beh, (O,) and"},{"kind":"arabic","text_bw":"A^aEiq~apN","text_ar":"اَعِقَّةٌ"},{"kind":"text","text":", which is an extr. [meaning anomalous] pl. (Ham p. 93.) ↓"},{"kind":"arabic","text_bw":"*uqN Euqaqu","text_ar":"ذُقٌ عُقَقُ","orth_type":"arrow"},{"kind":"text","text":", (S, O,) in a trad., (S,) said by Aboo-Sufyán to Hamzeh on the day of Ohod, when he passed by him slain, (S, * O,) means"},{"kind":"arabic","text_bw":"*uqN jazaA='a fiEolika","text_ar":"ذُقٌ جَزَا=ءَ فِعْلِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Taste thou the recompense of thy deed"},{"kind":"text","text":"], (S,) or"},{"kind":"arabic","text_bw":"*uqi Alqatola","text_ar":"ذُقِ القَتْلَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"taste thou slaughter"},{"kind":"text","text":"], (O,)"},{"kind":"arabic","text_bw":"yaA EaAq~u","text_ar":"يَا عَاقُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O undutiful,"},{"kind":"text","text":"&c.; or, accord. to the explanation in the TA mentioned above,"},{"kind":"arabic","text_bw":"Euqaqu","text_ar":"عُقَقُ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"yaA Euqaqu","text_ar":"يَا عُقَقُ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"O very undutiful,"},{"kind":"text","text":"&c.]. (S, O.)"}],"source_refs":["S","O","TA","Msb","K"]}]},"classical_definitions":null}