{"lemma":"عاهاتِ","slug":"عاهاتِ","root":"ع.#.ه","root_slug":"ع-_-ه","root_link":"/words/roots/ع-_-ه","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31126"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D9%87%D8%A7%D8%AA%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"handicap, disability, disqualification","examples":[{"text":"ذُو عَاهَةٍ","english":"handicapped"},{"text":"وُلِدَ بِعَاهَةٍ","english":"He was born with a disability."}]}]},"etymology":null,"ipa":["/ʕaː.ha/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31126","headword_ar":"عَاهَةٌ","root":"Ewh","body":[{"kind":"text","text":", in which the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"is substituted for"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"accord. to some, and for"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"accord. to others, (Msb, * TA,) is originally of the measure"},{"kind":"arabic","text_bw":"faEalapN","text_ar":"فَعَلَةٌ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", (Msb,) and is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"A=fapN","text_ar":"ا=فَةٌ"},{"kind":"text","text":"[signifying"},{"kind":"italic_en","text":"A bane;"},{"kind":"text","text":"such as"},{"kind":"italic_en","text":"a disease, pest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"murrain;"},{"kind":"text","text":"(tropical:)  and"},{"kind":"italic_en","text":"a blight, blast, taint, canker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"see 1, in two places]. (S, Msb, K, TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA yuwridan~a *uw EaAhapK Ealay muSiH~K","text_ar":"لَا يُورِدَنَّ ذُو عَاهَةٍ عَلَي مُصِحٍّ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"One whose camels are affected with a bane, such as mange &c., shall not bring them to water immediately after one whose camels are in a healthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound, state."},{"kind":"text","text":"(TA. [See also art."},{"kind":"arabic","text_bw":"SH","text_ar":"صح"},{"kind":"text","text":".]"},{"kind":"page_break","n":2205}],"source_refs":["Msb"]}]},"classical_definitions":null}