,"entry_ids":["n7940"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AD%D9%8E%D8%B3%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be careful, to be on guard"},{"pos":"verb","gloss":"to take precautions"},{"pos":"verb","gloss":"to seek to know, to try to find out"},{"pos":"noun","gloss":"verbal noun of تَحَسَّبَ (taḥassaba) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7940","headword_ar":"تحسَب","root":"Hsb","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought leisurely and repeatedly, to learn"},{"kind":"text","text":"news: (A, K, * TA:)"},{"kind":"italic_en","text":"he sought after"},{"kind":"text","text":"news: (K, * TA:)"},{"kind":"italic_en","text":"he inquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asked, respecting"},{"kind":"text","text":"news; (S, K, * TA; [in the CK,"},{"kind":"arabic","text_bw":"Asotaxoyara","text_ar":"اسْتَخْيَرَ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"Aisotaxobara","text_ar":"اِسْتَخْبَرَ"},{"kind":"text","text":";]) of the dial. of El-Hijáz: (TA:)"},{"kind":"italic_en","text":"he searched after"},{"kind":"text","text":"news"},{"kind":"italic_en","text":"as a spy."},{"kind":"text","text":"(A 'Obeyd, TA.) It is said in a trad., accord. to one reading,"},{"kind":"arabic","text_bw":"kaAnuwA yajotamiEuwna fayataHas~abuwna","text_ar":"كَانُوا يَجْتَمِعُونَ فَيَتَحَسَّبُونَ"},{"kind":"arabic","text_bw":"AlS~alaApa","text_ar":"الصَّلَاةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They used to assemble, and endeavour to ascertain the time of prayer:"},{"kind":"text","text":"but the common reading is"},{"kind":"arabic","text_bw":"yataHay~anuwna","text_ar":"يَتَحَيَّنُونَ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"He reclined upon a pillow."},{"kind":"text","text":"(K.)"}],"source_refs":["TA"]}]},"classical_definitions":null}