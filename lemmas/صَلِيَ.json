orm":"تَصْلَُوا","in_corpus":true,"count":11,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَصْلَُونَ","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْلَيْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْلَى","in_corpus":true,"count":747,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَصْلَ","in_corpus":true,"count":88,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْلَى","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَصْلَ","in_corpus":true,"count":81,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْلَيا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْلَيانِ","in_corpus":true,"count":16,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْلَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْلَيانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْلَُوا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْلَُونَ","in_corpus":true,"count":44,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْلَيْنَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصْلَى","in_corpus":true,"count":78,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْلَى","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَلِيْنا","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَلِيْتُ","in_corpus":true,"count":198,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْلَ","in_corpus":true,"count":21,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْلَ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2249,"cross_references":{"qac":{"found":true,"lemma_key":"صَلِيَ","root":"صلي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n24818","","n24827","n24830"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%84%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to suffer from","tags":["intransitive","transitive"],"examples":[{"text":"سَيَصْلَى نَارًا ذَاتَ لَهَبٍ"}]},{"pos":"verb","gloss":"to abate, to come to an end (of one's suffering)"},{"pos":"noun","gloss":"verbal noun of صَلِيَ (ṣaliya) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of صَلَى (ṣalā) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24818","headword_ar":"صلّى","root":"Slw","body":[{"kind":"text","text":", (S, M, K,) quasi-inf. n."},{"kind":"arabic","text_bw":"SalaApN","text_ar":"صَلَاةٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Sal`wp","text_ar":"صَلٰوة"},{"kind":"text","text":", for which one should not say"},{"kind":"arabic","text_bw":"taSoliyapN","text_ar":"تَصْلِيَةٌ"},{"kind":"text","text":", (S, K,) or the latter is allowable as agreeable with rule and as occurring in old poetry, (MF, TA,)"},{"kind":"italic_en","text":"He prayed, supplicated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petitioned:"},{"kind":"text","text":"(S, M, K:) and [particularly]"},{"kind":"italic_en","text":"he performed the divinely-appointed act"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of prayer commonly"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"termed"},{"kind":"arabic","text_bw":"SalaAp","text_ar":"صَلَاة"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Sal`wp","text_ar":"صَلٰوة"},{"kind":"text","text":". (S.) Hence, in the Kur [ix. 104], (TA,)"},{"kind":"arabic","text_bw":"waSal~i Ealayohimo","text_ar":"وَصَلِّ عَلَيْهِمْ"},{"kind":"italic_en","text":"And pray thou for them."},{"kind":"text","text":"(Msb, TA.)"},{"kind":"arabic","text_bw":"Sal~aY EalaY","text_ar":"صَلَّى عَلَى"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He prayed for such a one, and praised him."},{"kind":"text","text":"(TA.) And hence the verse of ElAashà cited in art."},{"kind":"arabic","text_bw":"rsm","text_ar":"رسم"},{"kind":"text","text":", conj. 8. (S, Mgh, * TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"mano duEiYa A_ilaY waliymapK faloyujibo","text_ar":"مَنْ دُعِىَ اـِلَى وَلِيمَةٍ فَلْيُجِبْ"},{"kind":"arabic","text_bw":"waA_il~aA faloyuSal~i","text_ar":"وَاـِلَّا فَلْيُصَلِّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Whoso is invited to a banquet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a marriage-feast, let him comply, or, if not, let him pray"},{"kind":"text","text":"for the inviter]. (M.) And the saying, in a verse of El-Aashà,"},{"kind":"arabic","text_bw":"Ealayoki mivola Al~a*iY Sal~ayoti","text_ar":"عَلَيْكِ مِثْلَ الَّذِى صَلَّيْتِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Keep thou to the like of thy prayer;"},{"kind":"text","text":"i. e. he enjoined her to repeat the prayer for him: or, as some relate it,"},{"kind":"arabic","text_bw":"Ealayoki mivolu Al~a*iY Sal~ayoti","text_ar":"عَلَيْكِ مِثْلُ الَّذِى صَلَّيْتِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"upon thee be the like of that for which thou hast prayed:"},{"kind":"text","text":"(M:) these words he addressed to his daughter, on the occasion of her saying, “ O my Lord, ward off from my father diseases and pain. ” (Mgh.) The saying"},{"kind":"arabic","text_bw":"Eabiydu fulaAnK yuSal~uwna","text_ar":"عَبِيدُ فُلَانٍ يُصَلُّونَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The slaves of such a one perform the divinely-appointed act of prayer"},{"kind":"text","text":"] means that they have attained to the age of virility. (Mgh.) ―         -b2-"},{"kind":"arabic","text_bw":"Sl~Y Ealayohi","text_ar":"صلّى عَلَيْهِ"},{"kind":"text","text":", said of an angel, means"},{"kind":"italic_en","text":"He prayed for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begged, forgiveness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pardon, for him:"},{"kind":"text","text":"and thus the verb sometimes means when said of other than an angel; as in the trad. of Sowdeh, in which it is said,"},{"kind":"arabic","text_bw":"A_i*aA mitonaA Sal~aY lanaA EuvomaAnu bonu maZoEuwnK","text_ar":"اـِذَا مِتْنَا صَلَّى لَنَا عُثْمَانُ بْنُ مَظْعُونٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When we die, 'Othmán Ibn-Madh'oon will pray for forgiveness for us"},{"kind":"text","text":"]; he having then died. (TA.) ―         -b3-  [And, said of a man,"},{"kind":"italic_en","text":"He blessed him,"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he invoked"},{"kind":"text","text":"God's"},{"kind":"italic_en","text":"blessing upon him;"},{"kind":"text","text":"namely, the Prophet; or he said,"},{"kind":"arabic","text_bw":"Aall~`hum~a Sal~i Ealayohi","text_ar":"اَللّٰهُمَّ صَلِّ عَلَيْهِ"},{"kind":"text","text":"(expl. by what here follows) accord. to the rendering of"},{"kind":"arabic","text_bw":"Sal~uwA Ealayohi","text_ar":"صَلُّوا عَلَيْهِ"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"EalaY Aln~abiY~i","text_ar":"عَلَى النَّبِىِّ"},{"kind":"text","text":", by Bd and others in the Kur xxxiii. 56.] One says,"},{"kind":"arabic","text_bw":"Sal~ayotu EalaY Aln~abiY~i","text_ar":"صَلَّيْتُ عَلَى النَّبِىِّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I blessed the Prophet;"},{"kind":"text","text":"&c.]. (S.) ―         -b4-  And, said of God,"},{"kind":"italic_en","text":"He blessed him,"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"He conferred blessing upon him:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"He had mercy on him:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"He magnified him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conferred honour upon him:"},{"kind":"text","text":"hence the saying,"},{"kind":"arabic","text_bw":"Aall~`hum~a Sal~i EalaY A=li A^abiY A^awofaY","text_ar":"اَللّٰهُمَّ صَلِّ عَلَى ا=لِ اَبِى اَوْفَى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"O God, bless the family of Aboo-Owfà:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have mercy on"},{"kind":"text","text":"&c.: but in the saying [in the Kur xxxiii. 56],"},{"kind":"arabic","text_bw":"A_in~a A@ll~`ha wamalaAy^ikatahu yuSal~uwna EalaY Aln~abiY~i","text_ar":"اـِنَّ ا@للّٰهَ وَمَلَايِكَتَهُ يُصَلُّونَ عَلَى النَّبِىِّ"},{"kind":"text","text":", the verb does not import two meanings; for it has there only one meaning, which is “ magnification ” [i. e. these words mean"},{"kind":"italic_en","text":"Verily God and his angels magnify the Prophet;"},{"kind":"text","text":"or rather I would render them,"},{"kind":"italic_en","text":"bless the Prophet,"},{"kind":"text","text":"as this rendering implies magnification and also a meaning of the quasi-inf. n. given in the M and K, which is “ eulogy, ” or “ commendation, ” bestowed by God upon his apostle, while it imports God's “ conferring of blessing ” and the angels' “ invoking thereof ” ]: (Msb, TA:) [it is said that]"},{"kind":"arabic","text_bw":"All~`hum~a Sal~i EalaY muHam~adK","text_ar":"اللّٰهُمَّ صَلِّ عَلَى مُحَمَّدٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"O God, magnify Mohammad in the present world by exalting his renown and manifesting his invitation"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to ElIslám"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and rendering permanent his law, and in the world to come by accepting his intercession for his people and multiplying his reward:"},{"kind":"text","text":"and it is disputed whether or not this form of prayer may be used for any but the Prophet [Mohammad]: El-Khattábee says that it may not, though he himself used it for others. (TA.) ["},{"kind":"arabic","text_bw":"Sal~aY A@ll~`hu Ealayohi","text_ar":"صَلَّى ا@للّٰهُ عَلَيْهِ"},{"kind":"arabic","text_bw":"wasal~ama","text_ar":"وَسَلَّمَ"},{"kind":"text","text":"is a phrase commonly used by the Muslims after the mention of their prophet: see art."},{"kind":"arabic","text_bw":"slm","text_ar":"سلم"},{"kind":"text","text":". See also"},{"kind":"arabic","text_bw":"SalaApN","text_ar":"صَلَاةٌ"},{"kind":"text","text":"below.]       -A2-"},{"kind":"arabic","text_bw":"Sl~Y","text_ar":"صلّى"},{"kind":"text","text":"said of a horse, (S, K,) inf. n."},{"kind":"arabic","text_bw":"taSoliyapN","text_ar":"تَصْلِيَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He followed next after the foremost"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a race, at the goal"},{"kind":"text","text":"]. (S, K.) Hence the saying [in a trad. of 'Alee],"},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"arabic","text_bw":"rasuwlu A@ll~`hi waSal~aY A^abuw bakorK waval~ava Eumaru","text_ar":"رَسُولُ ا@للّٰهِ وَصَلَّى اَبُو بَكْرٍ وَثَلَّثَ عُمَرُ"},{"kind":"text","text":"[expl. in art."},{"kind":"arabic","text_bw":"sbq","text_ar":"سبق"},{"kind":"text","text":"]. (Mgh.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Sl~Y AlHimaAru A^utunahu","text_ar":"صلّى الحِمَارُ اُتُنَهُ"},{"kind":"text","text":", (Sgh, K,) inf. n."},{"kind":"arabic","text_bw":"taSoliyapN","text_ar":"تَصْلِيَةٌ"},{"kind":"text","text":", (Sgh, TA,)"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"wild"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ass drove together his she-asses, and made them to take the way"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that he would follow"},{"kind":"text","text":"]. (Sgh, K, TA.)"}],"source_refs":["S","M","K","MF","TA","Msb","Sgh"]},{"entry_id":"n24827","headword_ar":"صَلًى","root":"SlY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SalaA='N","text_ar":"صَلَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n24830","headword_ar":"صَلِىٌّ","root":"SlY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maSoliY~N","text_ar":"مَصْلِىٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]}}