"num":"d"},{"role":"present_3fd","form":"تُجْلَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْلِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجْلِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجْلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجْلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجْلَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُجْلِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُجْل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْلَى","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجْلَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْلِي","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجْلِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَجْلَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَجْلَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":45,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n6190","n6208"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AC%D9%92%D9%84%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to evacuate, to expel, to force to leave","tags":["transitive"]},{"pos":"verb","gloss":"to go away, to leave (عَنْ (ʕan))","tags":["intransitive"]}]},"etymology":null,"ipa":["/ʔad͡ʒ.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6190","headword_ar":"اجلى","root":"jlw","body":[{"kind":"text","text":"as an intrans. v.: see 1, in two places. ―         -b2-"},{"kind":"arabic","text_bw":"A^ajolawo Eani Alqatiyli","text_ar":"اَجْلَوْ عَنِ القَتِيلِ"},{"kind":"italic_en","text":"They cleared themselves away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, from the slain person."},{"kind":"text","text":"(S, Mgh, Msb, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AjlY yaEoduw","text_ar":"اجلى يَعْدُو"},{"kind":"italic_en","text":"He hastened, running:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"hastened somewhat, running:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"AjlY","text_ar":"اجلى"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, and hastened."},{"kind":"text","text":"(So accord. to some copies of the K, where we find"},{"kind":"arabic","text_bw":"waA^ajolaY baEuda wa A^asoraEa","text_ar":"وَاَجْلَى بَعُدَ وَ اَسْرَعَ"},{"kind":"text","text":"instead of"},{"kind":"arabic","text_bw":"wa A^ajolaY","text_ar":"وَ اَجْلَى"},{"kind":"arabic","text_bw":"yaEoduw A^asoraEa","text_ar":"يَعْدُو اَسْرَعَ"},{"kind":"text","text":".)       -A2-  As a trans. v.: see 1, in four places."}],"source_refs":["K","TA"]},{"entry_id":"n6208","headword_ar":"اَجْلَى","root":"jlw","body":[{"kind":"italic_en","text":"Having that degree of baldness which is termed"},{"kind":"arabic","text_bw":"jalFA","text_ar":"جَلًا"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"baldness of the fore part of the head:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"baldness of half of the head;"},{"kind":"text","text":"(S, K;) which is the beginning of"},{"kind":"arabic","text_bw":"SalaEN","text_ar":"صَلَعٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"baldness less than what is termed"},{"kind":"arabic","text_bw":"SalaEN","text_ar":"صَلَعٌ"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"baldness of half of the head,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(A'Obeyd, TA:) fem."},{"kind":"arabic","text_bw":"jalowaA='N","text_ar":"جَلْوَا=ءٌ"},{"kind":"text","text":". (K.) [See"},{"kind":"arabic","text_bw":"A^ajolaHu","text_ar":"اَجْلَحُ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"italic_en","text":"Beautiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"handsome, in face, bald in the sides of the forehead."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"jabohapN jalowaA='u","text_ar":"جَبْهَةٌ جَلْوَا=ءُ"},{"kind":"italic_en","text":"A wide forehead."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"samaA='N jalowaA='N","text_ar":"سَمَا=ءٌ جَلْوَا=ءٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A cloudless sky:"},{"kind":"text","text":"(Ks, S, K:) and"},{"kind":"arabic","text_bw":"layolapN jalowaA='u","text_ar":"لَيْلَةٌ جَلْوَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"a cloudless, bright, night."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Aibonu A^ajolaY","text_ar":"اِبْنُ اَجْلَى"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Aibonu jalaA","text_ar":"اِبْنُ جَلَا"},{"kind":"text","text":", in two places. ―         -b6-  Also (i. e."},{"kind":"arabic","text_bw":"Abn AjlY","text_ar":"ابن اجلى"},{"kind":"text","text":") (assumed tropical:)"},{"kind":"italic_en","text":"The lion."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"faEalotuhu mino","text_ar":"فَعَلْتُهُ مِنْ"},{"kind":"arabic","text_bw":"A^ajolaAka","text_ar":"اَجْلَاكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A_ijolaAka","text_ar":"اـِجْلَاكَ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"I did it on account of thee, for thy sake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"because of thee;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"mino A^ajolika","text_ar":"مِنْ اَجْلِكَ"},{"kind":"text","text":". (K.)"}],"source_refs":["S","K","Ks"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%AC%D9%84%D9%89/","headword_ar":"أَجَلَى","entries":[{"lexicon_id":"dictionary_52","lexicon_en":"Yāqūt al-Ḥamawī, Muʿjam al-Buldān (d. 1229)","lexicon_ar":"معجم البلدان لياقوت الحموي","permalink":"https://arabiclexicon.hawramani.com/?p=136463#f4625e","body_html":"<div>أَجَلَى:</div><div>بفتح أوله وثانيه وثالثه، بوزن جمزى محرّك، وآخره ممال، وهذا البناء يختصّ بالمؤنث اسما وصفة، فالاسم نحو أجلى ودقرى وبردى، والصفة بشكي ومرطي وجمزى: وهو اسم جبل في شرقي ذات الأصاد، أرض من الشّربّة. وقال ابن السكيّت:</div><div>أجلى هضبات ثلاث على مبدأة النعم من الثّعل بشاطئ الجريب الذي يلقى الثّعل، وهو مرعى لهم معروف، قال:</div><div>حلّت سليمى جانب الجريب ... بأجلى، محلّة الغريب،</div><div>محلّ لا دان، ولا قريب</div><div>وقال الأصمعي: أجلى بلاد طيبة مريئة، تنبت الجليّ والصّليّان، وأنشد: حلّت سليمى. وقال السكّري في شرح قول القتّال الكلابي:</div><div>عفت أجلى من أهلها فقليبها ... إلى الدّوم، فالرّنقاء قفرا كثيبها</div><br>أجلى: هضبة بأعلى نجد. وقال محمد بن زياد الأعرابي:<br>سئلت بنت الحسن: أيّ البلاد أفضل مرعى وأسمن؟<br>فقالت: خياشيم الحزم أو جواء الصّمّان. قيل لها:<br>ثم ماذا؟ فقالت: أراها أجلى أنّى شئت، أي متى شئت بعد هذا. قال ويقال: إن أجلى موضع في طريق البصرة إلى مكة."}]}}