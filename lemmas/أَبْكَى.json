تَبْكِيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْكُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْكُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْكِيْنَ","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْك","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَبْكَى","in_corpus":true,"count":19,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَبْكِي","in_corpus":true,"count":16,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْك","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَبْكَى","in_corpus":true,"count":28,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَبْكِي","in_corpus":true,"count":21,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْكِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْكِيانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْكِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْكِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْكُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْكُونَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْكِيْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَبْك","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْك","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"بَكَيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَكَيْتُ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْكَى","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْكَى","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبْكِي","in_corpus":true,"count":17,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْكِي","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":275,"cross_references":{"qac":{"found":true,"lemma_key":"أَبْكَى","root":"بكي","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n3092"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D9%92%D9%83%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"masculine plural of بَاكٍ (bākin)","tags":["form-of","masculine","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3092","headword_ar":"بَكَى","root":"bkY","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"bukaA='N","text_ar":"بُكَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bukFA","text_ar":"بُكًا"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"mabokFY","text_ar":"مَبْكًى"},{"kind":"text","text":", (Har p. 11,)"},{"kind":"italic_en","text":"He wept; i. e. he lamented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grieved, shedding tears at the same time;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he lamented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grieved,"},{"kind":"text","text":"alone; and"},{"kind":"italic_en","text":"he shed tears"},{"kind":"text","text":"alone: (Er-Rághib, TA:) accord. to some, the preferable opinion is, that there is no difference between"},{"kind":"arabic","text_bw":"bukaA='u","text_ar":"بُكَا=ءُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bukFA","text_ar":"بُكًا"},{"kind":"text","text":": (TA:) or the former means the"},{"kind":"italic_en","text":"crying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uttering of the voice"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of lamentation"},{"kind":"text","text":"], (S, IKtt, Msb, TA, &c.,)"},{"kind":"italic_en","text":"that accompanies"},{"kind":"arabic","text_bw":"AlbukaA='","text_ar":"البُكَا=ء"},{"kind":"text","text":"[so in copies of the S and in the TA, but correctly"},{"kind":"arabic","text_bw":"AlbukaA","text_ar":"البُكَا"},{"kind":"text","text":"]; (S, IKtt, TA;) and the latter ("},{"kind":"arabic","text_bw":"bukFA","text_ar":"بُكًا"},{"kind":"text","text":"), the"},{"kind":"italic_en","text":"shedding of tears:"},{"kind":"text","text":"(S, IKtt, Msb, TA, &c.:) or the former, i. e. with medd, means the"},{"kind":"italic_en","text":"shedding of tears by reason of lamentation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief, and raising of the voice, or crying,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at the same time,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when the voice is predominant,"},{"kind":"text","text":"being like"},{"kind":"arabic","text_bw":"rugaA='N","text_ar":"رُغَا=ءٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"vugaA='N","text_ar":"ثُغَا=ءٌ"},{"kind":"text","text":"and other words of the same form applied to denote the uttering of a cry or of the voice; and the latter, [the"},{"kind":"italic_en","text":"shedding of tears &c."},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when lamentation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief, is predominant:"},{"kind":"text","text":"(Er-Rághib, TA:) or by the former is meant the"},{"kind":"italic_en","text":"crying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uttering of the voice"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of lamentation"},{"kind":"text","text":"]; and by the latter, the"},{"kind":"italic_en","text":"lamenting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grieving."},{"kind":"text","text":"(Kh, TA.)"},{"kind":"arabic","text_bw":"tabokaA='N","text_ar":"تَبْكَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tibokaA='N","text_ar":"تِبْكَا=ءٌ"},{"kind":"text","text":"[may be inf. ns. of"},{"kind":"arabic","text_bw":"bakaY","text_ar":"بَكَى"},{"kind":"text","text":"or of ↓"},{"kind":"arabic","text_bw":"bak~aY","text_ar":"بَكَّى","orth_type":"arrow"},{"kind":"text","text":", and] signify"},{"kind":"italic_en","text":"the same as"},{"kind":"arabic","text_bw":"bukaA='N","text_ar":"بُكَا=ءٌ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"much"},{"kind":"arabic","text_bw":"bukaA'","text_ar":"بُكَاء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"weeping,"},{"kind":"text","text":"&c.]: (K:) MF asserts that"},{"kind":"arabic","text_bw":"tibokaA='N","text_ar":"تِبْكَا=ءٌ"},{"kind":"text","text":"(with kesr) and the former of these explanations are unknown; but both the word and the explanation are mentioned by Lh, as used in a form of words uttered by Arab women of the desert to fascinate men: ISd, however, says that it should be"},{"kind":"arabic","text_bw":"tabokaA='","text_ar":"تَبْكَا=ء"},{"kind":"text","text":", because it is an inf. n. of a class formed to denote muchness [of the attribute signified by the verb], like"},{"kind":"arabic","text_bw":"taho*aArN","text_ar":"تَهْذَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taloEaAbN","text_ar":"تَلْعَابٌ"},{"kind":"text","text":"&c.; and IAar says that"},{"kind":"arabic","text_bw":"tabokaA'N","text_ar":"تَبْكَاءٌ"},{"kind":"text","text":", with fet-h, has the latter of the two significations assigned to it above. (TA.) [See what is said of the measure"},{"kind":"arabic","text_bw":"tifoEaAlN","text_ar":"تِفْعَالٌ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"bay~ana","text_ar":"بَيَّنَ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"bakaY lahu","text_ar":"بَكَى لَهُ"},{"kind":"text","text":"(MF, TA) and"},{"kind":"arabic","text_bw":"bakaY Ealayohi","text_ar":"بَكَى عَلَيْهِ"},{"kind":"text","text":", (S, Msb, K, MF,) meaning ["},{"kind":"italic_en","text":"He wept"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and only"},{"kind":"arabic","text_bw":"bakaY bihi","text_ar":"بَكَى بِهِ"},{"kind":"text","text":"[or thus and also"},{"kind":"arabic","text_bw":"bakaYminohu","text_ar":"بَكَىمِنْهُ"},{"kind":"text","text":"as appears from what follows] when meaning ["},{"kind":"italic_en","text":"He wept"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"because,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in consequence, of it:"},{"kind":"text","text":"('Ináyeh, MF, TA:) and"},{"kind":"arabic","text_bw":"bakaAhu","text_ar":"بَكَاهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bak~aAhu","text_ar":"بَكَّاهُ","orth_type":"arrow"},{"kind":"text","text":", (As, AZ, S, Msb, K,) inf. n. of the former"},{"kind":"arabic","text_bw":"bukaA='N","text_ar":"بُكَا=ءٌ"},{"kind":"text","text":"(K) [and"},{"kind":"arabic","text_bw":"bukFA","text_ar":"بُكًا"},{"kind":"text","text":"], and of the latter"},{"kind":"arabic","text_bw":"tabokiyapN","text_ar":"تَبْكِيَةٌ"},{"kind":"text","text":", (TA,) signify"},{"kind":"italic_en","text":"the same as"},{"kind":"arabic","text_bw":"bakaY","text_ar":"بَكَى"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"; (As, AZ, S, Msb, * K;) the object being a man: (As, S:) and (or as some say, TA)"},{"kind":"italic_en","text":"he wept for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over, him,"},{"kind":"text","text":"i. e., one dead; or"},{"kind":"italic_en","text":"did so, and enumerated his good qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"actions;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ravaAhu","text_ar":"رَثَاهُ"},{"kind":"text","text":": (K:) or, as some say,"},{"kind":"arabic","text_bw":"bakaAhu","text_ar":"بَكَاهُ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"he wept because,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in consequence, of it,"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"on account of being pained:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bakaY Ealayohi","text_ar":"بَكَى عَلَيْهِ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"he wept for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over, him,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by reason of tenderness of heart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion:"},{"kind":"text","text":"and [hence] it is said that"},{"kind":"arabic","text_bw":"bakayotuhu","text_ar":"بَكَيْتُهُ"},{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"bakayotu minohu","text_ar":"بَكَيْتُ مِنْهُ"},{"kind":"text","text":": (TA:) [and ↓"},{"kind":"arabic","text_bw":"bak~aAhu","text_ar":"بَكَّاهُ","orth_type":"arrow"},{"kind":"text","text":"may have an intensive, or a frequentative, meaning; for it is said that]"},{"kind":"arabic","text_bw":"bak~iY","text_ar":"بَكِّى"},{"kind":"text","text":", addressed to the eye, signifies"},{"kind":"italic_en","text":"weep thou much,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"repeatedly."},{"kind":"text","text":"(Ham p. 461.) ―         -b2- [Hence,]"},{"kind":"arabic","text_bw":"bakat Als~aHaAbapu","text_ar":"بَكَت السَّحَابَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The cloud rained."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"bakaY","text_ar":"بَكَى"},{"kind":"text","text":"also means"},{"kind":"italic_en","text":"He sang:"},{"kind":"text","text":"[in the CK,"},{"kind":"arabic","text_bw":"wbakaY Ean~iY","text_ar":"وبَكَى عَنِّى"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"wbakaY gan~aY","text_ar":"وبَكَى غَنَّى"},{"kind":"text","text":":] thus it has two contr. significations: (K, TA:) accord. to MF, it has this meaning only in relation to the pigeon and the like; but it is also used in this sense when said of a man, as in a verse cited voce"},{"kind":"arabic","text_bw":"janaAzapN","text_ar":"جَنَازَةٌ"},{"kind":"text","text":", q. v. : and he observes that the assertion of its having two contr significations requires consideration, seeing that it is also said to signify"},{"kind":"arabic","text_bw":"ravaY","text_ar":"رَثَى"},{"kind":"text","text":"; [for in the performance of"},{"kind":"arabic","text_bw":"rivaA='","text_ar":"رِثَا=ء"},{"kind":"text","text":", it is a common practice to sing;] but"},{"kind":"arabic","text_bw":"rivaA='","text_ar":"رِثَا=ء"},{"kind":"text","text":"is generally accompanied by lamentation, and"},{"kind":"arabic","text_bw":"ginaA='","text_ar":"غِنَا=ء"},{"kind":"text","text":"by rejoicing. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"baAkayotuhu fabakayotuhu","text_ar":"بَاكَيْتُهُ فَبَكَيْتُهُ"},{"kind":"text","text":": see 3."}],"source_refs":["Msb","K","S","TA","MF","As","AZ"]}]}}