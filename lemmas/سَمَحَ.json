,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسْمَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسْمَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْمَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْمَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسْمَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسْمَحُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْمَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْمَحُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسْمَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَسْمَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سَمَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَمَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُسْمَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُسْمَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسْمَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْمَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n20638","","n20641","n20642"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%85%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to allow, to permit (لِ (li) someone) (بِ (bi) something / أَن (ʔan) to do something)"},{"pos":"verb","gloss":"to be magnanimous, to be generous , (particularly with verbal noun سَمْح samḥ)"},{"pos":"verb","gloss":"act kindly"},{"pos":"verb","gloss":"walk with a light and noiseless step"},{"pos":"verb","gloss":"straighten"},{"pos":"noun","gloss":"verbal noun of سَمُحَ (samuḥa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"magnanimity"},{"pos":"adj","gloss":"magnanimous, generous"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20638","headword_ar":"سَمُحَ","root":"smH","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"samaAHN","text_ar":"سَمَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samaAHapN","text_ar":"سَمَاحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sumuwHN","text_ar":"سُمُوحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sumuwHapN","text_ar":"سُمُوحَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samoHN","text_ar":"سَمْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"simaAHN","text_ar":"سِمَاحٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous;"},{"kind":"text","text":"(S, * Msb, * K;) as also ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":": (Msb, K:) but the unaugmented verb commonly known, but faultily omitted in the K, is"},{"kind":"arabic","text_bw":"samaHa","text_ar":"سَمَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and this is the only one mentioned by IKtt and IKoot and a number of other authors:"},{"kind":"arabic","text_bw":"samuHa","text_ar":"سَمُحَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"karuma","text_ar":"كَرُمَ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"he became of the people of"},{"kind":"arabic","text_bw":"Als~amaAHap","text_ar":"السَّمَاحَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"liberality,"},{"kind":"text","text":"&c.]: (MF:) [but]"},{"kind":"arabic","text_bw":"samaHa","text_ar":"سَمَحَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":"both signify as above;"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, liberal,"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"he gave from a motive of generosity and liberality:"},{"kind":"text","text":"this is the correct explanation of both; though some say that the former only is used in this sense; and the latter, in relation to compliance and submissiveness. (L.) You say,"},{"kind":"arabic","text_bw":"samaHa bihi","text_ar":"سَمَحَ بِهِ"},{"kind":"text","text":", (S, A, Msb,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"samaAHN","text_ar":"سَمَاحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"samaAHapN","text_ar":"سَمَاحَةٌ"},{"kind":"text","text":"(S, * A, * Msb) and"},{"kind":"arabic","text_bw":"sumuwHN","text_ar":"سُمُوحٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He was liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous, with it;"},{"kind":"text","text":"(S, A, Msb;) and"},{"kind":"italic_en","text":"gave it;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"complied therein with that which was desired of him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":". (Msb.) [And"},{"kind":"arabic","text_bw":"samaHa lahu","text_ar":"سَمَحَ لَهُ"},{"kind":"italic_en","text":"He was liberal,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":"; whence,] God is represented, in a trad., as saying,"},{"kind":"arabic","text_bw":"liEabodiY","text_ar":"لِعَبْدِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asomiHuwA","text_ar":"اَسْمِحُوا","orth_type":"arrow"},{"kind":"arabic","text_bw":"kaA_isomaAHihi A_ilaY EibaAdiY","text_ar":"كَاـِسْمَاحِهِ اـِلَى عِبَادِى"},{"kind":"italic_en","text":"Be ye liberal,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to my servant,"},{"kind":"text","text":"[meaning Mohammad,]"},{"kind":"italic_en","text":"like as he is liberal,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to my servants."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"samaHa liY","text_ar":"سَمَحَ لِى"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He gave"},{"kind":"text","text":"(S, A)"},{"kind":"italic_en","text":"to me,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"to him:"},{"kind":"text","text":"(A:) and"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"saAmaHahu","text_ar":"سَامَحَهُ","orth_type":"arrow"},{"kind":"italic_en","text":"he gave him such a thing."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"samaHa liY bi*`lika","text_ar":"سَمَحَ لِى بِذٰلِكَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sAmH","text_ar":"سامح","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He complied with my desire in that thing."},{"kind":"text","text":"(L: see also a similar phrase below.) ―         -b2-"},{"kind":"arabic","text_bw":"samaHato","text_ar":"سَمَحَتْ"},{"kind":"text","text":", said of a she-camel, means"},{"kind":"italic_en","text":"She became submissive, and went quickly:"},{"kind":"text","text":"(L:) and ↓"},{"kind":"arabic","text_bw":"AsmHt","text_ar":"اسمحت","orth_type":"arrow"},{"kind":"text","text":"said of a beast ("},{"kind":"arabic","text_bw":"daAb~ap","text_ar":"دَابَّة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"it became gentle and submissive after being refractory:"},{"kind":"text","text":"(L, K: *) and in like manner ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":"; (A;) and ↓"},{"kind":"arabic","text_bw":"sm~H","text_ar":"سمّح","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tasomiyHN","text_ar":"تَسْمِيحٌ"},{"kind":"text","text":"; (L;) said of a camel: (A, L:) or"},{"kind":"arabic","text_bw":"tasomiyHN","text_ar":"تَسْمِيحٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"going an easy pace:"},{"kind":"text","text":"(S, L, K:) and the"},{"kind":"italic_en","text":"going quickly:"},{"kind":"text","text":"(L, K:) or (so in the L, but in the K “ and ”) the act of"},{"kind":"italic_en","text":"fleeing."},{"kind":"text","text":"(L, K.) And ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"italic_en","text":"It became easy and submissive."},{"kind":"text","text":"(L.) You say,"},{"kind":"arabic","text_bw":"qaruwnatuhu","text_ar":"قَرُونَتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asomaHato","text_ar":"اَسْمَحَتْ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) and"},{"kind":"arabic","text_bw":"qariynatuhu","text_ar":"قَرِينَتُهُ"},{"kind":"text","text":", as also ↓"},{"kind":"arabic","text_bw":"saAmaHato","text_ar":"سَامَحَتْ","orth_type":"arrow"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"His mind became submissive,"},{"kind":"text","text":"(S, A, L, K,)"},{"kind":"arabic","text_bw":"li*`lika AlA^amori","text_ar":"لِذٰلِكَ الاَمْرِ"},{"kind":"italic_en","text":"to that thing."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"samaHa","text_ar":"سَمَحَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"samaAHN","text_ar":"سَمَاحٌ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"sm~H","text_ar":"سمّح","orth_type":"arrow"},{"kind":"text","text":", (Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"tasomiyHN","text_ar":"تَسْمِيحٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"sAmH","text_ar":"سامح","orth_type":"arrow"},{"kind":"text","text":", (Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"musaAmaHapN","text_ar":"مُسَامَحَةٌ"},{"kind":"text","text":"; (S, A, L, K;) and ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":", (Mgh,) and ↓"},{"kind":"arabic","text_bw":"tsm~H","text_ar":"تسمّح","orth_type":"arrow"},{"kind":"text","text":"; (L;) also signify"},{"kind":"italic_en","text":"He acted in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gentle, manner;"},{"kind":"text","text":"(S, A, Mgh, L, K;) and"},{"kind":"italic_en","text":"he made easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"facilitated;"},{"kind":"text","text":"(L;)"},{"kind":"arabic","text_bw":"fiY A^amorK","text_ar":"فِى اَمْرٍ"},{"kind":"italic_en","text":"in an affair:"},{"kind":"text","text":"(Mgh, L:) and ↓"},{"kind":"arabic","text_bw":"musaAmaHapN","text_ar":"مُسَامَحَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"acting in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gentle, manner"},{"kind":"text","text":"in a contest in thrusting, or piercing, with spears or the like, and smiting with swords, and running. (L.) It is said in a well-known trad.,"},{"kind":"arabic","text_bw":"Als~amaAHu rabaAHN","text_ar":"السَّمَاحُ رَبَاحٌ"},{"kind":"italic_en","text":"The acting in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gentle, manner,"},{"kind":"text","text":"in affairs,"},{"kind":"italic_en","text":"is"},{"kind":"text","text":"a means of"},{"kind":"italic_en","text":"gain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"profit,"},{"kind":"text","text":"to the performer thereof. (L.) And you say,"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"sAmHhu","text_ar":"سامحهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He acted in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gentle, manner with him."},{"kind":"text","text":"(TK.) And"},{"kind":"arabic","text_bw":"samaHa lahu","text_ar":"سَمَحَ لَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"[a thing]"},{"kind":"italic_en","text":"easy to him."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"AisomaHo yusomaHo laka","text_ar":"اِسْمَحْ يُسْمَحْ لَكَ"},{"kind":"text","text":"(Meyd, Mgh, L) and"},{"kind":"arabic","text_bw":"bika","text_ar":"بِكَ"},{"kind":"text","text":", (L,) and"},{"kind":"arabic","text_bw":"yusomaHo laka","text_ar":"يُسْمَحْ لَكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^asomiHo","text_ar":"اَسْمِحْ","orth_type":"arrow"},{"kind":"text","text":"(Meyd, L) and"},{"kind":"arabic","text_bw":"bika","text_ar":"بِكَ"},{"kind":"text","text":", (L,) a trad., (Mgh, L,) meaning"},{"kind":"italic_en","text":"Facilitate thou,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"facilitation shall be rendered to thee:"},{"kind":"text","text":"(As, Sh, L:) or"},{"kind":"italic_en","text":"act thou in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a gentle, manner,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gentle, treatment, shall be rendered to thee:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"be thou compliant,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"compliance shall be rendered to thee."},{"kind":"text","text":"(Meyd.) And"},{"kind":"arabic","text_bw":"samaHa lahu biHaAjatihi","text_ar":"سَمَحَ لَهُ بِحَاجَتِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AsmH","text_ar":"اسمح","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made easy to him the object of his want."},{"kind":"text","text":"(IAar, L: see also a similar phrase above.) ―         -b4-"},{"kind":"arabic","text_bw":"samaAHapN","text_ar":"سَمَاحَةٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"sumuwHapN","text_ar":"سُمُوحَةٌ"},{"kind":"text","text":", (TA,) [app. inf. ns. of which the verb is"},{"kind":"arabic","text_bw":"samuHa","text_ar":"سَمُحَ"},{"kind":"text","text":",] in a branch, or rod, signify (tropical:)  The"},{"kind":"italic_en","text":"being even and smooth, without any knots"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"inequality of thickness:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"samoHN","text_ar":"سَمْحٌ"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","Msb","K","MF","A","L","Mgh","Meyd","As","Sh","TA"]},{"entry_id":"n20641","headword_ar":"سَمْحٌ","root":"smH","body":[{"kind":"text","text":"(T, S, A, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"samiHN","text_ar":"سَمِحٌ","orth_type":"arrow"},{"kind":"text","text":", of which the former is a contraction, (Msb,) [but which is seldom used,] as also ↓"},{"kind":"arabic","text_bw":"samiyHN","text_ar":"سَمِيحٌ","orth_type":"arrow"},{"kind":"text","text":"and [in an intensive sense] ↓"},{"kind":"arabic","text_bw":"misomaHN","text_ar":"مِسْمَحٌ","orth_type":"arrow"},{"kind":"text","text":"(T, M, TA) and ↓"},{"kind":"arabic","text_bw":"misomaAHN","text_ar":"مِسْمَاحٌ","orth_type":"arrow"},{"kind":"text","text":"(T, S, * M, A, * K, * TA) [and ↓"},{"kind":"arabic","text_bw":"samuwHN","text_ar":"سَمُوحٌ","orth_type":"arrow"},{"kind":"text","text":", occurring in the K voce"},{"kind":"arabic","text_bw":"naEuwsN","text_ar":"نَعُوسٌ"},{"kind":"text","text":", the last three fem. as well as masc.],"},{"kind":"italic_en","text":"Liberal, bountiful, munificent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"generous:"},{"kind":"text","text":"(T, S, M, A, Mgh, Msb, K, TA:) fem."},{"kind":"arabic","text_bw":"samoHapN","text_ar":"سَمْحَةٌ"},{"kind":"text","text":": (T, S, M, A, K:) pl."},{"kind":"arabic","text_bw":"simaAHN","text_ar":"سِمَاحٌ"},{"kind":"text","text":", (Th, T, S, M, A, Msb, K,) applied to women (Th, S, Msb, K) only, (Th, S, K,) or to men and to women, (T, M, TA,) and"},{"kind":"arabic","text_bw":"sumaHaA='u","text_ar":"سُمَحَا=ءُ"},{"kind":"text","text":", (T, S, M, A, Msb, K,) applied to a party of people, (S, A,) [i. e.] to men and to women, (T, M, TA,) as though pl. of"},{"kind":"arabic","text_bw":"samiyHN","text_ar":"سَمِيحٌ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"masaAmiyHu","text_ar":"مَسَامِيحُ"},{"kind":"text","text":", (T, S, M, A, K,) applied to men and to women, (T, M, A, *) pl. of"},{"kind":"arabic","text_bw":"misomaAHN","text_ar":"مِسْمَاحٌ"},{"kind":"text","text":", (A,) or as though pl. of"},{"kind":"arabic","text_bw":"misomaAHN","text_ar":"مِسْمَاحٌ"},{"kind":"text","text":". (S, K.) The dim. of"},{"kind":"arabic","text_bw":"samoHN","text_ar":"سَمْحٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"sumayoHN","text_ar":"سُمَيْحٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sumay~iHN","text_ar":"سُمَيِّحٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) but the latter is by some disallowed. (TA.) You say also,"},{"kind":"arabic","text_bw":"fulaAnN samoHN lamoHN","text_ar":"فُلَانٌ سَمْحٌ لَمْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lamiyHN","text_ar":"لَمِيحٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"samiyHN","text_ar":"سَمِيحٌ","orth_type":"arrow"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"Such a one is very liberal,"},{"kind":"text","text":"&c.; for in each case the latter epithet is probably an imitative sequent, and therefore a corroborative]. (L.) ―         -b2-"},{"kind":"arabic","text_bw":"daAb~apN samoHapN","text_ar":"دَابَّةٌ سَمْحَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A beast that is submissive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gentle:"},{"kind":"text","text":"and probably also"},{"kind":"italic_en","text":"quick:"},{"kind":"text","text":"see 1]. (A, voce"},{"kind":"arabic","text_bw":"jamoHapN","text_ar":"جَمْحَةٌ"},{"kind":"text","text":", q. v.) ―         -b3-  [Hence, app.,]"},{"kind":"arabic","text_bw":"samoHapu","text_ar":"سَمْحَةُ"},{"kind":"text","text":"is the name of"},{"kind":"italic_en","text":"A mare of Jaafar the son of Aboo-Tálib."},{"kind":"text","text":"(K. [See also"},{"kind":"arabic","text_bw":"saboHap","text_ar":"سَبْحَة"},{"kind":"text","text":".]) ―         -b4-  And"},{"kind":"arabic","text_bw":"A^um~u samoHapa","text_ar":"اُمُّ سَمْحَةَ"},{"kind":"italic_en","text":"The she-goat."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":".) ―         -b5-  And"},{"kind":"arabic","text_bw":"qawosN samoHapN","text_ar":"قَوْسٌ سَمْحَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A pliant bow."},{"kind":"text","text":"(K, * TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"EuwdN samoHN","text_ar":"عُودٌ سَمْحٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A branch,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rod, that is even and smooth,"},{"kind":"text","text":"(A, * Msb, * TA,)"},{"kind":"italic_en","text":"without any knot:"},{"kind":"text","text":"(A, K, TA:) or"},{"kind":"italic_en","text":"of even growth, so that what is between its two extremities is not more slender than its two extremities or than one of them."},{"kind":"text","text":"(AHn, TA.) One says also"},{"kind":"arabic","text_bw":"saAjapN","text_ar":"سَاجَةٌ"},{"kind":"arabic","text_bw":"samoHapN","text_ar":"سَمْحَةٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"An oblong squared piece,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a board"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tablet, of the wood of the"},{"kind":"arabic","text_bw":"sAj","text_ar":"ساج"},{"kind":"text","text":"(q. v.),"},{"kind":"italic_en","text":"that is even and smooth"},{"kind":"text","text":"]. (TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"mil~apN samoHapN","text_ar":"مِلَّةٌ سَمْحَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A religion in which is no straitness"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"nor difficulty."},{"kind":"text","text":"(TA.) ―         -b8-  The saying of 'Omar Ibn-'AbdEl-'Azeez"},{"kind":"arabic","text_bw":"A^a*~ino A^a*aAnFA samoHFA","text_ar":"اَذِّنْ اَذَانًا سَمْحًا"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"Recite thou a call to prayer"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without a prolonging of the voice, and trilling,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"without modulation."},{"kind":"text","text":"(Mgh.)"}],"source_refs":["T","S","A","Mgh","Msb","K","M","TA","Th"]},{"entry_id":"n20642","headword_ar":"سَمِحٌ","root":"smH","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]}]},"classical_definitions":null}