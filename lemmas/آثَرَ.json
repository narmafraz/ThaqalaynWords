{"lemma":"آثَرَ","slug":"آثَرَ","root":"#.ث.ر","root_slug":"_-ث-ر","root_link":"/words/roots/_-ث-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"آثَرْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"آثَرْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"آثَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"آثَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"آثَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"آثَرَ","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"آثَرَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"آثَرا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"آثَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"آثَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"آثَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُؤْثِر","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُؤْثِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤْثِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُؤْثِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُؤْثِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُؤْثِرُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُؤْثِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُؤْثِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُؤْثِر","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُؤْثِر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُؤْثِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُؤْثِرا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤْثِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤْثِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤْثِرُونَ","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤْثِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤْثِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"آثَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"آثَرْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤْثِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوثِر","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":37,"cross_references":{"qac":{"found":true,"lemma_key":"آثَرَ","root":"أثر","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["prep"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n194","n195","n196","n197","n198","n201","n199","n200"],"search_url":"https://lanelexicon.com/?s=%D8%A2%D8%AB%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"prep","gloss":"following on, immediately after","examples":[{"text":"تَحَوَّلَتِ الْبِنَايَةُ إِلَى أَنْقَاضٍ إِثْرَ الْغَارَةِ.","english":"The building turned into rubble following the raid."}]}]},"etymology":{"source":"wiktextract","text":"Adverbial accusative of a form of أَثَر (ʔaṯar, “track, trace”); approximate meaning \"on (its) track\"."},"ipa":["/ʔiθ.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n194","headword_ar":"اَثْرٌ","root":"Avr","body":[{"kind":"text","text":", (AZ, T, S, A, L, K, &c.,) said by Yaakoob to be the only form known to As, (S,) and ↓"},{"kind":"arabic","text_bw":"A^avarN","text_ar":"اَثَرٌ","orth_type":"arrow"},{"kind":"text","text":", which is a form used by poetic licence, (M, L,) and ↓"},{"kind":"arabic","text_bw":"A^vorapN","text_ar":"اثْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, L, K,) and ↓"},{"kind":"arabic","text_bw":"A^uvurN","text_ar":"اُثُرٌ","orth_type":"arrow"},{"kind":"text","text":", (M,) and ↓"},{"kind":"arabic","text_bw":"A^uvurN","text_ar":"اُثُرٌ","orth_type":"arrow"},{"kind":"text","text":", which is in like manner a sing., not a pl., (T, L,) and ↓"},{"kind":"arabic","text_bw":"A^vorapN","text_ar":"اثْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (El-Leblee,) and ↓"},{"kind":"arabic","text_bw":"A^aviyro","text_ar":"اَثِيرْ","orth_type":"arrow"},{"kind":"text","text":", (K,) The"},{"kind":"italic_en","text":"diversified wavy marks, streaks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grain,"},{"kind":"text","text":"of a sword; syn."},{"kind":"arabic","text_bw":"firinodN","text_ar":"فِرِنْدٌ"},{"kind":"text","text":"; (As, T, S, M, A, L, K;) and"},{"kind":"arabic","text_bw":"tasalosulN","text_ar":"تَسَلْسُلٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"diybaAjapu","text_ar":"دِيبَاجَةُ"},{"kind":"text","text":"; (AZ, T;) and its"},{"kind":"italic_en","text":"lustre,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glitter:"},{"kind":"text","text":"(M, L:) pl. [of the first]"},{"kind":"arabic","text_bw":"A^uvuro","text_ar":"اُثُرْ"},{"kind":"text","text":": (T, M, L, K:) the pl. of"},{"kind":"arabic","text_bw":"A^uvorapN","text_ar":"اُثْرَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^uvarN","text_ar":"اُثَرٌ"},{"kind":"text","text":". (El-Leblee.) Khufáf Ibn-Nudbeh Es-Sulamee says, [describing swords,]"},{"kind":"quote","text":"jalaAhaA AlS~ayoqaluwna faA_axolaSuwhaA\n                      \n                     \n                        xifaAfAF kul~uhaA yatoqiY biA^avori"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The furbishers polished them, and freed them from impurities,"},{"kind":"text","text":"making them"},{"kind":"italic_en","text":"light: each of them preserving itself"},{"kind":"text","text":"from the evil eye"},{"kind":"italic_en","text":"by means of"},{"kind":"text","text":"its"},{"kind":"italic_en","text":"lustre"},{"kind":"text","text":"]: i. e., each of them opposes to thee its"},{"kind":"arabic","text_bw":"firinod","text_ar":"فِرِنْد"},{"kind":"text","text":": (S, L:)"},{"kind":"arabic","text_bw":"yatoqiY","text_ar":"يَتْقِى"},{"kind":"text","text":"is a contraction of"},{"kind":"arabic","text_bw":"yat~aqiY","text_ar":"يَتَّقِى"},{"kind":"text","text":"; and the meaning is, when a person looks at them, their bright rays meet his eye, so that he cannot continue to look at them. (L.)"}],"source_refs":["S","M","L","K","T"]},{"entry_id":"n195","headword_ar":"اُثْرٌ","root":"Avr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"scar of a wound, remaining when the latter has healed;"},{"kind":"text","text":"(As, Sh, T, S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"A^uvurN","text_ar":"اُثُرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"A^avarN","text_ar":"اَثَرٌ","orth_type":"arrow"},{"kind":"text","text":": (Sh, T:) pl."},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":", though properly"},{"kind":"arabic","text_bw":"A_ivaArN","text_ar":"اـِثَارٌ"},{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"[but why this is said, I do not see; for"},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":"is a regular pl. of all the three forms of the sing.;] and"},{"kind":"arabic","text_bw":"A_uvuwrN","text_ar":"اـُثُورٌ"},{"kind":"text","text":"may be correctly used as a pl. (Sh, T, L.)       -A2-"},{"kind":"italic_en","text":"A mark made with a hot iron upon the inner"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"under"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"part of a camel's foot, by which to trace his footprints:"},{"kind":"text","text":"(M, K:) pl."},{"kind":"arabic","text_bw":"A^uvuwrN","text_ar":"اُثُورٌ"},{"kind":"text","text":". (M.) [See also"},{"kind":"arabic","text_bw":"A^uvorapN","text_ar":"اُثْرَةٌ"},{"kind":"text","text":".]       -A3-"},{"kind":"italic_en","text":"Lustre,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brightness,"},{"kind":"text","text":"of the face; as also ↓"},{"kind":"arabic","text_bw":"A^uvurN","text_ar":"اُثُرٌ","orth_type":"arrow"},{"kind":"text","text":". (M, K.)       -A4-  See"},{"kind":"arabic","text_bw":"A^avorN","text_ar":"اَثْرٌ"},{"kind":"text","text":".       -A5-  See also"},{"kind":"arabic","text_bw":"A_ivorN","text_ar":"اـِثْرٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","Sh","T","M"]},{"entry_id":"n196","headword_ar":"اـِثْرٌ","root":"Avr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^avarN","text_ar":"اَثَرٌ"},{"kind":"text","text":", in three places: ―         -b2-  and"},{"kind":"arabic","text_bw":"A^avorN","text_ar":"اَثْرٌ"},{"kind":"text","text":": ―         -b3-  and see"},{"kind":"arabic","text_bw":"A=virN","text_ar":"ا=ثِرٌ"},{"kind":"text","text":", in two places.       -A2-  Also, (S, M, K,) and ↓"},{"kind":"arabic","text_bw":"A^uvorN","text_ar":"اُثْرٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) but the latter is disallowed by more than one authority, (TA,)"},{"kind":"italic_en","text":"What is termed the"},{"kind":"arabic","text_bw":"xulaASap","text_ar":"خُلَاصَة"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"of clarified butter:"},{"kind":"text","text":"(S, M, K:) or, as some say, the"},{"kind":"italic_en","text":"milk when the clarified butter has become separated from it."},{"kind":"text","text":"(M.) [See also"},{"kind":"arabic","text_bw":"qi$odapN","text_ar":"قِشْدَةٌ"},{"kind":"text","text":".]"}],"source_refs":["S","M","K","TA"]},{"entry_id":"n197","headword_ar":"اَثَرٌ","root":"Avr","body":[{"kind":"italic_en","text":"A remain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relic,"},{"kind":"text","text":"of a thing; (M, Msb, K;) as of a house; as also ↓"},{"kind":"arabic","text_bw":"A^avaArapN","text_ar":"اَثَارَةٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb:)"},{"kind":"italic_en","text":"a trace remaining"},{"kind":"text","text":"of a thing; and of the stroke, or blow, of a sword: (S:) see also"},{"kind":"arabic","text_bw":"A^uvorN","text_ar":"اُثْرٌ"},{"kind":"text","text":":"},{"kind":"italic_en","text":"a sign, mark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trace;"},{"kind":"text","text":"opposed to the"},{"kind":"arabic","text_bw":"Eayon","text_ar":"عَيْن"},{"kind":"text","text":", or thing itself: (TA:)"},{"kind":"italic_en","text":"a footstep, vestige,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"track; a footprint;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"impression,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mark, made by the foot of a man"},{"kind":"text","text":"["},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon the ground;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A_ivorN","text_ar":"اـِثْرٌ","orth_type":"arrow"},{"kind":"text","text":": and"},{"kind":"italic_en","text":"an impress,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impression,"},{"kind":"text","text":"of anything: (El-Wá'ee:) pl."},{"kind":"arabic","text_bw":"A=vaArNH","text_ar":"ا=ثَارٌح"},{"kind":"text","text":"(M, Msb, K) and"},{"kind":"arabic","text_bw":"A_uvuwrN","text_ar":"اـُثُورٌ"},{"kind":"text","text":". (M, K.) [The sing. is also frequently used in a pl. sense: and the former of these pls. is often used to signify"},{"kind":"italic_en","text":"Remains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"monuments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"memorials, of anti-"},{"kind":"page_break","n":19},{"kind":"italic_en","text":"quity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of any past time."},{"kind":"text","text":"] It is said in a prov.,"},{"kind":"arabic","text_bw":"laA A^aTolubu A^avarFA baEoda EayonK","text_ar":"لَا اَطْلُبُ اَثَرًا بَعْدَ عَيْنٍ"},{"kind":"italic_en","text":"I will not seek a trace,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vestige,"},{"kind":"text","text":"[or, as we rather say in English,"},{"kind":"italic_en","text":"a shadow,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"after"},{"kind":"text","text":"suffering"},{"kind":"italic_en","text":"a reality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"substance,"},{"kind":"text","text":"to escape me: or, as some relate it,"},{"kind":"arabic","text_bw":"laA taTolubo","text_ar":"لَا تَطْلُبْ"},{"kind":"italic_en","text":"seek not thou."},{"kind":"text","text":"(Har pp. 120 and 174.) And one says,"},{"kind":"arabic","text_bw":"qaTaEa All~`hu A^avarahu","text_ar":"قَطَعَ اللّٰهُ اَثَرَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May God cut short his footsteps"},{"kind":"text","text":"]: meaning may"},{"kind":"italic_en","text":"God render him crippled:"},{"kind":"text","text":"for when one is crippled, his footsteps cease. (TA.) And"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"layaSoduqu A^avaruhu","text_ar":"لَيَصْدُقُ اَثَرُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^avarahu","text_ar":"اَثَرَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a one,"},{"kind":"text","text":"if asked,"},{"kind":"italic_en","text":"will not tell thee truly whence he comes:"},{"kind":"text","text":"(M in art."},{"kind":"arabic","text_bw":"Sdq","text_ar":"صدق"},{"kind":"text","text":":) a prov. said of a liar. (TA.) And"},{"kind":"arabic","text_bw":"xarajotu","text_ar":"خَرَجْتُ"},{"kind":"text","text":", (S, M, * K,) and"},{"kind":"arabic","text_bw":"jay^otu","text_ar":"جَيْتُ"},{"kind":"text","text":", (El-Wá'ee, Msb,)"},{"kind":"arabic","text_bw":"fyi A^avarihi","text_ar":"فيِ اَثَرِهِ"},{"kind":"text","text":", and ↓,"},{"kind":"arabic","text_bw":"fy A_ivorihi","text_ar":"في اـِثْرِهِ"},{"kind":"text","text":", (T, S, M, Msb, K,) the former of which is said by more than one to be the more chaste, (TA,) [but the latter seems to be the more common,] and"},{"kind":"arabic","text_bw":"EalaY A^avarihi","text_ar":"عَلَى اَثَرِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"ElY A_ivorihi","text_ar":"على اـِثْرِهِ","orth_type":"arrow"},{"kind":"text","text":", (El-Wá'ee, Msb,)"},{"kind":"italic_en","text":"I went out,"},{"kind":"text","text":"(S, &c.,) and"},{"kind":"italic_en","text":"I came,"},{"kind":"text","text":"(El-Wá'ee, Msb,)"},{"kind":"italic_en","text":"after him:"},{"kind":"text","text":"(M, A, K:) or"},{"kind":"italic_en","text":"at his heel:"},{"kind":"text","text":"(Expos. of the Fs:) or"},{"kind":"italic_en","text":"following near upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hard upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near after him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"following him nearly:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"as though treading in his footsteps."},{"kind":"text","text":"(El-Wá'ee.) And"},{"kind":"arabic","text_bw":"A^avara *iY A^aviyrayoni","text_ar":"اَثَرَ ذِى اَثِيرَيْنِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=virN","text_ar":"ا=ثِرٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"italic_en","text":"An impress"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impression, a mark, stamp, character,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trace, in a fig. sense; an effect."},{"kind":"text","text":"(The Lexicons passim.) You say,"},{"kind":"arabic","text_bw":"EalaY maA$iyatihi A^avarN HasanN","text_ar":"عَلَى مَاشِيَتِهِ اَثَرٌ حَسَنٌ"},{"kind":"italic_en","text":"Upon his camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, is an impress of a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition; of fatness, and of good tending;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"A_iSobaEN","text_ar":"اـِصْبَعٌ"},{"kind":"text","text":". (TA in art."},{"kind":"arabic","text_bw":"SbE","text_ar":"صبع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A_in~ahu laHasanu AlA^avarifiY","text_ar":"اـِنَّهُ لَحَسَنُ الاَثَرِفِى"},{"kind":"arabic","text_bw":"maAlihi","text_ar":"مَالِهِ"},{"kind":"italic_en","text":"Verily he has the impress of a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, in his camels,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"Hasanu AlA_iSobaEi","text_ar":"حَسَنُ الاـِصْبَعِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Almasi","text_ar":"المَسِ"},{"kind":"text","text":". (TA ubi suprà.) And"},{"kind":"arabic","text_bw":"Ealayohi A^avaru ka*aA","text_ar":"عَلَيْهِ اَثَرُ كَذَا"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, bears the mark, stamp, character,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trace, of such a thing."},{"kind":"text","text":"(The Lexicons passim.) ―         -b3-  [The pl.]"},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Signs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks, set up to show the way."},{"kind":"text","text":"(K.) ―         -b4-  Also the sing.,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^avorN","text_ar":"اَثْرٌ"},{"kind":"text","text":", q. v. (M, L.) ―         -b5-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xabarN","text_ar":"خَبَرٌ"},{"kind":"text","text":"[both of which words are generally held to be syn., as meaning"},{"kind":"italic_en","text":"A tradition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"narration relating or describing a saying or an action &c., of Mo- hammad"},{"kind":"text","text":"]: (M, K:) or, accord. to some, the former signifies"},{"kind":"italic_en","text":"what is related as received from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"one or more of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the Companions of Mohammad;"},{"kind":"text","text":"(TA;) but it may also be applied to"},{"kind":"italic_en","text":"a saying of the Prophet;"},{"kind":"text","text":"(Kull p. 152;) and the latter, what is from Mohammad himself; (TA;) or from another; or from him or another: (Kull p. 152:) or the former signifies"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"sun~apN","text_ar":"سُنَّةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a practice or saying,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"practices and sayings collectively, of Mo- hammad, or any other person who is an authority in matters of religion, namely, any prophet, or a Companion of Mohammad, as handed down by tradition"},{"kind":"text","text":"]: (S, A:) pl."},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":". (S, M.) You say,"},{"kind":"arabic","text_bw":"wajadotuhu fiy AlA^avari","text_ar":"وَجَدْتُهُ فِي الاَثَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I found it in the traditions of the practices and sayings of the Prophet; &c."},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"fulaAnN mino Hamalapi AlA=vaAri","text_ar":"فُلَانٌ مِنْ حَمَلَةِ الا=ثَارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is of those who bear in their memories, knowing by heart, the traditions of the practices and sayings of the Prophet;"},{"kind":"text","text":"&c.]. (A.) ―         -b6-  A man's"},{"kind":"italic_en","text":"origin;"},{"kind":"text","text":"as in the sayings,"},{"kind":"arabic","text_bw":"maA yudoraY lahu A^ayona A^avarN","text_ar":"مَا يُدْرَى لَهُ اَيْنَ اَثَرٌ"},{"kind":"italic_en","text":"It is not known where was his origin;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA yudoraY lahu maA A^varN","text_ar":"مَا يُدْرَى لَهُ مَا اثَرٌ"},{"kind":"italic_en","text":"It is not known what is his origin."},{"kind":"text","text":"(Ks, Lh, M.) ―         -b7-  The"},{"kind":"italic_en","text":"term,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"period, of life:"},{"kind":"text","text":"so called because it follows life: (Msb, TA:) or from the same word as signifying the print of one's foot upon the ground; because when one dies, his footprints cease to be seen. (TA.) ―         -b8-  [For the former of these two reasons,]"},{"kind":"arabic","text_bw":"A=vaArahumo","text_ar":"ا=ثَارَهُمْ"},{"kind":"text","text":"in the Kur xxxvi. 11 means"},{"kind":"italic_en","text":"The rewards and punishments of their good and evil lives."},{"kind":"text","text":"(M, L.)       -A2-"},{"kind":"arabic","text_bw":"A=vaArN","text_ar":"ا=ثَارٌ"},{"kind":"text","text":"is also a pl. of"},{"kind":"arabic","text_bw":"vaA^orN","text_ar":"ثَاْرٌ"},{"kind":"text","text":", q. v.; formed by transposition from"},{"kind":"arabic","text_bw":"A^avoA=rN","text_ar":"اَثْا=رٌ"},{"kind":"text","text":". (Yaa- Koob, and M in art."},{"kind":"arabic","text_bw":"vA^r","text_ar":"ثار"},{"kind":"text","text":".)"}],"source_refs":["Msb","S","TA","M","K","T","A"]},{"entry_id":"n198","headword_ar":"اَثُرٌ","root":"Avr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who chooses for himself"},{"kind":"text","text":"[in preference to his companions] (ISk, S, M, K)"},{"kind":"italic_en","text":"good things,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"in partition,"},{"kind":"text","text":"(M, TA,) or"},{"kind":"italic_en","text":"good actions, and qualities of the mind;"},{"kind":"text","text":"(ISk, S;) as also ↓"},{"kind":"arabic","text_bw":"A^avirN","text_ar":"اَثِرٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K.)"}],"source_refs":["ISk","S","M","K","TA"]},{"entry_id":"n201","headword_ar":"اَثُرٌ","root":"Avr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^avaArapN","text_ar":"اَثَارَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n199","headword_ar":"اَثِرٌ","root":"Avr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^avurN","text_ar":"اَثُرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n200","headword_ar":"اُثُرٌ","root":"Avr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^uvorN","text_ar":"اُثْرٌ"},{"kind":"text","text":", in two places: ―         -b2-  and see"},{"kind":"arabic","text_bw":"A^avorN","text_ar":"اَثْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}