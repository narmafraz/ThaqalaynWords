:"mHali","text_ar":"محَلِ"},{"kind":"text","text":"; the CK,"},{"kind":"arabic","text_bw":"maHal~i","text_ar":"مَحَلِّ"},{"kind":"text","text":"; and my MS. copy of the K,"},{"kind":"arabic","text_bw":"mHl","text_ar":"محل"},{"kind":"text","text":", without any vowel-sign and without the sheddeh:] from Ibn-'Abbád; (O;) and thus in the L. (TA.)"}],"source_refs":["O","K","TA"]},{"entry_id":"n28984","headword_ar":"عُزْلٌ","root":"Ezl","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n28985","headword_ar":"عَزَلٌ","root":"Ezl","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"Eazila","text_ar":"عَزِلَ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b2-  Also The"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, of not having with one any weapon;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"EuzolN","text_ar":"عُزْلٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA: [the latter, by reason of an ambiguity in the K, misunderstood by Freytag as syn. with"},{"kind":"arabic","text_bw":"EizaAlN","text_ar":"عِزَالٌ"},{"kind":"text","text":"in the sense in which this is expl. in the CK:]) they are two dial. vars., like"},{"kind":"arabic","text_bw":"$agalN","text_ar":"شَغَلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ugolN","text_ar":"شُغْلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"baxalN","text_ar":"بَخَلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buxolN","text_ar":"بُخْلٌ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A deficiency in one of the"},{"kind":"arabic","text_bw":"HaroqafataAni","text_ar":"حَرْقَفَتَانِ"},{"kind":"text","text":"[app. meaning,"},{"kind":"italic_en","text":"in the crest of one of the two hip-bones"},{"kind":"text","text":"]. (IAar, O, K.) ―         -b4-  And The"},{"kind":"italic_en","text":"hinder part"},{"kind":"text","text":"of an ass: so in the saying,"},{"kind":"arabic","text_bw":"AiqoraEo Eazala HimaArika","text_ar":"اِقْرَعْ عَزَلَ حِمَارِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Strike thou the binder part of thy ass"},{"kind":"text","text":"]: (O, K:) said to the driver of the ass. (O.)"}],"source_refs":["O","K"]},{"entry_id":"n28986","headword_ar":"عُزُلٌ","root":"Ezl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aEozalu","text_ar":"اَعْزَلُ"},{"kind":"text","text":", in three places."}],"source_refs":[]}]}}