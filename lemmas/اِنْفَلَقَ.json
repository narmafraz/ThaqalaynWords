s_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n34533"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D9%81%D9%8E%D9%84%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become split, to become cleft, to become cloven, to crack"}]},"etymology":null,"ipa":["/in.fa.la.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34533","headword_ar":"انفلق","root":"flq","body":[{"kind":"italic_en","text":"It became split, cleft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divided lengthwise; it split, clave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clave asunder;"},{"kind":"text","text":"(S, Mgh, O, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tfl~q","text_ar":"تفلّق","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, * K;) [or] the latter signifies"},{"kind":"arabic","text_bw":"ta$aq~aqa","text_ar":"تَشَقَّقَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"it became split,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in pieces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in several"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many places"},{"kind":"text","text":"]. (O, Msb.) The former occurs in the Kur xxvi. 63, said of the sea [as meaning"},{"kind":"italic_en","text":"It clave asunder"},{"kind":"text","text":"]. (O.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Anflq AlS~uboHu","text_ar":"انفلق الصُّبْحُ"},{"kind":"text","text":"(S and K in art."},{"kind":"arabic","text_bw":"ETs","text_ar":"عطس"},{"kind":"text","text":") and ↓"},{"kind":"arabic","text_bw":"tfl~q","text_ar":"تفلّق","orth_type":"arrow"},{"kind":"text","text":"(TA in the present art.)"},{"kind":"italic_en","text":"The dawn broke."},{"kind":"text","text":"(TA in explanation of the latter.)"}],"source_refs":[]}]},"classical_definitions":null}