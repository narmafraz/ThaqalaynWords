in respect of stature"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"proportion"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"AEtdl","text_ar":"اعتدل"},{"kind":"arabic","text_bw":"Al$~iEoru","text_ar":"الشِّعْرُ"},{"kind":"italic_en","text":"The poetry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verse, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, measured, and right in its feet."},{"kind":"text","text":"(TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, of a middling sort, in quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality;"},{"kind":"text","text":"(K, TA;) as a body between tallness and shortness, and water between the hot and the"},{"kind":"page_break","n":1974},{"kind":"text","text":"cold; and ["},{"kind":"italic_en","text":"moderate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"temperate,"},{"kind":"text","text":"] as a day of which the air is pleasant. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}