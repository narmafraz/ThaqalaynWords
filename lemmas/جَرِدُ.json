{"lemma":"جَرِدُ","slug":"جَرِدُ","root":"ج.ر.د","root_slug":"ج-ر-د","root_link":"/words/roots/ج-ر-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":19},"lanes":{"found":true,"entry_ids":["n5464","n5465","n5469","n5470","n5471","n5472"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B1%D9%90%D8%AF%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to peel, to husk, to rind"},{"pos":"verb","gloss":"to strip, to denude"},{"pos":"verb","gloss":"to inventory"},{"pos":"verb","gloss":"to be destitute of herbage, to be barren"},{"pos":"verb","gloss":"to have short hair (of a horse)"},{"pos":"verb","gloss":"to be bald (of a man)"},{"pos":"verb","gloss":"to get a skin disease from eating locusts"},{"pos":"verb","gloss":"to strip, to denude, to peel, to husk, to rind"},{"pos":"verb","gloss":"to bare, to dispossess, to deprive, to free, to divest"},{"pos":"verb","gloss":"to unsheathe"},{"pos":"verb","gloss":"to abstract (used as English “abstract” in philosophy or art)"},{"pos":"verb","gloss":"to send, to dispatch, to detach"},{"pos":"noun","gloss":"verbal noun of جَرَدَ (jarada, “to peel; to strip; to inventory”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"inventory; stock"},{"pos":"noun","gloss":"worn-out garment"},{"pos":"noun","gloss":"uncovered pudendum"},{"pos":"noun","gloss":"verbal noun of جَرَدَ (jarada, “to be barren (of land); to have short or no hair”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"barren land, earth without herbage"},{"pos":"adj","gloss":"destitute of herbage"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5464","headword_ar":"جَرَدَ","root":"jrd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jarodN","text_ar":"جَرْدٌ"},{"kind":"text","text":": see 2, in nine places. ―         -b2-"},{"kind":"arabic","text_bw":"jarada AljaraAdu AlA^aroDa","text_ar":"جَرَدَ الجَرَادُ الاَرْضَ"},{"kind":"text","text":", (A, L, Msb,) aor. and inf. n. as above, (L,) (tropical:)"},{"kind":"italic_en","text":"The locusts stripped the land of all its herbage;"},{"kind":"text","text":"(A, * L;)"},{"kind":"italic_en","text":"ate what was upon the land."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"jaradahumu AljaAruwdu","text_ar":"جَرَدَهُمُ الجَارُودُ"},{"kind":"text","text":"(tropical:) ["},{"kind":"italic_en","text":"The year of drought destroyed them"},{"kind":"text","text":"]. (A.)       -A2-"},{"kind":"arabic","text_bw":"juridati AlA^aroDu","text_ar":"جُرِدَتِ الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land had its herbage eaten by locusts;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"was smitten by locusts."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"jurida","text_ar":"جُرِدَ"},{"kind":"text","text":"said of seed-produce, (assumed tropical:)"},{"kind":"italic_en","text":"It was smitten"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"eaten"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by locusts."},{"kind":"text","text":"(K.) ―         -b3-  And said of a man, (S,) (assumed tropical:)"},{"kind":"italic_en","text":"He had a complaint of his belly from having eaten locusts."},{"kind":"text","text":"(S, K.)       -A3-"},{"kind":"arabic","text_bw":"jarida","text_ar":"جَرِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jaradN","text_ar":"جَرَدٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a place)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, destitute of herbage."},{"kind":"text","text":"(K, TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had no hair upon him"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"upon his body,"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"except in certain parts:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^ajoradu","text_ar":"اَجْرَدُ"},{"kind":"text","text":"]. (S: but only the inf. n. is there mentioned.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse, K, TA, or similar beast, TA)"},{"kind":"italic_en","text":"had short hair:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"had short and fine hair:"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Anjrd","text_ar":"انجرد","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) [See"},{"kind":"arabic","text_bw":"A^ajoradu","text_ar":"اَجْرَدُ"},{"kind":"text","text":".] ―         -b4-  See also 7. ―         -b5-  Also, (S, K,) inf. n. as above, (S,) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"became affected with the cutaneous eruption termed"},{"kind":"arabic","text_bw":"$arFY","text_ar":"شَرًى"},{"kind":"text","text":","},{"kind":"italic_en","text":"from having eaten locusts."},{"kind":"text","text":"(S, K.)"}],"source_refs":["A","L","Msb","S","K","TA"]},{"entry_id":"n5465","headword_ar":"جرّد","root":"jrd","body":[{"kind":"text","text":", (A, L,) inf. n."},{"kind":"arabic","text_bw":"tajoriydN","text_ar":"تَجْرِيدٌ"},{"kind":"text","text":", (S, A, L,)"},{"kind":"italic_en","text":"He stripped, divested, bared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denuded,"},{"kind":"text","text":"of garments, or clothes. (S, A, L.) You say,"},{"kind":"arabic","text_bw":"jr~dhu mino viyaAbihi","text_ar":"جرّدهُ مِنْ ثِيَابِهِ"},{"kind":"text","text":", (A,) or"},{"kind":"arabic","text_bw":"mn vawobihi","text_ar":"من ثَوْبِهِ"},{"kind":"text","text":", (Th, L, K,) as also ↓"},{"kind":"arabic","text_bw":"jaradahu","text_ar":"جَرَدَهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"jr~dhu vawobahu","text_ar":"جرّدهُ ثَوْبَهُ"},{"kind":"text","text":", (Th, L,)"},{"kind":"italic_en","text":"He stripped, divested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"denuded, him of his garments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his garment:"},{"kind":"text","text":"(Th, A, L, K:) [this is the only signification of the verb given in the A as proper; its other significations given in that lexicon being there said to be tropical:] or"},{"kind":"arabic","text_bw":"jar~adotuhu mino viyaAbihi","text_ar":"جَرَّدْتُهُ مِنْ ثِيَابِهِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I pulled off from him his garments:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jaradotu","text_ar":"جَرَدْتُ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jarodN","text_ar":"جَرْدٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"I removed from the thing that which was upon it."},{"kind":"text","text":"(Msb.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"He peeled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pared,"},{"kind":"text","text":"a thing;"},{"kind":"italic_en","text":"divested"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"of its peel, bark, coat, covering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jarada","text_ar":"جَرَدَ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) aor. and inf. n. as above: (L:) and ↓ the latter, (assumed tropical:)"},{"kind":"italic_en","text":"he peeled off"},{"kind":"text","text":"anything,"},{"kind":"page_break","n":406},{"kind":"arabic","text_bw":"Eano $aYo'K","text_ar":"عَنْ شَىْءٍ"},{"kind":"italic_en","text":"from a thing."},{"kind":"text","text":"(S, L.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"He stripped"},{"kind":"text","text":"skin"},{"kind":"italic_en","text":"of its hair;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jarada","text_ar":"جَرَدَ","orth_type":"arrow"},{"kind":"text","text":". (L, K.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(drought)"},{"kind":"italic_en","text":"rendered"},{"kind":"text","text":"the earth, or land,"},{"kind":"italic_en","text":"bare of herbage:"},{"kind":"text","text":"so in the L and other lexicons: in the K, ↓"},{"kind":"arabic","text_bw":"jarada","text_ar":"جَرَدَ","orth_type":"arrow"},{"kind":"text","text":": but the former is the right. (TA.) ―         -b5-  (assumed tropical:)"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"$*~b","text_ar":"شذّب"},{"kind":"text","text":"[generally signifying"},{"kind":"italic_en","text":"He pruned"},{"kind":"text","text":"a tree or plant]. (S, TA.) ―         -b6-  (tropical:)  ["},{"kind":"italic_en","text":"He bared"},{"kind":"text","text":"a sword;]"},{"kind":"italic_en","text":"he drew forth"},{"kind":"text","text":"a sword (S, A, K) from its scabbard; (A;) as also ↓"},{"kind":"arabic","text_bw":"jarada","text_ar":"جَرَدَ","orth_type":"arrow"},{"kind":"text","text":"(TA, and so in some copies of the K in the place of the former verb,) aor. as above. (TA.) ―         -b7-  [(assumed tropical:)"},{"kind":"italic_en","text":"He detached"},{"kind":"text","text":"a company from an army: see"},{"kind":"arabic","text_bw":"jariydapN","text_ar":"جَرِيدَةٌ"},{"kind":"text","text":".] ―         -b8-  [(assumed tropical:)"},{"kind":"italic_en","text":"He divested"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"of every accessory, adjunct, appendage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adventitious thing; rendered"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"bare, shere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mere."},{"kind":"text","text":"] ―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"the writing, or book, (L, K,) and the copy of the Kur-án, (L,)"},{"kind":"italic_en","text":"free from syllabical signs,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"and from additions and prefaces:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he divested"},{"kind":"text","text":"the Kur-án"},{"kind":"italic_en","text":"of the diacritical points, and of the vowel-signs of desinential syntax, and the like:"},{"kind":"text","text":"(Ibrá- heem [En-Nakha'ee]:) or"},{"kind":"italic_en","text":"he wrote"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"read"},{"kind":"text","text":"it, or"},{"kind":"italic_en","text":"recited"},{"kind":"text","text":"it,"},{"kind":"italic_en","text":"without connecting with it any of the stories,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"traditions, related by the Jews or Christians."},{"kind":"text","text":"(Ibn'Oyeyneh, accord. to the L; or A'Obeyd, accord. to the TA.) ―         -b10-"},{"kind":"arabic","text_bw":"jr~d AlquTona","text_ar":"جرّد القُطْنَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"jaradahu","text_ar":"جَرَدَهُ","orth_type":"arrow"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He separated the cotton from its seeds, with a"},{"kind":"arabic","text_bw":"miHolaAj","text_ar":"مِحْلَاج"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"separated and loosened it by means of a bow and a kind of wooden mallet, by striking the string of the bow with the mallet:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Halajahu","text_ar":"حَلَجَهُ"},{"kind":"text","text":". (K.) ―         -b11-"},{"kind":"arabic","text_bw":"jr~d AlHaj~a","text_ar":"جرّد الحَجَّ"},{"kind":"text","text":", (ISb, K,) and"},{"kind":"arabic","text_bw":"biAlHaj~i","text_ar":"بِالحَجِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjr~d","text_ar":"تجرّد","orth_type":"arrow"},{"kind":"text","text":", (TA,) which latter alone is mentioned by Z and Ibn-El-Jowzee, (MF,) (assumed tropical:)"},{"kind":"italic_en","text":"He performed the rites and ceremonies of the pilgrimage"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlHaj~","text_ar":"الحَجّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"separately from those of"},{"kind":"arabic","text_bw":"AlEumorap","text_ar":"العُمْرَة"},{"kind":"text","text":"[q. v.]: (ISh, Z, Ibn-El-Jowzee, K:) or the former signifies"},{"kind":"italic_en","text":"he made the performance of the pilgrimage to be free from the vitiations of worldly desires and objects."},{"kind":"text","text":"(Har p. 392.) [See also 5.] ―         -b12-"},{"kind":"arabic","text_bw":"jur~ida liloqiyaAmi bika*aA","text_ar":"جُرِّدَ لِلْقِيَامِ بِكَذَا"},{"kind":"text","text":": see 5. ―         -b13-"},{"kind":"arabic","text_bw":"jr~d Alqawoma","text_ar":"جرّد القَوْمَ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"jaradahumo","text_ar":"جَرَدَهُمْ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) aor. and inf. n. as above; (L;) (assumed tropical:)"},{"kind":"italic_en","text":"He asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begged, of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men, and they refused him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave him against their will."},{"kind":"text","text":"(L, K.)       -A2-  Also, (K,) inf. n. as above, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He wore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put on,"},{"kind":"arabic","text_bw":"juruwd","text_ar":"جُرُود"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"old and wornout garments."},{"kind":"text","text":"(K.)"}],"source_refs":["A","L","S","Th","K","ISb","TA","MF"]},{"entry_id":"n5469","headword_ar":"جَرْدٌ","root":"jrd","body":[{"kind":"text","text":"(tropical:)  A garment"},{"kind":"italic_en","text":"old and worn out,"},{"kind":"text","text":"(L, K, TA,)"},{"kind":"italic_en","text":"of which the nap has fallen off:"},{"kind":"text","text":"or one"},{"kind":"italic_en","text":"between that which is new and that which is old and worn out:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"juruwdN","text_ar":"جُرُودٌ"},{"kind":"text","text":". (L, TA.) You say"},{"kind":"arabic","text_bw":"burodapN jarodN","text_ar":"بُرْدَةٌ جَرْدٌ"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"jarodapN","text_ar":"جَرْدَةٌ","orth_type":"arrow"},{"kind":"text","text":"[alone], (S, L, TA,) (tropical:)"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"brdp","text_ar":"بردة"},{"kind":"italic_en","text":"worn so that it has become smooth."},{"kind":"text","text":"(S, A, L, TA. *) And [the pl.]"},{"kind":"arabic","text_bw":"juruwdN","text_ar":"جُرُودٌ"},{"kind":"text","text":", (K, TA, in the CK"},{"kind":"arabic","text_bw":"jaruwd","text_ar":"جَرُود"},{"kind":"text","text":",) as a subst., (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"Old and worn-out garments."},{"kind":"text","text":"(K.) It is said in a trad. of Aboo-Bekr,"},{"kind":"arabic","text_bw":"layosa EinodanaA mino maAli","text_ar":"لَيْسَ عِنْدَنَا مِنْ مَالِ"},{"kind":"arabic","text_bw":"Almusolimiyna A_il~aA jarodu h`*ihi AlqaTiyfapi","text_ar":"المُسْلِمِينَ اـِلَّا جَرْدُ هٰذِهِ القَطِيفَةِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"There is not in our possession, of the property of the Muslims, save this threadbare and worn-out"},{"kind":"arabic","text_bw":"qTyfp","text_ar":"قطيفة"},{"kind":"text","text":". (TA.)       -A2-  (assumed tropical:)  The"},{"kind":"italic_en","text":"pudendum,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pudenda;"},{"kind":"text","text":"[app. because usually shaven, or depilated;] syn."},{"kind":"arabic","text_bw":"farojN","text_ar":"فَرْجٌ"},{"kind":"text","text":", (K,) i. e."},{"kind":"arabic","text_bw":"EaworapN","text_ar":"عَوْرَةٌ"},{"kind":"text","text":". (TA.) ―         -b2-  And (assumed tropical:)  The"},{"kind":"italic_en","text":"penis."},{"kind":"text","text":"(K.)       -A3-  (assumed tropical:)"},{"kind":"italic_en","text":"A shield."},{"kind":"text","text":"(K.)       -A4-  (assumed tropical:)"},{"kind":"italic_en","text":"A remnant of property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of cattle."},{"kind":"text","text":"(K.)       -A5-  See also"},{"kind":"arabic","text_bw":"jariydapN","text_ar":"جَرِيدَةٌ"},{"kind":"text","text":"."}],"source_refs":["L","K","TA","A","S"]},{"entry_id":"n5470","headword_ar":"جُرْدٌ","root":"jrd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jariydapN","text_ar":"جَرِيدَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n5471","headword_ar":"جَرَدٌ","root":"jrd","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spacious, tract of land in which is no herbage:"},{"kind":"text","text":"(S, A, K:) an inf. n. used as an appellative subst. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"rumiYa EalaY jaradihi","text_ar":"رُمِىَ عَلَى جَرَدِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ajoradihi","text_ar":"اَجْرَدِهِ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was shot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"struck with a missile, on his back."},{"kind":"text","text":"(K.)       -A2-  See also what next follows."}],"source_refs":["S","A","K"]},{"entry_id":"n5472","headword_ar":"جَرِدٌ","root":"jrd","body":[{"kind":"text","text":", (K,) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"A^ajoradu","text_ar":"اَجْرَدُ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) fem."},{"kind":"arabic","text_bw":"jarodaA='u","text_ar":"جَرْدَا=ءُ"},{"kind":"text","text":"; (A, K;) and ↓"},{"kind":"arabic","text_bw":"jaradN","text_ar":"جَرَدٌ","orth_type":"arrow"},{"kind":"text","text":", (TA, as from the K,) which last is an inf. n. used as an epithet; (TA;) (tropical:)  A place (A, K)"},{"kind":"italic_en","text":"destitute of herbage:"},{"kind":"text","text":"(S, A, K:) you say"},{"kind":"arabic","text_bw":"A^aroDN jaridapN","text_ar":"اَرْضٌ جَرِدَةٌ"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"jarodaA='u","text_ar":"جَرْدَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"(A, K) and ↓"},{"kind":"arabic","text_bw":"jaradiy~apN","text_ar":"جَرَدِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"faDaA='N","text_ar":"فَضَا=ءٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ajoradu","text_ar":"اَجْرَدُ","orth_type":"arrow"},{"kind":"text","text":": of which last the pl. is ["},{"kind":"arabic","text_bw":"jurodN","text_ar":"جُرْدٌ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"A^ajaAridu","text_ar":"اَجَارِدُ"},{"kind":"text","text":". (S.) ―         -b2-  Also, the first, (assumed tropical:)  A man"},{"kind":"italic_en","text":"affected with the cutaneous eruption termed"},{"kind":"arabic","text_bw":"$arFY","text_ar":"شَرًى"},{"kind":"text","text":","},{"kind":"italic_en","text":"from having eaten locusts."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","S","A","TA"]}]}}