y_in_corpus":72,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n32985","n32998"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%AA%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to deliver a formal opinion to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to deliver a formal opinion to (someone); to deliver a fatwa","tags":["transitive"]},{"pos":"verb","gloss":"to furnish (someone) with information","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"From Classical Syriac ЬҗЬҰЬ¬Ьқ (КҫapМ„tД«, вҖңto expand; to propagate (orthodoxy)вҖқ), which is a causative to Proto-West Semitic *pataw- (вҖңto penetrateвҖқ), perhaps also encompassing idioms such as Akkadian р’Ҡ»р’үҶ р’үҝр’Ң…р’Ң‘р’Ңқ (uznam petГ»m), р’Ҡ»р’үҶ р’ҒҚр’Ң“р’Ң…р’Ңқ (uznam puttГ»m, literally вҖңto open an earвҖқ), from the related *pataбёҘ- (вҖңto openвҖқ), so it would be equivalent to Arabic ЩҒЩҺШӘЩҺШӯЩҺ ШЈЩҸШ°Щ’ЩҶЩӢШ§ (fataбёҘa К”uбёҸnan).\nThe corresponding noun ЩҒЩҺШӘЩ’ЩҲЩҺЩү (fatwДҒ, вҖңformal opinionвҖқ) has its patterning reflecting Classical Syriac ЬҰЬ¬ЬҳЬҗ (peб№ҜwДҒ, вҖңspinning out, breadth (of words)вҖқ)."},"ipa":["/К”af.taЛҗ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32985","headword_ar":"Ш§ЩҒШӘЩү","root":"ftw or ftY","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a learned man)"},{"kind":"italic_en","text":"notified the decision of the law"},{"kind":"text","text":"[in, or respecting, a particular case]. (Msb.) [And the verb in this sense is trans.: you say,]"},{"kind":"arabic","text_bw":"AftAhu fiY AlA^amori","text_ar":"Ш§ЩҒШӘШ§ЩҮЩҸ ЩҒЩҗЩү Ш§Щ„Ш§ЩҺЩ…Щ’ШұЩҗ"},{"kind":"italic_en","text":"He notified, made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained, to him,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what he required to know,"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"what was the decision of the law, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the case;"},{"kind":"text","text":"(M, K, TA;) it being dubious: said of a lawyer. (TA.) And"},{"kind":"arabic","text_bw":"A^afotaAniY","text_ar":"Ш§ЩҺЩҒЩ’ШӘЩҺШ§ЩҶЩҗЩү"},{"kind":"arabic","text_bw":"fiY masoA^alapK","text_ar":"ЩҒЩҗЩү Щ…ЩҺШіЩ’Ш§ЩҺЩ„ЩҺШ©ЩҚ"},{"kind":"text","text":", (T, S,) inf. n."},{"kind":"arabic","text_bw":"A_ifotaA='N","text_ar":"Ш§ЩҖЩҗЩҒЩ’ШӘЩҺШ§=ШЎЩҢ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a lawyer)"},{"kind":"italic_en","text":"gave me an answer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reply,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"stating the decision of the law,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"respecting a question."},{"kind":"text","text":"(T, S, TA.) And"},{"kind":"arabic","text_bw":"A^afotayotu fulaAnFA fiY ruw^oyaA raA=haA","text_ar":"Ш§ЩҺЩҒЩ’ШӘЩҺЩҠЩ’ШӘЩҸ ЩҒЩҸЩ„ЩҺШ§ЩҶЩӢШ§ ЩҒЩҗЩү ШұЩҸЩҲЩ’ЩҠЩҺШ§ ШұЩҺШ§=ЩҮЩҺШ§"},{"kind":"italic_en","text":"I interpreted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained, to such a one, a dream that he had seen."},{"kind":"text","text":"(T, TA.)       -A2-  Also"},{"kind":"italic_en","text":"He drank with the"},{"kind":"arabic","text_bw":"futaY~","text_ar":"ЩҒЩҸШӘЩҺЩүЩ‘"},{"kind":"text","text":"[q. v.]. (IAar, T, TA.)"}],"source_refs":["T","S"]},{"entry_id":"n32998","headword_ar":"Ш§ЩҺЩҒЩ’ШӘЩҺЩү","root":"ftw or ftY","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aSogaru","text_ar":"Ш§ЩҺШөЩ’ШәЩҺШұЩҸ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"less,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"least, in years,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"age"},{"kind":"text","text":"]: from"},{"kind":"arabic","text_bw":"AlftY","text_ar":"Ш§Щ„ЩҒШӘЩү"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"AlfataY","text_ar":"Ш§Щ„ЩҒЩҺШӘЩҺЩү"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"AlfatiY~u","text_ar":"Ш§Щ„ЩҒЩҺШӘЩҗЩүЩҸЩ‘"},{"kind":"text","text":"]. (Ham p. 207.)"}],"source_refs":[]}]},"classical_definitions":null}