:"d"},{"role":"present_3fd","form":"تُفْتَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْتِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْتِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفْتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْتُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفْتَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُفْتِيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفْت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُفْتَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْتَى","in_corpus":true,"count":24,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفْتِي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْتِي","in_corpus":true,"count":8,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَفْتَيْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَفْتَيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":72,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n32985","n32998"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%AA%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to deliver a formal opinion to (someone)","tags":["transitive"]},{"pos":"verb","gloss":"to deliver a formal opinion to (someone); to deliver a fatwa","tags":["transitive"]},{"pos":"verb","gloss":"to furnish (someone) with information","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"From Classical Syriac ܐܦܬܝ (ʾap̄tī, “to expand; to propagate (orthodoxy)”), which is a causative to Proto-West Semitic *pataw- (“to penetrate”), perhaps also encompassing idioms such as Akkadian 𒊻𒉆 𒉿𒌅𒌑𒌝 (uznam petûm), 𒊻𒉆 𒁍𒌓𒌅𒌝 (uznam puttûm, literally “to open an ear”), from the related *pataḥ- (“to open”), so it would be equivalent to Arabic فَتَحَ أُذْنًا (fataḥa ʔuḏnan).\nThe corresponding noun فَتْوَى (fatwā, “formal opinion”) has its patterning reflecting Classical Syriac ܦܬܘܐ (peṯwā, “spinning out, breadth (of words)”)."},"ipa":["/ʔaf.taː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32985","headword_ar":"افتى","root":"ftw or ftY","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a learned man)"},{"kind":"italic_en","text":"notified the decision of the law"},{"kind":"text","text":"[in, or respecting, a particular case]. (Msb.) [And the verb in this sense is trans.: you say,]"},{"kind":"arabic","text_bw":"AftAhu fiY AlA^amori","text_ar":"افتاهُ فِى الاَمْرِ"},{"kind":"italic_en","text":"He notified, made known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained, to him,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what he required to know,"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"what was the decision of the law, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"respecting,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the case;"},{"kind":"text","text":"(M, K, TA;) it being dubious: said of a lawyer. (TA.) And"},{"kind":"arabic","text_bw":"A^afotaAniY","text_ar":"اَفْتَانِى"},{"kind":"arabic","text_bw":"fiY masoA^alapK","text_ar":"فِى مَسْاَلَةٍ"},{"kind":"text","text":", (T, S,) inf. n."},{"kind":"arabic","text_bw":"A_ifotaA='N","text_ar":"اـِفْتَا=ءٌ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a lawyer)"},{"kind":"italic_en","text":"gave me an answer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a reply,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"stating the decision of the law,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"respecting a question."},{"kind":"text","text":"(T, S, TA.) And"},{"kind":"arabic","text_bw":"A^afotayotu fulaAnFA fiY ruw^oyaA raA=haA","text_ar":"اَفْتَيْتُ فُلَانًا فِى رُوْيَا رَا=هَا"},{"kind":"italic_en","text":"I interpreted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained, to such a one, a dream that he had seen."},{"kind":"text","text":"(T, TA.)       -A2-  Also"},{"kind":"italic_en","text":"He drank with the"},{"kind":"arabic","text_bw":"futaY~","text_ar":"فُتَىّ"},{"kind":"text","text":"[q. v.]. (IAar, T, TA.)"}],"source_refs":["T","S"]},{"entry_id":"n32998","headword_ar":"اَفْتَى","root":"ftw or ftY","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aSogaru","text_ar":"اَصْغَرُ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"less,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"least, in years,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"age"},{"kind":"text","text":"]: from"},{"kind":"arabic","text_bw":"AlftY","text_ar":"الفتى"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"AlfataY","text_ar":"الفَتَى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"AlfatiY~u","text_ar":"الفَتِىُّ"},{"kind":"text","text":"]. (Ham p. 207.)"}],"source_refs":[]}]}}