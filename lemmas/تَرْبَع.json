"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَرْبَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْبَع","in_corpus":true,"count":236,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":246,"cross_references":{"qac":{"found":true,"lemma_key":"رَبَع","root":"ربع","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n14530","n14531","n14532","n14533","n14534"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D9%92%D8%A8%D9%8E%D8%B9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"one fourth, one quarter"},{"pos":"noun","gloss":"quarter (area or region)"}]},"etymology":{"source":"wiktextract","text":"Compare أَرْبَعَة (ʔarbaʕa, “four”). Cognate to Hebrew רֹבַע (róva', “quarter”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14530","headword_ar":"رَبْعٌ","root":"rbE","body":[{"kind":"italic_en","text":"A place where people remain, abide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwell, in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":"; (K, TA;) as also ↓"},{"kind":"arabic","text_bw":"marobaEN","text_ar":"مَرْبَعٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"murotabaEN","text_ar":"مُرْتَبَعٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:)"},{"kind":"page_break","n":1017},{"kind":"text","text":"this is the primary signification: (TA:) and hence, (TA,) (tropical:)"},{"kind":"italic_en","text":"a place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode,"},{"kind":"text","text":"(Sh, S, Msb, K, TA,)"},{"kind":"italic_en","text":"of a people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"a settled place of abode; a place of constant residence; a dwelling; a home; whenever and wherever it be;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"marobaEN","text_ar":"مَرْبَعٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"murotabaEN","text_ar":"مُرْتَبَعٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and (assumed tropical:)"},{"kind":"italic_en","text":"a house, wherever it be:"},{"kind":"text","text":"(S, Mgh, K:) [in Egypt,"},{"kind":"italic_en","text":"a range of distinct lodgings over shops"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magazines, separate from the shops"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magazines, but generally having one common entrance and staircase:"},{"kind":"text","text":"] pl. [of mult.]"},{"kind":"arabic","text_bw":"ribaAEN","text_ar":"رِبَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rubuwEN","text_ar":"رُبُوعٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^arobaAEN","text_ar":"اَرْبَاعٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^arobuEN","text_ar":"اَرْبُعٌ"},{"kind":"text","text":": (S, Msb, K:) and the pl. of ↓"},{"kind":"arabic","text_bw":"marobaEN","text_ar":"مَرْبَعٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"maraAbiEu","text_ar":"مَرَابِعُ"},{"kind":"text","text":". (S.) You say,"},{"kind":"arabic","text_bw":"maA A^awosaEa raboEa baniY fulaAnK","text_ar":"مَا اَوْسَعَ رَبْعَ بَنِى فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"How ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spacious, is the place of alighting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, of the sons of such a one!"},{"kind":"text","text":"(S, TA.) ―         -b2-  Hence, also, (tropical:)  The"},{"kind":"italic_en","text":"people of a place of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode;"},{"kind":"text","text":"(Sh, Msb, TA;) the"},{"kind":"italic_en","text":"people of a house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent:"},{"kind":"text","text":"(Aboo-Málik, TA:)"},{"kind":"italic_en","text":"a company of men"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"a large number:"},{"kind":"text","text":"(IB:) pl. as above: (Msb:)"},{"kind":"arabic","text_bw":"rubuwEN","text_ar":"رُبُوعٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"people of places of alighting"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode:"},{"kind":"text","text":"(Sh:) and also"},{"kind":"italic_en","text":"tribes."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"A^akavara A@ll~`hu raboEaka","text_ar":"اَكَثَرَ ا@للّٰهُ رَبْعَكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"May God multiply the people of thy house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"humu Alyawoma raboEN","text_ar":"هُمُ اليَوْمَ رَبْعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They now,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to-day,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"are a large number;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"have become many, and have increased."},{"kind":"text","text":"(TA.) ―         -b3-  [Hence, also,] (assumed tropical:)"},{"kind":"italic_en","text":"A bier;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a bier with a corpse upon it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"naEo$N","text_ar":"نَعْشٌ"},{"kind":"text","text":". (K, TA: [in the CK"},{"kind":"arabic","text_bw":"nafos","text_ar":"نَفْس"},{"kind":"text","text":".]) So in the saying,"},{"kind":"arabic","text_bw":"Hamalotu raboEahu","text_ar":"حَمَلْتُ رَبْعَهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I bore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried, his bier,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his bier with his corpse upon it"},{"kind":"text","text":"]. (TA.) ―         -b4-  (assumed tropical:)  The"},{"kind":"italic_en","text":"extremity of a mountain."},{"kind":"text","text":"(TA.) [App. because travellers often stop and rest there.]       -A2-  Also"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raboEapN","text_ar":"رَبْعَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb, K,) which signifies, (S, L, &c.,) as also ↓"},{"kind":"arabic","text_bw":"rabaEapN","text_ar":"رَبَعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"marobuwEN","text_ar":"مَرْبُوعٌ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb, K,) or"},{"kind":"arabic","text_bw":"Alxaloqi","text_ar":"الخَلْقِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"marobuwEu","text_ar":"مَرْبُوعُ","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, L,) and ↓"},{"kind":"arabic","text_bw":"murotabiEN","text_ar":"مُرْتَبِعٌ","orth_type":"arrow"},{"kind":"text","text":", (S, L, K,) and ↓"},{"kind":"arabic","text_bw":"murotabaEN","text_ar":"مُرْتَبَعٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"mirobaAEN","text_ar":"مِرْبَاعٌ","orth_type":"arrow"},{"kind":"text","text":", (K, but this last [says SM] I have not seen in the lexicons, except applied by the author of the “ Mo- heet ” as an epithet to a rope, TA,) applied to a man, (S, L, &c.,)"},{"kind":"italic_en","text":"Of middling stature;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"neither tall nor short;"},{"kind":"text","text":"(S, L;)"},{"kind":"italic_en","text":"between tall and short:"},{"kind":"text","text":"(K:) and so, applied to a woman, ↓"},{"kind":"arabic","text_bw":"raboEapN","text_ar":"رَبْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Mgh, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"rabaEapN","text_ar":"رَبَعَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, Msb,) though originally applied to a man, like"},{"kind":"arabic","text_bw":"xamosapN","text_ar":"خَمْسَةٌ"},{"kind":"text","text":"&c.: (L:) the pl. of"},{"kind":"arabic","text_bw":"raboEN","text_ar":"رَبْعٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"raboEuwna","text_ar":"رَبْعُونَ"},{"kind":"text","text":": (Fr:) and that of ↓"},{"kind":"arabic","text_bw":"raboEapN","text_ar":"رَبْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"rabaEaAtN","text_ar":"رَبَعَاتٌ"},{"kind":"text","text":", applied to men and to women, (S, Mgh, L, K,) and"},{"kind":"arabic","text_bw":"raboEaAtN","text_ar":"رَبْعَاتٌ"},{"kind":"text","text":"also; (IAar, Fr, L, K) the former of these two pls. being anomalous, because a word of the measure"},{"kind":"arabic","text_bw":"faEolapN","text_ar":"فَعْلَةٌ"},{"kind":"text","text":"has not its medial radical movent when it is an epithet, but only when it is a subst. and has not"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"y","text_ar":"ي"},{"kind":"text","text":"for that radical; (S, O, K;) or the medial radical is movent in this instance because"},{"kind":"arabic","text_bw":"raboEapN","text_ar":"رَبْعَةٌ"},{"kind":"text","text":"is originally a fem. subst. applied to a male and a female, and used as an epithet; (L;) or because it resembles a subst. in its being applied alike to a man and a woman. (Az.)"}],"source_refs":["S","Msb","K","TA","Sh","Mgh","IB","L","Fr","IAar"]},{"entry_id":"n14531","headword_ar":"رُبْعٌ","root":"rbE","body":[{"kind":"text","text":"(S, Mgh, Msb, K) and ↓"},{"kind":"arabic","text_bw":"rubuEN","text_ar":"رُبُعٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) the former a contraction of the latter, (Msb,) [which is the more chaste, but the former is the more common,]"},{"kind":"italic_en","text":"A fourth part;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"one of four parts;"},{"kind":"text","text":"(Mgh;;) as also ↓"},{"kind":"arabic","text_bw":"rabiyEN","text_ar":"رَبِيعٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) like"},{"kind":"arabic","text_bw":"Ea$iyrN","text_ar":"عَشِيرٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"mirobaAEN","text_ar":"مِرْبَاعٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"miEo$aArN","text_ar":"مِعْشَارٌ"},{"kind":"text","text":": (Ktr, and S:) or the last signifies, (Msb, K,) or signifies also, (S,) the"},{"kind":"italic_en","text":"fourth part of the spoil, which the chief used to take"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"in the Time of Ignorance:"},{"kind":"text","text":"(K:) the pl. of"},{"kind":"arabic","text_bw":"ruboEN","text_ar":"رُبْعٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rubuEN","text_ar":"رُبُعٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^arobaAEN","text_ar":"اَرْبَاعٌ"},{"kind":"text","text":"[a pl. of pauc.] (Msb, TA) and"},{"kind":"arabic","text_bw":"rubuwEN","text_ar":"رُبُوعٌ"},{"kind":"text","text":"[a pl. of mult]: (TA:) and that of ↓"},{"kind":"arabic","text_bw":"rabiyEN","text_ar":"رَبِيعٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"rubuEN","text_ar":"رُبُعٌ"},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"Alr~uboEu AlhaA$imiY~u","text_ar":"الرُّبْعُ الهَاشِمِىُّ"},{"kind":"italic_en","text":"The same as the"},{"kind":"arabic","text_bw":"SaAE","text_ar":"صَاع"},{"kind":"text","text":"; because the"},{"kind":"arabic","text_bw":"qafiyz","text_ar":"قَفِيز"},{"kind":"text","text":"is twelve times what is termed"},{"kind":"arabic","text_bw":"man~","text_ar":"مَنّ"},{"kind":"text","text":": but"},{"kind":"arabic","text_bw":"Alr~uboEu AlHaj~aAjiY~u","text_ar":"الرُّبْعُ الحَجَّاجِىُّ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the same as the"},{"kind":"arabic","text_bw":"mud~","text_ar":"مُدّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"which is a quarter of what is termed"},{"kind":"arabic","text_bw":"AlS~aAEu","text_ar":"الصَّاعُ"},{"kind":"arabic","text_bw":"AlHaj~aAjiY~u","text_ar":"الحَجَّاجِىُّ"},{"kind":"text","text":". (Mgh.) [In Egypt, the"},{"kind":"arabic","text_bw":"ruboE","text_ar":"رُبْع"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"the fourth part of a"},{"kind":"arabic","text_bw":"wuyobap","text_ar":"وُيْبَة"},{"kind":"text","text":", q. v.] ―         -b3-"},{"kind":"arabic","text_bw":"A^arobaAEu Alr~aA^osi","text_ar":"اَرْبَاعُ الرَّاْسِ"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"four"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"regions of the head."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","Msb","K","TA"]},{"entry_id":"n14532","headword_ar":"رِبْعٌ","root":"rbE","body":[{"kind":"text","text":"The"},{"kind":"arabic","text_bw":"Zimo'","text_ar":"ظِمْء"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"interval between two water-ings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping from water during that interval,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which is meant in the phrase"},{"kind":"arabic","text_bw":"rabaEati AlA_ibilu","text_ar":"رَبَعَتِ الاـِبِلُ"},{"kind":"text","text":"[q. v.]; (S;)"},{"kind":"italic_en","text":"a certain"},{"kind":"arabic","text_bw":"Zimo'","text_ar":"ظِمْء"},{"kind":"italic_en","text":"of camels, respecting which authors differ:"},{"kind":"text","text":"(TA:) it is"},{"kind":"italic_en","text":"when camels are kept from the water three days"},{"kind":"text","text":"["},{"kind":"italic_en","text":"counting two portions of days as one of those days"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"four days"},{"kind":"text","text":"["},{"kind":"italic_en","text":"counting two portions of days as two days"},{"kind":"text","text":"(for the difference is only verbal)],"},{"kind":"italic_en","text":"and three"},{"kind":"text","text":"["},{"kind":"italic_en","text":"whole"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"nights, and come to the water on the fourth day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"counting the day of the next preceding watering as the first"},{"kind":"text","text":"]; (K;) or [in other words]"},{"kind":"italic_en","text":"their coming to the water one day, and leaving it two days, and then coming to it on the fourth day;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a period of three"},{"kind":"text","text":"["},{"kind":"italic_en","text":"whole"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"nights and four days"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of which the first and last are incomplete"},{"kind":"text","text":"]; as is indicated in the K: or, as some say, [but this at variance with common usage,]"},{"kind":"italic_en","text":"their being kept from the water four"},{"kind":"text","text":"["},{"kind":"italic_en","text":"nights"},{"kind":"text","text":"(for the n. of number is here fem.)],"},{"kind":"italic_en","text":"and then coming to it on the fifth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"day"},{"kind":"text","text":"(for the n. of number is here masc.)]. (TA.) You say,"},{"kind":"arabic","text_bw":"waradati AlA_ibilu Alr~iboEa","text_ar":"وَرَدَتِ الاـِبِلُ الرِّبْعَ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rabaEati AlA_ibilu","text_ar":"رَبَعَتِ الاـِبِلُ"},{"kind":"text","text":". (S, K.) And"},{"kind":"arabic","text_bw":"waradato A_ibiluhu riboEFA","text_ar":"وَرَدَتْ اـِبِلُهُ رِبْعًا"},{"kind":"text","text":": see 4. (S.) And"},{"kind":"arabic","text_bw":"A^aworada AlA_ibila riboEFA","text_ar":"اَوْرَدَ الاـِبِلَ رِبْعًا"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^arobaEa AlA_ibila","text_ar":"اَرْبَعَ الاـِبِلَ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b2-  [Also, for"},{"kind":"arabic","text_bw":"sayoru riboEK","text_ar":"سَيْرُ رِبْعٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"A journey in which the camels are watered only on the first and fourth days."},{"kind":"text","text":"] ―         -b3-  [In like manner,] with respect to fever, it signifies The"},{"kind":"italic_en","text":"seizing on one day and leaving two days and then coming again on the fourth day"},{"kind":"text","text":"["},{"kind":"italic_en","text":"counting the day of the next preceding fit as the first"},{"kind":"text","text":"]. (S, K.) [The fever is termed]"},{"kind":"arabic","text_bw":"Hum~aY Alr~iboEi","text_ar":"حُمَّى الرِّبْعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The quartan fever;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the fever that occurs on one day and intermits two days and then comes again on the fourth, and so on."},{"kind":"text","text":"(Msb.) And you say,"},{"kind":"arabic","text_bw":"jaA='atohu AlHum~aY riboEFA","text_ar":"جَا=ءَتْهُ الحُمَّى رِبْعًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"rabaEato Ealayohi AlHum~aY","text_ar":"رَبَعَتْ عَلَيْهِ الحُمَّى"},{"kind":"text","text":"[q. v.]. (K.) ―         -b4-  Also The"},{"kind":"italic_en","text":"fourth young one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"vlv","text_ar":"ثلث"},{"kind":"text","text":".)"}],"source_refs":["TA"]},{"entry_id":"n14533","headword_ar":"رُبَعَ","root":"rbE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rubaAEu","text_ar":"رُبَاعُ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"rubaEN","text_ar":"رُبَعٌ"},{"kind":"italic_en","text":"A young camel brought forth in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"autumn"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"which is the beginning of the breedingtime:"},{"kind":"text","text":"(S, Msb, K:) so called because he widens his stepping, and runs: [see 1, near the end of the paragraph:] (TA:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": pl. masc."},{"kind":"arabic","text_bw":"ribaAEN","text_ar":"رِبَاعٌ"},{"kind":"text","text":"[a pl. of mult.] and"},{"kind":"arabic","text_bw":"A^arobaAEN","text_ar":"اَرْبَاعٌ"},{"kind":"text","text":"[a pl. of pauc.]; (S, Msb, K;) both irreg.; for accord. to the rule given by Sb, the pl. should be"},{"kind":"arabic","text_bw":"riboEaAnN","text_ar":"رِبْعَانٌ"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"SrodaAnN","text_ar":"صرْدَانٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"SaradN","text_ar":"صَرَدٌ"},{"kind":"text","text":"]: (TA:) pl. fem."},{"kind":"arabic","text_bw":"rubaEaAtN","text_ar":"رُبَعَاتٌ"},{"kind":"text","text":"(S, Msb, K, TA [in the CK, erroneously,"},{"kind":"arabic","text_bw":"raboEAtN","text_ar":"رَبْعاتٌ"},{"kind":"text","text":"]) and"},{"kind":"arabic","text_bw":"ribaAEN","text_ar":"رِبَاعٌ"},{"kind":"text","text":". (K.) Hence the saying,"},{"kind":"arabic","text_bw":"maA lahu hubaEN walaA rubaEN","text_ar":"مَا لَهُ هُبَعٌ وَلَا رُبَعٌ"},{"kind":"italic_en","text":"He has not a young camel brought forth in the end of the breeding-time nor one brought forth in the beginning thereof."},{"kind":"text","text":"(S, TA.) [See another ex. voce"},{"kind":"arabic","text_bw":"bulaEN","text_ar":"بُلَعٌ"},{"kind":"text","text":".] ―         -b2-  [Hence, also,]"},{"kind":"arabic","text_bw":"Alr~ubaEi","text_ar":"الرُّبَعِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A very small star in the midst of the"},{"kind":"arabic","text_bw":"EawaAy^i*","text_ar":"عَوَايِذ"},{"kind":"text","text":","},{"kind":"italic_en","text":"which are in the head of"},{"kind":"arabic","text_bw":"Alt~in~iyn","text_ar":"التِّنِّين"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Draco"},{"kind":"text","text":"]. (Kzw.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n14534","headword_ar":"رُبُعٌ","root":"rbE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ruboEN","text_ar":"رُبْعٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}