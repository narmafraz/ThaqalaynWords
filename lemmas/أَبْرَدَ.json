asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُبْرِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُبْرِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُبْرِد","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُبْرِد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُبْرِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُبْرِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُبْرِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُبْرِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُبْرِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُبْرِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُبْرِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُبْرِد","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُبْرِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَبْرَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَبْرَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":28,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n2213","n2236"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D9%92%D8%B1%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2213","headword_ar":"ابرد","root":"brd","body":[{"kind":"italic_en","text":"He entered upon a cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool, time:"},{"kind":"text","text":"(Mgh, Msb:)"},{"kind":"italic_en","text":"he entered upon the last part of the day:"},{"kind":"text","text":"(M, K:)"},{"kind":"italic_en","text":"he entered upon the time when the sun had declined:"},{"kind":"text","text":"(Mohammad Ibn-Kaab, T:) and"},{"kind":"italic_en","text":"he entered upon the cool season, at the end of the summer."},{"kind":"text","text":"(Lth, T.) [Hence,]"},{"kind":"arabic","text_bw":"A^aboriduwA biAlT~aEaAmi","text_ar":"اَبْرِدُوا بِالطَّعَامِ"},{"kind":"italic_en","text":"Delay ye to eat food until it is cool:"},{"kind":"text","text":"occurring in a trad. (El-Munáwee.) And"},{"kind":"arabic","text_bw":"A^aboriduwA biAlZ~uhori","text_ar":"اَبْرِدُوا بِالظُّهْرِ"},{"kind":"text","text":"(T, A, Mgh, Msb)"},{"kind":"italic_en","text":"Defer ye the noon-prayers until the cooler time of the day, when the vehemence of the heat shall have become allayed."},{"kind":"text","text":"(Mgh, Msb.) And"},{"kind":"arabic","text_bw":"A^aborido Eanoka mina AlZ~ahiyripa","text_ar":"اَبْرِدْ عَنْكَ مِنَ الظَّهِيرِةَ"},{"kind":"italic_en","text":"Stay thou until the mid-day heat shall have become assuaged, and the air be cool."},{"kind":"text","text":"(M, and L in art."},{"kind":"arabic","text_bw":"fyH","text_ar":"فيح"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"Abrdlahu","text_ar":"ابردلَهُ"},{"kind":"italic_en","text":"He gave him to drink what was cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool."},{"kind":"text","text":"(M, K.) You say also,"},{"kind":"arabic","text_bw":"saqayotuhu faA^aboradotu lahu","text_ar":"سَقَيْتُهُ فَاَبْرَدْتُ لَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I gave him to drink what was cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool."},{"kind":"text","text":"(A'Obeyd, S.) ―         -b3-"},{"kind":"arabic","text_bw":"Abrdhu","text_ar":"ابردهُ"},{"kind":"italic_en","text":"He brought it cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool."},{"kind":"text","text":"(M, K.) ―         -b4-  See"},{"kind":"arabic","text_bw":"baradahu","text_ar":"بَرَدَهُ"},{"kind":"text","text":", first sentence. ―         -b5-  And see 2.       -A2-  See also 1, in four places; last three sentences."}],"source_refs":["Mgh","Msb","M","K","T","A"]},{"entry_id":"n2236","headword_ar":"اَبْرَدُ","root":"brd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool"},{"kind":"text","text":"]. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AlA^aboradaAni","text_ar":"الاَبْرَدَانِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AlbarodaAni","text_ar":"البَرْدَانِ","orth_type":"arrow"},{"kind":"italic_en","text":"The morning,"},{"kind":"page_break","n":186},{"kind":"italic_en","text":"between daybreak and sunrise, and the evening, between sunset and nightfall;"},{"kind":"text","text":"(T, S, M, K;) also called"},{"kind":"arabic","text_bw":"AlEaSoraAni","text_ar":"العَصْرَانِ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"AlS~aroEaAni","text_ar":"الصَّرْعَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alr~idofaAni","text_ar":"الرِّدْفَانِ"},{"kind":"text","text":": (T:) or (as in the S, but in the M and K “and”)"},{"kind":"italic_en","text":"the morning-shade and evening-shade:"},{"kind":"text","text":"(S, M, K:) so called because of their coldness, or coolness. (TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"baridN","text_ar":"بَرِدٌ"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"vaworN A^aboradu","text_ar":"ثَوْرٌ اَبْرَدُ"},{"kind":"italic_en","text":"A bull upon which are spots,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"patches, of white and black:"},{"kind":"text","text":"(S, M:) of the dial. of El-Yemen. (M.) ―         -b5-  And"},{"kind":"arabic","text_bw":"AlA^aboradu","text_ar":"الاَبْرَدُ"},{"kind":"italic_en","text":"The leopard:"},{"kind":"text","text":"fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (T, K: [but in the TT, the fem. is written like the masc.:]) pl."},{"kind":"arabic","text_bw":"AlA^abaAridu","text_ar":"الاَبَارِدُ"},{"kind":"text","text":". (T, K.) The female is also called"},{"kind":"arabic","text_bw":"Alxayovamapu","text_ar":"الخَيْثَمَةُ"},{"kind":"text","text":". (T.)"}],"source_refs":["S","K","T","M"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%A8%D8%B1%D8%AF/","headword_ar":"أَبْرَدَ","entries":[{"lexicon_id":"dictionary_11","lexicon_en":"Ibn al-Athīr al-Jazarī, al-Nihāya fī Gharīb al-Ḥadīth wa-l-Athar (d. 1210 CE) النهاية في غريب الحديث والأثر لأبي السعادات ابن الأثير الجزري","lexicon_ar":"","permalink":"https://arabiclexicon.hawramani.com/?p=17838#37d0c1","body_html":"<span class=\"title1\">(أَبْرَدَ)</span><br><span>(س) فِيهِ «إِنَّ الْبِطِّيخَ يَقْلَعُ الإِبْرِدَة» الإِبْرِدَة- بِكَسْرِ الْهَمْزَةِ وَالرَّاءِ- عِلَّةٌ مَعْرُوفَةٌ مِنْ غَلَبَةِ الْبَرْدِ وَالرُّطُوبَةِ تُفَتّرُ عَنِ الْجِمَاعِ، وَهَمْزَتُهَا زَائِدَةٌ، وَإِنَّمَا أَوْرَدْنَاهَا هَاهُنَا حَمْلا عَلَى ظَاهِرِ لَفْظِهَا.</span>"}]}}