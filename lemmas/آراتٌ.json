{"lemma":"آراتٌ","slug":"آراتٌ","root":"NTWS","root_slug":"NTWS","root_link":"/words/roots/NTWS","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n543"],"search_url":"https://lanelexicon.com/?s=%D8%A2%D8%B1%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to have sex with"}]},"etymology":null,"ipa":["/ʔaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n543","headword_ar":"اـِرَاتٌ","root":"Arv","body":[{"kind":"italic_en","text":"Fire;"},{"kind":"text","text":"(T, M, L, K;) as also ↓"},{"kind":"arabic","text_bw":"A_iraAvapN","text_ar":"اـِرَاثَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ariyvN","text_ar":"اَرِيثٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or (so accord. to the M and"},{"kind":"italic_en","text":"L,"},{"kind":"text","text":"but in the K “and”)"},{"kind":"italic_en","text":"tinder,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like, prepared for fire;"},{"kind":"text","text":"(M, L, K;) [as also ↓"},{"kind":"arabic","text_bw":"A_iraAvapN","text_ar":"اـِرَاثَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^urovapN","text_ar":"اُرْثَةٌ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"or"},{"kind":"text","text":"these two words signify"},{"kind":"italic_en","text":"a means of kindling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflaming;"},{"kind":"text","text":"as will be seen from what follows:] or"},{"kind":"italic_en","text":"a lump of the dung of a horse or the like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a similar thing, with which one kindles a fire;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^urovapN","text_ar":"اُرْثَةٌ","orth_type":"arrow"},{"kind":"text","text":": (A:) or this last signifies"},{"kind":"italic_en","text":"dung of camels or horses or the like,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stick,"},{"kind":"text","text":"(T,)"},{"kind":"italic_en","text":"that is prepared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put in readiness, by the ashes,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"buried in them,"},{"kind":"text","text":"(T,)"},{"kind":"italic_en","text":"for the time when it may be wanted"},{"kind":"text","text":"(T, S, K)"},{"kind":"italic_en","text":"for fuel."},{"kind":"text","text":"(T.) It is said in a prov., mentioned in the collection of Meyd,"},{"kind":"arabic","text_bw":"AlEadaAwapi","text_ar":"العَدَاوَةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aln~amiymapu","text_ar":"النَّمِيمَةُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Calumny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slander, is a means of kindling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflaming, enmity"},{"kind":"text","text":"]. (TA: but in Freytag's Arab. Prov., ii. 773, in the place of"},{"kind":"arabic","text_bw":"ArAvp","text_ar":"اراثة"},{"kind":"text","text":", we find ↓"},{"kind":"arabic","text_bw":"A^urovap","text_ar":"اُرْثَة","orth_type":"arrow"},{"kind":"text","text":".)"}],"source_refs":["TA","A","S","K","T"]}]}}