text":"["},{"kind":"italic_en","text":"men"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to see and to hear"},{"kind":"text","text":"["},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (K.) And"},{"kind":"arabic","text_bw":"faEalotuhu","text_ar":"فَعَلْتُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tasomiEataka","text_ar":"تَسْمِعَتَكَ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"tasomiEapF laka","text_ar":"تَسْمِعَةً لَكَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I did it in order that thou mightest hear it."},{"kind":"text","text":"(AZ, K.) [See also"},{"kind":"arabic","text_bw":"samoEN","text_ar":"سَمْعٌ"},{"kind":"text","text":", where similar phrases are mentioned and explained.] ―         -b2-"},{"kind":"arabic","text_bw":"Als~umoEapu","text_ar":"السُّمْعَةُ"},{"kind":"text","text":", also, signifies"},{"kind":"italic_en","text":"What is heard, of fame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"report,"},{"kind":"text","text":"&c.: (Har p. 34:) and [particularly]"},{"kind":"italic_en","text":"good report."},{"kind":"text","text":"(Id. p. 196.)"}],"source_refs":[]}]},"classical_definitions":null}