r":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَغْفَى","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَغْفَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n32152"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%81%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32152","headword_ar":"غَفًى","root":"gfw and gfY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"refuse that is taken forth from wheat, and thrown away,"},{"kind":"text","text":"(Fr, S, TA,)"},{"kind":"italic_en","text":"such as"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the noxious weed called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"zuw^aAn","text_ar":"زُوَان"},{"kind":"text","text":"[q. v.]; (S;)"},{"kind":"italic_en","text":"a thing that is in wheat, such as"},{"kind":"arabic","text_bw":"zw^An","text_ar":"زوان"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"and other refuse:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"straw"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]; (K, TA;) accord. to IAar, the"},{"kind":"italic_en","text":"bad, that is thrown away,"},{"kind":"text","text":"of wheat; as also ↓"},{"kind":"arabic","text_bw":"gafaA='N","text_ar":"غَفَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":". (Az, TA.) ―         -b2-  Also, (thus accord. to ISd in all the senses here following in this paragraph that are found in the K, as is said in the TA, and thus in some copies of the K,) or ↓"},{"kind":"arabic","text_bw":"gufaA='N","text_ar":"غُفَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (thus in the copies of the K followed in the TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"guvaA='N","text_ar":"غُثَا=ءٌ"},{"kind":"text","text":"[i. e. The"},{"kind":"italic_en","text":"rubbish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small rubbish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"particles of things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refuse, and scum, and rotten leaves mixed with the scum,"},{"kind":"text","text":"of a torrent]. (K, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"Fragments,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broken portions, of wheat:"},{"kind":"text","text":"(K, TA;) or the"},{"kind":"italic_en","text":"stalks thereof."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"italic_en","text":"A blight incident to palm-trees, like dust falling upon the unripe dates, preventing their becoming ripe,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"and rendering them tasteless."},{"kind":"text","text":"(S [in which the word thus expl. is"},{"kind":"arabic","text_bw":"gafFY","text_ar":"غَفًى"},{"kind":"text","text":"] and TA.) And"},{"kind":"italic_en","text":"A thick crust that comes upon unripe dates:"},{"kind":"text","text":"[see 4 in art."},{"kind":"arabic","text_bw":"gfr","text_ar":"غفر"},{"kind":"text","text":":] or, as some say,"},{"kind":"italic_en","text":"bad dates, that become"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"in the skin"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse, and like the wings of locusts."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"italic_en","text":"A disease incident to straw, rendering it bad."},{"kind":"text","text":"(TA.) ―         -b6-  Also"},{"kind":"italic_en","text":"Such as they drive away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expel, of their camels."},{"kind":"text","text":"(K, TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"gafFY","text_ar":"غَفًى"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"bad"},{"kind":"text","text":"of anything. (TA.) ―         -b8-  And The"},{"kind":"italic_en","text":"low, vile, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"lower, viler,"},{"kind":"text","text":"&c.; or the"},{"kind":"italic_en","text":"refuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rabble;"},{"kind":"text","text":"of mankind. (TA.)"}],"source_refs":["Fr","S","TA","K"]}]},"classical_definitions":null}