n":"m","num":"p"},{"role":"present_2mp","form":"تُرابِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُرابِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُرابِط","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُرابِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُرابِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُرابِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُرابِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُرابِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُرابِطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُرابِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُرابِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رابَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رابَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُرابِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُرابِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":true,"lemma_key":"رابَطَ","root":"ربط","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n14512"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%A8%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"link, linkage"},{"pos":"noun","gloss":"hyperlink, link"},{"pos":"verb","gloss":"to be lined up, posted, stationed (of troops)"},{"pos":"verb","gloss":"to line up, take up positions"},{"pos":"verb","gloss":"to camp"},{"pos":"verb","gloss":"to be moored (of ships)"},{"pos":"verb","gloss":"to move into fighting positions"},{"pos":"verb","gloss":"to keep post or remain at or on the frontier, be on guard in a frontier-station"},{"pos":"verb","gloss":"to persevere in a thing"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of رَبَطَ (rabaṭa, “to link”)."},"ipa":["/raː.bitˤ/","/raː.ba.tˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14512","headword_ar":"رَابِطٌ","root":"rbT","body":[{"kind":"text","text":"[act. part. n. of 1]. ―         -b2-"},{"kind":"arabic","text_bw":"xal~afa fulaAnN biAlv~agori","text_ar":"خَلَّفَ فُلَانٌ بِالثَّغْرِ"},{"kind":"arabic","text_bw":"jayo$FA raAbiTapF","text_ar":"جَيْشًا رَابِطَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one left behind him on the frontier an army having their horses tied in preparation for the enemy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping post"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"bibaladi ka*aA raAbiTapN mina Alxayoli","text_ar":"بِبَلَدِ كَذَا رَابِطَةٌ مِنَ الخَيْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In such a town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, is a company of horsemen having their horses tied at the frontier in preparation for the enemy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping post on the frontier:"},{"kind":"text","text":"or it may perhaps mean,"},{"kind":"italic_en","text":"a number of horses tied:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"rabiyTN","text_ar":"رَبِيطٌ"},{"kind":"text","text":"]. (S.) ↓"},{"kind":"arabic","text_bw":"muraAbiTapN","text_ar":"مُرَابِطَةٌ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A company of warriors;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of men warring against an enemy:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"a company of men having their horses tied at the frontier in preparation for the enemy;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"keeping post on the frontier;"},{"kind":"text","text":"and in like manner [its pl.]"},{"kind":"arabic","text_bw":"muraAbiTaAtN","text_ar":"مُرَابِطَاتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a company of horsemen having their horses tied"},{"kind":"text","text":"&c. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"fulaAnN raAbiTu AljaA^o$i","text_ar":"فُلَانٌ رَابِطُ الجَاْشِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AljaA^o$i","text_ar":"الجَاْشِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rabiyTu","text_ar":"رَبِيطُ","orth_type":"arrow"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Such a one is strong in heart:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"courageous:"},{"kind":"text","text":"(K:) as though he tied himself from flight, (S, TA,) and restrained himself. by his boldness and courage. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"nafosN raAbiTN","text_ar":"نَفْسٌ رَابِطٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A spirit"},{"kind":"text","text":"["},{"kind":"italic_en","text":"still attached to the body,"},{"kind":"text","text":"and consequently"},{"kind":"italic_en","text":"not doomed, but"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having ample power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"liberty,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"capable of good;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"waAsiEN A^ariyDN","text_ar":"وَاسِعٌ اَرِيضٌ"},{"kind":"text","text":". (K.) An Arab is related by IAar to have said,"},{"kind":"arabic","text_bw":"Aall~`hum~a A@gofiroliY waAljilodu baAridN waAln~afosu","text_ar":"اَللّٰهُمَّ ا@غْفِرْلِى وَالجِلْدُ بَارِدٌ وَالنَّفْسُ"},{"kind":"arabic","text_bw":"raAbiTN waAlS~uHufu munota$irapN waAlt~awobapu maqobuwlapN","text_ar":"رَابِطٌ وَالصُّحُفُ مُنْتَشِرَةٌ وَالتَّوْبَةُ مَقْبُولَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O God, forgive me while the skin is cool,"},{"kind":"text","text":"not heated by fever,"},{"kind":"italic_en","text":"and the spirit is yet attached to my body, and is at liberty, and capable of good, and the volumes"},{"kind":"text","text":"in which my actions are registered"},{"kind":"italic_en","text":"are still expanded, and repentance is accepted"},{"kind":"text","text":"]: he meant thereby, while he was in health; before death. (TA.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"rabiyTN","text_ar":"رَبِيطٌ"},{"kind":"text","text":", in two places."}],"source_refs":["Mgh","S","K","TA"]}]},"classical_definitions":null}