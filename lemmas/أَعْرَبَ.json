{"lemma":"أَعْرَبَ","slug":"أَعْرَبَ","root":"ع.ر.ب","root_slug":"ع-ر-ب","root_link":"/words/roots/ع-ر-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَعْرَبْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَعْرَبْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَعْرَبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَعْرَبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَعْرَبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَعْرَبَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَعْرَبَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَعْرَبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَعْرَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَعْرَبُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَعْرَبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْرِب","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْرِبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْرِبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْرِبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْرِبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْرِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْرِبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْرِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْرِب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْرِب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْرِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْرِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْرِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْرِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْرِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْرِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْرِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْرِب","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْرِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَعْرَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَعْرَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n28531","n28565"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%B1%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to Arabicize, Arabize; to give an Arabic form"},{"pos":"verb","gloss":"to make clear, to make plain, to express unmistakably, to state clearly, to declare"},{"pos":"verb","gloss":"to utter, to voice, to proclaim, to make known, to manifest"},{"pos":"verb","gloss":"to give to understand, to give expression to a sentiment"},{"pos":"verb","gloss":"to use desinential inflection (ʾiʿrāb), to speak or write using the grammatical endings"},{"pos":"verb","gloss":"to parse or construe (a word, a phrase, a sentence, and so on)"},{"pos":"verb","gloss":"to give earnest money"},{"pos":"verb","gloss":"to speak obscenely towards; to expressly excite the sexual lust of","tags":["obsolete"]},{"pos":"verb","gloss":"to copulate with, to coitize (a عَرُوب (ʕarūb) woman)","tags":["obsolete","vulgar"]}]},"etymology":{"source":"wiktextract","text":"Denominal verb of عَرْبُون (ʕarbūn).\n\nDenominal verb of عَرُوب (ʕarūb)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28531","headword_ar":"اعرب","root":"Erb","body":[{"kind":"text","text":", (AZ, Msb, TA,) [for"},{"kind":"arabic","text_bw":"AErb AlkalaAma","text_ar":"اعرب الكَلَامَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"AfSH","text_ar":"افصح"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AfSH AlkalaAma","text_ar":"افصح الكَلَامَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"He spoke clearly, plainly, distinctly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intel-ligibly,"},{"kind":"text","text":"(AZ, A, Msb, K, * TA,)"},{"kind":"italic_en","text":"in Arabic;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"tEr~b","text_ar":"تعرّب","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AstErb","text_ar":"استعرب","orth_type":"arrow"},{"kind":"text","text":"; said of a foreigner, or one [previously] not clear, plain, distinct, or intelligible, in speech: (AZ, Msb, TA:) and ↓"},{"kind":"arabic","text_bw":"Earuba","text_ar":"عَرُبَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EurobN","text_ar":"عُرْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuruwbN","text_ar":"عُرُوبٌ"},{"kind":"text","text":", accord. to Th, and"},{"kind":"arabic","text_bw":"EurobapN","text_ar":"عُرْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EiraAbapN","text_ar":"عِرَابَةٌ"},{"kind":"text","text":"[which accord. to general analogy would be"},{"kind":"arabic","text_bw":"EaraAbapN","text_ar":"عَرَابَةٌ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"Euruwbiy~apN","text_ar":"عُرُوبِيَّةٌ"},{"kind":"text","text":"; (TA;) or ↓"},{"kind":"arabic","text_bw":"Eariba","text_ar":"عَرِبَ","orth_type":"arrow"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) [likewise] signifies"},{"kind":"italic_en","text":"he spoke clearly, plainly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinctly, after being barbarous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vitious, in speech:"},{"kind":"text","text":"(Msb, TA:) and ↓"},{"kind":"arabic","text_bw":"Earuba","text_ar":"عَرُبَ","orth_type":"arrow"},{"kind":"italic_en","text":"he spoke without incorrectness;"},{"kind":"text","text":"(Msb;) and [so"},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":", for]"},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"committing no error in speech:"},{"kind":"text","text":"(K, TA:) and the"},{"kind":"italic_en","text":"expressing of meanings clearly, plainly, distinctly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuously, by words."},{"kind":"text","text":"(TA.) [↓"},{"kind":"arabic","text_bw":"Er~b","text_ar":"عرّب","orth_type":"arrow"},{"kind":"text","text":", also, has a similar meaning:] it is said in a trad.,"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kaAnuwA yasotaHib~uwna A^ano yulaq~inuwA AlS~abiY~a Hiyna yuEar~ibu","text_ar":"كَانُوا يَسْتَحِبُّونَ اَنْ يُلَقِّنُوا الصَّبِىَّ حِينَ يُعَرِّبُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"yaquwla laA A_ilaAha A_il~aA A@ll~`hu saboEa mar~aAtK","text_ar":"يَقُولَ لَا اـِلَاهَ اـِلَّا ا@للّٰهُ سَبْعَ مَرَّاتٍ"},{"kind":"text","text":"(O, TA) i. e. ["},{"kind":"italic_en","text":"They used to like teaching the boy,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"when he spoke distinctly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"articulately,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to say"},{"kind":"text","text":"“"},{"kind":"italic_en","text":"There is no deity but God"},{"kind":"text","text":"”"},{"kind":"italic_en","text":"seven times."},{"kind":"text","text":"] (TA.) And one says,"},{"kind":"arabic","text_bw":"AErb AlkalaAma","text_ar":"اعرب الكَلَامَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AErb bihi","text_ar":"اعرب بِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He made the speech"},{"kind":"text","text":"[that he spoke]"},{"kind":"italic_en","text":"clear, plain, distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perspicuous."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AErb biHuj~atihi","text_ar":"اعرب بِحُجَّتِهِ"},{"kind":"italic_en","text":"He declared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke out clearly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly, his argument, plea, allegation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, without fearing any one."},{"kind":"text","text":"(S, O.) And"},{"kind":"arabic","text_bw":"A^aEorabotu Al$~aYo'a","text_ar":"اَعْرَبْتُ الشَّىْءَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AErbt","text_ar":"اعربت"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Ear~abotuhu","text_ar":"عَرَّبْتُهُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Er~bt Eanohu","text_ar":"عرّبت عَنْهُ"},{"kind":"text","text":", which last, accord. to Fr, is better than"},{"kind":"arabic","text_bw":"Er~bthu","text_ar":"عرّبتهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AErbthu","text_ar":"اعربتهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I made the thing clear, plain, distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifest."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AErb Eam~aA fiY Damiyrihi","text_ar":"اعرب عَمَّا فِى ضَمِيرِهِ"},{"kind":"italic_en","text":"He declared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke out clearly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly, what was in his mind."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AErb Eanohu lisaAnuhu","text_ar":"اعرب عَنْهُ لِسَانُهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Er~b","text_ar":"عرّب","orth_type":"arrow"},{"kind":"arabic","text_bw":"Enh","text_ar":"عنه"},{"kind":"text","text":","},{"kind":"italic_en","text":"His tongue made clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke clearly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly, for him:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eam~aA fiY","text_ar":"عَمَّا فِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yuEar~ibu","text_ar":"يُعَرِّبُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"qalobihi lisaAnuhu","text_ar":"قَلْبِهِ لِسَانُهُ"},{"kind":"italic_en","text":"His tongue tells plainly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declares, what is in his heart."},{"kind":"text","text":"(Az, TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"Alv~ay~ibu tuEoribu Eano nafosihaA","text_ar":"الثَّيِّبُ تُعْرِبُ عَنْ نَفْسِهَا"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"AlA^ay~imu","text_ar":"الاَيِّمُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tuEar~ibu","text_ar":"تُعَرِّبُ","orth_type":"arrow"},{"kind":"text","text":", accord. to different relaters, but some say the former only, (Msb,) i. e. ["},{"kind":"italic_en","text":"She who has become a widow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"been divorced,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"she who has no husband, whether she be a virgin"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not being a virgin,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"shall speak out plainly for herself"},{"kind":"text","text":"[when demanded in marriage]: (S, Msb:) or"},{"kind":"arabic","text_bw":"Alv~ay~ibu yuEoribu EanohaA lisaAnuhaA","text_ar":"الثَّيِّبُ يُعْرِبُ عَنْهَا لِسَانُهَا"},{"kind":"text","text":", so accord. to IKt, (O,) or"},{"kind":"arabic","text_bw":"EnhA","text_ar":"عنها"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"yuEar~ibu","text_ar":"يُعَرِّبُ","orth_type":"arrow"},{"kind":"text","text":", (Mgh, O,) so accord. to A 'Obeyd, but, as IAmb says, both are dial. vars. of which neither is preferable to the other; and the meaning is ["},{"kind":"italic_en","text":"she who has become a widow,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"her tongue"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"shall declare for her."},{"kind":"text","text":"(O.) One says also,"},{"kind":"arabic","text_bw":"AErb Eani Alr~ajuli","text_ar":"اعرب عَنِ الرَّجُلِ"},{"kind":"italic_en","text":"He spoke out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explained, for the man."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eani Alqawomi","text_ar":"عَنِ القَوْمِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ear~abotu","text_ar":"عَرَّبْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I spoke for the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party;"},{"kind":"text","text":"(Fr, S, Mgh, * O, K;)"},{"kind":"italic_en","text":"and pleaded for them;"},{"kind":"text","text":"(Fr, Mgh, * TA;) as also"},{"kind":"arabic","text_bw":"A^aEorabotu","text_ar":"اَعْرَبْتُ"},{"kind":"text","text":"; but the former in this sense is better known. (Mgh.) And"},{"kind":"arabic","text_bw":"AErb Eanohu","text_ar":"اعرب عَنْهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Enh","text_ar":"عنه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Er~b","text_ar":"عرّب","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He pleaded his cause."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eano HaAjatihi","text_ar":"عَنْ حَاجَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Er~b","text_ar":"عرّب","orth_type":"arrow"},{"kind":"italic_en","text":"He spoke and pleaded for the object of his want."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, chaste, uncorrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from barbarousness, in speech;"},{"kind":"text","text":"although not an Arab. (Msb.) And"},{"kind":"arabic","text_bw":"lahu AlkalaAma","text_ar":"لَهُ الكَلَامَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ear~abotu","text_ar":"عَرَّبْتُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEoriybN","text_ar":"تَعْرِيبٌ"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"A^aEorabotu lh","text_ar":"اَعْرَبْتُ له"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"I made the speech"},{"kind":"text","text":"[that I spoke]"},{"kind":"italic_en","text":"clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain, to him, so that there was in it no barbarousness."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"manoTiqahu","text_ar":"مَنْطِقَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Er~b","text_ar":"عرّب","orth_type":"arrow"},{"kind":"text","text":", (S, O,) inf. n."},{"kind":"arabic","text_bw":"taEoriybN","text_ar":"تَعْرِيبٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He made his speech free from error,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incorrectness."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"A^aEorabotu AlHarofa","text_ar":"اَعْرَبْتُ الحَرْفَ"},{"kind":"italic_en","text":"I made the"},{"kind":"arabic","text_bw":"Hrf","text_ar":"حرف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"word"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain:"},{"kind":"text","text":"or the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"in this case denotes privation, and the meaning is (assumed tropical:)"},{"kind":"italic_en","text":"I removed its"},{"kind":"arabic","text_bw":"Erb","text_ar":"عرب"},{"kind":"text","text":", [app. ↓"},{"kind":"arabic","text_bw":"Earab","text_ar":"عَرَب","orth_type":"arrow"},{"kind":"text","text":", from this word as inf. n. of"},{"kind":"arabic","text_bw":"Eariba","text_ar":"عَرِبَ"},{"kind":"text","text":"used in relation to the stomach &c.,] i. e."},{"kind":"italic_en","text":"vagueness."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AErb kalaAmahu","text_ar":"اعرب كَلَامَهُ"},{"kind":"italic_en","text":"He made his speech free from error,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incorrectness, in"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AlA_iEoraAb","text_ar":"الاـِعْرَاب"},{"kind":"text","text":"[here meaning what grammarians generally intend thereby, namely,"},{"kind":"italic_en","text":"desinential syntax,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the science of the various inflections of words, literal"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"virtual, by reason of the various governing words"},{"kind":"text","text":"]. (S, O.) ["},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":"is also used by grammarians as meaning"},{"kind":"italic_en","text":"He declined"},{"kind":"text","text":"a word; and"},{"kind":"arabic","text_bw":"A^uEoriba","text_ar":"اُعْرِبَ"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"It was declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declinable;"},{"kind":"text","text":"in these senses opposed to"},{"kind":"arabic","text_bw":"banaY","text_ar":"بَنَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buniYa","text_ar":"بُنِىَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"binaA='N","text_ar":"بِنَا=ءٌ"},{"kind":"text","text":": and the former also as meaning"},{"kind":"italic_en","text":"He analyzed grammatically,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parsed,"},{"kind":"text","text":"a sentence: and the inf. n. of the verb (act. and pass.) in these senses is"},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":".] ―         -b3-  See also 2, first sentence: ―         -b4-  and again in the first third part of the paragraph. ―         -b5-"},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"[a person]"},{"kind":"italic_en","text":"to revert from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquish, foul speech;"},{"kind":"text","text":"(K, TA;) and so ↓"},{"kind":"arabic","text_bw":"taEoriybN","text_ar":"تَعْرِيبٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b6-  And The"},{"kind":"italic_en","text":"speaking foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obscene, language;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"taEoriybN","text_ar":"تَعْرِيبٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AisotiEoraAbN","text_ar":"اِسْتِعْرَابٌ","orth_type":"arrow"},{"kind":"text","text":": (O, K:) thus it bears two contr. significations. (K, TA.) One says of a man,"},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":"[&c.], (S, O,) or"},{"kind":"arabic","text_bw":"AErb fiY kalaAmihi","text_ar":"اعرب فِى كَلَامِهِ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He spoke foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obscene, language."},{"kind":"text","text":"(S, O, Msb.) [Golius and Freytag have assigned this meaning to ↓"},{"kind":"arabic","text_bw":"tEr~b","text_ar":"تعرّب","orth_type":"arrow"},{"kind":"text","text":"also: the latter of them as from the S and K; in neither of which do I find it.] ―         -b7-  And The"},{"kind":"italic_en","text":"act of copulating:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"speaking of that act in an oblique,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indirect, manner."},{"kind":"text","text":"(K.)       -A2-  And"},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":", (S, O,) inf. n."},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He had a child born to him of Arabian complexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"colour."},{"kind":"text","text":"(S, O, K.) ―         -b2-  And"},{"kind":"italic_en","text":"He possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to acquire, horses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"camels, of pure Arabian race."},{"kind":"text","text":"(TA. [See also 2, in the middle of the latter half; and see"},{"kind":"arabic","text_bw":"muEoribN","text_ar":"مُعْرِبٌ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":"signifies One's"},{"kind":"italic_en","text":"knowing"},{"kind":"text","text":"a horse"},{"kind":"italic_en","text":"of pure Arabian race from one of mean race by his neighing."},{"kind":"text","text":"(K.) And A horse's"},{"kind":"italic_en","text":"being known by his neighing to be of pure Arabian race, free from any admixture of other than Arabian blood:"},{"kind":"text","text":"(K, TA:) [or his"},{"kind":"italic_en","text":"making himself to be known as such by his neighing;"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"AErb","text_ar":"اعرب"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"neighed, and was consequently known to be of Arabian race."},{"kind":"text","text":"(A.) ―         -b4-  And The"},{"kind":"italic_en","text":"making"},{"kind":"text","text":"a horse"},{"kind":"italic_en","text":"to run."},{"kind":"text","text":"(K.) Accord. to Fr, one says,"},{"kind":"arabic","text_bw":"AErb EalaY farasihi","text_ar":"اعرب عَلَى فَرَسِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He made his horse to run:"},{"kind":"text","text":"but he adds that some say"},{"kind":"arabic","text_bw":"Agrb","text_ar":"اغرب"},{"kind":"text","text":". (O.)       -A3-  And"},{"kind":"arabic","text_bw":"A_iEoraAbN","text_ar":"اـِعْرَابٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"taking as one's wife a woman such as is termed"},{"kind":"arabic","text_bw":"EaruwbN","text_ar":"عَرُوبٌ"},{"kind":"text","text":"[q. v.]. (K.)       -A4-"},{"kind":"arabic","text_bw":"AErb saqoYu Alqawomi","text_ar":"اعرب سَقْىُ القَوْمِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The people's watering"},{"kind":"text","text":"[of their camels],"},{"kind":"italic_en","text":"having been at one time on alternate days, and another time on the fourth day after that of the next preceding watering, then became, and continued to be, of one uniform way."},{"kind":"text","text":"(S, O.)       -A5-  See also 2, last four sentences."}],"source_refs":["AZ","Msb","TA","A","K","O","S","Mgh"]},{"entry_id":"n28565","headword_ar":"اَعْرَبُ","root":"Erb","body":[{"kind":"italic_en","text":"More,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, distinct"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain"},{"kind":"text","text":"[&c.]. (TA.)"}],"source_refs":[]}]}}