per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَلْجَأا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَلْجَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْجَأُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْجَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلْجَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَلْجَأْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَلْجَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَلْجَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"لَجَأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"لَجَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":19,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n37566","n37568"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D8%AC%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take shelter, to take refuge; to seek asylum"},{"pos":"verb","gloss":"to resort to"},{"pos":"verb","gloss":"to compel, to coerce to take refuge"},{"pos":"verb","gloss":"to transfer (a right towards a thing), to consider someone as a refuge of","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of لَجَئَ (lajaʔa, “to take refuge”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"shelter, refuge"}]},"etymology":null,"ipa":["/la.d͡ʒa.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37566","headword_ar":"لجّا","root":"ljA^","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"talojiy^apN","text_ar":"تَلْجِيَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He forced"},{"kind":"text","text":"a person"},{"kind":"italic_en","text":"to do a thing against his will:"},{"kind":"text","text":"(S, K:) or,"},{"kind":"italic_en","text":"to do a thing which was contrary to what it appeared to be."},{"kind":"text","text":"(AHeyth.) ―         -b2-"},{"kind":"arabic","text_bw":"talojiy^apN","text_ar":"تَلْجِيَةٌ"},{"kind":"text","text":"is also explained as signifying The"},{"kind":"italic_en","text":"leaving one's property to some one"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more of his heirs, in preference to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the exclusion of, the other"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"others."},{"kind":"arabic","text_bw":"lj~A^","text_ar":"لجّا"},{"kind":"italic_en","text":"He so left"},{"kind":"text","text":"his property. (ISh.) ―         -b3-  See 4."}],"source_refs":["S","K"]},{"entry_id":"n37568","headword_ar":"لَجَاٌ","root":"ljA^","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"malojaA^N","text_ar":"مَلْجَاٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"mulotajaA^N","text_ar":"مُلْتَجَاٌ","orth_type":"arrow"},{"kind":"text","text":"(K, art."},{"kind":"arabic","text_bw":"lHd","text_ar":"لحد"},{"kind":"text","text":"; &c.)"},{"kind":"italic_en","text":"A place to which one has recourse for refuge, protection, preservation, concealment, covert,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lodging; a place of refuge; an asylum; a refuge."},{"kind":"text","text":"(S, K.) The hemzeh of the ↓ second is sometimes elided; and this is done to assimilate the word to"},{"kind":"arabic","text_bw":"manojaA","text_ar":"مَنْجَا"},{"kind":"text","text":", when it is used therewith; like as"},{"kind":"arabic","text_bw":"mnjA","text_ar":"منجا"},{"kind":"text","text":"is written with hemzeh to assimilate it in the like case to"},{"kind":"arabic","text_bw":"malojaA^N","text_ar":"مَلْجَاٌ"},{"kind":"text","text":". ―         -b2-  [↓"},{"kind":"arabic","text_bw":"mljA^N","text_ar":"ملجاٌ","orth_type":"arrow"},{"kind":"text","text":"is often applied to a man: and you say also,]"},{"kind":"arabic","text_bw":"fulaAnN Hasanu","text_ar":"فُلَانٌ حَسَنُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AlmalojaA_i","text_ar":"المَلْجَاـِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is a good person to whom to have recourse for protection"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealment"},{"kind":"text","text":"]. The pl. of"},{"kind":"arabic","text_bw":"lajaA^N","text_ar":"لَجَاٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^alojaA='N","text_ar":"اَلْجَا=ءٌ"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"lajaA^N","text_ar":"لَجَاٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A wife."},{"kind":"text","text":"(L.) ―         -b4-"},{"kind":"italic_en","text":"An heir."},{"kind":"text","text":"(ISh.) [See 2.]       -A2-  The"},{"kind":"italic_en","text":"frog:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"a kind of tortoise, that lives on the land and in the sea:"},{"kind":"text","text":"(M:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (K.)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"ljA^p","text_ar":"لجاة"},{"kind":"italic_en","text":"of the sea"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"All~ajaA^apu AlbaHoriy~apu","text_ar":"اللَّجَاَةُ البَحْرِيَّةُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"is asserted to have a tongue in its breast, and to kill the animal that it strikes."},{"kind":"text","text":"(Dmr.)"}],"source_refs":["S","K","M"]}]}}