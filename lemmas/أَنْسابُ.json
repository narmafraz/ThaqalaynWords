nusoyapN","text_ar":"نُسْيَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"Relationship; relation; kindred; consanguinity;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"family; race; lineage; parentage; pedigree; genealogy; origin; reputed relationship"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lineage"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"origin;"},{"kind":"text","text":"] (K;)"},{"kind":"italic_en","text":"with respect to father and mother;"},{"kind":"text","text":"(ISk;) or"},{"kind":"italic_en","text":"with respect to fathers only:"},{"kind":"text","text":"(K:) pl. of the first,"},{"kind":"arabic","text_bw":"A^anosaAbN","text_ar":"اَنْسَابٌ"},{"kind":"text","text":"; (S;) of the ↓ second,"},{"kind":"arabic","text_bw":"nisabN","text_ar":"نِسَبٌ"},{"kind":"text","text":"; and of the ↓ third,"},{"kind":"arabic","text_bw":"nusabN","text_ar":"نُسَبٌ"},{"kind":"text","text":". (Msb.) The first, by poetical license, is contracted into ↓"},{"kind":"arabic","text_bw":"nasobN","text_ar":"نَسْبٌ","orth_type":"arrow"},{"kind":"text","text":". (T.) [You say,]"},{"kind":"arabic","text_bw":"bayonahumaA nasabN","text_ar":"بَيْنَهُمَا نَسَبٌ"},{"kind":"italic_en","text":"Between them is relationship;"},{"kind":"text","text":"said whether they may lawfully marry one another, or not. (Msb.) See"},{"kind":"arabic","text_bw":"nasiybN","text_ar":"نَسِيبٌ"},{"kind":"text","text":"."}],"source_refs":["S","K"]}]}}