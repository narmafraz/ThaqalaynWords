{"lemma":"جُفَرٌ","slug":"جُفَرٌ","root":"ج.ف.ر","root_slug":"ج-ف-ر","root_link":"/words/roots/ج-ف-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n5962","","n5963"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8F%D9%81%D9%8E%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"divination, fortune-telling"}]},"etymology":{"source":"wiktextract","text":"From عِلْمُ الْجَفْر (ʕilmu l-jafr)"},"ipa":["/d͡ʒafr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5962","headword_ar":"جَفَرَ","root":"jfr","body":[{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became wide:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"became inflated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swollen."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"jafara janobaAhu","text_ar":"جَفَرَ جَنْبَاهُ"},{"kind":"italic_en","text":"His"},{"kind":"text","text":"(a kid's, S and Msb, or lamb's, Msb)"},{"kind":"italic_en","text":"sides became widened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distended:"},{"kind":"text","text":"(S, Msb:) and"},{"kind":"arabic","text_bw":"janobaAhu","text_ar":"جَنْبَاهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajfr","text_ar":"اجفر","orth_type":"arrow"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"Anjfr","text_ar":"انجفر","orth_type":"arrow"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"hDm","text_ar":"هضم"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"his"},{"kind":"text","text":"(a horse's)"},{"kind":"italic_en","text":"sides became inflated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swollen."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a lamb, K, and a kid, TA)"},{"kind":"italic_en","text":"became what is termed"},{"kind":"arabic","text_bw":"jaforN","text_ar":"جَفْرٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"tjf~r","text_ar":"تجفّر","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Astjfr","text_ar":"استجفر","orth_type":"arrow"},{"kind":"text","text":": (K:) and ↓"},{"kind":"arabic","text_bw":"tjf~rt","text_ar":"تجفّرت","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Astjfrt","text_ar":"استجفرت","orth_type":"arrow"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a kid)"},{"kind":"italic_en","text":"became a"},{"kind":"arabic","text_bw":"jaforap","text_ar":"جَفْرَة"},{"kind":"text","text":". (ISh, TA.) And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a boy)"},{"kind":"italic_en","text":"became what is termed"},{"kind":"arabic","text_bw":"jaforN","text_ar":"جَفْرٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"tjf~r","text_ar":"تجفّر","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"Astjfr","text_ar":"استجفر","orth_type":"arrow"},{"kind":"text","text":": (A:) and this last verb,"},{"kind":"italic_en","text":"he became large in the sides."},{"kind":"text","text":"(L.)       -A2-"},{"kind":"arabic","text_bw":"jafara","text_ar":"جَفَرَ"},{"kind":"text","text":"(S, A)"},{"kind":"arabic","text_bw":"Eani AlD~iraAbi","text_ar":"عَنِ الضِّرَابِ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Eani AlA_ibili","text_ar":"عَنِ الاـِبِلِ"},{"kind":"text","text":", (A,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"jufuwrN","text_ar":"جُفُورٌ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"Ajtfr","text_ar":"اجتفر","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Ajfr","text_ar":"اجفر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ijofaArN","text_ar":"اـِجْفَارٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"jf~r","text_ar":"جفّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajofiyrN","text_ar":"تَجْفِيرٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a stallioncamel)"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"abstained,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"from covering,"},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"and avoided it; having indulged in it so much that he was wearied;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"and his seminal fluid became little:"},{"kind":"text","text":"(TA:) you say of a ram,"},{"kind":"arabic","text_bw":"rabaDa","text_ar":"رَبَضَ"},{"kind":"text","text":", (S, A,) not"},{"kind":"arabic","text_bw":"jafara","text_ar":"جَفَرَ"},{"kind":"text","text":". (S.) And"},{"kind":"page_break","n":433},{"kind":"arabic","text_bw":"jafara Eani AlmaroA^api","text_ar":"جَفَرَ عَنِ المَرْاَةِ"},{"kind":"text","text":", (IAar, TA,) and"},{"kind":"arabic","text_bw":"EanohaA","text_ar":"عَنْهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajfr","text_ar":"اجفر","orth_type":"arrow"},{"kind":"text","text":", (IAar, K,) and ↓"},{"kind":"arabic","text_bw":"Ajtfr","text_ar":"اجتفر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"jf~r","text_ar":"جفّر","orth_type":"arrow"},{"kind":"text","text":", (IAar, TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"abstained from the woman;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"he abstained from sexual intercourse with her."},{"kind":"text","text":"(IAar, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jafara mina AlmaraDi","text_ar":"جَفَرَ مِنَ المَرَضِ"},{"kind":"italic_en","text":"He recovered from the disease."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["K","S","Msb","TA","A","IAar"]},{"entry_id":"n5963","headword_ar":"جَفْرٌ","root":"jfr","body":[{"kind":"italic_en","text":"A lamb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kid, whose sides have become widened, or distended:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a lamb,"},{"kind":"text","text":"(IAmb, Msb, K,) and"},{"kind":"italic_en","text":"a kid,"},{"kind":"text","text":"(K, * TA,)"},{"kind":"italic_en","text":"that has become large, and begun to pasture,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and whose sides have become widened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distended:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a lamb,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"a kid,"},{"kind":"text","text":"(S, Mgh, Msb, K, * TA,)"},{"kind":"italic_en","text":"that is four months old,"},{"kind":"text","text":"(S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"and whose sides have become widened, and that is weaned,"},{"kind":"text","text":"(A'Obeyd, S,)"},{"kind":"italic_en","text":"and has taken to pasture:"},{"kind":"text","text":"(A'Obeyd, TA:) or"},{"kind":"italic_en","text":"this is sometimes four months, and sometimes five months, after the birth:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a young lamb, and a kid, after it has been weaned, when six months old:"},{"kind":"text","text":"(IAar, TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^ajofaArN","text_ar":"اَجْفَارٌ"},{"kind":"text","text":"(K) and [of mult.]"},{"kind":"arabic","text_bw":"jifaArN","text_ar":"جِفَارٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"jafarapN","text_ar":"جَفَرَةٌ"},{"kind":"text","text":": (K) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S, A, Mgh, Msb, K:) or"},{"kind":"arabic","text_bw":"jaforapN","text_ar":"جَفْرَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a female kid that has become satiated with leguminous herbs and with shrubs, and is independent of its mother:"},{"kind":"text","text":"(ISh, TA:) IAmb applies it to a female lamb and a female kid; and this is correct, though some say that it is applied to the latter only. (TA.) ―         -b2-"},{"kind":"italic_en","text":"A boy when his belly has become widened,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"when his flesh has become swollen out,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"and he has begun to eat:"},{"kind":"text","text":"(A, K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"(K.) [See"},{"kind":"arabic","text_bw":"$aAdixN","text_ar":"شَادِخٌ"},{"kind":"text","text":"; and see also"},{"kind":"arabic","text_bw":"muTab~ixN","text_ar":"مُطَبِّخٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"italic_en","text":"A well,"},{"kind":"text","text":"(Msb, K,) or"},{"kind":"italic_en","text":"a wide well,"},{"kind":"text","text":"(S, A,)"},{"kind":"italic_en","text":"not cased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walled round, within;"},{"kind":"text","text":"(S, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"jaforapN","text_ar":"جَفْرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (R, TA:) or,"},{"kind":"italic_en","text":"of which a portion is cased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walled round, within,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and a portion is not:"},{"kind":"text","text":"(TA:) the former of the masc. gender: pl."},{"kind":"arabic","text_bw":"jifaArN","text_ar":"جِفَارٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"fulaAnN munohadimu Aljafori","text_ar":"فُلَانٌ مُنْهَدِمُ الجَفْرِ"},{"kind":"text","text":"(A, K *) ["},{"kind":"italic_en","text":"Such a one's well is in a state of demolition;"},{"kind":"text","text":"meaning,]"},{"kind":"italic_en","text":"such a one has no judgment:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"has no intelligence."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"A_in~a jaforaka EalaY~a lahaArK","text_ar":"اـِنَّ جَفْرَكَ عَلَىَّ لَهَارٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily thy well is falling in upon me;"},{"kind":"text","text":"meaning]"},{"kind":"italic_en","text":"thy mischief is coming quickly upon me."},{"kind":"text","text":"(A, TA.) ―         -b3-  [The pl.]"},{"kind":"arabic","text_bw":"jafaArN","text_ar":"جَفَارٌ"},{"kind":"text","text":"also signifies [simply]"},{"kind":"italic_en","text":"Wells."},{"kind":"text","text":"(K.) ―         -b4-  And hence, (TA,) She-camels"},{"kind":"italic_en","text":"abounding with milk."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["Msb","IAmb","K","TA","S","Mgh","IAar","A","ISh","R"]}]},"classical_definitions":null}