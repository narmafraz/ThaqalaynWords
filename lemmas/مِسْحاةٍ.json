{"lemma":"مِسْحاةٍ","slug":"مِسْحاةٍ","root":"س.ح.#","root_slug":"س-ح-_","root_link":"/words/roots/س-ح-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n19182"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%90%D8%B3%D9%92%D8%AD%D8%A7%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19182","headword_ar":"مِسْحَاةٌ","root":"sHw and sHY","body":[{"kind":"italic_en","text":"A shovel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spade, of iron;"},{"kind":"text","text":"(MA, PS;)"},{"kind":"italic_en","text":"an implement"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"like the"},{"kind":"arabic","text_bw":"mijorafap","text_ar":"مِجْرَفَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"except that it is of iron,"},{"kind":"text","text":"(S, Msb,)"},{"kind":"italic_en","text":"with which clay, soil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mud, is cleared away"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"from the surface of the earth:"},{"kind":"text","text":"(Msb:)"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"misoHaAp","text_ar":"مِسْحَاة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for digging,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"a spade,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"has a cross piece of wood upon which the digger presses his foot:"},{"kind":"text","text":"K, voce"},{"kind":"arabic","text_bw":"EitorN","text_ar":"عِتْرٌ"},{"kind":"text","text":":) and there is"},{"kind":"italic_en","text":"a curved kind,"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"a sort of hoe,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"such as is called in Pers."},{"kind":"arabic","text_bw":"kananod","text_ar":"كَنَنْد"},{"kind":"text","text":": (S:) pl."},{"kind":"arabic","text_bw":"masaAHK","text_ar":"مَسَاحٍ"},{"kind":"text","text":". (S, Msb.) Ru-beh likens the toes, or extremities of the fore parts of the hoofs, of horses, to"},{"kind":"arabic","text_bw":"masaAHK","text_ar":"مَسَاحٍ"},{"kind":"text","text":"; because with them they pare the ground: so in the T: or, accord. to the M, he likens thereto the hoofs of asses. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"misoHaApu Aln~aAri","text_ar":"مِسْحَاةُ النَّارِ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"The fire-shovel;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing with which the fire is stirred."},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"miHoraAvo","text_ar":"مِحْرَاثْ"},{"kind":"text","text":".)"}],"source_refs":["S","Msb","K"]}]},"classical_definitions":null}