{"lemma":"اِسْوَدَّ","slug":"اِسْوَدَّ","root":"س.#.د","root_slug":"س-_-د","root_link":"/words/roots/س-_-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"اِسْوَدَدْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"اِسْوَدَدْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"اِسْوَدَدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"اِسْوَدَدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"اِسْوَدَدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"اِسْوَدَّ","in_corpus":true,"count":37,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"اِسْوَدَّت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"اِسْوَدّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"اِسْوَدَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"اِسْوَدُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"اِسْوَدَدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَسْوَدّ","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَسْوَدِد","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَسْوَدِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَسْوَدِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَسْوَدّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَسْوَدّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَسْوَدُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسْوَدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسْوَدِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسْوَدّ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسْوَدِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسْوَدّ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسْوَدِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسْوَدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسْوَدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْوَدّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْوَدّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْوَدُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْوَدُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْوَدِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْوَدّ","in_corpus":true,"count":37,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْوَدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"اِسْوَدَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"اِسْوَدَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":97,"cross_references":{"qac":{"found":true,"lemma_key":"اِسْوَدَّ","root":"سود","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n21167","n21189"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B3%D9%92%D9%88%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become black, to blacken"}]},"etymology":null,"ipa":["/is.wad.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21167","headword_ar":"اسوّد","root":"swd","body":[{"kind":"text","text":", (S, M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"AisowidaAdN","text_ar":"اِسْوِدَادٌ"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"AswAd~","text_ar":"اسوادّ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) inf. n."},{"kind":"arabic","text_bw":"AiswiydaAdN","text_ar":"اِسوِيدَادٌ"},{"kind":"text","text":"; (S, K;) and in poetry it is allowable to say ↓"},{"kind":"arabic","text_bw":"AisowaA^ad~a","text_ar":"اِسْوَاَدَّ","orth_type":"arrow"},{"kind":"text","text":", to avoid the concurrence of two quiescent letters; imperative [of ↓ the second]"},{"kind":"arabic","text_bw":"AisowaAdido","text_ar":"اِسْوَادِدْ"},{"kind":"text","text":", and the last two letters in this may be incorporated together [so that you may say"},{"kind":"arabic","text_bw":"AisowaAd~","text_ar":"اِسْوَادّ"},{"kind":"text","text":"]; (S;) said of a thing; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"sawida","text_ar":"سَوِدَ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Msb,) said of a man, (S, TA,) and of a thing, (TA,) aor."},{"kind":"arabic","text_bw":"yasowadu","text_ar":"يَسْوَدُ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"saAda","text_ar":"سَادَ","orth_type":"arrow"},{"kind":"text","text":", (M,) first pers."},{"kind":"arabic","text_bw":"sudotu","text_ar":"سُدْتُ"},{"kind":"text","text":", a form used by some; (S;)"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he, became"},{"kind":"arabic","text_bw":"A^asowad","text_ar":"اَسْوَد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"black"},{"kind":"text","text":"]: (S, M, Msb, K:) and ↓"},{"kind":"arabic","text_bw":"AswAd~","text_ar":"اسوادّ","orth_type":"arrow"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, became intensely so."},{"kind":"text","text":"(TA.) Nuseyb says,"},{"kind":"quote","text":"falamo A^amoliko sawaAdiY wataHotahu ↓ \n      sawidotu\n                      \n                     \n                        qamiySN mina AlquwhiY~i biyDN banaAy^iquho"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I am black,"},{"kind":"text","text":"(for Nuseyb was a slave,)"},{"kind":"italic_en","text":"and am not master of my person; but beneath it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"within it, is a shirt like the cloth of Koohistán, the gores of which are white:"},{"kind":"text","text":"by this"},{"kind":"arabic","text_bw":"qmyS","text_ar":"قميص"},{"kind":"text","text":"he means his heart;"},{"kind":"arabic","text_bw":"AlqamiySu","text_ar":"القَمِيصُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"qamiySu Alqalobi","text_ar":"قَمِيصُ القَلْبِ"},{"kind":"text","text":", tropically meaning “ the pericardium; ” and, by a synecdoche, “ the heart itself, with its appertenances ”]. (S, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Aswd~ wajohuhu","text_ar":"اسودّ وَجْهُهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His face became black:"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"his face became expressive of grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"displeasure, occasioned by fear"},{"kind":"text","text":"["},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"]: (Bd in iii. 102:)"},{"kind":"italic_en","text":"he became grieved, sorrowful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"displeased;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course, by reason of shame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in consequence of a deed that he had done"},{"kind":"text","text":"(Bd in xvi. 60) ["},{"kind":"italic_en","text":"&c.:"},{"kind":"text","text":"and often meaning"},{"kind":"italic_en","text":"he became disgraced"},{"kind":"text","text":"]: opposed to"},{"kind":"arabic","text_bw":"AiboyaD~a","text_ar":"اِبْيَضَّ"},{"kind":"text","text":". (Bd in iii. 102.)"}],"source_refs":["S","M","Msb","K","TA"]},{"entry_id":"n21189","headword_ar":"اَسْوَدُ","root":"swd","body":[{"kind":"italic_en","text":"Greater,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"greatest, in respect of estimation, rank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^ajal~u","text_ar":"اَجَلُّ"},{"kind":"text","text":": (S, K:) and, as some say,"},{"kind":"italic_en","text":"more"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"liberal"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bountiful"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"munificent:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"clement"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forbearing."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"huwa A^asowadu mino fulaAnK","text_ar":"هُوَ اَسْوَدُ مِنْ فُلَانٍ"},{"kind":"italic_en","text":"He is greater"},{"kind":"text","text":"&c. ("},{"kind":"arabic","text_bw":"A^ajal~u","text_ar":"اَجَلُّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"than such a one."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"AlA^asowadu mina Alqawomi","text_ar":"الاَسْوَدُ مِنَ القَوْمِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The greatest"},{"kind":"text","text":"&c. ("},{"kind":"arabic","text_bw":"AlA^ajal~u","text_ar":"الاَجَلُّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(K, TA.)       -A2-  Also"},{"kind":"italic_en","text":"Black;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"having"},{"kind":"arabic","text_bw":"sawaAd","text_ar":"سَوَاد"},{"kind":"text","text":", (M, * Mgh,) which is"},{"kind":"italic_en","text":"the contr. of"},{"kind":"arabic","text_bw":"bayaAD","text_ar":"بَيَاض"},{"kind":"text","text":": (M, Mgh:) and ↓"},{"kind":"arabic","text_bw":"A^asowadiY~N","text_ar":"اَسْوَدِىٌّ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":": (Ham p. 379:) [or has an intensive signification, like"},{"kind":"arabic","text_bw":"A^aHomarY~N","text_ar":"اَحْمَرىٌّ"},{"kind":"text","text":":] the fem. of"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"sawodaA='u","text_ar":"سَوْدَا=ءُ"},{"kind":"text","text":": (Mgh, Msb:) the dim. of"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"A^usay~idu","text_ar":"اُسَيِّدُ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb,) and it is allowable to say ↓"},{"kind":"arabic","text_bw":"A^usayowidu","text_ar":"اُسَيْوِدُ","orth_type":"arrow"},{"kind":"text","text":", [as is shown by an ex. voce"},{"kind":"arabic","text_bw":"A^asak~u","text_ar":"اَسَكُّ"},{"kind":"text","text":",] meaning ["},{"kind":"italic_en","text":"a little black thing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blackish,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"approaching to black;"},{"kind":"text","text":"(S;) and the abbreviated dim. is ↓"},{"kind":"arabic","text_bw":"suwayodN","text_ar":"سُوَيْدٌ","orth_type":"arrow"},{"kind":"text","text":": (S, Mgh, Msb:) the dim. of"},{"kind":"arabic","text_bw":"sawodaA='u","text_ar":"سَوْدَا=ءُ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"suwayodaA='u","text_ar":"سُوَيْدَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) the pl. of"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":"(M, Msb) and of"},{"kind":"arabic","text_bw":"sawodaA='u","text_ar":"سَوْدَا=ءُ"},{"kind":"text","text":"(Msb) is"},{"kind":"arabic","text_bw":"suwdN","text_ar":"سُودٌ"},{"kind":"text","text":"(M, Msb) and"},{"kind":"arabic","text_bw":"suwdaAnN","text_ar":"سُودَانٌ"},{"kind":"text","text":"[which latter is especially applied to human beings]. (M.)"},{"kind":"arabic","text_bw":"Als~uwdaAnu","text_ar":"السُّودَانُ"},{"kind":"text","text":"is said in the R to denote ["},{"kind":"italic_en","text":"The negroes;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that particular people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"race, who are the most stinking of mankind in the armpits and sweat,"},{"kind":"text","text":"and the more so those who are eunuchs. (TA.) [It (i. e."},{"kind":"arabic","text_bw":"AlswdAn","text_ar":"السودان"},{"kind":"text","text":") is also sometimes used for"},{"kind":"arabic","text_bw":"A^aroDu Als~uwdaAni","text_ar":"اَرْضُ السُّودَانِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"bilaAdu Als~uwdaAni","text_ar":"بِلَادُ السُّودَانِ"},{"kind":"text","text":", ("},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the country, of the negroes,"},{"kind":"text","text":") or the like: it is thus used in the TA voce"},{"kind":"arabic","text_bw":"samogarapu","text_ar":"سَمْغَرَةُ"},{"kind":"text","text":".] And the epithet"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":"is also applied by the Arabs to a thing that is"},{"kind":"arabic","text_bw":"A^axoDar","text_ar":"اَخْضَر"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"green"},{"kind":"text","text":"]; because it appears to be thus at a distance. (Msb. [See"},{"kind":"arabic","text_bw":"A^axoDaru","text_ar":"اَخْضَرُ"},{"kind":"text","text":": and see"},{"kind":"arabic","text_bw":"HadiyqapN dahomaA='u","text_ar":"حَدِيقَةٌ دَهْمَا=ءُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mudohaAm~apN","text_ar":"مُدْهَامَّةٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A^adohamu","text_ar":"اَدْهَمُ"},{"kind":"text","text":".]) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^asowadu Alqalobi","text_ar":"اَسْوَدُ القَلْبِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sawodaA=w^uhu","text_ar":"سَوْدَا=وُهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sawaAdN","text_ar":"سَوَادٌ"},{"kind":"text","text":". ―         -b3-  [And"},{"kind":"arabic","text_bw":"Als~awodaA='u","text_ar":"السَّوْدَا=ءُ"},{"kind":"italic_en","text":"The black bile; one of the four humours of the body;"},{"kind":"text","text":"of which the others are the yellow bile ("},{"kind":"arabic","text_bw":"AlS~aforaA='u","text_ar":"الصَّفْرَا=ءُ"},{"kind":"text","text":"), the blood ("},{"kind":"arabic","text_bw":"Ald~amu","text_ar":"الدَّمُ"},{"kind":"text","text":"), and the phlegm ("},{"kind":"arabic","text_bw":"Albalogamu","text_ar":"البَلْغَمُ"},{"kind":"text","text":").] ―         -b4-"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"text","text":"as opposed to"},{"kind":"arabic","text_bw":"A^aHomaru","text_ar":"اَحْمَرُ"},{"kind":"text","text":"[and meaning The"},{"kind":"italic_en","text":"Arab race,"},{"kind":"text","text":"and also, accord. to some, in this case also, the"},{"kind":"italic_en","text":"black"},{"kind":"text","text":"]: see"},{"kind":"arabic","text_bw":"A^aHomaru","text_ar":"اَحْمَرُ"},{"kind":"text","text":", in two places. ―         -b5-  As applied to a certain bird: see"},{"kind":"arabic","text_bw":"suwdaAniy~apN","text_ar":"سُودَانِيَّةٌ"},{"kind":"text","text":", in two places. ―         -b6-  Also, as a subst., (S,) or an epithet in which the quality of a subst. predominates, (Sh, M,) so that it is used as a subst., (Sh, TA,) but imperfectly decl., (TA,) (tropical:)"},{"kind":"italic_en","text":"A great serpent,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"in which is blackness:"},{"kind":"text","text":"(S, M:) the"},{"kind":"italic_en","text":"worst and greatest and most noxious of serpents, than which there is none more daring, for sometimes it opposes itself to a company of travellers, and follows the voice, and it is that which seeks retaliation, and he who is bitten by it will not escape death:"},{"kind":"text","text":"(Sh, TA:) it is pluralized as a subst., (Sh, S, M,) its pl. being"},{"kind":"arabic","text_bw":"A^asaAwidu","text_ar":"اَسَاوِدُ"},{"kind":"text","text":"(S, M) and"},{"kind":"arabic","text_bw":"A^asaAwiydu","text_ar":"اَسَاوِيدُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^asowadaAtN","text_ar":"اَسْوَدَاتٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) were it an epithet [used as such], its pl. would be"},{"kind":"arabic","text_bw":"suwdN","text_ar":"سُودٌ"},{"kind":"text","text":": it is also called"},{"kind":"arabic","text_bw":"A^asowadu saAliHN","text_ar":"اَسْوَدُ سَالِحٌ"},{"kind":"text","text":", because it casts off its slough every year: you do not say"},{"kind":"arabic","text_bw":"A^asowadu","text_ar":"اَسْوَدُ"},{"kind":"arabic","text_bw":"saAlixK","text_ar":"سَالِخٍ"},{"kind":"text","text":": (S:) the female is called ↓"},{"kind":"arabic","text_bw":"A^asowadapN","text_ar":"اَسْوَدَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M,) which is extr.; (M;) and to this the epithet"},{"kind":"arabic","text_bw":"saAlixapN","text_ar":"سَالِخَةٌ"},{"kind":"text","text":"is not applied. (S.) ―         -b7-"},{"kind":"arabic","text_bw":"AlA^asowadaAni","text_ar":"الاَسْوَدَانِ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"The serpent and the scorpion;"},{"kind":"text","text":"(Sh, Mgh, Msb, K;) which are to be killed during prayer: (Sh, Mgh, Msb:) so called by the attribution of predominance [to the former]. (Sh, TA.) ―         -b8-  And (tropical:)"},{"kind":"italic_en","text":"Dates and water;"},{"kind":"text","text":"(El-Ahmar, As, S, M, A, Mgh, Msb, K;) both together being thus called by a term which properly applies to one only, [accord. to some,] for [they say that]"},{"kind":"arabic","text_bw":"AlA^asowadu","text_ar":"الاَسْوَدُ"},{"kind":"text","text":"alone signifies"},{"kind":"italic_en","text":"dates,"},{"kind":"text","text":"not water, and especially, or mostly,"},{"kind":"italic_en","text":"the dates of El-Medeeneh;"},{"kind":"text","text":"and in like manner, Aboo-Bekr and 'Omar together are called"},{"kind":"arabic","text_bw":"AlEumaraAni","text_ar":"العُمَرَانِ"},{"kind":"text","text":"; and the sun and the moon together,"},{"kind":"arabic","text_bw":"AlqamaraAni","text_ar":"القَمَرَانِ"},{"kind":"text","text":": (TA:) or, as some say, it means"},{"kind":"italic_en","text":"water and milk;"},{"kind":"text","text":"and is applied by a rájiz to"},{"kind":"italic_en","text":"water and the herb called"},{"kind":"arabic","text_bw":"Alfav~","text_ar":"الفَثّ"},{"kind":"text","text":", of [the grain of] which bread is made, and is eaten [in time of dearth or drought]. (M, L.) See also"},{"kind":"arabic","text_bw":"suwayodN","text_ar":"سُوَيْدٌ"},{"kind":"text","text":". ―         -b9-  Also (assumed tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Har~ap","text_ar":"حَرَّة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"tract strewn with black and crumbling stones"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and night:"},{"kind":"text","text":"(S, M, L:) so called because of their blackness. (M, L.) A party came as guests to Muzebbid El-Medenee, and he said to them, “ There is nothing for you with us but the"},{"kind":"arabic","text_bw":"A^asowadaAni","text_ar":"اَسْوَدَانِ"},{"kind":"text","text":": ” and they replied, “ Verily therein is a sufficiency: dates and water: ” but he said, “ I meant not that: I only meant the"},{"kind":"arabic","text_bw":"Har~ap","text_ar":"حَرَّة"},{"kind":"text","text":"and the night. ” (S, M.) And as to the saying of 'Áïsheh, that she was with the Prophet when they had no food, but only the"},{"kind":"arabic","text_bw":"A^asowadaAni","text_ar":"اَسْوَدَانِ"},{"kind":"text","text":", which is expl. by the lexicologists as meaning dates and water, [and thus by Mtr in the Mgh, ISd says,] in my opinion she only meant the"},{"kind":"arabic","text_bw":"Har~ap","text_ar":"حَرَّة"},{"kind":"text","text":"and night. (M.) ―         -b10-"},{"kind":"arabic","text_bw":"huwa A^asowadu Alkabidi","text_ar":"هُوَ اَسْوَدُ الكَبِدِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He is black-livered"},{"kind":"text","text":"] means (tropical:)"},{"kind":"italic_en","text":"he is an enemy:"},{"kind":"text","text":"(A, TA:) and"},{"kind":"arabic","text_bw":"suwdu AlA^akobaAdi","text_ar":"سُودُ الاَكْبَادِ"},{"kind":"text","text":"means (tropical:)"},{"kind":"italic_en","text":"enemies."},{"kind":"text","text":"(M, A.) ―         -b11-  You say also,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN biganamihi suwda AlbuTuwni","text_ar":"جَا=ءَ فُلَانٌ بِغَنَمِهِ سُودَ البُطُونِ"},{"kind":"text","text":", and, in like manner,"},{"kind":"arabic","text_bw":"Humora AlkulaY","text_ar":"حُمْرَ الكُلَى"},{"kind":"text","text":", both meaning (tropical:)"},{"kind":"italic_en","text":"Such a one brought his sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, in a lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an emaciated, state."},{"kind":"text","text":"(As, S, and A in art."},{"kind":"arabic","text_bw":"Hmr","text_ar":"حمر"},{"kind":"text","text":".) ―         -b12-  And"},{"kind":"arabic","text_bw":"ramaY bisahomihi AlA^asowadi","text_ar":"رَمَى بِسَهْمِهِ الاَسْوَدِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He shot with his lucky arrow,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"that was smeared with blood,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"by means of which he looked for good fortune,"},{"kind":"text","text":"(K, TA,) because he had shot with it and hit the object shot at, (TA,) or as though it were black (K, TA) with blood, (TA,) or by its having been much handled. (K, TA.) ―         -b13-  And"},{"kind":"arabic","text_bw":"kal~amotuhu famaA rad~a EalaY~a sawodaA='a walaA bayoDaA='a","text_ar":"كَلَّمْتُهُ فَمَا رَدَّ عَلَىَّ سَوْدَا=ءَ وَلَا بَيْضَا=ءَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I spoke to him, and he did not return to me a bad word nor a good one:"},{"kind":"text","text":"(S, L:) or"},{"kind":"italic_en","text":"a single word."},{"kind":"text","text":"(A.) ―         -b14-"},{"kind":"arabic","text_bw":"waToA^apN sawodaA='u","text_ar":"وَطْاَةٌ سَوْدَا=ءُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"A footstep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"footprint, that is becoming effaced:"},{"kind":"text","text":"a recent one is termed"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":". (S.) ―         -b15-"},{"kind":"arabic","text_bw":"Als~awodaA='u","text_ar":"السَّوْدَا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Cultivated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"planted, land;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"AlbayoDaA='u","text_ar":"البَيْضَا=ءُ"},{"kind":"text","text":"[q. v.]. (TA in art."},{"kind":"arabic","text_bw":"byD","text_ar":"بيض"},{"kind":"text","text":"[See also"},{"kind":"arabic","text_bw":"sawodapN","text_ar":"سَوْدَةٌ"},{"kind":"text","text":".]) ―         -b16-  [But"},{"kind":"arabic","text_bw":"sanapN sawodaA='u","text_ar":"سَنَةٌ سَوْدَا=ءُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"A very severe year; more severe than such as is termed"},{"kind":"arabic","text_bw":"HamoraA='u","text_ar":"حَمْرَا=ءُ"},{"kind":"text","text":"; which is more severe than the"},{"kind":"arabic","text_bw":"bayoDA='","text_ar":"بَيْضا=ء"},{"kind":"text","text":", and still more so than the"},{"kind":"arabic","text_bw":"$ahobaA='","text_ar":"شَهْبَا=ء"},{"kind":"text","text":": see arts."},{"kind":"arabic","text_bw":"$hb","text_ar":"شهب"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hmr","text_ar":"حمر"},{"kind":"text","text":".] ―         -b17-"},{"kind":"arabic","text_bw":"AlHab~apu Als~awodaA='u","text_ar":"الحَبَّةُ السَّوْدَا=ءُ"},{"kind":"text","text":", said in a"},{"kind":"page_break","n":1464},{"kind":"text","text":"trad. to be a remedy for every disease except death, (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Al$~uwniyzu","text_ar":"الشُّونِيزُ"},{"kind":"text","text":"[q. v.], (K,) as also ↓"},{"kind":"arabic","text_bw":"Als~uwayodaA='u","text_ar":"السُّوَيْدَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (TA,) [i. e.] this latter signifies"},{"kind":"arabic","text_bw":"Hab~apu","text_ar":"حَبَّةُ"},{"kind":"arabic","text_bw":"Al$~uwniyzi","text_ar":"الشُّونِيزِ"},{"kind":"text","text":", (M,) or properly"},{"kind":"arabic","text_bw":"Al$~iyniyz","text_ar":"الشِّينِيز"},{"kind":"text","text":", for thus the Arabs called it accord. to IAar: or, as some say,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AlHab~apu AlxaDoraA='u","text_ar":"الحَبَّةُ الخَضْرَا=ءُ"},{"kind":"text","text":"[q. v. in art."},{"kind":"arabic","text_bw":"Hb","text_ar":"حب"},{"kind":"text","text":"], because the Arabs [often] call black"},{"kind":"arabic","text_bw":"A^axoDar","text_ar":"اَخْضَر"},{"kind":"text","text":", and green"},{"kind":"arabic","text_bw":"A^asowad","text_ar":"اَسْوَد"},{"kind":"text","text":". (TA.)       -A3-  It is also used as an epithet denoting excess; but as such is anomalous, being formed from a verb whence the simple epithet is of the measure"},{"kind":"arabic","text_bw":"A^afoEalu","text_ar":"اَفْعَلُ"},{"kind":"text","text":": so in the saying,"},{"kind":"arabic","text_bw":"A^asowadu mino Halaki","text_ar":"اَسْوَدُ مِنْ حَلَكِ"},{"kind":"arabic","text_bw":"AlguraAbi","text_ar":"الغُرَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Blacker than the blackness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intense blackness, of the crow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raven:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"HalakN","text_ar":"حَلَكٌ"},{"kind":"text","text":"]. (I'Ak p. 237. [See also its contr."},{"kind":"arabic","text_bw":"A^aboyaDu","text_ar":"اَبْيَضُ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"bayaADN","text_ar":"بَيَاضٌ"},{"kind":"text","text":"; and see Har p. 286.])"}],"source_refs":["S","K","M","Mgh","Msb","Sh","TA","L","A"]}]}}