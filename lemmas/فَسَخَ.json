gen":"m","num":"p"},{"role":"present_2mp","form":"تَفْسَخُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْسَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْسَخ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْسَخ","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْسَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْسَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْسَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْسَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْسَخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْسَخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْسَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فَسَخْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَسَخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْسَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْسَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":33,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n33839"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B3%D9%8E%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to dislocate, to disjoint"},{"pos":"verb","gloss":"to tear apart, to rend, to sever"},{"pos":"verb","gloss":"to rescind, to annul, to revoke, to cancel"},{"pos":"verb","gloss":"to fade (of a color or a colored item)"},{"pos":"verb","gloss":"to tear to pieces, to rend, to mangle"},{"pos":"noun","gloss":"verbal noun of فَسَخَ (fasaḵa) (form I): annulment, revocation, cancellation","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of فَسِخَ (fasiḵa, “to fade”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to salt (fish)","tags":["Egypt"]}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew פָּסַח (pasákh, “to pass over, skip”).\n\nDenominal from فَسِيخ (fasīḵ, “small salted fish”)."},"ipa":["/fa.sa.xa/","/fasx/","/fa.sax/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33839","headword_ar":"فَسَخَ","root":"fsx","body":[{"kind":"text","text":", (S, A, L, K,) aor."},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"fasoxN","text_ar":"فَسْخٌ"},{"kind":"text","text":"; (S, L;) and ↓"},{"kind":"arabic","text_bw":"fs~x","text_ar":"فسّخ","orth_type":"arrow"},{"kind":"text","text":"; (L; [but this has an intensive signification;])"},{"kind":"italic_en","text":"He dislocated, luxated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disjointed,"},{"kind":"text","text":"(A, L, K,) one's arm, or hand, (S, A, L, K,) or a limb,"},{"kind":"italic_en","text":"without breaking:"},{"kind":"text","text":"(L:) [and]"},{"kind":"arabic","text_bw":"fasaxotu AlmafoSila Eano mawoDiEihi","text_ar":"فَسَخْتُ المَفْصِلَ عَنْ مَوْضِعِهِ"},{"kind":"italic_en","text":"I removed the joint from its place."},{"kind":"text","text":"(Msb.) ―         -b2-  And the former v., aor. and inf. n. as above,"},{"kind":"italic_en","text":"He removed"},{"kind":"text","text":"a stick, or twig, or branch,"},{"kind":"italic_en","text":"from its place with his hand."},{"kind":"text","text":"(Msb.) ―         -b3-  And the same v., (S, Msb,) aor. as above, (A,) and so the inf. n., (K,)"},{"kind":"italic_en","text":"He cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast off,"},{"kind":"text","text":"(S, Msb, K,) a garment, (S, Msb,) or his garments. (A.) You say,"},{"kind":"arabic","text_bw":"fasaxotu Ean~iY vawobiY","text_ar":"فَسَخْتُ عَنِّى ثَوْبِى"},{"kind":"italic_en","text":"I cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast off, from me my garment."},{"kind":"text","text":"(S.) ―         -b4-  And the same v., (L, Msb,) [aor. and] inf. n. as above, (K,)"},{"kind":"italic_en","text":"He separated, disunited, sundered, dissundered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"(L, Msb, K,) a thing. (L, Msb.) ―         -b5-  Also, the same verb, (S, A, L, Msb,) aor. as above, (L,) and so the inf. n., (L, Msb, K,) (tropical:)"},{"kind":"italic_en","text":"He undid, dissolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"annulled,"},{"kind":"text","text":"(S, A, L, Msb, K,) a sale, (S, A, L, Msb,) and a determination, resolution, or decision, (S,) and a marriage, (S, A, L,) and a contract, compact, or covenant, and an affair. (Msb.) ―         -b6-  And the same v., (L, Msb,) [aor. and] inf. n. as above, (L, K,) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Msb)"},{"kind":"italic_en","text":"corrupted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered,"},{"kind":"text","text":"the judgment, or opinion. (L, Msb, K.)       -A2-"},{"kind":"arabic","text_bw":"fasixa","text_ar":"فَسِخَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L, K,) inf. n."},{"kind":"arabic","text_bw":"fasaxN","text_ar":"فَسَخٌ"},{"kind":"text","text":"; (L;) or"},{"kind":"arabic","text_bw":"fasaxa","text_ar":"فَسَخَ"},{"kind":"text","text":", this v. being intrans. as well as trans.; (Msb;) (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the judgment, or opinion,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered."},{"kind":"text","text":"(L, Msb, K.) ―         -b2-  [And, accord. to the TK,"},{"kind":"arabic","text_bw":"fasixa","text_ar":"فَسِخَ"},{"kind":"text","text":", (but this I think to be a mistake for"},{"kind":"arabic","text_bw":"fasaxa","text_ar":"فَسَخَ"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"fasoxN","text_ar":"فَسْخٌ"},{"kind":"text","text":", signifies"},{"kind":"arabic","text_bw":"DaEufa","text_ar":"ضَعُفَ"},{"kind":"text","text":"((assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weak,"},{"kind":"text","text":"app."},{"kind":"italic_en","text":"in intellect and in body;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"fasoxN","text_ar":"فَسْخٌ"},{"kind":"text","text":"below); said of a man: and"},{"kind":"arabic","text_bw":"jahila","text_ar":"جَهِلَ"},{"kind":"text","text":"(app. intrans., meaning (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, ignorant;"},{"kind":"text","text":"but accord. to the TK trans., meaning"},{"kind":"italic_en","text":"he knew not"},{"kind":"text","text":"a thing).] ―         -b3-  In the conventional language of the philosophers,"},{"kind":"arabic","text_bw":"Alfasoxu","text_ar":"الفَسْخُ"},{"kind":"text","text":"[as an inf. n.] signifies (assumed tropical:)"},{"kind":"italic_en","text":"The transmigration of the rational soul of a human being from his body to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"some one of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the inanimate,"},{"kind":"page_break","n":2396},{"kind":"italic_en","text":"not increasing, bodies, such as the minerals,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"metals, and the simple elements:"},{"kind":"text","text":"(Dict. of Technical Terms used in the Sciences of the Musalmans:) or,"},{"kind":"italic_en","text":"to a plant:"},{"kind":"text","text":"the former meaning being that of"},{"kind":"arabic","text_bw":"Alr~asoxu","text_ar":"الرَّسْخُ"},{"kind":"text","text":". (So in a marginal note in a copy of the TK.)"}],"source_refs":["S","A","L","K","Msb"]}]}}