in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَمَرَّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَمَرَّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَمَرَّد","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَمَرَّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَمَرَّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَمَرَّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَمَرَّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَمَرَّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَمَرَّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَمَرَّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَمَرَّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَتَمَرَّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَمَرَّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"تَمَرَّدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تَمَرَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":[""],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%85%D9%8E%D8%B1%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to rebel, to revolt","examples":[{"text":"10th century, Al-Mutanabbi\nإِذَا أَنْتَ أَكْرَمْتَ الْكَرِيمَ مَلَكْتَهُ / وَإِنْ أَنْتَ أَكْرَمْتَ اللَّئِيمَ تَمَرَّدَا\nʔiḏā ʔanta ʔakramta l-karīma malaktahu / waʔin ʔanta ʔakramta l-laʔīma tamarradā","english":"(please add an English translation of this quotation)"},{"text":"إِنَّ أَكْبَرَ قِيَمِ الإِنْسَانِ هِيَ تِلْكَ الَّتِي يَبْدَأُ مِنْهَا (بِالرَّفْضِ) وَ(عَدَمِ التَّسْلِيمِ) اللَّذَيْنِ يَتَلَخَّصَانِ بِكَلِمَةِ (لَا) وَمِنْهَا بَدَأَ آدَمٌ أَبُو البَشَرِ.. أُمِرَ أَنْ لَا يَأْكُلَ مِنْ تِلْكَ الثَّمَرَةِ، لٰكِنَّهُ اَكَلَ، فَصَارَ بَعْدَئِذٍ بَشَرًا وَهَبَطَ إِلَىٰ الأَرْضِ، وِإِلَّا لَكَانَ مَلَكًا لَا مِيزَةَ لَهُ، وَلَصَارَ غَيْرُهُ آدَمَ وَلَفُرِضَ عَلَيْهِ أَنْ يَسْجُدَ أَمَامَهُ، لَكِنَّهُ تَمَرَّدَ فَصَارَ آدَم.","english":"For sure the biggest human value is that from which s/he begings by \"refusing\" and \"not consenting\" that are summarised in the word \"no\" and from it began Adam the father of humanity.. He had been ordered not to eat from that fruit, but he ate, and henceforth he became a human and landed on Earth, if he had not he would have been an angel with no distinguishing feature, and someone else would have become Adam and he would have been obliged to prostrate before him, but he rebelled and so he became Adam."}]},{"pos":"verb","gloss":"to be arrogant, to be insolent"},{"pos":"verb","gloss":"to be uncooperative, to be disobedient"},{"pos":"noun","gloss":"verbal noun of تَمَرَّدَ (tamarrada) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *marad- (“to fortify, to set up resistance; to escape, to find a means to get away; to leave one's people, to branch off or split from a group”). Cognate with Hebrew מרדנות (mar(e)dānūt), Aramaic מִרְדָּא (mirdā), Classical Syriac ܡܪܕܐ (merdā), Classical Mandaic ࡌࡉࡓࡃࡀ (MYRDʾ)."},"ipa":["/ta.mar.ra.da/","/ta.mar.rud/"],"lanes_definition":null,"classical_definitions":null}