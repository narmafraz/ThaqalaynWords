"role":"present_2mp","form":"تَثْقُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَثْقُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَثْقُل","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَثْقُل","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَثْقُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَثْقُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَثْقُلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَثْقُلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَثْقُلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَثْقُلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَثْقُلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَثْقُل","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَثْقُل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ثَقُلْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ثَقُلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":40,"cross_references":{"qac":{"found":true,"lemma_key":"ثَقُلَ","root":"ثقل","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":23},"lanes":{"found":true,"entry_ids":["n4556"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D9%82%D9%8F%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be heavy","examples":[{"text":"فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ ۝ فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ ۝ وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ ۝ فَأُمُّهُ هَاوِيَةٌ ۝ وَمَا أَدْرَاكَ مَا هِيَهْ ۝ نَارٌ حَامِيَةٌ"}]},{"pos":"verb","gloss":"to be or become pregnant"},{"pos":"verb","gloss":"to become severe (of an illness)"},{"pos":"verb","gloss":"to deteriorate (of one's hearing, etc.)"},{"pos":"verb","gloss":"to be slurred (of speech)"},{"pos":"verb","gloss":"to be burdensome, to be oppressive"},{"pos":"verb","gloss":"to be difficult"},{"pos":"verb","gloss":"to be sluggish, to be dull-witted"},{"pos":"verb","gloss":"to be too sluggish, to be slow","examples":[{"text":"ثَقُلُوا عَنْ حَاجَتِنَا.","english":"They are slow to do what we need."}]},{"pos":"verb","gloss":"to be too dull-witted"},{"pos":"verb","gloss":"to load, to burden, to make heavy"},{"pos":"verb","gloss":"to weigh; to determine the weight of an object","tags":["transitive"]},{"pos":"verb","gloss":"to be heavier than, to outweigh","tags":["transitive"]},{"pos":"verb","gloss":"to make (something) heavy","tags":["transitive"]},{"pos":"verb","gloss":"to burden","tags":["transitive"]},{"pos":"verb","gloss":"to ask too much of, to overburden"},{"pos":"verb","gloss":"to bother, to trouble"},{"pos":"noun","gloss":"weight"},{"pos":"noun","gloss":"burden, load","examples":[{"text":"وَأَخۡرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا","english":"And the earth discharges its burdens"}]},{"pos":"noun","gloss":"gravity"},{"pos":"noun","gloss":"verbal noun of ثَقُلَ (ṯaqula) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"heaviness"},{"pos":"adj","gloss":"masculine plural of ثَقِيل (ṯaqīl)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ṯql (“to weigh; burden, weight”). Cognate with Hebrew שקל and Aramaic תקל.\n\nCausative of ثَقُلَ (ṯaqula, “to be heavy”).\n\nCompare Hebrew שֶׁקֶל (šéqel), Aramaic תִּקְלָא (tiqlā), Ugaritic 𐎘𐎖𐎍 (ṯql).\n\nInflected form."},"ipa":["/θa.qu.la/","/θaq.qa.la/","/θiq.lun/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4556","headword_ar":"ثَقُلَ","root":"vql","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"viqalN","text_ar":"ثِقَلٌ"},{"kind":"text","text":"(S, Msb, K, &c.) and"},{"kind":"arabic","text_bw":"viqolN","text_ar":"ثِقْلٌ"},{"kind":"text","text":", a contraction of the former, (Msb,) and"},{"kind":"arabic","text_bw":"vaqaAlapN","text_ar":"ثَقَالَةٌ"},{"kind":"text","text":", (K, TA, in the CK"},{"kind":"arabic","text_bw":"viqAlap","text_ar":"ثِقالَة"},{"kind":"text","text":", but) like"},{"kind":"arabic","text_bw":"karaAmapN","text_ar":"كَرَامَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy, weighty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ponderous."},{"kind":"text","text":"(S, K.) [See"},{"kind":"arabic","text_bw":"viqalN","text_ar":"ثِقَلٌ"},{"kind":"text","text":", below.] ―         -b2-  See also 4. ―         -b3-  [(assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy, weighty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preponderant, ideally."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"faA^am~aA mano vaqulato mawaAziynuhu","text_ar":"فَاَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ"},{"kind":"text","text":", in the Kur ci. 5, means (assumed tropical:)"},{"kind":"italic_en","text":"And as to him whose good deeds shall be preponderant."},{"kind":"text","text":"(Bd, Jel.) [See also Kur vii. 7 and xxiii. 104.] ―         -b4-  [(assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weighty,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"onerous, burdensome, oppressive, afflictive, grievous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troublesome."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"vaqula Alqawolu","text_ar":"ثَقُلَ القَوْلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The saying was"},{"kind":"text","text":"["},{"kind":"italic_en","text":"heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weighty,"},{"kind":"text","text":"&c.; or]"},{"kind":"italic_en","text":"unpleasant to be heard."},{"kind":"text","text":"(TA.) And it is said in the Kur vii. 186,"},{"kind":"arabic","text_bw":"vaqulato fiY Als~am`waAti waAlA^aroDi","text_ar":"ثَقُلَتْ فِى السَّمٰوَاتِ وَالاَرْضِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the time of the resurrection)"},{"kind":"italic_en","text":"will be momentous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"formidable,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the heavens and on the earth,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"to the inhabitants of the heavens and the earth,"},{"kind":"text","text":"(Bd, Jel,)"},{"kind":"italic_en","text":"to the angels and men and genii;"},{"kind":"text","text":"app. alluding to the wisdom shown in concealing it: (Bd:) or it means"},{"kind":"italic_en","text":"the knowledge thereof"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is difficult"},{"kind":"text","text":"]: (Ibn-'Arafeh, TA:) or"},{"kind":"italic_en","text":"it is occult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hidden."},{"kind":"text","text":"(Kt, TA.) ["},{"kind":"arabic","text_bw":"vaqula","text_ar":"ثَقُلَ"},{"kind":"text","text":"is also said of a word, and of a sound, meaning (assumed tropical:)"},{"kind":"italic_en","text":"It was heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not easy, of utterance;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heavy to the ear:"},{"kind":"text","text":"see 2. And of an affair, or action, meaning (assumed tropical:)"},{"kind":"italic_en","text":"It was afflictive, grievous, troublesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult."},{"kind":"text","text":"In these and similar senses, it is trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":": you say,"},{"kind":"arabic","text_bw":"vaqula Ealayohi","text_ar":"ثَقُلَ عَلَيْهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy, weighty, onerous,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to him."},{"kind":"text","text":"In like manner also it is said of food, meaning (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy to the stomach; difficult of digestion."},{"kind":"text","text":"] You say also,"},{"kind":"arabic","text_bw":"vaqula samoEuhu","text_ar":"ثَقُلَ سَمْعُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His hearing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"his hearing partially went."},{"kind":"text","text":"(K, TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy"},{"kind":"text","text":"in sickness, or disease: [and in like manner, in his sleep:] the verb is thus, with damm to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":"; though said in the K to be"},{"kind":"arabic","text_bw":"vaqila","text_ar":"ثَقِلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"fariHa","text_ar":"فَرِحَ"},{"kind":"text","text":", as meaning"},{"kind":"italic_en","text":"his disease became violent;"},{"kind":"text","text":"(Fet-h el-Báree, TA;) not improbably through error or inadvertence. (MF.) ―         -b6-  [(assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy, slow, sluggish, indolent, lazy, dull, torpid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drowsy; wanting in alacrity, activity, agility, animation, spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence; stupid."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"yavoqulu Eano qubuwli maA yuloqaY A_ilayohi","text_ar":"يَثْقُلُ عَنْ قُبُولِ مَا يُلْقَى اـِلَيْهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He is averse from receiving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accepting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admitting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is"},{"kind":"page_break","n":344},{"kind":"italic_en","text":"slow to receive,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"what is said to him"},{"kind":"text","text":"]. (TA.) ―         -b7-  Also, said of the"},{"kind":"arabic","text_bw":"Earofaj","text_ar":"عَرْفَج"},{"kind":"text","text":", and of the"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Its shoots became luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succulent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sappy."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"vaqalahu","text_ar":"ثَقَلَهُ"},{"kind":"text","text":", (JK, S, K,)"},{"kind":"arabic","text_bw":"biyadihi","text_ar":"بِيَدِهِ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"vaqolN","text_ar":"ثَقْلٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He tried the weight of it,"},{"kind":"text","text":"(JK, S, K,) namely, a thing, (K,) or a sheep or goat, (S,)"},{"kind":"italic_en","text":"by lifting it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with his hand"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to see if it were heavy or light."},{"kind":"text","text":"(S, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"vaqala Al$~aYo'u","text_ar":"ثَقَلَ الشَّىْءُ"},{"kind":"arabic","text_bw":"Al$~aYo'a fiY Alwazoni","text_ar":"الشَّىْءَ فِى الوَزْنِ"},{"kind":"text","text":", aor. and inf. n. as above, (S,)"},{"kind":"italic_en","text":"The thing surpassed the thing in weight; outweighed it."},{"kind":"text","text":"(PS.) ―         -b3-  See also 2."}],"source_refs":["Msb","TA","Bd","Jel","JK","S","K"]}]}}