هَلَّ","root":"هلل","pos":"V","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n1429","n1434","n1435"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%87%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1429","headword_ar":"اَهَلَ","root":"Ahl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^uhuwlN","text_ar":"اُهُولٌ"},{"kind":"text","text":"; (Msb;) or"},{"kind":"arabic","text_bw":"A^uhila","text_ar":"اُهِلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a place, Msb, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, peopled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inhabited."},{"kind":"text","text":"(Msb, K, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^ahala","text_ar":"اَهَلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"He married,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took a wife;"},{"kind":"text","text":"(Yoo, S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tA^h~l","text_ar":"تاهّل","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"A@t~ahala","text_ar":"ا@تَّهَلَ","orth_type":"arrow"},{"kind":"text","text":", [written with the disjunctive alif"},{"kind":"arabic","text_bw":"Ait~ahala","text_ar":"اِتَّهَلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"A@t~axa*a","text_ar":"ا@تَّخَذَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A@t~azara","text_ar":"ا@تَّزَرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A@tamana","text_ar":"ا@تَمَنَ"},{"kind":"text","text":"&c.], (K,) of the measure"},{"kind":"arabic","text_bw":"AftEl","text_ar":"افتعل"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^ahala","text_ar":"اَهَلَ"},{"kind":"text","text":"; (Ks, S, Msb;) or"},{"kind":"arabic","text_bw":"A^ahila","text_ar":"اَهِلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K;) or both; (JK;)"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", (JK,) i. e."},{"kind":"arabic","text_bw":"biAlr~ajuli","text_ar":"بِالرَّجُلِ"},{"kind":"text","text":", (Ks, S,) or"},{"kind":"arabic","text_bw":"biAl$~aY'i","text_ar":"بِالشَّىءِ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^anisa","text_ar":"اَنِسَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sociable, companionable, friendly, amicable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"familiar, with him,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"the man;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cheered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gladdened, by his company"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"converse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its"},{"kind":"text","text":"("},{"kind":"italic_en","text":"the thing's"},{"kind":"text","text":")"},{"kind":"italic_en","text":"presence"},{"kind":"text","text":"]. (JK, S, Msb, K.)"}],"source_refs":["K","JK","Ks","S"]},{"entry_id":"n1434","headword_ar":"اَهْلٌ","root":"Ahl","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"people"},{"kind":"text","text":"of a house or dwelling, and of a town or village, and of a country: and the"},{"kind":"italic_en","text":"family"},{"kind":"text","text":"of a man:] a man's"},{"kind":"italic_en","text":"cohabitants of one dwelling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of abode,"},{"kind":"text","text":"(Er-Rághib, Kull p. 84,) and"},{"kind":"italic_en","text":"of one town"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country:"},{"kind":"text","text":"(Er-Rághib:) afterwards applied to a man's"},{"kind":"italic_en","text":"fellow-members of one family"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"race,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of one religion,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of one craft"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"art"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(Er-Rághib, Kull:) or, as some say,"},{"kind":"italic_en","text":"relations, whether they have followers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dependents, or not;"},{"kind":"text","text":"whereas"},{"kind":"arabic","text_bw":"A=lN","text_ar":"ا=لٌ"},{"kind":"text","text":"signifies relations with their followers or dependents: (Kull:) or it originally signifies"},{"kind":"italic_en","text":"relations:"},{"kind":"text","text":"and sometimes is applied to"},{"kind":"italic_en","text":"followers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dependents:"},{"kind":"text","text":"and signifies also the"},{"kind":"arabic","text_bw":"A^ahol","text_ar":"اَهْل"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inhabitants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"family,] of a house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent:"},{"kind":"text","text":"(Msb:) or a man's"},{"kind":"italic_en","text":"nearer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nearest, relations by descent from the same father or ancestor;"},{"kind":"text","text":"or his"},{"kind":"italic_en","text":"kinsfolk;"},{"kind":"text","text":"his"},{"kind":"italic_en","text":"relations:"},{"kind":"text","text":"(K:) or, accord. to [the Imám] Mohammad, a man's"},{"kind":"italic_en","text":"wife"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"wives] and"},{"kind":"text","text":"his"},{"kind":"italic_en","text":"children and household who are the objects of"},{"kind":"text","text":"his"},{"kind":"italic_en","text":"expenditure;"},{"kind":"text","text":"and thus,"},{"kind":"italic_en","text":"any brother and sister,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paternal uncle and son of a paternal uncle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strange"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distantly-related child, whom a man feeds or sustains in his abode:"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"most particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most special, dependents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"of a man: on the authority of El-Ghooree: (Mgh:) [J indicates some of these meanings merely by saying that it signifies] the"},{"kind":"arabic","text_bw":"A^ahol","text_ar":"اَهْل"},{"kind":"text","text":"of a man, and the"},{"kind":"arabic","text_bw":"A^ahol","text_ar":"اَهْل"},{"kind":"text","text":"of a house; as also ↓"},{"kind":"arabic","text_bw":"A^aholapN","text_ar":"اَهْلَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S:) [see also"},{"kind":"arabic","text_bw":"A=lN","text_ar":"ا=لٌ"},{"kind":"text","text":"; in the explanations of which, certain distinctions between it and"},{"kind":"arabic","text_bw":"A^aholN","text_ar":"اَهْلٌ"},{"kind":"text","text":"will be found mentioned:] the pl. is"},{"kind":"arabic","text_bw":"A^aholuwna","text_ar":"اَهْلُونَ"},{"kind":"text","text":", [like"},{"kind":"arabic","text_bw":"A^aroDuwna","text_ar":"اَرْضُونَ"},{"kind":"text","text":", a form sometimes used for"},{"kind":"arabic","text_bw":"A^araDuwna","text_ar":"اَرَضُونَ"},{"kind":"text","text":"] (Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"A^ahaAlK","text_ar":"اَهَالٍ"},{"kind":"text","text":", (S, Mgh, Msb, K,) with an additional"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"[implied by the tenween, and expressed in the accus. case, and when the word is determinate, as in"},{"kind":"arabic","text_bw":"AlA^ahaAliY","text_ar":"الاَهَالِى"},{"kind":"text","text":",] (S,) contr. to rule, (S, Mgh,) like"},{"kind":"arabic","text_bw":"layaAlK","text_ar":"لَيَالٍ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"layolN","text_ar":"لَيْلٌ"},{"kind":"text","text":", (S,) [and like"},{"kind":"arabic","text_bw":"A^araAD","text_ar":"اَرَاض"},{"kind":"text","text":", respecting which and"},{"kind":"arabic","text_bw":"lyaAlK","text_ar":"ليَالٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ahaAlK","text_ar":"اَهَالٍ"},{"kind":"text","text":", see"},{"kind":"arabic","text_bw":"A^aroDN","text_ar":"اَرْضٌ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"A=haAlN","text_ar":"ا=هَالٌ"},{"kind":"text","text":", (S, K,) a pl. [of pauc.] sometimes occurring in poetry, (S,) [like"},{"kind":"arabic","text_bw":"A=raADN","text_ar":"ا=رَاضٌ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"A^aholaAtN","text_ar":"اَهْلَاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ahalaAtN","text_ar":"اَهَلَاتٌ"},{"kind":"text","text":"[as though pls. of"},{"kind":"arabic","text_bw":"A^aholapN","text_ar":"اَهْلَةٌ"},{"kind":"text","text":"]. (S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A^aholu Albayoti","text_ar":"اَهْلُ البَيْتِ"},{"kind":"text","text":"The ["},{"kind":"italic_en","text":"people"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"inhabitants"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"family] of the house"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent."},{"kind":"text","text":"(Mgh, K.) But"},{"kind":"arabic","text_bw":"A^awoSaY lA^aholi bayotihi","text_ar":"اَوْصَى لاَهْلِ بَيْتِهِ"},{"kind":"text","text":"means the same as"},{"kind":"arabic","text_bw":"AwSY lijinosihi","text_ar":"اوصى لِجِنْسِهِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"He left by will,"},{"kind":"text","text":"of his property,"},{"kind":"italic_en","text":"to the children of his father,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"his kindred by the father's side,] exclusively of all relations of the mother."},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"jns","text_ar":"جنس"},{"kind":"text","text":".) [See also"},{"kind":"arabic","text_bw":"A^aholu Alr~ajuli","text_ar":"اَهْلُ الرَّجُلِ"},{"kind":"text","text":", below.] ―         -b3-"},{"kind":"arabic","text_bw":"A^ahola AlquraY","text_ar":"اَهْلَ القُرَى"},{"kind":"italic_en","text":"The [people"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"inhabitants of the towns"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^aholu Albaladi","text_ar":"اَهْلُ البَلَدِ"},{"kind":"italic_en","text":"The settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constant, inhabitants of the country"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^aholu AlHaDari","text_ar":"اَهْلُ الحَضَرِ"},{"kind":"italic_en","text":"The people of the region,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regions, of cities, towns,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages, and of cultivated land."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"HDr","text_ar":"حضر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A^aholu Almadari wa Alwabari","text_ar":"اَهْلُ المَدَرِ وَ الوَبَرِ"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"mdr","text_ar":"مدر"},{"kind":"text","text":", &c.) ["},{"kind":"italic_en","text":"The people of the towns"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villages,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the inhabitants of the buildings, and of the tents,"},{"kind":"text","text":"(Kull,) or"},{"kind":"italic_en","text":"deserts."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"wbr","text_ar":"وبر"},{"kind":"text","text":") ―         -b4-  ["},{"kind":"arabic","text_bw":"A^aholu Alqubuwri","text_ar":"اَهْلُ القُبُورِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AlmaqaAbiri","text_ar":"المَقَابِرِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The people of the graces,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the places of graves;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"those buried therein."},{"kind":"text","text":"] ―         -b5-  ["},{"kind":"arabic","text_bw":"A^aholu Aljan~api","text_ar":"اَهْلُ الجَنَّةِ"},{"kind":"italic_en","text":"The people of Paradise."},{"kind":"text","text":"] ―         -b6-  ["},{"kind":"arabic","text_bw":"A^aholu Aln~aAri","text_ar":"اَهْلُ النَّارِ"},{"kind":"italic_en","text":"The people of the fire,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"of Hell."},{"kind":"text","text":"] ―         -b7-  See also"},{"kind":"arabic","text_bw":"A^ahilapN","text_ar":"اَهِلَةٌ"},{"kind":"text","text":". ―         -b8-  The following is an ex. of"},{"kind":"arabic","text_bw":"Ahl","text_ar":"اهل"},{"kind":"text","text":"as explained above in the first sentence on the authority of the K:"},{"kind":"arabic","text_bw":"AlA^aholu A_ilaY AlA^aholi A^asoraEu mina","text_ar":"الاَهْلُ اـِلَى الاَهْلِ اَسْرَعُ مِنَ"},{"kind":"arabic","text_bw":"Als~iyli A_ilaY Als~aholi","text_ar":"السِّيلِ اـِلَى السَّهْلِ"},{"kind":"text","text":"a prov. [meaning"},{"kind":"italic_en","text":"Kinsfolk are quicker of tendency to kinsfolk than the torrent to the plain"},{"kind":"text","text":"]. (TA.) So, too, a saying of a poet cited voce"},{"kind":"arabic","text_bw":"xafoDN","text_ar":"خَفْضٌ"},{"kind":"text","text":". (TA.) [And]"},{"kind":"arabic","text_bw":"A^aholaka waAll~ayola","text_ar":"اَهْلَكَ وَاللَّيْلَ"},{"kind":"text","text":"a prov. meaning"},{"kind":"arabic","text_bw":"baAdir A^aholaka waA@Ho*ari All~ayola wa Zulomatahu","text_ar":"بَادِر اَهْلَكَ وَا@حْذَرِ اللَّيْلَ وَ ظُلْمَتَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Betake thyself early to thy family, and beware of the night and its darkness"},{"kind":"text","text":"]. (Har p. 175.) [And]"},{"kind":"arabic","text_bw":"maroHabFA waA^aholFA","text_ar":"مَرْحَبًا وَاَهْلًا"},{"kind":"text","text":"(S, K) a saying meaning"},{"kind":"italic_en","text":"Thou hast come to an ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a spacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roomy, place, and to"},{"kind":"text","text":"[people like thine own]"},{"kind":"italic_en","text":"kinsfolk;"},{"kind":"text","text":"therefore be cheerful, or sociable, not sad, or shy: (S:) or"},{"kind":"italic_en","text":"thou hast found,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"met with, [an ample,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a spacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roomy, place, and] kinsfolk, not strangers."},{"kind":"text","text":"(K.) [And]"},{"kind":"arabic","text_bw":"A^aholFA wa saholFA wamaroHabFA","text_ar":"اَهْلًا وَ سَهْلًا وَمَرْحَبًا"},{"kind":"italic_en","text":"Thou hast come to a people who are"},{"kind":"text","text":"[like]"},{"kind":"italic_en","text":"kinsfolk, and to a place that is plain, even, not rugged, and that is ample, spacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roomy;"},{"kind":"text","text":"therefore rejoice thyself, and be not sad, or shy. (Msb.) ―         -b9-"},{"kind":"arabic","text_bw":"A^aholu Aln~abiY~i","text_ar":"اَهْلُ النَّبِىِّ"},{"kind":"italic_en","text":"The [family"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"wives and daughters of the Prophet, and his son-in-law 'Alee:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his women; and"},{"kind":"text","text":"(as some say, TA)"},{"kind":"italic_en","text":"the men who are his"},{"kind":"arabic","text_bw":"A=l","text_ar":"ا=ل"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"comprising the grandchildren"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aHofaAd","text_ar":"اَحْفَاد"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and [other] progeny:"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"A^aholu Albayoti","text_ar":"اَهْلُ البَيْتِ"},{"kind":"text","text":"as used in the Kur xxxiii. 33, occurring also [in a like sense] in xi. 76: (TA:) and"},{"kind":"arabic","text_bw":"AlA^aholu","text_ar":"الاَهْلُ"},{"kind":"text","text":"is conventionally applied to"},{"kind":"italic_en","text":"the nearer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nearest, kinsfolk of the Prophet."},{"kind":"text","text":"(Er-Rághib.) ―         -b10-"},{"kind":"arabic","text_bw":"A^aholu kul~i nabiY~K","text_ar":"اَهْلُ كُلِّ نَبِىٍّ"},{"kind":"text","text":"also means"},{"kind":"italic_en","text":"The people to whom any prophet is sent;"},{"kind":"text","text":"(K, TA;) and"},{"kind":"italic_en","text":"those who are of his religion."},{"kind":"text","text":"(TA.) ―         -b11-  In the phrase"},{"kind":"arabic","text_bw":"A=lN","text_ar":"ا=لٌ"},{"kind":"arabic","text_bw":"A@ll~`hi warasuwlihi","text_ar":"ا@للّٰهِ وَرَسُولِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The friends,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^awoliyaA='","text_ar":"اَوْلِيَا=ء"},{"kind":"text","text":"K, TA,) and"},{"kind":"italic_en","text":"the assistants,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"of God and of his apostle,"},{"kind":"text","text":"the first word is originally"},{"kind":"arabic","text_bw":"A^ahol","text_ar":"اَهْل"},{"kind":"text","text":". (K, TA.) ―         -b12-"},{"kind":"arabic","text_bw":"A^aholu A@ll~`hi","text_ar":"اَهْلُ ا@للّٰهِ"},{"kind":"text","text":"is also an appellation which used to be applied to"},{"kind":"italic_en","text":"The readers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reciters [of the Kur-án"},{"kind":"text","text":"]. (TA.) ―         -b13-"},{"kind":"arabic","text_bw":"A^aholu Alr~ajuli","text_ar":"اَهْلُ الرَّجُلِ"},{"kind":"text","text":"also signifies (tropical:)"},{"kind":"italic_en","text":"The man's wife;"},{"kind":"text","text":"(Mgh, * Msb, * K;) as well as"},{"kind":"italic_en","text":"his wife and children;"},{"kind":"text","text":"(TA;) [so, too, in the present day,"},{"kind":"arabic","text_bw":"A^aholu bayoti Alr~ajuli","text_ar":"اَهْلُ بَيْتِ الرَّجُلِ"},{"kind":"text","text":";] and so, too, ↓"},{"kind":"arabic","text_bw":"A^aholatuhu","text_ar":"اَهْلَتُهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) Hence the phrase"},{"kind":"arabic","text_bw":"banaY Ealay","text_ar":"بَنَى عَلَي"},{"kind":"arabic","text_bw":"A^aholihi","text_ar":"اَهْلِهِ"},{"kind":"text","text":"[see art."},{"kind":"arabic","text_bw":"bnYi","text_ar":"بنىِ"},{"kind":"text","text":"]: (Kull:) and"},{"kind":"arabic","text_bw":"daxala biA^aholihi","text_ar":"دَخَلَ بِاَهْلِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"daxala EalaY A^aholihi","text_ar":"دَخَلَ عَلَى اَهْلِهِ"},{"kind":"text","text":"[see art."},{"kind":"arabic","text_bw":"dxl","text_ar":"دخل"},{"kind":"text","text":"]. (Har p. 502; &c.) ―         -b14-"},{"kind":"arabic","text_bw":"A^aholu ma*ohabK","text_ar":"اَهْلُ مَذْهَبٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"those who follow,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and believe,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"a certain persuasion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"body of tenets."},{"kind":"text","text":"(K, TA.) [Hence,]"},{"kind":"arabic","text_bw":"A^aholu Als~unapi","text_ar":"اَهْلُ السُّنَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Those who conform to the institutes of Mohammad"},{"kind":"text","text":"]. (TA.) [And]"},{"kind":"arabic","text_bw":"A^aholu AlA^ahowaA='i","text_ar":"اَهْلُ الاَهْوَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of erroneous opinions;] those whose belief is not that of the class termed"},{"kind":"arabic","text_bw":"A^aholu Als~un~api","text_ar":"اَهْلُ السُّنَّةِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"but who hare the same"},{"kind":"arabic","text_bw":"qibolap","text_ar":"قِبْلَة"},{"kind":"text","text":". (TA.) [And]"},{"kind":"arabic","text_bw":"A^aholu AlA_isolaAmi","text_ar":"اَهْلُ الاـِسْلَامِ"},{"kind":"italic_en","text":"Those who follow the religion of El-Islám."},{"kind":"text","text":"(Mgh.) [And]"},{"kind":"arabic","text_bw":"A^aholu AlquroA=ni","text_ar":"اَهْلُ القُرْا=نِ"},{"kind":"italic_en","text":"Those who read,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recite, the Kur-án, and perform the duties enjoined thereby."},{"kind":"text","text":"(Mgh.) [And]"},{"kind":"arabic","text_bw":"A^aholu AlkitaAbi","text_ar":"اَهْلُ الكِتَابِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of the Scripture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Bible:"},{"kind":"text","text":"and]"},{"kind":"italic_en","text":"the readers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reciters, of the Mosaic Law, and of the Gospel."},{"kind":"text","text":"(TA.) ―         -b15-"},{"kind":"arabic","text_bw":"A^aholu AlEilomi","text_ar":"اَهْلُ العِلْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science;] those who are characterized by knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science."},{"kind":"text","text":"(Msb.) ―         -b16-"},{"kind":"arabic","text_bw":"A^aholu","text_ar":"اَهْلُ"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The possessors of command:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"those who superintend the affairs [of others"},{"kind":"text","text":"]; (K, TA;) like"},{"kind":"arabic","text_bw":"A^uluwAlA^amri","text_ar":"اُلُوالاَمرِ"},{"kind":"text","text":", q. v. (TA.) ―         -b17-"},{"kind":"arabic","text_bw":"A^aholu AlmaraAtibi","text_ar":"اَهْلُ المَرَاتِبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The people of exalted stations, posts of honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignities"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"rtb","text_ar":"رتب"},{"kind":"text","text":".) ―         -b18-"},{"kind":"arabic","text_bw":"A^aholu Al*~im~api","text_ar":"اَهْلُ الذِّمَّةِ"},{"kind":"text","text":"(Mgh in art."},{"kind":"arabic","text_bw":"*m","text_ar":"ذم"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"A^aholu AlEahodi","text_ar":"اَهْلُ العَهْدِ"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Ehd","text_ar":"عهد"},{"kind":"text","text":")"},{"kind":"italic_en","text":"Those persons,"},{"kind":"text","text":"(Mgh, TA,)"},{"kind":"italic_en","text":"of the unbelievers,"},{"kind":"text","text":"(Mgh,) [namely,"},{"kind":"italic_en","text":"Christians, Jews,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"Sabians,"},{"kind":"text","text":"but no others,]"},{"kind":"italic_en","text":"who have a compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covenant, with the Muslims,"},{"kind":"text","text":"(Mgh, TA,)"},{"kind":"italic_en","text":"paying a poll-tax, whereby they are secure of their property and blood,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"whereby the Muslims are responsible for their security [and freedom and toleration] as long as they act agreeably to the compact."},{"kind":"text","text":"(TA.) ―         -b19-"},{"kind":"arabic","text_bw":"A^aholN","text_ar":"اَهْلٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"possessors,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"owners,"},{"kind":"text","text":"of property: as in the Kur iv. 61. (TA.) ―         -b20-"},{"kind":"arabic","text_bw":"A^aholN","text_ar":"اَهْلٌ"},{"kind":"arabic","text_bw":"lika*aA","text_ar":"لِكَذَا"},{"kind":"text","text":"A person, (S, K,) and persons, for it is used as a sing. and as a pl., (K,)"},{"kind":"italic_en","text":"having a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just title, to such a thing; entitled thereto; worthy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deserving, thereof; meet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fit, for it:"},{"kind":"text","text":"(S, K:) the vulgar say ↓"},{"kind":"arabic","text_bw":"musotaA^ohilN","text_ar":"مُسْتَاْهِلٌ","orth_type":"arrow"},{"kind":"text","text":", which is not allowable: (S:) or this assertion of J's is of no account. (K: see 10.) You say,"},{"kind":"arabic","text_bw":"huw A^aholN","text_ar":"هُو اَهْلٌ"},{"kind":"arabic","text_bw":"liA_ikoraAmi","text_ar":"لِاـِكْرَامِ"},{"kind":"italic_en","text":"He is entitled to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy of being, treated with honour."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"lik~uli","text_ar":"لِكُّلِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa A^aholapN","text_ar":"هُوَ اَهْلَةٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"xayor","text_ar":"خَيْر"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is entitled to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy of, all that is good"},{"kind":"text","text":"]. (Ibn- 'Abbád.) And"},{"kind":"arabic","text_bw":"wud~K","text_ar":"وُدٍّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ahlapN","text_ar":"اَهلَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"He who is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"they who are, entitled to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy of, love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection."},{"kind":"text","text":"(S, Sgh.) And hence, in the Kur [lxxiv. last verse],"},{"kind":"arabic","text_bw":"huwa A^aholu Alt~aqowaY waA^aholu Almagofirapi","text_ar":"هُوَ اَهْلُ التَّقْوَى وَاَهْلُ المَغْفِرَةِ"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"He is the Being entitled to be regarded with pious fear, and the Being entitled to forgive"},{"kind":"text","text":"those who so regard Him. (Jel.) In the phrase"},{"kind":"arabic","text_bw":"A^hola AlvanaA='i waAlmajodi","text_ar":"اهْلَ الثَنَا=ءِ وَالمَجْدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"0 Thou who art the Being entitled to praise and glory"},{"kind":"text","text":"], occurring in a form of prayer, the first word is mansoob as a vocative: and it may be marfooa, as the enunciative of an inchoative suppressed; i. e."},{"kind":"arabic","text_bw":"A^anota A^aholu","text_ar":"اَنْتَ اَهْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou art the Being entitled"},{"kind":"text","text":"&c.]. (Msb.) ―         -b21-  [Frequently, also,"},{"kind":"arabic","text_bw":"A^aholN","text_ar":"اَهْلٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"author,"},{"kind":"text","text":"or, more commonly,"},{"kind":"italic_en","text":"authors,"},{"kind":"text","text":"of a thing; like"},{"kind":"arabic","text_bw":"SaAHibN","text_ar":"صَاحِبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aSoHaAbN","text_ar":"اَصْحَابٌ"},{"kind":"text","text":"; as in"},{"kind":"arabic","text_bw":"A^aholu AlbidaEi","text_ar":"اَهْلُ البِدَعِ"},{"kind":"italic_en","text":"The author,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"authors, of innovations;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aholu AlZ~ulomi","text_ar":"اَهْلُ الظُّلْمِ"},{"kind":"italic_en","text":"The author,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"authors, of wrong."},{"kind":"text","text":"]"}],"source_refs":["Kull","Msb","K","Mgh","S","TA"]},{"entry_id":"n1435","headword_ar":"اَهِلٌ","root":"Ahl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aholiyYN","text_ar":"اَهْلِيىٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}