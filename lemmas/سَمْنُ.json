{"lemma":"سَمْنُ","slug":"سَمْنُ","root":"س.م.ن","root_slug":"س-م-ن","root_link":"/words/roots/س-م-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n20786","n20790","n20791"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%85%D9%92%D9%86%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be fat, to be corpulent, to be obese, to be stout"},{"pos":"verb","gloss":"to become fat"},{"pos":"verb","gloss":"to make fat, make plump, to fatten"},{"pos":"noun","gloss":"clarified butter, ghee"},{"pos":"noun","gloss":"verbal noun of سَمِنَ (samina) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"fatness, plumpness, fleshiness, stoutness, corpulence"},{"pos":"noun","gloss":"obesity"},{"pos":"noun","gloss":"quail (Coturnix coturnix)","tags":["collective"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *šamn- and the root س م ن (s m n)."},"ipa":["/sa.mi.na/","/sam.ma.na/","/samn/","/si.man/","/sum.mun/","/sum.man/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20786","headword_ar":"سَمِنَ","root":"smn","body":[{"kind":"text","text":", (S, M, L, Msb, K,) aor."},{"kind":"text","text":"; (L, Msb, K;) and"},{"kind":"arabic","text_bw":"samuna","text_ar":"سَمُنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) inf. n. of the former"},{"kind":"arabic","text_bw":"simanN","text_ar":"سِمَنٌ"},{"kind":"text","text":"(S, M, L, K) and"},{"kind":"arabic","text_bw":"samaAnapN","text_ar":"سَمَانَةٌ"},{"kind":"text","text":", (M, L, K,) or the former is a simple subst. (Msb) [and the latter by rule inf. n. of the latter verb];"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plump;"},{"kind":"text","text":"(S, M, L;) or"},{"kind":"italic_en","text":"in the condition of having much flesh and fat:"},{"kind":"text","text":"(Msb:) and ↓"},{"kind":"arabic","text_bw":"tsm~n","text_ar":"تسمّن","orth_type":"arrow"},{"kind":"text","text":"has a like meaning [i. e."},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fattened, rendered plump,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to have much flesh and fat"},{"kind":"text","text":"]. (S, L. *) A poet says,"},{"kind":"quote","text":"rakibonaAhaA samaAnatahaA falam~aA\n                      \n                     \n                        badato minohaA Als~anaAsinu waAlD~uluwEu"},{"kind":"text","text":"(IAar, M, L,) meaning"},{"kind":"italic_en","text":"We rode her during her state of fatness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plumpness,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"but when the edges of her vertebræ, and the ribs, became apparent,"},{"kind":"text","text":"...] (M, L.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"samina Albur~u","text_ar":"سَمِنَ البُرُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"simanN","text_ar":"سِمَنٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The wheat became full in the grain."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"Sfr","text_ar":"صفر"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"samanahu","text_ar":"سَمَنَهُ"},{"kind":"text","text":", (S, M, L, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"samonN","text_ar":"سَمْنٌ"},{"kind":"text","text":", (S, M, L,)"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"prepared it,"},{"kind":"text","text":"] namely, food,"},{"kind":"italic_en","text":"with"},{"kind":"arabic","text_bw":"samon","text_ar":"سَمْن"},{"kind":"text","text":"[q. v. infrà]; (M, L, K;) as also ↓"},{"kind":"arabic","text_bw":"sm~nh","text_ar":"سمّنه","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Asmnhu","text_ar":"اسمنهُ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the first signifies, (S,) or signifies also, and so ↓ the second and ↓ third, (M, L,)"},{"kind":"italic_en","text":"he moistened it, and stirred it about,"},{"kind":"text","text":"(S, M, L,) namely, food, (S, L,) or bread, (M, L,)"},{"kind":"italic_en","text":"with"},{"kind":"arabic","text_bw":"samon","text_ar":"سَمْن"},{"kind":"text","text":", (S, M, L,)"},{"kind":"arabic","text_bw":"lahumo","text_ar":"لَهُمْ"},{"kind":"italic_en","text":"for them."},{"kind":"text","text":"(S.) ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"Asmnhu","text_ar":"اسمنهُ","orth_type":"arrow"},{"kind":"text","text":", (L,) or"},{"kind":"arabic","text_bw":"samana Alqawoma","text_ar":"سَمَنَ القَوْمَ"},{"kind":"text","text":", (M, K,) aor. and inf. n. as above, (M,)"},{"kind":"italic_en","text":"He fed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, with"},{"kind":"arabic","text_bw":"samon","text_ar":"سَمْن"},{"kind":"text","text":". (M, L, K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"samanotu lahu","text_ar":"سَمَنْتُ لَهُ"},{"kind":"italic_en","text":"I seasoned his bread for him with"},{"kind":"arabic","text_bw":"samon","text_ar":"سَمْن"},{"kind":"text","text":". (L.)"}],"source_refs":["S","M","L","Msb","K","IAar"]},{"entry_id":"n20790","headword_ar":"سَمْنٌ","root":"smn","body":[{"kind":"italic_en","text":"Clarified butter; ghee;"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"silaA='","text_ar":"سِلَا=ء"},{"kind":"italic_en","text":"of fresh butter,"},{"kind":"text","text":"(M, L, K,) or"},{"kind":"italic_en","text":"of milk;"},{"kind":"text","text":"(L;) it is"},{"kind":"italic_en","text":"of the cow,"},{"kind":"text","text":"and sometimes"},{"kind":"italic_en","text":"of the goat:"},{"kind":"text","text":"(S, L:)"},{"kind":"italic_en","text":"what comes forth,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"is made,"},{"kind":"text","text":"(Msb,) [or"},{"kind":"italic_en","text":"clarified, by cooking it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boiling it, sometimes with an admixture of"},{"kind":"arabic","text_bw":"sawiyq","text_ar":"سَوِيق"},{"kind":"text","text":"(or"},{"kind":"italic_en","text":"meal of parched barley"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wheat"},{"kind":"text","text":"), or"},{"kind":"italic_en","text":"dates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"globules of gazelles' dung,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"xulaASapN","text_ar":"خُلَاصَةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qi$odapN","text_ar":"قِشْدَةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qilodapN","text_ar":"قِلْدَةٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"from the milk of cows,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of goats,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"sheep:"},{"kind":"text","text":"(Msb:) [n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":":] pl. [of mult.]"},{"kind":"arabic","text_bw":"sumonaAnN","text_ar":"سُمْنَانٌ"},{"kind":"text","text":"(S, M, L, Msb, K, in the CK [erroneously]"},{"kind":"arabic","text_bw":"simonaAnN","text_ar":"سِمْنَانٌ"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"sumuwnN","text_ar":"سُمُونٌ"},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^asomunN","text_ar":"اَسْمُنٌ"},{"kind":"text","text":": (M, L, K:)"},{"kind":"italic_en","text":"it counteracts all poisons, clears away the filth from foul ulcers, matures all tumours, and removes the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"discoloration and spots termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"kalaf","text_ar":"كَلَف"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"nama$","text_ar":"نَمَش"},{"kind":"italic_en","text":"from the face, applied as a liniment."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"samonu Alhabiydi","text_ar":"سَمْنُ الهَبِيدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Decocted juice of the colocynth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of its pulp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seed"},{"kind":"text","text":"]. (TA voce"},{"kind":"arabic","text_bw":"xawolaEN","text_ar":"خَوْلَعٌ"},{"kind":"text","text":", q. v.)"}],"source_refs":["M","L","K","S","Mgh","Msb"]},{"entry_id":"n20791","headword_ar":"سِمَنٌ","root":"smn","body":[{"kind":"italic_en","text":"Fatness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plumpness; contr. of"},{"kind":"arabic","text_bw":"huzaAlN","text_ar":"هُزَالٌ"},{"kind":"text","text":"; (M, L;) or the"},{"kind":"italic_en","text":"condition of having much flesh and fat."},{"kind":"text","text":"(Msb.) [See 1, first sentence.]"}],"source_refs":[]}]}}