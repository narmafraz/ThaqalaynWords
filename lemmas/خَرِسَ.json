n":"m","num":"p"},{"role":"present_2mp","form":"تَخْرَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْرَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْرَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْرَس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْرَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْرَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْرَسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْرَسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْرَسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْرَسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْرَسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"خَرِسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَرِسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَخْرَس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْرَس","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n10323"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B1%D9%90%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be mute, to be dumb"},{"pos":"verb","gloss":"to become silent, keep silent, hold one's tongue"},{"pos":"verb","gloss":"to guess, to estimate"},{"pos":"verb","gloss":"to conjecture, to surmise"},{"pos":"verb","gloss":"to tell an untruth, falsehood; to lie"}]},"etymology":null,"ipa":["/xa.ri.sa/","/xa.ra.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10323","headword_ar":"خَرِسَ","root":"xrs","body":[{"kind":"text","text":", (Msb, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"xarasN","text_ar":"خَرَسٌ"},{"kind":"text","text":", (S, A, Msb, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was dumb; was naturally, by conformation, prevented from speaking;"},{"kind":"text","text":"(Msb;) ["},{"kind":"italic_en","text":"he was destitute of the faculty of speech, by natural conformation, like the beast:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"A^axorasu","text_ar":"اَخْرَسُ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tonguetied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld from speech,"},{"kind":"text","text":"(A, K,)"},{"kind":"italic_en","text":"either from inability to find words to express what he would say,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by natural conformation"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the organs of speech"},{"kind":"text","text":"]. (TA.) You say also"},{"kind":"arabic","text_bw":"xarisa Almajolisu","text_ar":"خَرِسَ المَجْلِسُ"},{"kind":"italic_en","text":"The assembly was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, mute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"speechless."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"xarasa AlmaroA^apa","text_ar":"خَرَسَ المَرْاَةَ"},{"kind":"text","text":", (Lh, IAth,) aor."},{"kind":"text","text":", (Lh,) [inf. n., app.,"},{"kind":"arabic","text_bw":"xarosN","text_ar":"خَرْسٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He fed the woman with what is termed"},{"kind":"arabic","text_bw":"xurosap","text_ar":"خُرْسَة"},{"kind":"text","text":"; (Lh, IAth;)"},{"kind":"italic_en","text":"He fed her on the occasion of child-birth;"},{"kind":"text","text":"(Lh;) as also ↓"},{"kind":"arabic","text_bw":"xr~s","text_ar":"خرّس","orth_type":"arrow"},{"kind":"arabic","text_bw":"EalyhaA","text_ar":"عَليهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoriysN","text_ar":"تَخْرِيسٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"taxorisapN","text_ar":"تَخْرِسَةٌ"},{"kind":"text","text":". (TA.) In like manner you say, ↓"},{"kind":"arabic","text_bw":"xr~shaA","text_ar":"خرّسهَا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taxoriysN","text_ar":"تَخْرِيسٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"xrs EanohaA","text_ar":"خرس عَنْهَا"},{"kind":"text","text":"; [so in the TA, without any syll. signs to the verb;]"},{"kind":"italic_en","text":"He made for her what is termed"},{"kind":"arabic","text_bw":"xurosap","text_ar":"خُرْسَة"},{"kind":"text","text":". (TA.) And ↓"},{"kind":"arabic","text_bw":"xurisato","text_ar":"خُرِسَتْ","orth_type":"arrow"},{"kind":"text","text":", (S, L,) or"},{"kind":"arabic","text_bw":"xurisato","text_ar":"خُرِسَتْ"},{"kind":"text","text":", (so in a copy of the A,)"},{"kind":"italic_en","text":"She was fed with what is so termed:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"a feast on the occasion of her having given birth to a child was made for her."},{"kind":"text","text":"(S, L.)       -A3-"},{"kind":"arabic","text_bw":"xarisa","text_ar":"خَرِسَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He drank from the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of wine-jar called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xaros","text_ar":"خَرْس"},{"kind":"text","text":", (Sgh, K,) i. e."},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"dan~","text_ar":"دَنّ"},{"kind":"text","text":". (TA.)"}],"source_refs":["Msb","K","S","A","Lh","IAth","L","Sgh"]}]},"classical_definitions":null}