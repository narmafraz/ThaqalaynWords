l,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرُومُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرِيم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرِيم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رُمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رُمْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رِمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رِمْتُ","in_corpus":true,"count":5,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرُوم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُوم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":53,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n14313","n16740","n17137","n17140"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to aspire to, to aim at, to envisage, to propose to oneself, to desire ardently","tags":["transitive"],"examples":[{"text":"زهير بن أبي سلمى - Zuhayr ibn Abi Sulma\nوَمَنْ هابَ أَسْبَابَ المَنِيَّةِ يَلْقَهَا ... وَلَوْ رَامَ أَسْبَابَ السَّمَاءِ بِسُلَّمِ\nwaman hāba ʔasbāba l-maniyyati yalqahā ... walaw rāma ʔasbāba s-samāʔi bisullami","english":"(please add an English translation of this quotation)"}]},{"pos":"verb","gloss":"to depart from, to separate oneself from"},{"pos":"noun","gloss":"who shoots or throws, marksman, archer, etc."}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *rawam-, related to *rayam-.\n\nFrom Proto-Semitic *rayam-, related to *rawam-.\n\nDerived from the active participle of رَمَى (ramā)."},"ipa":["/raː.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14313","headword_ar":"رَاْمٌ","root":"rA^m","body":[{"kind":"italic_en","text":"A she-camel's young one;"},{"kind":"text","text":"(T, S;) accord. to IAar: (T:) or"},{"kind":"italic_en","text":"a she-camel's young one which she affects,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to which she inclines:"},{"kind":"text","text":"(M:) and, (S, M,) accord. to Lth, (T,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"baw~N","text_ar":"بَوٌّ"},{"kind":"text","text":"[which has the former of the meanings above, but more commonly signifies"},{"kind":"italic_en","text":"a skin of a young unweaned camel stuffed with straw"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with panic grass"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with dry herbage, to which a she-camel is made to incline when her young one has died; it being brought near to the mother of a young camel that has died, in order that she may incline to it and yield her milk"},{"kind":"text","text":"]: (T, S, M, K:) or"},{"kind":"italic_en","text":"a young one to which she that is not its mother is made to incline."},{"kind":"text","text":"(T.)"}],"source_refs":["T","M","S","K"]},{"entry_id":"n16740","headword_ar":"رَامٍ","root":"rmY","body":[{"kind":"text","text":"act. part. n. of 1; (Lth, T, TA;)"},{"kind":"italic_en","text":"Throwing,"},{"kind":"text","text":"&c.: (TA:) [pl."},{"kind":"arabic","text_bw":"rumaApN","text_ar":"رُمَاةٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,"},{"kind":"arabic","text_bw":"Alr~aAmiY","text_ar":"الرَّامِى"},{"kind":"text","text":"a name of"},{"kind":"italic_en","text":"The constellation Sagittarius; the ninth of the signs of the zodiac:"},{"kind":"text","text":"thus called in the present day; but more commonly,"},{"kind":"arabic","text_bw":"Alqawosu","text_ar":"القَوْسُ"},{"kind":"text","text":".] ―         -b3-  [Hence likewise,]"},{"kind":"arabic","text_bw":"raAmK","text_ar":"رَامٍ"},{"kind":"text","text":"also signifies (assumed tropical:)  [One"},{"kind":"italic_en","text":"who assails"},{"kind":"text","text":"with reproach, &c.:] (assumed tropical:)  one"},{"kind":"italic_en","text":"who reproaches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upbraids;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who gives an ill name:"},{"kind":"text","text":"(KL:) [(assumed tropical:)  one"},{"kind":"italic_en","text":"who accuses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspects,"},{"kind":"text","text":"another: see"},{"kind":"arabic","text_bw":"maromiY~N","text_ar":"مَرْمِىٌّ"},{"kind":"text","text":".]"}],"source_refs":["TA","KL"]},{"entry_id":"n17137","headword_ar":"رَامَ","root":"rwm","body":[{"kind":"text","text":", (T, S, M, Msb,) aor."},{"kind":"arabic","text_bw":"yaruwmu","text_ar":"يَرُومُ"},{"kind":"text","text":", (T, S, Msb,) inf. n."},{"kind":"arabic","text_bw":"rawomN","text_ar":"رَوْمٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"maraAmN","text_ar":"مَرَامٌ"},{"kind":"text","text":", (Msb, K, TA,)"},{"kind":"italic_en","text":"He sought, sought for"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Talaba","text_ar":"طَلَبَ"},{"kind":"text","text":", (T, * M, Msb, K, *) a thing. (S, M, Msb.) ―         -b2-  [And hence,"},{"kind":"italic_en","text":"He attempted"},{"kind":"text","text":"another person in fight &c., and a thing.] ―         -b3-  And [hence also]"},{"kind":"arabic","text_bw":"Alr~awomu","text_ar":"الرَّوْمُ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"rawomu AlHarakapi","text_ar":"رَوْمُ الحَرَكَةِ"},{"kind":"text","text":", mentioned by Sb, (S,) [as though signifying"},{"kind":"italic_en","text":"The desiring to pronounce the vowel-sound without fully accomplishing that desire,"},{"kind":"text","text":"] means ["},{"kind":"italic_en","text":"the pronouncing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a vowel-sound"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Harakap","text_ar":"حَرَكَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"slurred"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muxotalasap","text_ar":"مُخْتَلَسَة"},{"kind":"text","text":")"},{"kind":"italic_en","text":"and rendered obscure,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by,"},{"kind":"text","text":"[accord. to different copies of the S,]"},{"kind":"italic_en","text":"a sort of alleviation"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the utterance"},{"kind":"text","text":"]; (S;)"},{"kind":"italic_en","text":"it is more"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in effect"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"than what is termed"},{"kind":"arabic","text_bw":"AlA_i$omaAm","text_ar":"الاـِشْمَام"},{"kind":"text","text":","},{"kind":"italic_en","text":"because it is heard;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"and it is of the same measure"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in prosody"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"as the vowel-sound"},{"kind":"text","text":"["},{"kind":"italic_en","text":"fully pronounced"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"as"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the case of what is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hamozapN bayona bayona","text_ar":"هَمْزَةٌ بَيْنَ بَيْنَ"},{"kind":"text","text":", such as in the saying of the poet,"},{"kind":"quote","text":"A^aAano zum~a A^ajomaAlN wafaAraqa jiyrapN\n                      \n                     \n                        wa SaAHa guraAbu Albayoni A^anota Haziynu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Is it because that camels have had the nose-reins attached to them, and neighbours have separated, one from another, and the raven of disunion has uttered its cry, thou art mourning?"},{"kind":"text","text":"];"},{"kind":"arabic","text_bw":"A^aAano zumo","text_ar":"اَاَنْ زُمْ"},{"kind":"italic_en","text":"being scanned as"},{"kind":"arabic","text_bw":"faEuwluno","text_ar":"فَعُولُنْ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"and it not being allowable to make the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in"},{"kind":"arabic","text_bw":"fEwln","text_ar":"فعولن"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"quiescent: it is such also as in the phrase in the Kur"},{"kind":"text","text":"[ii. 181]"},{"kind":"arabic","text_bw":"$ahoru ramaDaAna","text_ar":"شَهْرُ رَمَضَانَ"},{"kind":"italic_en","text":"with him who makes"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the dammeh"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"obscure; it being only with a slurred vowel-sound"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Harakap muxotalasap","text_ar":"حَرَكَة مُخْتَلَسَة"},{"kind":"text","text":");"},{"kind":"italic_en","text":"and it not being allowable for the former"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"italic_en","text":"of"},{"kind":"arabic","text_bw":"$hr","text_ar":"شهر"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to be quiescent, because the"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"italic_en","text":"before it is quiescent, for this would lead to the combination of two quiescent letters in a case of continuity,"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"when there is no pause after them,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without there being before them a soft letter"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", as in"},{"kind":"arabic","text_bw":"dawaAb~","text_ar":"دَوَابّ"},{"kind":"text","text":"&c.],"},{"kind":"italic_en","text":"which is not found in any of the dialects of the Arabs:"},{"kind":"text","text":"and it is such also as in the instances in the Kur [xv. 9 and x. 36 and xxxvi. 49]"},{"kind":"arabic","text_bw":"A_in~aA naHonu","text_ar":"اـِنَّا نَحْنُ"},{"kind":"arabic","text_bw":"naz~alonaA A@l*~ikora","text_ar":"نَزَّلْنَا ا@لذِّكْرَ"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"A^am~ano laA yahid~iY","text_ar":"اَمَّنْ لَا يَهِدِّى"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"yaxiS~imuwna","text_ar":"يَخِصِّمُونَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for"},{"kind":"arabic","text_bw":"yahotadiY","text_ar":"يَهْتَدِى"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"yaxotaSimuwna","text_ar":"يَخْتَصِمُونَ"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and the like thereof:"},{"kind":"text","text":"no regard should be paid to the saying of Fr, that in this [last] and the like instances a letter [which in this instance and in the next preceding it is"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"] is incorporated into another [following it]; for they [i. e. the Arabs] do not realize this mode [of incorporation]; and he who combines two quiescent letters in an instance in which the slurring of the vowel-sound ("},{"kind":"arabic","text_bw":"AixotilaAsu AlHarakapi","text_ar":"اِخْتِلَاسُ الحَرَكَةِ"},{"kind":"text","text":") is not proper errs; as in the reading of Hamzeh, in the Kur [xviii. 96],"},{"kind":"arabic","text_bw":"famaA A@sT~aAEuwA","text_ar":"فَمَا ا@سطَّاعُوا"},{"kind":"text","text":"; for the"},{"kind":"arabic","text_bw":"s","text_ar":"س"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"AlAisotifoEaAlu","text_ar":"الاِسْتِفْعَالُ"},{"kind":"text","text":"may not be made movent in any manner [and therefore it may not be incorporated into the following letter]. (S, TA.)"},{"kind":"arabic","text_bw":"Alr~awomu","text_ar":"الرَّوْمُ"},{"kind":"text","text":"is [also] in a case of pausing after a word ending with any letter except the fem."},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", [in like manner] meaning"},{"kind":"italic_en","text":"The indicating the vowel with an obscure sound:"},{"kind":"text","text":"(I' Ak p. 351:)"},{"kind":"arabic","text_bw":"rawomu AlHarakapi","text_ar":"رَوْمُ الحَرَكَةِ"},{"kind":"text","text":"in pausing after a word that is"},{"kind":"arabic","text_bw":"marofuwE","text_ar":"مَرْفُوع"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"majoruwr","text_ar":"مَجْرُور"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"raAma Al$~aYo'a","text_ar":"رَامَ الشَّىْءَ"},{"kind":"text","text":"signifying"},{"kind":"arabic","text_bw":"Talabahu","text_ar":"طَلَبَهُ"},{"kind":"text","text":": Sb says that those of whom one says"},{"kind":"arabic","text_bw":"raAmuwA AlHarakapa","text_ar":"رَامُوا الحَرَكَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They slurred the vowel-sound"},{"kind":"text","text":"] are induced to do what this signifies [instead of suppressing the vowel-sound entirely] by eagerness to exclude it from the case of that which is necessarily made quiescent in every instance, and to show that its case is, in their opinion, not like the case of that which is made quiescent in every instance. (M.) [See also 4 in art."},{"kind":"arabic","text_bw":"$wr","text_ar":"شور"},{"kind":"text","text":".]"}],"source_refs":["T","S","M","Msb","K","TA"]},{"entry_id":"n17140","headword_ar":"رَامٌ","root":"rwm","body":[{"kind":"italic_en","text":"A certain species of trees."},{"kind":"text","text":"(S, K. *)"}],"source_refs":[]}]}}