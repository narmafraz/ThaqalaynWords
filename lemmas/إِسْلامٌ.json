{"lemma":"إِسْلامٌ","slug":"إِسْلامٌ","root":"س.ل.م","root_slug":"س-ل-م","root_link":"/words/roots/س-ل-م","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"إِسْلام","root":"سلم","pos":"N","occurrence_count":8},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["name","noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of أَسْلَمَ (ʔaslama) (form IV)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"submission, resignation, reconciliation"},{"pos":"noun","gloss":"religious submission to God, piety","examples":[{"text":"الْإِسْلَام","english":"Islam (religion of Muslims)"}]},{"pos":"name","gloss":"a male given name"}]},"etymology":{"source":"wiktextract","text":"Verbal noun of أَسْلَمَ (ʔaslama)."},"ipa":["/ʔis.laːm/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A5%D8%B3%D9%84%D8%A7%D9%85/","headword_ar":"إسلام","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22852#89beb8","body_html":"<span>الإسلام: الخضوع والانقياد لما أخبر به الرسول صلى الله عليه وسلم. وفي الكشاف: أن كل ما يكون الإقرار باللسان من غير مواطأة القلب، فهو إسلام، وما واطأ فيه القلب اللسان فهو إيمان. أقول: هذا مذهب الشافعي، وأما مذهب أبي حنيفة فلا فرق بينهما.</span>"}]}}