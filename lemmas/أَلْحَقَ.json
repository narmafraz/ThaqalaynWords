"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُلْحَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُلْحَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُلْحِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُلْحِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُلْحَقُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُلْحَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُلْحِقُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُلْحِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُلْحَقْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُلْحِقْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُلْحَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُلْحَق","in_corpus":true,"count":270,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُلْحِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُلْحِق","in_corpus":true,"count":270,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَلْحَقْنا","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَلْحَقْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":618,"cross_references":{"qac":{"found":true,"lemma_key":"أَلْحَقَ","root":"لحق","pos":"V","occurrence_count":4},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to attach, to affix, to join, to append, to annex, to add (something بِ to); to connect (something بِ to)"},{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to attach, to affix, to join, to append, to annex, to add (something بِ to); to affiliate (someone) to (someone)"},{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to attach, to affix, to join, to append, to annex, to add (something بِ to); to admit, to enroll (someone بِ to/in an organization)"},{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to enclose (something بِ in)"},{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to inflict (something بِ upon)"},{"pos":"verb","gloss":"to cause (someone) to reach (بِ someone); to increase, to augment (something بِ by)"}]},"etymology":null,"ipa":null,"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D9%84%D8%AD%D9%82/","headword_ar":"الحق","entries":[{"lexicon_id":"dictionary_27","lexicon_en":"Al-Barakatī, al-Taʿrīfāt al-Fiqhīya (d. 1975 CE)","lexicon_ar":"التعريفات الفقهيّة للبركتي","permalink":"https://arabiclexicon.hawramani.com/?p=36749#19e944","body_html":"الحَقُّ: هو الثابت الذي لا يسوغ إنكاره، اليقينُ، ضدُ الباطل، الحظُّ والنصيبُ، المالُ والمِلكُ، الأمر المقضيُّ جمعه حقوق. والحقُّ من أسماء الله تعالى الموجود حقيقةً المتحقق وجودُه وإآلهيَّته."},{"lexicon_id":"dictionary_22","lexicon_en":"Al-Munāwī, al-Tawqīf ʿalā Muhimmāt al-Taʿārīf (d. 1622 CE)","lexicon_ar":"التوقيف على مهمات التعاريف للمناوي","permalink":"https://arabiclexicon.hawramani.com/?p=36749#0d7cec","body_html":"<span>الحق: لغة الثابت الذي لا يسوغ إنكاره. وعرفا: الحكم المطابق للواقع، يطلق على الأقوال والعقائد والأديان والمذاهب باعتبار اشتمالها على ذلك، ويقابله الباطل. وأما الصدق فشاع في الأقوال فقط ويقابله الكذب. وفرق بينهما بأن المطابقة تعتبر في الحق من جانب الواقع، وفي الصدق من جانب الحكم، فمعنى صدق الحكم مطابقته للواقع ومعنى، حقيته مطابقة الواقع إياه كذا في شرح العقائد. وقال الراغب: الحق المطابقة والموافقة كمطابقة رجل الباب في حقه لدورانه على استقامة. والحق يقال لموجد الشيء بحسب ما تقتضيه الحكمة، ولذلك قيل في الله هو الحق، وللموجود بحسب مقتضى الحكمة، ولذلك يقال: فعل الله كله حق نحو الموت والبعث حق، وللاعتقاد في الشيء المطابق لما عليه ذلك الشيء في نفسه، نحو اعتقاد زيد في البعث حق، وللفعل والقول الواقع بحسب ما يجب وقدر ما يجب وفي الوقت الذي يجب، نحو فعلك حق، وقولك حق. ويقال: أحققت ذا أي أثبته حقا، أو حكمت بكونه حقا. فإحقاق الحق ضربان: أحدهما بإظهار الأدلة والآيات، ومنه {جَعَلْنَا لَكُمْ عَلَيْهِمْ سُلْطَانًا مُبِينًا} أي حجة قوية. والثاني: بإكمال الشريعة وبثها، ومنه {وَاللَّهُ مُتِمُّ نُورِه} . ويستعمل استعمال الواجب واللازم والجائز نحو: {وَكَانَ حَقًّا عَلَيْنَا نَصْرُ الْمُؤْمِنِينَ} . والحقيقة تستعمل تارة في الشيء الذي له ثبات ووجود، وتارة في الاعتقاد، وتارة في العمل، وتارة في القول. وفي المصباح: حق الشيء وجب وثبت، ولهذا يقال لمرافق الدار حقوقها. وحقت القيامة أحاطت بالخلائق، وحقت الحاجة نزلت واشتدت. وحققت الأمر وتحققته تيقنته وجعلته ثابتا لازما. وحقيقة الشيء منتهاه وأصله المشتمل عليه، وزيد حقيق بكذا خليق به، ماخوذ من الحق الثابت. وقولهم هو، أحق بكذا يستعمل بمعنيين: أحدهما اختصاصه بذلك بغير شريك كزيد أحق بماله أي لا حق لغيره فيه. الثاني: أن يكون أفعل تفضيل فيقتضي اشتراكه مع غيره وترجيحه عليه، ومنه \"الأيم أحق بنفسها من وليها\" ، فهما مشتركان لكن حقها آكد. واستحق فلان الأمر استوجب، ومنه قولهم خرج المبيع مستحقا.</span><br>"}]}}