{"lemma":"شَرَهُ","slug":"شَرَهُ","root":"ش.ر.ه","root_slug":"ش-ر-ه","root_link":"/words/roots/ش-ر-ه","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n22005","n22250","n22251"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%8E%D9%87%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"wolverine, a mammal of the Mustelidae family, Gulo gulo."},{"pos":"verb","gloss":"to be greedy"},{"pos":"verb","gloss":"to eat greedily, to be gluttonous"},{"pos":"noun","gloss":"gluttony, gourmandism, ravenousness, voracity"},{"pos":"noun","gloss":"greediness, greed, covetousness, avidity"},{"pos":"adj","gloss":"greedy (على for food), gluttonous"},{"pos":"adj","gloss":"voracious, ravenous"},{"pos":"adj","gloss":"ravenous eater, glutton"},{"pos":"adj","gloss":"greedy, covetous, avid"}]},"etymology":{"source":"wiktextract","text":"Derived from شَرِهَ (šariha, “to eat greedily, to be gluttonous”). Calque of English wolverine."},"ipa":["/ʃa.ri.ha/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22005","headword_ar":"شِرَّةٌ","root":"$r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$ar~N","text_ar":"شَرٌّ"},{"kind":"text","text":", first sentence. ―         -b2-  Also The"},{"kind":"italic_en","text":"inordinate desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerness,"},{"kind":"text","text":"(S,) and"},{"kind":"italic_en","text":"sprightliness,"},{"kind":"text","text":"of youth: (S, K:) and in an absolute sense,"},{"kind":"italic_en","text":"inordinate desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerness;"},{"kind":"text","text":"and [simply]"},{"kind":"italic_en","text":"desire;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"sprightliness:"},{"kind":"text","text":"(TA:) [and]"},{"kind":"italic_en","text":"sharpness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"angriness."},{"kind":"text","text":"(Har p. 35.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a lih`*aA AlquroA=ni $ir~apF vum~a A_in~a liln~aAsi Eanohu fatorapF","text_ar":"اـِنَّ لِهٰذَا القُرْا=نِ شِرَّةً ثُمَّ اـِنَّ لِلنَّاسِ عَنْهُ فَتْرَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily there is an eagerness for this Kur-án: then men have a weariness of it"},{"kind":"text","text":"]. (L.)"}],"source_refs":["S","K","TA"]},{"entry_id":"n22250","headword_ar":"شَرِهَ","root":"$rh","body":[{"kind":"text","text":"(S, MA, Mgh, Msb, K)"},{"kind":"arabic","text_bw":"EalaY AlT~aEaAmi","text_ar":"عَلَى الطَّعَامِ"},{"kind":"text","text":"(MA, Mgh, Msb)"},{"kind":"arabic","text_bw":"wagayorihi","text_ar":"وَغَيْرِهِ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"A_ilaY AlT~aEaAmi","text_ar":"اـِلَى الطَّعَامِ"},{"kind":"text","text":", (TA, [perhaps a mistranscription,]) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$arahN","text_ar":"شَرَهٌ"},{"kind":"text","text":", (S, MA, Mgh, Msb,) said of a man, (S,)"},{"kind":"italic_en","text":"He was vehemently desirous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greedy;"},{"kind":"text","text":"(MA;) or"},{"kind":"italic_en","text":"very vehemently desirous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very greedy;"},{"kind":"text","text":"(Mgh, Msb;) or"},{"kind":"italic_en","text":"overcome by vehement desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greediness;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"of the food"},{"kind":"text","text":"(MA, Mgh, Msb)"},{"kind":"italic_en","text":"&c.:"},{"kind":"text","text":"(Msb:) or, as some say,"},{"kind":"italic_en","text":"he was affected with the worst of vehement desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of greediness."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","MA","Mgh","Msb","K"]},{"entry_id":"n22251","headword_ar":"شَرِهٌ","root":"$rh","body":[{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"$arohaAnu","text_ar":"شَرْهَانُ","orth_type":"arrow"},{"kind":"text","text":"(Lth, K) ["},{"kind":"italic_en","text":"Vehemently desirous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greedy;"},{"kind":"text","text":"(see 1;) or]"},{"kind":"italic_en","text":"very vehemently desirous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very greedy;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"overcome by vehement desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greediness:"},{"kind":"text","text":"(K:) or, accord. to some,"},{"kind":"italic_en","text":"affected with the worst of vehement desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of greediness."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","Lth"]}]}}