تَذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْتَذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْتَذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْتَذِر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْتَذِر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْتَذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْتَذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْتَذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْتَذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْتَذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْتَذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْتَذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"اِعْتَذَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"اِعْتَذَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَعْتَذِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْتَذِر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28432"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B9%D9%92%D8%AA%D9%8E%D8%B0%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to excuse oneself; to apologise to","examples":[{"text":"يَنْبَغِي أَنْ يَعْتَذِرَ.","english":"He should apologize."}]}]},"etymology":null,"ipa":["/iʕ.ta.ða.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28432","headword_ar":"اعتذر","root":"E*r","body":[{"kind":"text","text":", (S, O, Msb, &c.,) inf. n."},{"kind":"arabic","text_bw":"AiEoti*aArN","text_ar":"اِعْتِذَارٌ"},{"kind":"text","text":", (S, O, TA,) and [quasi-inf. ns.] ↓"},{"kind":"arabic","text_bw":"Ei*orapN","text_ar":"عِذْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEo*irapN","text_ar":"مَعْذِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and for"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر"},{"kind":"text","text":"one says also"},{"kind":"arabic","text_bw":"AiEa*~ara","text_ar":"اِعَذَّرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEa*~iru","text_ar":"يَعَذِّرُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"AiEi*~aArN","text_ar":"اِعِذَّارٌ"},{"kind":"text","text":"; and it is allowable to say"},{"kind":"arabic","text_bw":"AiEi*~ira","text_ar":"اِعِذِّرَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEi*~iru","text_ar":"يَعِذِّرُ"},{"kind":"text","text":"; but the former of these two variations is the more approved; (AHeyth, TA;) [in the former case, the original being changed to"},{"kind":"arabic","text_bw":"AiEato*ara","text_ar":"اِعَتْذَرَ"},{"kind":"text","text":", then to"},{"kind":"arabic","text_bw":"AiEa*o*ara","text_ar":"اِعَذْذَرَ"},{"kind":"text","text":", then to"},{"kind":"arabic","text_bw":"AiEa*~ara","text_ar":"اِعَذَّرَ"},{"kind":"text","text":"; and in the latter case, to"},{"kind":"arabic","text_bw":"AiEoto*ara","text_ar":"اِعْتْذَرَ"},{"kind":"text","text":", then to"},{"kind":"arabic","text_bw":"AiEito*ara","text_ar":"اِعِتْذَرَ"},{"kind":"text","text":", then to"},{"kind":"arabic","text_bw":"AiEi*o*ara","text_ar":"اِعِذْذَرَ"},{"kind":"text","text":", then to"},{"kind":"arabic","text_bw":"AiEi*ora","text_ar":"اِعِذْرَ"},{"kind":"text","text":", and then to"},{"kind":"arabic","text_bw":"AiEi*~ira","text_ar":"اِعِذِّرَ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"He excused himself; he adduced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urged, an excuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a plea, for himself;"},{"kind":"text","text":"(Fr, S, * O, * TA;) as also ↓"},{"kind":"arabic","text_bw":"tE*~r","text_ar":"تعذّر","orth_type":"arrow"},{"kind":"text","text":". (S, O, K.) [See"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"AEt*r A_ilaY~a","text_ar":"اعتذر اـِلَىَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He excused himself to me;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he begged me to accept his excuse;"},{"kind":"text","text":"(Msb;) and AZ says, I have heard two Arabs of the desert, one of the tribe of Temeem and one of the tribe of Keys, say,"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taEa*~arotu","text_ar":"تَعَذَّرْتُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Alr~ajuli","text_ar":"الرَّجُلِ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"AiEota*arotu","text_ar":"اِعْتَذَرْتُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I excused myself to the man"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"AEt*r mino *anobihi","text_ar":"اعتذر مِنْ ذَنْبِهِ"},{"kind":"text","text":"(S, * O, * TA) and ↓"},{"kind":"arabic","text_bw":"tE*~r","text_ar":"تعذّر","orth_type":"arrow"},{"kind":"text","text":"(TA) ["},{"kind":"italic_en","text":"He excused himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urged an excuse, for his crime, sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misdeed:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he asserted himself to be clear of his crime, sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"misdeed."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر"},{"kind":"arabic","text_bw":"Eano fiEolihi","text_ar":"عَنْ فِعْلِهِ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"mino fElh","text_ar":"مِنْ فعله"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He showed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifested, his excuse for his deed."},{"kind":"text","text":"(Msb.) [It is said that] the primary meaning of"},{"kind":"arabic","text_bw":"AlAiEoti*aAru","text_ar":"الاِعْتِذَارُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"The cutting a man off from the object of his want, and from that to which he clings in his heart."},{"kind":"text","text":"(TA.) [Hence, perhaps, one says"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"He excused himself for not complying with a claim,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"request."},{"kind":"text","text":"] ―         -b2-  See also 4, in two places, near the beginning. ―         -b3-  Also"},{"kind":"italic_en","text":"He did not adduce an excuse."},{"kind":"text","text":"(Fr, TA.) [Thus it has two contr. significations. See also 2.]       -A2-  Also"},{"kind":"italic_en","text":"He complained,"},{"kind":"text","text":"(O, Msb, K,)"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"italic_en","text":"of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Msb.)       -A3-  And"},{"kind":"arabic","text_bw":"AEt*rt AlmiyaAhu","text_ar":"اعتذرت المِيَاهُ"},{"kind":"italic_en","text":"The waters stopped, ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became cut off."},{"kind":"text","text":"(O, K.) ―         -b2-  See also 5, last sentence but one, in two places.       -A4-  And"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر"},{"kind":"arabic","text_bw":"AlEimaAmapa","text_ar":"العِمَامَةَ"},{"kind":"italic_en","text":"He made the turban to have two portions"},{"kind":"text","text":"["},{"kind":"italic_en","text":"its two ends"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hanging down behind."},{"kind":"text","text":"(O, K.)       -A5-  And"},{"kind":"arabic","text_bw":"AlAiEoti*aAru","text_ar":"الاِعْتِذَارُ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"The act of devirginating."},{"kind":"text","text":"(S, O, [See"},{"kind":"arabic","text_bw":"Eu*orapN","text_ar":"عُذْرَةٌ"},{"kind":"text","text":".])"}],"source_refs":["S","O","TA","Msb","K"]}]},"classical_definitions":null}