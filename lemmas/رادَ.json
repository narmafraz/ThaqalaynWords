"تَرُودُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرُودُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرُدْنَ","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرُد","in_corpus":true,"count":145,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَرُود","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرُد","in_corpus":true,"count":48,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرُود","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرُودُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرُودُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرُدْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رُدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رُدْتُ","in_corpus":true,"count":9,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُود","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرُود","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":274,"cross_references":{"qac":{"found":true,"lemma_key":"رادَ","root":"ردد","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n14261","n15199","n17032","n17036"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to return, give back, requite","tags":["transitive"]},{"pos":"verb","gloss":"to oppose, to fight"}]},"etymology":{"source":"wiktextract","text":"Compare رَدَّ (radda, “to return”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14261","headword_ar":"رَاْدٌ","root":"rA^d","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ruw^odN","text_ar":"رُوْدٌ"},{"kind":"text","text":". ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"raA^odu AlD~uHaY","text_ar":"رَاْدُ الضُّحَى"},{"kind":"text","text":"(T, S, M, A, L, K) and ↓"},{"kind":"arabic","text_bw":"raAy^iduhu","text_ar":"رَايِدُهُ","orth_type":"arrow"},{"kind":"text","text":"(K) (tropical:)"},{"kind":"italic_en","text":"The stage of the"},{"kind":"arabic","text_bw":"DuHaY","text_ar":"ضُحَى"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"period after sunrise"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that is termed the"},{"kind":"arabic","text_bw":"$abaAb","text_ar":"شَبَاب"},{"kind":"italic_en","text":"of the day;"},{"kind":"text","text":"(A;) i. e.,"},{"kind":"italic_en","text":"when the sun has risen high,"},{"kind":"text","text":"(T, S, A, K, TA,)"},{"kind":"italic_en","text":"one fifth of the day having passed:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"the brightness thereof:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the period after the spreading of the sunshine and the time when the sun has become high."},{"kind":"text","text":"(M.)       -A2-  Also"},{"kind":"arabic","text_bw":"Alr~aA^odu","text_ar":"الرَّاْدُ"},{"kind":"text","text":"(S, M, A, and so accord. to some copies of the K) and ↓"},{"kind":"arabic","text_bw":"Alr~uw^odu","text_ar":"الرُّوْدُ","orth_type":"arrow"},{"kind":"text","text":", (S, M, and so accord. to some copies of the K,) or"},{"kind":"arabic","text_bw":"raA^odu All~aHoYi","text_ar":"رَاْدُ اللَّحْىِ"},{"kind":"text","text":", (T,) and ↓"},{"kind":"arabic","text_bw":"Alr~aA^odapu","text_ar":"الرَّاْدَةُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Alr~uw^odapu","text_ar":"الرُّوْدَةُ","orth_type":"arrow"},{"kind":"text","text":"likewise, (accord. to some copies of the K, [but these I do not find in this sense in any other lexicon,]) or"},{"kind":"arabic","text_bw":"Alruw^odapu","text_ar":"الرُوْدَةُ"},{"kind":"text","text":"only of all these, (accord. to other copies of the K, in some of which it is written without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"The root of the jaw-bone"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^aSolu All~aHoYi","text_ar":"اَصْلُ اللَّحْىِ"},{"kind":"text","text":"), (T, S, M, A, K,)"},{"kind":"italic_en","text":"that projects beneath the ear:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"the part of the jaw-bone whence the molar teeth"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlA^aDoraAs","text_ar":"الاَضْرَاس"},{"kind":"text","text":")"},{"kind":"italic_en","text":"grow:"},{"kind":"text","text":"or the"},{"kind":"arabic","text_bw":"raA^odaAni","text_ar":"رَاْدَانِ"},{"kind":"text","text":"are"},{"kind":"italic_en","text":"the two thin extremities of the"},{"kind":"arabic","text_bw":"laHoyaAni","text_ar":"لَحْيَانِ"},{"kind":"text","text":"[meaning the"},{"kind":"italic_en","text":"two sides of the lower jaw-bone"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"which are in their upper part, sharp, and curved, and suspended in two holes beneath the two ears:"},{"kind":"text","text":"(M:) pl."},{"kind":"arabic","text_bw":"A^aroA=dN","text_ar":"اَرْا=دٌ"},{"kind":"text","text":". (S.)       -A3-  Also"},{"kind":"arabic","text_bw":"raA^odN","text_ar":"رَاْدٌ"},{"kind":"italic_en","text":"A vacant tract"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xalaA='","text_ar":"خَلَا=ء"},{"kind":"text","text":") of land. (K.)"}],"source_refs":["T","S","M","A","L","K","TA"]},{"entry_id":"n15199","headword_ar":"رَادٌّ","root":"rd","body":[{"kind":"text","text":"sing. of ↓"},{"kind":"arabic","text_bw":"rududN","text_ar":"رُدُدٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) which signifies"},{"kind":"italic_en","text":"Unseemly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugly;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"having a quality that repels the eye;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"rad~apN","text_ar":"رَدَّةٌ"},{"kind":"text","text":";)] applied to men. (IAar, K, TA.) ―         -b2-  See also what next follows."}],"source_refs":["TA"]},{"entry_id":"n17032","headword_ar":"رَادَ","root":"rwd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaruwdu","text_ar":"يَرُودُ"},{"kind":"text","text":", (T, S, A,) inf. n."},{"kind":"arabic","text_bw":"rawadaAnN","text_ar":"رَوَدَانٌ"},{"kind":"text","text":"(A, TA) and"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a thing, S,)"},{"kind":"italic_en","text":"came and went;"},{"kind":"text","text":"(T, S, A, K;) ["},{"kind":"italic_en","text":"went to and fro;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was restless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsettled."},{"kind":"text","text":"(T, TA.) One says,"},{"kind":"arabic","text_bw":"maA liY A^araAka taruwdu muno*u Alyawomi","text_ar":"مَا لِى اَرَاكَ تَرُودُ مُنْذُ اليَوْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What aileth me that I see thee coming and going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going to and fro, during this day?"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"raAdato","text_ar":"رَادَتْ"},{"kind":"text","text":", (S, M, A, K,) aor."},{"kind":"arabic","text_bw":"taruwdu","text_ar":"تَرُودُ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"rawadaAnN","text_ar":"رَوَدَانٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruw^uwdN","text_ar":"رُوُودٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"went about to and from the tents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"houses, of her female neighbours."},{"kind":"text","text":"(S, M, A, K.) And"},{"kind":"arabic","text_bw":"rAdt","text_ar":"رادت"},{"kind":"arabic","text_bw":"AlA_ibilu","text_ar":"الاـِبِلُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taruwdu","text_ar":"تَرُودُ"},{"kind":"text","text":", (AHn, M,) inf. n."},{"kind":"arabic","text_bw":"riyaAdN","text_ar":"رِيَادٌ"},{"kind":"text","text":"(AHn, S, M, K) [and app."},{"kind":"arabic","text_bw":"rawadaAnN","text_ar":"رَوَدَانٌ"},{"kind":"text","text":"&c. as above],"},{"kind":"italic_en","text":"The camels went to and fro in the place of pasture."},{"kind":"text","text":"(AHn, S, M, K.) And"},{"kind":"arabic","text_bw":"rAd Aln~aEamu fiY AlmaroEiY","text_ar":"راد النَّعَمُ فِى المَرْعِى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ryaAdN","text_ar":"ريَادٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The cattle went to and fro in the place of pasture."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"rAdt Ald~awaAb~u","text_ar":"رادت الدَّوَابُّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rawadaAnN","text_ar":"رَوَدَانٌ"},{"kind":"text","text":"[and app."},{"kind":"arabic","text_bw":"riyaAdN","text_ar":"رِيَادٌ"},{"kind":"text","text":"also]; and ↓"},{"kind":"arabic","text_bw":"AstrAdt","text_ar":"استرادت","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The beasts pastured"},{"kind":"text","text":"["},{"kind":"italic_en","text":"going to and fro"},{"kind":"text","text":"]. (M.) And"},{"kind":"arabic","text_bw":"rAdt Alr~KyHu","text_ar":"رادت الرٍّيحُ"},{"kind":"text","text":", (T, M,) aor."},{"kind":"arabic","text_bw":"taruwdu","text_ar":"تَرُودُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"page_break","n":1184},{"kind":"arabic","text_bw":"rawadaAnN","text_ar":"رَوَدَانٌ"},{"kind":"text","text":"(T, TA) and"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruw^uwd","text_ar":"رُوُود"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The wind became in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of commotion:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"veered about."},{"kind":"text","text":"(M, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"rAd wisaAduhu","text_ar":"راد وِسَادُهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His pillow moved to and fro;"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, restless,"},{"kind":"text","text":"(S, A,)"},{"kind":"italic_en","text":"by reason of disease"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety:"},{"kind":"text","text":"(A:) [or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sleepless:"},{"kind":"text","text":"for] a poet uses the phrase"},{"kind":"arabic","text_bw":"raA*a wisaAduhaA","text_ar":"رَاذَ وِسَادُهَا"},{"kind":"text","text":"as expressive of an imprecation, mean ing (assumed tropical:)"},{"kind":"italic_en","text":"May she be sleepless, so that her pillow may not remain still."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"rAd xurotu Alqawomi","text_ar":"راد خُرْتُ القَوْمِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rAdt A^axoraAtuhumo","text_ar":"رادت اَخْرَاتُهُمْ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xurotN","text_ar":"خُرْتٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"rAd","text_ar":"راد"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaruwdu","text_ar":"يَرُودُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"riyaAdN","text_ar":"رِيَادٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"ArtAd","text_ar":"ارتاد","orth_type":"arrow"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"AirotiyaAdN","text_ar":"اِرْتِيَادٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AstrAd","text_ar":"استراد","orth_type":"arrow"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He sought, sought after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired, to find and take,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to get;"},{"kind":"text","text":"(Msb, K;) a thing. (Msb.) [It seems to imply the going to and fro in seeking.] You say,"},{"kind":"arabic","text_bw":"rAd","text_ar":"راد"},{"kind":"arabic","text_bw":"AlkalaA^a","text_ar":"الكَلَاَ"},{"kind":"text","text":", (S, A, Mgh, L,) and"},{"kind":"arabic","text_bw":"AlmaA='a","text_ar":"المَا=ءَ"},{"kind":"text","text":", (Mgh,) aor."},{"kind":"arabic","text_bw":"yaruwdu","text_ar":"يَرُودُ"},{"kind":"text","text":", (S, A, Mgh, L,) inf. n."},{"kind":"arabic","text_bw":"riyaAdN","text_ar":"رِيَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":": (S, L;) and ↓"},{"kind":"arabic","text_bw":"ArtAdhu","text_ar":"ارتادهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, Mgh, L;) [and ↓"},{"kind":"arabic","text_bw":"Astrdhu","text_ar":"استردهُ","orth_type":"arrow"},{"kind":"text","text":", as appears from what follows;] and simply"},{"kind":"arabic","text_bw":"rAd","text_ar":"راد"},{"kind":"text","text":"; (L;)"},{"kind":"italic_en","text":"He sought after herbage,"},{"kind":"text","text":"(S, Mgh, L,) and"},{"kind":"italic_en","text":"water."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"rAd A^aholahu kalaA^F","text_ar":"راد اَهْلَهُ كَلَاً"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"manozilFA","text_ar":"مَنْزِلًا"},{"kind":"text","text":", (M, L,) and"},{"kind":"arabic","text_bw":"rAd lahumo kalaA^F","text_ar":"راد لَهُمْ كَلَاً"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"manozilFA","text_ar":"مَنْزِلًا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ"},{"kind":"text","text":"(T, M, L) and"},{"kind":"arabic","text_bw":"riyaAdN","text_ar":"رِيَادٌ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"ArdtAd","text_ar":"اردتاد","orth_type":"arrow"},{"kind":"text","text":"; (T, M, L;) and ↓"},{"kind":"arabic","text_bw":"AstrAd","text_ar":"استراد","orth_type":"arrow"},{"kind":"text","text":"; (M, L;)"},{"kind":"italic_en","text":"He looked for,"},{"kind":"text","text":"(T,) and"},{"kind":"italic_en","text":"sought after, herbage,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a place in which to alight,"},{"kind":"text","text":"(T, M, L,)"},{"kind":"italic_en","text":"and chose the best"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that he could find"},{"kind":"text","text":"], (T,)"},{"kind":"italic_en","text":"for his family."},{"kind":"text","text":"(T, M, L.) And"},{"kind":"arabic","text_bw":"AlT~ayoru","text_ar":"الطَّيْرُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tasotariydu","text_ar":"تَسْتَرِيدُ","orth_type":"arrow"},{"kind":"italic_en","text":"The birds seek after their sustenance, going to and fro in search of it."},{"kind":"text","text":"(A.) [Hence,]"},{"kind":"arabic","text_bw":"libawolihi","text_ar":"لِبَوْلِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"ArtAd","text_ar":"ارتاد","orth_type":"arrow"},{"kind":"italic_en","text":"He sought a soft place,"},{"kind":"text","text":"(S, Mgh, L,) or"},{"kind":"italic_en","text":"a sloping place,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"for his urine."},{"kind":"text","text":"when he desired to void it, (S, Mgh, L,) lest it should return towards him, or sprinkle back upon him: (L:) from a trad. (S, L.) ―         -b2-"},{"kind":"arabic","text_bw":"rAd Ald~aAra","text_ar":"راد الدَّارَ"},{"kind":"text","text":", aor. as above,"},{"kind":"italic_en","text":"He questioned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interrogated,"},{"kind":"text","text":"[respecting a person beloved,]"},{"kind":"italic_en","text":"the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode."},{"kind":"text","text":"(M.) ―         -b3-"},{"kind":"arabic","text_bw":"rudotu Ald~awaAb~a","text_ar":"رُدْتُ الدَّوَابَّ"},{"kind":"italic_en","text":"I pastured the beasts;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^aradotuhaA","text_ar":"اَرَدْتُهَا","orth_type":"arrow"},{"kind":"text","text":". (M.)"}],"source_refs":["T","S","A","TA","K","M","AHn","Msb","Mgh","L"]},{"entry_id":"n17036","headword_ar":"رَادٌ","root":"rwd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raAy^idN","text_ar":"رَايِدٌ"},{"kind":"text","text":", with which it is syn. (S, M, K.)"},{"kind":"arabic","text_bw":"raAdapN","text_ar":"رَادَةٌ"},{"kind":"text","text":"[is its fem.: and] is a pl. of"},{"kind":"arabic","text_bw":"raAy^idN","text_ar":"رَايِدٌ"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"AimoraA^apN raAdapN","text_ar":"اِمْرَاَةٌ رَادَةٌ"},{"kind":"italic_en","text":"A woman who goes about to and from the tents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"houses, of her female neighbours;"},{"kind":"text","text":"(AZ, As, S, M, A, K;) as also"},{"kind":"arabic","text_bw":"raAdN","text_ar":"رَادٌ"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"rawaAdN","text_ar":"رَوَادٌ","orth_type":"arrow"},{"kind":"text","text":"(S M) and ↓"},{"kind":"arabic","text_bw":"raw^uwdN","text_ar":"رَوُودٌ","orth_type":"arrow"},{"kind":"text","text":"(Aboo-' Alee, M) and ↓"},{"kind":"arabic","text_bw":"ruwaAdapN","text_ar":"رُوَادَةٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"vumaAmap","text_ar":"ثُمَامَة"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"raAy^idapN","text_ar":"رَايِدَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say"},{"kind":"arabic","text_bw":"AimoraA^opN raA^odapN gayoru raAdapK","text_ar":"اِمْرَاْةٌ رَاْدَةٌ غَيْرُ رَادَةٍ"},{"kind":"italic_en","text":"A soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender, woman; not one that roves about:"},{"kind":"text","text":"in which the former"},{"kind":"arabic","text_bw":"rAdp","text_ar":"رادة"},{"kind":"text","text":"may be without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", and the latter must be so. (A and TA in art."},{"kind":"arabic","text_bw":"rA^d","text_ar":"راد"},{"kind":"text","text":".) [See"},{"kind":"arabic","text_bw":"ruw^odN","text_ar":"رُوْدٌ"},{"kind":"text","text":"; where it is stated that"},{"kind":"arabic","text_bw":"raAdN","text_ar":"رَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raAdapN","text_ar":"رَادَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"ruwdapN","text_ar":"رُودَةٌ","orth_type":"arrow"},{"kind":"text","text":", as epithets applied to a girl or woman, are syn., one with another, meaning"},{"kind":"italic_en","text":"Soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tender,"},{"kind":"text","text":"&c., like"},{"kind":"arabic","text_bw":"raA^odN","text_ar":"رَاْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raA^odapN","text_ar":"رَاْدَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruw^odapN","text_ar":"رُوْدَةٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"riyHN raAdapN","text_ar":"رِيحٌ رَادَةٌ"},{"kind":"italic_en","text":"A wind blowing violently to and fro:"},{"kind":"text","text":"(TA:) [and ↓"},{"kind":"arabic","text_bw":"riyHN raAy^idapN","text_ar":"رِيحٌ رَايِدَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; or"},{"kind":"italic_en","text":"wind in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of commotion.;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veering about:"},{"kind":"text","text":"see 1.] [And]"},{"kind":"italic_en","text":"A wind blowing gently;"},{"kind":"text","text":"(A;) and so ↓"},{"kind":"arabic","text_bw":"rawodN","text_ar":"رَوْدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"raAy^idapN","text_ar":"رَايِدَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"rawaAdN","text_ar":"رَوَادٌ","orth_type":"arrow"},{"kind":"text","text":". (TA. [See also art."},{"kind":"arabic","text_bw":"ryd","text_ar":"ريد"},{"kind":"text","text":".])"}],"source_refs":["TA","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%A7%D8%AF/","headword_ar":"راد","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=17337#629077","body_html":"راد<br>من (ر ا د) الرائد يتقدم القوم يبصر لهم الكلأ ومساقط الغيث، ورسول قومه."},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=17337#9c5455","body_html":"<span>[ر اد] غُصْنٌ رَؤُودٌ: وهو أَرْطَبُ ما يَكُونُ وأَرْخَصُهُ، وقد رَؤُدَ وتَرَأَّدَ. وقيلَ: تَرَؤُّدُه: تَفَيُّؤُه وتَذَبُّلُه. وتَرَاؤُدُهُ كَقَوِلْكَ تَراعُدُه: تَمَيُّلُه وتَمَيُّحُه يَميناً وشمالاً. والرَّأْدَةُ، والرّؤْدَةُ، والرَّءَودَةُ كُلُّه: السَّرِيَعةُ الشَّبابِ مع حُسْنٍ غِذاءٍ، وهِيَ الرُّؤْدُ أيضاً، والجمعُ: أَرْادٌ. والرِّئْدُ: فَرْخُ الشَّجَرَةِ، وقيلَ: هو ما لانَ من أَغْصانِهَا، والجمعُ: رِئْدانٌ. </span><span>ورِئْدُ الرَّجُلُ: تِربْهُ، وكَذلكَ الأُنْثَى، وأكثر ما يكُونُ في الإنَاثِ، قَالَ:</span><br><br><span>(قَالتْ سُلَيْمَى قَوْلَةً لريِدِهَا </span><span class=\"red\">...</span><span> )</span><br><br><span>أرادَ الهَمْزَ فخَفَّفَ، أو أَبْدَلَ طَلَباً للرِّدْفِ، والجمعُ: أَرْادٌ. والرَّأْدُ: رُوْنَقُ الضُّحى، وقيلَ: هو بَعْدَ انْبِساطِ الشَّمْسِ، وارِتْفَاعِ النَّهارِ، وقد تَراءَدَ، وتَرَأَدَ. الرَّاْدُ، والرُّؤدُ: أَصْلُ اللَّحْيِ، وقيلَ: أَصْلُ مَنْبِتِ الأَضْراسِ في اللَّحْيِ، وقِيلَ: الرَّأْدنِ: طَرَفا اللَّحْيَينِ الدَّقِيقانِ اللّذانِ [في] أَعْلاهُما، وهُما المُحَدَّدانِ الأَحْجَنانِ المُعَلَّقانِ في خُرْتَيْنِ دُونَ الأُذُنَيْنِ. وقِيلَ: طَرَفُ كُلِّ غُصْنٍ رُؤْدٌ، والجَمْعُ: أَرْآدٌ، وأَرائِدُ، وأَرائِدُ نادِرٌ، وليسَ بجَمْعِ جَمْعٍ؛ إذا لو كانَ ذِلكَ لقِيلَ: أَرائِيدُ، أَنْشَدَ ثَعْلَبٌ:</span><br><br><span>(تَرَى شُؤُونَ رَأْسِه العَوارِداَ </span><span class=\"red\">...</span><span> )</span><br><br><span>(الخطْمَ واللَّحْيَيْنِ والأَرائِداَ </span><span class=\"red\">...</span><span> )</span><br><br><span>والرُّؤْدُ: التُّؤَدَةُ، قالَ:</span><br><br><span>(كأَنَّه ثَمَل يَمِشيِ على رُودِ </span><span class=\"red\">...</span><span> )</span><br><br><span>احْتاجَ إِلى الرِّدْفِ فخَفَّفَ هَمْزَةَ الرُّؤْدِ، ومَنْ جَعَلَه تكبِيرَ رُوَيْدٍ لم يَجْعَلْ أَصْلَه الهَمْزَِ، وروَاهُ أبو عُبَيْدٍ:</span><br><br><span>(كأَنَّها مثلُ من يَمْشِي على رُودِ </span><span class=\"red\">...</span><span> )</span><br><br><span>فَقَلب ((ثَمِلٌ)) وغَيَّر بِناءهَ، وهو خَطَأٌ. وتَرَأَدَ الرَّجُلُ: قامَ فأَخَذَتْهُ رَعْدَةٌ في عِظَامِه. وتَرَأَدَتِ الحَيَّةُ: اهْتَزَّتْ في انْسِيابِها. وتَرَأَدَ الشَّيْءُ: الَتَوَى فذَهَبَ وجاءَ. </span>"}]}}