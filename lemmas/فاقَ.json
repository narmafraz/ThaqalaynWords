references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n34847","n34983"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to exceed, to surpass, to go over, to go beyond","examples":[{"text":"فَاقَ أَصْدِقَاءَهُ شَجَاعَةً.","english":"He surpassed his friends in courage."}]},{"pos":"verb","gloss":"to die (together with نَفْسَهُ (nafsahu))"},{"pos":"verb","gloss":"to have hiccup"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34847","headword_ar":"فَاقٌ","root":"fwq","body":[{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"large bowl such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"jafonap","text_ar":"جَفْنَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"filled with food."},{"kind":"text","text":"(Lth, T, O, K.)       -A2-  And"},{"kind":"italic_en","text":"Cooked olive-oil."},{"kind":"text","text":"(O, K, TA.) So in the saying of Shemmákh, (O, TA, *) describing the hair of a woman, (TA,)"},{"kind":"quote","text":"qaAmato turiyka A^aviyva Aln~aboti munosadilFA\n                      \n                     \n                        mivola AlA^asaAwidi qado mus~iHona biAlqaAfi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She stood showing to thee"},{"kind":"text","text":"hair"},{"kind":"italic_en","text":"abundant and luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant and long, in respect of growth, let down, like the black serpents that have been anointed with cooked olive-oil"},{"kind":"text","text":"]: or, as some say, meaning"},{"kind":"arabic","text_bw":"AlA^anofaAq","text_ar":"الاَنْفَاق"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"fresh olive-oil"},{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"A_inofaAq","text_ar":"اـِنْفَاق"},{"kind":"text","text":", a Pers. word signifying “ olive-oil ”]: or, as AA relates it, the poet said,"},{"kind":"arabic","text_bw":"qado $ud~ixona biAlfaAqi","text_ar":"قَدْ شُدِّخْنَ بِالفَاقِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that have been crushed in the"},{"kind":"arabic","text_bw":"fAq","text_ar":"فاق"},{"kind":"text","text":"]; and accord. to him the last word has the meaning here next following. (O, TA.)       -A3-  And The"},{"kind":"italic_en","text":"desert;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaHoraA='u","text_ar":"صَحْرَا=ءُ"},{"kind":"text","text":": (O, K, TA:) so says AA: and on one occasion he says that"},{"kind":"arabic","text_bw":"AlfAq","text_ar":"الفاق"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"a certain land:"},{"kind":"text","text":"(O: a meaning also mentioned in the K:) or"},{"kind":"italic_en","text":"a certain wide land."},{"kind":"text","text":"(TA.)       -A4-  It is also expl. as signifying"},{"kind":"arabic","text_bw":"baAn","text_ar":"بَان"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Oil of ben"},{"kind":"text","text":"]: and also"},{"kind":"italic_en","text":"A comb:"},{"kind":"text","text":"on the authority of Th: and it may have either of these meanings in the verse cited above. (TA.)       -A5-  And accord. to the K, it signifies"},{"kind":"italic_en","text":"Tall, and incongruous in make;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"fuwqN","text_ar":"فُوقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fuwqapN","text_ar":"فُوقَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fiyqN","text_ar":"فِيقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fuwaAqN","text_ar":"فُوَاقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"fuyaAqN","text_ar":"فُيَاقٌ","orth_type":"arrow"},{"kind":"text","text":": but these words are all correctly, in this [or a similar] sense with two káfs. (TA.)       -A6-  Also, accord. to the K,"},{"kind":"italic_en","text":"A certain aquatic bird, long in the neck:"},{"kind":"text","text":"but this, likewise, is correctly with two káfs. (TA.)"}],"source_refs":["TA","O","K"]},{"entry_id":"n34983","headword_ar":"فَاقَ","root":"fyq","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafiyqu","text_ar":"يَفِيقُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"fAq binafosihi","text_ar":"فاق بِنَفْسِهِ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"fwq","text_ar":"فوق"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%A7%D9%82/","headword_ar":"فَاقّ","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=104020#9c9bae","body_html":"فَاقّ<br>من (ف ق ق) الشيء المنفرج، وفاتح الشيء، والفاصل بين الأشياء."}]}}