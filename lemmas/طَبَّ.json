:"s"},{"role":"present_3fs","form":"تَطْبُب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطْبِب","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطُبّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطُبّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطِبّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطِبّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطُبّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطُبّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِبّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطِبّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطُبُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطُبُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِبُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطِبُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْبُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَطْبِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَطُبّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطُبّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطِبّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَطِبّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طَبَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَبَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":11,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n26261"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D8%A8%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of طَبَّ (ṭabba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"medicine (field of study)"},{"pos":"verb","gloss":"to treat medically"},{"pos":"noun","gloss":"verbal noun of طَبَّ (ṭabba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of طَبَّ (ṭabba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/tˤibː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26261","headword_ar":"طَبَّ","root":"Tb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (O, Msb, K, TA,) agreeably with analogy in the case of a trans. reduplicative verb [like this], (TA,) and"},{"kind":"text","text":", (K, TA,) which is irregular, (TA,) inf. n."},{"kind":"arabic","text_bw":"Tab~N","text_ar":"طَبٌّ"},{"kind":"text","text":"(O, * Msb, K, * TA) [and app."},{"kind":"arabic","text_bw":"Tib~N","text_ar":"طِبٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tub~N","text_ar":"طُبٌّ"},{"kind":"text","text":"also accord. to the O and K, but, accord. to the Msb,"},{"kind":"arabic","text_bw":"Tib~N","text_ar":"طِبٌّ"},{"kind":"text","text":"is the subst. from this verb, and app."},{"kind":"arabic","text_bw":"Tub~N","text_ar":"طُبٌّ"},{"kind":"text","text":"is likewise a simple subst.],"},{"kind":"italic_en","text":"He treated medically, therapeutically,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"curatively,"},{"kind":"text","text":"(O, * Msb, K, *) another person (O, Msb) [or the body, and in like manner the soul: see"},{"kind":"arabic","text_bw":"Tib~N","text_ar":"طِبٌّ"},{"kind":"text","text":", below]. ―         -b2-  And"},{"kind":"arabic","text_bw":"Tabyota","text_ar":"طَبيْتَ"},{"kind":"text","text":", with kesr, (S, O, K,) and"},{"kind":"arabic","text_bw":"Tababota","text_ar":"طَبَبْتَ"},{"kind":"text","text":", with fet-h, (O, K,) [third pers. of each"},{"kind":"arabic","text_bw":"Tab~a","text_ar":"طَبَّ"},{"kind":"text","text":", and, accord. to analogy, the aor. of the former is"},{"kind":"text","text":", and of the latter"},{"kind":"text","text":", but from what follows it seems probable that one says also"},{"kind":"arabic","text_bw":"Tabubota","text_ar":"طَبُبْتَ"},{"kind":"text","text":"in the same sense, aor."},{"kind":"text","text":", unless"},{"kind":"arabic","text_bw":"Tababota","text_ar":"طَبَبْتَ"},{"kind":"text","text":"have"},{"kind":"arabic","text_bw":"taTut~u","text_ar":"تَطُتُّ"},{"kind":"text","text":"as an irreg. aor.,]"},{"kind":"italic_en","text":"Thou wast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becamest a"},{"kind":"arabic","text_bw":"Tabiyt","text_ar":"طَبِيت"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"physician"},{"kind":"text","text":"], not having been such. (S, O, K.) One says,"},{"kind":"arabic","text_bw":"A_ino kunota *aA Tub~K faTub~a liEayonayoka","text_ar":"اـِنْ كُنْتَ ذَا طُبٍّ فَطُبَّ لِعَيْنَيْكَ"},{"kind":"text","text":", (S, O, and so in copies of the K,) or"},{"kind":"arabic","text_bw":"liEayonika","text_ar":"لِعَيْنِكَ"},{"kind":"text","text":", (so in other copies of the K,) or"},{"kind":"arabic","text_bw":"linafosika","text_ar":"لِنَفْسِكَ"},{"kind":"text","text":", (ISk, TA,) and"},{"kind":"arabic","text_bw":"*A Tab~K","text_ar":"ذا طَبٍّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"*A Tib~K","text_ar":"ذا طِبٍّ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"faTab~a","text_ar":"فَطَبَّ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"faTib~a","text_ar":"فَطِبَّ"},{"kind":"text","text":"; (K;) [i. e."},{"kind":"italic_en","text":"If thou be a possessor of the art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science, of physic, be a physician to thine eyes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thine eye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thyself;"},{"kind":"text","text":"] meaning, begin by rectifying thyself. (ISk, TA. [See also Freytag's Arab. Prov. ii. 902.]) ―         -b3-  And [hence]"},{"kind":"arabic","text_bw":"Tab~a","text_ar":"طَبَّ"},{"kind":"text","text":"signifies also (assumed tropical:)"},{"kind":"italic_en","text":"He acted with skill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expertness:"},{"kind":"text","text":"[and in this sense likewise the second pers. is probably"},{"kind":"arabic","text_bw":"Tabibota","text_ar":"طَبِبْتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tababota","text_ar":"طَبَبْتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tabubota","text_ar":"طَبُبْتَ"},{"kind":"text","text":", of which last the inf. n. is app."},{"kind":"arabic","text_bw":"TabaAbapN","text_ar":"طَبَابَةٌ"},{"kind":"text","text":", occurring in one of the phrases here following:] so in the saying,"},{"kind":"arabic","text_bw":"AiSonaEohu SanoEapa mano Tab~a limano Hab~a","text_ar":"اِصْنَعْهُ صَنْعَةَ مَنْ طَبَّ لِمَنْ حَبَّ"},{"kind":"text","text":"i. e. (assumed tropical:)"},{"kind":"italic_en","text":"Do thou it in the manner of him who acts with skill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expertness, for him whom he loves:"},{"kind":"text","text":"a prov., relating to the accomplishing an object of want skilfully and well. (El-Ahmar, TA. [See also Freytag's Arab. Prov. i. 717.]) One says also,"},{"kind":"arabic","text_bw":"AiEomalo fiY h`*aA Eamala mano Tab~a limano Hab~a","text_ar":"اِعْمَلْ فِى هٰذَا عَمَلَ مَنْ طَبَّ لِمَنْ حَبَّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Do thou, in this, the deed of him who acts with skill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expertness, for him whom he loves"},{"kind":"text","text":"]. (M, Msb, * TA.) And"},{"kind":"arabic","text_bw":"mano Hab~a Tab~a","text_ar":"مَنْ حَبَّ طَبَّ"},{"kind":"text","text":", (Meyd,) or"},{"kind":"arabic","text_bw":"mano A^aHab~a","text_ar":"مَنْ اَحَبَّ"},{"kind":"arabic","text_bw":"Tab~a","text_ar":"طَبَّ"},{"kind":"text","text":", (K,) (assumed tropical:)"},{"kind":"italic_en","text":"He who loves is skilful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligent,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"exercises art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ingenuity,"},{"kind":"text","text":"for him whom he loves: (Meyd:) or (assumed tropical:)"},{"kind":"italic_en","text":"he who loves executes affairs with deliberateness and gentleness."},{"kind":"text","text":"(K.) [That one says"},{"kind":"arabic","text_bw":"Tabubota","text_ar":"طَبُبْتَ"},{"kind":"text","text":", as well as"},{"kind":"arabic","text_bw":"Tabibota","text_ar":"طَبِبْتَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tababota","text_ar":"طَبَبْتَ"},{"kind":"text","text":", seems to be indicated by the fact that ↓"},{"kind":"arabic","text_bw":"TabaAbapN","text_ar":"طَبَابَةٌ","orth_type":"arrow"},{"kind":"text","text":", as an inf. n., is thus written, in a copy of the KL in my possession, and expl. as meaning The"},{"kind":"italic_en","text":"medical art:"},{"kind":"text","text":"Golius, however, appears to have found it written, in a copy of the same work, ↓"},{"kind":"arabic","text_bw":"TibaAbapN","text_ar":"طِبَابَةٌ","orth_type":"arrow"},{"kind":"text","text":", which is agreeable with analogy as inf. n. of a verb of the measure"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":"significant of an art, and is probably correct: Freytag mentions the pl."},{"kind":"arabic","text_bw":"TabaAy^ibu","text_ar":"طَبَايِبُ"},{"kind":"text","text":"as signifying medical"},{"kind":"page_break","n":1820},{"kind":"text","text":"arts, on the authority of the Deewán of the Hudhalees.] ―         -b4-"},{"kind":"arabic","text_bw":"Tab~ahu","text_ar":"طَبَّهُ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He enchanted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fascinated him:"},{"kind":"text","text":"(O:) and"},{"kind":"arabic","text_bw":"Tub~a","text_ar":"طُبَّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, S, A)"},{"kind":"italic_en","text":"was enchanted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fascinated."},{"kind":"text","text":"(S, A, O. [See also"},{"kind":"arabic","text_bw":"Tib~N","text_ar":"طِبٌّ"},{"kind":"text","text":", below.]) ―         -b5-"},{"kind":"arabic","text_bw":"Tab~a Als~iqaA='a","text_ar":"طَبَّ السِّقَا=ءَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"Tab~N","text_ar":"طَبٌّ"},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"Tb~bhu","text_ar":"طبّبهُ","orth_type":"arrow"},{"kind":"text","text":", with teshdeed to denote muchness, (S, TA,) inf. n."},{"kind":"arabic","text_bw":"tTobiybN","text_ar":"تطْبِيبٌ"},{"kind":"text","text":"; (K, TA;)"},{"kind":"italic_en","text":"He covered the seams of the water-skin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"milk-skin, with a"},{"kind":"arabic","text_bw":"TibaAbap","text_ar":"طِبَابَة"},{"kind":"text","text":"[q. v.]: (S, K, * TA:) and"},{"kind":"arabic","text_bw":"Tab~a Alxuraza","text_ar":"طَبَّ الخُرَزَ"},{"kind":"italic_en","text":"he covered the seams with a"},{"kind":"arabic","text_bw":"TibaAbap","text_ar":"طِبَابَة"},{"kind":"text","text":": (TA) [and]"},{"kind":"arabic","text_bw":"AlmazaAdap","text_ar":"المَزَادَة"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Tab~abati","text_ar":"طَبَّبَتِ","orth_type":"arrow"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a girl, or young woman,)"},{"kind":"italic_en","text":"put"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sewed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a piece of skin called"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"TibaAbN","text_ar":"طِبَابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"TibaAbapN","text_ar":"طِبَابَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"upon the place of junction"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of each"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the two extremities of the loop-shaped handles of the"},{"kind":"arabic","text_bw":"mzAdp","text_ar":"مزادة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leathern water-bag"},{"kind":"text","text":"]; as though she rectified the"},{"kind":"arabic","text_bw":"mzAdp","text_ar":"مزادة"},{"kind":"text","text":"thereby. (A.)"}],"source_refs":["O","Msb","K","TA","S","ISk","Meyd"]}]},"classical_definitions":null}