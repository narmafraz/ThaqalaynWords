"num":"p"},{"role":"present_2mp","form":"تَأْنَفُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَأْنَفْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَأْنَف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَأْنَف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَأْنَفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَأْنَفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْنَفانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْنَفا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْنَفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْنَفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْنَفْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَأْنَف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَنِفْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَنِفْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":true,"lemma_key":"أَنِفَ","root":"أنف","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["","n1361","n1362","n1363","n1364"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%86%D9%90%D9%81%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1361","headword_ar":"اَنْفٌ","root":"Anf","body":[{"kind":"text","text":"a word of well-known meaning; (Lth, T, K;) The"},{"kind":"italic_en","text":"nose;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maEoTisN","text_ar":"مَعْطِسٌ"},{"kind":"text","text":"; (Msb;) the"},{"kind":"italic_en","text":"aggregate composed of the two nostrils and the septum and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"bone called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qaSabap","text_ar":"قَصَبَة"},{"kind":"text","text":", which is the hard part of the"},{"kind":"arabic","text_bw":"Anf","text_ar":"انف"},{"kind":"text","text":"; (MF;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"manoxirN","text_ar":"مَنْخِرٌ"},{"kind":"text","text":"[which is evidently an explanation by a synecdoche, as this word properly signifies"},{"kind":"italic_en","text":"nostril"},{"kind":"text","text":"]: (M:) it pertains to man and to others: (S:) ↓"},{"kind":"arabic","text_bw":"A^unofN","text_ar":"اُنْفٌ","orth_type":"arrow"},{"kind":"text","text":"is a dial. var. of the same; (MF, TA;) and so is ↓"},{"kind":"arabic","text_bw":"A_inofN","text_ar":"اـِنْفٌ","orth_type":"arrow"},{"kind":"text","text":", which is a form used by the vulgar peculiarly: (TA:) the pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A=nufN","text_ar":"ا=نُفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=naAfN","text_ar":"ا=نَافٌ"},{"kind":"text","text":"(S, M, Msb, K) and [of mult.]"},{"kind":"arabic","text_bw":"A^unuwfN","text_ar":"اُنُوفٌ"},{"kind":"text","text":". (T, S, M, Msb, K.) The dual is applied to The"},{"kind":"italic_en","text":"two nostrils;"},{"kind":"text","text":"as in the saying of Muzáhim El-'Okeylee,"},{"kind":"arabic","text_bw":"yasuwfu biA^anofiyohi","text_ar":"يَسُوفُ بِاَنْفِيْهِ"},{"kind":"arabic","text_bw":"Aln~iqaAEa","text_ar":"النِّقَاعَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He scents with his two nostrils the dust"},{"kind":"text","text":"]. (TA.) You say also,"},{"kind":"arabic","text_bw":"huwa yatatab~aEu A^anofahu","text_ar":"هُوَ يَتَتَبَّعُ اَنْفَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He scents,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sniffs, the odour, and follows it."},{"kind":"text","text":"(T, [in which, however, I find"},{"kind":"arabic","text_bw":"yatobaEu","text_ar":"يَتْبَعُ"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"yttb~E","text_ar":"يتتبّع"},{"kind":"text","text":"] O, L, K, TA.) And, of a she-camel,"},{"kind":"arabic","text_bw":"taroA^amu biA^anofihiA","text_ar":"تَرْاَمُ بِاَنْفِهِا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"She makes a show of affection with her nose, by smelling her young one;"},{"kind":"text","text":"not having true love]. (S, M, K, voce"},{"kind":"arabic","text_bw":"mu*aAy^irN","text_ar":"مُذَايِرٌ"},{"kind":"text","text":"; &c.: see also"},{"kind":"arabic","text_bw":"muEaAriDN","text_ar":"مُعَارِضٌ"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"maAta Hatofa A^anofihi","text_ar":"مَاتَ حَتْفَ اَنْفِهِ"},{"kind":"text","text":"(S, K, &c., in art."},{"kind":"arabic","text_bw":"Htf","text_ar":"حتف"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"Htf A^anofiyohi","text_ar":"حتف اَنْفِيْهِ"},{"kind":"text","text":", (K ibid.,) (assumed tropical:)"},{"kind":"italic_en","text":"He died"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a natural death,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"on his bed,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"without being slain or beaten"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"or drowned or burned."},{"kind":"text","text":"(K. [See art."},{"kind":"arabic","text_bw":"Htf","text_ar":"حتف"},{"kind":"text","text":"]) And"},{"kind":"arabic","text_bw":"HamiYa A^anofuhu","text_ar":"حَمِىَ اَنْفُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became vehemently angry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enraged;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"warima A^anofuhu","text_ar":"وَرِمَ اَنْفُهُ"},{"kind":"text","text":". (IAth. [See also art."},{"kind":"arabic","text_bw":"Hmy","text_ar":"حمي"},{"kind":"text","text":"]) And"},{"kind":"arabic","text_bw":"rajulN HamiY~u","text_ar":"رَجُلٌ حَمِىُّ"},{"kind":"arabic","text_bw":"AlA^anofi","text_ar":"الاَنْفِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A disdainful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scornful, man; who disdains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scorns, being injured."},{"kind":"text","text":"(T, K, TA. [See, again, art."},{"kind":"arabic","text_bw":"Hmy","text_ar":"حمي"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"samiY~u AlA^anofi","text_ar":"سَمِىُّ الاَنْفِ"},{"kind":"text","text":"(assumed tropical:)  [lit."},{"kind":"italic_en","text":"Highnosed,"},{"kind":"text","text":"signifies the same;]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^anofaAnu","text_ar":"اَنْفَانُ"},{"kind":"text","text":". (T, K.) And"},{"kind":"arabic","text_bw":"A^anofN fiy Als~amaA='i waA@sotN fiY AlmaA='i","text_ar":"اَنْفٌ فِي السَّمَا=ءِ وَا@سْتٌ فِى المَا=ءِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A nose in the sky and a rump in the water"},{"kind":"text","text":"]; a prov., applied to him who magnifies himself in words and is little in actions. (Har p. 641.) And"},{"kind":"arabic","text_bw":"HaEala","text_ar":"حَعَلَ"},{"kind":"arabic","text_bw":"A^anofahu fiY qafaAhu","text_ar":"اَنْفَهُ فِى قَفَاهُ"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"He put his nose in the back of his neck"},{"kind":"text","text":"]; meaning"},{"kind":"italic_en","text":"he turned away from the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what was right, and betook himself to what was false,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vain:"},{"kind":"text","text":"(K, TA:) expressing the utmost degree of turning away, or turning the head, from a thing. (TA.) And"},{"kind":"arabic","text_bw":"A^aDaAEa maTolaba","text_ar":"اَضَاعَ مَطْلَبَ"},{"kind":"arabic","text_bw":"A^anofihi","text_ar":"اَنْفِهِ"},{"kind":"text","text":", (M, K,) and"},{"kind":"arabic","text_bw":"muwoDiEa A^anofihi","text_ar":"مُوْضِعَ اَنْفِهِ"},{"kind":"text","text":", (M,) (assumed tropical:)  ["},{"kind":"italic_en","text":"He neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left unprotected,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the womb from which he had come forth:"},{"kind":"text","text":"(Th, M:) or"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"faroj","text_ar":"فَرْج"},{"kind":"italic_en","text":"of his mother."},{"kind":"text","text":"(Ibn-'Abbád, K.) And"},{"kind":"arabic","text_bw":"huwa AlfaHolu laA yuqoraEu","text_ar":"هُوَ الفَحْلُ لَا يُقْرَعُ"},{"kind":"arabic","text_bw":"A^anofuhu","text_ar":"اَنْفُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"laA yuqodaEu","text_ar":"لَا يُقْدَعُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He is the speaker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"orator, who is not to be rebutted."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"AlA^asdi A^anofu","text_ar":"الاَسدِ اَنْفُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The nose of the lion"},{"kind":"text","text":"] is"},{"kind":"italic_en","text":"the asterism called"},{"kind":"arabic","text_bw":"Aln~avorapu","text_ar":"النَّثْرَةُ"},{"kind":"text","text":", q. v. (Kzw in his Description of the Mansions of the Moon.) ―         -b2-  (assumed tropical:)  ["},{"kind":"italic_en","text":"A prominent part"},{"kind":"text","text":"of anything, as being likened to a nose;] the"},{"kind":"italic_en","text":"extremity"},{"kind":"text","text":"of anything. (M.) [Thus,]"},{"kind":"arabic","text_bw":"A^anofu jabalK","text_ar":"اَنْفُ جَبَلٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A prominence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"projecting part, of a mountain."},{"kind":"text","text":"(T, S, M, Msb, TA.)"},{"kind":"arabic","text_bw":"A^anofu Aln~aAbi","text_ar":"اَنْفُ النَّابِ"},{"kind":"text","text":", (S, M. K, TA,) in [some of] the copies of the K erroneously,"},{"kind":"arabic","text_bw":"AlbaAbi","text_ar":"البَابِ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The extremity,"},{"kind":"text","text":"(S, M, K, TA,) or"},{"kind":"italic_en","text":"edge,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"of the canine tooth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tush, when it comes forth."},{"kind":"text","text":"(S, M, K, TA.)"},{"kind":"arabic","text_bw":"A^anofu","text_ar":"اَنْفُ"},{"kind":"arabic","text_bw":"xuf~i AlbaEiyri","text_ar":"خُفِّ البَعِيرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The extremity of the"},{"kind":"arabic","text_bw":"manosim","text_ar":"مَنْسِم"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"toe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"each of the two nails of the foot,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the camel."},{"kind":"text","text":"(T, K.)"},{"kind":"arabic","text_bw":"A^anofu All~iHoyapi","text_ar":"اَنْفُ اللِّحْيَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The fore part,"},{"kind":"text","text":"(M, TA,) or"},{"kind":"italic_en","text":"side,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"of the beard."},{"kind":"text","text":"(M, K, TA.)"},{"kind":"arabic","text_bw":"A^anofu","text_ar":"اَنْفُ"},{"kind":"arabic","text_bw":"Aln~aEoli","text_ar":"النَّعْلِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The toe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foremost extremity, of the sandal"},{"kind":"text","text":"[also called its"},{"kind":"arabic","text_bw":"A^asalap","text_ar":"اَسَلَة"},{"kind":"text","text":"and its"},{"kind":"arabic","text_bw":"*unaAbap","text_ar":"ذُنَابَة"},{"kind":"text","text":"]. (M.)"},{"kind":"arabic","text_bw":"A^anofaA Alqawosi","text_ar":"اَنْفَا القَوْسِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The two extremities which are in the inner sides of the two curved ends of the bow."},{"kind":"text","text":"(M.) ―         -b3-  (assumed tropical:)  The"},{"kind":"italic_en","text":"first,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"first part,"},{"kind":"text","text":"of anything; (S, M, K;) relating also to times; (M;) as also ↓"},{"kind":"arabic","text_bw":"musotaA^onafN","text_ar":"مُسْتَاْنَفٌ","orth_type":"arrow"},{"kind":"text","text":"(M, TA.) Thus,"},{"kind":"arabic","text_bw":"A^anofu AlmaroEaY","text_ar":"اَنْفُ المَرْعَى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The first of the herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasture."},{"kind":"text","text":"(S, * M.)"},{"kind":"arabic","text_bw":"A^anofu","text_ar":"اَنْفُ"},{"kind":"arabic","text_bw":"AlmaTari","text_ar":"المَطَرِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The first vegetation produced by the rain."},{"kind":"text","text":"(T, K.)"},{"kind":"arabic","text_bw":"jaA='a fiY A^anofi Alxayoli","text_ar":"جَا=ءَ فِى اَنْفِ الخَيْلِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He came among the first of the horses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"horsemen"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"saAra","text_ar":"سَارَ"},{"kind":"arabic","text_bw":"fiY A^anofi Aln~ahaAri","text_ar":"فِى اَنْفِ النَّهَارِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He journeyed in the first part of the day"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"h`*aA A^anofu Eamali fulaAnK","text_ar":"هٰذَا اَنْفُ عَمَلِ فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"This is the first of the things which such a one has begun to do."},{"kind":"text","text":"(T, TA.)"},{"kind":"arabic","text_bw":"A^anofu Al$~ad~i","text_ar":"اَنْفُ الشَّدِّ"},{"kind":"text","text":", (T, S, M,) and"},{"kind":"arabic","text_bw":"AlEadowi","text_ar":"العَدْوِ"},{"kind":"text","text":", (M,) (assumed tropical:)"},{"kind":"italic_en","text":"The first of the run,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"running:"},{"kind":"text","text":"(T:)"},{"kind":"italic_en","text":"the most vehement thereof."},{"kind":"text","text":"(T, S, M, K. *)"},{"kind":"arabic","text_bw":"A^anofu Albarodi","text_ar":"اَنْفُ البَرْدِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The first of the cold:"},{"kind":"text","text":"(T:)"},{"kind":"italic_en","text":"the most vehement thereof;"},{"kind":"text","text":"(T, S, M;) so says Yaákoob. (S.) ―         -b4-  (tropical:)"},{"kind":"italic_en","text":"A lord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief."},{"kind":"text","text":"(IAar, T, K.) You say,"},{"kind":"arabic","text_bw":"huwa A^anofu qawomihi","text_ar":"هُوَ اَنْفُ قَوْمِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is the lord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, of his people."},{"kind":"text","text":"(TA.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"A piece broken off"},{"kind":"text","text":"of a cake of bread. (K, TA.) ―         -b6-  (assumed tropical:)"},{"kind":"italic_en","text":"A part"},{"kind":"text","text":"of ground, or land,"},{"kind":"italic_en","text":"that is hard, and lying open, exposed to the sun."},{"kind":"text","text":"(IF, K.)"}],"source_refs":["M","S","TA","Msb","K","Th","T"]},{"entry_id":"n1362","headword_ar":"اُنْفٌ","root":"Anf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^anofN","text_ar":"اَنْفٌ"},{"kind":"text","text":", first sentence:       -A2-  and see"},{"kind":"arabic","text_bw":"A^unufN","text_ar":"اُنُفٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1363","headword_ar":"اـِنْفٌ","root":"Anf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^anofN","text_ar":"اَنْفٌ"},{"kind":"text","text":", first sentence."}],"source_refs":[]},{"entry_id":"n1364","headword_ar":"اَنِفٌ","root":"Anf","body":[{"kind":"text","text":"A camel"},{"kind":"italic_en","text":"having a complaint of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffering pain in, his nose, from the"},{"kind":"arabic","text_bw":"burap","text_ar":"بُرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"nose-ring"},{"kind":"text","text":"]: (ISk, S, M, K:) or"},{"kind":"italic_en","text":"wounded by the nose-rein, whether it be with a"},{"kind":"arabic","text_bw":"xi$aA$","text_ar":"خِشَاش"},{"kind":"italic_en","text":"or"},{"kind":"arabic","text_bw":"burap","text_ar":"بُرَة"},{"kind":"text","text":"(A 'Obeyd, T, M)"},{"kind":"italic_en","text":"or"},{"kind":"arabic","text_bw":"xizaAmap","text_ar":"خِزَامَة"},{"kind":"text","text":"[all of which are different kinds of nose-rings]. (A' Obeyd, T.) And consequently,"},{"kind":"italic_en","text":"Submissive, and tractable:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"submissive and obedient, that dislikes chiding and beating, and goes as he is able to do spontaneously and easily:"},{"kind":"text","text":"(Aboo-Sa'eed, TA:) and ↓"},{"kind":"arabic","text_bw":"A=nifN","text_ar":"ا=نِفٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (A 'Obeyd, M, K;) but the former is the more correct and the more chaste: (Sgh, K:) by rule, it should be"},{"kind":"arabic","text_bw":"maA^onuwfN","text_ar":"مَاْنُوفٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"maSoduwrN","text_ar":"مَصْدُورٌ"},{"kind":"text","text":", (T, S, M,) and"},{"kind":"arabic","text_bw":"maboTuwnN","text_ar":"مَبْطُونٌ"},{"kind":"text","text":". (T, S.) To such a camel, the believer is likened in a trad.; (T, S, M;) because he ceases not to complain, or suffer pain; (M;) or because he does not require to be chidden nor to be punished, but endures and performs what is incumbent on him. (Aboo-Sa'eed, TA.) ―         -b2-"},{"kind":"italic_en","text":"Disdaining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disdainful; scorning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scornful; i. q."},{"kind":"arabic","text_bw":"HamiY~u AlA^anofi","text_ar":"حَمِىُّ الاَنْفِ"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"A^anofaAnu","text_ar":"اَنْفَانُ","orth_type":"arrow"},{"kind":"text","text":"[signifies the same;]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"samiY~u AlA^anofi","text_ar":"سَمِىُّ الاَنْفِ"},{"kind":"text","text":". (T, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"A=nifN","text_ar":"ا=نِفٌ"},{"kind":"text","text":"."}],"source_refs":["ISk","S","M","K","TA","Sgh","T"]}]}}