":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُدَمِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُدَمِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُدَمِّر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُدَمِّر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُدَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُدَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُدَمِّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُدَمِّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُدَمِّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُدَمِّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُدَمِّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُدَمِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُدَمِّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"دَمَّرْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دَمَّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":true,"lemma_key":"دَمَّرَ","root":"دمر","pos":"V","occurrence_count":8},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n13071","n13074"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%85%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to destroy","examples":[{"text":"فَلَمَّا رَأَوْهُ عَارِضًا مُسْتَقْبِلَ أَوْدِيَتِهِمْ قَالُوا هٰذَا عَارِضٌ مُمْطِرُنَا بَلْ هُوَ مَا ٱسْتَعْجَلْتُم بِهِ رِيحٌ فِيهَا عَذَابٌ أَلِيمٌ\n تُدَمِّرُ كُلَّ شَيْءٍ بِأَمْرِ رَبِّهَا فَأَصْبَحُوا لَا يُرَى إِلَّا مَسَاكِنُهُمْ كَذٰلِكَ نَجْزِي الْقَوْمَ الْمُجْرِمِينَ","english":"And when they saw it as a cloud approaching their valleys, they said, \"This is a cloud bringing us rain!\" Rather, it is that for which you were impatient: a wind, within it a painful punishment,\n destroying everything by command of its Lord. And they became so that nothing was seen except their dwellings. Thus do We recompense the criminal people."}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13071","headword_ar":"دَمَرَ","root":"dmr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (T, M, A, Msb, &c.,) inf. n."},{"kind":"arabic","text_bw":"damaArN","text_ar":"دَمَارٌ"},{"kind":"text","text":"(T, M, MF, TA) and"},{"kind":"arabic","text_bw":"damaArapN","text_ar":"دَمَارَةٌ"},{"kind":"text","text":"(MF, TA) and"},{"kind":"arabic","text_bw":"dumuwrN","text_ar":"دُمُورٌ"},{"kind":"text","text":", (MF,) or"},{"kind":"arabic","text_bw":"damaArN","text_ar":"دَمَارٌ"},{"kind":"text","text":"is a simple subst., (Msb,) and"},{"kind":"arabic","text_bw":"dumuwrN","text_ar":"دُمُورٌ"},{"kind":"text","text":"is an inf. n. of"},{"kind":"arabic","text_bw":"damara","text_ar":"دَمَرَ"},{"kind":"text","text":"in a trans. sense, (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a people, T, M, A, or a thing, Msb)"},{"kind":"italic_en","text":"perished:"},{"kind":"text","text":"(T, M, A, Msb, TA:) or"},{"kind":"italic_en","text":"perished utterly."},{"kind":"text","text":"(TA.)       -A2-  See also 2.       -A3-"},{"kind":"arabic","text_bw":"damara Ealayohimo","text_ar":"دَمَرَ عَلَيْهِمْ"},{"kind":"text","text":", (S, * M, A, K,) aor."},{"kind":"text","text":", (S, M,) inf. n."},{"kind":"arabic","text_bw":"dumuwrN","text_ar":"دُمُورٌ"},{"kind":"text","text":"(S, M, A, K) and"},{"kind":"arabic","text_bw":"damorN","text_ar":"دَمْرٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He intruded upon them; went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came, in to them without permission:"},{"kind":"text","text":"(S, * M, A, K: *) or"},{"kind":"italic_en","text":"intruded upon them in an evil manner."},{"kind":"text","text":"(K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"mano sabaqa Tarofuhu A@sotiy^o*aAnahu faqado damara","text_ar":"مَنْ سَبَقَ طَرْفُهُ ا@سْتِيْذَانَهُ فَقَدْ دَمَرَ"},{"kind":"italic_en","text":"He whose look precedes his asking permission"},{"kind":"text","text":"[does that which is as bad as the act of him who]"},{"kind":"italic_en","text":"enters without permission."},{"kind":"text","text":"(S, * TA.) And it is said,"},{"kind":"arabic","text_bw":"A_i*aA daxalota","text_ar":"اـِذَا دَخَلْتَ"},{"kind":"arabic","text_bw":"Ald~uwra A_iy~aAka wa Ald~umuwra","text_ar":"الدُّورَ اـِيَّاكَ وَ الدُّمُورَ"},{"kind":"italic_en","text":"When thou enterest houses,"},{"kind":"text","text":"[meaning, desirest to enter them,]"},{"kind":"italic_en","text":"beware of entering without permission."},{"kind":"text","text":"(A.)"}],"source_refs":["T","M","MF","TA","Msb","A","S","K"]},{"entry_id":"n13074","headword_ar":"دَمِرٌ","root":"dmr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"daAmirN","text_ar":"دَامِرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}