ms","form":"أَقْوَ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقْوَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":120,"cross_references":{"qac":{"found":true,"lemma_key":"تَقْوَى","root":"وقي","pos":"N","occurrence_count":17},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3995"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%82%D9%92%D9%88%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to strengthen, to bolster, to potentiate"},{"pos":"noun","gloss":"verbal noun of قَوِيَ (qawiya) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3995","headword_ar":"تَقْوَى","root":"Quasi tqY: or, accord. to some, tqw","body":[{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"taqowFY","text_ar":"تَقْوًى"},{"kind":"text","text":", accord. to different readings in the Kur ix. 110, (Bd,) [of which readings the former is the more common,] is originally"},{"kind":"arabic","text_bw":"taqoyaA","text_ar":"تَقْيَا"},{"kind":"text","text":", (K,) [or"},{"kind":"arabic","text_bw":"taqoyFA","text_ar":"تَقْيًا"},{"kind":"text","text":",] or [rather"},{"kind":"arabic","text_bw":"waqoyaA","text_ar":"وَقْيَا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"waqoyFA","text_ar":"وَقْيًا"},{"kind":"text","text":", and then]"},{"kind":"arabic","text_bw":"waqowaY","text_ar":"وَقْوَى"},{"kind":"text","text":", of the measure"},{"kind":"arabic","text_bw":"faEolaY","text_ar":"فَعْلَى"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"waqayotu","text_ar":"وَقَيْتُ"},{"kind":"text","text":", (ISd, TA,) or, accord. to MF, the right opinion is that it is ["},{"kind":"arabic","text_bw":"waqowFY","text_ar":"وَقْوًى"},{"kind":"text","text":",] of the measure"},{"kind":"arabic","text_bw":"faEowalN","text_ar":"فَعْوَلٌ"},{"kind":"text","text":", (TA,) and is thus transformed in order to make a distinction between the subst. and the epithet such as"},{"kind":"arabic","text_bw":"xazoyaA","text_ar":"خَزْيَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SadoyaA","text_ar":"صَدْيَا"},{"kind":"text","text":": (K:) it is a subst. from"},{"kind":"arabic","text_bw":"Ait~aqaY","text_ar":"اِتَّقَى"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"waqaY","text_ar":"وَقَى"},{"kind":"text","text":"; (Msb, K;) [and signifies"},{"kind":"italic_en","text":"Fear; caution;"},{"kind":"text","text":"&c.: (see 1:) and particularly"},{"kind":"italic_en","text":"reverential,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pious, fear of God:"},{"kind":"text","text":"or simply"},{"kind":"italic_en","text":"piety:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"preservation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarding, of oneself,"},{"kind":"text","text":"accord. to some,"},{"kind":"italic_en","text":"exceedingly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extraordinarily, from sin, either of commission or of omission:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"preservation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarding, of oneself from punishment in the world to come, and from acts of disobedience, by righteous conduct:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"righteousness, virtue, justice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honesty:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"taqiY~N","text_ar":"تَقِىٌّ"},{"kind":"text","text":":) its explanations in relation to religion are many and various, but are all resolvable into"},{"kind":"italic_en","text":"fear of God,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of sin;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"preservation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarding, of oneself from sin:"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"taqiy~apN","text_ar":"تَقِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tuqaApN","text_ar":"تُقَاةٌ","orth_type":"arrow"},{"kind":"text","text":"are syn. with each other (S) and with"},{"kind":"arabic","text_bw":"taqoway","text_ar":"تَقْوَي"},{"kind":"text","text":", (Msb,) and are used as inf. ns. of"},{"kind":"arabic","text_bw":"Ait~aqaY","text_ar":"اِتَّقَى"},{"kind":"text","text":": (S:) and ↓"},{"kind":"arabic","text_bw":"tuqFY","text_ar":"تُقًى","orth_type":"arrow"},{"kind":"text","text":"[also] is syn. with"},{"kind":"arabic","text_bw":"taqoway","text_ar":"تَقْوَي"},{"kind":"text","text":"; (S;) or it is pl. of ↓"},{"kind":"arabic","text_bw":"tuqaApN","text_ar":"تُقَاةٌ","orth_type":"arrow"},{"kind":"text","text":", or a coll. n., (Kzz, IB, Msb,) like as"},{"kind":"arabic","text_bw":"TulFY","text_ar":"طُلًى"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"TulaApN","text_ar":"طُلَاةٌ"},{"kind":"text","text":", (Kzz, IB,) and as"},{"kind":"arabic","text_bw":"ruTabN","text_ar":"رُطَبٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"ruTabapN","text_ar":"رُطَبَةٌ"},{"kind":"text","text":". (Msb.)"},{"kind":"arabic","text_bw":"waA=taAhumo taqowaAhumo","text_ar":"وَا=تَاهُمْ تَقْوَاهُمْ"},{"kind":"text","text":", in the Kur xlvii. 19, means"},{"kind":"italic_en","text":"And hath explained to them,"},{"kind":"text","text":"(Bd,) or"},{"kind":"italic_en","text":"suggested to them,"},{"kind":"text","text":"(Jel, TA,)"},{"kind":"italic_en","text":"what they should fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that from which they should preserve themselves:"},{"kind":"text","text":"(Bd, Jel, TA:) or"},{"kind":"italic_en","text":"hath aided them to practise their"},{"kind":"arabic","text_bw":"taqowaY","text_ar":"تَقْوَى"},{"kind":"text","text":": (Bd:) or"},{"kind":"italic_en","text":"hath given them the recompense of their"},{"kind":"arabic","text_bw":"tqwY","text_ar":"تقوى"},{"kind":"text","text":". (Bd, TA.) And"},{"kind":"arabic","text_bw":"huwa A^aholu Alt~aqowaY","text_ar":"هُوَ اَهْلُ التَّقْوَى"},{"kind":"text","text":", in the Kur lxxiv. last verse, means"},{"kind":"italic_en","text":"He is entitled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worthy, to be feared;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to be reverentially,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piously, feared."},{"kind":"text","text":"(Bd, Jel, K.)"}],"source_refs":["Bd","K","ISd","TA","S","Msb","Kzz","IB","Jel"]}]}}