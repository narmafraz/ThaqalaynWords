{"lemma":"طاقَ","slug":"طاقَ","root":"ط.#.ق","root_slug":"ط-_-ق","root_link":"/words/roots/ط-_-ق","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"طُقْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"طُقْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"طُقْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"طُقْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"طُقْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"طاقَ","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"طاقَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"طاقا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"طاقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"طاقُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"طُقْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَطُق","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَطُوق","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَطُوقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَطُوقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَطُوقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَطُوقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَطُوقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَطُوقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَطُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَطُق","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَطُوق","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَطُق","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَطُوق","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَطُوقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَطُوقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَطُوقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَطُوقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطُوقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطُوقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"طُقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طُقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَطُوق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطُوق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n27330"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be able to do (something) (to be capable of doing)"},{"pos":"verb","gloss":"to be able to do (something) (to be in a position to do)"},{"pos":"verb","gloss":"to bear, to tolerate"},{"pos":"noun","gloss":"arch"}]},"etymology":{"source":"wiktextract","text":"From Middle Iranian *tāk (“arch”); compare Middle Persian [script needed] (tʾg /⁠tāg⁠/, “arch”). Ultimately from the Proto-Indo-European root *teg- (“to cover; roof”), and akin to Latin toga (“garment”) and Ancient Greek στέγος (stégos, “roof”)."},"ipa":["/tˤaː.qa/","/tˤaːq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27330","headword_ar":"طَاقٌ","root":"Twq","body":[{"kind":"italic_en","text":"A curved construction"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"structure;"},{"kind":"text","text":"(S, O, K;) [said to be] a Pers. word arabicized; (S, O;) and its pl. is"},{"kind":"arabic","text_bw":"TaAqaAtN","text_ar":"طَاقَاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TiyqaAnN","text_ar":"طِيقَانٌ"},{"kind":"text","text":": (S, O, K:) or"},{"kind":"italic_en","text":"an arch"},{"kind":"text","text":"of a building, wherever it is; and the pl. is"},{"kind":"arabic","text_bw":"A^aTowaAqN","text_ar":"اَطْوَاقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TiyqaAnN","text_ar":"طِيقَانٌ"},{"kind":"text","text":": (JK, TA:) and as signifying [thus, or]"},{"kind":"italic_en","text":"an arch constructed with bricks,"},{"kind":"text","text":"it is [said to be] originally ↓"},{"kind":"arabic","text_bw":"TaAy^iqN","text_ar":"طَايِقٌ","orth_type":"arrow"},{"kind":"text","text":"; and therefore to have for its pl."},{"kind":"arabic","text_bw":"TawaAy^iqu","text_ar":"طَوَايِقُ"},{"kind":"text","text":": so says Az. (TA.) [It is often applied to"},{"kind":"italic_en","text":"An arched gateway"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doorway:"},{"kind":"text","text":"and to"},{"kind":"italic_en","text":"a vault."},{"kind":"text","text":"And]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"kuw~apN","text_ar":"كُوَّةٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"A mural aperture; a hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an aperture, in a wall;"},{"kind":"text","text":"a meaning also assigned to"},{"kind":"arabic","text_bw":"A_iforiyzN","text_ar":"اـِفْرِيزٌ"},{"kind":"text","text":", by which"},{"kind":"arabic","text_bw":"TaAqN","text_ar":"طَاقٌ"},{"kind":"text","text":"will be found to be expl. in what follows: or"},{"kind":"italic_en","text":"a niche in a wall;"},{"kind":"text","text":"which, as also"},{"kind":"italic_en","text":"a window,"},{"kind":"text","text":"is now often called ↓"},{"kind":"arabic","text_bw":"TaAqapN","text_ar":"طَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":"]. (So in the Munjid of Kr.) [And app."},{"kind":"italic_en","text":"A kind of arched construction with a flat top which forms a shelf, against a wall."},{"kind":"text","text":"(See"},{"kind":"arabic","text_bw":"raf~N","text_ar":"رَفٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sahowapN","text_ar":"سَهْوَةٌ"},{"kind":"text","text":".)] And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A_iforiyzN","text_ar":"اـِفْرِيزٌ"},{"kind":"text","text":"[which is expl. as meaning"},{"kind":"italic_en","text":"a projecting roof"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covering"},{"kind":"text","text":"of a wall: and"},{"kind":"italic_en","text":"a projecting coping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cornice, surrounding the upper part of a wall:"},{"kind":"text","text":"and in the KL as meaning"},{"kind":"italic_en","text":"a hole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an aperture, of a wall;"},{"kind":"text","text":"(as mentioned above;) but its author adds “ so we have heard ”]: (MA voce"},{"kind":"arabic","text_bw":"A_iforiyzN","text_ar":"اـِفْرِيزٌ"},{"kind":"text","text":":) or so"},{"kind":"arabic","text_bw":"A^aTowaAqN","text_ar":"اَطْوَاقٌ"},{"kind":"text","text":". (JK, and O on the authority of Ibn-'Abbád. [But this I think doubtful, and the more so as it will be seen in what follows that another meaning assigned in these same lexicons to"},{"kind":"arabic","text_bw":"A^aTowaAqN","text_ar":"اَطْوَاقٌ"},{"kind":"text","text":"is said by IB to be a meaning of"},{"kind":"arabic","text_bw":"TaAqN","text_ar":"طَاقٌ"},{"kind":"text","text":".]) ―         -b2-  See also"},{"kind":"arabic","text_bw":"TaAy^iqN","text_ar":"طَايِقٌ"},{"kind":"text","text":", in two places. ―         -b3-  [Also"},{"kind":"italic_en","text":"A layer, stratum, lamina,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any flat piece,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"of a thing,"},{"kind":"italic_en","text":"such as is in some cases placed over,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"under, a similar piece"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"anything such as is in some cases lined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"otherwise combined, with another similar thing:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"TaAqaAtN","text_ar":"طَاقَاتٌ"},{"kind":"text","text":".] You say"},{"kind":"arabic","text_bw":"TaAqu naEolK","text_ar":"طَاقُ نَعْلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A single piece of leather of a sole"},{"kind":"text","text":"that consists of two or more of such pieces]; (S, O, K;) and"},{"kind":"arabic","text_bw":"nEolK","text_ar":"نعْلٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"TaAqapu","text_ar":"طَاقَةُ","orth_type":"arrow"},{"kind":"text","text":"[which means the same]. (K.) And"},{"kind":"arabic","text_bw":"naEolN TaAqN waAHidN","text_ar":"نَعْلٌ طَاقٌ وَاحِدٌ"},{"kind":"italic_en","text":"A single sole;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"a sole of a single piece; not made of two pieces sewed together, one upon the other."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"nEl","text_ar":"نعل"},{"kind":"text","text":".) And [in like manner] a garment is said to be"},{"kind":"arabic","text_bw":"TaAqN waAHidN","text_ar":"طَاقٌ وَاحِدٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Single, not double, not lined nor faced nor stuffed"},{"kind":"text","text":"]. (Az, in TA in art."},{"kind":"arabic","text_bw":"smT","text_ar":"سمط"},{"kind":"text","text":", [where this meaning is clearly indicated,] and Th, in M, same art.) Thus one says"},{"kind":"arabic","text_bw":"saraAwiylu TaAqN waAHidN","text_ar":"سَرَاوِيلُ طَاقٌ وَاحِدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Trousers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drawers, of single cloth"},{"kind":"text","text":"]. (Th, M and K in art."},{"kind":"arabic","text_bw":"smT","text_ar":"سمط"},{"kind":"text","text":".) [See also what is said of the phrase"},{"kind":"arabic","text_bw":"Als~araAwiylu AlT~aAqu","text_ar":"السَّرَاوِيلُ الطَّاقُ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"rijolN","text_ar":"رِجْلٌ"},{"kind":"text","text":".] One says also"},{"kind":"arabic","text_bw":"gazolN TaAqN waAHidN","text_ar":"غَزْلٌ طَاقٌ وَاحِدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Spun thread that is a single yarn"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"gazolN mafotuwlN TaAqayoni","text_ar":"غَزْلٌ مَفْتُولٌ طَاقَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Spun thread twisted of two yarns"},{"kind":"text","text":"]. (S and TA in art."},{"kind":"arabic","text_bw":"sHl","text_ar":"سحل"},{"kind":"text","text":".) See also"},{"kind":"arabic","text_bw":"TaAqapN","text_ar":"طَاقَةٌ"},{"kind":"text","text":", which has a similar meaning. [And see an ex. of the pl."},{"kind":"arabic","text_bw":"TaAqaAt","text_ar":"طَاقَات"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"raboEapN","text_ar":"رَبْعَةٌ"},{"kind":"text","text":".]       -A2-  Also"},{"kind":"italic_en","text":"A certain sort of garment,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"having sleeves."},{"kind":"text","text":"(S, O.) [And] accord. to Esh-Shereeshee,"},{"kind":"italic_en","text":"A garment worn by a new-born child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young infant, without an opening at the bosom."},{"kind":"text","text":"(Har p. 502.) ―         -b2-  And (O, K) accord. to IAar, (O,)"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"TayolasaAn","text_ar":"طَيْلَسَان"},{"kind":"text","text":"[q. v.]: (O, K:) or"},{"kind":"italic_en","text":"such as is"},{"kind":"arabic","text_bw":"A^axoDar","text_ar":"اَخْضَر"},{"kind":"text","text":"[properly meaning"},{"kind":"italic_en","text":"green;"},{"kind":"text","text":"but when applied to a garment commonly meaning, as used by the Arabs,"},{"kind":"italic_en","text":"of a dark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ashy, dust-colour;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a dingy ashcolour"},{"kind":"text","text":"]: (Kr, K:) pl."},{"kind":"arabic","text_bw":"TiyqaAnN","text_ar":"طِيقَانٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"siyjaAnN","text_ar":"سِيجَانٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"saAjN","text_ar":"سَاجٌ"},{"kind":"text","text":". (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"garment of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"kisaA='i","text_ar":"كِسَا=ءِ"},{"kind":"text","text":": (IB, TA:) and (TA) so"},{"kind":"arabic","text_bw":"A^aTowaAqN","text_ar":"اَطْوَاقٌ"},{"kind":"text","text":". (JK, and O and TA on the authority of Ibn- 'Abbád. [But this, as I have shown above, I think doubtful.]) ―         -b4-  And"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"woman's muffler,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"head-covering, such as is called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"ximaAr","text_ar":"خِمَار"},{"kind":"text","text":". (IAar, TA.) ―         -b5-  And one says,"},{"kind":"arabic","text_bw":"raA^ayotu A^aroDFA kaA^an~ahaA AlT~iyqaAnu","text_ar":"رَاَيْتُ اَرْضًا كَاَنَّهَا الطِّيقَانُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I saw a land as though it were"},{"kind":"text","text":"spread with"},{"kind":"italic_en","text":"the garments called"},{"kind":"arabic","text_bw":"TyqAn","text_ar":"طيقان"},{"kind":"text","text":"]; meaning,"},{"kind":"italic_en","text":"whereof the herbage was abundant."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","O","K","JK","TA","Kr","IB"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B7%D8%A7%D9%82/","headword_ar":"طاقا","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=106849#1db4bf","body_html":"طاقا<br>عن اليابانية بمعنى معشوقة القوام وشريفة من النبلاء. يستخدم للإناث."},{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=106849#d82a92","body_html":"طاقا<br>صورة كتابية صوتية من طاقة: القدرة وشعبة أو حزمة من ريحان أو زهر أو شعر أو خيوط أو حبال."}]}}