n":"m","num":"p"},{"role":"present_2mp","form":"تَمْسَخُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَمْسَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَمْسَخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَمْسَخ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَمْسَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمْسَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَمْسَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمْسَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَمْسَخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمْسَخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَمْسَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَمْسَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَمْسَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"مَسَخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"مَسَخْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":true,"lemma_key":"مَسَخَ","root":"مسخ","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n38581","n38582"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B3%D9%8E%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to transform, transmute, change into something else"},{"pos":"verb","gloss":"to distort, spoil"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew מַסֵּכָה (masekhá, “molten image”)."},"ipa":["/ma.sa.xa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38581","headword_ar":"مَسْخٌ","root":"msx","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"masiyxN","text_ar":"مَسِيخٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) [the former originally an inf. n., and therefore used as sing. and dual and pl. without alteration, though"},{"kind":"arabic","text_bw":"musuwxN","text_ar":"مُسُوخٌ"},{"kind":"text","text":"is used as a pl. by late writers, (see De Sacy's Chrest. Ar., ii. 273,)] the latter of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"Transformed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"metamorphosed, into a worse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more ugly, shape."},{"kind":"text","text":"(L, K.) Ex."},{"kind":"arabic","text_bw":"AljaAn~u masoxu Aljin~i","text_ar":"الجَانُّ مَسْخُ الجِنِّ"},{"kind":"italic_en","text":"The Jánn,"},{"kind":"text","text":"which are slender serpents,"},{"kind":"italic_en","text":"are the transformed of the Jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Genii;"},{"kind":"text","text":"like as certain persons of the Children of Israel were transformed into apes. [See Kur, ii. 61.] (L, from a trad.) ―         -b2-  Also, the ↓ latter,"},{"kind":"italic_en","text":"Deformed; rendered ugly in make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"form."},{"kind":"text","text":"(K.) Hence, some say, the appellation of"},{"kind":"arabic","text_bw":"Ald~aj~aAlu","text_ar":"الدَّجَّالُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Almasiyxu","text_ar":"المَسِيخُ","orth_type":"arrow"},{"kind":"text","text":"[more commonly"},{"kind":"arabic","text_bw":"AlmasiyHu","text_ar":"المَسِيحُ"},{"kind":"arabic","text_bw":"Ald~j~An","text_ar":"الدّجّان"},{"kind":"text","text":", q. v.]. (TA.) ―         -b3-  Also, the same, (tropical:)  A man"},{"kind":"italic_en","text":"having no beauty."},{"kind":"text","text":"(S, K.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"Weak and stupid:"},{"kind":"text","text":"(K:) also an epithet applied to a man. (TA.) ―         -b5-  And (assumed tropical:)  Flesh-meat, (S, L, K,) and fruit, (L, K,)"},{"kind":"italic_en","text":"that has no taste; tasteless; insipid:"},{"kind":"text","text":"(S, L, K:) or, applied to food,"},{"kind":"italic_en","text":"that has no salt nor colour nor taste:"},{"kind":"text","text":"and sometimes,"},{"kind":"italic_en","text":"that is between sweet and bitter."},{"kind":"text","text":"(L.) El-Ash'ar Er-Rakabán, of the tribe of Asad, a Jáhilee, says, addressing a man named Ridwán, (L,)"},{"kind":"quote","text":"masiyxN maliyxN kalaHomi AlHuwaA\n                     \n                     \n                        ri laA A^anota HulowN walaA A^anota mur~N"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Tasteless, insipid, like the flesh of a new-born camel, thou art not sweet nor art thou bitter"},{"kind":"text","text":"]. (S, L.)"}],"source_refs":["L","K","S"]},{"entry_id":"n38582","headword_ar":"مَسَخٌ","root":"msx","body":[{"kind":"italic_en","text":"Leanness"},{"kind":"text","text":"of the arm, between the shoulder and the elbow. (L.)"}],"source_refs":[]}]},"classical_definitions":null}