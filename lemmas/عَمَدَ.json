lanelexicon.com/?s=%D8%B9%D9%8E%D9%85%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to prop up, to support"},{"pos":"verb","gloss":"to intend, to resolve, to purpose"},{"pos":"verb","gloss":"to embark on, to take up"},{"pos":"verb","gloss":"to baptize, to christen"},{"pos":"verb","gloss":"to baptize, to christen"},{"pos":"noun","gloss":"intent, intention, design, purpose, plan"},{"pos":"noun","gloss":"premeditation, intent"},{"pos":"noun","gloss":"verbal noun of عَمَدَ (ʕamada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"adj","gloss":"intentional, deliberate, on purpose"},{"pos":"adj","gloss":"premeditated, intentional"},{"pos":"noun","gloss":"plural of عَمُود (ʕamūd)","tags":["form-of","plural"],"examples":[{"text":"فِي عَمَدٍ مُمَدَّدَة"}]}]},"etymology":{"source":"wiktextract","text":"From the root ع م د (ʕ m d). Cognate to Hebrew עמד (amád, “to stand; to be about to”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30495","headword_ar":"عَمَدٌ","root":"Emd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EamuwdN","text_ar":"عَمُودٌ"},{"kind":"text","text":"(of which it is a quasi-pl. n., as it is also of"},{"kind":"arabic","text_bw":"EimaAdN","text_ar":"عِمَادٌ"},{"kind":"text","text":"), in four places: and"},{"kind":"arabic","text_bw":"EumodapN","text_ar":"عُمْدَةٌ"},{"kind":"text","text":".       -A2-  [It is also an inf. n. of"},{"kind":"arabic","text_bw":"Eamada lahu","text_ar":"عَمَدَ لَهُ"},{"kind":"text","text":", q. v.:       -A3-  and the inf. n. of"},{"kind":"arabic","text_bw":"Eamida","text_ar":"عَمِدَ"},{"kind":"text","text":", q. v.: ―         -b2-  and hence it signifies]"},{"kind":"italic_en","text":"A swelling, with galls, in the back of a camel."},{"kind":"text","text":"(L.)"}],"source_refs":[]},{"entry_id":"n30496","headword_ar":"عَمِدٌ","root":"Emd","body":[{"kind":"text","text":"Earth"},{"kind":"italic_en","text":"moistened by rain so that when a portion of it is grasped in the hand it becomes compacted by reason of its moisture:"},{"kind":"text","text":"(S, O, L:) or"},{"kind":"italic_en","text":"moistened by rain and compacted, layer upon layer."},{"kind":"text","text":"(L.) ―         -b2-  [Hence] one says,"},{"kind":"arabic","text_bw":"huwa Eamidu Alv~araY","text_ar":"هُوَ عَمِدُ الثَّرَى"},{"kind":"italic_en","text":"Text is missing in originalndant in goodness, beneficence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounty."},{"kind":"text","text":"(AZ, Sh, O, K.) ―         -b3-"},{"kind":"arabic","text_bw":"EamidN","text_ar":"عَمِدٌ"},{"kind":"text","text":"is also applied to a camel, meaning"},{"kind":"italic_en","text":"Having the inner part of his hump broken"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bruised"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by his being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"much"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ridden, while the outer part remains whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound:"},{"kind":"text","text":"(S, O, L:) or"},{"kind":"italic_en","text":"having his hump swollen in consequence of the galling of the saddle and of the cloth beneath it, and broken"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bruised"},{"kind":"text","text":"]: fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": and, with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", a she-camel"},{"kind":"italic_en","text":"broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"subdued, by the weight of her burden."},{"kind":"text","text":"(L.) Lebeed says, describing rain (S, O, L) that caused the valleys to flow, (S,)"},{"kind":"quote","text":"fabaAta Als~ayolu yarokabu jaAnibayohi\n                      \n                     \n                        mina Albaq~aAri kaAlEamidi Alv~aqaAli"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the torrent continued during the night, what resembled the heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slow-paced, camel such as is termed"},{"kind":"arabic","text_bw":"Eamid","text_ar":"عَمِد"},{"kind":"italic_en","text":"overlying its two sides, from"},{"kind":"text","text":"the valley of"},{"kind":"italic_en","text":"El-Bakkár"},{"kind":"text","text":"]: As says, he means that a collection of clouds resembling the [camel termed]"},{"kind":"arabic","text_bw":"Eamid","text_ar":"عَمِد"},{"kind":"text","text":"overlay the two sides of the torrent; i. e., that clouds encompassed it with rain. (S, O, L.) ―         -b4-  Also, applied to a pustule,"},{"kind":"italic_en","text":"Swollen in consequence of its having been squeezed before it had become ripe, and retaining its egg"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"white globule"},{"kind":"text","text":"]. (L.)"}],"source_refs":["S","O","L"]},{"entry_id":"n30500","headword_ar":"عُمُدٌّ","root":"Emd","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Eumud~aAniY~N","text_ar":"عُمُدَّانِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(O, L, K) and ↓"},{"kind":"arabic","text_bw":"Eumud~aAnN","text_ar":"عُمُدَّانٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEam~adN","text_ar":"مُعَمَّدٌ","orth_type":"arrow"},{"kind":"text","text":"(L) or ↓"},{"kind":"arabic","text_bw":"muEomadN","text_ar":"مُعْمَدٌ","orth_type":"arrow"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"A youth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young man, full of the sap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigour, of youth:"},{"kind":"text","text":"(O, L, K:) or"},{"kind":"italic_en","text":"bulky,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corpulent, and tall:"},{"kind":"text","text":"(L:) the fem. (of every one of these, L) is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (L, K:) and the pl. of the second is ↓"},{"kind":"arabic","text_bw":"Eumud~aAniy~uwna","text_ar":"عُمُدَّانِيُّونَ","orth_type":"arrow"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"Eumud~aAniy~apN","text_ar":"عُمُدَّانِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a"},{"kind":"italic_en","text":"corpulent, bulky,"},{"kind":"text","text":"woman; (O, L;) as also ↓"},{"kind":"arabic","text_bw":"Eumud~aAnapN","text_ar":"عُمُدَّانَةٌ","orth_type":"arrow"},{"kind":"text","text":". (O.)"}],"source_refs":["O","L","K","TA"]}]}}