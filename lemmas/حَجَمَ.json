,"gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْجُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْجُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْجُم","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْجُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْجُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْجُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْجُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْجُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْجُمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْجُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْجُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْجُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْجُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَجَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَجَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n7217"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AC%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"size; volume","examples":[{"text":"بَيْتُهُمْ مُتَوَسِّط الْحَجْم","english":"their house is middle-sized"}]},{"pos":"verb","gloss":"to suck from; to cup, to apply scarificator and cupping glass on"},{"pos":"verb","gloss":"to restrain, to withhold, to impede"}]},"etymology":null,"ipa":["/ħad͡ʒm/","/ħa.d͡ʒa.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7217","headword_ar":"حَجَمَ","root":"Hjm","body":[{"kind":"text","text":"said of the breast of a woman or girl: see 4.       -A2-"},{"kind":"arabic","text_bw":"Hajama","text_ar":"حَجَمَ"},{"kind":"text","text":", (ISk, S, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajomN","text_ar":"حَجْمٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child, ISk, S, TA)"},{"kind":"italic_en","text":"sucked"},{"kind":"text","text":"(ISk, S, K) the breast of his mother. (ISk, S, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Hajamahu","text_ar":"حَجَمَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajomN","text_ar":"حَجْمٌ"},{"kind":"text","text":", (S, Mgh, Msb,)"},{"kind":"italic_en","text":"He scarified him"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and drew blood from him with the"},{"kind":"arabic","text_bw":"miHojamap","text_ar":"مِحْجَمَة"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"he cupped him"},{"kind":"text","text":"]; (Msb;)"},{"kind":"italic_en","text":"he performed upon him the operation of the"},{"kind":"arabic","text_bw":"Haj~aAm","text_ar":"حَجَّام"},{"kind":"text","text":", (Mgh,) or,"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"HaAjim","text_ar":"حَاجِم"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"who sucks the mouth of the"},{"kind":"arabic","text_bw":"miHojamap","text_ar":"مِحْجَمَة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to draw the blood"},{"kind":"text","text":"]. (Az, TA.) ―         -b3-  And [hence,]"},{"kind":"arabic","text_bw":"Hajamatohu AlHay~apu","text_ar":"حَجَمَتْهُ الحَيَّةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The serpent bit him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Hajamati","text_ar":"حَجَمَتِ"},{"kind":"arabic","text_bw":"AlfuHuwlu AlEayora","text_ar":"الفُحُولُ العَيْرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The stallions bit the ass."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Hajama AlEaZoma","text_ar":"حَجَمَ العَظْمَ"},{"kind":"text","text":", (TA,) inf. n. as above, (K,) (assumed tropical:)"},{"kind":"italic_en","text":"He ate off the flesh from the bone."},{"kind":"text","text":"(K, TA.)       -A3-"},{"kind":"arabic","text_bw":"Hajama AlbaEiyra","text_ar":"حَجَمَ البَعِيرَ"},{"kind":"text","text":", (S, Msb, TA,) aor,"},{"kind":"text","text":", (S TA,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"He put a"},{"kind":"arabic","text_bw":"HijaAm","text_ar":"حِجَام"},{"kind":"italic_en","text":"upon the mouth"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"muzzle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the camel,"},{"kind":"text","text":"when excited,"},{"kind":"italic_en","text":"in order that he might not bite;"},{"kind":"text","text":"(S, TA;) ["},{"kind":"italic_en","text":"he muzzled the camel;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he bound the camel's mouth"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"muzzle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with a thing."},{"kind":"text","text":"(Msb.) ―         -b2-  Hence, (Har p. 474,)"},{"kind":"arabic","text_bw":"Hajamotuhu Eani Al$~aYo'i","text_ar":"حَجَمْتُهُ عَنِ الشَّىْءِ"},{"kind":"text","text":", (S, Msb, * TA,) and"},{"kind":"arabic","text_bw":"Eano SaAHibatihi","text_ar":"عَنْ صَاحِبَتِهِ"},{"kind":"text","text":", (TA,) inf. n. as above, (K,)"},{"kind":"italic_en","text":"I made him to refrain, forbear, abstain,"},{"kind":"text","text":"(S, TA,) or"},{"kind":"italic_en","text":"go back;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"I withheld him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restrained him;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"from the thing,"},{"kind":"text","text":"(S, TA,) and"},{"kind":"italic_en","text":"from his female companion."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Hajama","text_ar":"حَجَمَ"},{"kind":"arabic","text_bw":"Tarofahu Eanohu","text_ar":"طَرْفَهُ عَنْهُ"},{"kind":"italic_en","text":"He turned away his eye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eyes, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eano HaAjatihi","text_ar":"عَنْ حَاجَتِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aHojamotuhu","text_ar":"اَحْجَمْتُهُ","orth_type":"arrow"},{"kind":"text","text":"is also mentioned, as meaning"},{"kind":"italic_en","text":"I withheld him from the object of his want;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prevented him from attaining it."},{"kind":"text","text":"(TA.)"}],"source_refs":["ISk","S","K","Mgh","Msb","TA"]}]},"classical_definitions":null}