{"lemma":"مَجْمُوعِي","slug":"مَجْمُوعِي","root":"ج.م.ع","root_slug":"ج-م-ع","root_link":"/words/roots/ج-م-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مَجْمُوع","root":"جمع","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n6332"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%AC%D9%92%D9%85%D9%8F%D9%88%D8%B9%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"united"},{"pos":"adj","gloss":"reconciled"},{"pos":"noun","gloss":"sum, crowd"}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of جَمَعَ (jamaʕa, “to unite, to reconcile”)."},"ipa":["/mad͡ʒ.muːʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6332","headword_ar":"مَجْمُوعٌ","root":"jmE","body":[{"kind":"italic_en","text":"Collected; brought, or gathered, together; gathered up; assembled; congregated; mustered; drawn together;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"contracted;"},{"kind":"text","text":"] (S, K, TA;) ["},{"kind":"italic_en","text":"from several places,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"hence and thence, although not made as one thing."},{"kind":"text","text":"(S, Sgh, L, K.) It is said in the Kur [xi. 105],"},{"kind":"arabic","text_bw":"*`lika yawomN","text_ar":"ذٰلِكَ يَوْمٌ"},{"kind":"arabic","text_bw":"majomuwEN lahu Aln~aAsi","text_ar":"مَجْمُوعٌ لَهُ النَّاسِ"},{"kind":"italic_en","text":"That is a day for which mankind shall be collected."},{"kind":"text","text":"(TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"jamoEN","text_ar":"جَمْعٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}