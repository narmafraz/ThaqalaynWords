{"lemma":"خَبَطَ","slug":"خَبَطَ","root":"خ.ب.ط","root_slug":"خ-ب-ط","root_link":"/words/roots/خ-ب-ط","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَبَطْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَبَطْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَبَطْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَبَطْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَبَطْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَبَطَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَبَطَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَبَطا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَبَطَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَبَطُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَبَطْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْبِط","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْبِطِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْبِطِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْبِطا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْبِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْبِطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْبِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْبِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْبِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْبِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْبِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْبِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْبِطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْبِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْبِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْبِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَبَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَبَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n9930"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%A8%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"knock, kick, hit"},{"pos":"verb","gloss":"to knock"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9930","headword_ar":"خَبَطَ","root":"xbT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb, K, TA,) inf. n."},{"kind":"arabic","text_bw":"xaboTN","text_ar":"خَبْطٌ"},{"kind":"text","text":", (Msb, TA, &c.,)"},{"kind":"italic_en","text":"He struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat,"},{"kind":"text","text":"(Msb, TA,) anything: (TA:) or"},{"kind":"italic_en","text":"he struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat,"},{"kind":"text","text":"it, or him,"},{"kind":"italic_en","text":"vehemently:"},{"kind":"text","text":"(M, K, TA:) or"},{"kind":"arabic","text_bw":"xaboTN","text_ar":"خَبْطٌ"},{"kind":"text","text":"signifies a camel's"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beating,"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"with his fore foot:"},{"kind":"text","text":"(T, TA:) or in the cases of beasts, ("},{"kind":"arabic","text_bw":"dawaAb~","text_ar":"دَوَابّ"},{"kind":"text","text":", [generally meaning horses and mules and asses,]) the"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beating, with the fore feet;"},{"kind":"text","text":"not with the hind feet: and in the case of the camel,"},{"kind":"italic_en","text":"with the fore foot and the hind foot:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement treading;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the fore feet of beasts"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"dwAb~","text_ar":"دوابّ"},{"kind":"text","text":"): (TA:) or, accord. to the Keshsháf, the act of"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beating, in a way"},{"kind":"page_break","n":698},{"kind":"italic_en","text":"that is not right:"},{"kind":"text","text":"or, as some say, the"},{"kind":"italic_en","text":"going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeying, upon what is not the middle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"main part, of the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is not the main road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon a road not open to view:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consecutive, striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beating, in different ways:"},{"kind":"text","text":"and afterwards tropically applied to any (tropical:)"},{"kind":"italic_en","text":"beating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"striking, that is not approved:"},{"kind":"text","text":"or originally, the"},{"kind":"italic_en","text":"striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beating, with the fore foot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the hind foot,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(MF, TA:) with the fore feet or legs, it is like"},{"kind":"arabic","text_bw":"ramoHN","text_ar":"رَمْحٌ"},{"kind":"text","text":"with the hind feet or legs. (TA.) You say, of a camel,"},{"kind":"arabic","text_bw":"xabaTa AlA^aroDa","text_ar":"خَبَطَ الاَرْضَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"xabaTa AlA^aroDa biyadihi","text_ar":"خَبَطَ الاَرْضَ بِيَدِهِ"},{"kind":"text","text":", (S, K,) inf. n. as above, (S,)"},{"kind":"italic_en","text":"He struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat, the ground with his fore foot:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"he struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat, vehemently the ground with his fore foot;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"txb~T","text_ar":"تخبّط","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AxtbT","text_ar":"اختبط","orth_type":"arrow"},{"kind":"text","text":"signify the same: (K:) it is said in the O that"},{"kind":"arabic","text_bw":"xabaTahu","text_ar":"خَبَطَهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he struck him with his fore foot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, and prostrated him,"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"txb~Thu","text_ar":"تخبّطهُ","orth_type":"arrow"},{"kind":"text","text":": and ↓"},{"kind":"arabic","text_bw":"AxtbT","text_ar":"اختبط","orth_type":"arrow"},{"kind":"text","text":", said of a camel, is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xabaTa","text_ar":"خَبَطَ"},{"kind":"text","text":": and in the T, that"},{"kind":"arabic","text_bw":"birijolihi","text_ar":"بِرِجْلِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taxab~aTaniY","text_ar":"تَخَبَّطَنِى","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn, with"},{"kind":"arabic","text_bw":"xabaTaniY","text_ar":"خَبَطَنِى"},{"kind":"text","text":". (TA.) Hence the trad.,"},{"kind":"arabic","text_bw":"laA taxobiTuwA xaboTa Aljamali","text_ar":"لَا تَخْبِطُوا خَبْطَ الجَمَلِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Ye shall not beat"},{"kind":"text","text":"the ground"},{"kind":"italic_en","text":"as the camel does with his fore foot"},{"kind":"text","text":"in rising]; meant to forbid a man's putting forward his foot in rising from prostration [in prayer]. (TA.) And"},{"kind":"arabic","text_bw":"xabaTahu","text_ar":"خَبَطَهُ"},{"kind":"text","text":", (K, TA,) aor. and inf. n. as above, (TA,) signifies also"},{"kind":"italic_en","text":"He trod him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, vehemently,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"as the camel does with his fore foot."},{"kind":"text","text":"(TA.) ―         -b2-  Hence, (S,)"},{"kind":"arabic","text_bw":"fulaAnN yaxobiTu xaboTa Ea$owaA='a","text_ar":"فُلَانٌ يَخْبِطُ خَبْطَ عَشْوَا=ءَ"},{"kind":"text","text":"(S, * TA) (tropical:)  ["},{"kind":"italic_en","text":"Such a one goes at random, in a headstrong and reckless manner,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like the weak-sighted she-camel that beats the ground with her fore feet"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taxobiTu","text_ar":"تَخْبِطُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"as she goes along, not guarding herself from anything."},{"kind":"text","text":"(S, TA.) It is a prov., applied to him who turns away from a thing as though he were not cognizant of it: or to him who is continually falling into a thing. (Har p. 239.) Zuheyr says,"},{"kind":"quote","text":"raA^ayotu AlmanaAyaA xaboTa Ea$owaA='a mano tuSibo\n                      \n                     \n                        tumitohu wamano tuxoTiy^o yuEam~aro fayahorami"},{"kind":"italic_en","text":"I saw the fates"},{"kind":"text","text":"["},{"kind":"italic_en","text":"treading mankind"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like the treading of the weak-sighted she-camel; whom they smote, him they killed: and whom they missed, he was made to continue in life so that he lived to extreme old age."},{"kind":"text","text":"(TA, and EM p. 132.) In like manner you say,"},{"kind":"arabic","text_bw":"fulaAnN yaxobiTu fiY EamoyaA='a","text_ar":"فُلَانٌ يَخْبِطُ فِى عَمْيَا=ءَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one undertakes what he undertakes with ignorance."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xabaTa A^amorahu EalaY gayori baSyrapK","text_ar":"خَبَطَ اَمْرَهُ عَلَى غَيْرِ بَصيرَةٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He prosecuted his affair without mental perception,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without certainty"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"E$w","text_ar":"عشو"},{"kind":"text","text":", q. v.) And"},{"kind":"arabic","text_bw":"yaxobiTu fiY AlZ~alaAmi","text_ar":"يَخْبِطُ فِى الظَّلَامِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He goes in the night without a lamp, and so becomes confounded and perplexed, and unable to see his right course, and errs from the way, and perchance may fall into a well."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xabaTa All~ayola","text_ar":"خَبَطَ اللَّيْلَ"},{"kind":"text","text":", (K, TA,) aor. and inf. n. as above, (TA,) (tropical:)"},{"kind":"italic_en","text":"He went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeyed, in the night without direction."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"baAta","text_ar":"بَاتَ"},{"kind":"arabic","text_bw":"yaxobiTu AlZ~alomaA='a","text_ar":"يَخْبِطُ الظَّلْمَا=ءَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He passed the night traversing the darkness without direction"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"xaboTN","text_ar":"خَبْطٌ"},{"kind":"text","text":"is said to signify (assumed tropical:)  The act of"},{"kind":"italic_en","text":"journeying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going, without direction:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon what is not the middle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"main part, of the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what is not the main road."},{"kind":"text","text":"(TA.) ―         -b3-  [And hence, perhaps,]"},{"kind":"arabic","text_bw":"xabaTahu","text_ar":"خَبَطَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He asked of him a benefit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"favour, without any tie of relationship;"},{"kind":"text","text":"(K, * TA;) as also ↓"},{"kind":"arabic","text_bw":"AxtbThu","text_ar":"اختبطهُ","orth_type":"arrow"},{"kind":"text","text":": (IB, K:) or this is from"},{"kind":"arabic","text_bw":"xaboTu waraqi Al$~ajari","text_ar":"خَبْطُ وَرَقِ الشَّجَرِ"},{"kind":"text","text":"[explained in what follows]: (Har p. 425:) or the latter, [or both,]"},{"kind":"italic_en","text":"he came to him seeking his beneficence without any such tie:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"or he came to him seeking a gift;"},{"kind":"text","text":"because he who does so must beat the ground with his feet: (IF:) and you also say,"},{"kind":"arabic","text_bw":"maEoruwfahu","text_ar":"مَعْرُوفَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxtbT","text_ar":"اختبط","orth_type":"arrow"},{"kind":"text","text":". (Aboo-Málik, TA.) [The latter verb is the more common. See also 10.] ―         -b4-  And (tropical:)"},{"kind":"italic_en","text":"He conferred a benefit upon him without there having been any acquaintance between them,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"and without there being anything to draw them near, and without there being any relationship:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"xabaTahu bixayori","text_ar":"خَبَطَهُ بِخَيْرِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the same:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he bestowed on him a benefit,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"being asked:"},{"kind":"text","text":"(TA:) and you say also,"},{"kind":"arabic","text_bw":"bixayorK","text_ar":"بِخَيْرٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxtbThu","text_ar":"اختبطهُ","orth_type":"arrow"},{"kind":"text","text":": (Aboo-Málik, TA:) and"},{"kind":"arabic","text_bw":"xabaTa fiyhimo bixayorK","text_ar":"خَبَطَ فِيهِمْ بِخَيْرٍ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"He benefited them."},{"kind":"text","text":"(TA.) 'Alkameh Ibn-'Abadeh says, (S, TA,) praising El-Hárith Ibn-AbeeShemir, (TA,)"},{"kind":"quote","text":"wafiY kul~i HaY~K qado xabaTota biniEomapK"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"And upon every tribe thou hast conferred benefit,"},{"kind":"text","text":"app. meaning"},{"kind":"italic_en","text":"without being related to them"},{"kind":"text","text":"]: (S, TA:) but it is said in a marginal note to the S, that"},{"kind":"arabic","text_bw":"xabaT~a","text_ar":"خَبَطَّ"},{"kind":"text","text":"would be better; and so it is accord. to one relation: in the L, however, it is said that"},{"kind":"arabic","text_bw":"xabat~a","text_ar":"خَبَتَّ"},{"kind":"text","text":"would be more agreeable with analogy. (TA.) Accord. to AZ,"},{"kind":"arabic","text_bw":"xabaTotu Alr~ajula","text_ar":"خَبَطْتُ الرَّجُلَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xaboTN","text_ar":"خَبْطٌ"},{"kind":"text","text":", signifies (assumed tropical:)"},{"kind":"italic_en","text":"I held loving communion, commerce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intercourse, with the man."},{"kind":"text","text":"(TA.) ―         -b5-  [In respect of the places which I have given to the abovementioned significations of asking and conferring a benefit, I have followed the opinion of IF; but it is said in the TA, and, I think, with greater probability, that they are from what here next follows.] ―         -b6-"},{"kind":"arabic","text_bw":"xabaTa Alwaraqa mina Al$~ajari","text_ar":"خَبَطَ الوَرَقَ مِنَ الشَّجَرِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xaboTN","text_ar":"خَبْطٌ"},{"kind":"text","text":", (Lth, T, Msb,)"},{"kind":"italic_en","text":"He made the leaves to fall from the trees:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he beat the leaves of the trees,"},{"kind":"text","text":"(Lth, T,) meaning large trees of the kind called"},{"kind":"arabic","text_bw":"TaloH","text_ar":"طَلْح"},{"kind":"text","text":", [acacia, or mimosa, gummifera,]"},{"kind":"italic_en","text":"with a staff,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick,"},{"kind":"text","text":"(Lth,)"},{"kind":"italic_en","text":"so that they fell off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became scattered,"},{"kind":"text","text":"(Lth, T,) after which he gave them as food to camels; (Lth;)"},{"kind":"italic_en","text":"refrainfrom injuring thereby the trunks and branches of the trees:"},{"kind":"text","text":"(T:) and"},{"kind":"arabic","text_bw":"lahu xabaTFA","text_ar":"لَهُ خَبَطًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxtbT","text_ar":"اختبط","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"xabaTa","text_ar":"خَبَطَ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"xabaTa Al$~ajarapa","text_ar":"خَبَطَ الشَّجَرَةَ"},{"kind":"text","text":", (S, K,) aor. as above, (TA,) and so the inf. n., (S,)"},{"kind":"italic_en","text":"He beat the tree with a staff,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stick, in order that its leaves might fall off:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he bound the tree, and then made its leaves to fall,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"by beating it"},{"kind":"text","text":"with a staff, or stick, to give them as food to camels and other beasts. (TA.) The leaves are stored up for the camels; and in wintertime are bruised, or broken up, for them, and moistened with water, and given to them as fodder. (Har p. 218.) Mohammad was asked, Does"},{"kind":"arabic","text_bw":"AlgaboT","text_ar":"الغَبْط"},{"kind":"text","text":"[i. e. “ the wishing for a blessing on the condition that it shall not become transferred from its possessor ”] injure [its author]? and he answered,"},{"kind":"arabic","text_bw":"laA A_il~aA kamaA yaDur~u AlEiDaAha AlxaboTu","text_ar":"لَا اـِلَّا كَمَا يَضُرُّ العِضَاهَ الخَبْطُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"No, save as the beating off the leaves injures the"},{"kind":"text","text":"trees called"},{"kind":"italic_en","text":"'idáh"},{"kind":"text","text":"]; i. e., it only diminishes, without annulling, its author's recompense, like the beating off the leaves of the 'idáh, without cutting them down and extirpating them; for the leaves will grow again. (TA.) [See also art."},{"kind":"arabic","text_bw":"gbT","text_ar":"غبط"},{"kind":"text","text":".] ―         -b7-  Hence, (A, TA,)"},{"kind":"arabic","text_bw":"xabaTa Alqawoma bisayofihi","text_ar":"خَبَطَ القَوْمَ بِسَيْفِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He struck the people with his sword."},{"kind":"text","text":"(A, K, TA.) ―         -b8-"},{"kind":"arabic","text_bw":"xabaTahu Al$~ayoTaAnu","text_ar":"خَبَطَهُ الشَّيْطَانُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The devil touched him with a hurt,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"so as to corrupt him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorder him, and render him insane;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"txb~Thu","text_ar":"تخبّطهُ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) or the latter, [which is the more common,]"},{"kind":"italic_en","text":"the devil corrupted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered him:"},{"kind":"text","text":"(S, Mgh, Msb: *) lit.,"},{"kind":"italic_en","text":"struck him:"},{"kind":"text","text":"(Mgh, Msb:) or"},{"kind":"italic_en","text":"prostrated him, and sported with him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trampled upon him, and prostrated him."},{"kind":"text","text":"(TA.) It is said in the Kur [ii. 276], ↓"},{"kind":"arabic","text_bw":"laA yaquwmuwna A_il~aA kamaA yaquwmu A@l~a*iY yataxab~aTuhu","text_ar":"لَا يَقُومُونَ اـِلَّا كَمَا يَقُومُ ا@لَّذِى يَتَخَبَّطُهُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Al$~ayoTaAnu mina A@lomas~i","text_ar":"الشَّيْطَانُ مِنَ ا@لْمَسِّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"They shall not rise save as he riseth whom the devil prostrateth by reason of possession,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity"},{"kind":"text","text":"]; i. e., as he who is affected by diabolical possession rises, in his state of possession, when he is prostrated, and falls: or it means,"},{"kind":"italic_en","text":"whom the devil corrupts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorders, by rendering him insane."},{"kind":"text","text":"(K, * TA.) [You say also, of a drug,"},{"kind":"arabic","text_bw":"AlEaqola","text_ar":"العَقْلَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xb~T","text_ar":"خبّط","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It disordered the intellect:"},{"kind":"text","text":"see the act. part. n., below.] ―         -b9-"},{"kind":"arabic","text_bw":"xabaTa","text_ar":"خَبَطَ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"threw himself down"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"where he was,"},{"kind":"text","text":"(S, L,)"},{"kind":"italic_en","text":"to sleep,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"and slept."},{"kind":"text","text":"(L.) And (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"slept."},{"kind":"text","text":"(A' Obeyd, TA.) In the K,"},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"naAma","text_ar":"نَامَ"},{"kind":"text","text":". (TA.) ―         -b10-"},{"kind":"arabic","text_bw":"xabaTa EalaY AlbaAbi","text_ar":"خَبَطَ عَلَى البَابِ"},{"kind":"italic_en","text":"He knocked upon the door,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at the door."},{"kind":"text","text":"(TA.) ―         -b11-"},{"kind":"arabic","text_bw":"xabaTa","text_ar":"خَبَطَ"},{"kind":"arabic","text_bw":"AlEiroqu","text_ar":"العِرْقُ"},{"kind":"italic_en","text":"The vein beat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulsated."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","K","TA","M","T","MF","S","IB","IF","Lth","A","Mgh","L"]}]}}