{"lemma":"لَمَحاتٌ","slug":"لَمَحاتٌ","root":"ل.م.ح","root_slug":"ل-م-ح","root_link":"/words/roots/ل-م-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n37974","n37979"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D9%85%D9%8E%D8%AD%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37974","headword_ar":"لَمَحَهُ","root":"lmH","body":[{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"lamaHa A_ilayohi","text_ar":"لَمَحَ اـِلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L, Msb, K), inf. n."},{"kind":"arabic","text_bw":"lamoHN","text_ar":"لَمْحٌ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"AlmH","text_ar":"المح","orth_type":"arrow"},{"kind":"text","text":", (L, K,) or ↓"},{"kind":"arabic","text_bw":"AlmHhu","text_ar":"المحهُ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb,) and ↓"},{"kind":"arabic","text_bw":"AltmHhu","text_ar":"التمحهُ","orth_type":"arrow"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He glanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took a light,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slight, look, at him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(S;) like"},{"kind":"arabic","text_bw":"lamaA^ahu","text_ar":"لَمَاَهُ"},{"kind":"text","text":"; (Nh;)"},{"kind":"italic_en","text":"snatched a sight of him"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it unawares:"},{"kind":"text","text":"(L, Msb, K;) or, accord. to some,"},{"kind":"arabic","text_bw":"lamaHa","text_ar":"لَمَحَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he looked;"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AlmHhu","text_ar":"المحهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"he made him to look;"},{"kind":"text","text":"but the former explanation is the more correct: or"},{"kind":"arabic","text_bw":"lamaHa","text_ar":"لَمَحَ"},{"kind":"text","text":"is only said of one looking"},{"kind":"italic_en","text":"from a distance."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"lamaHotuhu biAlbaSari","text_ar":"لَمَحْتُهُ بِالبَصَرِ"},{"kind":"italic_en","text":"I directed"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Saw~abotu","text_ar":"صَوَّبْتُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"my sight towards him."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"lamaHa AlbaSaru","text_ar":"لَمَحَ البَصَرُ"},{"kind":"italic_en","text":"The sight extended to a thing."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"lamaHa","text_ar":"لَمَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"lamoHN","text_ar":"لَمْحٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"lamaHaAnN","text_ar":"لَمَحَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"talomaAHN","text_ar":"تَلْمَاحٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(lightning, and a star,)"},{"kind":"italic_en","text":"shone; gleamed; glistened; i. q."},{"kind":"arabic","text_bw":"lamaEa","text_ar":"لَمَعَ"},{"kind":"text","text":". (S, K.)"}],"source_refs":["S","L","Msb","K"]},{"entry_id":"n37979","headword_ar":"لَمْحَةٌ","root":"lmH","body":[{"kind":"text","text":", subst. from"},{"kind":"arabic","text_bw":"lamaHa","text_ar":"لَمَحَ"},{"kind":"text","text":", (S, L,)"},{"kind":"italic_en","text":"A glance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slight look."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"lamoHapN","text_ar":"لَمْحَةٌ"},{"kind":"italic_en","text":"A shining, gleaming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistening,"},{"kind":"text","text":"of lightning. (S.) ―         -b3-"},{"kind":"arabic","text_bw":"fiY fulaAnK lamoHapN mino A^abiyhi","text_ar":"فِى فُلَانٍ لَمْحَةٌ مِنْ اَبِيهِ"},{"kind":"italic_en","text":"In such a one is a likeness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point of resemblance, to his father:"},{"kind":"text","text":"then they said"},{"kind":"arabic","text_bw":"mino Abyh","text_ar":"مِنْ ابيه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"malAmiHu","text_ar":"مَلامِحُ","orth_type":"arrow"},{"kind":"text","text":", (S,) signifying"},{"kind":"italic_en","text":"likenessess,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"points of resemblance;"},{"kind":"text","text":"forming an extr. pl., (S, K,) as though from another word than"},{"kind":"arabic","text_bw":"lamoHapN","text_ar":"لَمْحَةٌ"},{"kind":"text","text":": (S:) they did not say"},{"kind":"arabic","text_bw":"malomaHapN","text_ar":"مَلْمَحَةٌ"},{"kind":"text","text":". (TA.) ―         -b4-  ↓"},{"kind":"arabic","text_bw":"malaAmiHu","text_ar":"مَلَامِحُ","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"What appear of the beauties and defects of the face"},{"kind":"text","text":"(K) of a human being: or the"},{"kind":"italic_en","text":"parts thereof that are glanced at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"viewed lightly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quickly."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","L","K"]}]}}