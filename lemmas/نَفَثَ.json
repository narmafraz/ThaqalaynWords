sp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْفُثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفُثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفِثا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْفِثانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْفُثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفُثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفِثُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْفِثُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْفُثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْفِثْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَنْفُث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْفُث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْفِث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْفِث","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"نَفَثْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"نَفَثْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n40152"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D9%81%D9%8E%D8%AB%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cough out, to spit out"},{"pos":"verb","gloss":"to get rid of something"}]},"etymology":null,"ipa":["/na.fa.θa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40152","headword_ar":"نَفَثَ","root":"nfv","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafovN","text_ar":"نَفْثٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"nafavaAnN","text_ar":"نَفَثَانٌ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"He puffed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blew, without spitting:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he sputtered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blew forth a little spittle in minute scattered particles:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he spat:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"["},{"kind":"italic_en","text":"did as though he"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"spat without ejecting spittle:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafava fY AlEuqodapi","text_ar":"نَفَثَ فى العُقْدَةِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he spat, ejecting a little spittle, upon the knot,"},{"kind":"text","text":"in enchantment: (Msb:) or"},{"kind":"arabic","text_bw":"Aln~afovu","text_ar":"النَّفْثُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"like"},{"kind":"arabic","text_bw":"Aln~afoxu","text_ar":"النَّفْخُ"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"blowing, and less than"},{"kind":"arabic","text_bw":"Alt~afolu","text_ar":"التَّفْلُ"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"spitting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ejecting spittle from the mouth:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"like blowing, with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the emission of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"spittle:"},{"kind":"text","text":"(Keshsháf;) or"},{"kind":"italic_en","text":"like blowing,"},{"kind":"text","text":"as done in enchantment,"},{"kind":"italic_en","text":"without spittle:"},{"kind":"text","text":"the action, if accompanied by spittle, being termed"},{"kind":"arabic","text_bw":"Altfl","text_ar":"التفل"},{"kind":"text","text":": this is the most correct explanation: ('Ináyeh:) or"},{"kind":"italic_en","text":"gentle blowing without spittle:"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AlA*kAr","text_ar":"الاذكار"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"more than blowing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"like blowing; but less than spitting: sometimes without spittle,"},{"kind":"text","text":"thus differing from"},{"kind":"arabic","text_bw":"Altfl","text_ar":"التفل"},{"kind":"text","text":";"},{"kind":"italic_en","text":"and sometimes with a little spittle,"},{"kind":"text","text":"thus differing from"},{"kind":"arabic","text_bw":"Alnfx","text_ar":"النفخ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"the emitting wind from the mouth, together with a little spittle."},{"kind":"text","text":"(MF.) ―         -b2-"},{"kind":"arabic","text_bw":"laA bud~a","text_ar":"لَا بُدَّ"},{"kind":"arabic","text_bw":"lilomaSoduwri A^ano yanofiva","text_ar":"لِلْمَصْدُورِ اَنْ يَنْفِثَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who has a disease in his chest must spit"},{"kind":"text","text":"]. A proverb. (S.) ―         -b3-"},{"kind":"arabic","text_bw":"nafavahu mino fiyhi","text_ar":"نَفَثَهُ مِنْ فِيهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafovN","text_ar":"نَفْثٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He ejected it from his mouth."},{"kind":"text","text":"(Msb.) ―         -b4-  [Hence,]"},{"kind":"arabic","text_bw":"nafava All~`hu Al$~aYo'i fiY","text_ar":"نَفَثَ اللّٰهُ الشَّىْءِ فِى"},{"kind":"arabic","text_bw":"Alqalobi","text_ar":"القَلْبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"God cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, the thing into the heart."},{"kind":"text","text":"(Msb) ―         -b5-"},{"kind":"arabic","text_bw":"nafiva fiY ruwEiY ka*aA","text_ar":"نَفِثَ فِى رُوعِى كَذَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a thing was inspired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, into my mind."},{"kind":"text","text":"(A.) ―         -b6-"},{"kind":"arabic","text_bw":"nafava fiY ruwEiY","text_ar":"نَفَثَ فِى رُوعِى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the Holy Spirit [Gabriel])"},{"kind":"italic_en","text":"inspired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put, into my mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heart."},{"kind":"text","text":"(Nh, from a trad.) ―         -b7-  [You say,]"},{"kind":"arabic","text_bw":"lawo nafava Ealayoka fulaAnN qaT~araka","text_ar":"لَوْ نَفَثَ عَلَيْكَ فُلَانٌ قَطَّرَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If such a one blew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spat, upon thee, he would throw thee down upon thy side."},{"kind":"text","text":"]. Said to one who tries his strength with one superior to him. (A.) ―         -b8-"},{"kind":"arabic","text_bw":"nafava EalaY~a","text_ar":"نَفَثَ عَلَىَّ"},{"kind":"arabic","text_bw":"gaDabFA","text_ar":"غَضَبًا"},{"kind":"text","text":"as though meaning"},{"kind":"italic_en","text":"He blew at me by reason of the violence of his anger."},{"kind":"text","text":"(L.) [See also"},{"kind":"arabic","text_bw":"nafata","text_ar":"نَفَتَ"},{"kind":"text","text":".] ―         -b9-"},{"kind":"arabic","text_bw":"AlHay~apu tanofivu Als~am~a A_i*aA nakazato","text_ar":"الحَيَّةُ تَنْفِثُ السَّمَّ اـِذَا نَكَزَتْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The serpent ejects venom from its mouth when it inflicts a wound with its nose"},{"kind":"text","text":"]. (S.) ―         -b10-"},{"kind":"arabic","text_bw":"nafava","text_ar":"نَفَثَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wound)"},{"kind":"italic_en","text":"emitted"},{"kind":"text","text":"blood. (TA.) ―         -b11-  [From the blowing or spitting upon the knots:]"},{"kind":"arabic","text_bw":"nafavahu","text_ar":"نَفَثَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafovN","text_ar":"نَفْثٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He enchanted him."},{"kind":"text","text":"(Msb.) ―         -b12-"},{"kind":"arabic","text_bw":"nafavati Alqidoru","text_ar":"نَفَثَتِ القِدْرُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nafiyvN","text_ar":"نَفِيثٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nafovN","text_ar":"نَفْثٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The cooking-pot boiled:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"boiled, and threw forth what resembled arrows, by reason of the vehemence of its boiling."},{"kind":"text","text":"(Msb.) [See also"},{"kind":"arabic","text_bw":"nafatat","text_ar":"نَفَتَت"},{"kind":"text","text":".] It is when it begins to boil. (TA.)"}],"source_refs":["S","K","TA","Msb"]}]},"classical_definitions":null}