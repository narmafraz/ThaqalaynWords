ext":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, folded, folded up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"folded together,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"rolled up,"},{"kind":"text","text":"] quasi-pass. of"},{"kind":"arabic","text_bw":"TawaY","text_ar":"طَوَى"},{"kind":"text","text":"(S, K, TA) as signifying the contr. of"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":"; (TA;) as also ↓"},{"kind":"arabic","text_bw":"AiT~awaY","text_ar":"اِطَّوَى","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) of the measure"},{"kind":"arabic","text_bw":"AifotaEala","text_ar":"اِفْتَعَلَ"},{"kind":"text","text":", mentioned by Az and ISd. (TA.) See also 5. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AnTwY baTonuhu","text_ar":"انطوى بَطْنُهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His belly became lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lank"},{"kind":"text","text":"]; said of a camel, and of a sheep or goat. (JK voce"},{"kind":"arabic","text_bw":"AirotaqaY","text_ar":"اِرْتَقَى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"AinoTiwaA='u AlHa$aA","text_ar":"اِنْطِوَا=ءُ الحَشَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The state of being lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lank, in the belly"},{"kind":"text","text":"]. (S and TA voce"},{"kind":"arabic","text_bw":"A^axoTafa","text_ar":"اَخْطَفَ"},{"kind":"text","text":", q. v.) ―         -b3-  See also a verse cited in the first paragraph. ―         -b4-  [Hence also,]"},{"kind":"arabic","text_bw":"AnTwY EalaY AlHiqodi","text_ar":"انطوى عَلَى الحِقْدِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alwud~i","text_ar":"الوُدِّ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He conceived"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though he infolded"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the heart rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affection."},{"kind":"text","text":"(MA.) And"},{"kind":"arabic","text_bw":"AnTwY qalobuhu EalaY gil~K","text_ar":"انطوى قَلْبُهُ عَلَى غِلٍّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His heart conceived, as though it infolded, rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","K","TA"]}]},"classical_definitions":null}