ry_id":"n33849","headword_ar":"فَسَدَ","root":"fsd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, M, A, O, L, Msb, K, &c.,) which is the aor. commonly known, (TA,) and"},{"kind":"text","text":", (IDrd, M, O, L, K,) which is of weak authority; (IDrd, O, TA;) and"},{"kind":"arabic","text_bw":"fasuda","text_ar":"فَسُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, M, O, L, K;) inf. n."},{"kind":"arabic","text_bw":"fasaAdN","text_ar":"فَسَادٌ"},{"kind":"text","text":"(S. M, A, O, L, K) and"},{"kind":"arabic","text_bw":"fusuwdN","text_ar":"فُسُودٌ"},{"kind":"text","text":", (M, O, L, K,) the former being inf. n. of"},{"kind":"arabic","text_bw":"fasada","text_ar":"فَسَدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, A, O,) and so the latter, and the former being also inf. n. of"},{"kind":"arabic","text_bw":"fasuda","text_ar":"فَسُدَ"},{"kind":"text","text":", (O,) or the former is of"},{"kind":"arabic","text_bw":"fasuda","text_ar":"فَسُدَ"},{"kind":"text","text":"and the latter is of"},{"kind":"arabic","text_bw":"fasada","text_ar":"فَسَدَ"},{"kind":"text","text":", (TA,) or the former is a simple subst., and the latter is the inf. n.; (Msb;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, A, O) [and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bad, evil, corrupt, unsound, wrong, wrongful, improper, unrighteous, wicked, vitious, depraved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dishonest; devoid of virtue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"efficacy; in a corrupted, vitiated, perverted, marred, spoiled, injured, impaired, deteriorated, tainted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infected, state; in a state of disorder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disturbance, destruction, annihilation, consumption, waste,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruin;"},{"kind":"text","text":"(MA, KL, PS, &c.;) and so ↓"},{"kind":"arabic","text_bw":"Astfsd","text_ar":"استفسد","orth_type":"arrow"},{"kind":"text","text":": (KL:)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"SalaHa","text_ar":"صَلَحَ"},{"kind":"text","text":": (M, * L, K:)"},{"kind":"italic_en","text":"it became altered in its state"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the worse"},{"kind":"text","text":"]: and"},{"kind":"italic_en","text":"it became null, void, of no force,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no account;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it came to nought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished;"},{"kind":"text","text":"accord. to the explanation by most of the expositors of the ex. in the Kur xxi. 22. (MF.)"}],"source_refs":["TA","IDrd","M","O","L","K","S","A","KL"]}]}}