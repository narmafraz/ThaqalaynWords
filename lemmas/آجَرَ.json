mp","form":"تُؤْجِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُؤْجِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُؤْجِر","in_corpus":true,"count":20,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُؤْجِر","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُؤْجِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُؤْجِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤْجِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤْجِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤْجِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤْجِرُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤْجِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"آجَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"آجَرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤْجِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوجِر","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":98,"cross_references":{"qac":{"found":true,"lemma_key":"آجَرَ","root":"أجر","pos":"N","occurrence_count":105},"wiktextract":{"found":true,"entry_count":11,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n273","n274"],"search_url":"https://lanelexicon.com/?s=%D8%A2%D8%AC%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to reward, to pay, to compensate"},{"pos":"verb","gloss":"to hire, to rent out"},{"pos":"verb","gloss":"to serve for hire"},{"pos":"verb","gloss":"to let (someone, e. g. a slave) for hire"},{"pos":"verb","gloss":"to rent, to hire"},{"pos":"noun","gloss":"verbal noun of أَجَرَ (ʔajara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"wages, salary, pay, hire"},{"pos":"noun","gloss":"reward, recompense, requital, compensation"},{"pos":"noun","gloss":"gift, morning gift"},{"pos":"noun","gloss":"plural of أُجْرَة (ʔujra)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to pierce or to slit so as to drag along, to stab and hinder","examples":[{"text":"وَآخِرَ مِنْهُم أَجْرَرْتُ رُمْحِي\n وَفِي ٱلْبَجْلِيِّ مِعْبَلةٌ وَقِيعُ","english":"And the last of them I pierced with my spear\nAnd in al-bajlī was a sharpened arrowhead"}]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew אגר (agár, “to gather, to harvest”).\n\nCompare Hebrew אַגְרָה (agrá, “fee, toll”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n273","headword_ar":"اَجْرٌ","root":"Ajr","body":[{"kind":"italic_en","text":"A recompense, compensation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reward,"},{"kind":"text","text":"(S, K, &c.,)"},{"kind":"italic_en","text":"for what one has done;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"vawaAbN","text_ar":"ثَوَابٌ"},{"kind":"text","text":"; (S;) as also ↓"},{"kind":"arabic","text_bw":"A_ijaArapN","text_ar":"اـِجَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ajaArapN","text_ar":"اَجَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^NjaArapN","text_ar":"اٌجَارَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) of which three forms the first is the most generally known and the most chaste, (TA,) and ↓"},{"kind":"arabic","text_bw":"A^ujorapN","text_ar":"اُجْرَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or, as some say, there is a distinction between"},{"kind":"arabic","text_bw":"A^ajorN","text_ar":"اَجْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vawaAbN","text_ar":"ثَوَابٌ"},{"kind":"text","text":": El-'Eynee says, in the Expos. of El-Bukháree, that what is obtained by the fundamental practices of the law, and by obligatory religious services, is termed"},{"kind":"arabic","text_bw":"vwAb","text_ar":"ثواب"},{"kind":"text","text":"; and what is obtained by supererogatory acts of religion,"},{"kind":"arabic","text_bw":"Ajr","text_ar":"اجر"},{"kind":"text","text":"; for"},{"kind":"arabic","text_bw":"vwAb","text_ar":"ثواب"},{"kind":"text","text":"is properly a substitute for a thing itself; and"},{"kind":"arabic","text_bw":"Ajr","text_ar":"اجر"},{"kind":"text","text":", for the profit arising from a thing; though each is sometimes used in the sense of the other: (TA:) it is well known that"},{"kind":"arabic","text_bw":"Ajr","text_ar":"اجر"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a recompense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reward, from God to a man, for righteous conduct;"},{"kind":"text","text":"(MF;)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A_ijaArapN","text_ar":"اـِجَارَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"recompense, compensation, hire, pay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wages, from one man to another, for work;"},{"kind":"text","text":"(Mgh, MF;) and hence"},{"kind":"arabic","text_bw":"AlA^ajiyru","text_ar":"الاَجِيرُ"},{"kind":"text","text":"; (MF;) and ↓"},{"kind":"arabic","text_bw":"A^ujorapN","text_ar":"اُجْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"also has this latter signification, (Mgh, TA,) and is syn. with"},{"kind":"arabic","text_bw":"kiraA='N","text_ar":"كِرَا=ءٌ"},{"kind":"text","text":"; (S, Mgh, K;) [signifying likewise"},{"kind":"italic_en","text":"rent"},{"kind":"text","text":"for a house, and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"] but"},{"kind":"arabic","text_bw":"A^ajorN","text_ar":"اَجْرٌ"},{"kind":"text","text":"is used [sometimes] in the sense of"},{"kind":"arabic","text_bw":"A_ijaArapN","text_ar":"اـِجَارَةٌ"},{"kind":"text","text":"and in that of"},{"kind":"arabic","text_bw":"A^ujorapN","text_ar":"اُجْرَةٌ"},{"kind":"text","text":": (Msb:) the pl. of"},{"kind":"arabic","text_bw":"A^ajorN","text_ar":"اَجْرٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^ujuwrN","text_ar":"اُجُورٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"A=jaArN","text_ar":"ا=جَارٌ"},{"kind":"text","text":"; (K;) but the latter form was unknown to MF: (TA:) the pl. of ↓"},{"kind":"arabic","text_bw":"A^ujorapN","text_ar":"اُجْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^ajarN","text_ar":"اَجَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ujuraAtN","text_ar":"اُجُرَاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ujaraAtN","text_ar":"اُجَرَاتٌ"},{"kind":"text","text":". (Msb.) [One says,"},{"kind":"arabic","text_bw":"A^ajoruka Ealay All~`hi","text_ar":"اَجْرُكَ عَلَي اللّٰهِ"},{"kind":"italic_en","text":"Thy recompense is due from God."},{"kind":"text","text":"And, to console a person for the death of a relation or friend,"},{"kind":"arabic","text_bw":"EaZ~ama All~`hu A^ajoraka","text_ar":"عَظَّمَ اللّٰهُ اَجْرَكَ"},{"kind":"arabic","text_bw":"fiyhi","text_ar":"فِيهِ"},{"kind":"italic_en","text":"May God largely compensate thee for him!"},{"kind":"text","text":"i. e., for the loss of him.] By the expression"},{"kind":"arabic","text_bw":"A^ajorK kiriymK","text_ar":"اَجْرٍ كِرِيمٍ"},{"kind":"text","text":"in the Kur xxxvi. 10 is said to be meant"},{"kind":"italic_en","text":"Paradise."},{"kind":"text","text":"(TA.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"A dowry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nuptial gift; a gift that is given to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, a bride:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"A^ujuwrN","text_ar":"اُجُورٌ"},{"kind":"text","text":": so in the Kur xxxiii. 49 [&c.]. (TA.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"Praise; good fame."},{"kind":"text","text":"(K.) So, as some say, in the Kur xxix. 26. (TA.)"}],"source_refs":["K","TA","Mgh","Msb"]},{"entry_id":"n274","headword_ar":"اَجُرٌّ","root":"Ajr","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ujurN","text_ar":"اُجُرٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=jur~N","text_ar":"ا=جُرٌّ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}