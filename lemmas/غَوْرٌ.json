{"lemma":"غَوْرٌ","slug":"غَوْرٌ","root":"غ.#.ر","root_slug":"غ-_-ر","root_link":"/words/roots/غ-_-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"غَوْر","root":"غور","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n32611"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%88%D9%92%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of غَارَ (ḡāra) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"depression, sunken place, bottom, low part"},{"pos":"noun","gloss":"deepness in thought","tags":["figuratively"]},{"pos":"verb","gloss":"synonym of غَارَ (ḡāra, “to descend, to enter in a state of depression; to seep away”)","tags":["intransitive"]},{"pos":"verb","gloss":"to make depressed, to make enter a low position","tags":["transitive"]},{"pos":"verb","gloss":"to palatalize"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32611","headword_ar":"غَوْرٌ","root":"gwr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"bottom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest part,"},{"kind":"text","text":"of anything; (S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"gaworaY","text_ar":"غَوْرَى","orth_type":"arrow"},{"kind":"text","text":": (K:) and its"},{"kind":"italic_en","text":"depth."},{"kind":"text","text":"(TA.) ―         -b2-  You say,"},{"kind":"arabic","text_bw":"Earafotu gawora h`*ihi AlmasoA^alapi","text_ar":"عَرَفْتُ غَوْرَ هٰذِهِ المَسْاَلَةِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I have become acquainted with the bottom of this question"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"fulaAnN baEiydu Algawori","text_ar":"فُلَانٌ بَعِيدُ الغَوْرِ"},{"kind":"text","text":"(S) (tropical:)"},{"kind":"italic_en","text":"Such a one is deep and excellent in judgment; one who examines deeply."},{"kind":"text","text":"(TA.) [See also 1.] And"},{"kind":"arabic","text_bw":"hawa baHorN laA yudoraku gaworuhu","text_ar":"هَوَ بَحْرٌ لَا يُدْرَكُ غَوْرُهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is a sea whereof the bottom shall not be reached"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"mano","text_ar":"مَنْ"},{"kind":"arabic","text_bw":"A^aboEadu gaworFA fiY AlbaATili min~iY","text_ar":"اَبْعَدُ غَوْرًا فِى البَاطِلِ مِنِّى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Who is deeper in knowledge with respect to what is vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false, than I?"},{"kind":"text","text":"]. (TA, from a trad.) ―         -b3-"},{"kind":"italic_en","text":"Low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, land, country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground;"},{"kind":"text","text":"(S, Msb, K;) [like"},{"kind":"arabic","text_bw":"xaworN","text_ar":"خَوْرٌ"},{"kind":"text","text":";] as also ↓"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"gaArN","text_ar":"غَارٌ"},{"kind":"text","text":", in the first of its senses expl. above.       -A2-  Applied to water,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"gaAy^irN","text_ar":"غَايِرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Sinking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going away, into the ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth"},{"kind":"text","text":"]: (S, K:) an inf. n. used as an epithet, like"},{"kind":"arabic","text_bw":"maA='N sakobN","text_ar":"مَا=ءٌ سَكْبٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"dirohamN DarobN","text_ar":"دِرْهَمٌ ضَرْبٌ"},{"kind":"text","text":". (S.)"}],"source_refs":["K","S"]}]},"classical_definitions":null}