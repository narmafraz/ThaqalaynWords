{"lemma":"عَطْفُ","slug":"عَطْفُ","root":"ع.ط.ف","root_slug":"ع-ط-ف","root_link":"/words/roots/ع-ط-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"عَطْفُ","root":"عطف","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n29576","","n29579","n29580","n29581"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B7%D9%92%D9%81%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to incline, to sympathize"},{"pos":"verb","gloss":"to be benevolent, to be favourable (+ عَلَى)"}]},"etymology":null,"ipa":["/ʕa.tˤa.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29576","headword_ar":"عَطَفَ","root":"ETf","body":[{"kind":"text","text":", (S, Mgh, O, Msb, K,) aor."},{"kind":"text","text":", (O, K,) inf. n."},{"kind":"arabic","text_bw":"EuTuwfN","text_ar":"عُطُوفٌ"},{"kind":"text","text":", (Mgh, Msb,) or"},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":", (O, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(a man, S, O, or a thing, Msb,)"},{"kind":"italic_en","text":"inclined;"},{"kind":"text","text":"(S, Mgh, O, Msb, K;) or"},{"kind":"italic_en","text":"bent:"},{"kind":"text","text":"(MF, TA:) and ↓"},{"kind":"arabic","text_bw":"AnETf","text_ar":"انعطف","orth_type":"arrow"},{"kind":"text","text":"also has the former meaning, (Mgh, Msb, * TA,) as in the saying"},{"kind":"arabic","text_bw":"AnETf naHowahu","text_ar":"انعطف نَحْوَهُ"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, inclined towards him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(TA;)"},{"kind":"page_break","n":2080},{"kind":"text","text":"[or the latter meaning;] or"},{"kind":"italic_en","text":"it became inclined,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"became bent,"},{"kind":"text","text":"(S, * O, Msb, K,) or"},{"kind":"italic_en","text":"both,"},{"kind":"text","text":"(TA,) as quasi-pass. of"},{"kind":"arabic","text_bw":"EaTafahu","text_ar":"عَطَفَهُ"},{"kind":"text","text":"; (S, O, Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"tET~f","text_ar":"تعطّف","orth_type":"arrow"},{"kind":"text","text":"likewise has both of these meanings, as quasi-pass. of"},{"kind":"arabic","text_bw":"ET~fhu","text_ar":"عطّفهُ"},{"kind":"text","text":", or [signifies"},{"kind":"italic_en","text":"it became much inclined"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"bent,"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"ET~f","text_ar":"عطّف"},{"kind":"text","text":"is with teshdeed to denote muchness. (TA.) ―         -b2-  Hence, (MF, TA,)"},{"kind":"arabic","text_bw":"EaTafa Ealayohi","text_ar":"عَطَفَ عَلَيْهِ"},{"kind":"text","text":", (S, Mgh, MA, O, K,) [aor. as above,] inf. n."},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":"; (MA, MF, TA;) and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tET~f","text_ar":"تعطّف","orth_type":"arrow"},{"kind":"text","text":"; (S, MA, O, K;) [and ↓"},{"kind":"arabic","text_bw":"AnETf","text_ar":"انعطف","orth_type":"arrow"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":";] (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, favourably inclined towards him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affectionate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind, to him;"},{"kind":"text","text":"(MA, PS;)"},{"kind":"italic_en","text":"he regarded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"treated him, with mercy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion;"},{"kind":"text","text":"(MA, Mgh;) because in mercy, or pity, or compassion, is an inclining towards its object; (Mgh;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^a$ofaqa","text_ar":"اَشْفَقَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"; (S, O, K;) and"},{"kind":"arabic","text_bw":"waSalahu","text_ar":"وَصَلَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bar~ahu","text_ar":"بَرَّهُ"},{"kind":"text","text":". (TA in explanation of the second.) And"},{"kind":"arabic","text_bw":"EaTafato EalaY","text_ar":"عَطَفَتْ عَلَى"},{"kind":"arabic","text_bw":"waladihaA","text_ar":"وَلَدِهَا"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":", said of a she camel, (assumed tropical:)"},{"kind":"italic_en","text":"She became favourably inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassionate, towards her young one, and yielded her milk;"},{"kind":"text","text":"(Msb;) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tET~ft","text_ar":"تعطّفت","orth_type":"arrow"},{"kind":"text","text":"[signifies the same, or"},{"kind":"italic_en","text":"she was made to incline to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to affect him"},{"kind":"text","text":"]. (M in art."},{"kind":"arabic","text_bw":"rA^m","text_ar":"رام"},{"kind":"text","text":", &c) ―         -b3-"},{"kind":"arabic","text_bw":"EaTafa Ealayohi","text_ar":"عَطَفَ عَلَيْهِ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returned, against him:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he charged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made an assault"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attack, upon him,"},{"kind":"text","text":"[in battle,]"},{"kind":"italic_en","text":"and turned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"returned, against him:"},{"kind":"text","text":"(O, K:) or"},{"kind":"italic_en","text":"he returned against him with that which he disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"to him with that which he desired."},{"kind":"text","text":"(L, referring to a verse of Aboo-Wejzeh Es-Saadee cited in art."},{"kind":"arabic","text_bw":"Hyn","text_ar":"حين"},{"kind":"text","text":", q. v.) ―         -b4-  And"},{"kind":"arabic","text_bw":"EaTafa","text_ar":"عَطَفَ"},{"kind":"text","text":", aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":", (K, TA,) signifies also"},{"kind":"italic_en","text":"He turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back."},{"kind":"text","text":"(K, * TA.) ―         -b5-  And [hence,]"},{"kind":"arabic","text_bw":"EaTafa Eanohu","text_ar":"عَطَفَ عَنْهُ"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"the contr. of"},{"kind":"arabic","text_bw":"EaTafa Ealayohi","text_ar":"عَطَفَ عَلَيْهِ"},{"kind":"text","text":"in the first of the senses assigned to this latter above [i. e. it signifies (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, averse from him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disaffected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unkind, to him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unmerciful, unpitying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncompassionate, to him"},{"kind":"text","text":"]. (MF, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"EuTuwfN","text_ar":"عُطُوفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":"[as intrans. inf. ns.] also signify A sheep's, or goat's,"},{"kind":"italic_en","text":"bending the neck, not by reason of an ailment."},{"kind":"text","text":"(TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":"[app. likewise as an intrans. inf. n.] also signifies The"},{"kind":"italic_en","text":"folding of the extremities of the skirt, of the facing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outer side, upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"against, the lining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inner side."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"EaTafahu","text_ar":"عَطَفَهُ"},{"kind":"text","text":", (Mgh, Msb, TA,) [aor. as above,] inf. n."},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":", (Mgh, Msb,)"},{"kind":"italic_en","text":"He inclined it;"},{"kind":"text","text":"(Mgh, Msb, TA;) namely, a thing; (Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"AstETfhu","text_ar":"استعطفهُ","orth_type":"arrow"},{"kind":"text","text":": (Mgh:) or"},{"kind":"italic_en","text":"he bent it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubled it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"folded it:"},{"kind":"text","text":"(Msb:) or it signifies also"},{"kind":"italic_en","text":"he bent it:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"ET~fhu","text_ar":"عطّفهُ","orth_type":"arrow"},{"kind":"text","text":"likewise, inf. n."},{"kind":"arabic","text_bw":"taEoTiyfN","text_ar":"تَعْطِيفٌ"},{"kind":"text","text":", has both of these meanings: (TA:) or this latter verb is with teshdeed to denote muchness [of the action], or multiplicity [of the objects]: (S, O, TA:) you say,"},{"kind":"arabic","text_bw":"EaTafotu AlEuwda","text_ar":"عَطَفْتُ العُودَ"},{"kind":"text","text":"(S)"},{"kind":"italic_en","text":"I bent"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"inclined"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of wood:"},{"kind":"text","text":"(MA, PS:) and"},{"kind":"arabic","text_bw":"AlEiydaAna","text_ar":"العِيدَانَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaT~afotu","text_ar":"عَطَّفْتُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, the sticks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieces of wood"},{"kind":"text","text":"]: (S, O:) and"},{"kind":"arabic","text_bw":"zaA^osa Alxa$abapi","text_ar":"زَاْسَ الخَشَبَةِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaT~afotu","text_ar":"عَطَّفْتُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined, much, the head of the piece of wood"},{"kind":"text","text":"]. (TA.) One says of a she-gazelle,"},{"kind":"arabic","text_bw":"taEoTifu jiydahaA A_i*aA rabaDato","text_ar":"تَعْطِفُ جِيدَهَا اـِذَا رَبَضَتْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"She inclines,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bends, her neck when she lies down on her breast"},{"kind":"text","text":"]. (O, K.) And one says,"},{"kind":"arabic","text_bw":"EaTafa raA^osa","text_ar":"عَطَفَ رَاْسَ"},{"kind":"arabic","text_bw":"baEiyrihi A_ilayohi","text_ar":"بَعِيرِهِ اـِلَيْهِ"},{"kind":"italic_en","text":"He inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned aside, the head of his camel towards him;"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"naAqatahu","text_ar":"نَاقَتَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstETf","text_ar":"استعطف","orth_type":"arrow"},{"kind":"italic_en","text":"He turned aside his she-camel"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EaTafahaA","text_ar":"عَطَفَهَا"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by pulling her nose-rein in order that she should incline her head."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"EaTafa AlwisaAdapa","text_ar":"عَطَفَ الوِسَادَةَ"},{"kind":"text","text":", (S, O, K,) aor. and inf. n. as above; (O;) and ↓"},{"kind":"arabic","text_bw":"EaT~afahaA","text_ar":"عَطَّفَهَا","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doubled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"folded, the pillow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cushion,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"when leaning with his elbow upon it."},{"kind":"text","text":"(O.) ―         -b2-  And [hence] one says,"},{"kind":"arabic","text_bw":"EaTafa A@ll~`hu biqalobi Als~uloTaAni","text_ar":"عَطَفَ ا@للّٰهُ بِقَلْبِ السُّلْطَانِ"},{"kind":"arabic","text_bw":"EalY riEay~athi","text_ar":"عَلى رِعَيَّتهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"God made the heart of the Sultán,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ruling power, to be favourably inclined towards his subjects; to regard them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"treat them, with mercy."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"EaTafatoka Ealayohimu Alr~aHimu","text_ar":"عَطَفَتْكَ عَلَيْهِمُ الرَّحِمُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The feeling of relationship,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consanguinity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the sympathy of blood, caused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hath caused, thee to be favourably inclined towards them;"},{"kind":"text","text":"&c.]. (Ham p. 765.) And"},{"kind":"arabic","text_bw":"EaTafa Aln~aAqapa EalaY waladihaA","text_ar":"عَطَفَ النَّاقَةَ عَلَى وَلَدِهَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He made the she-camel to incline to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affect, her young one"},{"kind":"text","text":"]. (M in art."},{"kind":"arabic","text_bw":"rA^m","text_ar":"رام"},{"kind":"text","text":"; &c.: see also"},{"kind":"arabic","text_bw":"liqaAHN muEaT~afapN","text_ar":"لِقَاحٌ مُعَطَّفَةٌ"},{"kind":"text","text":"in this art.) And"},{"kind":"arabic","text_bw":"tuEoTafu EalaY Albaw~i","text_ar":"تُعْطَفُ عَلَى البَوِّ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"is made to incline to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affect, the stuffed skin of a young unweaned camel"},{"kind":"text","text":"in order that she may yield her milk, when her young one has died]. (S, O, [See"},{"kind":"arabic","text_bw":"EaTuwfN","text_ar":"عَطُوفٌ"},{"kind":"text","text":".]) ―         -b3-  And"},{"kind":"arabic","text_bw":"EaTafotuhu Eano HaAjatihi","text_ar":"عَطَفْتُهُ عَنْ حَاجَتِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I turned him away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, from his object of want."},{"kind":"text","text":"(Msb.) ―         -b4-  And"},{"kind":"arabic","text_bw":"EaTofu Almudomaji","text_ar":"عَطْفُ المُدْمَجِ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"AlqidoHi","text_ar":"القِدْحِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The turning round about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shuffling, of the gaming-arrow."},{"kind":"text","text":"(S voce"},{"kind":"arabic","text_bw":"mudomajN","text_ar":"مُدْمَجٌ"},{"kind":"text","text":": see a verse there cited.)"}],"source_refs":["S","Mgh","O","Msb","K","TA","MF","MA","PS"]},{"entry_id":"n29579","headword_ar":"عَطْفٌ","root":"ETf","body":[{"kind":"text","text":": see the next paragraph, last sentence, in two places. ―         -b2-  [It is used in grammar as meaning"},{"kind":"italic_en","text":"Adjunction"},{"kind":"text","text":"to an antecedent: this is of two kinds;"},{"kind":"arabic","text_bw":"EaTofu AlbayaAni","text_ar":"عَطْفُ البَيَانِ"},{"kind":"italic_en","text":"the explicative adjunction,"},{"kind":"text","text":"as in"},{"kind":"arabic","text_bw":"jaA='a A^axuwka zayodN","text_ar":"جَا=ءَ اَخُوكَ زَيْدٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"EaTofu Aln~asaqi","text_ar":"عَطْفُ النَّسَقِ"},{"kind":"italic_en","text":"the ordinal adjunction,"},{"kind":"text","text":"as in"},{"kind":"arabic","text_bw":"jaA='a zayodN waEamorNw","text_ar":"جَا=ءَ زَيْدٌ وَعَمْرٌو"},{"kind":"text","text":": (in each of which instances the latter noun is termed ↓"},{"kind":"arabic","text_bw":"maEoTuwfN","text_ar":"مَعْطُوفٌ","orth_type":"arrow"},{"kind":"text","text":"; and the former noun"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maEoTuwfN","text_ar":"مَعْطُوفٌ","orth_type":"arrow"},{"kind":"text","text":":) and hence,"},{"kind":"arabic","text_bw":"Harofu EaTofK","text_ar":"حَرْفُ عَطْفٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"a particle of adjunction;"},{"kind":"text","text":"or what we commonly call"},{"kind":"italic_en","text":"a conjunction;"},{"kind":"text","text":"(as"},{"kind":"arabic","text_bw":"wa","text_ar":"وَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vum~a","text_ar":"ثُمَّ"},{"kind":"text","text":", &c.;) also termed ↓"},{"kind":"arabic","text_bw":"HarofN EaATifN","text_ar":"حَرْفٌ عَاطِفٌ","orth_type":"arrow"},{"kind":"italic_en","text":"an adjunctive particle."},{"kind":"text","text":"]"}],"source_refs":[]},{"entry_id":"n29580","headword_ar":"عِطْفٌ","root":"ETf","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of a human being,"},{"kind":"italic_en","text":"from the head to the hip,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the foot:"},{"kind":"text","text":"(Mgh:) and the"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of a thing: (Msb:) or the dual signifies the"},{"kind":"italic_en","text":"two sides"},{"kind":"text","text":"of a man,"},{"kind":"italic_en","text":"from the part next the head to the hips:"},{"kind":"text","text":"(S, O:) and the"},{"kind":"italic_en","text":"two sides of the neck"},{"kind":"text","text":"of a man: (TA:) and the"},{"kind":"italic_en","text":"two sides"},{"kind":"text","text":"of anything: (S, O, K:) as relating to a man, (TA,) or a thing. (Msb,) the pl. is"},{"kind":"arabic","text_bw":"A^aEoTaAfN","text_ar":"اَعْطَافٌ"},{"kind":"text","text":", [properly a pl. of pane.,] (Msb, TA,) and, as relating to a man,"},{"kind":"arabic","text_bw":"EiTaAfN","text_ar":"عِطَافٌ"},{"kind":"text","text":"also, and"},{"kind":"arabic","text_bw":"EuTuwfN","text_ar":"عُطُوفٌ"},{"kind":"text","text":". (TA.) Hence the phrase,"},{"kind":"arabic","text_bw":"humo","text_ar":"هُمْ"},{"kind":"arabic","text_bw":"A^aloyanu EiTofFA","text_ar":"اَلْيَنُ عِطْفًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They are more pliant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pliable;"},{"kind":"text","text":"properly as meaning"},{"kind":"italic_en","text":"flexible, supple, lithe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limber;"},{"kind":"text","text":"but app. here used tropically, as meaning"},{"kind":"italic_en","text":"compliant:"},{"kind":"text","text":"compare"},{"kind":"arabic","text_bw":"lay~inu AljaAnibi","text_ar":"لَيِّنُ الجَانِبِ"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"lay~inu AlA^aEoTaAfi","text_ar":"لَيِّنُ الاَعْطَافِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Pliant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pliable,"},{"kind":"text","text":"&c.], applied to a horse: (En-Nadr, TA voce"},{"kind":"arabic","text_bw":"guwojN","text_ar":"غُوْجٌ"},{"kind":"text","text":": [see also"},{"kind":"arabic","text_bw":"EaAjN","text_ar":"عَاجٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"Ewj","text_ar":"عوج"},{"kind":"text","text":":]) and ↓"},{"kind":"arabic","text_bw":"saholu AlmaEoTifi","text_ar":"سَهْلُ المَعْطِفِ","orth_type":"arrow"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"AlmaEaATifi","text_ar":"المَعَاطِفِ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlA^aEoTaAfi","text_ar":"الاَعْطَافِ"},{"kind":"text","text":", which signify the same,] so applied. (S and O and TA voce"},{"kind":"arabic","text_bw":"gawojN","text_ar":"غَوْجٌ"},{"kind":"text","text":".) And [hence, also,] one says,"},{"kind":"arabic","text_bw":"vanaY Ean~iY EiTofahu","text_ar":"ثَنَى عَنِّى عِطْفَهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He bent from me his side"},{"kind":"text","text":"], meaning"},{"kind":"italic_en","text":"he turned away from me."},{"kind":"text","text":"(S, O, K.) And"},{"kind":"arabic","text_bw":"jaA='a vaAniYa EiTofihi","text_ar":"جَا=ءَ ثَانِىَ عِطْفِهِ"},{"kind":"italic_en","text":"He came in an unstraitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pleasant and plentiful, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition:"},{"kind":"text","text":"(O, K:) or (K)"},{"kind":"arabic","text_bw":"vaAniYa EiTofihi","text_ar":"ثَانِىَ عِطْفِهِ"},{"kind":"text","text":"in the Kur [xxii. 9] means (O)"},{"kind":"italic_en","text":"twisting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bending, his neck:"},{"kind":"text","text":"(O, K:) or (K)"},{"kind":"italic_en","text":"magnifying himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaving proudly, and turning away"},{"kind":"text","text":"(O, K)"},{"kind":"italic_en","text":"from El-Islám."},{"kind":"text","text":"(O.) And"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"yanoZuru fiY EiTofayohi","text_ar":"يَنْظُرُ فِى عِطْفَيْهِ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"Such a one looks at his sides"},{"kind":"text","text":"], meaning,"},{"kind":"italic_en","text":"is self-conceited."},{"kind":"text","text":"(IDrd, O, K. *) ―         -b2-"},{"kind":"page_break","n":2081},{"kind":"text","text":"Also The"},{"kind":"italic_en","text":"armpit"},{"kind":"text","text":"(Az, O, K, TA) of a man: and his"},{"kind":"italic_en","text":"shoulder:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"EuTuwfN","text_ar":"عُطُوفٌ"},{"kind":"text","text":". (Az, TA.) ―         -b3-  And The"},{"kind":"italic_en","text":"curved part of each of the two extremities"},{"kind":"text","text":"of the bow; (O, K, TA;) the two being called its"},{"kind":"arabic","text_bw":"EiTofaAni","text_ar":"عِطْفَانِ"},{"kind":"text","text":". (TA.) One says,"},{"kind":"arabic","text_bw":"taEaw~aja Alqawosu fiY EiTofayohi","text_ar":"تَعَوَّجَ القَوْسُ فِى عِطْفَيْهِ"},{"kind":"text","text":", (O, TA,) in the copies of the K,"},{"kind":"arabic","text_bw":"taEar~aja Alfarasu fiY","text_ar":"تَعَرَّجَ الفَرَسُ فِى"},{"kind":"arabic","text_bw":"EiTofayohi","text_ar":"عِطْفَيْهِ"},{"kind":"text","text":", but the former is the right, (TA,) meaning ["},{"kind":"italic_en","text":"The bow"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"bent to the right and left"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the two curved parts of its extremities"},{"kind":"text","text":"]. (O, K, TA.) ―         -b4-  One says also,"},{"kind":"arabic","text_bw":"tanaH~a Eano EiTofi AlT~ariyqi","text_ar":"تَنَحَّ عَنْ عِطْفِ الطَّرِيقِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Go thou aside from"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the beaten track of the road;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaTofihi","text_ar":"عَطْفِهِ","orth_type":"arrow"},{"kind":"text","text":": (IAar, O, K:) or ↓"},{"kind":"arabic","text_bw":"EaTofN","text_ar":"عَطْفٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a bending"},{"kind":"text","text":"(Mgh, Msb) in a street (Mgh) or road, (Msb,) being an inf. n. used as a simple subst.; but the"},{"kind":"arabic","text_bw":"EiTof","text_ar":"عِطْف"},{"kind":"text","text":"in a street [or road] is ["},{"kind":"italic_en","text":"a bent part,"},{"kind":"text","text":"being] of the measure"},{"kind":"arabic","text_bw":"fiEolN","text_ar":"فِعْلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":". (Mgh. [See similar instances voce"},{"kind":"arabic","text_bw":"*iboHN","text_ar":"ذِبْحٌ"},{"kind":"text","text":".])"}],"source_refs":["Mgh","Msb","S","O","TA","K","Az","IAar"]},{"entry_id":"n29581","headword_ar":"عَطَفٌ","root":"ETf","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaTafapN","text_ar":"عَطَفَةٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"Length of the edges of the eyelids,"},{"kind":"text","text":"(O, K, TA,)"},{"kind":"italic_en","text":"and a bending"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"upwards"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thereof:"},{"kind":"text","text":"(TA:) occurring in a trad.: or the word, as some relate it, is"},{"kind":"arabic","text_bw":"gaTafN","text_ar":"غَطَفٌ"},{"kind":"text","text":"[q. v.]; (O, TA;) which is of higher authority. (TA.)"}],"source_refs":["O","K","TA"]}]}}