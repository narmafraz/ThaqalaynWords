":"and ↓"},{"kind":"arabic","text_bw":"riHolapK","text_ar":"رِحْلَةٍ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"miroHalN","text_ar":"مِرْحَلٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"minobarN","text_ar":"مِنْبَرٌ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"muroHilN","text_ar":"مُرْحِلٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"raHiylN","text_ar":"رَحِيلٌ","orth_type":"arrow"},{"kind":"text","text":", so in the T, (TA,)"},{"kind":"italic_en","text":"A strong he-camel:"},{"kind":"text","text":"(T, K:) and (so in the K [but properly “ or ”])"},{"kind":"arabic","text_bw":"bEyr *w ruHolapK","text_ar":"بعير ذو رُحْلَةٍ"},{"kind":"text","text":"(CK) or ↓"},{"kind":"arabic","text_bw":"riHolapK","text_ar":"رِحْلَةٍ","orth_type":"arrow"},{"kind":"text","text":"(K accord. to the TA) or both, and ↓"},{"kind":"arabic","text_bw":"miroHalN","text_ar":"مِرْحَلٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"(O,) and ↓"},{"kind":"arabic","text_bw":"jamalN raHiylN","text_ar":"جَمَلٌ رَحِيلٌ","orth_type":"arrow"},{"kind":"text","text":", (AA, S, S, O, K, TA,) and ↓"},{"kind":"arabic","text_bw":"naAqapN raHiylapN","text_ar":"نَاقَةٌ رَحِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, O) or"},{"kind":"arabic","text_bw":"raHiylN","text_ar":"رَحِيلٌ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"*aAtu ruHolapK","text_ar":"ذَاتُ رُحْلَةٍ"},{"kind":"text","text":", (S,) a"},{"kind":"italic_en","text":"he-camel,"},{"kind":"text","text":"(S, O, K,) and"},{"kind":"italic_en","text":"a she-camel,"},{"kind":"text","text":"(S, O,)"},{"kind":"italic_en","text":"strong to journey;"},{"kind":"text","text":"(S, O, K, TA;) so says Fr: (O:) or"},{"kind":"italic_en","text":"strong to be saddled:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"naAqapN raHiylapN","text_ar":"نَاقَةٌ رَحِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raHiylN","text_ar":"رَحِيلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muroHilapN","text_ar":"مُرْحِلَةٌ","orth_type":"arrow"},{"kind":"text","text":", accord. to the “ Nawádir el-Aaráb, ”"},{"kind":"italic_en","text":"a she-camel that is excellent, generous, of high breed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong, light, and swift;"},{"kind":"text","text":"(TA;) and so ↓"},{"kind":"arabic","text_bw":"musotaroHilapN","text_ar":"مُسْتَرْحِلَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA. [See also"},{"kind":"arabic","text_bw":"raAHilapN","text_ar":"رَاحِلَةٌ"},{"kind":"text","text":".]) ―         -b2-  See also the next paragraph, in seven places."}],"source_refs":["TA","K","T","CK","O","AA","S"]},{"entry_id":"n15054","headword_ar":"رِحْلَةٌ","root":"rHl","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"act of saddling"},{"kind":"text","text":"of camels: (K, * TA:) [and also, agreeably with analogy,"},{"kind":"italic_en","text":"a mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of saddling"},{"kind":"text","text":"of camels:] so in the saying,"},{"kind":"arabic","text_bw":"A_in~ahu laHasanu Alr~iHolapi","text_ar":"اـِنَّهُ لَحَسَنُ الرِّحْلَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily he is good in respect of the saddling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the mode"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner of saddling,"},{"kind":"text","text":"of camels]. (K.) ―         -b2-  Also"},{"kind":"italic_en","text":"A removal, departure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journey;"},{"kind":"text","text":"(AZ, S, Msb, K;) and so ↓"},{"kind":"arabic","text_bw":"ruHolapN","text_ar":"رُحْلَةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"raHiylN","text_ar":"رَحِيلٌ","orth_type":"arrow"},{"kind":"text","text":": (S, K: [the last said in the Msb to be and inf. n.:]) you say"},{"kind":"arabic","text_bw":"danato","text_ar":"دَنَتْ"},{"kind":"arabic","text_bw":"riHolatunaA","text_ar":"رِحْلَتُنَا"},{"kind":"text","text":"(S) or"},{"kind":"arabic","text_bw":"qarubato riHolatunaA","text_ar":"قَرُبَتْ رِحْلَتُنَا"},{"kind":"text","text":"(Msb) ["},{"kind":"italic_en","text":"Our removal,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has drawn near"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"A_in~ahu","text_ar":"اـِنَّهُ"},{"kind":"arabic","text_bw":"la*uw riHolapK A_ilaY Almuluwki","text_ar":"لَذُو رِحْلَةٍ اـِلَى المُلُوكِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"riHolap","text_ar":"رِحْلَة","orth_type":"arrow"},{"kind":"italic_en","text":"Verily he is one who journeys,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has journeyed, to the kings:"},{"kind":"text","text":"(Lh, TA:) and in like manner"},{"kind":"arabic","text_bw":"ruHolapN","text_ar":"رُحْلَةٌ"},{"kind":"text","text":"is used in the Kur cvi. 2: (TA:) ―         -b3-  or ↓"},{"kind":"arabic","text_bw":"riHolapN","text_ar":"رِحْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"with damm, (S, Msb, K,) signifies The"},{"kind":"italic_en","text":"thing to which one removes, departs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journeys;"},{"kind":"text","text":"(AZ, Msb;) or the"},{"kind":"italic_en","text":"direction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"object, to which one desires to repair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betakes himself:"},{"kind":"text","text":"(AA, S, Msb, K:) and also, (K,) or"},{"kind":"arabic","text_bw":"ruHolapN","text_ar":"رُحْلَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"a single journey;"},{"kind":"text","text":"(K, TA;) as ISd says: (TA:) you say, ↓"},{"kind":"arabic","text_bw":"mak~apu ruHolatiY","text_ar":"مَكَّةُ رُحْلَتِى","orth_type":"arrow"},{"kind":"italic_en","text":"Mekkeh is the point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"object, to which I desire to remove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journey:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"A^anotumo ruHolatiY","text_ar":"اَنْتُمْ رُحْلَتِى","orth_type":"arrow"},{"kind":"italic_en","text":"Ye are they to whom I remove,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"journey:"},{"kind":"text","text":"(S, TA:) and ↓"},{"kind":"arabic","text_bw":"A^anota ruHolatunaA","text_ar":"اَنْتَ رُحْلَتُنَا","orth_type":"arrow"},{"kind":"italic_en","text":"Thou art the object to which we repair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betake ourselves."},{"kind":"text","text":"(Msb.) And hence ↓"},{"kind":"arabic","text_bw":"ruHolapN","text_ar":"رُحْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"is applied to signify"},{"kind":"italic_en","text":"A noble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an exalted, person,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a great man of learning, to whom one journeys for his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the latter's"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"need,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"want, or for his"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the former's"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"science."},{"kind":"text","text":"(TA.) ―         -b4-  See also the next preceding paragraph, in three places."}],"source_refs":["Lh","Msb","K","S","TA","AA"]}]}}