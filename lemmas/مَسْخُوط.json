{"lemma":"مَسْخُوط","slug":"مَسْخُوط","root":"س.خ.ط","root_slug":"س-خ-ط","root_link":"/words/roots/س-خ-ط","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n19210"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B3%D9%92%D8%AE%D9%8F%D9%88%D8%B7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"passive participle of سَخِطَ (saḵiṭa)","tags":["form-of","participle","passive"]}]},"etymology":{"source":"wiktextract","text":"Derived from the passive participle of the verb سَخِطَ (saḵiṭa, “to become angry”)."},"ipa":["/mas.xuːtˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19210","headword_ar":"مَسْخُوطٌ","root":"sxT","body":[{"kind":"italic_en","text":"Disliked, disapproved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated:"},{"kind":"text","text":"(A, K:) in this sense applied to a gift. (A, TA.) You say also,"},{"kind":"arabic","text_bw":"huwa masoxuwTN Ealayohi","text_ar":"هُوَ مَسْخُوطٌ عَلَيْهِ"},{"kind":"italic_en","text":"He is an object of anger."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"Transformed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"metamorphosed, into a worse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more ugly, shape:"},{"kind":"text","text":"[and hence applied by the Arabs in the present day to any idol or other image of ancient workmanship; such being regarded by them as metamorphosed in consequence of having incurred the wrath of God:] and"},{"kind":"italic_en","text":"short:"},{"kind":"text","text":"but thus applied, it is a vulgar term. (TA.)"}],"source_refs":["A","K"]}]}}