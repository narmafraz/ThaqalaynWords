lexicon.com/?s=%D9%82%D9%8E%D8%AA%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35153","headword_ar":"قَتَرَ","root":"qtr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"qatorN","text_ar":"قَتْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qutuwrN","text_ar":"قُتُورٌ"},{"kind":"text","text":"; (TK;) and"},{"kind":"arabic","text_bw":"qatira","text_ar":"قَتِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(roast meat, S, Msb, K, and a cookingpot, and burnt bone, and a perfume with which one fumigates, K, or aloes-wood, TA)"},{"kind":"italic_en","text":"exhaled its scent, smell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"odour;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"qt~r","text_ar":"قتّر","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taqotiyrN","text_ar":"تَقْتِيرٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"arabic","text_bw":"qatarati Aln~aAru","text_ar":"قَتَرَتِ النَّارُ"},{"kind":"italic_en","text":"The fire smoked."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"qatara","text_ar":"قَتَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"qatorN","text_ar":"قَتْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qutuwrN","text_ar":"قُتُورٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(sustenance)"},{"kind":"italic_en","text":"was barely sufficient;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"A^aqotara","text_ar":"اَقْتَرَ","orth_type":"arrow"},{"kind":"text","text":". (CK: but this latter is omitted in the TA; and in a MS. copy of the K I find in its place"},{"kind":"arabic","text_bw":"A^qotaru","text_ar":"اقْتَرُ"},{"kind":"text","text":", as a syn. of"},{"kind":"arabic","text_bw":"qaAtirN","text_ar":"قَاتِرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qatuwrN","text_ar":"قَتُورٌ"},{"kind":"text","text":".) [This signification is implied in the K, but not expressed, and I think it doubtful.] ―         -b2-"},{"kind":"arabic","text_bw":"qatara EalaY EiyaAlihi","text_ar":"قَتَرَ عَلَى عِيَالِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"qatorN","text_ar":"قَتْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qutuwrN","text_ar":"قُتُورٌ"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"qt~r","text_ar":"قتّر","orth_type":"arrow"},{"kind":"arabic","text_bw":"Ealayohimo","text_ar":"عَلَيْهِمْ"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"taqotiyrN","text_ar":"تَقْتِيرٌ"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"Aqtr","text_ar":"اقتر","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iqotaArN","text_ar":"اـِقْتَارٌ"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"He scanted his household, stinted them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was niggardly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parsimonious towards them, in expenditure;"},{"kind":"text","text":"(S, Msb, K;) like"},{"kind":"arabic","text_bw":"qadara","text_ar":"قَدَرَ"},{"kind":"text","text":": (S, art."},{"kind":"arabic","text_bw":"qdr","text_ar":"قدر"},{"kind":"text","text":":) as though he took only the"},{"kind":"arabic","text_bw":"qutaAr","text_ar":"قُتَار"},{"kind":"text","text":"[or scent] of a thing. (El-Basáïr.)"},{"kind":"arabic","text_bw":"walamo yaqoturuwA","text_ar":"وَلَمْ يَقْتُرُوا"},{"kind":"text","text":"in the Kur, xxv. 67, signifies"},{"kind":"arabic","text_bw":"walamo yaqoturuwA Eam~aA yajibu Ealayohimo mina Aln~afaqapi","text_ar":"وَلَمْ يَقْتُرُوا عَمَّا يَجِبُ عَلَيْهِمْ مِنَ النَّفَقَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nor are sparing of what is incumbent on them, of expenditure"},{"kind":"text","text":"]. (Fr.) You say also"},{"kind":"arabic","text_bw":"A@ll~`hu rizoqahu","text_ar":"ا@للّٰهُ رِزْقَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aqotara","text_ar":"اَقْتَرَ","orth_type":"arrow"},{"kind":"italic_en","text":"God made his means of subsistence strait,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"scanty."},{"kind":"text","text":"(IAth.) And"},{"kind":"arabic","text_bw":"qutira Ealayohi rizoquhu","text_ar":"قُتِرَ عَلَيْهِ رِزْقُهُ"},{"kind":"italic_en","text":"His means of subsistence were scanted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straitened, to him,"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"fudira","text_ar":"فُدِرَ"},{"kind":"text","text":"; (S, art."},{"kind":"arabic","text_bw":"qdr","text_ar":"قدر"},{"kind":"text","text":";) and"},{"kind":"arabic","text_bw":"rizoquhu","text_ar":"رِزْقُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taqat~ara","text_ar":"تَقَتَّرَ","orth_type":"arrow"},{"kind":"text","text":"[signifies the same]. (TA in art."},{"kind":"arabic","text_bw":"Hrf","text_ar":"حرف"},{"kind":"text","text":", &c.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n35154","headword_ar":"قتّر","root":"qtr","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taqotiyrN","text_ar":"تَقْتِيرٌ"},{"kind":"text","text":": see 1. ―         -b2-"},{"kind":"italic_en","text":"He excited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"raised, the scent termed"},{"kind":"arabic","text_bw":"qutaAr","text_ar":"قُتَار"},{"kind":"text","text":". (S.) ―         -b3-"},{"kind":"arabic","text_bw":"qt~r liloA^asadi","text_ar":"قتّر لِلْاَسَدِ"},{"kind":"italic_en","text":"He put for the lion some flesh-meat"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"in the pitfall,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"that he might perceive its scent."},{"kind":"text","text":"(S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"qt~r lilowaHo$i","text_ar":"قتّر لِلْوَحْشِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a hunter, TA)"},{"kind":"italic_en","text":"fumigated"},{"kind":"text","text":"["},{"kind":"italic_en","text":"himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his clothes"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with camels' dung, in order that the wild animals might not perceive his"},{"kind":"text","text":"(the hunter's)"},{"kind":"italic_en","text":"smell,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and flee from him."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"qt~r EalaY EiyaAlihi","text_ar":"قتّر عَلَى عِيَالِهِ"},{"kind":"text","text":": see 1."}],"source_refs":["S","K","TA"]},{"entry_id":"n35157","headword_ar":"قَتْرٌ","root":"qtr","body":[{"kind":"italic_en","text":"What is barely sufficient, of sustenance;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"taqotiyrN","text_ar":"تَقْتِيرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"what is barely sufficient to sustain life, of expenditure."},{"kind":"text","text":"(Lth.)"}],"source_refs":["K"]},{"entry_id":"n35158","headword_ar":"قُتْرٌ","root":"qtr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"quturN","text_ar":"قُتُرٌ"},{"kind":"text","text":".       -A2-"},{"kind":"italic_en","text":"A side, quarter, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"region;"},{"kind":"text","text":"(S, K;) a dial. form of"},{"kind":"arabic","text_bw":"quTorN","text_ar":"قُطْرٌ"},{"kind":"text","text":"; (S;) as also ↓"},{"kind":"arabic","text_bw":"quturN","text_ar":"قُتُرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) either"},{"kind":"italic_en","text":"side"},{"kind":"text","text":"of a man: (JK, L:) pl."},{"kind":"arabic","text_bw":"A^aqotaArN","text_ar":"اَقْتَارٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["K","JK","L"]},{"entry_id":"n35159","headword_ar":"قَتَرٌ","root":"qtr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"qatarapN","text_ar":"قَتَرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or the latter, and the former is its pl., (S,) [or rather the former is a coll. gen. n., and the latter is the n. un.,] and ↓"},{"kind":"arabic","text_bw":"qatorapN","text_ar":"قَتْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"Dust;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"gubaArN","text_ar":"غُبَارٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"gabarahN","text_ar":"غَبَرَهٌ"},{"kind":"text","text":": (K:) so in the Kur, lxxx. 41: (AO, S:) or the"},{"kind":"italic_en","text":"dust of an army:"},{"kind":"text","text":"(Nh:) or"},{"kind":"italic_en","text":"dust-colour overspread with blackness:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"italic_en","text":"blackness"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"darkness."},{"kind":"text","text":"(Bd, Jel, lxxx. 41.)"}],"source_refs":["K","S","AO","Nh","T","TA"]},{"entry_id":"n35160","headword_ar":"قُتُرٌ","root":"qtr","body":[{"kind":"text","text":"[and app. ↓"},{"kind":"arabic","text_bw":"qutorN","text_ar":"قُتْرٌ","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"quTurN","text_ar":"قُطُرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quTorN","text_ar":"قُطْرٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"Aloes-wood with which one fumigates."},{"kind":"text","text":"(TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"qutorN","text_ar":"قُتْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}