وا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَضِيقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَضِيق","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضِق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَضِيق","in_corpus":true,"count":13,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضِيقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضِيقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضِيقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضِيقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضِيقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضِيقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"ضِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضِقْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَضِيق","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَضِيق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":66,"cross_references":{"qac":{"found":true,"lemma_key":"ضاقَ","root":"ضيق","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n26230"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D8%A7%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become narrow"},{"pos":"verb","gloss":"to straighten"},{"pos":"verb","gloss":"to be or become tired"}]},"etymology":{"source":"wiktextract","text":"From the root ض ي ق (ḍ y q), from Proto-Semitic *ṣ́yḳ- (“to be narrow”). Cognate with Biblical Hebrew צוּק (ṣûq, “to constrain, bring into straits, press upon”) and Akkadian 𒊓𒀀𒄣 (sâqu)."},"ipa":["/dˤaː.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26230","headword_ar":"ضَاقَ","root":"Dyq","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaDiyqu","text_ar":"يَضِيقُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"DayoqN","text_ar":"ضَيْقٌ"},{"kind":"text","text":"(S, O, Msb, K) and"},{"kind":"arabic","text_bw":"DiyqN","text_ar":"ضِيقٌ"},{"kind":"text","text":", (S, O, K,) or this latter is a simple subst., (Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait; contr. of"},{"kind":"arabic","text_bw":"Ait~asaEa","text_ar":"اِتَّسَعَ"},{"kind":"text","text":"; (Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"tDy~q","text_ar":"تضيّق","orth_type":"arrow"},{"kind":"text","text":", [or rather this signifies"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rendered narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait,"},{"kind":"text","text":"being quasipass. of 2,] and ↓"},{"kind":"arabic","text_bw":"tDAyq","text_ar":"تضايق","orth_type":"arrow"},{"kind":"text","text":": (K:) it is said of a thing, (S, O, Msb,) and of a place. (Msb.) [See also"},{"kind":"arabic","text_bw":"DayoqN","text_ar":"ضَيْقٌ"},{"kind":"text","text":"below.]"},{"kind":"arabic","text_bw":"DaAqato Ealayohimu A@loA^aroDu","text_ar":"ضَاقَتْ عَلَيْهِمُ ا@لْاَرْضُ"},{"kind":"text","text":", in the Kur ix. 119, means"},{"kind":"italic_en","text":"The earth became strait to them."},{"kind":"text","text":"(Bd, Jel.) And one says,"},{"kind":"arabic","text_bw":"DaAqato bihi AlA^aroDu","text_ar":"ضَاقَتْ بِهِ الاَرْضُ"},{"kind":"text","text":"[meaning, in like manner,"},{"kind":"italic_en","text":"The earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land, became narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait, with him"},{"kind":"text","text":"]: 'Amr Ibn-El-Ahtam says,"},{"kind":"quote","text":"laEamoruka maA DaAqato bilaAdN biA^aholihaA\n                      \n                     \n                        wal`kin~a A^axolaAqa Alr~ijaAli taDiyqu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By thy life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by thy religion, countries have not become narrow with their inhabitants, but the dispositions of the men become narrow"},{"kind":"text","text":"]. (O, TA.) ["},{"kind":"arabic","text_bw":"DAq bihi","text_ar":"ضاق بِهِ"},{"kind":"text","text":"often signifies, and so does"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tDAyq","text_ar":"تضايق","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, choked, surcharged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overfilled, with it;"},{"kind":"text","text":"for instance, a water-course with water, and a place with people.] And ↓"},{"kind":"arabic","text_bw":"tDAyq","text_ar":"تضايق","orth_type":"arrow"},{"kind":"arabic","text_bw":"bihi AlA^amoru","text_ar":"بِهِ الاَمْرُ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"DAq Ealayohi","text_ar":"ضاق عَلَيْهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strait to him"},{"kind":"text","text":"]. (O, TA. [See an ex. in art."},{"kind":"arabic","text_bw":"rHb","text_ar":"رحب"},{"kind":"text","text":", conj. 6.]) One says also,"},{"kind":"arabic","text_bw":"DAq Ealayohi","text_ar":"ضاق عَلَيْهِ"},{"kind":"arabic","text_bw":"maEaA$uhu","text_ar":"مَعَاشُهُ"},{"kind":"text","text":": see 4. [And"},{"kind":"arabic","text_bw":"DAq Alwaqotu","text_ar":"ضاق الوَقْتُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The time became strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"DAq Sadoruhu","text_ar":"ضاق صَدْرُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His bosom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, became strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracted:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"DAq Eanohu Sadoruka","text_ar":"ضاق عَنْهُ صَدْرُكَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Thy mind became so contracted as to be incapable of it:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy mind shrank from it"},{"kind":"text","text":"]. (K.) [And"},{"kind":"arabic","text_bw":"yaDiyqu AlEaqolu Eano taqodiyrihi","text_ar":"يَضِيقُ العَقْلُ عَنْ تَقْدِيرِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The intellect is incapable of determining its limit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"DAq Eani AljawaAbi","text_ar":"ضاق عَنِ الجَوَابِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biAljawaAbi","text_ar":"بِالجَوَابِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He was straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"embarrassed, so as to be unable to reply,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to answer; he was incapable of replying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"answering"},{"kind":"text","text":"]: both signify the same. (TA in art."},{"kind":"arabic","text_bw":"znd","text_ar":"زند"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"DAq bAlA^amori *aroEFA","text_ar":"ضاق بالاَمْرِ ذَرْعًا"},{"kind":"text","text":", (S, * O, * Msb,) meaning (assumed tropical:)"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, was difficult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, to him,"},{"kind":"text","text":"(Msb,) originally"},{"kind":"arabic","text_bw":"DAq *aroEuhu bihi","text_ar":"ضاق ذَرْعُهُ بِهِ"},{"kind":"text","text":", (S, * O, * Msb,) i. e."},{"kind":"italic_en","text":"his ability"},{"kind":"text","text":"["},{"kind":"italic_en","text":"was straitened by it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was inadequate to it"},{"kind":"text","text":"]; and"},{"kind":"italic_en","text":"his power:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"his art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"artifice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his way, course, mode,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, of acting"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"ma*ohabuhu","text_ar":"مَذْهَبُهُ"},{"kind":"text","text":") ["},{"kind":"italic_en","text":"was straitened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered difficult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, by it"},{"kind":"text","text":"]. (O. [See more voce"},{"kind":"arabic","text_bw":"*aroEN","text_ar":"ذَرْعٌ"},{"kind":"text","text":": and see a similar phrase in the Kur xi. 79 and xxix. 32.]) And hence, app., the saying"},{"kind":"arabic","text_bw":"DAq","text_ar":"ضاق"},{"kind":"arabic","text_bw":"AlmaAlu Eani Ald~uyuwni","text_ar":"المَالُ عَنِ الدُّيُونِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The property was inadequate to the debts."},{"kind":"text","text":"(Msb.) And you say,"},{"kind":"arabic","text_bw":"DAq Eanoka","text_ar":"ضاق عَنْكَ"},{"kind":"arabic","text_bw":"Al$~aYo'u","text_ar":"الشَّىْءُ"},{"kind":"text","text":"[meaning"},{"kind":"arabic","text_bw":"lamo yasaEoka","text_ar":"لَمْ يَسَعْكَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The thing was not allowable to thee"},{"kind":"text","text":"]: one says,"},{"kind":"arabic","text_bw":"laA yasaEuniY $aYo'N wayaDiyqa","text_ar":"لَا يَسَعُنِى شَىْءٌ وَيَضِيقَ"},{"kind":"arabic","text_bw":"Eanoka","text_ar":"عَنْكَ"},{"kind":"text","text":", (S, O, * TA, [in the O, erroneously,"},{"kind":"arabic","text_bw":"lA","text_ar":"لا"},{"kind":"arabic","text_bw":"ystgnY","text_ar":"يستغنى"},{"kind":"text","text":",]) i. e."},{"kind":"arabic","text_bw":"waA^ano yaDiyqa Eanoka","text_ar":"وَاَنْ يَضِيقَ عَنْكَ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A thing will not be allowable to me conjointly with its being disallowable to thee,"},{"kind":"arabic","text_bw":"waA^ano yaDiyqN","text_ar":"وَاَنْ يَضِيقٌ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"maEa Dayoqihi","text_ar":"مَعَ ضَيْقِهِ"},{"kind":"text","text":"]:"},{"kind":"arabic","text_bw":"balo mataY wasiEaniY $aYo'N wasiEaka","text_ar":"بَلْ مَتَى وَسِعَنِى شَىْءٌ وَسِعَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"but when a thing is allowable to me, it is allowable to thee"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"wsE","text_ar":"وسع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"DAq","text_ar":"ضاق"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yaDiayqu","text_ar":"يَضَِيقُ"},{"kind":"text","text":", K, inf. n."},{"kind":"arabic","text_bw":"DiyqN","text_ar":"ضِيقٌ"},{"kind":"text","text":", TA,) (tropical:)"},{"kind":"italic_en","text":"He was"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, niggardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious."},{"kind":"text","text":"(S, O, Msb, K, TA.)"}],"source_refs":["S","O","Msb","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B6%D8%A7%D9%82/","headword_ar":"ضاقَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=30846#3c0183","body_html":"<span>ضاقَ يَضيقُ ضَيْقاً، ويُفْتَحُ، وتَضَيَّقَ وتَضايَقَ: ضِدُّ اتَّسَعَ، وأضاقَه وضَيَّقَهُ، فهو ضَيِّقٌ وضَيْقٌ وضائِقٌ.</span><br><span>والضَّيْقُ: الشَّكُّ في القَلْبِ، ويُكْسَر، وما ضاقَ عنه صَدْرُكَ،</span><br><span>وة باليَمامةِ، وبالكسر: يكونُ فيما يَتَّسِعُ ويَضيقُ، كالدارِ والثَّوبِ، أو هُما سَواءٌ.</span><br><span>والمَضيقُ: ما ضاقَ من الأماكِنِ والأُمورِ،</span><br><span>وة بِلِحْفِ آرَةَ.</span><br><span>والضِّيقَى، كضِيزَى وطُوبَى تأنيثا: الأَضْيَقِ.</span><br><span>والضِيقَةُ، بالكسر: الفَقْرُ، وسُوءُ الحالِ، ويُفْتَحُ، ج: ضَيْقٌ، ومَنْزِلٌ للقَمَرِ، وطريقٌ بين الطائِفِ وحُنَيْنٍ،</span><br><span>وع قُرْبَ عَيْذابَ.</span><br><span>وضاقَ يَضيقُ: بَخِلَ.</span><br><span>وأضاقَ: ذَهَبَ مالُه.</span><br><span>وضايَقَه: عاسَره.</span><br><span>والضياقُ، ككِتابٍ: دُرْجَةٌ من خِرَقٍ وطِيبٍ تَسْتَضيقُ بها المرأةُ.</span>"}]}}