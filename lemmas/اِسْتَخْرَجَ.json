":"italic_en","text":"He tilled"},{"kind":"text","text":"land,"},{"kind":"italic_en","text":"and made"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"productive."},{"kind":"text","text":"(See K voce"},{"kind":"arabic","text_bw":"gaAmirN","text_ar":"غَامِرٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Ausotuxorijati AlA^aroDu","text_ar":"اُسْتُخْرِجَتِ الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land was put into a good state for sowing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"planting."},{"kind":"text","text":"(AHn, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Astxrjhu","text_ar":"استخرجهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Axtrjhu","text_ar":"اخترجهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He asked him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"petitioned him, to go,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"come, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he desired of him that he should go,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"come, out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(TA.)"}],"source_refs":[]}]}}