{"lemma":"مُهَرِّبٌ","slug":"مُهَرِّبٌ","root":"ه.ر.ب","root_slug":"ه-ر-ب","root_link":"/words/roots/ه-ر-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n41099","n41101"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%87%D9%8E%D8%B1%D9%90%D9%91%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of هَرَبَ (haraba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"fleeing in dismay, escape, refuge"}]},"etymology":{"source":"wiktextract","text":"Noun of place of the verb هَرَبَ (haraba, “to run”)."},"ipa":["/mah.rab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41099","headword_ar":"مَهْرَبٌ","root":"hrb","body":[{"kind":"italic_en","text":"A place to which one flees; a place of refuge."},{"kind":"text","text":"(Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"fulaAnN lanaA mahorabN","text_ar":"فُلَانٌ لَنَا مَهْرَبٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one is a refuge to us."},{"kind":"text","text":"(TA.)"}],"source_refs":[]},{"entry_id":"n41101","headword_ar":"مِهْرَبٌ","root":"hrb","body":[{"kind":"italic_en","text":"A piece of wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wooden implement, which the sower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ploughman, draws forward and backward"},{"kind":"text","text":"["},{"kind":"italic_en","text":"over the ground"},{"kind":"text","text":"]. (K.) [A piece of the trunk of a tree, or of a thick branch, is thus drawn over the soil after sowing.]"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D9%87%D8%B1%D8%A8/","headword_ar":"مهربان","entries":[{"lexicon_id":"dicti