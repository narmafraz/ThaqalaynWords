mp","form":"تَدُوسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَدُوسُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدُسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدُس","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَدُوس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدُس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَدُوس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدُوسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدُوسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدُوسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدُوسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدُوسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدُوسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدُسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"دُسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دُسْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدُوس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدُوس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n13421"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tread on, to trample, to step on","tags":["transitive"],"examples":[{"text":"اَلْخَيْلُ تَدُوسُ ٱلْقَتْلَى بِٱلْحَوَافِرِ","english":"The horses are trampling upon the slain with the hoofs."}]}]},"etymology":null,"ipa":["/daː.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13421","headword_ar":"دَاسَ","root":"dws","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yduwsu","text_ar":"يدُوسُ"},{"kind":"text","text":", (S, M, Msb,) inf. n."},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":"(S, M, A, Mgh, K) and"},{"kind":"arabic","text_bw":"diyaAsN","text_ar":"دِيَاسٌ"},{"kind":"text","text":"(M, A, K) and"},{"kind":"arabic","text_bw":"diyaAsapN","text_ar":"دِيَاسَةٌ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"He trod, trod upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trampled upon,"},{"kind":"text","text":"(M, A, Mgh, Msb, K,) a thing, (S, M, Mgh,) or the ground, (Msb,)"},{"kind":"italic_en","text":"vehemently,"},{"kind":"text","text":"(Mgh, Msb,) with the foot. (S, Mgh, Msb, K.) You say,"},{"kind":"arabic","text_bw":"daAsuwhu biA^aqodaAmihimo","text_ar":"دَاسُوهُ بِاَقْدَامِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They trod,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trampled, upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with their feet"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Alxayolu taduwsu AlqatolaY biAlHawaAfiri","text_ar":"الخَيْلُ تَدُوسُ القَتْلَى بِالحَوَافِرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The horses trample upon the slain with the hoofs"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"daAsa","text_ar":"دَاسَ"},{"kind":"arabic","text_bw":"AlT~aEaAma","text_ar":"الطَّعَامَ"},{"kind":"text","text":", (S, A,) or"},{"kind":"arabic","text_bw":"AlHinoTapa","text_ar":"الحِنْطَةَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"AlHab~a","text_ar":"الحَبَّ"},{"kind":"text","text":", (M,) aor."},{"kind":"arabic","text_bw":"yaduwsu","text_ar":"يَدُوسُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"dyaAsapN","text_ar":"ديَاسَةٌ"},{"kind":"text","text":", (S, A, Mgh,) or"},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"diyaAsN","text_ar":"دِيَاسٌ"},{"kind":"text","text":", but some say that"},{"kind":"arabic","text_bw":"diyaAsN","text_ar":"دِيَاسٌ"},{"kind":"text","text":"is not of the language of the Arabs, and some say that it is tropical, as though from"},{"kind":"arabic","text_bw":"daAsa","text_ar":"دَاسَ"},{"kind":"text","text":"in the"},{"kind":"page_break","n":933},{"kind":"text","text":"sense explained above, (Msb,) or the professors of practical religion use it in the place of"},{"kind":"arabic","text_bw":"diyaAsapN","text_ar":"دِيَاسَةٌ"},{"kind":"text","text":"by a kind of license, relying upon the understanding of the hearer or reader, or do so erroneously, (Mgh,)"},{"kind":"italic_en","text":"He trod,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thrashed,"},{"kind":"text","text":"(M, Mgh, Msb,)"},{"kind":"italic_en","text":"the wheat,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"grain,"},{"kind":"text","text":"(M,) either"},{"kind":"italic_en","text":"by the feet of beasts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by repeatedly drawing over it the"},{"kind":"arabic","text_bw":"midowas","text_ar":"مِدْوَس"},{"kind":"text","text":"[q. v. infrà]"},{"kind":"italic_en","text":"until it became"},{"kind":"arabic","text_bw":"tibon","text_ar":"تِبْن"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"cut straw"},{"kind":"text","text":"]; (Mgh;) as also ↓"},{"kind":"arabic","text_bw":"A^adaAsahu","text_ar":"اَدَاسَهُ","orth_type":"arrow"},{"kind":"text","text":". (M.) You say,"},{"kind":"arabic","text_bw":"daAsuwhu dawosa AlHaSiydi","text_ar":"دَاسُوهُ دَوْسَ الحَصِيدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They trod,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trampled, upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with the treading of reaped corn"},{"kind":"text","text":"]. (A.) ―         -b3-"},{"kind":"arabic","text_bw":"daAsahu","text_ar":"دَاسَهُ"},{"kind":"text","text":", (IAar, TA,) inf. n."},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":", (IAar, A, K,)"},{"kind":"italic_en","text":"He abased him."},{"kind":"text","text":"(IAar, A, K.) ―         -b4-"},{"kind":"arabic","text_bw":"nazala AlEaduw~u bibaniY fulaAnK","text_ar":"نَزَلَ العَدُوُّ بِبَنِى فُلَانٍ"},{"kind":"arabic","text_bw":"fajaAsahumo waHaAsahumo wadaAsahumo","text_ar":"فَجَاسَهُمْ وَحَاسَهُمْ وَدَاسَهُمْ"},{"kind":"italic_en","text":"The enemy"},{"kind":"text","text":"["},{"kind":"italic_en","text":"came upon and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"slew the sons of such a one, and went through the midst of their dwellings, and made havoc among them."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"daAsahaA","text_ar":"دَاسَهَا"},{"kind":"text","text":", (A, TA,) inf. n."},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":", (A, K,) (tropical:)"},{"kind":"italic_en","text":"Inivit eam;"},{"kind":"text","text":"scil., feminam: (A:)"},{"kind":"italic_en","text":"vehementer inivit eam:"},{"kind":"text","text":"(A, K: [in the former, this signification is given as proper, though that immediately preceding is said to be tropical: in the TA, the latter is said to be tropical:])"},{"kind":"italic_en","text":"conscendit et vehementer inivit eam."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"daAsahu","text_ar":"دَاسَهُ"},{"kind":"text","text":", (S, M, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":", (Msb, K,) or"},{"kind":"arabic","text_bw":"diyaAsN","text_ar":"دِيَاسٌ"},{"kind":"text","text":", (As, A, Mgh,) (tropical:)"},{"kind":"italic_en","text":"He polished it;"},{"kind":"text","text":"namely, a sword, (S, M, A, Mgh, Msb, K,) and the like, (K,) or some other thing. (Msb.) ―         -b7-  Hence,"},{"kind":"arabic","text_bw":"dawosN","text_ar":"دَوْسٌ"},{"kind":"text","text":"also signifies (tropical:)  The"},{"kind":"italic_en","text":"framing, and dressing up, of deceit, guile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumvention:"},{"kind":"text","text":"(As, A, TA:) [agreeably with which explanation the verb,"},{"kind":"arabic","text_bw":"daAsa","text_ar":"دَاسَ"},{"kind":"text","text":", is probably used, though not mentioned in the A nor in the TA:] or simply, the act of"},{"kind":"italic_en","text":"deceiving, beguiling, circumventing, and practising artifice."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"A^axa*onaA fiY Ald~awosi","text_ar":"اَخَذْنَا فِى الدَّوْسِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"We set about the framing, and dressing up, of deceit, guile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumvention:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"we set about deceiving,"},{"kind":"text","text":"&c. (TA.)"}],"source_refs":["S","M","Msb","A","Mgh","K","IAar","TA","As"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AF%D8%A7%D8%B3/","headword_ar":"داس","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=70546#5082ec","body_html":"داس<br>عن الفارسية بمعنى منجل."}]}}