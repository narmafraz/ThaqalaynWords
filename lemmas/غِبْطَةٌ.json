{"lemma":"غِبْطَةٌ","slug":"غِبْطَةٌ","root":"غ.ب.ط","root_slug":"غ-ب-ط","root_link":"/words/roots/غ-ب-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n31381"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%90%D8%A8%D9%92%D8%B7%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of غَبَطَ (ḡabaṭa) and غَبِطَ (ḡabiṭa) (form I)","tags":["form-of","noun-from-verb","uncountable"]},{"pos":"noun","gloss":"bliss, beatitude"},{"pos":"noun","gloss":"emulation, admiration (endeavor or desire to equal without wishing any harm or loss upon them)"},{"pos":"noun","gloss":"His Beatitude, a title used for Eastern Churches’ patriarchs","examples":[{"text":"صَاحِبَ ٱلْغِبْطَةِ\nṣāḥiba l-ḡibṭati"}]}]},"etymology":null,"ipa":["/ɣib.tˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31381","headword_ar":"غِبْطَةٌ","root":"gbT","body":[{"kind":"italic_en","text":"A good state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"(S, L, Msb, K;)"},{"kind":"italic_en","text":"a state of happiness;"},{"kind":"text","text":"(L, K;)"},{"kind":"italic_en","text":"and of enjoyment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wellbeing;"},{"kind":"text","text":"(L;) as also ↓"},{"kind":"arabic","text_bw":"gaboTN","text_ar":"غَبْطٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"in the saying,"},{"kind":"arabic","text_bw":"Aall~`hum~a gaboTFA laA haboTFA","text_ar":"اَللّٰهُمَّ غَبْطًا لَا هَبْطًا"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"O God,"},{"kind":"text","text":"we ask of Thee"},{"kind":"italic_en","text":"a good state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition"},{"kind":"text","text":"[&c.], (S, K,) and we put our trust in Thee for preservation"},{"kind":"italic_en","text":"that we may not be brought down from our state,"},{"kind":"text","text":"(S, TA,) or"},{"kind":"italic_en","text":"that we may not be abased and humbled:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"place us in a station for which we may be regarded"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with unenvious emulation,"},{"kind":"text","text":"i. e.,]"},{"kind":"italic_en","text":"with a wish to be in the like condition without its being desired that it should pass away from us,"},{"kind":"text","text":"(K, * TA,) and"},{"kind":"italic_en","text":"remove from us the stations of abasement and humiliation:"},{"kind":"text","text":"(TA:) or [we ask of Thee]"},{"kind":"italic_en","text":"exaltation, not humiliation;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"increase of"},{"kind":"text","text":"thy"},{"kind":"italic_en","text":"bounty, not declension nor diminution."},{"kind":"text","text":"(TA.) [See also 1, second sentence.]"}],"source_refs":["S","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%BA%D8%A8%D8%B7%D8%A9/","headword_ar":"غبطة","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23440#ec86fb","body_html":"<span>الغبطة: عبارة عن تمني حصول النعمة لك، كما كان حاصلًا لغيرك، من غير تمني زوالها عنه.</span>"}]}}