count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفْرَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْرَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْرِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفْرِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفْرَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْرَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْرِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفْرِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفْرَدْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُفْرِدْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُفْرَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْرَد","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُفْرِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفْرِد","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَفْرَدْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَفْرَدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":37,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n33431"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%81%D9%92%D8%B1%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be peerless or unequaled"},{"pos":"verb","gloss":"to assign, to destine, to earmark, to allocate, to set aside"},{"pos":"verb","gloss":"to isolate, to separate"},{"pos":"verb","gloss":"to devote"},{"pos":"verb","gloss":"to seclude, to estrange, to isolate"},{"pos":"verb","gloss":"to remove from authority or office"},{"pos":"verb","gloss":"to send away"},{"pos":"verb","gloss":"to give birth to one animal (not used for she-camel because it almost never brings more than one baby camel)"}]},"etymology":null,"ipa":["/ʔaf.ra.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33431","headword_ar":"افرد","root":"frd","body":[{"kind":"text","text":"as intrans.: see 7. ―         -b2-"},{"kind":"arabic","text_bw":"A^aforadato","text_ar":"اَفْرَدَتْ"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a female, S, L, a pregnant female, A, or a woman, K)"},{"kind":"italic_en","text":"brought forth one only:"},{"kind":"text","text":"(S, A, L, K:) opposed to"},{"kind":"arabic","text_bw":"A^atoA^amato","text_ar":"اَتْاَمَتْ"},{"kind":"text","text":": (A:) not said of a she-camel, because she never brings forth more than one. (S, L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"Afrdhu","text_ar":"افردهُ"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, to be single; sole;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one, and no more."},{"kind":"text","text":"(Lth, T, M, * L, Msb. *) ―         -b4-  And"},{"kind":"italic_en","text":"He put,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"set, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, apart, aside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away; he separated him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(S, K.) You say,"},{"kind":"arabic","text_bw":"Afrdhu minohu","text_ar":"افردهُ مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He separated him from him, and rendered him solitary;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he left him solitary"},{"kind":"text","text":"]. (A and Mgh in art."},{"kind":"arabic","text_bw":"wtr","text_ar":"وتر"},{"kind":"text","text":".) [See an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"EaA*ibN","text_ar":"عَاذِبٌ"},{"kind":"text","text":".] ―         -b5-  [Hence,]"},{"kind":"arabic","text_bw":"Afrd fulAanFA bi$aYo'K","text_ar":"افرد فُلاَنًا بِشَىْءٍ"},{"kind":"italic_en","text":"He made such a one to have a thing to himself alone, with none to share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"participate, with him in it."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"frz","text_ar":"فرز"},{"kind":"text","text":".) ―         -b6-  And"},{"kind":"arabic","text_bw":"Afrd AlHaj~a Eani AlEumorapi","text_ar":"افرد الحَجَّ عَنِ العُمْرَةِ"},{"kind":"italic_en","text":"He performed the rites and ceremonies of the pilgrimage separately from those of the"},{"kind":"arabic","text_bw":"Eumorapi","text_ar":"عُمْرَةِ"},{"kind":"text","text":"[q. v.]. (Msb.) ―         -b7-  And"},{"kind":"arabic","text_bw":"Afrd A_ilayohi rasuwlAF","text_ar":"افرد اـِلَيْهِ رَسُولاً"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"He sent"},{"kind":"text","text":"["},{"kind":"italic_en","text":"away"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a messenger to him."},{"kind":"text","text":"(K.)"}],"source_refs":["S","A","L","K"]}]},"classical_definitions":null}