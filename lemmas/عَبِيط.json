,"text":"(T, Msb:) ["},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"EaAriDN","text_ar":"عَارِضٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAriDapN","text_ar":"عَارِضَةٌ"},{"kind":"text","text":": (see the latter of these two words:)] pl."},{"kind":"arabic","text_bw":"EubuTN","text_ar":"عُبُطٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"EibaATN","text_ar":"عِبَاطٌ"},{"kind":"text","text":": (O, K:) and ↓"},{"kind":"arabic","text_bw":"maEobuwTapN","text_ar":"مَعْبُوطَةٌ","orth_type":"arrow"},{"kind":"text","text":", also, applied to a sheep or goat, signifies"},{"kind":"italic_en","text":"slaughtered in a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"healthy, state."},{"kind":"text","text":"(TA.) Also"},{"kind":"arabic","text_bw":"EabiyTN","text_ar":"عَبِيطٌ"},{"kind":"text","text":", applied to flesh-meat, signifies"},{"kind":"italic_en","text":"the same:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"in a sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"healthy, state:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"free from anything injurious, except a fracture of a bone;"},{"kind":"text","text":"(T, Msb;) so says Ibn-Buzurj: (TA:) or"},{"kind":"italic_en","text":"fresh;"},{"kind":"text","text":"(O, K;) and so applied to blood, (Mgh, K,) and to saffron: (K:) or, applied to blood,"},{"kind":"italic_en","text":"pure; free from admixture;"},{"kind":"text","text":"(S, O, Msb;)"},{"kind":"italic_en","text":"and fresh:"},{"kind":"text","text":"(S, O:) also, applied to flesh-meat,"},{"kind":"italic_en","text":"fresh,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"not cooked:"},{"kind":"text","text":"(IAth:) and ↓"},{"kind":"arabic","text_bw":"maEobuwTN","text_ar":"مَعْبُوطٌ","orth_type":"arrow"},{"kind":"text","text":", applied to the same,"},{"kind":"italic_en","text":"not such as a beast or bird of prey has fastened upon, nor affected by disease."},{"kind":"text","text":"(Az, L.) ―         -b2-"},{"kind":"arabic","text_bw":"EabiyTN","text_ar":"عَبِيطٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Slit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent,"},{"kind":"text","text":"(S, O, TA,)"},{"kind":"italic_en","text":"when whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound;"},{"kind":"text","text":"(TA;) applied to a garment, or piece of cloth; (S, O, TA;) and to leather; &c.; (TA;) and so ↓"},{"kind":"arabic","text_bw":"maEobuwTN","text_ar":"مَعْبُوطٌ","orth_type":"arrow"},{"kind":"text","text":": pl. of the former,"},{"kind":"arabic","text_bw":"EubuTN","text_ar":"عُبُطٌ"},{"kind":"text","text":". (S, O, TA.) ―         -b3-  And Dust"},{"kind":"italic_en","text":"raised"},{"kind":"text","text":"by the hoofs of an ass. (TA.)"}],"source_refs":["A","O","K","T","S","Msb","TA","Mgh","IAth"]}]}}