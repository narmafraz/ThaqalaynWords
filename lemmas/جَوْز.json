n","text":"walnut;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walnuts;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a well-known fruit,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"which is eaten:"},{"kind":"text","text":"(Msb:) a Persian word, (S,) arabicized; (S, Msb, K;) originally"},{"kind":"arabic","text_bw":"Gawozo","text_ar":"گَوْزْ"},{"kind":"text","text":": (Mgh, Msb, K:) n. un."},{"kind":"arabic","text_bw":"jawozapN","text_ar":"جَوْزَةٌ"},{"kind":"text","text":": (S, TA:) pl."},{"kind":"arabic","text_bw":"jawozaAtN","text_ar":"جَوْزَاتٌ"},{"kind":"text","text":": (S, K, TA: in the CK"},{"kind":"arabic","text_bw":"jawozaAnN","text_ar":"جَوْزَانٌ"},{"kind":"text","text":":)"},{"kind":"italic_en","text":"the tree thereof abounds in the land of the Arabs, in the province of El-Yemen, where it bears fruit and is cultivated; and in the Sarawát"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Als~arawaAt","text_ar":"السَّرَوَات"},{"kind":"text","text":")"},{"kind":"italic_en","text":"are trees thereof, which are not cultivated: the wood thereof is characterized by hardness and strength."},{"kind":"text","text":"(AHn. TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jawozu baw~ay","text_ar":"جَوْزُ بَوَّي"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"jawozu baw~aA","text_ar":"جَوْزُ بَوَّا"},{"kind":"text","text":", with the short alif, as heard from the physicians, in Persian"},{"kind":"arabic","text_bw":"Gawozi buwyaA","text_ar":"گَوْزِ بُويَا"},{"kind":"text","text":", (Mgh, under the letter"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":",) [vulgarly called"},{"kind":"arabic","text_bw":"jawozu AlT~iybi","text_ar":"جَوْزُ الطِّيبِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The nutmeg;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain medicine;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"it is of the size of the gall-nut"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EafoS","text_ar":"عَفْص"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"easily broken, with a thin coat,"},{"kind":"text","text":"(Mgh, TA,)"},{"kind":"italic_en","text":"having a pleasant odour,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"a pleasant and sharp odour; and the best kind is the red, with a black coat, and heavy:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"it is good for the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"affection of the face termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"laqowap","text_ar":"لَقْوَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"strengthens the stomach and heart, and removes cold."},{"kind":"text","text":"(Mgh.) ―         -b3-"},{"kind":"arabic","text_bw":"jawozu maAvilK","text_ar":"جَوْزُ مَاثِلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The datura stramonium,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thorn-apple;"},{"kind":"text","text":"] also"},{"kind":"italic_en","text":"a certain medicine;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"having the property of producing torpor; resembling the"},{"kind":"arabic","text_bw":"jawozu AlqaYo'i","text_ar":"جَوْزُ القَىْءِ"},{"kind":"text","text":"(see what follows);"},{"kind":"italic_en","text":"having upon it small, thick thorns; and its seed is like that of the"},{"kind":"arabic","text_bw":"A^utoruj~","text_ar":"اُتْرُجّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"citror."},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"jawozu Alq~Yo'i","text_ar":"جَوْزُ القّىْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Nux vomica;"},{"kind":"text","text":"] also"},{"kind":"italic_en","text":"a certain medicine,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"having a power similar to that of the white"},{"kind":"arabic","text_bw":"xarobaq","text_ar":"خَرْبَق"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hellebore"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"jawozu Alhinodi","text_ar":"جَوْزُ الهِنْدِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The cocoa-nut;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what is commonly called the"},{"kind":"arabic","text_bw":"naArajiyl","text_ar":"نَارَجِيل"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","A","TA","Msb","Mgh"]}]}}