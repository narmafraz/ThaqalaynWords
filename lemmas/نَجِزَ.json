ull,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39422","headword_ar":"نَجِزَ","root":"njz","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"najazN","text_ar":"نَجَزٌ"},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"najozN","text_ar":"نَجْزٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, TA,)"},{"kind":"italic_en","text":"came to an end; came to nought; perished, passed away:"},{"kind":"text","text":"(S, K, TA:) in these senses, the former is the more chaste, and has been so generally used that the latter has been said to be not allowable; but both have been heard. (TA.)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a speech or discourse)"},{"kind":"italic_en","text":"finished,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and became complete."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"died:"},{"kind":"text","text":"(S:) occurring in a verse of En-Nábighah Edh-Dhubyánee: as related by J,"},{"kind":"arabic","text_bw":"najiza","text_ar":"نَجِزَ"},{"kind":"text","text":"; but as related by A 'Obeyd,"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"najaza AlwaEodu","text_ar":"نَجَزَ الوَعْدُ"},{"kind":"text","text":", (A, Mgh, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"najozN","text_ar":"نَجْزٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"najiza","text_ar":"نَجِزَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K;) inf. n."},{"kind":"arabic","text_bw":"najazN","text_ar":"نَجَزٌ"},{"kind":"text","text":"; (TK;)"},{"kind":"italic_en","text":"The promise came to pass, and was accomplished:"},{"kind":"text","text":"(A, Mgh:) or"},{"kind":"italic_en","text":"the promise was prompt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quick, in taking effect:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the thing promised"},{"kind":"text","text":"(TK)"},{"kind":"italic_en","text":"came, arrived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became present:"},{"kind":"text","text":"(K, TA:) in this sense, the former is the more chaste; but both have been heard. (TA.)       -A3-"},{"kind":"arabic","text_bw":"najaza","text_ar":"نَجَزَ"},{"kind":"text","text":"is also trans.: see 4, in four places."}],"source_refs":["S","K","TA","A","Mgh","Msb","TK"]}]},"classical_definitions":null}