{"lemma":"مُرْدِ","slug":"مُرْدِ","root":"م.ر.د","root_slug":"م-ر-د","root_link":"/words/roots/م-ر-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"مُرْدِ","root":"ردد","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n38443","n38445","n15202","n15203","n15204"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B1%D9%92%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"beardless, without a beard"}]},"etymology":{"source":"wiktextract","text":"Color or defect adjective from م ر د (m r d)."},"ipa":["/ʔam.rad/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38443","headword_ar":"مَرَدَ","root":"mrd","body":[{"kind":"text","text":", (aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":", S, L,)"},{"kind":"italic_en","text":"He steeped"},{"kind":"text","text":"bread, (S, L, K,) or corn, (Msb,)"},{"kind":"italic_en","text":"in water, and mashed"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with his hand, so as to soften it:"},{"kind":"text","text":"(S, L, Msb, K:) or"},{"kind":"italic_en","text":"he soaked"},{"kind":"text","text":"bread"},{"kind":"italic_en","text":"in water;"},{"kind":"text","text":"(M, L;) and so"},{"kind":"arabic","text_bw":"marava","text_ar":"مَرَثَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mara*a","text_ar":"مَرَذَ"},{"kind":"text","text":", with the dotted"},{"kind":"arabic","text_bw":"*","text_ar":"ذ"},{"kind":"text","text":"; or"},{"kind":"italic_en","text":"he softened"},{"kind":"text","text":"bread"},{"kind":"italic_en","text":"in water, and crumbled it with his fingers."},{"kind":"text","text":"(As, L.) ―         -b2-"},{"kind":"arabic","text_bw":"maradahu","text_ar":"مَرَدَهُ"},{"kind":"italic_en","text":"He rubbed it"},{"kind":"text","text":"(a thing) in water. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maradahu","text_ar":"مَرَدَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He crumbled it"},{"kind":"text","text":"[namely bread &c.], or"},{"kind":"italic_en","text":"broke it into small pieces, with his fingers;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"varadahu","text_ar":"ثَرَدَهُ"},{"kind":"text","text":". (TA [but only the inf. n. is there mentioned.]) ―         -b4-"},{"kind":"arabic","text_bw":"maradahu","text_ar":"مَرَدَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"soft."},{"kind":"text","text":"(L.) ―         -b5-"},{"kind":"arabic","text_bw":"maradahu","text_ar":"مَرَدَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"mr~dhu","text_ar":"مرّدهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He made it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"soft and smooth; he polished it."},{"kind":"text","text":"(L.) See also 2. ―         -b6-"},{"kind":"arabic","text_bw":"marada","text_ar":"مَرَدَ"},{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":", S, L,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a child, S, L)"},{"kind":"italic_en","text":"mumbled"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"marasa","text_ar":"مَرَسَ"},{"kind":"text","text":") the breast (S, * L, *"},{"kind":"page_break","n":2706},{"kind":"text","text":"K) of his mother: (S, L:) or"},{"kind":"italic_en","text":"sucked it."},{"kind":"text","text":"(IKtt.) ―         -b7-"},{"kind":"arabic","text_bw":"marida","text_ar":"مَرِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He continued to eat"},{"kind":"arabic","text_bw":"mariyd","text_ar":"مَرِيد"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"dates soaked in milk until rendered soft."},{"kind":"text","text":"(K.) ―         -b8-"},{"kind":"arabic","text_bw":"marida","text_ar":"مَرِدَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a branch)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, destitute of leaves."},{"kind":"text","text":"(IAar, L.) ―         -b9-"},{"kind":"arabic","text_bw":"maridati AlA^aroDu","text_ar":"مَرِدَتِ الاَرْضُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"maradN","text_ar":"مَرَدٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The land was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, destitute of herbage, excepting a small quantity."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"arabic","text_bw":"marida","text_ar":"مَرِدَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, without hair upon the fetlock."},{"kind":"text","text":"(IKtt.) ―         -b11-"},{"kind":"arabic","text_bw":"marida","text_ar":"مَرِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"maradN","text_ar":"مَرَدٌ"},{"kind":"text","text":"(S, L, Msb, K) and"},{"kind":"arabic","text_bw":"muruwdapN","text_ar":"مُرُودَةٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"tmr~d","text_ar":"تمرّد","orth_type":"arrow"},{"kind":"text","text":"; (S, A, L, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a youth, or young man,)"},{"kind":"italic_en","text":"was as yet beardless:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"had no hair upon his cheeks:"},{"kind":"text","text":"(IAar, L:) or"},{"kind":"italic_en","text":"remained to a late period without his beard having grown,"},{"kind":"text","text":"(L, K,) or"},{"kind":"italic_en","text":"without the hair of his face having grown forth."},{"kind":"text","text":"(S, L, Msb)       -A2-"},{"kind":"arabic","text_bw":"marada","text_ar":"مَرَدَ"},{"kind":"text","text":"aor."},{"kind":"text","text":", (A, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"muruwdN","text_ar":"مُرُودٌ"},{"kind":"text","text":"(A, L, K) and"},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":"; (IAar, L;) and"},{"kind":"arabic","text_bw":"maruda","text_ar":"مَرُدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"maraAdapN","text_ar":"مَرَادَةٌ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"muruwdapN","text_ar":"مُرُودَةٌ"},{"kind":"text","text":"; (TA, and some copies of the K;) and ↓"},{"kind":"arabic","text_bw":"tmr~d","text_ar":"تمرّد","orth_type":"arrow"},{"kind":"text","text":"; (A, L;)"},{"kind":"italic_en","text":"He exalted himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was insolent and audacious, in pride and in acts of rebellion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedience;"},{"kind":"text","text":"(IAar, L;)"},{"kind":"italic_en","text":"he was hold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"audacious;"},{"kind":"text","text":"(M, L, K;)"},{"kind":"italic_en","text":"and immoderate, inordinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exhorbitant;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, immoderately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inordinately, proud,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unbelieving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedient"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rebellious;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exalted himself and was inordinate in infidelity;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was extravagant in acts of disobedience and in wrongdoing;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was refractory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"averse from obedience:"},{"kind":"text","text":"(S, M, A, L, Msb, K:) or"},{"kind":"italic_en","text":"he went to such an extreme as thereby to pass from out of the general state"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"category"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of that species"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to which he belonged"},{"kind":"text","text":"]. (M, L, K.) ―         -b2-  So in the phrase"},{"kind":"arabic","text_bw":"mrd EalaY AlA^amori","text_ar":"مرد عَلَى الاَمْرِ"},{"kind":"italic_en","text":"He was bold"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"audacious, and immoderate, &c., in the affair:"},{"kind":"text","text":"(M, L:) and in like manner,"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"arabic","text_bw":"Al$~ar~i","text_ar":"الشَّرِّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"in evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief:"},{"kind":"arabic","text_bw":"EalayonaA","text_ar":"عَلَيْنَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tmr~d","text_ar":"تمرّد","orth_type":"arrow"},{"kind":"italic_en","text":"He acted immoderately, inordinately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitantly, &c., towards us,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"against us."},{"kind":"text","text":"(L.) ―         -b3-  Some explain"},{"kind":"arabic","text_bw":"maruda","text_ar":"مَرُدَ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"xabuva","text_ar":"خَبُثَ"},{"kind":"text","text":"[signifying"},{"kind":"italic_en","text":"He was bad, evil, wicked, malignant, noxious, corrupt, &c."},{"kind":"text","text":"]. (MF.) ―         -b4-"},{"kind":"arabic","text_bw":"maAridN waEaz~a AlA^abolaqu","text_ar":"مَارِدٌ وَعَزَّ الاَبْلَقُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tamar~ada","text_ar":"تَمَرَّدَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Márid hath resisted the attempt to take it, and El-Ablak hath proved strong"},{"kind":"text","text":"]: a proverb: (S:) originally said by Ex-Zebbà, the Queen of the Arabs, with reference to two fortresses which she had failed to take. (TA.)       -A3-"},{"kind":"arabic","text_bw":"marada","text_ar":"مَرَدَ"},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"marodN","text_ar":"مَرْدٌ"},{"kind":"text","text":", (L, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a sailor)"},{"kind":"italic_en","text":"pushed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"propelled,"},{"kind":"text","text":"a ship or boat,"},{"kind":"italic_en","text":"with a"},{"kind":"arabic","text_bw":"murodiY~","text_ar":"مُرْدِىّ"},{"kind":"text","text":". (L, K.) ―         -b2-"},{"kind":"italic_en","text":"He drove vehemently."},{"kind":"text","text":"(L, K.)       -A4-"},{"kind":"arabic","text_bw":"marada EalaY $aYo'K","text_ar":"مَرَدَ عَلَى شَىْءٍ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] (K,) inf. n."},{"kind":"arabic","text_bw":"muruwdN","text_ar":"مُرُودٌ"},{"kind":"text","text":"; (S, L;) and ↓"},{"kind":"arabic","text_bw":"tmr~d","text_ar":"تمرّد","orth_type":"arrow"},{"kind":"text","text":"; (L.) (tropical:)"},{"kind":"italic_en","text":"He became accustomed, habituated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inured, to a thing."},{"kind":"text","text":"(S, L, K.) ―         -b2-"},{"kind":"arabic","text_bw":"maraduwA EalaY Aln~ifaAqi","text_ar":"مَرَدُوا عَلَى النِّفَاقِ"},{"kind":"text","text":"[Kur., ix., 102,] (tropical:)"},{"kind":"italic_en","text":"They have become accustomed, habituated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inured, to hypocrisy:"},{"kind":"text","text":"(Fr., A, L:) or"},{"kind":"italic_en","text":"they have exalted themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become insolent and audacious, in hypocrisy:"},{"kind":"text","text":"(IAar:) accord. to Er-Rághib, it is from"},{"kind":"arabic","text_bw":"$ajarapN marodaA='u","text_ar":"شَجَرَةٌ مَرْدَا=ءُ"},{"kind":"text","text":"“ a tree without leaves; ” meaning, (assumed tropical:)"},{"kind":"italic_en","text":"they have become destitute of good."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"marada EalaY AlkalaAmi","text_ar":"مَرَدَ عَلَى الكَلَامِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became accustomed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"habituated, to what was said, so that he cared not for it."},{"kind":"text","text":"(L.)"}],"source_refs":["S","L","K","Msb","IAar","A","M"]},{"entry_id":"n38445","headword_ar":"مَرْدٌ","root":"mrd","body":[{"kind":"text","text":"[Coll. gen. n.]"},{"kind":"italic_en","text":"Bread crumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broken into small pieces, with the fingers, and then moistened with broth;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"variydN","text_ar":"ثَرِيدٌ"},{"kind":"text","text":". (T, L.) ―         -b2-"},{"kind":"italic_en","text":"What is fresh and juicy of the fruit of the"},{"kind":"arabic","text_bw":"A^araAk","text_ar":"اَرَاك"},{"kind":"text","text":": (T, S, L, K:) what is ripe thereof is called"},{"kind":"arabic","text_bw":"kabaAvN","text_ar":"كَبَاثٌ"},{"kind":"text","text":": (T, L:) or [in the CK, and]"},{"kind":"italic_en","text":"what is ripe thereof:"},{"kind":"text","text":"(L, K:) what has become black being called"},{"kind":"arabic","text_bw":"kbAv","text_ar":"كباث"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"brm","text_ar":"برم"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"certain red and large things pertaining thereto:"},{"kind":"text","text":"n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (AHn, L.)"}],"source_refs":["T","S","L","K"]},{"entry_id":"n15202","headword_ar":"مَرَدٌّ","root":"rd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rad~N","text_ar":"رَدٌّ"},{"kind":"text","text":", second sentence."}],"source_refs":[]},{"entry_id":"n15203","headword_ar":"مُرِدٌّ","root":"rd","body":[{"kind":"text","text":"A ewe or she-goat (S, K) or other animal (S)"},{"kind":"italic_en","text":"secreting milk in her udder before bringing forth:"},{"kind":"text","text":"(S, K:) or a she-camel"},{"kind":"italic_en","text":"having her udder shining, and infused with milk;"},{"kind":"text","text":"(Ks, M, L;) as also"},{"kind":"arabic","text_bw":"muromidN","text_ar":"مُرْمِدٌ"},{"kind":"text","text":": (Ks, L:) and any female"},{"kind":"italic_en","text":"near to bringing forth, and having her belly and udder large."},{"kind":"text","text":"(M, L.) And A she-camel"},{"kind":"italic_en","text":"having her udder and vulva inflated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swollen, in consequence of her lying upon moist ground:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"whose vulva is swollen in consequence of lust for the stallion:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having her"},{"kind":"arabic","text_bw":"A^arofaAg","text_ar":"اَرْفَاغ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"groins,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inguinal creases,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"her udder, and her vulva, swollen in consequence of drinking much water:"},{"kind":"text","text":"(M, L:) and a he-camel, (T, K,) and a she-camel, (T, L,)"},{"kind":"italic_en","text":"heavy from drinking much water:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"maraAd~u","text_ar":"مَرَادُّ"},{"kind":"text","text":". (T, L, K.) ―         -b2-  Also, [app. from the first of the meanings explained in this paragraph,] A man"},{"kind":"italic_en","text":"who has been long without a wife,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"absent from his home,"},{"kind":"text","text":"(T, * L, * K,)"},{"kind":"italic_en","text":"and whose seminal fluid has in consequence returned into his back;"},{"kind":"text","text":"(T, L;) as also ↓"},{"kind":"arabic","text_bw":"maroduwdN","text_ar":"مَرْدُودٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) And [hence,] (assumed tropical:)"},{"kind":"italic_en","text":"Very libidinous;"},{"kind":"text","text":"(S, K;) applied to a man. (S.) And (assumed tropical:)  ["},{"kind":"italic_en","text":"Swollen with anger;"},{"kind":"text","text":"see 4: or]"},{"kind":"italic_en","text":"angry."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"jaA='a fulaAnN murid~a Alwajohi","text_ar":"جَا=ءَ فُلَانٌ مُرِدَّ الوَجْهِ"},{"kind":"italic_en","text":"Such a one came angry"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in countenance"},{"kind":"text","text":"]. (S.) ―         -b3-  Also A sea (T, S)"},{"kind":"italic_en","text":"tumultuous with waves;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"maw~aAjN","text_ar":"مَوَّاجٌ"},{"kind":"text","text":": (K:)"},{"kind":"italic_en","text":"having many waves:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"having much water."},{"kind":"text","text":"(T.)"}],"source_refs":["S","K","Ks","L","M","T"]},{"entry_id":"n15204","headword_ar":"مِرَدٌّ","root":"rd","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who repels much, and often wheels away and then returns to the fight;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who repels and returns much."},{"kind":"text","text":"(M, L.)"}],"source_refs":[]}]},"classical_definitions":null}