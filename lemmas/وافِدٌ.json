{"lemma": "وافِدٌ", "slug": "وافِدٌ", "root": "#.ف.د", "root_slug": "_-ف-د", "root_link": "/words/roots/_-ف-د", "pos": "ADJ", "pos_camel": "adj", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": false}, "lanes": {"found": true, "entry_ids": ["n42161"], "search_url": "https://lanelexicon.com/?s=%D9%88%D8%A7%D9%81%D9%90%D8%AF%D9%8C"}}, "translations": {"en": "envoy", "fa": "فرستاده", "ur": "سفیر", "tr": "elçi", "id": "utusan", "bn": "দূত", "es": "enviado", "fr": "envoyé", "de": "Gesandter", "ru": "посол", "zh": "使者"}, "definition": null, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n42161", "headword_ar": "وَافِدٌ", "root": "wfd", "body": [{"kind": "italic_en", "text": "A man coming to a king,"}, {"kind": "text", "text": "(A,) or"}, {"kind": "italic_en", "text": "governor,"}, {"kind": "text", "text": "(S, A,) [or"}, {"kind": "italic_en", "text": "great man,"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "as an ambassador,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "envoy,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "messenger;"}, {"kind": "text", "text": "(S, A;) [or"}, {"kind": "italic_en", "text": "to convey gifts, and to ask aid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "assistance:"}, {"kind": "text", "text": "See 1:] pl., (S, L,) or [rather] this first is a quasi-pl. n., (L,) ↓"}, {"kind": "arabic", "text_bw": "wafodN", "text_ar": "وَفْدٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(S, A, L, K) and"}, {"kind": "arabic", "text_bw": "wuf~adN", "text_ar": "وُفَّدٌ"}, {"kind": "text", "text": "(K) and"}, {"kind": "arabic", "text_bw": "wuf~aAdN", "text_ar": "وُفَّادٌ"}, {"kind": "text", "text": "; (A, Msb;) and pl. of"}, {"kind": "arabic", "text_bw": "wafodN", "text_ar": "وَفْدٌ"}, {"kind": "text", "text": ","}, {"kind": "arabic", "text_bw": "A^awoqaAdN", "text_ar": "اَوْقَادٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "wufuwdN", "text_ar": "وُفُودٌ"}, {"kind": "text", "text": ": (S, L, Msb, K:)"}, {"kind": "arabic", "text_bw": "wafodN", "text_ar": "وَفْدٌ"}, {"kind": "text", "text": "is also explained as signifying"}, {"kind": "italic_en", "text": "a party that assembles together and comes to a country"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "town:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "a party that repairs to princes,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "governors, to visit, and to ask aid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "assistance,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "some benefit, &c.:"}, {"kind": "text", "text": "(L:) and"}, {"kind": "italic_en", "text": "a party that comes to a king respecting an affair of conquest,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "for congratulation,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the like:"}, {"kind": "text", "text": "(Mgh:) and"}, {"kind": "italic_en", "text": "a company chosen to go forth for the purpose of having an interview with great men:"}, {"kind": "text", "text": "(En-Nawawee:) and"}, {"kind": "italic_en", "text": "a company of riders:"}, {"kind": "text", "text": "(Jel, xix. 88:) and"}, {"kind": "italic_en", "text": "a company riding and honoured:"}, {"kind": "text", "text": "(Zj, in explanation of the same verse of the Kur-an:) but from the explanations in the K, and other lexicons, it seems to signify"}, {"kind": "italic_en", "text": "a party coming, whether walking"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "riding, chosen for the purpose of having an interview with great men,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "not:"}, {"kind": "text", "text": "the explanations of En-Nawawee and some others may be in accordance with general or conventional acceptations, and those of the rest may be proper, or literal. (TA.) ―         -b2-"}, {"kind": "arabic", "text_bw": "waAfidN", "text_ar": "وَافِدٌ"}, {"kind": "text", "text": "(tropical:)  A camel, (S, A, K,) or bird, (A,) or bird of the kind called"}, {"kind": "arabic", "text_bw": "AlqaTaA", "text_ar": "القَطَا"}, {"kind": "text", "text": ", (K,)"}, {"kind": "italic_en", "text": "that precedes the others"}, {"kind": "text", "text": "(S, A, K)"}, {"kind": "italic_en", "text": "in pace, and in coming to water."}, {"kind": "text", "text": "(A.) ―         -b3-"}, {"kind": "arabic", "text_bw": "AlwaAfidaAni", "text_ar": "الوَافِدَانِ"}, {"kind": "text", "text": "(in the poetry of ElAasha, S, L) (tropical:)"}, {"kind": "italic_en", "text": "The parts of the two cheeks which project when one chews, and which become depressed when one grows old."}, {"kind": "text", "text": "(S, A, L, K.) One says of a very old man,"}, {"kind": "arabic", "text_bw": "gaAba waAfidaAhu", "text_ar": "غَابَ وَافِدَاهُ"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "The middles of his cheeks have become depressed"}, {"kind": "text", "text": "]. (A.)"}], "source_refs": ["A", "S", "L", "K", "Msb", "Mgh"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}