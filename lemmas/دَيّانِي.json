},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an orderer,"},{"kind":"text","text":"(S, M, K,)"},{"kind":"italic_en","text":"of affairs"},{"kind":"text","text":"of another. (S.)"}],"source_refs":["S","M","K","TA","T"]}]},"classical_definitions":null}