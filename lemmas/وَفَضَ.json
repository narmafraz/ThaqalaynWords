"n42185","headword_ar":"وَفَضَ","root":"wfD","body":[{"kind":"text","text":", (A, Mgh, K.) aor."},{"kind":"arabic","text_bw":"yafiDu","text_ar":"يَفِضُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"wafoDN","text_ar":"وَفْضٌ"},{"kind":"text","text":"(A, K) and"},{"kind":"arabic","text_bw":"wafaDN","text_ar":"وَفَضٌ"},{"kind":"text","text":"; (IDrd, K;) and ↓"},{"kind":"arabic","text_bw":"AwfD","text_ar":"اوفض","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh, K,) and ↓"},{"kind":"arabic","text_bw":"AstwfD","text_ar":"استوفض","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He ran:"},{"kind":"text","text":"(A, Mgh, K:)"},{"kind":"italic_en","text":"he hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went quickly."},{"kind":"text","text":"(S, A, Mgh, K.) Hence, in the Kur. [lxx. 43,] ↓"},{"kind":"arabic","text_bw":"kaA^an~ahumo A_ilaY nuSubK yuwfiDuwna","text_ar":"كَاَنَّهُمْ اـِلَى نُصُبٍ يُوفِضُونَ","orth_type":"arrow"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"naSobK","text_ar":"نَصْبٍ"},{"kind":"text","text":","},{"kind":"italic_en","text":"As though they were hastening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"going quickly, to a thing set up for worship."},{"kind":"text","text":"(Fr, S, TA.) You say also"},{"kind":"arabic","text_bw":"wafaDati AlA_ibalu","text_ar":"وَفَضَتِ الاـِبَلُ"},{"kind":"italic_en","text":"The camels hastened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went quickly:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"went the pace termed"},{"kind":"arabic","text_bw":"xabab","text_ar":"خَبَب"},{"kind":"text","text":". (Khaleefeh El-Hoseynee.) And"},{"kind":"italic_en","text":"The camels became dispersed:"},{"kind":"text","text":"(AA:) and ↓"},{"kind":"arabic","text_bw":"AstwfDt","text_ar":"استوفضت","orth_type":"arrow"},{"kind":"italic_en","text":"they became dispersed"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in their pasturing."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","A","S","Mgh","M","AA","TA"]}]}}