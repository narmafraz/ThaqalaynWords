ue,"entry_ids":["n29070","","n29076","n29077","n29078","n29079","n29080","n29081"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B3%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29070","headword_ar":"عَسُرَ","root":"Esr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"(S, A, O, Msb, K) and"},{"kind":"arabic","text_bw":"EusurN","text_ar":"عُسُرٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"EasaArapN","text_ar":"عَسَارَةٌ"},{"kind":"text","text":"(Msb, K) [and"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusorapN","text_ar":"عُسْرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosarapN","text_ar":"مَعْسَرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEosurapN","text_ar":"مَعْسُرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusoraY","text_ar":"عُسْرَى"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"below)]; and"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":"; (S, O, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"tEs~r","text_ar":"تعسّر","orth_type":"arrow"},{"kind":"text","text":", (A, O, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"tEAsr","text_ar":"تعاسر","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AstEsr","text_ar":"استعسر","orth_type":"arrow"},{"kind":"text","text":"; (A, O, Msb, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an affair, or a thing, S, A, O, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate."},{"kind":"text","text":"(S, A, O, Msb, K, * TA.) You say,"},{"kind":"arabic","text_bw":"Easura Ealayohi","text_ar":"عَسُرَ عَلَيْهِ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", (S, O,) and ↓"},{"kind":"arabic","text_bw":"tEs~r","text_ar":"تعسّر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"tEAsr","text_ar":"تعاسر","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AstEsr","text_ar":"استعسر","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, difficult, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate, to him."},{"kind":"text","text":"(S, * O, * K.) ―         -b2-"},{"kind":"arabic","text_bw":"Easura maA fiY AlbaToni","text_ar":"عَسُرَ مَا فِى البَطْنِ"},{"kind":"text","text":", (as in the CK and a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (accord. to the TA,)"},{"kind":"italic_en","text":"What was in the belly would not come forth."},{"kind":"text","text":"(K.) You say"},{"kind":"arabic","text_bw":"Easara Ealayohi maA fiY AlbaToni","text_ar":"عَسَرَ عَلَيْهِ مَا فِى البَطْنِ"},{"kind":"italic_en","text":"What was in his belly would not come forth."},{"kind":"text","text":"(TA.) ―         -b3-  See also 4. ―         -b4-"},{"kind":"arabic","text_bw":"Easura","text_ar":"عَسُرَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (IKtt, TA,) or"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EasaArapN","text_ar":"عَسَارَةٌ"},{"kind":"text","text":"(Msb, IKtt, TA) and"},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":", (IKtt, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"had little gentleness,"},{"kind":"text","text":"(Msb, IKtt,)"},{"kind":"arabic","text_bw":"fiY AlA^umuwri","text_ar":"فِى الاُمُورِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in"},{"kind":"text","text":"the execucution of"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"]; (Msb;)"},{"kind":"italic_en","text":"and was narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"niggardly, in disposition:"},{"kind":"text","text":"(IKtt:) or"},{"kind":"italic_en","text":"he was hard in disposition;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illnatured."},{"kind":"text","text":"(K, * TK.) ―         -b5-"},{"kind":"arabic","text_bw":"Easura","text_ar":"عَسُرَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", (A, and so in the CK and a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (as in the TA,) inf. n."},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He acted contrarily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adversely, to him; opposed him;"},{"kind":"text","text":"(A, K;) as also ↓"},{"kind":"arabic","text_bw":"Es~r","text_ar":"عسّر","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taEosiyrN","text_ar":"تَعْسِيرٌ"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Es~r","text_ar":"عسّر","orth_type":"arrow"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"he straitened him."},{"kind":"text","text":"(Sb, O, * TA.) ―         -b6-"},{"kind":"arabic","text_bw":"Easura Alz~amaAnu","text_ar":"عَسُرَ الزَّمَانُ"},{"kind":"text","text":", (so in the CK and in a MS. copy of the K,) or"},{"kind":"arabic","text_bw":"Easara","text_ar":"عَسَرَ"},{"kind":"text","text":", (so in the TA,)"},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, became severe, rigorous, afflictive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adverse,"},{"kind":"text","text":"(K,)"},{"kind":"arabic","text_bw":"EalayonaA","text_ar":"عَلَيْنَا"},{"kind":"italic_en","text":"to us."},{"kind":"text","text":"(TA. ―         -b7-"},{"kind":"arabic","text_bw":"Easurati Aln~aAqapu","text_ar":"عَسُرَتِ النَّاقَةُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Easirat","text_ar":"عَسِرَت"},{"kind":"italic_en","text":"The she-camel was untrained."},{"kind":"text","text":"(O.) ―         -b8-  And"},{"kind":"arabic","text_bw":"Easarato","text_ar":"عَسَرَتْ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"Easarato bi*anabihaA","text_ar":"عَسَرَتْ بِذَنَبِهَا"},{"kind":"text","text":", (S, O, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EasaraAnN","text_ar":"عَسَرَانٌ"},{"kind":"text","text":"(S, O, K, TA) and"},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":", (O, K, TA,)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"raised her tail, after conception, to show the stallion that she was pregnant:"},{"kind":"text","text":"(S, * O, TA:) and [as also, app., ↓"},{"kind":"arabic","text_bw":"Es~rt","text_ar":"عسّرت","orth_type":"arrow"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Es~rt danabahaA","text_ar":"عسّرت دَنَبَهَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taEosiyrN","text_ar":"تَعْسِيرٌ"},{"kind":"text","text":", (see"},{"kind":"arabic","text_bw":"nAqp EasiyrN","text_ar":"ناقة عَسِيرٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"EasirN","text_ar":"عَسِرٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"raised her tail in her running."},{"kind":"text","text":"(K, TA.) [In the former case, the action denotes repugnance to the stallion: in the latter, a degree of refractoriness: in both, difficulty.]       -A2-"},{"kind":"arabic","text_bw":"Easara Algariyma","text_ar":"عَسَرَ الغَرِيمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, O, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":"; (S, O;) and ↓"},{"kind":"arabic","text_bw":"A^aEosarahu","text_ar":"اَعْسَرَهُ","orth_type":"arrow"},{"kind":"text","text":"; (O, Msb, K;)"},{"kind":"italic_en","text":"He demanded the debt of the debtor, it being difficult to him to pay it:"},{"kind":"text","text":"(S, O, Msb, K: *) and"},{"kind":"italic_en","text":"he took it of him, it being difficult to him to pay it, and was not lenient towards him until he was in easy circumstances."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Easarahu","text_ar":"عَسَرَهُ"},{"kind":"text","text":", (As, TA,) and ↓"},{"kind":"arabic","text_bw":"AEtsrhu","text_ar":"اعتسرهُ","orth_type":"arrow"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"He forced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compelled, him, against his wish;"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"italic_en","text":"to do the thing;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qasarahu","text_ar":"قَسَرَهُ"},{"kind":"text","text":", (As, TA,) and"},{"kind":"arabic","text_bw":"Aqtsrhu","text_ar":"اقتسرهُ"},{"kind":"text","text":". (S, O, TA.)       -A3-"},{"kind":"arabic","text_bw":"Easira","text_ar":"عَسِرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Easirato","text_ar":"عَسِرَتْ"},{"kind":"text","text":", (TK,) or"},{"kind":"arabic","text_bw":"Easarato","text_ar":"عَسَرَتْ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ"},{"kind":"text","text":", (S, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, TK,) and"},{"kind":"italic_en","text":"she,"},{"kind":"text","text":"(a woman, TK,)"},{"kind":"italic_en","text":"was left-handed."},{"kind":"text","text":"(S, Mgh, O, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"EasaraniY","text_ar":"عَسَرَنِى"},{"kind":"text","text":", (O, L, and K, and so in a copy of the S,) aor."},{"kind":"text","text":", (L,) or"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ"},{"kind":"text","text":"; (L, TA;) and ↓"},{"kind":"arabic","text_bw":"Eas~araniY","text_ar":"عَسَّرَنِى","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"EasiraniY","text_ar":"عَسِرَنِى"},{"kind":"text","text":", (L and TA, and so in a copy of the S,) aor."},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He came on my right side."},{"kind":"text","text":"(S, O, L, K, TA.)"}],"source_refs":["S","A","O","Msb","K","TA","IKtt","TK","As","Mgh","L"]},{"entry_id":"n29076","headword_ar":"عَسْرٌ","root":"Esr","body":[{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"AlEasoru","text_ar":"العَسْرُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EisorN","text_ar":"عِسْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n29077","headword_ar":"عُسْرٌ","root":"Esr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EusurN","text_ar":"عُسُرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, O, K) and ↓"},{"kind":"arabic","text_bw":"EasarN","text_ar":"عَسَرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, K) and ↓"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ","orth_type":"arrow"},{"kind":"text","text":"[respecting which, as well as some other words here mentioned, see below, in this paragraph, and see what is said of its contr."},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"EusorapN","text_ar":"عُسْرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEosarapN","text_ar":"مَعْسَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEosurapN","text_ar":"مَعْسُرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EusoraY","text_ar":"عُسْرَى","orth_type":"arrow"},{"kind":"text","text":"[all of which are app. inf. ns., of 1, q. v.,] (K)"},{"kind":"italic_en","text":"Difficulty; hardness; straitness; intricacy; contr. of"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":". (S, A, O, K.) ―         -b2-  'Eesà Ibn-'Omar observes that every noun of three letters of which the first is with damm and the second quiescent is pronounced by some of the Arabs with the second movent like the first; as"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusurN","text_ar":"عُسُرٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ruHomN","text_ar":"رُحْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruHumN","text_ar":"رُحُمٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HulomN","text_ar":"حُلْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HulumN","text_ar":"حُلُمٌ"},{"kind":"text","text":". (S, O.) ―         -b3-  It is said in the Kur [lxv. 7],"},{"kind":"arabic","text_bw":"sayajoEalu A@ll~`hu baEoda EusorK yusorFA","text_ar":"سَيَجْعَلُ ا@للّٰهُ بَعْدَ عُسْرٍ يُسْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God will give, after difficulty, ease"},{"kind":"text","text":"]. (O, TA.) And again, [xciv. 5 and 6,]"},{"kind":"arabic","text_bw":"faA_in~a maEa A@loEusori yusorFA maEa A@loEusori","text_ar":"فَاـِنَّ مَعَ ا@لْعُسْرِ يُسْرًا مَعَ ا@لْعُسْرِ"},{"kind":"arabic","text_bw":"yusorFA","text_ar":"يُسْرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And verily with difficulty"},{"kind":"text","text":"shall be"},{"kind":"italic_en","text":"ease: verily with difficulty"},{"kind":"text","text":"shall be"},{"kind":"italic_en","text":"ease"},{"kind":"text","text":"]: on reciting which, Ibn-Mes'ood said,"},{"kind":"arabic","text_bw":"lano yagoliba EusorN yusorayoni","text_ar":"لَنْ يَغْلِبَ عُسْرٌ يُسْرَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A difficulty will not predominate over twofold ease"},{"kind":"text","text":"], which, says Abu-l-'Abbás, is meant as an explanation of the words of the Kur immediately preceding it, agreeably with a rule mentioned by Fr [and applying to most cases, but not to all]: for"},{"kind":"arabic","text_bw":"AlEsr","text_ar":"العسر"},{"kind":"text","text":"being mentioned, and then repeated with"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", the latter is known to be the same as the former; and"},{"kind":"arabic","text_bw":"ysrA","text_ar":"يسرا"},{"kind":"text","text":"being mentioned, and repeated without"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", the latter is known to be different from the former. (O, * TA.) ―         -b4-  It is also said,"},{"kind":"arabic","text_bw":"lawo daxala AlEusoru juHorFA ladaxala Alyusoru Ealayohi","text_ar":"لَوْ دَخَلَ العُسْرُ جُحْرًا لَدَخَلَ اليُسْرُ عَلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"If difficulty were to enter a burrow in the ground, ease would enter upon it"},{"kind":"text","text":"]. (TA.) ―         -b5-  As to ↓"},{"kind":"arabic","text_bw":"maEosuwrN","text_ar":"مَعْسُورٌ","orth_type":"arrow"},{"kind":"text","text":", it is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"mayosuwrN","text_ar":"مَيْسُورٌ"},{"kind":"text","text":", and both are inf. ns.: (S, O:) or they are put in the places of"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yusorN","text_ar":"يُسْرٌ"},{"kind":"text","text":": (TA:) or accord. to Sb, they both are epithets; for he holds that there is no inf. n. of the measure"},{"kind":"arabic","text_bw":"mafoEuwlN","text_ar":"مَفْعُولٌ"},{"kind":"text","text":"; and the saying"},{"kind":"arabic","text_bw":"daEohu A_ilaY mayosuwrihi waA_ilaY","text_ar":"دَعْهُ اـِلَى مَيْسُورِهِ وَاـِلَى"},{"kind":"arabic","text_bw":"maEosuwrihi","text_ar":"مَعْسُورِهِ"},{"kind":"text","text":"is expl. as signifying"},{"kind":"italic_en","text":"Leave thou him to a thing in which he experiences ease, and to a thing in which he experiences difficulty:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEoquwlN","text_ar":"مَعْقُولٌ"},{"kind":"text","text":"is also expl. in like manner. (S, O.) [In like manner also,]"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"balagotu maEosuwra","text_ar":"بَلَغْتُ مَعْسُورَ","orth_type":"arrow"},{"kind":"text","text":"[may be expl. as signifying"},{"kind":"italic_en","text":"I effected a thing in which such a one experienced difficulty;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"I treated such a one with hardness, harshness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illnature;"},{"kind":"text","text":"being] said when thou hast not treated the person of whom thou speakest with gentleness, graciousness, courtesy, or civility. (O, TA.) You also say, [using"},{"kind":"arabic","text_bw":"mEswr","text_ar":"معسور"},{"kind":"text","text":"and its contr."},{"kind":"arabic","text_bw":"myswr","text_ar":"ميسور"},{"kind":"text","text":"as epithets,] ↓"},{"kind":"arabic","text_bw":"xu*N mayosuwrahu wadaEN maEosuwrahu","text_ar":"خُذٌ مَيْسُورَهُ وَدَعٌ مَعْسُورَهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Take thou what is easy thereof, and leave thou what is difficult thereof"},{"kind":"text","text":"]. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Poverty:"},{"kind":"text","text":"(Msb:) and ↓"},{"kind":"arabic","text_bw":"EusorapN","text_ar":"عُسْرَةٌ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"the same:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"littleness of possessions, of property, of wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of power:"},{"kind":"text","text":"(S, TA:) and ↓"},{"kind":"arabic","text_bw":"maEosarapN","text_ar":"مَعْسَرَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEosurapN","text_ar":"مَعْسُرَةٌ","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"the same:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"difficulty, and poverty;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"mayosarapN","text_ar":"مَيْسَرَةٌ"},{"kind":"text","text":": (O, TA:) both inf. ns.: (O:) and ↓"},{"kind":"arabic","text_bw":"EusoraY","text_ar":"عُسْرَى","orth_type":"arrow"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"the same:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"difficult things, affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"yusoraY","text_ar":"يُسْرَى"},{"kind":"text","text":": (S, O, TA:) and fem. of"},{"kind":"arabic","text_bw":"A^aEosaru","text_ar":"اَعْسَرُ"},{"kind":"text","text":", applied to a thing, or an affair, or a circumstance. (TA.) ―         -b7-  ↓"},{"kind":"arabic","text_bw":"jayo$u AlEusorapi","text_ar":"جَيْشُ العُسْرَةِ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The army of difficulty"},{"kind":"text","text":"] is an appellation given to the army of Tabook; because they were summoned to go thither during the intense heat of summer, (O, K,) and in the season of the ripening of the fruit, (O, TA,) so that it was hard to them; (O, K;) and because the Prophet never warred before with so numerous an army, amounting to thirty thousand. (O, TA.) ―         -b8-  ↓"},{"kind":"arabic","text_bw":"fasanuyas~iruhu liloEusoraY","text_ar":"فَسَنُيَسِّرُهُ لِلْعُسْرَى","orth_type":"arrow"},{"kind":"text","text":", in the Kur [xcii. 10], signifies, as some say, ["},{"kind":"italic_en","text":"We will smooth his way"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to punishment, and a difficult case."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["S","A","O","K","TA","Msb"]},{"entry_id":"n29078","headword_ar":"عِسْرٌ","root":"Esr","body":[{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"AlEisoru","text_ar":"العِسْرُ"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"A certain tribe of the Jinn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Genii;"},{"kind":"text","text":"(S, O, K;) as also ↓"},{"kind":"arabic","text_bw":"EasorN","text_ar":"عَسْرٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"AlEasoru","text_ar":"العَسْرُ"},{"kind":"text","text":": (O, K:) or the first, (S, O,) or second and ↓ last, (K,)"},{"kind":"italic_en","text":"a land inhabited by Jinn."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["S","O","K"]},{"entry_id":"n29079","headword_ar":"عَسَرٌ","root":"Esr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n29080","headword_ar":"عَسِرٌ","root":"Esr","body":[{"kind":"italic_en","text":"Difficult, hard, hard to be done"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished, hard to be borne"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endured, distressing, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intricate;"},{"kind":"text","text":"(S, O, Msb, K; *) applied to an affair, or a thing; (S, O, Msb;) as also ↓"},{"kind":"arabic","text_bw":"EasiyrN","text_ar":"عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":". (S, A, O, Msb, K.) ―         -b2-"},{"kind":"arabic","text_bw":"HaAjapN EasirN","text_ar":"حَاجَةٌ عَسِرٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"EasiyrN","text_ar":"عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"EasiyrN","text_ar":"عَسِيرٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EasiyrapN","text_ar":"عَسِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"A want difficult of attainment."},{"kind":"text","text":"(L, K.) ―         -b3-"},{"kind":"arabic","text_bw":"yawomN EasirN","text_ar":"يَوْمٌ عَسِرٌ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"EasiyrN","text_ar":"عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"A^aEosaru","text_ar":"اَعْسَرُ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"A difficult day; a day of difficulty;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"a hard, distressful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"calamitous, day;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an unfortunate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unlucky, day."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"rajulN EasirN","text_ar":"رَجُلٌ عَسِرٌ"},{"kind":"italic_en","text":"A man having little gentleness in"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the execution of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"affairs:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"hard in disposition;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"illnatured."},{"kind":"text","text":"(K.) [See 1.] ―         -b5-  ↓"},{"kind":"arabic","text_bw":"naAqapN EasiyrN","text_ar":"نَاقَةٌ عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, O,) or ↓"},{"kind":"arabic","text_bw":"EasiyrapN","text_ar":"عَسِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (as in one copy of the S,)"},{"kind":"italic_en","text":"A she-camel not trained:"},{"kind":"text","text":"(S, A, O:) or ↓"},{"kind":"arabic","text_bw":"naAqapN EasiyrN","text_ar":"نَاقَةٌ عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EawosaraAnapN","text_ar":"عَوْسَرَانَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EayosaraAnapN","text_ar":"عَيْسَرَانَةٌ","orth_type":"arrow"},{"kind":"text","text":"[and app. ↓"},{"kind":"arabic","text_bw":"EayosaraAniy~apN","text_ar":"عَيْسَرَانِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"] (K) or ↓"},{"kind":"arabic","text_bw":"EawosaraAniy~apN","text_ar":"عَوْسَرَانِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(Lth, Az, S, O, L) and ↓"},{"kind":"arabic","text_bw":"EayosaraAniy~apN","text_ar":"عَيْسَرَانِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(Lth, Az, TS, O, L) and ↓"},{"kind":"arabic","text_bw":"EayosuraAniy~apN","text_ar":"عَيْسُرَانِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (Lth, Az, TS, O,) but what Lth says is not agreeable with the usage of the Arabs, (Az, TS, O,)"},{"kind":"italic_en","text":"a she-camel that is ridden,"},{"kind":"text","text":"(Lth, Az, S, O, TA,) or"},{"kind":"italic_en","text":"laden,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"before she has been trained:"},{"kind":"text","text":"(Lth, Az, S, O, TA:) or"},{"kind":"italic_en","text":"that has been taken in the first stage of her training, while yet difficult to manage, and had her nose-rein attached, and been ridden:"},{"kind":"text","text":"(K:) and the epithet applied to a he-camel is ↓"},{"kind":"arabic","text_bw":"EasiyrN","text_ar":"عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) or"},{"kind":"arabic","text_bw":"EasirN","text_ar":"عَسِرٌ"},{"kind":"text","text":", (CK,) and ↓"},{"kind":"arabic","text_bw":"EayosaraAnN","text_ar":"عَيْسَرَانٌ","orth_type":"arrow"},{"kind":"text","text":"(Lth, Az, and so in some copies of the K,) and ↓"},{"kind":"arabic","text_bw":"EayosuraAnN","text_ar":"عَيْسُرَانٌ","orth_type":"arrow"},{"kind":"text","text":"(Lth, Az, TA, and so, in the place of the form immediately preceding, in some copies of the K,) and ↓"},{"kind":"arabic","text_bw":"EayosaraAniY~N","text_ar":"عَيْسَرَانِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"EayosuraAniY~N","text_ar":"عَيْسُرَانِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(K, TA) and ↓"},{"kind":"arabic","text_bw":"EawosaraAniY~N","text_ar":"عَوْسَرَانِىٌّ","orth_type":"arrow"},{"kind":"text","text":". (S, O.) ―         -b6-  Also ↓"},{"kind":"arabic","text_bw":"naAqapN EasiyrN","text_ar":"نَاقَةٌ عَسِيرٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A she-camel that raises her tail in her running;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaAsirN","text_ar":"عَاسِرٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the latter,"},{"kind":"italic_en","text":"raising her tail after conception:"},{"kind":"text","text":"(TA:) [see 1:] and [its pl.] ↓"},{"kind":"arabic","text_bw":"EawaAsiru","text_ar":"عَوَاسِرُ","orth_type":"arrow"},{"kind":"text","text":", applied to wolves,"},{"kind":"italic_en","text":"that are agitated in their running, and shake the head, and contort"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"takosiru","text_ar":"تَكْسِرُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"their tails,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"by reason of briskness."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"naAqapN EawosaraAniy~apN","text_ar":"نَاقَةٌ عَوْسَرَانِيَّةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A she-camel that is wont to raise her tail when she runs,"},{"kind":"text","text":"(TS, O, K,)"},{"kind":"italic_en","text":"by reason of sprightliness."},{"kind":"text","text":"(O, TA.) In the L, instead of"},{"kind":"arabic","text_bw":"taEosiyru","text_ar":"تَعْسِيرُ"},{"kind":"text","text":", preceding"},{"kind":"arabic","text_bw":"*anabihaA","text_ar":"ذَنَبِهَا"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"takosiyru","text_ar":"تَكْسِيرُ"},{"kind":"text","text":". (TA.) ―         -b7-  Also, ↓"},{"kind":"arabic","text_bw":"naAqapN EasiyrN","text_ar":"نَاقَةٌ عَسِيرٌ","orth_type":"arrow"},{"kind":"text","text":", (Lth, O, K,) or ↓"},{"kind":"arabic","text_bw":"EasiyrapN","text_ar":"عَسِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) accord. to Lth, (TA,)"},{"kind":"italic_en","text":"A she-camel not conceiving during her year"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after having been covered"},{"kind":"text","text":"]: (Lth, S, O, K:) but Az says that this explanation by Lth is not correct, and that"},{"kind":"arabic","text_bw":"nAqp Esyr","text_ar":"ناقة عسير"},{"kind":"text","text":"signifies, as expl. above, “ a she-camel that is ridden before she has been trained; ” and so As explains it; and ISk says the same. (TA.)"}],"source_refs":["K","L","S","Msb","A","O","Lth","Az","TS","TA","CK"]},{"entry_id":"n29081","headword_ar":"عُسُرٌ","root":"Esr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EusorN","text_ar":"عُسْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}