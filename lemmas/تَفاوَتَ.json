":true,"entry_ids":["n34760"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%81%D8%A7%D9%88%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be disparate, to vary, to differ, to be distinguishable","examples":[{"text":"تَانِكَ ٱلْأُخْتَانِ تَتَفَاوَتَانِ فِي ٱلسِّنِّ","english":"Those two sisters differ in age."}]},{"pos":"noun","gloss":"verbal noun of تَفَاوَتَ (tafāwata) (form VI)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"difference, distinction, disparity"},{"pos":"noun","gloss":"state of being uneven"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34760","headword_ar":"تفاوت","root":"fwt","body":[{"kind":"text","text":"has for its inf. n."},{"kind":"arabic","text_bw":"tafaAwutN","text_ar":"تَفَاوُتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tafaAwatN","text_ar":"تَفَاوَتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tafaAwitN","text_ar":"تَفَاوِتٌ"},{"kind":"text","text":", (S, M, O, K,) the second and third of which are mentioned by AZ; the second is said by ISk (who mentions this and the third, M) to be of the dial. of the Kilábees, and the third is mentioned by El-'Ambaree; both anomalous, for the inf. n. of a verb of the measure"},{"kind":"arabic","text_bw":"tafaAEala","text_ar":"تَفَاعَلَ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"tafaAEulN","text_ar":"تَفَاعُلٌ"},{"kind":"text","text":". [in the copies of the S"},{"kind":"arabic","text_bw":"ytfAEl","text_ar":"يتفاعل"},{"kind":"text","text":", and said to be so in J's handwriting,] with damm to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":"except in this instance (S. O:) but Sb said that there is not among inf. ns. an instance of"},{"kind":"arabic","text_bw":"tafaAEalN","text_ar":"تَفَاعَلٌ"},{"kind":"text","text":"nor of"},{"kind":"arabic","text_bw":"tafaAEilN","text_ar":"تَفَاعِلٌ"},{"kind":"text","text":". (M.)"},{"kind":"arabic","text_bw":"maA taraY fiY xaloqi A@lr~aHom`ni mino tafaAwutK","text_ar":"مَا تَرَى فِى خَلْقِ ا@لرَّحْمٰنِ مِنْ تَفَاوُتٍ"},{"kind":"text","text":", (T, M, O, K,) or ↓"},{"kind":"arabic","text_bw":"tafaw~utK","text_ar":"تَفَوُّتٍ","orth_type":"arrow"},{"kind":"text","text":", (T, O, K.) [the former in the CK and the latter in other copies of the K,] the latter being the reading of Hamzeh and Ks, in the Kur [lxvii. 3], (O,) means"},{"kind":"italic_en","text":"Thou seest not in the creation of the Compassionate,"},{"kind":"text","text":"(M, O,) i. e. in his creation of the heaven, (M,)"},{"kind":"italic_en","text":"any incongruity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discordance;"},{"kind":"text","text":"(T, M, O;) or"},{"kind":"italic_en","text":"any fault, defect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection,"},{"kind":"text","text":"so that the beholder might say, “ If it were thus, it were better; ” (T, O, K;) thus the latter reading is expl. by Es-Suddee; (T, O, TA;) and Fr says that both readings have one meaning: (T, TA:) you say of a thing ↓"},{"kind":"arabic","text_bw":"tfw~t","text_ar":"تفوّت","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tfAwt","text_ar":"تفاوت"},{"kind":"text","text":". (M.) ―         -b2-  And one says,"},{"kind":"arabic","text_bw":"tfAwt Al$~ayoA=ni","text_ar":"تفاوت الشَّيْا=نِ"},{"kind":"italic_en","text":"The two things were far apart, one from the other;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"widely distinct"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated;"},{"kind":"text","text":"(S, O, K;) or"},{"kind":"page_break","n":2455},{"kind":"italic_en","text":"differed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"were different."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"tafaAwataA","text_ar":"تَفَاوَتَا"},{"kind":"arabic","text_bw":"fiY AlfaDoli","text_ar":"فِى الفَضْلِ"},{"kind":"italic_en","text":"They two were distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissimilar, in respect of excellence,"},{"kind":"text","text":"(Msb,) or"},{"kind":"arabic","text_bw":"fiY Al$~arafi","text_ar":"فِى الشَّرَفِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in eminence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nobility"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","M","O","K","T","TA","Msb"]}]},"classical_definitions":null}