":["n7137"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AD%D9%92%D8%AA%D9%8E%D8%AC%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hide, to cover oneself, to veil, to vanish"}]},"etymology":null,"ipa":["/iħ.ta.d͡ʒa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7137","headword_ar":"احتجب","root":"Hjb","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became prevented, hindered, debarred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"precluded: he became secluded;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he secluded himself:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became veiled, concealed, hidden, covered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protected;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"tHj~b","text_ar":"تحجّب","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) You say,"},{"kind":"arabic","text_bw":"AHtjb","text_ar":"احتجب"},{"kind":"arabic","text_bw":"Almaliku Eini Aln~aAsi","text_ar":"المَلِكُ عِنِ النَّاسِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The King secluded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became secluded"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed, from the people"},{"kind":"text","text":"]. (S, A.) And"},{"kind":"arabic","text_bw":"AHtjbt Al$~amosu fiY Als~aHaAbi","text_ar":"احتجبت الشَّمْسُ فِى السَّحَابِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The sun became concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concealed itself, in the clouds"},{"kind":"text","text":"]. (A, TA.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"AHtjbt AlmaroA^apu biyawmK","text_ar":"احتجبت المَرْاَةُ بِيَومٍ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"biyawomK mino taAsiEihaA","text_ar":"بِيَوْمٍ مِنْ تَاسِعِهَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mino yawomK mino taAsiEihaA","text_ar":"مِنْ يَوْمٍ مِنْ تَاسِعِهَا"},{"kind":"text","text":", (TA,) [as though meaning"},{"kind":"italic_en","text":"The woman secluded herself from"},{"kind":"text","text":"the commencement of"},{"kind":"italic_en","text":"a day of her ninth"},{"kind":"text","text":"month of pregnancy:] said of a pregnant woman, (TA,) when a day has passed of her ninth [month, during which it was probably a custom for a woman to seclude herself in the house or tent]. (K, TA.)"}],"source_refs":["K","TA"]}]},"classical_definitions":null}