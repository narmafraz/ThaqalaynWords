{"lemma":"مَزَّ","slug":"مَزَّ","root":"م.ز.ز","root_slug":"م-ز-ز","root_link":"/words/roots/م-ز-ز","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"مَزَزْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"مَزَزْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"مَزَزْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"مَزَزْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"مَزَزْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"مَزَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"مَزَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"مَزّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"مَزَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"مَزُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"مَزَزْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَمُزّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَمْزُز","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَمُزِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَمُزِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَمُزّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَمُزّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَمُزُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَمُزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَمْزُزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَمُزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَمْزُز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَمُزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَمْزُز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَمُزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَمُزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَمُزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَمُزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَمُزُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَمُزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَمْزُزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَمُزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَمُزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"مَزَزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"مَزَزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n38512"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to suck, to slurp","examples":[{"text":"فما مزه قهوة قرقف شمولا تروق براووقها","english":"What he slurps of wine from a bowl, it wholly gets strained by its sifter."}]},{"pos":"noun","gloss":"verbal noun of مَزَّ (mazza) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Onomatopoeic, compare مَصَّ (maṣṣa, “to suck”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38512","headword_ar":"مَزَّ","root":"mz","body":[{"kind":"text","text":", [sec. pers."},{"kind":"arabic","text_bw":"mazuzota","text_ar":"مَزُزْتَ"},{"kind":"text","text":"aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"mazaAzapN","text_ar":"مَزَازَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquired, a taste between sweet and sour."},{"kind":"text","text":"(TA; but only the inf. n. of the verb in this sense is there mentioned.) AZ also mentions, as heard from the Kilábees, the saying,"},{"kind":"arabic","text_bw":"qa*o maz~a $araAbukumo A^aqobaHa AlmazaAzapi","text_ar":"قَذْ مَزَّ شَرَابُكُمْ اَقْبَحَ المَزَازَةِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Almuzuwzapi","text_ar":"المُزُوزَةِ"},{"kind":"text","text":", as meaning, ["},{"kind":"italic_en","text":"Your beverage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wine,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hath become very sour."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"maz~ahu","text_ar":"مَزَّهُ"},{"kind":"text","text":", (S, A, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"maz~N","text_ar":"مَزٌّ"},{"kind":"text","text":", (S, TA,) [and accord. to one copy of the S,"},{"kind":"arabic","text_bw":"mazaAzapN","text_ar":"مَزَازَةٌ"},{"kind":"text","text":", but this I regard as a mistake of a copyist,]"},{"kind":"italic_en","text":"He sucked it; i. q."},{"kind":"arabic","text_bw":"maS~ahu","text_ar":"مَصَّهُ"},{"kind":"text","text":". (S, A, K.)"}],"source_refs":["S","A","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%85%D8%B2/","headword_ar":"مز","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=53765#512e37","body_html":"مز: تو مرد (تركية مست): جواريب (الملابس 405) (بيرتون 1: 274).<br>مز: فج، غير ناضج (بوشر).<br>مزز: محمض (بوشر).<br>ممززة: تصنع من اللحم المطبوخ بالبخار مع البصل وثفل قصب السكر والخل و (دوزينة) من الدقيق المقطف (لين عادات 2: 267)."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=53765#93d8eb","body_html":"<span class=\"title1\">مز</span><br><span>المِز: الشيْءُ المَزِيْزُ؛ وهو الذي يَقعُ مَوْقِعَكَ في بلاغَتِه وجَوْدَتِه وكَثْرَتِه، يُقال: عَزِيْز مَزِيْزٌ، والفِعْلُ: مَزَّ يَمُز مَزَازَةً. والمِزُّ: الفَضْلُ، لِذا على ذا مِز، وهو أمَز منه. والمَزَزُ - أيضاً -: الكَثْرَةُ. والمُز: طَعْم بَيْنَ الحُمُوْضَةِ والحَلاَوَةِ. والمُزَةُ: الخَمْرَةُ اللذِيذَةُ الطعْمِ، وهي المُزَّاءُ والمَزاء. والتَمَرزُ: شُرْبُ ذلك، وهو المَص - أيضاً - قَليلاً قَليلاً. والمَضةُ: مَزَّةٌ. وصَحْفَةٌ مِمَزَّة: واسِعَةٌ. وطَعَام مَزِيْز: أي قَلِيل.</span><br><span>وبُر مازٌّ: وهو الذي لا يَكادُ يُعْجَنُ لِرَخَاوَته. وخَلْق مَزْمَازٌ: أي حَسَنٌ مُمْتَد. وتَمَزْمَزَتِ الألْيَةُ: تَحَرَّكَتْ. وتَمَزْمَزَ الرَّجُلُ للقِيَام. وتَمَزْمَزَ بَنُو فلانٍ: أي انْحَاشُوا وفَرِقُوا. ومازَزْتُ بَيْنَ الشَّيْئيْنِ: أي باعَدْتُ. وتَمَازَّتْ به النيَّةُ: تَبَاعَدَتْ. وذَهَبَ على مَزَزِه: أي مَهَلِه.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=53765#37a91e","body_html":"<div>مز</div><div><br></div><div>1 مَزَّ, [sec. <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> مَزُزْتَ <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَزَازَةٌ, It had, or acquired, a taste between sweet and sour. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>; but only the <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of the verb in this sense is there mentioned.) <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr> also mentions, as heard from the Kilábees, the saying, قَذْ مَزَّ شَرَابُكُمْ أَقْبَحَ المَزَازَةِ, and المُزُوزَةِ, as meaning, [Your beverage, or wine,] hath become very sour. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)</div><div><br></div><div><span class=\"sub-sense\">A2:</span> مَزَّهُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَزٌّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) [and <abbr title=\"according\">accord.</abbr> to one copy of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, مَزَازَةٌ, but this I regard as a mistake of a copyist,] He sucked it; <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> مَصَّهُ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.)</div><div><br></div><div>5 تَمَزَّّ [He sipped:] see 10 in art. دبر.</div><div><br></div><div>R. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1 مَزْمَزَهُ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> مَزْمَزَةٌ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) He put him, or it, in motion, or into a state of commotion; or shook him, or it; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) and moved him, or it, forwards and backwards: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or he put him, or it, in violent motion, or into a state of violent commotion; or shook him, or it, violently: (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, art. تر; and <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) as, for instance, a drunken man, in order that he might recover from his intoxication. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See also تَرْتَرَهُ.</div><div><br></div><div>R. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 2 تَمَزْمَزَ He ate, and drank, what had a taste between sweet and sour. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)</div><div><br></div><div><span class=\"sub-sense\">A2:</span> He, or it, was, or became, put in motion, or in a state of commotion, or shaken, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and moved forwards and backwards: or in violent motion, or into a state of violent commotion, or shaken violently. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) </div><div><br></div><div><span class=\"sub-sense\">b2:</span> تَمَزْمَزَ لِلْقِيَامِ He raised himself, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or put himself in motion, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) to stand. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)</div><div><br></div><div>مَزٌّ: see its <abbr title=\"feminine, مؤَنَّثٌ\">fem.</abbr> مَزَّةٌ.</div><div><br></div><div>مُزٌّ, applied to beverage, or wine, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and to a pomegranate, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) Having a taste between sweet and sour: (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) <abbr title=\"feminine, مؤَنَّثٌ\">fem.</abbr> with ة. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr> mentions its signifying Very sour beverage or wine; as heard from the Kilábees. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) You say also خَمْرَةٌ مُزَّةٌ, meaning, Wine, or a wine in which is a taste between sweet and sour; said to be from mixing unripe and ripe dates [in making it]: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or wine in which is a sour taste, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and in which is no goodness. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) See also مَزَّةٌ.</div><div><br></div><div>قَهْوَةٌ مَزَّةٌ Wine having a pleasant, delicious, or sweet, taste: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) so called because it bites, or burns, the tongue; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) as also ↓ مُزٌّ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) which, however, is [not an <abbr title=\"نَعْتٌ and وَصْفٌ and صِفَةٌ\">epithet</abbr> but] a <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or the former signifies لذيذة المقطع [<abbr title=\"apparently\">app.</abbr> meaning having a pleasant sharpness, or acidity]: (so in the <abbr title=\"The Lisān al-ʿArab of Ibn Manẓur\">L</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"al-Jawharī\">J</abbr> says, that one should not say ↓ مِزَّةٌ, but this form is said to occur in one relation of a verse or El-Aashà. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See also مُزٌّ.</div><div><br></div><div><span class=\"sub-sense\">A2:</span> Also مَزَّةٌ A single suck or sucking. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) It is said in a <abbr title=\"tradition (hadith), حَدِيْثٌ\">trad.</abbr> لَا تُحَرِّمُ المَزَّةُ وَلَا المزَّتَانِ [The sucking once will not render marriage unlawful, nor will the two suckings], meaning, in drawing milk from the breast. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) [See a similar saying <abbr title=\"under the heading\">voce</abbr> عَيْفَةٌ.]</div><div><br></div><div>مِزَّةٌ: see مَزَّةٌ.</div>"}]}}