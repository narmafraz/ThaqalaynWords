m":"d"},{"role":"present_3md","form":"يُتَمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُتَمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُتِمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتِمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتَمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُتَمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُتِمُّونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُتِمُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُتَمُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُتَمُّونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُتْمِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَتْمَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَتْمَمْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُتِمّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُتِمّ","in_corpus":true,"count":48,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُتَمّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُتَمّ","in_corpus":true,"count":48,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":435,"cross_references":{"qac":{"found":true,"lemma_key":"أَتَمَّ","root":"تمم","pos":"V","occurrence_count":16},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n141","","n4080"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AA%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n141","headword_ar":"اَتْمٌ","root":"Atm","body":[{"kind":"text","text":", (M, K,) in, or in relation to, a"},{"kind":"arabic","text_bw":"siqaA='","text_ar":"سِقَا=ء"},{"kind":"text","text":"[or skin for water or milk], (TA,) signifies The"},{"kind":"italic_en","text":"having two punctures of a seam"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xuzorataAni","text_ar":"خُزْرَتَانِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"rent so as to become one."},{"kind":"text","text":"(M, K.) You say,"},{"kind":"arabic","text_bw":"A^atamati AlqirobapN","text_ar":"اَتَمَتِ القِرْبَةٌ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^atomN","text_ar":"اَتْمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The water-skin had its two punctures"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"xzrtAhA","text_ar":"خزرتاها"},{"kind":"text","text":"[or rather"},{"kind":"italic_en","text":"two of its punctures,"},{"kind":"text","text":"agreeably with the explanation of the inf. n. in the M and K, as given above,])"},{"kind":"italic_en","text":"rent so that they became one."},{"kind":"text","text":"(TK.) ―         -b2-  [And hence,] The"},{"kind":"italic_en","text":"meeting together of the"},{"kind":"arabic","text_bw":"masolakaAni","text_ar":"مَسْلَكَانِ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vagina and rectum"},{"kind":"text","text":"]: whence"},{"kind":"arabic","text_bw":"A^atuwmN","text_ar":"اَتُومٌ"},{"kind":"text","text":"[q. v.] as an epithet applied to a woman. (Ham p. 373.) ―         -b3-  [It seems to be indicated in the T, that one says,"},{"kind":"arabic","text_bw":"A^atima AlnisaA='u","text_ar":"اَتِمَ النِسَا=ءُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^atama","text_ar":"اَتَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; as meaning, or perhaps the former only,"},{"kind":"italic_en","text":"The women assembled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came together:"},{"kind":"text","text":"for I there find, immediately after"},{"kind":"arabic","text_bw":"maA^otamN","text_ar":"مَاْتَمٌ"},{"kind":"text","text":"as signifying “a place in which women assemble,” “one says,"},{"kind":"arabic","text_bw":"A^atima","text_ar":"اَتِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^atama","text_ar":"اَتَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":":” but it is then added that, accord. to Khálid Ibn-Yezeed,"},{"kind":"arabic","text_bw":"mA^tm","text_ar":"ماتم"},{"kind":"text","text":"is from"},{"kind":"arabic","text_bw":"A^atima","text_ar":"اَتِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":".]       -A2-"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"fatoqN","text_ar":"فَتْقٌ"},{"kind":"text","text":"[The act of"},{"kind":"italic_en","text":"rending, rending asunder, ripping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"undoing the sewing"},{"kind":"text","text":"of a thing]. (TA.) ―         -b2-  The act of"},{"kind":"italic_en","text":"cutting."},{"kind":"text","text":"(Sgh, K.) You say,"},{"kind":"arabic","text_bw":"A^atamahu","text_ar":"اَتَمَهُ"},{"kind":"italic_en","text":"He cut it."},{"kind":"text","text":"(TK.)       -A3-"},{"kind":"arabic","text_bw":"A^atama","text_ar":"اَتَمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"He brought together,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"united,"},{"kind":"text","text":"two things. (T.) [See"},{"kind":"arabic","text_bw":"A^atuwmN","text_ar":"اَتُومٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maA^otamN","text_ar":"مَاْتَمٌ"},{"kind":"text","text":".]       -A4-"},{"kind":"arabic","text_bw":"A^atama biAlmakaAni","text_ar":"اَتَمَ بِالمَكَانِ"},{"kind":"text","text":", (Sgh, Msb,) with two forms of aor., [app."},{"kind":"text","text":"and"},{"kind":"text","text":",] (Msb,) inf. n."},{"kind":"arabic","text_bw":"A^atomN","text_ar":"اَتْمٌ"},{"kind":"text","text":", (Sgh, K,) or"},{"kind":"arabic","text_bw":"A^utuwmN","text_ar":"اُتُومٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"A^atima","text_ar":"اَتِمَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"He stayed, remained, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place."},{"kind":"text","text":"(Sgh, Msb, K.)"}],"source_refs":["M","K","TA","Sgh","Msb"]},{"entry_id":"n4080","headword_ar":"اتمّ","root":"tm","body":[{"kind":"text","text":", said of the moon: see 1. ―         -b2-  Said of a plant,"},{"kind":"italic_en","text":"It became tall and full-grown;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became of its full height, and blossomed."},{"kind":"text","text":"(M, K.) ―         -b3-"},{"kind":"arabic","text_bw":"A^atam~ato","text_ar":"اَتَمَّتْ"},{"kind":"text","text":", said of one that is pregnant,"},{"kind":"italic_en","text":"She completed the days of her gestation:"},{"kind":"text","text":"(S:) or, said of a woman and of a she-camel, (M,)"},{"kind":"italic_en","text":"she became near to bringing forth."},{"kind":"text","text":"(M, K.) ―         -b4-"},{"kind":"arabic","text_bw":"At~m A_ilaY mawoDiEi ka*aA","text_ar":"اتّم اـِلَى مَوْضِعِ كَذَا"},{"kind":"text","text":": see 1.       -A2-"},{"kind":"arabic","text_bw":"Atm~ Al$~aYo'a","text_ar":"اتمّ الشَّىْءَ"},{"kind":"text","text":", (S, M, K,) or"},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":", (Mgh,) and"},{"kind":"arabic","text_bw":"Atm~ bihi","text_ar":"اتمّ بِهِ"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"A_itomaAmN","text_ar":"اـِتْمَامٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"tm~mhu","text_ar":"تمّمهُ","orth_type":"arrow"},{"kind":"text","text":", (T, S, M, K,) inf. n."},{"kind":"arabic","text_bw":"tatomiymN","text_ar":"تَتْمِيمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tatim~apN","text_ar":"تَتِمَّةٌ"},{"kind":"text","text":"; (T, TA;) and ↓"},{"kind":"arabic","text_bw":"Asttm~hu","text_ar":"استتمّهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, K;) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tam~a","text_ar":"تَمَّ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tam~a","text_ar":"تَمَّ","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) signify the same; (S Mgh;) i. e."},{"kind":"arabic","text_bw":"jaEalahu taAm~aA","text_ar":"جَعَلَهُ تَامَّا"},{"kind":"text","text":"(M in explanation of all but the last, and K in explanation of all that are mentioned therein,) and"},{"kind":"arabic","text_bw":"A^akomalahu","text_ar":"اَكْمَلَهُ"},{"kind":"text","text":"(M in explanation of the last) ["},{"kind":"italic_en","text":"He made the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the affair, complete, entire, whole,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"full;"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"without,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"free from, deficiency; he completed it:"},{"kind":"text","text":"and sometimes,"},{"kind":"italic_en","text":"he consummated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfected, it"},{"kind":"text","text":"]."},{"kind":"arabic","text_bw":"waA^atim~uw AlHaj~a waAlEumorapa","text_ar":"وَاَتِمُّو الحَجَّ وَالعُمْرَةَ"},{"kind":"text","text":", in the Kur [ii. 192], means"},{"kind":"italic_en","text":"And perform ye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplish ye, completely, the rites and ceremonies"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the pilgrimage and the minor pilgrimage"},{"kind":"text","text":"]; (M, * Bd;) accord. to some: or, as some say,"},{"kind":"arabic","text_bw":"A_itomaAmu AlHaj~i","text_ar":"اـِتْمَامُ الحَجِّ"},{"kind":"text","text":"means that the money, or the like, that one expends in performing the pilgrimage should be lawfully obtained, and that one should refrain from doing what God has forbidden. (M.) And"},{"kind":"arabic","text_bw":"faA^atam~ahun~a","text_ar":"فَاَتَمَّهُنَّ"},{"kind":"text","text":", in the Kur [ii. 118], means"},{"kind":"italic_en","text":"And he performed them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accomplished them, completely,"},{"kind":"text","text":"(Bd, Jel,)"},{"kind":"italic_en","text":"and rightly:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"he did according to them."},{"kind":"text","text":"(Fr, TA.)       -A3-"},{"kind":"arabic","text_bw":"Atm~hu","text_ar":"اتمّهُ"},{"kind":"italic_en","text":"He gave him what are termed"},{"kind":"arabic","text_bw":"timam","text_ar":"تِمَم"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"tim~apN","text_ar":"تِمَّةٌ"},{"kind":"text","text":", and meaning"},{"kind":"arabic","text_bw":"jizaz","text_ar":"جِزَز"},{"kind":"text","text":"[explained below, voce"},{"kind":"arabic","text_bw":"tim~apN","text_ar":"تِمَّةٌ"},{"kind":"text","text":"], (M, TA,)"},{"kind":"italic_en","text":"in order that he might complete therewith his web."},{"kind":"text","text":"(TA.) [In consequence of its being misplaced in the K, this is there made to signify"},{"kind":"italic_en","text":"He gave him a"},{"kind":"arabic","text_bw":"tim~","text_ar":"تِمّ"},{"kind":"text","text":", meaning a"},{"kind":"arabic","text_bw":"faA^os","text_ar":"فَاْس"},{"kind":"text","text":"or a"},{"kind":"arabic","text_bw":"misoHaAp","text_ar":"مِسْحَاة"},{"kind":"text","text":".]"}],"source_refs":["S","M","K","Mgh","T","Bd","Jel","TA"]}]}}