n":"m","num":"p"},{"role":"present_2mp","form":"تَضْرِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَضْرِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَضْرِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَضْرِط","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَضْرِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَضْرِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَضْرِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَضْرِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَضْرِطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَضْرِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَضْرِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَضْرِط","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَضْرِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ضَرَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ضَرَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n25767"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%B1%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fart audibly"},{"pos":"noun","gloss":"verbal noun of ضَرَطَ (ḍaraṭa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/dˤa.ra.tˤa/","/dˤa.ri.tˤa/","/dˤartˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25767","headword_ar":"ضَرَطَ","root":"DrT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"DariTa","text_ar":"ضَرِطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) inf. n."},{"kind":"arabic","text_bw":"DariTN","text_ar":"ضَرِطٌ"},{"kind":"text","text":"(S, Msb, K, in the Msb said to be of the latter verb,) and"},{"kind":"arabic","text_bw":"DaroTN","text_ar":"ضَرْطٌ"},{"kind":"text","text":"(Msb, K, in the Msb said to be of the former verb,) and"},{"kind":"arabic","text_bw":"DariyTN","text_ar":"ضَرِيطٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"DuraATN","text_ar":"ضُرَاطٌ"},{"kind":"text","text":", (K,) or the last is a simple subst., (Msb,) [a coarse word, signifying]"},{"kind":"italic_en","text":"He broke wind,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"emitted wind from the anus, with a sound."},{"kind":"text","text":"(S, K.) [When it is without sound, you say"},{"kind":"arabic","text_bw":"fasaA","text_ar":"فَسَا"},{"kind":"text","text":".] Hence the prov.,"},{"kind":"arabic","text_bw":"A^awodaY AlEayoru A_il~aA DariTFA","text_ar":"اَوْدَى العَيْرُ اـِلَّا ضَرِطًا"},{"kind":"italic_en","text":"The ass had no power remaining except"},{"kind":"text","text":"[that of]"},{"kind":"italic_en","text":"emitting wind from the anus, with a sound:"},{"kind":"text","text":"(S, K:) applied to a vile, or an abject, person, and to an old man; and in allusion to a thing's becoming in a bad, or corrupt, state, so that there remains of it nothing but what is of no use: (K:) the last word is in the accus. case as denoting a thing of a different kind from that signified by the preceding noun. (O.) And"},{"kind":"arabic","text_bw":"A^ajobanu mina Almanozuwfi","text_ar":"اَجْبَنُ مِنَ المَنْزُوفِ"},{"kind":"arabic","text_bw":"DariTFA","text_ar":"ضَرِطًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More cowardly than he who is exhausted by emitting wind from the anus, with a sound"},{"kind":"text","text":"]: another prov.: [its origin is variously related: see Freytag's Arab. Prov., i. 320:] or"},{"kind":"arabic","text_bw":"Almanozuwfu","text_ar":"المَنْزُوفُ"},{"kind":"arabic","text_bw":"DariTFA","text_ar":"ضَرِطًا"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"DaroTFA","text_ar":"ضَرْطًا"},{"kind":"text","text":", for it is differently written in different copies of the K,] is"},{"kind":"italic_en","text":"a certain beast, between the dog and the cat,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"between the dog and the wolf,"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"which, when one cries out at it, emits wind from the anus, with a sound, by reason of cowardice."},{"kind":"text","text":"(Sgh, K.)"}],"source_refs":["K","Msb","S","O"]}]},"classical_definitions":null}