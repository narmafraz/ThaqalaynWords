_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَتَجاف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَجاف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":15,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n6000"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AC%D8%A7%D9%81%D9%8E%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"shun, avoid, withdraw from, loathe, be averse to, become aloof, separated or removed from, draw away, shrink or flinch from"},{"pos":"verb","gloss":"to be rude, rough, unsympathetic, act the ruffian, abuse each pther"}]},"etymology":null,"ipa":["/ta.d͡ʒaː.faː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6000","headword_ar":"تجافى","root":"jfw","body":[{"kind":"text","text":": see 1, in three places. [Said of a person prostrating himself, or lying down, it means"},{"kind":"italic_en","text":"He drew up his body from that on which he rested."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"tjAfY Eanohu","text_ar":"تجافى عَنْهُ"},{"kind":"text","text":"generally signifies"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, receded, withdrew, removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became remote"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aloof"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated by some space"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interval, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he drew away, shrank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flinched, from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"] It is said, of the difference between"},{"kind":"arabic","text_bw":"Al*~aboH","text_ar":"الذَّبْح"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Alqatol","text_ar":"القَتْل"},{"kind":"text","text":", that the former is by cutting the external jugular veins; and the latter,"},{"kind":"arabic","text_bw":"biA_iyqaAEi AlfiEili fiY AlmaHal~i maEa","text_ar":"بِاـِيقَاعِ الفِعِلِ فِى المَحَلِّ مَعَ"},{"kind":"arabic","text_bw":"Alt~ajaAfiY","text_ar":"التَّجَافِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By causing the act to take effect upon the place thereof while standing aloof"},{"kind":"text","text":"]; meaning that the"},{"kind":"arabic","text_bw":"qaAtil","text_ar":"قَاتِل"},{"kind":"text","text":"strikes from a distance, not knowing whether he will hit the place or not. (Mgh.) And [hence] you say,"},{"kind":"arabic","text_bw":"tjAfY lahu Eano Haq~ihi","text_ar":"تجافى لَهُ عَنْ حَقِّهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He relinquished,"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"he gave, to him, his right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"xmS","text_ar":"خمص"},{"kind":"text","text":".) ―         -b2-"},{"kind":"italic_en","text":"He inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned, from side to side:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from right to wrong."},{"kind":"text","text":"(Har p. 125.) [See 6 in art."},{"kind":"arabic","text_bw":"dfw","text_ar":"دفو"},{"kind":"text","text":".]"}],"source_refs":[]}]}}