{"lemma":"أَسْجَحانِ","slug":"أَسْجَحانِ","root":"س.ج.ح","root_slug":"س-ج-ح","root_link":"/words/roots/س-ج-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n18908"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B3%D9%92%D8%AC%D9%8E%D8%AD%D8%A7%D9%86%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18908","headword_ar":"اَسْجَحُ","root":"sjH","body":[{"kind":"italic_en","text":"Beautiful, and of just proportion;"},{"kind":"text","text":"(T, S, L, K;) applied to the make, (T,) or to the face, (S,) or to a man: (L:) or a face"},{"kind":"italic_en","text":"equable in form."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"rajulN A^asojaHu Alxad~ayoni","text_ar":"رَجُلٌ اَسْجَحُ الخَدَّيْنِ"},{"kind":"text","text":"(A, L, TA)"},{"kind":"italic_en","text":"A man even, and soft, and long, in moderation, with little flesh, and wide, in the cheeks:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"smooth, and long, with little flesh, and wide, in the cheeks."},{"kind":"text","text":"(L.) ―         -b2-  Also A camel"},{"kind":"italic_en","text":"thin in the lip."},{"kind":"text","text":"(Ham p. 283.) ―         -b3-  And the fem.,"},{"kind":"arabic","text_bw":"sajoHaA='u","text_ar":"سَجْحَا=ءُ"},{"kind":"text","text":", A she-camel"},{"kind":"italic_en","text":"perfect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complete,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"in length,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tallness, and in largeness:"},{"kind":"text","text":"(L:) and a she-camel"},{"kind":"italic_en","text":"long in the back."},{"kind":"text","text":"(K.)"}],"source_refs":["T","S","L","A","TA","K"]}]},"classical_definitions":null}