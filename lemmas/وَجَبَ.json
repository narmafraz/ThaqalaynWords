{"lemma":"وَجَبَ","slug":"وَجَبَ","root":"#.ج.ب","root_slug":"_-ج-ب","root_link":"/words/roots/_-ج-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"وَجَبْتَ","in_corpus":true,"count":32,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"وَجَبْتِ","in_corpus":true,"count":32,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"وَجَبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"وَجَبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"وَجَبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"وَجَبَ","in_corpus":true,"count":115,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"وَجَبَت","in_corpus":true,"count":32,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"وَجَبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"وَجَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"وَجَبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"وَجَبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجِب","in_corpus":true,"count":45,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجِبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجِبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجِبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجِبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجِبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجِبْنَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجِب","in_corpus":true,"count":298,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجِب","in_corpus":true,"count":45,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجِبانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجِبْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجِب","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجِب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"وَجَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَجَبْتُ","in_corpus":true,"count":32,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":644,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n41659"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%AC%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be necessary, have to be; must: followed by عَلَى (ʕalā, “on”) or by أَنْ (ʔan) and the subjunctive with a personal subject","tags":["intransitive"],"examples":[{"text":"كَمَا يَجِبُ","english":"as it should be, as it must be"},{"text":"يَجِبُ أَن أَذْهَبَ","english":"It is necessary for me to go; I must go"}]},{"pos":"verb","gloss":"to be one's duty; to be incumbent, imposed, enjoined: followed by عَلَى (ʕalā, “on”)","tags":["intransitive"],"examples":[{"text":"يَجِب عَلَيْهِ أَنْ ...","english":"it is his duty to, he has to, he must"}]},{"pos":"verb","gloss":"to impose (something) on","tags":["transitive"]}]},"etymology":{"source":"wiktextract","text":"Form I verb from the root و ج ب (w j b).\n\nCausative Form II verb from the root و ج ب (w j b); compare وَجَبَ (wajaba, “to be necessary”)."},"ipa":["/wa.d͡ʒa.ba/","/wad͡ʒ.d͡ʒa.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41659","headword_ar":"وَجَبَ","root":"wjb","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajibu","text_ar":"يَجِبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":"(Lh, K) and"},{"kind":"arabic","text_bw":"wajobN","text_ar":"وَجْبٌ"},{"kind":"text","text":"(Lh)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wall, or the like, Msb, or a house, or anything, Lh,)"},{"kind":"italic_en","text":"fell down."},{"kind":"text","text":"(Lh, K, Msb.) See"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It fell to the ground."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":"does not signify a single act; but is an inf. n. in an absolute sense, unrestricted to the signification of a single act: ex."},{"kind":"arabic","text_bw":"wajobapu Al$~amosi","text_ar":"وَجْبَةُ الشَّمْسِ"},{"kind":"italic_en","text":"The falling of the sun, in setting."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"faA_i*aA wajabato junuwbuhaA","text_ar":"فَاـِذَا وَجَبَتْ جُنُوبُهَا"},{"kind":"text","text":"[Kur. xxii. 37,] is said to signify"},{"kind":"italic_en","text":"And when their sides fall down upon the ground:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"and when their souls depart, and they fall down."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"wajabati Al$~amosu","text_ar":"وَجَبَتِ الشَّمْسُ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"wajobN","text_ar":"وَجْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wujuwbN","text_ar":"وُجُوبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":"(see above),"},{"kind":"italic_en","text":"The sun set."},{"kind":"text","text":"(S, K.) ―         -b6-"},{"kind":"arabic","text_bw":"wajabati AlEayonu","text_ar":"وَجَبَتِ العَيْنُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The eye was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sunk in the head."},{"kind":"text","text":"(K.) ―         -b7-"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"arabic","text_bw":"yajibu","text_ar":"يَجِبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wujuwbN","text_ar":"وُجُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mawojibN","text_ar":"مَوْجِبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He fell down and died:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"he died."},{"kind":"text","text":"(K.) ―         -b8-  Hudbeh Ibn-Khashram says,"},{"kind":"quote","text":"faqulotu lahu laA taboki Eayonuka A_in~ahu\n                      \n                     \n                        bikaf~aY~a maA laA qayotu A_i*o HaAna mawojibiY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I said to him, Let not thine eye weep; for by my own hands is occasioned what I experience, now that my death has come to pass"},{"kind":"text","text":"]. By"},{"kind":"arabic","text_bw":"mwjb","text_ar":"موجب"},{"kind":"text","text":"he means"},{"kind":"arabic","text_bw":"mawotN","text_ar":"مَوْتٌ"},{"kind":"text","text":". (TA.) ―         -b9-  [See also"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":", which seems to be a third inf. n. of the verb in this sense.] ―         -b10-"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":", (aor."},{"kind":"arabic","text_bw":"yajibu","text_ar":"يَجِبُ"},{"kind":"text","text":", TA,) inf. n."},{"kind":"arabic","text_bw":"wajiybN","text_ar":"وَجِيبٌ"},{"kind":"text","text":"(Th, S,) and"},{"kind":"arabic","text_bw":"wajobN","text_ar":"وَجْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wajabaAnN","text_ar":"وَجَبَانٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"wujuwbN","text_ar":"وُجُوبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the heart)"},{"kind":"italic_en","text":"palpitated, beat, throbbed;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"was agitated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of commotion."},{"kind":"text","text":"(S.) ―         -b11-"},{"kind":"arabic","text_bw":"wajabati AlA_ibilu","text_ar":"وَجَبَتِ الاـِبِلُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"wj~bt","text_ar":"وجّبت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The camels could scarcely arise from the places where they lay down."},{"kind":"text","text":"(TA.) ―         -b12-"},{"kind":"arabic","text_bw":"waHuba","text_ar":"وَحُبَ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yawojubu","text_ar":"يَوْجُبُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"wujuwbapN","text_ar":"وُجُوبَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was cowardly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pusillanimous."},{"kind":"text","text":"(S, K.) ―         -b13-"},{"kind":"arabic","text_bw":"wajabahu Eanohu","text_ar":"وَجَبَهُ عَنْهُ"},{"kind":"italic_en","text":"He drove him back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned him back, from it,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"when he had long kept to it."},{"kind":"text","text":"(Nawádir el-Aaráb.)"},{"kind":"page_break","n":2922},{"kind":"text","text":"-A2-"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Awjb","text_ar":"اوجب","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA,)"},{"kind":"italic_en","text":"ate once a day."},{"kind":"text","text":"(Th, K) See"},{"kind":"arabic","text_bw":"wajobapN","text_ar":"وَجْبَةٌ"},{"kind":"text","text":".       -A3-"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajibu","text_ar":"يَجِبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wujuwbN","text_ar":"وُجُوبٌ"},{"kind":"text","text":"(S, K,) and"},{"kind":"arabic","text_bw":"jibapN","text_ar":"جِبَةٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, necessitated, necessary, requisite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unavoidable: it was binding, obligatory, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"lazima","text_ar":"لَزِمَ"},{"kind":"text","text":"; (S, K, Msb;) [lit. accord. to some,"},{"kind":"italic_en","text":"it fell"},{"kind":"text","text":"on a person: see 4;] and"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":", (Telweeh,) which means nearly the same as"},{"kind":"arabic","text_bw":"lazima","text_ar":"لَزِمَ"},{"kind":"text","text":". (TA.) ―         -b2-  For a fuller explanation, see its syn."},{"kind":"arabic","text_bw":"Haq~a","text_ar":"حَقَّ"},{"kind":"text","text":". [In the science of the fundamentals of religion,"},{"kind":"italic_en","text":"It necessarily was"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existed; was a thing of which the nonexistence could not be mentally conceived:"},{"kind":"text","text":"as is the essence of God. (Ibr. D.)] ―         -b3-  ["},{"kind":"arabic","text_bw":"wajaba Ealayohi ka*aA","text_ar":"وَجَبَ عَلَيْهِ كَذَا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^ano yafaEala ka*aA","text_ar":"اَنْ يَفَعَلَ كَذَا"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the doing of such a thing, was binding, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory upon him; was unavoidable to him; lay on him; was his necessary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indispensable duty:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was binding, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory upon him, by God's express appointment, so that he would be punished for neglecting it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was that which should be preferred and approved."},{"kind":"text","text":"See"},{"kind":"arabic","text_bw":"waAjibN","text_ar":"وَاجِبٌ"},{"kind":"text","text":".] ―         -b4-  See also another explanation, afterwards. ―         -b5-"},{"kind":"arabic","text_bw":"wajaba AlbayoEu","text_ar":"وَجَبَ البَيْعُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yajibu","text_ar":"يَجِبُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jibapN","text_ar":"جِبَةٌ"},{"kind":"text","text":"(Lh, S, Msb) and"},{"kind":"arabic","text_bw":"wujuwbN","text_ar":"وُجُوبٌ"},{"kind":"text","text":"(Lh, Msb)"},{"kind":"italic_en","text":"The sale was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, binding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory;"},{"kind":"text","text":"(Msb, TA;)"},{"kind":"italic_en","text":"ratified, fixed, settled, decided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determined;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"completed, accomplished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concluded; it had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took, effect; it was extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, effectual:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"wajabato yamiynuhu","text_ar":"وَجَبَتْ يَمِينُهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"bat~ato","text_ar":"بَتَّتْ"},{"kind":"text","text":", q. v. (M, in art."},{"kind":"arabic","text_bw":"bt","text_ar":"بت"},{"kind":"text","text":".) ―         -b6-  It is said in a trad.,"},{"kind":"arabic","text_bw":"A_i*aA kaAna AlbayoEu Eano xiyaArK","text_ar":"اـِذَا كَانَ البَيْعُ عَنْ خِيَارٍ"},{"kind":"arabic","text_bw":"faqado wajaba","text_ar":"فَقَدْ وَجَبَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When the sale is optional, it is binding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory"},{"kind":"text","text":"]: i. e., when one says, after the contract, “ Take thy choice to reject the sale, or to make it effectual, ” and the person so addressed chooses to do the latter, the sale is binding, even if the two parties have not yet separated. (TA.) ―         -b7-  In like manner,"},{"kind":"arabic","text_bw":"wajaba AlHaq~u","text_ar":"وَجَبَ الحَقُّ"},{"kind":"text","text":", inf. ns. as above,"},{"kind":"italic_en","text":"The right, due,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claim, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, binding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed, settled, decided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determined."},{"kind":"text","text":"(Msb.) ―         -b8-"},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب"},{"kind":"arabic","text_bw":"Alwjb","text_ar":"الوجب"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب"},{"kind":"text","text":": (TA: [unexplained; but following"},{"kind":"arabic","text_bw":"wajobN","text_ar":"وَجْبٌ"},{"kind":"text","text":"as signifying “ a bet, &c.: ” app. meaning"},{"kind":"italic_en","text":"The bet, wager,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake, became due,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent"},{"kind":"text","text":"]. ―         -b9-  ["},{"kind":"arabic","text_bw":"wajaba Ealayoh","text_ar":"وَجَبَ عَلَيْه"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, necessitated, necessary, requisite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unavoidable, for him to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suffer,"},{"kind":"text","text":"such a thing; and hence, sometimes,"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, binding, obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent, on him."},{"kind":"text","text":"] ―         -b10-"},{"kind":"arabic","text_bw":"wajaba Ealayohi Alqawolu","text_ar":"وَجَبَ عَلَيْهِ القَوْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The saying"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentence became necessitated to take effect upon him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became requisite that the saying"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sentence should take effect upon him."},{"kind":"text","text":"] Jel, in xxxvi. 6, &c. ―         -b11-  ["},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"arabic","text_bw":"lahu ka*aA","text_ar":"لَهُ كَذَا"},{"kind":"italic_en","text":"Such a thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, due to him;"},{"kind":"text","text":"as, for instance, a reward, or a punishment.] ―         -b12-"},{"kind":"arabic","text_bw":"wajaba Ealayohi Alqatolu","text_ar":"وَجَبَ عَلَيْهِ القَتْلُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Slaughter was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, his due."},{"kind":"text","text":"] (TA, in art."},{"kind":"arabic","text_bw":"bqY","text_ar":"بقى"},{"kind":"text","text":", &c.)"}],"source_refs":["Lh","K","S","TA","Th","Msb"]}]}}