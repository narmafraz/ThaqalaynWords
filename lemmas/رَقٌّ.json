{"lemma":"رَقٌّ","slug":"رَقٌّ","root":"ر.ق.ق","root_slug":"ر-ق-ق","root_link":"/words/roots/ر-ق-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رَقّ","root":"رقق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":12},"lanes":{"found":true,"entry_ids":["n16272"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%82%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be thin, fine"},{"pos":"verb","gloss":"to be soft, tender"},{"pos":"verb","gloss":"to pity, to sympathize, to have compassion (for)"},{"pos":"verb","gloss":"to rap (on a door)"},{"pos":"verb","gloss":"to crush, to grind, to pulverize, to beat into a powder"},{"pos":"verb","gloss":"to batter, to ram"},{"pos":"verb","gloss":"to soften, to weaken, to relent"},{"pos":"verb","gloss":"to be or become a slave"},{"pos":"noun","gloss":"turtle"},{"pos":"noun","gloss":"parchment"},{"pos":"noun","gloss":"riq, an Arabian tambourine"},{"pos":"noun","gloss":"bondage, slavery, servitude"}]},"etymology":{"source":"wiktextract","text":"Compare Classical Syriac ܪܩܐ (raqqā, “tortoise”) and Akkadian raqqum (“turtle, tortoise”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16272","headword_ar":"رَقٌّ","root":"rq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raqiyqN","text_ar":"رَقِيقٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"ruq~N","text_ar":"رُقٌّ"},{"kind":"text","text":".       -A2-  Also, (JK, S, Mgh, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"riq~N","text_ar":"رِقٌّ","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) but the latter is a rare dial. var. though some read thus in the Kur lii. 3, (Msb,) ["},{"kind":"italic_en","text":"Parchment;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"vellum;"},{"kind":"text","text":"so in the present day; or]"},{"kind":"italic_en","text":"skin,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"thin skin,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"upon which one writes:"},{"kind":"text","text":"(S, Mgh, Msb, K:) or (so accord. to the Mgh, but in the K “ and ”)"},{"kind":"italic_en","text":"a white"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"blank"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"SaHiyfap","text_ar":"صَحِيفَة"},{"kind":"text","text":"[which means a"},{"kind":"italic_en","text":"paper"},{"kind":"text","text":"and a"},{"kind":"italic_en","text":"piece of skin,"},{"kind":"text","text":"but generally such as is written upon]: (JK, Mgh, K:) or metaphorically applied to (tropical:)"},{"kind":"italic_en","text":"a skin written upon:"},{"kind":"text","text":"properly one upon which one writes: (Bd in lii. 3:) accord. to Fr, (assumed tropical:)  the"},{"kind":"arabic","text_bw":"SaHaAy^if","text_ar":"صَحَايِف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"papers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pieces of skin,"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"records,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that will be produced to the sons of Adam on the day of resurrection;"},{"kind":"text","text":"which indicates that such as is written is also thus termed: (Az, TA:) in the Kur lii. 3, [accord. to some,] applied to (assumed tropical:)"},{"kind":"italic_en","text":"the Book of the Law revealed to Moses:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the Kur-án."},{"kind":"text","text":"(Jel.)       -A3-  Also, (K,) or the former word [only], (JK, S, Msb,) The"},{"kind":"italic_en","text":"tortoise:"},{"kind":"text","text":"(JK:) or"},{"kind":"italic_en","text":"a great tortoise:"},{"kind":"text","text":"(S, K:) or the"},{"kind":"italic_en","text":"male tortoise:"},{"kind":"text","text":"(Msb:) and the"},{"kind":"italic_en","text":"crocodile:"},{"kind":"text","text":"(JK:) or, (K,) accord. to Ibráheem El-Harbee, (TA,)"},{"kind":"italic_en","text":"a certain aquatic reptile,"},{"kind":"text","text":"(K, TA,) [app. the"},{"kind":"italic_en","text":"turtle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sea-tortoise,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having four legs, and claws,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nails, and teeth in a head which it exposes and conceals, and which is killed for food:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"ruquwqN","text_ar":"رُقُوقٌ"},{"kind":"text","text":". (A'Obeyd, JK, S, Msb, K.)"}],"source_refs":["JK","S","Mgh","Msb","K","Az","TA"]}]},"classical_definitions":null}