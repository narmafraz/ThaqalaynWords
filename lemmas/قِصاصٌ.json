":"قَصَاصَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (so in a copy of the M, and in the CK, and in a MS copy of the K [in the TA ↓"},{"kind":"arabic","text_bw":"quSaASaA='u","text_ar":"قُصَاصَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", which I think a mistake,]) and ↓"},{"kind":"arabic","text_bw":"qiSaASaA='u","text_ar":"قِصَاصَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) [the first an inf. n. of 3, q. v.,]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qawadN","text_ar":"قَوَدٌ"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"Retaliation, by slaying for slaying,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wounding for wounding,"},{"kind":"text","text":"(M, Msb, TA,) and"},{"kind":"italic_en","text":"mutilating for mutilating."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","M","Msb","K","TA"]},{"entry_id":"n35710","headword_ar":"قَصَّاصٌ","root":"qS","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaS~N","text_ar":"قَصٌّ"},{"kind":"text","text":", last signification."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%82%D8%B5%D8%A7%D8%B5/","headword_ar":"قصاص","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23500#3e55f5","body_html":"<span>القصاص: هو أن يفعل بالفاعل مثل ما فعل.</span>"}]}}