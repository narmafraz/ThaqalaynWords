{"lemma":"عَجِيباتٌ","slug":"عَجِيباتٌ","root":"ع.ج.ب","root_slug":"ع-ج-ب","root_link":"/words/roots/ع-ج-ب","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"عَجِيب","root":"عجب","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n28103"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%90%D9%8A%D8%A8%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"wonderful, marvelous"},{"pos":"adj","gloss":"foreign"},{"pos":"adj","gloss":"exotic"},{"pos":"adj","gloss":"amazing"},{"pos":"adj","gloss":"weird, strange"}]},"etymology":null,"ipa":["/ʕa.d͡ʒiːb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28103","headword_ar":"عَجِيبٌ","root":"Ejb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajabN","text_ar":"عَجَبٌ"},{"kind":"text","text":", in four places, near the middle of the paragraph. ―         -b2-  Also"},{"kind":"italic_en","text":"Loved, beloved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an object of love:"},{"kind":"text","text":"so in the following verse, cited by Th:"},{"kind":"quote","text":"wamaA Albuxolu yanohaAniY walaA Aljuwdu qaAdaniY\n                      \n                     \n                        wal`kin~ahaA DarobN A_ilaY~a EajiybN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And neither does niggardliness forbid me nor liberality lead me; but she is a sort"},{"kind":"text","text":"of person,"},{"kind":"italic_en","text":"to me, an object of love"},{"kind":"text","text":"]: by"},{"kind":"arabic","text_bw":"qaAdaniY","text_ar":"قَادَنِى"},{"kind":"text","text":", the poet means"},{"kind":"arabic","text_bw":"yaquwduniY","text_ar":"يَقُودُنِى"},{"kind":"text","text":". (L, TA.)"}],"source_refs":[]}]},"classical_definitions":null}