:"m","num":"s"},{"role":"present_1ms","form":"أَرَ","in_corpus":true,"count":18,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرَ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2104,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n32908"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AA%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"rhubarb"}]},"etymology":{"source":"wiktextract","text":"From Persian ریوند (rivand)."},"ipa":["/raː.wand/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32908","headword_ar":"فَتَرَ","root":"ftr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"futuwrN","text_ar":"فُتُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"futaArN","text_ar":"فُتَارٌ"},{"kind":"text","text":", [the latter is thus accord. to the M, and some copies of the K, and in the TA is said to be like"},{"kind":"arabic","text_bw":"guraAbN","text_ar":"غُرَابٌ"},{"kind":"text","text":", but in the CK and one MS. copy of the K I find it written"},{"kind":"arabic","text_bw":"fitaAr","text_ar":"فِتَار"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, M, TA)"},{"kind":"italic_en","text":"remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became allayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"still, after vehemence;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"became gentle after violence."},{"kind":"text","text":"(M, K, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"fatara","text_ar":"فَتَرَ"},{"kind":"arabic","text_bw":"Eano Eamalihi","text_ar":"عَنْ عَمَلِهِ"},{"kind":"text","text":", (Msb, TA,) aro."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"futuwrN","text_ar":"فُتُورٌ"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"He remitted, flagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became remiss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languid, in his work,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"labour:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he remitted therein after vigour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemence; became gentle therein after violence."},{"kind":"text","text":"(Msb.) ―         -b3-  Hence, (Msb,)"},{"kind":"arabic","text_bw":"fatara AlHar~u","text_ar":"فَتَرَ الحَرُّ"},{"kind":"text","text":", (S, O, Msb, TA,) aor."},{"kind":"text","text":", (S, O,) inf. n."},{"kind":"arabic","text_bw":"fatorapN","text_ar":"فَتْرَةٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"futuwrN","text_ar":"فُتُورٌ"},{"kind":"text","text":", (S, O, Msb,) (tropical:)"},{"kind":"italic_en","text":"The heat remitted after vehemence; became gentle after violence:"},{"kind":"text","text":"(Msb, TA:)"},{"kind":"italic_en","text":"the heat remitted, abated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flagged; became languid and faint:"},{"kind":"text","text":"and the verb is used in like manner of other things; (S;) for instance, of a price: (Fr, in TA, art."},{"kind":"arabic","text_bw":"qT","text_ar":"قط"},{"kind":"text","text":":) and of a man, signifying"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"languid, languid and faint,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"lax in the joints;"},{"kind":"text","text":"(Ham p. 799;) [as also ↓"},{"kind":"arabic","text_bw":"tft~r","text_ar":"تفتّر","orth_type":"arrow"},{"kind":"text","text":", occurring in the K in art."},{"kind":"arabic","text_bw":"xtr","text_ar":"ختر"},{"kind":"text","text":", &c.]. And"},{"kind":"arabic","text_bw":"fatara Albarodu","text_ar":"فَتَرَ البَرْدُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The cold abated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remitted;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became allayed."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"fatara AlmaA='u","text_ar":"فَتَرَ المَا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The water abated in heat so as to become tepid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lukewarm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"between hot and cold;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"faAtirN","text_ar":"فَاتِرٌ"},{"kind":"text","text":";)]"},{"kind":"italic_en","text":"the water ceased to be hot."},{"kind":"text","text":"(M, K.) ―         -b5-"},{"kind":"arabic","text_bw":"fatara jisomuhu","text_ar":"فَتَرَ جِسْمُهُ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"futuwrN","text_ar":"فُتُورٌ"},{"kind":"text","text":", (M, K,) (assumed tropical:)"},{"kind":"italic_en","text":"His body became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"languid;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"lax in the joints, and weak."},{"kind":"text","text":"(M, K.) ―         -b6-  And"},{"kind":"arabic","text_bw":"fatara AlT~arofu","text_ar":"فَتَرَ الطَّرْفُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The look of the eye,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eyes, became languishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languid;"},{"kind":"text","text":"expl. by"},{"kind":"arabic","text_bw":"Ainokasara naZaruhu","text_ar":"اِنْكَسَرَ نَظَرُهُ"},{"kind":"text","text":". (IKtt, TA.) [See"},{"kind":"arabic","text_bw":"TarofN faAtirN","text_ar":"طَرْفٌ فَاتِرٌ"},{"kind":"text","text":", below; and see also 4.]       -A2-"},{"kind":"arabic","text_bw":"fatarahu","text_ar":"فَتَرَهُ"},{"kind":"italic_en","text":"He measured it by the"},{"kind":"arabic","text_bw":"fitor","text_ar":"فِتْر"},{"kind":"text","text":": (M, O, K:) like"},{"kind":"arabic","text_bw":"$abarahu","text_ar":"شَبَرَهُ"},{"kind":"text","text":"“ he measured it by the"},{"kind":"arabic","text_bw":"$ibor","text_ar":"شِبْر"},{"kind":"text","text":". ” (M, O.)"}],"source_refs":["Msb","TA","S","O","M","K"]}]}}