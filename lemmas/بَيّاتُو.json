^amoru bayaAtFA","text_ar":"اَتَاهُمُ الاَمْرُ بَيَاتًا"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, happened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came, to them in the latter part of the night."},{"kind":"text","text":"(T.)"}],"source_refs":["S","M","TA"]}]},"classical_definitions":null}