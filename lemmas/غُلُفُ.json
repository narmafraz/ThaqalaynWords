{"lemma":"غُلُفُ","slug":"غُلُفُ","root":"غ.ل.ف","root_slug":"غ-ل-ف","root_link":"/words/roots/غ-ل-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"غُلُفُ","root":"غلف","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n32271","","n32273","n32274","n32275"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8F%D9%84%D9%8F%D9%81%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"cover"},{"pos":"noun","gloss":"wrapper"},{"pos":"noun","gloss":"envelope (for letters)"},{"pos":"noun","gloss":"case"},{"pos":"noun","gloss":"sheath, scabbard"},{"pos":"noun","gloss":"box, capsule"},{"pos":"noun","gloss":"fruit shell"},{"pos":"noun","gloss":"prepuce"},{"pos":"noun","gloss":"pericardium"}]},"etymology":{"source":"wiktextract","text":"Compare غَلَفَ (ḡalafa, “to sheathe, cover, wrap”)."},"ipa":["/ɣi.laːf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32271","headword_ar":"غَلَفَ","root":"glf","body":[{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"galofN","text_ar":"غَلْفٌ"},{"kind":"text","text":", (O, Msb, TA,)"},{"kind":"italic_en","text":"He put"},{"kind":"text","text":"a bottle, or flask, (S, O, K, TA,) or a knife, (Msb,) &c., (TA,)"},{"kind":"italic_en","text":"into a"},{"kind":"arabic","text_bw":"gilaAf","text_ar":"غِلَاف"},{"kind":"text","text":"[q. v.]; (S, O, Msb, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Aglf","text_ar":"اغلف","orth_type":"arrow"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"A_igolaAfN","text_ar":"اـِغْلَافٌ"},{"kind":"text","text":"; (Msb;) or ↓"},{"kind":"arabic","text_bw":"gl~f","text_ar":"غلّف","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tagoliyfN","text_ar":"تَغْلِيفٌ"},{"kind":"text","text":": (K, TA:) or ↓ the second signifies, (Msb,) or signifies also, (S,)"},{"kind":"italic_en","text":"he furnished"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with a"},{"kind":"arabic","text_bw":"gilaAf","text_ar":"غِلَاف"},{"kind":"text","text":"; (S, Msb;) or ↓"},{"kind":"arabic","text_bw":"gl~f","text_ar":"غلّف","orth_type":"arrow"},{"kind":"text","text":"signifies thus: (TA:)"},{"kind":"arabic","text_bw":"AlqaAruwrapa","text_ar":"القَارُورَةَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^agolafotu","text_ar":"اَغْلَفْتُ","orth_type":"arrow"},{"kind":"text","text":"is said by Lth to be from"},{"kind":"arabic","text_bw":"AlgilaAfu","text_ar":"الغِلَافُ"},{"kind":"text","text":"; and so ↓"},{"kind":"arabic","text_bw":"gal~afotuhaA","text_ar":"غَلَّفْتُهَا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tagoliyfN","text_ar":"تَغْلِيفٌ"},{"kind":"text","text":". (O.) ―         -b2-  And accord. to Lth, (O,) one says,"},{"kind":"arabic","text_bw":"galafa","text_ar":"غَلَفَ"},{"kind":"arabic","text_bw":"liHoyatahu biAlgaAliyapi","text_ar":"لِحْيَتَهُ بِالغَالِيَةِ"},{"kind":"text","text":", (S, Mgh, O, Msb,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"galofN","text_ar":"غَلْفٌ"},{"kind":"text","text":", (S,) meaning"},{"kind":"italic_en","text":"He daubed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smeared, his beard with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the perfume called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"gaAliyap","text_ar":"غَالِيَة"},{"kind":"text","text":"[q. v.], (Mgh, TA,) and likewise with other perfume, and with"},{"kind":"arabic","text_bw":"Hin~aA='","text_ar":"حِنَّا=ء"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"gal~afahaA","text_ar":"غَلَّفَهَا","orth_type":"arrow"},{"kind":"text","text":": (Mgh, TA:) but accord. to IDrd, the vulgar say so: (O, Msb, TA:) he says that the correct phrase is"},{"kind":"arabic","text_bw":"gal~aAhaA","text_ar":"غَلَّاهَا"},{"kind":"text","text":"(Mgh, O, Msb, TA)"},{"kind":"arabic","text_bw":"bAlgAlyp","text_ar":"بالغالية"},{"kind":"text","text":", (O,) and"},{"kind":"arabic","text_bw":"gal~alahaA","text_ar":"غَلَّلَهَا"},{"kind":"text","text":": (Mgh, O, Msb:) in a trad. of 'Aacute;ïsheh, however,"},{"kind":"arabic","text_bw":"liHoyapa rasuwli A@ll~`hi","text_ar":"لِحْيَةَ رَسُولِ ا@للّٰهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"kunotu A^ugal~ifu","text_ar":"كُنْتُ اُغَلِّفُ","orth_type":"arrow"},{"kind":"text","text":"occurs as meaning"},{"kind":"italic_en","text":"I used to daub,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smear, the beard of the Apostle of God"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"gAlyp","text_ar":"غالية"},{"kind":"text","text":","},{"kind":"italic_en","text":"doing so abundantly:"},{"kind":"text","text":"(TA:) and one says, of a man, ↓"},{"kind":"arabic","text_bw":"tgl~f","text_ar":"تغلّف","orth_type":"arrow"},{"kind":"text","text":"(Lth, Th, S, O, TA)"},{"kind":"arabic","text_bw":"biAlgaAliyapi","text_ar":"بِالغَالِيَةِ"},{"kind":"text","text":"(Th, S, TA)"},{"kind":"arabic","text_bw":"wasaAy^iri AlT~iybi","text_ar":"وَسَايِرِ الطِّيبِ"},{"kind":"text","text":"(Th, TA) [i. e."},{"kind":"italic_en","text":"He daubed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smeared, himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his beard, with"},{"kind":"arabic","text_bw":"gAlyp","text_ar":"غالية"},{"kind":"italic_en","text":"and the other sorts of perfume"},{"kind":"text","text":"]; and [in like manner,] ↓"},{"kind":"arabic","text_bw":"Agtlf","text_ar":"اغتلف","orth_type":"arrow"},{"kind":"text","text":"(Lth, O, TA)"},{"kind":"arabic","text_bw":"mina","text_ar":"مِنَ"},{"kind":"arabic","text_bw":"AlgaAliyapi","text_ar":"الغَالِيَةِ"},{"kind":"text","text":"(Lth, O) or"},{"kind":"arabic","text_bw":"mina AlT~iybi","text_ar":"مِنَ الطِّيبِ"},{"kind":"text","text":": (TA:) but accord. to the saying of IDrd [mentioned above], these are wrong, and should be only"},{"kind":"arabic","text_bw":"tagal~aY","text_ar":"تَغَلَّى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tagal~ala","text_ar":"تَغَلَّلَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"AigotalaY","text_ar":"اِغْتَلَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Aigotal~a","text_ar":"اِغْتَلَّ"},{"kind":"text","text":": (O:) or, accord. to Ibn-El-Faraj, one says"},{"kind":"arabic","text_bw":"bAlgAlyp","text_ar":"بالغالية"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tgl~f","text_ar":"تغلّف","orth_type":"arrow"},{"kind":"text","text":"when it is external; and"},{"kind":"arabic","text_bw":"tgl~l bihaA","text_ar":"تغلّل بِهَا"},{"kind":"text","text":"when it is internal, at the roots of the hair. (O, TA. [See also 2 in art."},{"kind":"arabic","text_bw":"gl","text_ar":"غل"},{"kind":"text","text":".])       -A2-"},{"kind":"arabic","text_bw":"galifa","text_ar":"غَلِفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"galafN","text_ar":"غَلَفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was uncircumcised."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","O","Msb","K","TA","Mgh","Lth","Th"]},{"entry_id":"n32273","headword_ar":"غَلْفٌ","root":"glf","body":[{"kind":"italic_en","text":"A species of trees,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"with which one tans,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"like"},{"kind":"text","text":"[accord. to some meaning"},{"kind":"italic_en","text":"the same as"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"garof","text_ar":"غَرْف"},{"kind":"text","text":"[q. v.]: (S, O, K, TA:)"},{"kind":"italic_en","text":"some say that one does not tan therewith unless together with the"},{"kind":"arabic","text_bw":"garof","text_ar":"غَرْف"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","O","K","TA"]},{"entry_id":"n32274","headword_ar":"غَلَفٌ","root":"glf","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"galifa","text_ar":"غَلِفَ"},{"kind":"text","text":"[q. v.]: (Msb:) [as a simple subst.,] The"},{"kind":"italic_en","text":"state of being uncircumcised."},{"kind":"text","text":"(S, O, K.) ―         -b2-  [Also, of the heart, (assumed tropical:)  The"},{"kind":"italic_en","text":"state of being"},{"kind":"arabic","text_bw":"A^agolaf","text_ar":"اَغْلَف"},{"kind":"text","text":": so, app., accord. to the TA: in the L written"},{"kind":"arabic","text_bw":"galafap","text_ar":"غَلَفَة"},{"kind":"text","text":".] ―         -b3-  And (assumed tropical:)"},{"kind":"italic_en","text":"Ample abundance of herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the goods, conveniences,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"comforts, of life."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb"]},{"entry_id":"n32275","headword_ar":"غَلِفٌ","root":"glf","body":[{"kind":"italic_en","text":"A certain plant, which is eaten, peculiarly, by the apes,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"monkeys:"},{"kind":"text","text":"mentioned by AHn. (TA.)"},{"kind":"page_break","n":2284}],"source_refs":[]}]}}