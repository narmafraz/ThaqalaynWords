p":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحَرِّضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَرِّضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَرِّض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَرِّض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَرِّضانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَرِّضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَرِّضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَرِّضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَرِّضُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَرِّضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَرِّضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَرَّضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَرَّضْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَرِّض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَرِّض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":true,"lemma_key":"حَرَّضَ","root":"حرض","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n7658","n7662","n7663","n7664","n7665","n7666"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D9%8E%D9%91%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to provoke"},{"pos":"verb","gloss":"to instigate, to whip up, to stir up"}]},"etymology":null,"ipa":["/ħar.ra.dˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7658","headword_ar":"حَرِضَ","root":"HrD","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"His stomach became in a corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, state:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"became in a corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, state, and sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diseased, so as to defile himself in his clothes:"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":", below:] or"},{"kind":"italic_en","text":"he became emaciated"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"dissolved"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by excessive love:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he became at the point of death:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"he suffered protracted disquietude of mind,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"disease;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"HaruDa","text_ar":"حَرُضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":": (K:) and"},{"kind":"arabic","text_bw":"HaraDa","text_ar":"حَرَضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HuruwDN","text_ar":"حُرُوضٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"HaroDN","text_ar":"حَرْضٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"he became heavily oppressed by disease;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly affected thereby so as to be at the point of death:"},{"kind":"text","text":"(K:) or this last form of the verb signifies"},{"kind":"italic_en","text":"he died,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"HaruDa","text_ar":"حَرُضَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaraDa","text_ar":"حَرَضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HuruwDN","text_ar":"حُرُوضٌ"},{"kind":"text","text":", as in the L; not"},{"kind":"arabic","text_bw":"HariDa","text_ar":"حَرِضَ"},{"kind":"text","text":", as in the K (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid; unable to rise from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quit, his place;"},{"kind":"text","text":"a signification given in the K to"},{"kind":"arabic","text_bw":"HariDa","text_ar":"حَرِضَ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid; possessing no good:"},{"kind":"text","text":"(TA:) [but of the correctness of one of the two forms here mentioned on the authority of the L, the author of the TA expresses a bout: app. with respect to the latter of them; for it is said,]"},{"kind":"arabic","text_bw":"HaruDa","text_ar":"حَرُضَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HaraADapN","text_ar":"حَرَاضَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuruwDapN","text_ar":"حُرُوضَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuruwDN","text_ar":"حُرُوضٌ"},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid, and bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vicious, and neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsaken;"},{"kind":"text","text":"(K, TA;) as also"},{"kind":"arabic","text_bw":"HariDa","text_ar":"حَرِضَ"},{"kind":"text","text":". (K: but only the former,"},{"kind":"arabic","text_bw":"HaruDa","text_ar":"حَرُضَ"},{"kind":"text","text":", is given in this sense in the TA.)       -A2-"},{"kind":"arabic","text_bw":"HaraDa","text_ar":"حَرَضَ"},{"kind":"text","text":"as a trans. v.: see 4, in two places.       -A3-"},{"kind":"arabic","text_bw":"HariDa","text_ar":"حَرِضَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", also signifies"},{"kind":"italic_en","text":"He picked up from the ground"},{"kind":"arabic","text_bw":"A_iHoriyD","text_ar":"اـِحْرِيض"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"safflower"},{"kind":"text","text":"]. (O, K.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n7662","headword_ar":"حَرْضٌ","root":"HrD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":", last sentence:       -A2-  and see also what here follows."}],"source_refs":[]},{"entry_id":"n7663","headword_ar":"حُرْضٌ","root":"HrD","body":[{"kind":"text","text":", (Mgh,) or ↓"},{"kind":"arabic","text_bw":"HuruDN","text_ar":"حُرُضٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) or both, (S, K,) the former mentioned by Sb, but in some of the copies of his book written with fet-h (↓"},{"kind":"arabic","text_bw":"HaroDN","text_ar":"حَرْضٌ","orth_type":"arrow"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"$ajaru AlA^u$onaAni","text_ar":"شَجَرُ الاُشْنَانِ"},{"kind":"text","text":"[The"},{"kind":"italic_en","text":"trees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plants, from which potash is obtained;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"kind of plants called kali,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glasswort,"},{"kind":"text","text":"&c.];"},{"kind":"italic_en","text":"which are of the kind called"},{"kind":"arabic","text_bw":"najiyl","text_ar":"نَجِيل"},{"kind":"text","text":": (Az, TA:) Aboo-Ziyád says that"},{"kind":"italic_en","text":"what is termed"},{"kind":"arabic","text_bw":"HuroD","text_ar":"حُرْض"},{"kind":"italic_en","text":"is slender in the extremities"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"duqaAqu AlA^aToraAfi","text_ar":"دُقَاقُ الاَطْرَافِ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"but its tree is large, being sometimes used for shade, and affords firewood, and it is that with which people wash clothes;"},{"kind":"text","text":"and he adds, we have not seen any"},{"kind":"arabic","text_bw":"HuroD","text_ar":"حُرْض"},{"kind":"text","text":"purer or whiter than some which grows in ElYemámeh, in a valley thereof called"},{"kind":"arabic","text_bw":"jaw~u AlxaDaArimi","text_ar":"جَوُّ الخَضَارِمِ"},{"kind":"text","text":": (TA:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^u$onaAnN","text_ar":"اُشْنَانٌ"},{"kind":"text","text":"[q. v.]; (S, A, Mgh, Msb, K;)"},{"kind":"italic_en","text":"with which the hands are washed after food."},{"kind":"text","text":"(TA. [But see"},{"kind":"arabic","text_bw":"Har~aADN","text_ar":"حَرَّاضٌ"},{"kind":"text","text":".]) So in the Kur [xii. 85], accord. to one reading, (K,) the reading of El- Hasan El-Basree, (Sgh,) ↓"},{"kind":"arabic","text_bw":"Hat~aY takuwna HuruDFA","text_ar":"حَتَّى تَكُونَ حُرُضًا","orth_type":"arrow"},{"kind":"text","text":", (Bd,) meaning"},{"kind":"italic_en","text":"Until thou be like"},{"kind":"arabic","text_bw":"A$nAn","text_ar":"اشنان"},{"kind":"italic_en","text":"in dryness;"},{"kind":"text","text":"as explained in the K, except that"},{"kind":"arabic","text_bw":"nuHuwlFA","text_ar":"نُحُولًا"},{"kind":"text","text":"is there erroneously put for"},{"kind":"arabic","text_bw":"quHuwlFA","text_ar":"قُحُولًا"},{"kind":"text","text":": (TA:) but EsSuddee disapproved of this reading. (Sgh.)       -A2-  Also"},{"kind":"arabic","text_bw":"HuroDN","text_ar":"حُرْضٌ"},{"kind":"text","text":", [and app."},{"kind":"arabic","text_bw":"HuruDN","text_ar":"حُرُضٌ"},{"kind":"text","text":"also,]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jiS~N","text_ar":"جِصٌّ"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"Gypsum"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Mgh","Msb","S","K","Az","TA","Sgh","Bd"]},{"entry_id":"n7664","headword_ar":"حَرَضٌ","root":"HrD","body":[{"kind":"italic_en","text":"Corruptness in the body,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the intellect,"},{"kind":"text","text":"(Ibn-'Arafeh, A, K,) and (assumed tropical:)"},{"kind":"italic_en","text":"in one's course of conduct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tenets."},{"kind":"text","text":"(Ibn-'Arafeh, K.) [See 1.]       -A2-  A man"},{"kind":"italic_en","text":"in a corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, state, and sick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diseased,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"so that he defiles himself"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yuHodivu","text_ar":"يُحْدِثُ"},{"kind":"text","text":"[but in some copies of the S this word is omitted])"},{"kind":"italic_en","text":"in his clothes;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"HaAriDapN","text_ar":"حَارِضَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HariDN","text_ar":"حَرِضٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) ↓ which last also signifies a man"},{"kind":"italic_en","text":"having his stomach in a corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, state;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"suffering protracted disquietude of mind, and disease:"},{"kind":"text","text":"(TA:) also the first, ("},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"weary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigued:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"at the point of death;"},{"kind":"text","text":"(Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"HaAirDN","text_ar":"حَاِرضٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) which last also signifies one"},{"kind":"italic_en","text":"near to dying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to perishing;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"having his body corrupted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, by disease, so as to be at the point of death,"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"HariDN","text_ar":"حَرِضٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and [in like manner] ↓"},{"kind":"arabic","text_bw":"muHoraDN","text_ar":"مُحْرَضٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"dying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perishing, from disease, being neither living so as to be an object of hope, nor dead so as to be an object of despair:"},{"kind":"text","text":"(T, TA:)"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"emaciated"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"dissolved"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by excessive love;"},{"kind":"text","text":"(AA accord. to the S, or AO accord. to the TA, and K;) as also ↓"},{"kind":"arabic","text_bw":"muHoraDN","text_ar":"مُحْرَضٌ","orth_type":"arrow"},{"kind":"text","text":", (S,) or ↓"},{"kind":"arabic","text_bw":"muHar~aDN","text_ar":"مُحَرَّضٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) and"},{"kind":"italic_en","text":"heavily oppressed by disease;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly affected thereby so as to be at the point of death:"},{"kind":"text","text":"so in the Kur xii. 85: (K:) [in the CK,"},{"kind":"arabic","text_bw":"HaraDFA","text_ar":"حَرَضًا"},{"kind":"text","text":"is her erroneously put for"},{"kind":"arabic","text_bw":"maraDFA","text_ar":"مَرَضًا"},{"kind":"text","text":":] or it there signifies"},{"kind":"italic_en","text":"heavily pressed upon by disease;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected by constant disease:"},{"kind":"text","text":"(AZ:) or"},{"kind":"italic_en","text":"extremely aged;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"old and weak:"},{"kind":"text","text":"(Katádeh:) and anything"},{"kind":"italic_en","text":"withering:"},{"kind":"text","text":"(TA:) [the following observation, which is inserted in the S after the first of the significations here given of"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":"used as an epithet, and in the K after a later signification which is said to be tropical, applies to it, when so used, in all its senses:] it is employed alike as sing. as pl. (Fr, S, K) and masc. (Fr) and fem.; (Fr, K;) being originally an inf. n.: (Fr, Msb:) or, like every inf. n. used as an epithet, it is for"},{"kind":"arabic","text_bw":"*uw","text_ar":"ذُو"},{"kind":"text","text":"followed by the inf. n., and therefore has no dual nor pl."},{"kind":"page_break","n":549},{"kind":"text","text":"form: (Zj:) but some of the Arabs use ↓"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ","orth_type":"arrow"},{"kind":"text","text":"as an epithet applied to a male, and ↓"},{"kind":"arabic","text_bw":"HaAriDapN","text_ar":"حَارِضَةٌ","orth_type":"arrow"},{"kind":"text","text":"as applied to a female; and these have duals and pls.: (Fr:) and sometimes"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":"has pls.; namely"},{"kind":"arabic","text_bw":"A^aHoraADN","text_ar":"اَحْرَاضٌ"},{"kind":"text","text":"; (K;) which is also pl. of"},{"kind":"arabic","text_bw":"HariDN","text_ar":"حَرِضٌ"},{"kind":"text","text":"and of"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ"},{"kind":"text","text":"; or, accord. to the L, it is allowable as a pl. of"},{"kind":"arabic","text_bw":"HariDN","text_ar":"حَرِضٌ"},{"kind":"text","text":", in the place of the more common pl."},{"kind":"arabic","text_bw":"HariDuwna","text_ar":"حَرِضُونَ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"HuroDaAni","text_ar":"حُرْضَانِ","orth_type":"arrow"},{"kind":"text","text":"; (K;) which is more approved; (TA;) and"},{"kind":"arabic","text_bw":"HariDapN","text_ar":"حَرِضَةٌ"},{"kind":"text","text":". (K: [this last being expressly said in the TA to be thus written, but in the CK it is written"},{"kind":"arabic","text_bw":"HaraDap","text_ar":"حَرَضَة"},{"kind":"text","text":".]) ―         -b2-  Also, applied to a man, (A,) (tropical:)"},{"kind":"italic_en","text":"Possessing no good;"},{"kind":"text","text":"(A, K;) like ↓"},{"kind":"arabic","text_bw":"HaAriDapN","text_ar":"حَارِضَةٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) which latter is explained by As as signifying a man"},{"kind":"italic_en","text":"in whom is no good:"},{"kind":"text","text":"(T, TA:) or the former, one"},{"kind":"italic_en","text":"whose good is not hoped for, nor his evil feared:"},{"kind":"text","text":"(K:) and a"},{"kind":"italic_en","text":"bad"},{"kind":"text","text":"man: (K:) and"},{"kind":"italic_en","text":"low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid; unable to rise from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quit, his place;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HariyDN","text_ar":"حَرِيضٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HariDN","text_ar":"حَرِضٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muHar~aDN","text_ar":"مُحَرَّضٌ","orth_type":"arrow"},{"kind":"text","text":", (K, [this last, in the CK, written"},{"kind":"arabic","text_bw":"muHar~iD","text_ar":"مُحَرِّض"},{"kind":"text","text":",]) or ↓"},{"kind":"arabic","text_bw":"muHoraDN","text_ar":"مُحْرَضٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"A_iHoriyDN","text_ar":"اـِحْرِيضٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid; in whom is no good:"},{"kind":"text","text":"(TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"bad, corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vitious, and neglected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsaken;"},{"kind":"text","text":"(K;) and so ↓"},{"kind":"arabic","text_bw":"maHoruwDN","text_ar":"مَحْرُوضٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"HiroDapN","text_ar":"حِرْضَةٌ","orth_type":"arrow"},{"kind":"text","text":", of which the pl. is"},{"kind":"arabic","text_bw":"HiraDN","text_ar":"حِرَضٌ"},{"kind":"text","text":"; (TA;) ↓"},{"kind":"arabic","text_bw":"maHoruwDN","text_ar":"مَحْرُوضٌ","orth_type":"arrow"},{"kind":"text","text":"also signifying"},{"kind":"italic_en","text":"made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asserted, to be low, base, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid;"},{"kind":"text","text":"(K, TA;) and so ↓"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"HiroDapN","text_ar":"حِرْضَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and this last signifying also"},{"kind":"italic_en","text":"having in him no good:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":"likewise signifies one"},{"kind":"italic_en","text":"who does not take to himself arms, nor fight:"},{"kind":"text","text":"(Lth, K:) its pl. is"},{"kind":"arabic","text_bw":"A^aHoraADN","text_ar":"اَحْرَاضٌ"},{"kind":"text","text":"(A, TA) and ↓"},{"kind":"arabic","text_bw":"HuroDaAnN","text_ar":"حُرْضَانٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) both these pls. signify"},{"kind":"italic_en","text":"weak"},{"kind":"text","text":"men,"},{"kind":"italic_en","text":"who will not fight:"},{"kind":"text","text":"(S:) and the former of them is explained as signifying the"},{"kind":"italic_en","text":"lowest, basest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"meanest, sort"},{"kind":"text","text":"of mankind: and men"},{"kind":"italic_en","text":"corrupt in their course of conduct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tenets:"},{"kind":"text","text":"also the latter of them as signifying men"},{"kind":"italic_en","text":"who know not the place of their chief:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HaAriDN","text_ar":"حَارِضٌ","orth_type":"arrow"},{"kind":"text","text":", of which the fem. is with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", signifies a"},{"kind":"italic_en","text":"stupid"},{"kind":"text","text":"man. (TA.) ―         -b3-  Also, applied to a she-camel,"},{"kind":"italic_en","text":"Lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated:"},{"kind":"text","text":"(K, TA:) and ↓"},{"kind":"arabic","text_bw":"HuroDaAnN","text_ar":"حُرْضَانٌ","orth_type":"arrow"},{"kind":"text","text":", so applied,"},{"kind":"italic_en","text":"vile:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"perishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dying;"},{"kind":"text","text":"in which sense it is likewise applied to a male camel. (TA.) ―         -b4-  Also, applied to language, or speech, (assumed tropical:)"},{"kind":"italic_en","text":"Bad;"},{"kind":"text","text":"(K;) and so, by poetic license, ↓"},{"kind":"arabic","text_bw":"HaroDN","text_ar":"حَرْضٌ","orth_type":"arrow"},{"kind":"text","text":"; or this, accord. to Sgh, is a dial. var.: (L, TA:) and"},{"kind":"italic_en","text":"perishing:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^aHoraADN","text_ar":"اَحْرَاضٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","TA","T","AZ","Fr","Msb","Zj","A","Lth","L"]},{"entry_id":"n7665","headword_ar":"حَرِضٌ","root":"HrD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaraDN","text_ar":"حَرَضٌ"},{"kind":"text","text":", in three places, near the beginning: ―         -b2-  and again in the latter half of the paragraph."}],"source_refs":[]},{"entry_id":"n7666","headword_ar":"حُرُضٌ","root":"HrD","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HuroDN","text_ar":"حُرْضٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]}}