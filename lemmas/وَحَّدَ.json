{"lemma":"وَحَّدَ","slug":"وَحَّدَ","root":"#.ح.د","root_slug":"_-ح-د","root_link":"/words/roots/_-ح-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"وَحَّدْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"وَحَّدْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"وَحَّدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"وَحَّدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"وَحَّدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"وَحَّدَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"وَحَّدَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"وَحَّدا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"وَحَّدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"وَحَّدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"وَحَّدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُوَحِّد","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُوَحِّدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُوَحِّدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُوَحِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُوَحِّدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُوَحِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُوَحِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُوَحِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُوَحِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُوَحِّد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُوَحِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُوَحِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوَحِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَحِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَحِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَحِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَحِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"وَحَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَحَّدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَحِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَحِّد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":true,"lemma_key":"وَحَّدَ","root":"وحد","pos":"N","occurrence_count":6},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n41729","n41734","n41735","n41736"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%AD%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be single"},{"pos":"verb","gloss":"to be alone"},{"pos":"verb","gloss":"to be unique"},{"pos":"verb","gloss":"to be incomparable"},{"pos":"verb","gloss":"to unify, to unite, to reduce to one","examples":[{"text":"ووحَّد محمّدُ العربَ لأوّل مرّة على ديانة توحيدية ودولة موحّدة.","english":"Muhammad united the Arabs for the first time in a monotheistic religion and a unified state."}]},{"pos":"verb","gloss":"to regularize"},{"pos":"verb","gloss":"to consider as single or unique"},{"pos":"verb","gloss":"to profess the unity of"},{"pos":"verb","gloss":"to connect"},{"pos":"verb","gloss":"to combine"},{"pos":"noun","gloss":"verbal noun of وَحَدَ (waḥada, “to be single, alone, unique, incomparable”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of وَحِدَ (waḥida, “to be single, alone, unique, incomparable”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"solitude"},{"pos":"adj","gloss":"by one's self (with pronoun affixes)","examples":[{"text":"جَاءَ وَحْدَهُ / عَلَى وَحْدِهِ","english":"He came alone."},{"text":"رَأَيْتُ الرَّجُلَ وَحْدَهُ.","english":"I saw the man alone."}]}]},"etymology":{"source":"wiktextract","text":"Compare وَاحِد (wāḥid, “one”).\n\nCausative of وَحَدَ (waḥada) and وَحِدَ (waḥida) and وَحُدَ (waḥuda)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41729","headword_ar":"وَحَدَ","root":"wHd","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHidu","text_ar":"يَحِدُ"},{"kind":"text","text":"; (T, L, Msb;) and"},{"kind":"arabic","text_bw":"waHida","text_ar":"وَحِدَ"},{"kind":"text","text":", (Lh, M, L, K,) aor."},{"kind":"arabic","text_bw":"yawoHadu","text_ar":"يَوْحَدُ"},{"kind":"text","text":"(Lh) and"},{"kind":"arabic","text_bw":"yaHidu","text_ar":"يَحِدُ"},{"kind":"text","text":"; (K;)"},{"kind":"page_break","n":2927},{"kind":"text","text":"with the latter aor., like"},{"kind":"arabic","text_bw":"wariva","text_ar":"وَرِثَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yarivu","text_ar":"يَرِثُ"},{"kind":"text","text":"; but"},{"kind":"arabic","text_bw":"waHida","text_ar":"وَحِدَ"},{"kind":"text","text":"with this aor. is not mentioned by the lexicologists or grammarians [except F]; (MF;) [and its aor. is therefore probably"},{"kind":"arabic","text_bw":"yawoHadu","text_ar":"يَوْحَدُ"},{"kind":"text","text":", only, agreeably with analogy, for which reason it seems to be omitted in the M;] and"},{"kind":"arabic","text_bw":"waHuda","text_ar":"وَحُدَ"},{"kind":"text","text":", (Lh, M, L, Msb, K,) aor. also"},{"kind":"arabic","text_bw":"yaHidu","text_ar":"يَحِدُ"},{"kind":"text","text":"; (K;) but this is without a parallel, and without any authority [except F]; (MF;) or"},{"kind":"arabic","text_bw":"yawoHadu","text_ar":"يَوْحَدُ"},{"kind":"text","text":"; (L;) [but this is also extr., and is probably a mistake for"},{"kind":"arabic","text_bw":"yawoHudu","text_ar":"يَوْحُدُ"},{"kind":"text","text":", which is the form agreeable with analogy;] inf. n."},{"kind":"arabic","text_bw":"HidapN","text_ar":"حِدَةٌ"},{"kind":"text","text":"(T, M, L, Msb, K) and"},{"kind":"arabic","text_bw":"waHodN","text_ar":"وَحْدٌ"},{"kind":"text","text":"(M, L, K) and"},{"kind":"arabic","text_bw":"waHadN","text_ar":"وَحَدٌ"},{"kind":"text","text":"(L) and"},{"kind":"arabic","text_bw":"waHodapN","text_ar":"وَحْدَةٌ"},{"kind":"text","text":", (L, K,) or"},{"kind":"arabic","text_bw":"wuHodapN","text_ar":"وُحْدَةٌ"},{"kind":"text","text":", (as in some copies of the K and in the TA) and"},{"kind":"arabic","text_bw":"wuHuwdN","text_ar":"وُحُودٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"waHaAdapN","text_ar":"وَحَادَةٌ"},{"kind":"text","text":"(M, L, Msb, K) and"},{"kind":"arabic","text_bw":"wuHuwdapN","text_ar":"وُحُودَةٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone, by himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"itself, apart from others;"},{"kind":"text","text":"(T, L, Msb;) as also [↓"},{"kind":"arabic","text_bw":"A_it~aHada","text_ar":"اـِتَّحَدَ","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"twH~d","text_ar":"توحّد","orth_type":"arrow"},{"kind":"text","text":"; and] ↓"},{"kind":"arabic","text_bw":"AstwHd","text_ar":"استوحد","orth_type":"arrow"},{"kind":"text","text":"; (A:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone, without anyone to cheer him by his society, company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conversation:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"he remained alone, by himself, apart from others;"},{"kind":"text","text":"(Lh, M, L, K;) as also ↓"},{"kind":"arabic","text_bw":"twH~d","text_ar":"توحّد","orth_type":"arrow"},{"kind":"text","text":". (M, L, K.) See also 5, below."}],"source_refs":["Lh","M","L","K","Msb","T","A"]},{"entry_id":"n41734","headword_ar":"وَحْدٌ","root":"wHd","body":[{"kind":"text","text":": see 1, and"},{"kind":"arabic","text_bw":"waHiydN","text_ar":"وَحِيدٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"raA^ayotuhu waHodahu","text_ar":"رَاَيْتُهُ وَحْدَهُ"},{"kind":"text","text":"(S, L, K)"},{"kind":"italic_en","text":"I saw him alone."},{"kind":"text","text":"(S, L.)"},{"kind":"arabic","text_bw":"wHd","text_ar":"وحد"},{"kind":"text","text":"is here an inf. n., having no dual nor pl. (K.) The Koofees hold it to be in the acc. case as an adv. n. of place: the Basrees, as an inf. n., in every instance; as though thou saidst"},{"kind":"arabic","text_bw":"A^awoHadotuhu","text_ar":"اَوْحَدْتُهُ"},{"kind":"arabic","text_bw":"biruw^oyatiY A_ibHaAdFA","text_ar":"بِرُوْيَتِى اـِبحَادًا"},{"kind":"text","text":", meaning “ I saw none save him, ” and then substituted"},{"kind":"arabic","text_bw":"wHdh","text_ar":"وحده"},{"kind":"text","text":": or, as Abu-l-'Abbás says, it may mean the man's being himself alone; as though thou saidst"},{"kind":"arabic","text_bw":"raA^ayotu rajulFA munofaridFA","text_ar":"رَاَيْتُ رَجُلًا مُنْفَرِدًا"},{"kind":"arabic","text_bw":"AinofiraAdFA","text_ar":"اِنْفِرَادًا"},{"kind":"text","text":", and then substituted"},{"kind":"arabic","text_bw":"wHdh","text_ar":"وحده"},{"kind":"text","text":". (S.) Or it is in the acc. case as a denotative of state accord. to the Basrees [and the grammarians in general]; not as an inf. n., J being in error in what he says on this matter: (IB, K:) the Basrees hold it to be a noun occupying the place of an inf. n. in the acc. case as a denotative of state; like"},{"kind":"arabic","text_bw":"jaA='a zayodN rakoDFA","text_ar":"جَا=ءَ زَيْدٌ رَكْضًا"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"raAkiDFA","text_ar":"رَاكِضًا"},{"kind":"text","text":": (IB:) excepting some of them, as Yoo, who holds it to be in the acc. case as an adv. n. of place, for"},{"kind":"arabic","text_bw":"EalaY waHodihi","text_ar":"عَلَى وَحْدِهِ"},{"kind":"text","text":", (IB, K,) like"},{"kind":"arabic","text_bw":"Einodahu","text_ar":"عِنْدَهُ"},{"kind":"text","text":": (TA:) and there is a third opinion, that of Hishám; that it is in the acc. case as an inf. n. (L.) Or, (accord. to IAar, L,) it is a noun used as a noun absolutely: (L, K:) so in the dial. of the Benoo-Temeem: (Msb:) you say"},{"kind":"arabic","text_bw":"jalasa waHodahu","text_ar":"جَلَسَ وَحْدَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EalaY waHodihi","text_ar":"عَلَى وَحْدِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"jalasaA EalaY waHodi himaA","text_ar":"جَلَسَا عَلَى وَحْدِ هِمَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"waHodayohimaA","text_ar":"وَحْدَيْهِمَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"jalasuwA EalaY waHodihimo","text_ar":"جَلَسُوا عَلَى وَحْدِهِمْ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He sat alone,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"they two sat alone,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"they sat alone"},{"kind":"text","text":"]. (L, K.) When not preceded by a prefixed n. [or a prep.], it is always in the acc. case: (Lth, L:) you say,"},{"kind":"arabic","text_bw":"laA A_ilaAah A_il~aA A@ll~`hu waHodahu","text_ar":"لَا اـِلَاَه اـِلَّا ا@للّٰهُ وَحْدَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is no deity but God alone"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"mararotu","text_ar":"مَرَرْتُ"},{"kind":"arabic","text_bw":"bizayodK waHodahu","text_ar":"بِزَيْدٍ وَحْدَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I passed by Zeyd alone"},{"kind":"text","text":"]: (L:) [excepting in a few cases, such as the phrases]"},{"kind":"arabic","text_bw":"qulonaA h`*aA AlA^amora waHodayonaA","text_ar":"قُلْنَا هٰذَا الاَمْرَ وَحْدَيْنَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We two alone said this thing"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"qaAlataAhu waHodayohumaA","text_ar":"قَالَتَاهُ وَحْدَيْهُمَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They two"},{"kind":"text","text":"women"},{"kind":"italic_en","text":"alone said it"},{"kind":"text","text":"]; mentioned by AZ. (L.) You say also,"},{"kind":"arabic","text_bw":"h`*aA EalaY waHodihi","text_ar":"هٰذَا عَلَى وَحْدِهِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"EalaY Hidatihi","text_ar":"عَلَى حِدَتِهِ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"This is by itself;"},{"kind":"text","text":"(L, K;) and"},{"kind":"arabic","text_bw":"humaA EalaY HidatihimaA","text_ar":"هُمَا عَلَى حِدَتِهِمَا"},{"kind":"italic_en","text":"They two are by themselves:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"humo EalaY Hidatihimo","text_ar":"هُمْ عَلَى حِدَتِهِمْ"},{"kind":"italic_en","text":"They are by themselves:"},{"kind":"text","text":"(L:) and"},{"kind":"arabic","text_bw":"A^aEoTi kul~a waAHidK","text_ar":"اَعْطِ كُلَّ وَاحِدٍ"},{"kind":"arabic","text_bw":"manohumo EalaY Hidatihi","text_ar":"مَنْهُمْ عَلَى حِدَتِهِ"},{"kind":"italic_en","text":"Give thou to every one of them by himself;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ElY HiyaAlihi","text_ar":"على حِيَالِهِ"},{"kind":"text","text":". (S.) The"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"HidapN","text_ar":"حِدَةٌ"},{"kind":"text","text":"is a substitute for the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"(S, L) which is cut off from the beginning. (L.) ―         -b3-"},{"kind":"arabic","text_bw":"waHodN","text_ar":"وَحْدٌ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"waHadN","text_ar":"وَحَدٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) A wild animal"},{"kind":"italic_en","text":"alone, by itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"apart from others."},{"kind":"text","text":"(L, K.) ―         -b4-"},{"kind":"arabic","text_bw":"waHadN","text_ar":"وَحَدٌ"},{"kind":"text","text":", (K,) or ↓"},{"kind":"arabic","text_bw":"waHadN","text_ar":"وَحَدٌ","orth_type":"arrow"},{"kind":"text","text":", (L,) A man"},{"kind":"italic_en","text":"whose lineage and origin are unknown."},{"kind":"text","text":"(Lth, L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"waHod","text_ar":"وَحْد"},{"kind":"text","text":"is used as the complement of a prefixed n. only in the following phrases: (A'Obeyd, S, L:)"},{"kind":"arabic","text_bw":"huwa nasiyju waHodihi","text_ar":"هُوَ نَسِيجُ وَحْدِهِ"},{"kind":"text","text":", which is an expression of praise; (S, L, K;) meaning, (tropical:)"},{"kind":"italic_en","text":"He is one unequalled; one who has no second:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"he is a man of right judgment:"},{"kind":"text","text":"you say also"},{"kind":"arabic","text_bw":"humaA nasiyjaA waHodihimaA","text_ar":"هُمَا نَسِيجَا وَحْدِهِمَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"humo nusajaA='u waHodihimo","text_ar":"هُمْ نُسَجَا=ءُ وَحْدِهِمْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"hiYa nasiyjapu waHodihaA","text_ar":"هِىَ نَسِيجَةُ وَحْدِهَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"hun~a nasaAy^iju waHodihin~a","text_ar":"هُنَّ نَسَايِجُ وَحْدِهِنَّ"},{"kind":"text","text":": (Lth, L:) [see art."},{"kind":"arabic","text_bw":"nsj","text_ar":"نسج"},{"kind":"text","text":":] it is as though you said"},{"kind":"arabic","text_bw":"nasiyju A_iforaAdK","text_ar":"نَسِيجُ اـِفْرَادٍ"},{"kind":"text","text":": you put"},{"kind":"arabic","text_bw":"wHdh","text_ar":"وحده"},{"kind":"text","text":"in the place of an inf. n. in the gen. case: (S:) and"},{"kind":"arabic","text_bw":"rajulu waHodihi","text_ar":"رَجُلُ وَحْدِهِ"},{"kind":"text","text":", (IAar, L,) and"},{"kind":"arabic","text_bw":"rujayolu waHodihi","text_ar":"رُجَيْلُ وَحْدِهِ"},{"kind":"text","text":", (S, L,) ["},{"kind":"italic_en","text":"A man unequalled; who has no second,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a little man"},{"kind":"text","text":"(probably meaning the contr.) &c.]: and"},{"kind":"arabic","text_bw":"qariyEu waHodihi","text_ar":"قَرِيعُ وَحْدِهِ"},{"kind":"italic_en","text":"A man with whom no one contends in excellence:"},{"kind":"text","text":"(Lth, L:) and"},{"kind":"arabic","text_bw":"Euyayoru waHodihi","text_ar":"عُيَيْرُ وَحْدِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"juHayo$u waHodihi","text_ar":"جُحَيْشُ وَحْدِهِ"},{"kind":"text","text":", which are expressions of dispraise; (S, L, K;) meaning, (tropical:)"},{"kind":"italic_en","text":"One who does not consult, nor mix with, any one, and who is contemptible and weak:"},{"kind":"text","text":"(Sh, L:)"},{"kind":"arabic","text_bw":"waHod","text_ar":"وَحْد"},{"kind":"text","text":"being used in the manner of an inf. n., not being an epithet nor an enunciative so as to be in concordance with the preceding noun, would be more properly in the acc. case; but the Arabs use it in these instances as the complement of a prefixed n.: (Lth, L:) these expressions are indeterminate: for the Arabs say,"},{"kind":"arabic","text_bw":"rub~a nasiyji waHodihi","text_ar":"رُبَّ نَسِيجِ وَحْدِهِ"},{"kind":"arabic","text_bw":"qado raA^ayotu","text_ar":"قَدْ رَاَيْتُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Few unequalled men have I seen"},{"kind":"text","text":"]. (Hishám, Fr., L.)"}],"source_refs":["S","L","K","IB","TA","Msb","Lth","IAar","Sh"]},{"entry_id":"n41735","headword_ar":"وَحَدٌ","root":"wHd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"waHodN","text_ar":"وَحْدٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"waHiydN","text_ar":"وَحِيدٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n41736","headword_ar":"وَحِدٌ","root":"wHd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"waHiydN","text_ar":"وَحِيدٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}