icon.com/?s=%D8%A3%D9%8E%D9%86%D9%92%D8%A8%D9%8E%D8%AA%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1693","headword_ar":"انبتّ","root":"bt","body":[{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cut off, severed, separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunited,"},{"kind":"text","text":"(Lth, T, S, M, Msb, K,)"},{"kind":"italic_en","text":"entirely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utterly;"},{"kind":"text","text":"(Lth, T, M;) namely, a thing; (M;) a rope, or cord; (Lth, T;) and a tie, or bond, of union between two persons: (T, M: *) as also ↓"},{"kind":"arabic","text_bw":"bat~a","text_ar":"بَتَّ","orth_type":"arrow"},{"kind":"text","text":", (Lth, AZ, T, M, Msb,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (M, [so accord. to a copy of that work, but it seems to be indicated in the Msb (see 1, near the close of the paragraph,) that it is"},{"kind":"text","text":"only, in this case,]) inf. n."},{"kind":"arabic","text_bw":"bat~N","text_ar":"بَتٌّ"},{"kind":"text","text":"; (Lth, AZ, T, M, K;) and ↓"},{"kind":"arabic","text_bw":"Abt~","text_ar":"ابتّ","orth_type":"arrow"},{"kind":"text","text":", (T, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"A_ibotaAtN","text_ar":"اـِبْتَاتٌ"},{"kind":"text","text":"; (T, TA;) the last said by Lth and AZ to be trans. only; (T, TA;) but it is both trans. and intrans., like the second: (T, Msb, TA:) so says En-Nawawee, as mentioned above: see 1. (TA.) You say,"},{"kind":"arabic","text_bw":"AinoqaTaEa fulaAnK faA@nobat~a Haboluhu Eanohu","text_ar":"اِنْقَطَعَ فُلَانٍ فَا@نْبَتَّ حَبْلُهُ عَنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one broke off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disunited himself, from such a one, and his tie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bond, of union became severed from him"},{"kind":"text","text":"]. (T, TA, [but in a copy of the former, for"},{"kind":"arabic","text_bw":"En flAn","text_ar":"عن فلان"},{"kind":"text","text":", is put"},{"kind":"arabic","text_bw":"Eano maAlihi","text_ar":"عَنْ مَالِهِ"},{"kind":"italic_en","text":"from his property."},{"kind":"text","text":"]) ―         -b2-"},{"kind":"italic_en","text":"He became unable to proceed in his journey, his camel that bore him breaking down, or stopping from fatigue, or perishing:"},{"kind":"text","text":"(A, * Mgh, * TA:) quasi-pass. of"},{"kind":"arabic","text_bw":"bat~ahu","text_ar":"بَتَّهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^abat~ahu","text_ar":"اَبَتَّهُ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"saAra Hat~aY A@nobat~a","text_ar":"سَارَ حَتَّى ا@نْبَتَّ"},{"kind":"italic_en","text":"He journeyed until he was unable to proceed"},{"kind":"text","text":"&c. (A, Mgh, TA.) [See also"},{"kind":"arabic","text_bw":"munobat~N","text_ar":"مُنْبَتٌّ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"italic_en","text":"His"},{"kind":"arabic","text_bw":"maA='","text_ar":"مَا=ء"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"the"},{"kind":"arabic","text_bw":"mA='","text_ar":"ما=ء"},{"kind":"italic_en","text":"of his back,"},{"kind":"text","text":"(Ks, T, K,) [i. e."},{"kind":"italic_en","text":"his seminal fluid,] became cut off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceased,"},{"kind":"text","text":"(Ks, T, A, K,)"},{"kind":"italic_en","text":"by reason of age:"},{"kind":"text","text":"(A:) said of a man. (Ks, T, A.)"}],"source_refs":["Lth","T","S","M","Msb","K","AZ","TA","A","Ks"]}]},"classical_definitions":null}