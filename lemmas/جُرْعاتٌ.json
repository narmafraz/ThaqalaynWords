{"lemma":"جُرْعاتٌ","slug":"جُرْعاتٌ","root":"ج.ر.ع","root_slug":"ج-ر-ع","root_link":"/words/roots/ج-ر-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n5556","n5557","n5558","n5559"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8F%D8%B1%D9%92%D8%B9%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"dose, shot (particularly of a drug)"},{"pos":"noun","gloss":"gulp, swallow"},{"pos":"noun","gloss":"dose, shot (particularly of a drug)"}]},"etymology":{"source":"wiktextract","text":"Instance noun from the verb جَرَعَ (jaraʕa)."},"ipa":["/d͡ʒar.ʕa/","/d͡ʒur.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5556","headword_ar":"جَرْعَةٌ","root":"jrE","body":[{"kind":"text","text":": see what next follows, in three places:       -A2-  and see"},{"kind":"arabic","text_bw":"jaraEapN","text_ar":"جَرَعَةٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n5557","headword_ar":"جُرْعَةٌ","root":"jrE","body":[{"kind":"italic_en","text":"A gulp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as much as is swallowed at once,"},{"kind":"text","text":"of water; a"},{"kind":"arabic","text_bw":"juroEap","text_ar":"جُرْعَة"},{"kind":"text","text":"of water being like a"},{"kind":"arabic","text_bw":"luqomap","text_ar":"لُقْمَة"},{"kind":"text","text":"of food: (Msb:) or a"},{"kind":"italic_en","text":"sup,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sip;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as much as is supped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sipped, at once;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a mouthful of what is supped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sipped;"},{"kind":"text","text":"(syn."},{"kind":"arabic","text_bw":"HusowapN","text_ar":"حُسْوَةٌ"},{"kind":"text","text":";) of water; (S, K;) as also ↓"},{"kind":"arabic","text_bw":"jaroEapN","text_ar":"جَرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jiroEapN","text_ar":"جِرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":": or"},{"kind":"arabic","text_bw":"juroEapN","text_ar":"جُرْعَةٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jaroEapN","text_ar":"جَرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"are substs. [signifying the"},{"kind":"italic_en","text":"act of swallowing"},{"kind":"text","text":"water] from"},{"kind":"arabic","text_bw":"jariEa AlmaA='a","text_ar":"جَرِعَ المَا=ءَ"},{"kind":"text","text":"“ he swallowed the water: ” (K:) or ↓"},{"kind":"arabic","text_bw":"jaroEapN","text_ar":"جَرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a single act of swallowing"},{"kind":"text","text":"water: (IAth, L:) and"},{"kind":"arabic","text_bw":"juroEapN","text_ar":"جُرْعَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"what one swallows:"},{"kind":"text","text":"(L, K:) or"},{"kind":"italic_en","text":"a mouthful which one swallows:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a small draught:"},{"kind":"text","text":"(IAth:) and its pl. is"},{"kind":"arabic","text_bw":"juraEN","text_ar":"جُرَعٌ"},{"kind":"text","text":". (Msb, TA.) The dim. is ↓"},{"kind":"arabic","text_bw":"jurayoEapN","text_ar":"جُرَيْعَةٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) And hence the prov.,"},{"kind":"arabic","text_bw":"A^afolata","text_ar":"اَفْلَتَ"},{"kind":"arabic","text_bw":"fulaAnN jurayoEapa Al*~aqani","text_ar":"فُلَانٌ جُرَيْعَةَ الذَّقَنِ"},{"kind":"text","text":", (Sgh, K,) the verb being intrans., and"},{"kind":"arabic","text_bw":"jryEp","text_ar":"جريعة"},{"kind":"text","text":"being in the accus. case as a denotative of state, as though the speaker said,"},{"kind":"arabic","text_bw":"A^afolata qaA*ifFA jurayoEapa Al*~aqani","text_ar":"اَفْلَتَ قَاذِفًا جُرَيْعَةَ الذَّقَنِ"},{"kind":"text","text":"; (Sgh;) or"},{"kind":"arabic","text_bw":"bijurayoEapi","text_ar":"بِجُرَيْعَةِ"},{"kind":"arabic","text_bw":"Al*~aqani","text_ar":"الذَّقَنِ"},{"kind":"text","text":"; (S, K;) or ↓"},{"kind":"arabic","text_bw":"bijurayoEaA=y^ihaA","text_ar":"بِجُرَيْعَا=يِهَا","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"Such a one escaped"},{"kind":"text","text":"[from destruction]"},{"kind":"italic_en","text":"when his spirit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the remains thereof, had become in his mouth;"},{"kind":"text","text":"(L, K;) or"},{"kind":"italic_en","text":"near thereto,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"as a sup"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"little sup"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of water to the chin"},{"kind":"text","text":"[of a person drinking]; (TA;) or"},{"kind":"italic_en","text":"when death was as near to him as a little sup of water to the chin;"},{"kind":"text","text":"(L;) or"},{"kind":"italic_en","text":"when at his last gasp:"},{"kind":"text","text":"(Fr, S:) applied to one who has been at the point of destruction, and then escaped: (S:) or, accord. to AZ, it is thus;"},{"kind":"arabic","text_bw":"A^afolataniY jurayoEapa Al*~aqani","text_ar":"اَفْلَتَنِى جُرَيْعَةَ الذَّقَنِ"},{"kind":"text","text":", which may mean"},{"kind":"italic_en","text":"he made me to escape"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"he escaped from me"},{"kind":"text","text":"&c.; in the latter case,"},{"kind":"arabic","text_bw":"AfltnY","text_ar":"افلتنى"},{"kind":"text","text":"being for"},{"kind":"arabic","text_bw":"A^afolata min~iY","text_ar":"اَفْلَتَ مِنِّى"},{"kind":"text","text":"; and [it is said that]"},{"kind":"arabic","text_bw":"jryEp","text_ar":"جريعة"},{"kind":"text","text":"is prefixed to"},{"kind":"arabic","text_bw":"Al*qn","text_ar":"الذقن"},{"kind":"text","text":"because the motion of the chin indicates the nearness of the departure of the soul: or the meaning of the words related by AZ may be, he made me, i. e. the remains of my soul, to escape; the last two words being a substitute for the pronoun affixed to the verb. (Sgh.) One says also,"},{"kind":"arabic","text_bw":"A^afolatanaYi jurayoEapa Alr~iyqi","text_ar":"اَفْلَتَنَىِ جُرَيْعَةَ الرِّيقِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He outwent me,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"escaped me,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and I swallowed my spittle in wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage, against him."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maA mino juroEapK A^aHomadu EuqobaAnFA mino juroEapi","text_ar":"مَا مِنْ جُرْعَةٍ اَحْمَدُ عُقْبَانًا مِنْ جُرْعَةِ"},{"kind":"arabic","text_bw":"gayoZK nakoZimuhaA","text_ar":"غَيْظٍ نَكْظِمُهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"There is nothing that is swallowed more praiseworthy in its result than what is swallowed of wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage, which we repress,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restrain"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb","K","IAth","L","TA","Sgh","Fr","S"]},{"entry_id":"n5558","headword_ar":"جِرْعَةٌ","root":"jrE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"juroEapN","text_ar":"جُرْعَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n5559","headword_ar":"جَرَعَةٌ","root":"jrE","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"jaroEapN","text_ar":"جَرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"jaroEaA='u","text_ar":"جَرْعَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"A^ajoraEu","text_ar":"اَجْرَعُ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"An even piece,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"a round piece,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hillock,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"of sand, that produces no plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage;"},{"kind":"text","text":"(S, K;) and, as some add,"},{"kind":"italic_en","text":"that retains no water:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a piece,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract, of sand, good for producing plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, in which is no softness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looseness:"},{"kind":"text","text":"(Sgh, L, K:) or"},{"kind":"italic_en","text":"land in which is ruggedness, resembling sand:"},{"kind":"text","text":"(L, K:) or"},{"kind":"italic_en","text":"a hill of which one side consists of sand, and one side of stones:"},{"kind":"text","text":"(K:) or what is termed ↓"},{"kind":"arabic","text_bw":"jrEA'","text_ar":"جرعاء","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AjrE","text_ar":"اجرع","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"larger than what is termed"},{"kind":"arabic","text_bw":"jaraEapN","text_ar":"جَرَعَةٌ"},{"kind":"text","text":": ↓"},{"kind":"arabic","text_bw":"jrEA'","text_ar":"جرعاء","orth_type":"arrow"},{"kind":"text","text":"is also explained as signifying"},{"kind":"italic_en","text":"sand of which the middle is elevated, and of which the sides are thin:"},{"kind":"text","text":"and, accord. to IAth, ↓"},{"kind":"arabic","text_bw":"AjrE","text_ar":"اجرع","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a wide place, in which is ruggedness:"},{"kind":"text","text":"(TA:) or this last,"},{"kind":"italic_en","text":"a plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, place, intermixed with sand:"},{"kind":"text","text":"(Ham p. 574:)"},{"kind":"arabic","text_bw":"jaraEapN","text_ar":"جَرَعَةٌ"},{"kind":"text","text":"is sing., or n. un., of ↓"},{"kind":"arabic","text_bw":"jaraEN","text_ar":"جَرَعٌ","orth_type":"arrow"},{"kind":"text","text":": (S, K: *) or, accord. to some, this last word is a sing., like"},{"kind":"arabic","text_bw":"AjrE","text_ar":"اجرع"},{"kind":"text","text":"; and its pl. [of pauc.] is"},{"kind":"arabic","text_bw":"A^ajoraAEN","text_ar":"اَجْرَاعٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"jiraAEN","text_ar":"جِرَاعٌ"},{"kind":"text","text":": the pl. of"},{"kind":"arabic","text_bw":"jaraEapN","text_ar":"جَرَعَةٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"jiroEaAnN","text_ar":"جِرْعَانٌ"},{"kind":"text","text":": and the pl. of ↓"},{"kind":"arabic","text_bw":"jaroEapN","text_ar":"جَرْعَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"jiraAEN","text_ar":"جِرَاعٌ"},{"kind":"text","text":": and the pl. of ↓"},{"kind":"arabic","text_bw":"jiriEA'","text_ar":"جِرِعاء","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"jaroEaAwaAtN","text_ar":"جَرْعَاوَاتٌ"},{"kind":"text","text":": and the pl. of ↓"},{"kind":"arabic","text_bw":"AjrE","text_ar":"اجرع","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^ajaAriEu","text_ar":"اَجَارِعُ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","TA","Sgh","L"]}]}}