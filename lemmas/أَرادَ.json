},{"role":"present_1ms","form":"أُرِيد","in_corpus":true,"count":87,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1661,"cross_references":{"qac":{"found":true,"lemma_key":"أَرادَ","root":"رود","pos":"V","occurrence_count":139},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to want, will","examples":[{"text":"أُرِيدُ أَنْ أَنْصَرِفَ.","english":"I want to leave."},{"text":"الشَّعْبُ يُرِيدُ إِسْقَاطَ النِّظَامِ.","english":"The people want the toppling of the regime."}]},{"pos":"verb","gloss":"to be about to","tags":["figuratively"],"examples":[{"text":"فَوَجَدَا فِيهَا جِدَارًا يُرِيدُ أَن يَنْقَضَّ فَأَقَامَهُ","english":"There they found a wall ready to collapse, so the man set it right."}]}]},"etymology":null,"ipa":["/ʔa.raː.da/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%B1%D8%A7%D8%AF/","headword_ar":"أراد","entries":[{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10281#cb6458","body_html":"<span>أراد: في اليَوِم اليوم، بوزن فَعِل فقَلَب. وقال زهير :</span><br><br><span>[فَصَرِّمْ حَبْلَها إذْ صَرَّمَتْهُ] </span><span class=\"red\">...</span><span> وعادَكَ أَنْ تُلاقيَها العَداءُ</span>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10281#e81139","body_html":"<span>أراد: عَبْقَرَةً عَبْقَرَةً، فذهَبَتِ الهاء في القافية وصارَت ألفاً بَدَلاً للهاء. والعَبْقَريُّ: ضربُ من البُسُط، الواحدة بالهاء، وقال بعضهم: عَباقِريّ، فإن أرادَ بذلك جَمْعَ عَبْقَريٍّ، فإنَّ ذلك لا يكون لأنَّ المنسوبَ لا يُجْمَعُ على نِسبةٍ ولا سيَّما الرباعيُّ، لا يُجْمَعُ الخثعمي بالخَثاعِميِّ ولا المُهَلَّبِيِّ بالمَهالِبيِّ، ولا يجوز ذلك ألا أن يكونَ يُنسب اسمٌ على بناء الجماعة بعدَ تَمامِ الاسم نحو شَيءٍ تنسِبُه إلى حَضاجِر وسَراويل فيقال: حضاجري وسَراويليٌّ، ويُنسب كذلك إلى عَباقِر فيقال: عَباقِريٌّ. والعَبْقَرةُ: تَلألُؤ السَّراب.</span>"},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10281#a066e1","body_html":"<span>أراد: أوحَى إليها، إلاّ أنّ لغته: وَحَى، فإذا لم يذكر (لها) قال: أوحى. وزكريا أوحى إلى قومه، أي: أشار إليهم. والإيحاء: الإشارة. قال: </span><br><br><span>فأَوْحَتْ إليها والأنامِلُ رُسْلُها</span><br><br><span>وقوله : وَاسْتَحْيُوا نِساءَهُمْ</span><br><br><span>. أي: استفعلوا من الحياة، أي:</span><span> </span><a></a><a></a><span>اتركوهنَّ أحياء.</span><br><br><span>وفي الحديث: إنَّ الرّجل لَيُسألُ عن كلِّ شيءٍ حتى عن حَيَّةِ أهِلِه ،</span><br><br><span>أي: عن كلّ شيءٍ حيٍّ في منزله مثل الهرّة، فأنّث الحيّ فقال: حيّة. والحوايا: المَساطح، وهو أن يعمدوا إلى الصَّفا فيَحْوون له تُراباً يحبس عليهم الماء. الواحدة: حَوِيَّة. والحيّ: نقيض الميّت. والوَحَى: السُّرعة.</span>"}]}}