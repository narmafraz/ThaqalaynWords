{"lemma":"بَحْتِ","slug":"بَحْتِ","root":"ب.ح.ت","root_slug":"ب-ح-ت","root_link":"/words/roots/ب-ح-ت","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1816","n1818"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%AD%D9%92%D8%AA%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"pure, unmixed, sheer"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1816","headword_ar":"بَحُتَ","root":"bHt","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"buHuwtapN","text_ar":"بُحُوتَةٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"baHotN","text_ar":"بَحْتٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unmixed, free from admixture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pure:"},{"kind":"text","text":"(S, K:) [and]"},{"kind":"italic_en","text":"he was unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pure, in race, lineage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parentage."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","Msb","K"]},{"entry_id":"n1818","headword_ar":"بَحْتٌ","root":"bHt","body":[{"kind":"italic_en","text":"Unmixed, free from admixture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pure;"},{"kind":"text","text":"(S, A, Mgh, K;) applied to anything: (A, K:) anything"},{"kind":"italic_en","text":"that is eaten alone, without seasoning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condiment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"any savoury food:"},{"kind":"text","text":"and in like manner, seasoning, or condiment, or any savoury food,"},{"kind":"italic_en","text":"without bread:"},{"kind":"text","text":"(Ahmad Ibn-Yahyà:)"},{"kind":"italic_en","text":"unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pure, in race, lineage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parentage;"},{"kind":"text","text":"(S, A, Msb;) applied [for instance] to an Arab, (S, A,) and to an Arab of the desert: (TA:) originally an inf. n.; (Msb;) [and therefore] the same as masc. and fem. and dual and pl.: but if you will, you may use"},{"kind":"arabic","text_bw":"baHotapN","text_ar":"بَحْتَةٌ"},{"kind":"text","text":"as a fem. epithet, applied [for instance] to an Arab woman; and may use the dual and pl. forms: (S:) or the fem. is [properly] with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"; or, as some say, the word has no dual nor pl. nor dim. form. (K.) You say"},{"kind":"arabic","text_bw":"$araAbN baHotN","text_ar":"شَرَابٌ بَحْتٌ"},{"kind":"italic_en","text":"Unmixed wine"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beverage:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"xamorN baHotN","text_ar":"خَمْرٌ بَحْتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baHotapN","text_ar":"بَحْتَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xumuwrN baHotapN","text_ar":"خُمُورٌ بَحْتَةٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"unmixed wine"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wines"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"xubozN baHotN","text_ar":"خُبْزٌ بَحْتٌ"},{"kind":"italic_en","text":"Bread without anything else"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to season it"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"A^akala Alxuboza baHotFA","text_ar":"اَكَلَ الخُبْزَ بَحْتًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"All~aHoma baHotFA","text_ar":"اللَّحْمَ بَحْتًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"He ate the bread without any seasoning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condiment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"savoury food,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the flesh-meat without bread."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qad~ama A_ilayohi qafaArFA baHotFA","text_ar":"قَدَّمَ اـِلَيْهِ قَفَارًا بَحْتًا"},{"kind":"italic_en","text":"He presented to him food without any seasoning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condiment."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"Ad~ahana biduhonK baHotN","text_ar":"ادَّهَنَ بِدُهْنٍ بَحْتٌ"},{"kind":"italic_en","text":"He anointed himself with ointment unmixed with any perfume."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"misokN baHonN","text_ar":"مِسْكٌ بَحْنٌ"},{"kind":"text","text":"(A, Msb) ["},{"kind":"italic_en","text":"Unmixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unadulterated, and"},{"kind":"text","text":"therefore]"},{"kind":"italic_en","text":"strong"},{"kind":"text","text":"["},{"kind":"italic_en","text":"-scented,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"musk."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"barodN baHotN laHotN","text_ar":"بَرْدٌ بَحْتٌ لَحْتٌ"},{"kind":"italic_en","text":"Vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intense, cold;"},{"kind":"text","text":"(TA;) ["},{"kind":"italic_en","text":"as though unmixed with any degree of warmth;"},{"kind":"text","text":"] syn."},{"kind":"arabic","text_bw":"SaAdiqN","text_ar":"صَادِقٌ"},{"kind":"text","text":": (K in art."},{"kind":"arabic","text_bw":"lHt","text_ar":"لحت"},{"kind":"text","text":":) the last word is an imitative sequent. (TA in that art.)"}],"source_refs":["A","K","S","TA","Msb"]}]},"classical_definitions":null}