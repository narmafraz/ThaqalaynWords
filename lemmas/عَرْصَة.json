{"lemma":"عَرْصَة","slug":"عَرْصَة","root":"ع.ر.ص","root_slug":"ع-ر-ص","root_link":"/words/roots/ع-ر-ص","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28672"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B1%D9%92%D8%B5%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"courtyard, court"}]},"etymology":null,"ipa":["/ʕar.sˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28672","headword_ar":"عَرْصَةٌ","root":"ErS","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"court,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"open area,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAHap","text_ar":"سَاحَة"},{"kind":"text","text":",) of a house; (T, Msb;) i. e.,"},{"kind":"italic_en","text":"a spacious vacant part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"thereof,"},{"kind":"italic_en","text":"in which is no building;"},{"kind":"text","text":"(Msb;) so called because the children play, or sport, &c., ("},{"kind":"arabic","text_bw":"yaEotariSuwna","text_ar":"يَعْتَرِصُونَ"},{"kind":"text","text":",) therein: (T, Msb:) or"},{"kind":"italic_en","text":"any spacious piece of ground between houses, in which is no building:"},{"kind":"text","text":"(S, O, K:) or"},{"kind":"italic_en","text":"any distinct piece of ground in which is no building;"},{"kind":"text","text":"accord. to EthTha'álibee, in his book entitled “ Fikh el-Loghah: ” (Msb:) or"},{"kind":"italic_en","text":"any open space in which is no building:"},{"kind":"text","text":"(As, TA:) or the"},{"kind":"italic_en","text":"ground"},{"kind":"text","text":"of a house,"},{"kind":"italic_en","text":"where it is built;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"any chamber"},{"kind":"text","text":"of a house,"},{"kind":"italic_en","text":"in which one sits, not in the upper part:"},{"kind":"text","text":"(A:) pl."},{"kind":"arabic","text_bw":"A^aEoraASN","text_ar":"اَعْرَاصٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"EiraASN","text_ar":"عِرَاصٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaraSaAtN","text_ar":"عَرَصَاتٌ"},{"kind":"text","text":"(S, A, O, Msb, K.)"}],"source_refs":["T","Msb","S","O","K","As","TA","A"]}]}}