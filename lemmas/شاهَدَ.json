um":"p"},{"role":"present_2mp","form":"تُشاهِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُشاهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُشاهِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُشاهَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُشاهِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُشاهَد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُشاهِد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُشاهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشاهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشاهِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُشاهِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشاهَدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشاهَدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشاهِدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشاهِدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشاهَدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشاهَدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشاهِدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشاهِدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشاهَدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُشاهِدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شاهَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شاهَدْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُشاهَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشاهَد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشاهِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشاهِد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"شُوهِدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شُوهِدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":59,"cross_references":{"qac":{"found":true,"lemma_key":"شاهَدَ","root":"شهد","pos":"N","occurrence_count":21},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["","n23197"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D8%A7%D9%87%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to see (with one’s own eyes), to view, to inspect, to watch, to observe, to witness","examples":[{"text":"شَاهَدْتُ كَثِيرًا مِنَ ٱلْأَجَانِبَ هُنَاكَ.","english":"I saw many foreigners there."}]},{"pos":"noun","gloss":"witness, one giving evidence","examples":[{"text":"شَاهِد عِيَان","english":"eyewitness"}]},{"pos":"noun","gloss":"notary public"},{"pos":"noun","gloss":"evidence, piece of evidence"},{"pos":"noun","gloss":"attestation"},{"pos":"noun","gloss":"textual evidence"},{"pos":"noun","gloss":"testimony"},{"pos":"noun","gloss":"upright, oblong tombstone"},{"pos":"noun","gloss":"forefinger, index finger"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb شَهِدَ (šahida).\n\nSense 6 might stem from the practice of raising the index finger while reciting the shahada."},"ipa":["/ʃaː.ha.da/","/ʃaː.hid/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23197","headword_ar":"شَاهِدٌ","root":"$hd","body":[{"kind":"text","text":"(S, Mgh, L, K) and ↓"},{"kind":"arabic","text_bw":"$ahiydN","text_ar":"شَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":"(S, * Mgh, L)"},{"kind":"italic_en","text":"One who tells,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gives information of, what he has witnessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seen"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beheld with his eye:"},{"kind":"text","text":"(Mgh, L:)"},{"kind":"italic_en","text":"one who declares what he knows:"},{"kind":"text","text":"(L:) one"},{"kind":"italic_en","text":"who knows, and declares what he knows:"},{"kind":"text","text":"(ISd, TA:)"},{"kind":"italic_en","text":"a witness,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"one who gives testimony,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence; who bears witness:"},{"kind":"text","text":"(S, * L, K: *) ["},{"kind":"italic_en","text":"one who gives decisive information:"},{"kind":"text","text":"(see 1, first sentence:)] pl. of the former ↓"},{"kind":"arabic","text_bw":"$ahodN","text_ar":"شَهْدٌ","orth_type":"arrow"},{"kind":"text","text":", (Akh, S, K,) or [rather] this is a quasi-pl. n., (Sb, TA,) like as"},{"kind":"arabic","text_bw":"SaHobN","text_ar":"صَحْبٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"SaAHibN","text_ar":"صَاحِبٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"saforN","text_ar":"سَفْرٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"saAfirN","text_ar":"سَافِرٌ"},{"kind":"text","text":", (S,) but some disallow this; (TA;) and ↓"},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ","orth_type":"arrow"},{"kind":"text","text":"[but see what is said of this in the latter half of the paragraph] and"},{"kind":"arabic","text_bw":"A^a$ohaAdN","text_ar":"اَشْهَادٌ"},{"kind":"text","text":"are also pls. of"},{"kind":"arabic","text_bw":"$aAhidN","text_ar":"شَاهِدٌ"},{"kind":"text","text":", (Mgh, L,) or of"},{"kind":"arabic","text_bw":"$ahodN","text_ar":"شَهْدٌ"},{"kind":"text","text":": (S, K:) the pl. of ↓"},{"kind":"arabic","text_bw":"$ahiydN","text_ar":"شَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"$uhadaA='u","text_ar":"شُهَدَا=ءُ"},{"kind":"text","text":". (S, Mgh.) [Hence,] ↓"},{"kind":"arabic","text_bw":"maEahaA saAy^iqN wa$ahiydN","text_ar":"مَعَهَا سَايِقٌ وَشَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":", in the Kur 1. 20: see art."},{"kind":"arabic","text_bw":"swq","text_ar":"سوق"},{"kind":"text","text":". ―         -b2-  [Hence also]"},{"kind":"arabic","text_bw":"Al$~aAhidu","text_ar":"الشَّاهِدُ"},{"kind":"text","text":"a name of the Prophet; (K;) meaning"},{"kind":"italic_en","text":"The witness"},{"kind":"text","text":"against those to whom he has been sent. (Jel in xxxiii. 44.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$aAhidN","text_ar":"شَاهِدٌ"},{"kind":"italic_en","text":"An angel:"},{"kind":"text","text":"(S, L, K:) or"},{"kind":"italic_en","text":"a guardian angel:"},{"kind":"text","text":"(Mujáhid:) pl."},{"kind":"arabic","text_bw":"A^a$ohaAdN","text_ar":"اَشْهَادٌ"},{"kind":"text","text":": or this means the"},{"kind":"italic_en","text":"prophets."},{"kind":"text","text":"(TA.) ―         -b4-  And The"},{"kind":"italic_en","text":"tongue:"},{"kind":"text","text":"(S, L, K:) from the saying,"},{"kind":"arabic","text_bw":"lifulaAnK $aAhidN HasanN","text_ar":"لِفُلَانٍ شَاهِدٌ حَسَنٌ"},{"kind":"italic_en","text":"Such a one has an elegant diction."},{"kind":"text","text":"(L.) One says also,"},{"kind":"arabic","text_bw":"maA lifulaAnK ruwaA='N walaA $aAhidN","text_ar":"مَا لِفُلَانٍ رُوَا=ءٌ وَلَا شَاهِدٌ"},{"kind":"italic_en","text":"Such a one has neither goodliness of aspect nor tongue."},{"kind":"text","text":"(Aboo-Bekr, L.) ―         -b5-  [As a conventional term used in lexicology &c.,]"},{"kind":"italic_en","text":"An evidential example,"},{"kind":"text","text":"generally poetical, of the form or meaning of a word or phrase: pl."},{"kind":"arabic","text_bw":"$awaAhidu","text_ar":"شَوَاهِدُ"},{"kind":"text","text":": the sciences that require"},{"kind":"arabic","text_bw":"$awaAhid","text_ar":"شَوَاهِد"},{"kind":"text","text":"being those of"},{"kind":"arabic","text_bw":"All~ugap","text_ar":"اللُّغَة"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlS~arof","text_ar":"الصَّرْف"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Aln~aHow","text_ar":"النَّحْو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlmaEaAniY","text_ar":"المَعَانِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlbayaAn","text_ar":"البَيَان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlbadiyE","text_ar":"البَدِيع"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlEaruwD","text_ar":"العَرُوض"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlqawaAfiY","text_ar":"القَوَافِى"},{"kind":"text","text":". (MF on the"},{"kind":"arabic","text_bw":"xuTobap","text_ar":"خُطْبَة"},{"kind":"text","text":"of the K.) [One says,"},{"kind":"arabic","text_bw":"h`*aA $aAhidN lika*aA","text_ar":"هٰذَا شَاهِدٌ لِكَذَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaY ka*aA","text_ar":"عَلَى كَذَا"},{"kind":"italic_en","text":"This is an evidential example of such a thing."},{"kind":"text","text":"] With respect to the classical language, absolutely,"},{"kind":"arabic","text_bw":"$wAhd","text_ar":"شواهد"},{"kind":"text","text":"are taken, by universal consent, from the Kur-án, and from the language [both verse and prose (Kull p. 348)] of those Arabs who lived before the period of the corruption [in any considerable degree] of the Arabic tongue: [see"},{"kind":"arabic","text_bw":"muwal~adN","text_ar":"مُوَلَّدٌ"},{"kind":"text","text":":] also, accord. to the general decision of the learned, from the Traditions of Mohammad; [which last source is excluded by some because traditions may be corrupted in language by their transmitters, and interpolated, and even forged;] and electively from the language of those Arabs who lived after the first corruption of the Arabic tongue, but before the corruption had become extensive. (Mz, 1st"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":"; and MF ubi suprà. [See, again,"},{"kind":"arabic","text_bw":"muwal~adN","text_ar":"مُوَلَّدٌ"},{"kind":"text","text":".]) The classes of the poets from whose poetry"},{"kind":"arabic","text_bw":"$wAhd","text_ar":"شواهد"},{"kind":"text","text":"are taken are the Pagan Arabs, the Mukhadrams, the Islámees, and the Muwelleds: [see"},{"kind":"arabic","text_bw":"jaAhiliY~N","text_ar":"جَاهِلِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muxaDoramN","text_ar":"مُخَضْرَمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_isolaAmiY~N","text_ar":"اـِسْلَامِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muwal~adN","text_ar":"مُوَلَّدٌ"},{"kind":"text","text":":] with respect to all the sciences above mentioned, they are taken from the poetry of the first, second, and third, classes; from that of the first and second by universal consent, and from that of the third electively: (MF ubi suprá:) but they are taken from the poetry of the fourth class with respect only to the sciences of"},{"kind":"arabic","text_bw":"AlmaEaAniY","text_ar":"المَعَانِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlbayaAn","text_ar":"البَيَان"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlbadiyE","text_ar":"البَدِيع"},{"kind":"text","text":". (Idem, and Kull p. 348.) [The age of the earliest existing classical poems (though some older fragments and couplets and single verses have been preserved) is only about a century before the birth of Mohammad: that of the latest, about a century after his death. (See the Preface to this work.)] ―         -b6-"},{"kind":"italic_en","text":"Knowing,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"and witnessing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beholding with his eye; a witness,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"an eyewitness;"},{"kind":"text","text":"(L, Msb;) as also ↓"},{"kind":"arabic","text_bw":"$ahiydN","text_ar":"شَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":": pl. of the former [or, as is said in the L in art."},{"kind":"arabic","text_bw":"mjd","text_ar":"مجد"},{"kind":"text","text":", of the former or of the latter,]"},{"kind":"arabic","text_bw":"A^a$ohaAdN","text_ar":"اَشْهَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ"},{"kind":"text","text":"; [but see what is said of these pls. in the first sentence of this paragraph;] and of the latter"},{"kind":"arabic","text_bw":"$uhadaA='u","text_ar":"شُهَدَا=ءُ"},{"kind":"text","text":". (Msb.) [See an ex. of ↓"},{"kind":"arabic","text_bw":"$ahiydN","text_ar":"شَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":"in this sense in a verse cited voce"},{"kind":"arabic","text_bw":"rab~N","text_ar":"رَبٌّ"},{"kind":"text","text":".] ―         -b7-  [Hence, in the present day, applied to"},{"kind":"italic_en","text":"A notary, who hears and writes and attests cases to be submitted for judgment in the court of a kádee."},{"kind":"text","text":"] ―         -b8-"},{"kind":"italic_en","text":"Present; a witness"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"one personally present;"},{"kind":"text","text":"(S, L, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"$ahiydN","text_ar":"شَهِيدٌ","orth_type":"arrow"},{"kind":"text","text":": (Msb:) pl. of the former"},{"kind":"arabic","text_bw":"$uh~adN","text_ar":"شُهَّدٌ"},{"kind":"text","text":"(S, L, K) [and"},{"kind":"arabic","text_bw":"A^a$ohaAdN","text_ar":"اَشْهَادٌ"},{"kind":"text","text":", as above,] and ↓"},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or this last is used as a pl. but is originally an inf. n. (S, L.) One says,"},{"kind":"arabic","text_bw":"Al$~aAhidu yaraY maA laA yaraY AlgaAy^ibu","text_ar":"الشَّاهِدُ يَرَى مَا لَا يَرَى الغَايِبُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"The present knows what the absent knows not."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"qawomN $uhuwdN","text_ar":"قَوْمٌ شُهُودٌ"},{"kind":"italic_en","text":"People,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persons, present."},{"kind":"text","text":"(S, A.) And"},{"kind":"arabic","text_bw":"kal~amotuhu EalaY ruw^uwsi AlA^a$ohaAdi","text_ar":"كَلَّمْتُهُ عَلَى رُوُوسِ الاَشْهَادِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I spoke to him before witnesses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persons present"},{"kind":"text","text":"]. (A.) ―         -b9-  [Hence, app., being opposed to"},{"kind":"arabic","text_bw":"gaAy^ibN","text_ar":"غَايِبٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"A running in which a horse exerts his force unsparingly;"},{"kind":"text","text":"(A, L;) as in the saying,"},{"kind":"arabic","text_bw":"lilofarasi gaAy^ibN wa$aAhidN","text_ar":"لِلْفَرَسِ غَايِبٌ وَشَاهِدٌ"},{"kind":"italic_en","text":"The horse has a run which he reserves"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for the time of need"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and a run which he performs unsparingly;"},{"kind":"text","text":"like the saying,"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"arabic","text_bw":"SawonN waba*olN","text_ar":"صَوْنٌ وَبَذْلٌ"},{"kind":"text","text":": (A: [see 1 in art."},{"kind":"arabic","text_bw":"b*l","text_ar":"بذل"},{"kind":"text","text":":]) or"},{"kind":"arabic","text_bw":"$aAhidN","text_ar":"شَاهِدٌ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"a running that testifies the excellence of a horse,"},{"kind":"text","text":"(IAar, K,)"},{"kind":"italic_en","text":"and his quality of outstripping others."},{"kind":"text","text":"(IAar, TA.) ―         -b10-"},{"kind":"italic_en","text":"A star"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"when visible"},{"kind":"text","text":"]; (Aboo-Eiyoob, K;) as being present and apparent in the night. (TA.) ―         -b11-  [Hence, accord. to some,]"},{"kind":"arabic","text_bw":"SalaApu Al$~aAhidi","text_ar":"صَلَاةُ الشَّاهِدِ"},{"kind":"italic_en","text":"The prayer of sunset;"},{"kind":"text","text":"(A, L, Msb, K;) because it is"},{"kind":"italic_en","text":"the prayer that is performed when the star becomes visible;"},{"kind":"text","text":"(Sh, L;) also called"},{"kind":"arabic","text_bw":"SalaApu AlbaSari","text_ar":"صَلَاةُ البَصَرِ"},{"kind":"text","text":", because the stars are seen at the time thereof: or, accord. to some,"},{"kind":"italic_en","text":"the prayer of daybreak;"},{"kind":"text","text":"(L;) [and so, accord. to some,"},{"kind":"arabic","text_bw":"SalaApu AlbaSari","text_ar":"صَلَاةُ البَصَرِ"},{"kind":"text","text":"; (see art."},{"kind":"arabic","text_bw":"bSr","text_ar":"بصر"},{"kind":"text","text":";)] as also ↓"},{"kind":"arabic","text_bw":"Alma$ohuwdu","text_ar":"المَشْهُودُ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and it is said to be so called because he who is travelling must perform it without abridging it, like him who is present at his home: Aboo-Sa'eed Ed-Dareer says that the former prayer is so called for this reason [as is also said in the A and Msb]: AM asserts that the first reason assigned above is the right one, because the prayer of daybreak, in like manner, may not be abridged, and is not thus called; but it is thus called by a poet. (L.) ―         -b12-  And"},{"kind":"arabic","text_bw":"Al$~aAhidu","text_ar":"الشَّاهِدُ"},{"kind":"text","text":"is a name of"},{"kind":"italic_en","text":"Friday;"},{"kind":"text","text":"(Fr, K;) as also ↓"},{"kind":"arabic","text_bw":"Alma$ohuwdu","text_ar":"المَشْهُودُ","orth_type":"arrow"},{"kind":"text","text":": or the latter is"},{"kind":"italic_en","text":"the day of resurrection:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"the day of 'Arafeh:"},{"kind":"text","text":"(Fr, K: [see"},{"kind":"arabic","text_bw":"Earafapu","text_ar":"عَرَفَةُ"},{"kind":"text","text":":]) because of the presence and congregation of people on each of those days. (TA.) ―         -b13-"},{"kind":"arabic","text_bw":"$aAhidN","text_ar":"شَاهِدٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Matter resembling mucus, that comes forth with the fœtus:"},{"kind":"text","text":"(S, K:) pl."},{"kind":"arabic","text_bw":"$uhuwdN","text_ar":"شُهُودٌ"},{"kind":"text","text":": which latter, accord. to ISd, means the"},{"kind":"arabic","text_bw":"A^agoraAs","text_ar":"اَغْرَاس"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"girosN","text_ar":"غِرْسٌ"},{"kind":"text","text":", q. v.,]"},{"kind":"italic_en","text":"upon the head of a young camel at the time of its birth."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"$uhuwdN Aln~aAqapi","text_ar":"شُهُودٌ النَّاقَةِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The marks left by the blood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by the membrane that enclosed the fœtus, of the she-camel, in the place where she has brought forth."},{"kind":"text","text":"(S, K.) ―         -b14-  Also A"},{"kind":"italic_en","text":"quick,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"expeditious,"},{"kind":"text","text":"thing or affair. (K.)"}],"source_refs":["S","Mgh","L","K","ISd","TA","Akh","Sb","Msb","IAar"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B4%D8%A7%D9%87%D8%AF/","headword_ar":"شاهد","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=23328#94980d","body_html":"<span>الشاهد: هو في اللغة عبارة عن الحاضر، وفي اصطلاح القوم: عبارة عما كان حاضرًا في قلب الإنسان، وغلب عليه ذكره؛ فإن كان الغالب عليه العلم فهو شاهد العلم، وإن كان الغالب عليه الحق، فهو شاهد الحق.</span>"}]}}