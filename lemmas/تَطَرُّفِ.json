{"lemma":"تَطَرُّفِ","slug":"تَطَرُّفِ","root":"ط.ر.ف","root_slug":"ط-ر-ف","root_link":"/words/roots/ط-ر-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n26610"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B7%D9%8E%D8%B1%D9%8F%D9%91%D9%81%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be extreme"},{"pos":"verb","gloss":"to be radical"},{"pos":"noun","gloss":"verbal noun of تَطَرَّفَ (taṭarrafa) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Compare طَرَف (ṭaraf, “edge”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26610","headword_ar":"تطرّف","root":"Trf","body":[{"kind":"text","text":"[as quasi-pass. of 2 signifies"},{"kind":"italic_en","text":"It became pointed, tapering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slender at the extremity:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"*ubaAbu Als~ayofi","text_ar":"ذُبَابُ السَّيْفِ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"*b","text_ar":"ذب"},{"kind":"text","text":"]. ―         -b2-  [And]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"SaAra TarafFA","text_ar":"صَارَ طَرَفًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It became an extremity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a side;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in, an extremity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a side"},{"kind":"text","text":"]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"kaAna laA yataTar~afu mina Albawoli","text_ar":"كَانَ لَا يَتَطَرَّفُ مِنَ البَوْلِ"},{"kind":"text","text":", in a trad. respecting the punishment of the grave, means"},{"kind":"italic_en","text":"He used. not to go far aside from urine."},{"kind":"text","text":"(L, TA. *) ―         -b4-"},{"kind":"arabic","text_bw":"tTr~ft","text_ar":"تطرّفت"},{"kind":"text","text":"said of a she-camel: see 1, near the end. ―         -b5-  Said of the sun,"},{"kind":"italic_en","text":"It became near to setting."},{"kind":"text","text":"(TA.) ―         -b6-"},{"kind":"arabic","text_bw":"tTr~f EalaY Alqawomi","text_ar":"تطرّف عَلَى القَوْمِ"},{"kind":"italic_en","text":"He made a sudden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an unexpected, attack upon the territory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwellings, of the people."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"tTr~f Al$~aYo'a","text_ar":"تطرّف الشَّىْءَ"},{"kind":"italic_en","text":"He took from the side of the thing:"},{"kind":"text","text":"[and]"},{"kind":"italic_en","text":"he took the side of it."},{"kind":"text","text":"(MA.) ―         -b2-  See also 2, last signification but one."}],"source_refs":[]}]},"classical_definitions":null}