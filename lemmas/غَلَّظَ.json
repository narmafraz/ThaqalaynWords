ition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32255","headword_ar":"غَلُظَ","root":"glZ","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S, Mgh, O, Msb, K;) and"},{"kind":"arabic","text_bw":"galaZa","text_ar":"غَلَظَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Sgh, K;) inf. n. [of the former]"},{"kind":"arabic","text_bw":"gilaZN","text_ar":"غِلَظٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and ↓"},{"kind":"arabic","text_bw":"gilaAZapN","text_ar":"غِلَاظَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"giloZapN","text_ar":"غِلْظَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, * O, K, * TK) and ↓"},{"kind":"arabic","text_bw":"guloZapN","text_ar":"غُلْظَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"galoZapN","text_ar":"غَلْظَةٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K, * TK,) all are inf. ns. of"},{"kind":"arabic","text_bw":"galuZa","text_ar":"غَلُظَ"},{"kind":"text","text":", (O,) or the last three, the second and third of which are mentioned in the Bári', on the authority of IAar, are simple substs.; (Msb;) and perhaps"},{"kind":"arabic","text_bw":"galoZN","text_ar":"غَلْظٌ"},{"kind":"text","text":"may be an inf. n. [of the latter verb]; (ISd, TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thick, gross, big, bulky,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse;"},{"kind":"text","text":"(Mgh, Msb, K;)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became"},{"kind":"arabic","text_bw":"gl~iyZ","text_ar":"غلِّيظ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"AstglZ","text_ar":"استغلظ","orth_type":"arrow"},{"kind":"text","text":". (S.) You say,"},{"kind":"arabic","text_bw":"galuZa jisomuhu","text_ar":"غَلُظَ جِسْمُهُ"},{"kind":"italic_en","text":"His body was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thick,"},{"kind":"text","text":"&c. (Mgh.) And"},{"kind":"arabic","text_bw":"Alz~aroEu","text_ar":"الزَّرْعُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstglZ","text_ar":"استغلظ","orth_type":"arrow"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"galuZa","text_ar":"غَلُظَ"},{"kind":"text","text":", (Jel in xlviii. 29,)"},{"kind":"italic_en","text":"The seed-produce became thick:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"strong:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"well grown and thick:"},{"kind":"text","text":"and in like manner one says of any plant or tree: (TA:) and"},{"kind":"arabic","text_bw":"galuZati Als~unobulapu","text_ar":"غَلُظَتِ السُّنْبُلَةُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AstglZt","text_ar":"استغلظت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"the ear of corn produced grain."},{"kind":"text","text":"(K.) [And"},{"kind":"arabic","text_bw":"galoZa","text_ar":"غَلْظَ"},{"kind":"arabic","text_bw":"Alv~awobu","text_ar":"الثَّوْبُ"},{"kind":"italic_en","text":"The garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, was thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coarse."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"galuZati AlA^aroDu","text_ar":"غَلُظَتِ الاَرْضُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"gilaZN","text_ar":"غِلَظٌ"},{"kind":"text","text":", and perhaps"},{"kind":"arabic","text_bw":"galoZN","text_ar":"غَلْظٌ"},{"kind":"text","text":"may be also an inf. n. [of this verb, or, more probably, of"},{"kind":"arabic","text_bw":"galaZat","text_ar":"غَلَظَت"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"The land was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rugged."},{"kind":"text","text":"(ISd. TA.) [In this sense, also,"},{"kind":"arabic","text_bw":"galuZa","text_ar":"غَلُظَ"},{"kind":"text","text":"is used in relation to various things.] ―         -b2-  [Said of a colour,"},{"kind":"italic_en","text":"It was dense,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deep:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"galiyZN","text_ar":"غَلِيظٌ"},{"kind":"text","text":".] ―         -b3-  Also (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, characterized by"},{"kind":"arabic","text_bw":"giloZap","text_ar":"غِلْظَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"the contr. of"},{"kind":"arabic","text_bw":"riq~ap","text_ar":"رِقَّة"},{"kind":"text","text":","},{"kind":"italic_en","text":"in manners, disposition, action"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conduct, speech, life,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(TA;) i. e.,"},{"kind":"italic_en","text":"rough; coarse; rude; unkind; hard; churlish; uncivil; surly; hard to deal with; incompliant; unobsequious; evil in disposition; illnatured;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"(S, by its explanation of"},{"kind":"arabic","text_bw":"giloZapN","text_ar":"غِلْظَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gilaAZapN","text_ar":"غِلَاظَةٌ"},{"kind":"text","text":"; and Msb: *) and in like manner, [as meaning"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"galiyZN","text_ar":"غَلِيظٌ"},{"kind":"text","text":",)] it is said of an affair: (TA:) and ↓"},{"kind":"arabic","text_bw":"tgl~Z","text_ar":"تغلّظ","orth_type":"arrow"},{"kind":"text","text":"is said of a crime; meaning"},{"kind":"italic_en","text":"it was gross,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"great;"},{"kind":"text","text":"but this is accord. to analogy only; not on the authority of hearsay. (Mgh.) It is said in the Kur [ix. 74, and lxvi. 9],"},{"kind":"arabic","text_bw":"wA@goluZo Ealayohimo","text_ar":"وا@غْلُظْ عَلَيْهِمْ"},{"kind":"italic_en","text":"And use thou roughness towards them:"},{"kind":"text","text":"(Bd in lxvi. 9:) and some read"},{"kind":"arabic","text_bw":"waA@goliZo","text_ar":"وَا@غْلِظْ"},{"kind":"text","text":", with kesr to the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":". (TA.) [See also"},{"kind":"arabic","text_bw":"giloZapN","text_ar":"غِلْظَةٌ"},{"kind":"text","text":", below.]"}],"source_refs":["S","Mgh","O","Msb","K","Bd","TA"]},{"entry_id":"n32260","headword_ar":"غَلْظٌ","root":"glZ","body":[{"kind":"italic_en","text":"Rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rugged, land"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground;"},{"kind":"text","text":"(ISd, K;) mentioned on the authority of Ibn-'Abbád; and by AHn, on the authority of En-Nadr; but it has been repudiated: and is said to be correctly ↓"},{"kind":"arabic","text_bw":"gilaZN","text_ar":"غِلَظٌ","orth_type":"arrow"},{"kind":"text","text":": ISd says, of the former word, “ I know not whether it be [properly] syn. with"},{"kind":"arabic","text_bw":"galiyZN","text_ar":"غَلِيظٌ"},{"kind":"text","text":", or whether it be an inf. n. used as an epithet: ” accord. to Kr, it signifies"},{"kind":"italic_en","text":"hard land without stones:"},{"kind":"text","text":"Ks says that"},{"kind":"arabic","text_bw":"galoZN","text_ar":"غَلْظٌ"},{"kind":"text","text":"is syn. with ↓"},{"kind":"arabic","text_bw":"gilaZN","text_ar":"غِلَظٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":[]},{"entry_id":"n32261","headword_ar":"غِلَظٌ","root":"glZ","body":[{"kind":"text","text":": [see 1: ―         -b2-  and] see"},{"kind":"arabic","text_bw":"galoZN","text_ar":"غَلْظٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}