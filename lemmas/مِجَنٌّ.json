ile to him after reconciliation."}, {"kind": "text", "text": "(Har p. 265.) ―         -b2-  Also"}, {"kind": "italic_en", "text": "A"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "woman's ornament such as is commonly called"}, {"kind": "text", "text": "]"}, {"kind": "arabic", "text_bw": "wi$aAH", "text_ar": "وِشَاح"}, {"kind": "text", "text": "(Az, K.)"}], "source_refs": ["Lh", "K"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}