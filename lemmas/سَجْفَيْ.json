{"lemma":"سَجْفَيْ","slug":"سَجْفَيْ","root":"س.ج.ف","root_slug":"س-ج-ف","root_link":"/words/roots/س-ج-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n18965","n18966","n18967"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%AC%D9%92%D9%81%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18965","headword_ar":"سَجْفٌ","root":"sjf","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n18966","headword_ar":"سِجْفٌ","root":"sjf","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"sajofN","text_ar":"سَجْفٌ","orth_type":"arrow"},{"kind":"text","text":"[of which the former is the more common]"},{"kind":"italic_en","text":"A curtain; a veil;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thing that veils, conceals, hides, covers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protects;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"sijaAfN","text_ar":"سِجَافٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sijaAfapN","text_ar":"سِجَافَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"a pair of curtains having an opening between them:"},{"kind":"text","text":"(IDrd, K:) or"},{"kind":"italic_en","text":"each half of a pair of curtains,"},{"kind":"text","text":"(Lth, K, TA,)"},{"kind":"italic_en","text":"divided in the midst,"},{"kind":"text","text":"(Lth, TA,)"},{"kind":"italic_en","text":"by which any door,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"entrance, is veiled;"},{"kind":"text","text":"(Lth, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"sijaAfN","text_ar":"سِجَافٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) this last is not a pl. of"},{"kind":"arabic","text_bw":"sijofN","text_ar":"سِجْفٌ"},{"kind":"text","text":": (TA:) thus"},{"kind":"arabic","text_bw":"Als~ijofaAni","text_ar":"السِّجْفَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the two separate halves"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that hang side by side, so as to meet together,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the curtain"},{"kind":"text","text":"of a tent, (Lth, S, TA,) in the fore part thereof: (S:) so in a verse of En-Nábighah EdhDhubyánee cited in the second paragraph of art."},{"kind":"arabic","text_bw":"rfE","text_ar":"رفع"},{"kind":"text","text":": (S, TA:) the pl. of"},{"kind":"arabic","text_bw":"sijofN","text_ar":"سِجْفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sajofN","text_ar":"سَجْفٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^asojaAfN","text_ar":"اَسْجَافٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sujuwfN","text_ar":"سُجُوفٌ"},{"kind":"text","text":"; and the pl. of ↓"},{"kind":"arabic","text_bw":"sijaAfN","text_ar":"سِجَافٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"sujufN","text_ar":"سُجُفٌ"},{"kind":"text","text":". (TA.) [Hence] one says,"},{"kind":"arabic","text_bw":"A^aroxaY All~ayolu","text_ar":"اَرْخَى اللَّيْلُ"},{"kind":"arabic","text_bw":"sujuwfahu","text_ar":"سُجُوفَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The night let down its curtains."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"sijofN","text_ar":"سِجْفٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"part that is behind a door"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an entrance."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["TA","IDrd","K","Lth","S"]},{"entry_id":"n18967","headword_ar":"سَجَفٌ","root":"sjf","body":[{"kind":"italic_en","text":"Slenderness of the waist:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"lankness of the belly."},{"kind":"text","text":"(K.) One says"},{"kind":"arabic","text_bw":"fiY xaSorihi sajafN","text_ar":"فِى خَصْرِهِ سَجَفٌ"},{"kind":"italic_en","text":"In his waist is slenderness:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiY baTonihi sajafN","text_ar":"فِى بَطْنِهِ سَجَفٌ"},{"kind":"italic_en","text":"In his belly is lankness."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"sajifato","text_ar":"سَجِفَتْ"},{"kind":"text","text":", in the first paragraph.]"}],"source_refs":[]}]}}