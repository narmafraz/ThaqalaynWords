n":"m","num":"p"},{"role":"present_2mp","form":"تُخادِعُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُخادِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُخادِع","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُخادِع","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُخادِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخادِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخادِعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخادِعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخادِعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخادِعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخادِعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُخادِع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخادِع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خادَعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خادَعْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":3,"cross_references":{"qac":{"found":true,"lemma_key":"خادَعَ","root":"خدع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n10135"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D8%A7%D8%AF%D9%8E%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to seek to deceive","examples":[{"text":"يُخَـٰدِعُونَ ٱللَّهَ وَٱلَّذِينَ ءَامَنُوا۟ وَمَا يَخْدَعُونَ إِلَّآ أَنفُسَهُمْ وَمَا يَشْعُرُونَ","english":"They seek to deceive Allah and the believers, yet they only deceive themselves, but they fail to perceive it."}]},{"pos":"verb","gloss":"to fool repeatedly"},{"pos":"noun","gloss":"active participle of خَدَعَ (ḵadaʕa)","tags":["active","form-of","participle"]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of خَدَعَ (ḵadaʕa, “to deceive”)"},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10135","headword_ar":"خَادِعٌ","root":"xdE","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Deceiving, deluding, beguiling, circumventing, outwitting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"] act. part. n. of"},{"kind":"arabic","text_bw":"xadaEahu","text_ar":"خَدَعَهُ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"xaduwEN","text_ar":"خَدُوعٌ","orth_type":"arrow"},{"kind":"text","text":"; (Msb;) or [rather] this latter is an intensive epithet, signifying one"},{"kind":"italic_en","text":"who deceives,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very deceitful,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"a great deceiver,"},{"kind":"text","text":"&c.; (Mgh, K;) and ↓"},{"kind":"arabic","text_bw":"xad~aAEu","text_ar":"خَدَّاعُ","orth_type":"arrow"},{"kind":"text","text":", (Msb, TA,) and ↓"},{"kind":"arabic","text_bw":"xadiEN","text_ar":"خَدِعٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"xayodaEN","text_ar":"خَيْدَعٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) [but these three are also intensive epithets, like"},{"kind":"arabic","text_bw":"xaduwEN","text_ar":"خَدُوعٌ"},{"kind":"text","text":";] and ↓"},{"kind":"arabic","text_bw":"xudaEapN","text_ar":"خُدَعَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies one"},{"kind":"italic_en","text":"who deceives,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"other men;"},{"kind":"text","text":"(S;) or [rather] this last is syn. with"},{"kind":"arabic","text_bw":"xaduwEN","text_ar":"خَدُوعٌ"},{"kind":"text","text":"as explained above, (K,) or"},{"kind":"arabic","text_bw":"xad~aAEN","text_ar":"خَدَّاعٌ"},{"kind":"text","text":": (Mgh:) [the pl. of"},{"kind":"arabic","text_bw":"xaAdiEapN","text_ar":"خَادِعَةٌ"},{"kind":"text","text":", fem. of"},{"kind":"arabic","text_bw":"xaAdiEN","text_ar":"خَادِعٌ"},{"kind":"text","text":", is"},{"kind":"arabic","text_bw":"xawaAdiEu","text_ar":"خَوَادِعُ"},{"kind":"text","text":":] and the pl. of ↓"},{"kind":"arabic","text_bw":"xaduwEN","text_ar":"خَدُوعٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"xuduEN","text_ar":"خُدُعٌ"},{"kind":"text","text":". (Mgh.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Dab~N xAdiEN","text_ar":"ضَبٌّ خادِعٌ"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"lizard of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Db~","text_ar":"ضبّ"},{"kind":"italic_en","text":"that deceives, beguiles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumvents;"},{"kind":"text","text":"(Z, TA;) as also ↓"},{"kind":"arabic","text_bw":"xadiEN","text_ar":"خَدِعٌ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"dahorN xaAdiEN","text_ar":"دَهْرٌ خَادِعٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"xudaEapN","text_ar":"خُدَعَةٌ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Deceiving,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"varying,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"very deceitful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very variable, fortune,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time"},{"kind":"text","text":"]. (TA.) [Whence, or] because of its variableness, (TA,) ↓"},{"kind":"arabic","text_bw":"AlxudaEapu","text_ar":"الخُدَعَةُ","orth_type":"arrow"},{"kind":"text","text":"is (tropical:)  a name for"},{"kind":"italic_en","text":"Fortune,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time."},{"kind":"text","text":"(K, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"xaAdiEu Alr~aA^oYi","text_ar":"خَادِعُ الرَّاْىِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one remains not steadily in one opinion."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"xuluqN xaAdiEN","text_ar":"خُلُقٌ خَادِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A varying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"variable, disposition."},{"kind":"text","text":"(S, K, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"suwqN xaAdiEapN","text_ar":"سُوقٌ خَادِعَةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A market varying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"variable, in its state;"},{"kind":"text","text":"(S, A, O, K;)"},{"kind":"italic_en","text":"at one time being brisk, and at another time dull, in respect of traffic:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"a market dull in respect of traffic:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a market in which one cannot obtain a thing because of its dearness."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"xaAdiEN","text_ar":"خَادِعٌ"},{"kind":"text","text":"also signifies (tropical:)  Anything"},{"kind":"italic_en","text":"unsaleable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult of sale, and in little demand."},{"kind":"text","text":"(TA.) And accord. to Fr, the Benoo-Asad use the epithet ↓"},{"kind":"arabic","text_bw":"muxaAdiEu","text_ar":"مُخَادِعُ","orth_type":"arrow"},{"kind":"text","text":"[perhaps a mistake for"},{"kind":"arabic","text_bw":"xaAdiEN","text_ar":"خَادِعٌ"},{"kind":"text","text":"] in the sense of (tropical:)"},{"kind":"italic_en","text":"High,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dear,"},{"kind":"text","text":"applied to a price. (TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"TariyqN xaAdiEN","text_ar":"طَرِيقٌ خَادِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A road that appears at one time and disappears at another;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xaduwEN","text_ar":"خَدُوعٌ","orth_type":"arrow"},{"kind":"text","text":": (K:)"},{"kind":"italic_en","text":"a road which one does not know:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"a road deviating from the right course;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"xayodaEN","text_ar":"خَيْدَعٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, K, TA;)"},{"kind":"italic_en","text":"which one does not know."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"maA='N xaAdiEN","text_ar":"مَا=ءٌ خَادِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A water to which one does not know the way."},{"kind":"text","text":"(TA.) ―         -b8-  [Hence also,]"},{"kind":"arabic","text_bw":"sinuwna xawaAdiEu","text_ar":"سِنُونَ خَوَادِعُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Years in which is little good; bad years:"},{"kind":"text","text":"(Sh, TA:) and"},{"kind":"arabic","text_bw":"sinuwna","text_ar":"سِنُونَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xad~aAEapN","text_ar":"خَدَّاعَةٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  (tropical:)"},{"kind":"italic_en","text":"years in which is little increase:"},{"kind":"text","text":"(S, K, TA:) from"},{"kind":"arabic","text_bw":"xadaEa","text_ar":"خَدَعَ"},{"kind":"text","text":"said of rain, or of spittle; and therefore doubly tropical: (TA:) or, as some say,"},{"kind":"italic_en","text":"years in which is much rain, and in which the produce is little."},{"kind":"text","text":"(Sgh.)"},{"kind":"arabic","text_bw":"xaAdiEN","text_ar":"خَادِعٌ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"Corrupt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bad;"},{"kind":"text","text":"applied to food and other things. (TA.) And you say,"},{"kind":"arabic","text_bw":"diynaArN xaAdiEN","text_ar":"دِينَارٌ خَادِعٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective, deenár."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"rajulN xaAdiEN","text_ar":"رَجُلٌ خَادِعٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A man who brings evil upon others."},{"kind":"text","text":"(TA.)"}],"source_refs":["Msb","TA","K","Mgh","A","Sh","S"]}]},"classical_definitions":null}