{"lemma":"زَوَّجَ","slug":"زَوَّجَ","root":"ز.#.ج","root_slug":"ز-_-ج","root_link":"/words/roots/ز-_-ج","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"زَوَّجْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"زَوَّجْتِ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"زَوَّجْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"زَوَّجْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"زَوَّجْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"زَوَّجَ","in_corpus":true,"count":15,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"زَوَّجَت","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"زَوَّجا","in_corpus":true,"count":28,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"زَوَّجَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"زَوَّجُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"زَوَّجْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُزَوِّج","in_corpus":true,"count":86,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُزَوِّجِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُزَوِّجِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُزَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُزَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُزَوِّجُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُزَوِّجُوا","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُزَوِّجْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُزَوِّج","in_corpus":true,"count":16,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُزَوِّج","in_corpus":true,"count":86,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُزَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُزَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُزَوِّجانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُزَوِّجا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُزَوِّجُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُزَوِّجُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُزَوِّجْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُزَوِّج","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُزَوِّج","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"زَوَّجْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"زَوَّجْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":258,"cross_references":{"qac":{"found":true,"lemma_key":"زَوَّجَ","root":"زوج","pos":"N","occurrence_count":76},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n18362"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D9%88%D9%8E%D9%91%D8%AC%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"one of a pair"},{"pos":"noun","gloss":"spouse, mate, partner; husband","examples":[{"text":"قَدْ سَمِعَ ٱللَّٰهُ قَوْلَ ٱلَّتِي تُجَادِلُكَ فِي زَوْجِهَا وَتَشْتَكِي إِلَى ٱللَّٰهِ وَٱللَّٰهُ يَسْمَعُ تَحَاوُرَكُمَا إِنَّ ٱللَّٰهَ سَمِيعٌ بَصِيرٌ","english":"God has certainly heard the speech of her who pleads with you about her husband and complains to God. God hears the conversation between the two of you."}]},{"pos":"noun","gloss":"spouse, mate, partner; wife","tags":["feminine"],"examples":[{"text":"فَقُلْنَا يَا آدَمُ إِنَّ هَٰذَا عَدُوٌّ لَّكَ وَلِزَوْجِكَ فَلَا يُخْرِجَنَّكُمَا مِنَ ٱلْجَنَّةِ فَتَشْقَىٰ","english":"We said, “O Adam! This is indeed an enemy of yours and your mate’s. So do not let him expel you from paradise, or you will be miserable.”"}]},{"pos":"noun","gloss":"a pair or couple","examples":[{"text":"هُمَا زَوْجَانِ","english":"They two are a pair or couple."}]},{"pos":"noun","gloss":"kind, type","tags":["archaic"],"examples":[{"text":"إِذَا رُجَّتِ الْأَرْضُ رَجًّا وَبُسَّتِ الْجِبَالُ بَسًّا فَكَانَتْ هَبَاءً مُّنْبَثًّا وَكُنتُمْ أَزْوَاجًا ثَلَاثَةً فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ وَأَصْحَابُ الْمَشْأَمَةِ مَا أَصْحَابُ الْمَشْأَمَةِ وَالسَّابِقُونَ السَّابِقُونَ","english":"When the earth is shaken with convulsion / And the mountains are crushed, crumbling / And become dust dispersing / And ye become of three kinds: Then the companions of the right – what are the companions of the right? And the companions of the left – what are the companions of the left? And the forerunners, the forerunners!"}]},{"pos":"verb","gloss":"to marry off, to give in marriage","tags":["ditransitive"]},{"pos":"verb","gloss":"to pair, to couple, to join in pairs"},{"pos":"verb","gloss":"to double, to geminate"}]},"etymology":{"source":"wiktextract","text":"From Aramaic זוגא (zawgā, “yoke, pair”), from Ancient Greek ζεῦγος (zeûgos, “yoke”) which was used in Greek for the yoke of marriage – now it forms a root ز و ج (z w j).\n\nDenominal verb derived from زَوْج (zawj, “pair”)."},"ipa":["/zawd͡ʒ/","/zaw.wa.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18362","headword_ar":"زَوْجٌ","root":"zwj","body":[{"kind":"text","text":"primarily signifies"},{"kind":"italic_en","text":"A sort of thing of any kind"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that is one of a pair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a pair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"any two things paired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coupled together,"},{"kind":"text","text":"whether they be"},{"kind":"italic_en","text":"likes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contraries:"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"either one of such two things:"},{"kind":"text","text":"(Az, TA:) or, accord. to 'Alee Ibn- 'Eesà,"},{"kind":"italic_en","text":"a sort of thing"},{"kind":"text","text":"[absolutely]: (Mgh:) or"},{"kind":"italic_en","text":"a sort of thing having its like,"},{"kind":"text","text":"(El-Ghooree, Mgh, Msb,) as in the case of species; (Msb;) or"},{"kind":"italic_en","text":"having its contrary,"},{"kind":"text","text":"(El-Ghooree, Mgh, Msb,) as the moist and the dry, and the male and the female, and the night and the day, and the bitter and the sweet; (Msb;) though sometimes applied to"},{"kind":"italic_en","text":"any sort of thing;"},{"kind":"text","text":"and to"},{"kind":"italic_en","text":"a single thing:"},{"kind":"text","text":"(El-Ghooree, Mgh:) or it is applied to"},{"kind":"italic_en","text":"a single thing"},{"kind":"text","text":"only when"},{"kind":"italic_en","text":"having with it a thing of the same kind;"},{"kind":"text","text":"(Mgh, Msb;)"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"a pair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple, of such things:"},{"kind":"text","text":"(Mgh:) the pl. is"},{"kind":"arabic","text_bw":"A^azowaAji","text_ar":"اَزْوَاجِ"},{"kind":"text","text":": (TA:) you say"},{"kind":"arabic","text_bw":"zawojaAni mino HamaAmK","text_ar":"زَوْجَانِ مِنْ حَمَامٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zawojaA HamaAmK","text_ar":"زَوْجَا حَمَامٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A pair"},{"kind":"page_break","n":1267},{"kind":"italic_en","text":"of pigeons"},{"kind":"text","text":"]: (A:) and"},{"kind":"arabic","text_bw":"Ai$otarayotu zawojaY HamaAmK","text_ar":"اِشْتَرَيْتُ زَوْجَى حَمَامٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I bought a pair of pigeons"},{"kind":"text","text":"], meaning a male and a female: (S:) and"},{"kind":"arabic","text_bw":"zawojaA niEaAlK","text_ar":"زَوْجَا نِعَالٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A pair of sandals"},{"kind":"text","text":"]: (S, A:) and in like manner"},{"kind":"arabic","text_bw":"zawojayoni","text_ar":"زَوْجَيْنِ"},{"kind":"text","text":"is used in the Kur xi. 42 and xxiii. 28; (S;) meaning a male and a female: (Bd, Jel:) or, accord. to the M,"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"one of a pair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"a pair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple together:"},{"kind":"text","text":"(TA:) and in like manner says AO, (Mgh, Msb,) and IKt, and IF: (Msb:) and ISh says that it signifies"},{"kind":"italic_en","text":"two;"},{"kind":"text","text":"(Mgh;) and so says IDrd: (Msb:) so that you say,"},{"kind":"arabic","text_bw":"humaA zawojN","text_ar":"هُمَا زَوْجٌ"},{"kind":"text","text":"as well as"},{"kind":"arabic","text_bw":"humaA zawojaAni","text_ar":"هُمَا زَوْجَانِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"They two are a pair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple"},{"kind":"text","text":"]; (S, K, TA;) like as you say,"},{"kind":"arabic","text_bw":"humaA sawaA='N","text_ar":"هُمَا سَوَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"humaA siy~aAni","text_ar":"هُمَا سِيَّانِ"},{"kind":"text","text":": (S, TA:) and"},{"kind":"arabic","text_bw":"EinodiY zawoju niEaAlK","text_ar":"عِنْدِى زَوْجُ نِعَالٍ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I have"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"two"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sandals"},{"kind":"text","text":"]; and"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"four:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"zawoju HamaAmK","text_ar":"زَوْجُ حَمَامٍ"},{"kind":"text","text":"as meaning a male and a female [of pigeons] is a phrase which should not be used; one to which the vulgar are addicted: (TA:) IAmb says, the vulgar are wrong in thinking that"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"two;"},{"kind":"text","text":"for the Arabs used not to employ such a phrase as"},{"kind":"arabic","text_bw":"zawoju HamaAmK","text_ar":"زَوْجُ حَمَامٍ"},{"kind":"text","text":", but used to say"},{"kind":"arabic","text_bw":"zawojaAni mina AlHamaAmi","text_ar":"زَوْجَانِ مِنَ الحَمَامِ"},{"kind":"text","text":", (Mgh, Msb, TA,) meaning a male and a female; (TA;) and"},{"kind":"arabic","text_bw":"zawojaAni mina AlxifaAfi","text_ar":"زَوْجَانِ مِنَ الخِفَافِ"},{"kind":"text","text":", (Mgh, Msb, TA,) meaning the right and the left [of boots]: (TA:) nor did they apply the term"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"to"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"of birds, like as they applied the dual,"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":", to"},{"kind":"italic_en","text":"two;"},{"kind":"text","text":"but they applied the term"},{"kind":"arabic","text_bw":"farodN","text_ar":"فَرْدٌ"},{"kind":"text","text":"to the male, and"},{"kind":"arabic","text_bw":"farodapN","text_ar":"فَرْدَةٌ"},{"kind":"text","text":"to the female: (Mgh, Msb:) Es-Sijistánee, also, says that the term"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"should not be applied to"},{"kind":"italic_en","text":"two,"},{"kind":"text","text":"neither of birds nor of other things, for this is a usage of the ignorant; but to every two,"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":": (Msb:) Az says that the grammarians disapprove the saying of ISh that"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"two"},{"kind":"text","text":"of any things, (Mgh, * TA,) and that"},{"kind":"arabic","text_bw":"zawojaAni mino xifaAfK","text_ar":"زَوْجَانِ مِنْ خِفَافٍ"},{"kind":"text","text":"signifies ["},{"kind":"italic_en","text":"Two pairs of boots,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"four"},{"kind":"text","text":"["},{"kind":"italic_en","text":"boots"},{"kind":"text","text":"]; for"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"with them signifies"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a pair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple"},{"kind":"text","text":"]: a man and his wife [together] are termed"},{"kind":"arabic","text_bw":"zawojaAni","text_ar":"زَوْجَانِ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"vamaAniyapa A^azowaAjK","text_ar":"ثَمَانِيَةَ اَزْوَاجٍ"},{"kind":"text","text":"in the Kur [vi. 144 and xxxix. 8] means"},{"kind":"italic_en","text":"Eight ones"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of pairs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couples"},{"kind":"text","text":"]: the primary meaning of"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"being that first mentioned in this paragraph; (TA:) in the Kur xxii. 5 and 1. 7 [it seems to be implied that it means"},{"kind":"italic_en","text":"pair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"couple;"},{"kind":"text","text":"but more probably in these instances] it means"},{"kind":"italic_en","text":"sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species:"},{"kind":"text","text":"(Bd, Jel:) it is also expl. by the word"},{"kind":"arabic","text_bw":"lawonN","text_ar":"لَوْنٌ"},{"kind":"text","text":"[used in this last sense]: (T, TA;) in the Kur xxxviii. 58, its pl."},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"A^alowaAnN","text_ar":"اَلْوَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^anowaAEN","text_ar":"اَنْوَاعٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"sorts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species"},{"kind":"text","text":"] of punishment: F explains the sing. as meaning"},{"kind":"arabic","text_bw":"lawonN mina Ald~iybaAji wanaHowihi","text_ar":"لَوْنٌ مِنَ الدِّيبَاجِ وَنَحْوِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species, of silk brocade and the like"},{"kind":"text","text":"]; but his restricting the signification by the words"},{"kind":"arabic","text_bw":"mn AldybAj wnHwh","text_ar":"من الديباج ونحوه"},{"kind":"text","text":"is not right, as is shown by a citation, in the T, of a verse of El-Aashà, in which he uses the phrase"},{"kind":"arabic","text_bw":"kul~u zawojK mina Ald~iybaAji","text_ar":"كُلُّ زَوْجٍ مِنَ الدِّيبَاجِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"every sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species, of silk brocade"},{"kind":"text","text":"], as an ex. of"},{"kind":"arabic","text_bw":"zwj","text_ar":"زوج"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"lwn","text_ar":"لون"},{"kind":"text","text":". (TA.) ―         -b2-  [Hence,] A woman's"},{"kind":"italic_en","text":"husband:"},{"kind":"text","text":"and a man's"},{"kind":"italic_en","text":"wife:"},{"kind":"text","text":"in which latter sense ↓"},{"kind":"arabic","text_bw":"zawojapN","text_ar":"زَوْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"is also used; (S, M, A, Mgh, * Msb, K; *) as in a verse of El-Farezdak cited in art"},{"kind":"arabic","text_bw":"bwl","text_ar":"بول"},{"kind":"text","text":", conj. 10; (S, Mgh;) but it is disallowed by As; (TA;) and the former word is the one of high authority, (Mgh, Msb,) and is that which occurs in the Kur, in ii. 33 and vii. 18, (S, Mgh, Msb, TA,) and in iv. 24, (Mgh, TA,) and in xxxiii. 37: (Mgh:) AHát says that the people of Nejd call a wife ↓"},{"kind":"arabic","text_bw":"zawojapN","text_ar":"زَوْجَةٌ","orth_type":"arrow"},{"kind":"text","text":", and that the people of the Haram use this word: but ISk says that the people of El-Hijáz call a wife"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"; and the rest of the Arabs, ↓"},{"kind":"arabic","text_bw":"zawojapN","text_ar":"زَوْجَةٌ","orth_type":"arrow"},{"kind":"text","text":": the lawyers use this latter word only, as applied to a wife, for the sake of perspicuity, fearing to confound the male with the female: (Msb:) the pl. of"},{"kind":"arabic","text_bw":"zawojN","text_ar":"زَوْجٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":"(Msb, K *) and"},{"kind":"arabic","text_bw":"ziwajapN","text_ar":"زِوَجَةٌ"},{"kind":"text","text":"; (K;) and the pl. of ↓"},{"kind":"arabic","text_bw":"zawojapN","text_ar":"زَوْجَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"zawojaAtN","text_ar":"زَوْجَاتٌ"},{"kind":"text","text":"(A, Mgh, Msb) and"},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":"also; (A, Msb;) and"},{"kind":"arabic","text_bw":"A^azaAwiyju","text_ar":"اَزَاوِيجُ"},{"kind":"text","text":"occurs [as a pl. pl., i. e. pl. of"},{"kind":"arabic","text_bw":"A^azowaAju","text_ar":"اَزْوَاجُ"},{"kind":"text","text":",] in a verse cited by ISk. (TA in art."},{"kind":"arabic","text_bw":"nA^j","text_ar":"ناج"},{"kind":"text","text":".) ―         -b3-  [Hence also,]"},{"kind":"italic_en","text":"A consociate, an associate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a comrade:"},{"kind":"text","text":"(A:) its pl. in this sense is"},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":", (S, A, K,) occurring in the Kur xxxvii. 22. (S, A.) ―         -b4-  And"},{"kind":"italic_en","text":"A fellow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"like:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":": in this sense, each one of a pair of boots is the"},{"kind":"arabic","text_bw":"zwj","text_ar":"زوج"},{"kind":"text","text":"of the other; and the husband is the"},{"kind":"arabic","text_bw":"zwj","text_ar":"زوج"},{"kind":"text","text":"of the wife; and the wife, the"},{"kind":"arabic","text_bw":"zwj","text_ar":"زوج"},{"kind":"text","text":"of the husband. (TA.) You say,"},{"kind":"arabic","text_bw":"EinodiY mino h`*aA A^azowaAjN","text_ar":"عِنْدِى مِنْ هٰذَا اَزْوَاجٌ"},{"kind":"italic_en","text":"I have, of this, fellows,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"likes."},{"kind":"text","text":"(TA.) ―         -b5-  As used by arithmeticians, (Mgh, Msb,)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"farodN","text_ar":"فَرْدٌ"},{"kind":"text","text":"; (S, Mgh, Msb, K;) i. e. it signifies"},{"kind":"italic_en","text":"An even number; a number that may be divided into two equal numbers;"},{"kind":"text","text":"(Msb;) as, for instance, four, and eight, as opposed to three, and seven: (Mgh:) pl."},{"kind":"arabic","text_bw":"A^azowaAjN","text_ar":"اَزْوَاجٌ"},{"kind":"text","text":". (S, Mgh.) One says"},{"kind":"arabic","text_bw":"zawojN A^awo farodN","text_ar":"زَوْجٌ اَوْ فَرْدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Even or odd?"},{"kind":"text","text":"], like as one says"},{"kind":"arabic","text_bw":"xasFA A^awo zakFA","text_ar":"خَسًا اَوْ زَكًا"},{"kind":"text","text":"[or rather"},{"kind":"arabic","text_bw":"zakFA A^awo xasFA","text_ar":"زَكًا اَوْ خَسًا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"$afoEN A^awo witorN","text_ar":"شَفْعٌ اَوْ وِتْرٌ"},{"kind":"text","text":". (S, Mgh.) ―         -b6-  Also"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of cloth such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"namaT","text_ar":"نَمَط"},{"kind":"text","text":"[q. v.]: or"},{"kind":"italic_en","text":"silk brocade;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"diybaAjN","text_ar":"دِيبَاجٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"namaT","text_ar":"نَمَط"},{"kind":"italic_en","text":"that is thrown over the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"kind of vehicle called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"hawodaj","text_ar":"هَوْدَج"},{"kind":"text","text":". (S, K, TA.)"}],"source_refs":["Az","TA","Mgh","A","S","Bd","Jel","Msb","K"]}]}}