uwaAliq","text_ar":"جُوَالِق"},{"kind":"text","text":". (K.)       -A5-  And"},{"kind":"arabic","text_bw":"Algaforu","text_ar":"الغَفْرُ"},{"kind":"text","text":"is the name of"},{"kind":"italic_en","text":"The star"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"λ","text_ar":"λ","orth_type":"plain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in the left foot of Virgo:"},{"kind":"text","text":"(Kzw in his Descr. of Virgo:) or"},{"kind":"italic_en","text":"three obscure stars,"},{"kind":"text","text":"(Kzw in his Descr. of the Mansions of the Moon,) or"},{"kind":"italic_en","text":"three small stars,"},{"kind":"text","text":"(S, K,) [most probably, I think, (not"},{"kind":"arabic","text_bw":"φ","text_ar":"φ","orth_type":"plain"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ι","text_ar":"ι","orth_type":"plain"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"κ","text_ar":"κ","orth_type":"plain"},{"kind":"text","text":", as supposed by Freytag, who refers to Ideler's “ Untersuch. ” pp. 169 and 288, but)"},{"kind":"arabic","text_bw":"ι","text_ar":"ι","orth_type":"plain"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"κ","text_ar":"κ","orth_type":"plain"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"λ","text_ar":"λ","orth_type":"plain"},{"kind":"italic_en","text":"of Virgo,"},{"kind":"text","text":"though said to be]"},{"kind":"italic_en","text":"belonging to Libra:"},{"kind":"text","text":"(S:)"},{"kind":"italic_en","text":"one of the Mansions of the Moon,"},{"kind":"text","text":"(S, K,) namely,"},{"kind":"italic_en","text":"the Fifteenth."},{"kind":"text","text":"(Kzw in his Descr. of the Mansions.)"}],"source_refs":["S","K"]},{"entry_id":"n32102","headword_ar":"غُفْرٌ","root":"gfr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"young of the mountain-goat;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"gaforN","text_ar":"غَفْرٌ","orth_type":"arrow"},{"kind":"text","text":"; but the former is the more common; (K;) the latter, rare: (TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^agofaArN","text_ar":"اَغْفَارٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"gifarapN","text_ar":"غِفَرَةٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"gufuwrN","text_ar":"غُفُورٌ"},{"kind":"text","text":": (Kr, K:) the"},{"kind":"italic_en","text":"female"},{"kind":"text","text":"is termed"},{"kind":"arabic","text_bw":"guforapN","text_ar":"غُفْرَةٌ"},{"kind":"text","text":": and it is said that"},{"kind":"arabic","text_bw":"guforN","text_ar":"غُفْرٌ"},{"kind":"text","text":"is an appellation of"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"and of"},{"kind":"italic_en","text":"a pl. number:"},{"kind":"text","text":"the"},{"kind":"page_break","n":2274},{"kind":"text","text":"phrase"},{"kind":"arabic","text_bw":"guforN kaviyrN","text_ar":"غُفْرٌ كَثِيرٌ"},{"kind":"text","text":"is mentioned [as meaning"},{"kind":"italic_en","text":"many young ones of the mountain-goat"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["TA","S","K","Kr"]},{"entry_id":"n32103","headword_ar":"غِفْرٌ","root":"gfr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"young of the cow"},{"kind":"text","text":"[probably meaning"},{"kind":"italic_en","text":"of the bovine antelope called the wild cow"},{"kind":"text","text":"]. (ElHejeree, K.) ―         -b2-  And"},{"kind":"italic_en","text":"A certain"},{"kind":"arabic","text_bw":"duwayob~ap","text_ar":"دُوَيْبَّة"},{"kind":"text","text":"[by which may be meant a"},{"kind":"italic_en","text":"small beast"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"creeping thing,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"insect"},{"kind":"text","text":"]: (IDrd, O, K:) so, says IDrd, they assert. (O.)"}],"source_refs":["IDrd","O","K"]},{"entry_id":"n32104","headword_ar":"غَفَرٌ","root":"gfr","body":[{"kind":"text","text":"(S, K, TA) and ↓"},{"kind":"arabic","text_bw":"gaforN","text_ar":"غَفْرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, TA) and ↓"},{"kind":"arabic","text_bw":"gufaArN","text_ar":"غُفَارٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"Hair like down, such as is upon the shank of a woman,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"upon the forehead,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like thereof:"},{"kind":"text","text":"(S, TA:) or the"},{"kind":"italic_en","text":"hair of the neck,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the jaws,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the back of the neck;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"gafiyrN","text_ar":"غَفِيرٌ","orth_type":"arrow"},{"kind":"text","text":"accord. to the copies of the K, but accord. to the L and other lexicons"},{"kind":"arabic","text_bw":"gaforN","text_ar":"غَفْرٌ"},{"kind":"text","text":": and the"},{"kind":"italic_en","text":"small, short, hairs"},{"kind":"text","text":"of the body. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"gafarN","text_ar":"غَفَرٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"growth of hair in the place of the mane"},{"kind":"text","text":"of a horse or similar beast. (TA.) ―         -b3-  And The"},{"kind":"italic_en","text":"nap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"villous substance, upon the surface of a garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth,"},{"kind":"text","text":"(S, K, TA,) and"},{"kind":"italic_en","text":"the like thereof;"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"gaforN","text_ar":"غَفْرٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (K, TA:) n. un."},{"kind":"arabic","text_bw":"gaforapN","text_ar":"غَفْرَةٌ"},{"kind":"text","text":"[and app."},{"kind":"arabic","text_bw":"gafarapN","text_ar":"غَفَرَةٌ"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"gafarN","text_ar":"غَفَرٌ"},{"kind":"text","text":"is also expl. as signifying the"},{"kind":"arabic","text_bw":"hudob","text_ar":"هُدْب"},{"kind":"text","text":"[app. here meaning likewise"},{"kind":"italic_en","text":"nap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pile,"},{"kind":"text","text":"or perhaps the"},{"kind":"italic_en","text":"unwoven end,"},{"kind":"text","text":"] of a garment, or piece of cloth, and [particularly] of the thin and soft sorts of what are termed"},{"kind":"arabic","text_bw":"xamaAy^iS","text_ar":"خَمَايِص"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quTuf","text_ar":"قُطُف"},{"kind":"text","text":"[pls. of"},{"kind":"arabic","text_bw":"xamiySapN","text_ar":"خَمِيصَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaTiyfapN","text_ar":"قَطِيفَةٌ"},{"kind":"text","text":"]; but not the extremities of"},{"kind":"arabic","text_bw":"A^arodiyap","text_ar":"اَرْدِيَة"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"malaAHif","text_ar":"مَلَاحِف"},{"kind":"text","text":"[pls. of"},{"kind":"arabic","text_bw":"ridaA='N","text_ar":"رِدَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"miloHafapN","text_ar":"مِلْحَفَةٌ"},{"kind":"text","text":"]. (TA.) ―         -b4-  And"},{"kind":"italic_en","text":"Small herbage;"},{"kind":"text","text":"(K:) [or]"},{"kind":"italic_en","text":"a sort of small, sprouting herbage, of the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":","},{"kind":"italic_en","text":"growing in plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, land, and upon the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"eminences termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A=kAm","text_ar":"ا=كام"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"A^akamapN","text_ar":"اَكَمَةٌ"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"when green, resembling green passerine birds standing; and when it has dried up, resembling such as are red, not standing."},{"kind":"text","text":"(L, TA. *)"}],"source_refs":["S","K","TA"]}]}}