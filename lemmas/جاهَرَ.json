translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to speak aloud"},{"pos":"verb","gloss":"to express"},{"pos":"verb","gloss":"to make known"}]},"etymology":null,"ipa":["/d͡ʒaː.ha.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6526","headword_ar":"جاهر","root":"jhr","body":[{"kind":"text","text":": see 1. ―         -b2-  [Its inf. n.]"},{"kind":"arabic","text_bw":"mujaAharapN","text_ar":"مُجَاهَرَةٌ"},{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"fighting"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with any one"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"face to face:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"showing open enmity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hostility, with any one:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"reading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reciting, a thing aloud:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"speaking loudly."},{"kind":"text","text":"(KL.) You say,"},{"kind":"arabic","text_bw":"jAhr biAlEadaAwapi","text_ar":"جاهر بِالعَدَاوَةِ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"mujaAharapN","text_ar":"مُجَاهَرَةٌ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"jihaArN","text_ar":"جِهَارٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He showed open enmity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hostility, with another."},{"kind":"text","text":"(S, * Msb.) And"},{"kind":"arabic","text_bw":"jaAharotuhumo biAlA^amori","text_ar":"جَاهَرْتُهُمْ بِالاَمْرِ"},{"kind":"italic_en","text":"I acted openly with them in the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EaAlanotuhumo bihi","text_ar":"عَالَنْتُهُمْ بِهِ"},{"kind":"text","text":". (JK.) [And"},{"kind":"arabic","text_bw":"jAhrhu","text_ar":"جاهرهُ"},{"kind":"italic_en","text":"He treated him openly"},{"kind":"text","text":"with enmity &c.] ―         -b3-"},{"kind":"arabic","text_bw":"jaAharahumo biAlA^amori","text_ar":"جَاهَرَهُمْ بِالاَمْرِ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"mujaAharapN","text_ar":"مُجَاهَرَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jihaArN","text_ar":"جِهَارٌ"},{"kind":"text","text":", (K,) [is explained as signifying]"},{"kind":"italic_en","text":"He vied with them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strove to overcome"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surpass them, in the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case."},{"kind":"text","text":"(K, * TA.) [But"},{"kind":"arabic","text_bw":"gAlbhm","text_ar":"غالبهم"},{"kind":"text","text":", in the TA, and"},{"kind":"arabic","text_bw":"AlmugaAlabapu","text_ar":"المُغَالَبَةُ"},{"kind":"text","text":", in the K, are here evidently mistranscriptions for"},{"kind":"arabic","text_bw":"EaAlanahumo","text_ar":"عَالَنَهُمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlmuEaAlanapu","text_ar":"المُعَالَنَةُ"},{"kind":"text","text":".]"}],"source_refs":["Msb","S","TA","K"]}]},"classical_definitions":null}