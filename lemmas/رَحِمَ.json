present_2mp","form":"تَرْحَمُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْحَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْحَم","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْحَم","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْحَما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْحَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْحَما","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْحَمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْحَمُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْحَمُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْحَمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَرْحَم","in_corpus":true,"count":40,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْحَم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"رَحِمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَحِمْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":111,"cross_references":{"qac":{"found":true,"lemma_key":"رَحِمَ","root":"رحم","pos":"V","occurrence_count":28},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n15081","n15082","n15083","n15084","n15085","n15086"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AD%D9%90%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to have mercy (upon), have compassion"},{"pos":"verb","gloss":"to spare, let off"},{"pos":"verb","gloss":"to save, relieve"},{"pos":"verb","gloss":"to be merciful"},{"pos":"verb","gloss":"to have mercy (upon)"},{"pos":"verb","gloss":"to ask God to have mercy (upon), to plead for God’s mercy"},{"pos":"noun","gloss":"uterus, womb","examples":[{"text":"هُوَ ٱلَّذِي يُصَوِّرُكُمۡ فِي ٱلۡأَرۡحَامِ كَيۡفَ يَشَاۤءُ","english":"He is the One Who causes you to take shape in the wombs, as He will cause to be"}]},{"pos":"noun","gloss":"relationship, kinship"},{"pos":"noun","gloss":"verbal noun of رَحِمَ (raḥima) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"mercy, commiseration","examples":[{"text":"أُمُّ رُحْمٍ","english":"Mecca"}]}]},"etymology":{"source":"wiktextract","text":"Cognate to Hebrew רחם (raḥam).\n\nRelated to Hebrew רֶחֶם (rékhem, “womb”). More at R-Ḥ-M."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15081","headword_ar":"رَحْمٌ","root":"rHm","body":[{"kind":"text","text":": see its syn."},{"kind":"arabic","text_bw":"raHimN","text_ar":"رَحِمٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n15082","headword_ar":"رُحْمٌ","root":"rHm","body":[{"kind":"text","text":": see its syn."},{"kind":"arabic","text_bw":"raHomapN","text_ar":"رَحْمَةٌ"},{"kind":"text","text":". ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"A^um~u ruHomK","text_ar":"اُمُّ رُحْمٍ"},{"kind":"text","text":"one of the names of"},{"kind":"italic_en","text":"Mekkeh;"},{"kind":"text","text":"(S, K; *) as also"},{"kind":"arabic","text_bw":"A^um~u Alr~uHomi","text_ar":"اُمُّ الرُّحْمِ"},{"kind":"text","text":"; (K;) meaning"},{"kind":"italic_en","text":"the source of"},{"kind":"arabic","text_bw":"Alr~aHomap","text_ar":"الرَّحْمَة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"or mercy,"},{"kind":"text","text":"&c.]. (TA.) [See also"},{"kind":"arabic","text_bw":"zuHomN","text_ar":"زُحْمٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n15083","headword_ar":"رِحْمٌ","root":"rHm","body":[{"kind":"text","text":": see its syn."},{"kind":"arabic","text_bw":"raHimN","text_ar":"رَحِمٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n15084","headword_ar":"رَحَمٌ","root":"rHm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"coming forth of the womb, in consequence of a disease."},{"kind":"text","text":"(IAar, TA.) [See also"},{"kind":"arabic","text_bw":"raHimato","text_ar":"رَحِمَتْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"raHima","text_ar":"رَحِمَ"},{"kind":"text","text":", of each of which it is an inf. n.]"}],"source_refs":[]},{"entry_id":"n15085","headword_ar":"رَحِمٌ","root":"rHm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"womb,"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"place of origin,"},{"kind":"text","text":"(Mgh, Msb, K,) and the"},{"kind":"italic_en","text":"receptacle,"},{"kind":"text","text":"(Mgh, K,)"},{"kind":"italic_en","text":"of the young,"},{"kind":"text","text":"(Mgh, Msb, K,)"},{"kind":"italic_en","text":"in the belly;"},{"kind":"text","text":"(Mgh;) as also ↓"},{"kind":"arabic","text_bw":"riHomN","text_ar":"رِحْمٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) a contraction of the former, and ↓"},{"kind":"arabic","text_bw":"raHomN","text_ar":"رَحْمٌ","orth_type":"arrow"},{"kind":"text","text":", which is of the dial. of Benoo-Kiláb: (Msb:) in this sense, (Msb,) which is the primary signification, (Mgh,) [i. e.] as meaning the"},{"kind":"arabic","text_bw":"raHim","text_ar":"رَحِم"},{"kind":"text","text":"of the female, (S,) it is fem.; (S, Msb;) or, as some say, masc.; (Msb;) but IB cites a verse in which"},{"kind":"arabic","text_bw":"riHom","text_ar":"رِحْم"},{"kind":"text","text":"is fem.: (TA:) pl."},{"kind":"arabic","text_bw":"A^aroHaAmN","text_ar":"اَرْحَامٌ"},{"kind":"text","text":". (MA.) ―         -b2-  Hence, (Mgh, Msb,) as also ↓"},{"kind":"arabic","text_bw":"riHomN","text_ar":"رِحْمٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"raHomN","text_ar":"رَحْمٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) (tropical:)"},{"kind":"italic_en","text":"Relationship;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"nearness of kin;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaraAbapN","text_ar":"قَرَابَةٌ"},{"kind":"text","text":": (S, Mgh, Msb, K:) [by some restricted to"},{"kind":"italic_en","text":"relationship by the female side;"},{"kind":"text","text":"as will be shown below:] and"},{"kind":"italic_en","text":"connexion by birth:"},{"kind":"text","text":"(Mgh, Msb:) or"},{"kind":"italic_en","text":"relationship connecting with a father"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ancestor:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near relationship:"},{"kind":"text","text":"so in the T: (TA:) or"},{"kind":"italic_en","text":"a connexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tie, of relationship:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"the ties of relationship:"},{"kind":"text","text":"(M, K, TA:) accord. to the K,"},{"kind":"arabic","text_bw":"Alr~aHimu","text_ar":"الرَّحِمُ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"AlqaraAbapu","text_ar":"القَرَابَةُ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A^aSoluhaA","text_ar":"اَصْلُهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^asobaAbuhaA","text_ar":"اَسْبَابُهَا"},{"kind":"text","text":": but in the M it is said,"},{"kind":"arabic","text_bw":"Alr~aHimu A^asobaAbu AlqaraAbapi waA^aSoluhaA Alr~aHimu Al~atiY hiYa manobitu","text_ar":"الرَّحِمُ اَسْبَابُ القَرَابَةِ وَاَصْلُهَا الرَّحِمُ الَّتِى هِىَ مَنْبِتُ"},{"kind":"arabic","text_bw":"Alwaladi","text_ar":"الوَلَدِ"},{"kind":"text","text":"; in which"},{"kind":"arabic","text_bw":"waA^aSoluhaA","text_ar":"وَاَصْلُهَا"},{"kind":"text","text":"forms no part of the explanation of"},{"kind":"arabic","text_bw":"AlrHm","text_ar":"الرحم"},{"kind":"text","text":", as the author of the K asserts it to do: (TA:) as meaning relationship,"},{"kind":"arabic","text_bw":"rHm","text_ar":"رحم"},{"kind":"text","text":"is in most instances masc.: (Msb:) pl. as above. (K.) It is said in a holy tradition ("},{"kind":"arabic","text_bw":"Hadiyv qudosiY~","text_ar":"حَدِيث قُدْسِىّ"},{"kind":"text","text":"[i. e. an inspired or a revealed tradition]) that God said, when He created"},{"kind":"arabic","text_bw":"Alr~aHim","text_ar":"الرَّحِم"},{"kind":"text","text":"[meaning “ relationship, ” &c.],"},{"kind":"arabic","text_bw":"A^anaA Al~aHom`nu waA^anota Alr~aHimu $aqaqotu","text_ar":"اَنَا الَّحْمٰنُ وَاَنْتَ الرَّحِمُ شَقَقْتُ"},{"kind":"arabic","text_bw":"A@somaka mini A@somiY famano waSalaka waSalotuhu wamano qaTaEaka","text_ar":"ا@سْمَكَ مِنِ ا@سْمِى فَمَنْ وَصَلَكَ وَصَلْتُهُ وَمَنْ قَطَعَكَ"},{"kind":"arabic","text_bw":"qaTaEotuhu","text_ar":"قَطَعْتُهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"I am"},{"kind":"arabic","text_bw":"AlrHm`n","text_ar":"الرحمٰن"},{"kind":"italic_en","text":"and thou art"},{"kind":"arabic","text_bw":"AlrHm","text_ar":"الرحم"},{"kind":"text","text":":"},{"kind":"italic_en","text":"I have derived thy name from my name: therefore whoso maketh thee close, I will make him close; and who severeth thee, I will sever him"},{"kind":"text","text":"]. (TA.) ["},{"kind":"arabic","text_bw":"waSala raHimahu","text_ar":"وَصَلَ رَحِمَهُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"He made close his tie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ties, of relationship, by kind behaviour to his kindred:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaTaEa raHimahu","text_ar":"قَطَعَ رَحِمَهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He severed his tie,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ties, of relationship, by unkind behaviour to his kindred:"},{"kind":"text","text":"see art."},{"kind":"arabic","text_bw":"wSl","text_ar":"وصل"},{"kind":"text","text":": and see also"},{"kind":"arabic","text_bw":"bal~a raHimahu","text_ar":"بَلَّ رَحِمَهُ"},{"kind":"text","text":", in the first paragraph of art."},{"kind":"arabic","text_bw":"bl","text_ar":"بل"},{"kind":"text","text":"; and a verse there cited.] ―         -b3-"},{"kind":"arabic","text_bw":"*uw Alr~aHimi","text_ar":"ذُو الرَّحِمِ"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"The possessor of relationship,"},{"kind":"text","text":"&c.; i. e.]"},{"kind":"italic_en","text":"the contr. of"},{"kind":"arabic","text_bw":"AlA^ajonabiY~u","text_ar":"الاَجْنَبِىُّ"},{"kind":"text","text":": (Mgh, Msb:) the pl."},{"kind":"arabic","text_bw":"*awuw AlA^aroHaAmi","text_ar":"ذَوُو الاَرْحَامِ"},{"kind":"text","text":", [or, as in the Kur viii. last verse, and xxxiii. 6,"},{"kind":"arabic","text_bw":"A^uwluw AlA^aroHaAmi","text_ar":"اُولُو الاَرْحَامِ"},{"kind":"text","text":",] in the classical language, means any"},{"kind":"italic_en","text":"relations:"},{"kind":"text","text":"and in law, any"},{"kind":"italic_en","text":"relations that have no portion"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of the inheritances termed"},{"kind":"arabic","text_bw":"faraAy^iD","text_ar":"فَرَايِض"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and are not"},{"kind":"text","text":"["},{"kind":"italic_en","text":"such heirs as are designated by the appellation"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EaSabap","text_ar":"عَصَبَة"},{"kind":"text","text":"[q. v.]; (KT, TA in art."},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"text","text":";) [i. e.,] with respect to the"},{"kind":"arabic","text_bw":"faraAy^iD","text_ar":"فَرَايِض"},{"kind":"text","text":", it means"},{"kind":"italic_en","text":"the relations by the women's side."},{"kind":"text","text":"(IAth, TA in the present art.)"},{"kind":"arabic","text_bw":"*uw raHimK maHoramK","text_ar":"ذُو رَحِمٍ مَحْرَمٍ"},{"kind":"text","text":"and [some say]"},{"kind":"arabic","text_bw":"muHar~amK","text_ar":"مُحَرَّمٍ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"*uw raHimK","text_ar":"ذُو رَحِمٍ"},{"kind":"arabic","text_bw":"maHoramN","text_ar":"مَحْرَمٌ"},{"kind":"text","text":"also (see art."},{"kind":"arabic","text_bw":"Hrm","text_ar":"حرم"},{"kind":"text","text":")] mean (assumed tropical:)"},{"kind":"italic_en","text":"A relation whom it is unlawful to marry,"},{"kind":"text","text":"[whether"},{"kind":"italic_en","text":"male"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"female,"},{"kind":"text","text":"the latter being included with the former, but the female, when particularly meant, is termed"},{"kind":"arabic","text_bw":"*aAtu","text_ar":"ذَاتُ"},{"kind":"arabic","text_bw":"raHimK maHoramK","text_ar":"رَحِمٍ مَحْرَمٍ"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"such as the mother and the daughter and the sister and the paternal aunt and the maternal aunt"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and the male relations of such degrees"},{"kind":"text","text":"]: and most of the learned, of the Companions and of the generation following these, and Aboo-Haneefeh and his companions, and Ahmad [Ibn-Hambal], hold that when one possesses a person that is termed"},{"kind":"arabic","text_bw":"*uw raHimK maHoramK","text_ar":"ذُو رَحِمٍ مَحْرَمٍ"},{"kind":"text","text":", this person becomes emancipated, whether male or female; but Esh-Sháfi'ee and others of the Imáms and of the Companions and of the generation following these hold that the children and the fathers and the mothers become emancipated, and not any others than these. (IAth, TA.) ―         -b4-  ["},{"kind":"arabic","text_bw":"HaAs~apu raHimK","text_ar":"حَاسَّةُ رَحِمٍ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"A feeling of relationship"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consanguinity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sympathy of blood;"},{"kind":"text","text":"and in like manner, elliptically,"},{"kind":"arabic","text_bw":"raHimN","text_ar":"رَحِمٌ"},{"kind":"text","text":"alone. You say,"},{"kind":"arabic","text_bw":"A^aT~ato","text_ar":"اَطَّتْ"},{"kind":"arabic","text_bw":"lahu min~iY HaAs~apu raHimK","text_ar":"لَهُ مِنِّى حَاسَّةُ رَحِمٍ"},{"kind":"text","text":"; expl. in art."},{"kind":"arabic","text_bw":"Hs","text_ar":"حس"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A^aT~ato","text_ar":"اَطَّتْ"},{"kind":"arabic","text_bw":"lahu raHimiY","text_ar":"لَهُ رَحِمِى"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"A^aT~ato bika Alr~aHimu","text_ar":"اَطَّتْ بِكَ الرَّحِمُ"},{"kind":"text","text":"; expl. in art."},{"kind":"arabic","text_bw":"AT","text_ar":"اط"},{"kind":"text","text":". ―         -b5-"},{"kind":"arabic","text_bw":"raHimN","text_ar":"رَحِمٌ"},{"kind":"text","text":"is also often used for"},{"kind":"arabic","text_bw":"farojN","text_ar":"فَرْجٌ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"HayaA='N","text_ar":"حَيَا=ءٌ"},{"kind":"text","text":", meaning (assumed tropical:)  The"},{"kind":"italic_en","text":"vulva:"},{"kind":"text","text":"see, for exs.,"},{"kind":"arabic","text_bw":"$uforN","text_ar":"شُفْرٌ"},{"kind":"text","text":", and 1 in art."},{"kind":"arabic","text_bw":"ZA=r","text_ar":"ظا=ر"},{"kind":"text","text":", and 8 in art."},{"kind":"arabic","text_bw":"HwS","text_ar":"حوص"},{"kind":"text","text":".]       -A2-  As an epithet, with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", applied to a she-camel: see"},{"kind":"arabic","text_bw":"raHuwmN","text_ar":"رَحُومٌ"},{"kind":"text","text":". ―         -b2-  And as an epithet without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", applied to a water-skin: see 1, last sentence but one."}],"source_refs":["Mgh","Msb","K","S","TA","A","M"]},{"entry_id":"n15086","headword_ar":"رُحُمٌ","root":"rHm","body":[{"kind":"text","text":": see the next paragraph.       -A2-  It is also pl. of"},{"kind":"arabic","text_bw":"raHuwmN","text_ar":"رَحُومٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":[]}]}}