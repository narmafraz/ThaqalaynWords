ary pains; to acquire, obtain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attain, a thing."},{"kind":"text","text":"(Msb, TA.)"},{"kind":"arabic","text_bw":"qurina AlHiroSu biAlHiromaAni","text_ar":"قُرِنَ الحِرْصُ بِالحِرْمَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Greediness,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"is coupled with prohibition"},{"kind":"text","text":"of the object thereof] is a saying of the Arabs. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Excessive solicitude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"care, and fear,"},{"kind":"text","text":"respecting a person; and"},{"kind":"italic_en","text":"excessive pity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compassion."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"HariySN","text_ar":"حَرِيصٌ"},{"kind":"text","text":".]"}],"source_refs":["Msb","S","K"]}]},"classical_definitions":null}