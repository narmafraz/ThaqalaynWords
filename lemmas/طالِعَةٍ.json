{"lemma":"طالِعَةٍ","slug":"طالِعَةٍ","root":"ط.ل.ع","root_slug":"ط-ل-ع","root_link":"/words/roots/ط-ل-ع","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n26939"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D9%84%D9%90%D8%B9%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"omen"},{"pos":"noun","gloss":"luck","tags":["uncountable"]},{"pos":"verb","gloss":"to read"},{"pos":"verb","gloss":"to study"},{"pos":"verb","gloss":"to look at, examine"},{"pos":"verb","gloss":"active participle of طَلَعَ (ṭalaʕa)","tags":["active","form-of","participle"]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb طَلَعَ (ṭalaʕa, “to appear”)."},"ipa":["/tˤaː.liʕ/","/tˤaː.la.ʕa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26939","headword_ar":"طالعهُ","root":"TlE","body":[{"kind":"text","text":", (S, O, K,) inf. n."},{"kind":"arabic","text_bw":"muTaAlaEapN","text_ar":"مُطَالَعَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TilaAEN","text_ar":"طِلَاعٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AiT~alaEa Ealayohi","text_ar":"اِطَّلَعَ عَلَيْهِ"},{"kind":"text","text":"; (S, O, K;) i. e., a thing: (S, O:) Lth says that"},{"kind":"arabic","text_bw":"TilaAEN","text_ar":"طِلَاعٌ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"AiT~ilaAEN","text_ar":"اِطِّلَاعٌ"},{"kind":"text","text":"; but Az disapproves this: (O:) [the verb is correctly explained in what here follows:] one says,"},{"kind":"arabic","text_bw":"TaAlaEotu DayoEatiY","text_ar":"طَالَعْتُ ضَيْعَتِى"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"naZarotuhaA waA@T~alaEotu EalayohaA","text_ar":"نَظَرْتُهَا وَا@طَّلَعْتُ عَلَيْهَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I inspected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"considered with my eye, my estate, and obtained a knowledge of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"acquainted myself with its condition"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"muTaAlaEapN","text_ar":"مُطَالَعَةٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"inspecting"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"well, in order to obtain a knowledge of it."},{"kind":"text","text":"(KL.) [Hence,"},{"kind":"arabic","text_bw":"muTaAlaEapu","text_ar":"مُطَالَعَةُ"},{"kind":"arabic","text_bw":"Alkutubi","text_ar":"الكُتُبِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The studying,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"perusing, of books."},{"kind":"text","text":"]       -A2-  See also the next paragraph, latter half, in three places."}],"source_refs":["S","O","K","TA"]}]},"classical_definitions":null}