{"lemma":"عَثَرَ","slug":"عَثَرَ","root":"ع.ث.ر","root_slug":"ع-ث-ر","root_link":"/words/roots/ع-ث-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَثَرْتَ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَثَرْتِ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَثَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَثَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَثَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَثَرَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَثَرَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَثَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَثَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَثَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَثَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعْثَر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَعْثُر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعْثَرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعْثَرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْثُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْثُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعْثَرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْثَرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْثُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْثُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعْثَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعْثَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْثُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْثُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعْثَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَعْثُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعْثَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعْثُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعْثَر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعْثُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعْثَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْثَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْثُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْثُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعْثَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْثَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْثُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْثُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعْثَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعْثَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْثُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْثُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعْثَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَعْثُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُعْثَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْثَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْثُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْثُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَثَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَثَرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":true,"lemma_key":"عَثَرَ","root":"عثر","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n28026"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AB%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to stumble, to trip","tags":["intransitive"]},{"pos":"verb","gloss":"to cause to stumble or trip, to trip"},{"pos":"verb","gloss":"to stumble upon, to find, to encounter","examples":[{"text":"\"الفلسطيني \"أقدم الليلة الماضية على سرقة شاحنة من منطقة حولون، وجرت عملية بحث عنها حتى عثر عليها في بيت داغان\" […] زعمت شرطة الاحتلال أنها اعتقلت فلسطينيا \"خطط لتنفيذ عملية طعن بالقدس، وانه عثر بحوزته على سكين.","english":"The Palestinian “undertook the theft of a truck from the Holon area last night, and an emprise of searching it has been carried out until it was stumbled upon in Bayt Dāġān” (…) The occupation police claimed that it has arrested a Palestinian who “projected to perform a stabbing operation in Al-Quds, and that a knife has been found in his possession."}]},{"pos":"verb","gloss":"to stumble upon, to find, to encounter; to find out, to discover","examples":[{"text":"فَإِنۡ عُثِرَ عَلَىٰۤ أَنَّهُمَا ٱسۡتَحَقَّاۤ إِثۡمࣰا فَـَٔاخَرَانِ يَقُومَانِ مَقَامَهُمَا مِنَ ٱلَّذِينَ ٱسۡتَحَقَّ عَلَيۡهِمُ ٱلۡأَوۡلَيَـٰنِ فَيُقۡسِمَانِ بِٱللَّهِ لَشَهَـٰدَتُنَاۤ أَحَقُّ مِن شَهَـٰدَتِهِمَا وَمَا ٱعۡتَدَيۡنَاۤ إِنَّاۤ إِذࣰا لَّمِنَ ٱلظَّـٰلِمِينَ","english":"And if it is found out that they deserve blame, so [let it be] two others of the heirs [instead] whom this [duty] has fallen upon. And these two [shall] swear, \"Our testimony is more truthful than theirs! We have not transgressed; [otherwise,] we would be of the wrongdoers."}]},{"pos":"verb","gloss":"to cause to stumble or trip, to trip up","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28026","headword_ar":"عَثَرَ","root":"Evr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, A, Mgh, O, Msb, K) and"},{"kind":"text","text":"; (A, Msb, K;) and"},{"kind":"arabic","text_bw":"Eavira","text_ar":"عَثِرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Eavura","text_ar":"عَثُرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (A, K;) inf. n."},{"kind":"arabic","text_bw":"EivaArN","text_ar":"عِثَارٌ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and"},{"kind":"arabic","text_bw":"EavorN","text_ar":"عَثْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaviyrN","text_ar":"عَثِيرٌ"},{"kind":"text","text":"; (K;) said of a man and of a horse, (S, Msb,)"},{"kind":"italic_en","text":"He stumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tripped;"},{"kind":"text","text":"[the most usual meaning;] or"},{"kind":"italic_en","text":"he fell upon his face;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kabaA","text_ar":"كَبَا"},{"kind":"text","text":"[which has both of these meanings]; as also ↓"},{"kind":"arabic","text_bw":"tEv~r","text_ar":"تعثّر","orth_type":"arrow"},{"kind":"text","text":": (A, K:) or [simply]"},{"kind":"italic_en","text":"he fell;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"saqaTa","text_ar":"سَقَطَ"},{"kind":"text","text":": (Mgh:) or one says of a man, (Msb on the authority of the Mukhtasar el-'Eyn, and TA on the authority of the T,)"},{"kind":"arabic","text_bw":"Eavara","text_ar":"عَثَرَ"},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"EuvuwrN","text_ar":"عُثُورٌ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"EavorapN","text_ar":"عَثْرَةٌ"},{"kind":"text","text":"; (TA; [perhaps a mistranscription for"},{"kind":"arabic","text_bw":"EavorN","text_ar":"عَثْرٌ"},{"kind":"text","text":";]) and of a horse,"},{"kind":"arabic","text_bw":"Eavara","text_ar":"عَثَرَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EivaArN","text_ar":"عِثَارٌ"},{"kind":"text","text":"; (Msb, TA;)"},{"kind":"arabic","text_bw":"fiEaAlN","text_ar":"فِعَالٌ"},{"kind":"text","text":"being a measure of inf. ns. of verbs signifying various faults of horses and the like. (TA.) You say,"},{"kind":"arabic","text_bw":"Eavara fiY vawobihi","text_ar":"عَثَرَ فِى ثَوْبِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He stumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tripped, upon his garment"},{"kind":"text","text":"]. (S, O, Msb.) And"},{"kind":"arabic","text_bw":"fiY A^a*oyaAlihi","text_ar":"فِى اَذْيَالِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xaraja yataEav~aru","text_ar":"خَرَجَ يَتَعَثَّرُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He went forth stumbling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tripping, upon his skirts"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Eavara bihi farasuhu fasaqaTa","text_ar":"عَثَرَ بِهِ فَرَسُهُ فَسَقَطَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His horse stumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tripped, with him, and he fell"},{"kind":"text","text":"]. (S, O.) And it is said in a prov.,"},{"kind":"arabic","text_bw":"AljawaAdu qado yaEovuru","text_ar":"الجَوَادُ قَدْ يَعْثُرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The swift and excellent horse sometimes stumbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trips"},{"kind":"text","text":"]: applied to a person by whom a slip that is not of his nature is seen to have been committed. (O.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Eavara fiY kalaAmihi","text_ar":"عَثَرَ فِى كَلَامِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tEv~r","text_ar":"تعثّر","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He stumbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tripped, in his speech"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"lisaAnuhu","text_ar":"لِسَانُهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tEv~r","text_ar":"تعثّر","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His tongue halted, faltered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hesitated."},{"kind":"text","text":"(S, O, TA.) ―         -b3-  And [hence, app.,]"},{"kind":"arabic","text_bw":"Eavara","text_ar":"عَثَرَ"},{"kind":"text","text":", (Kr, K, TA,) inf. n."},{"kind":"arabic","text_bw":"EavorN","text_ar":"عَثْرٌ"},{"kind":"text","text":", (Kr, O, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He lied."},{"kind":"text","text":"(Kr, O, K, TA.) One says,"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"fiY AlEavori waAlbaAy^ini","text_ar":"فِى العَثْرِ وَالبَايِنِ"},{"kind":"text","text":", meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"Such a one is occupied"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in truth and falsehood"},{"kind":"text","text":"[or rather"},{"kind":"italic_en","text":"in falsehood and truth"},{"kind":"text","text":"]. (O, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Eavara Ealayohi","text_ar":"عَثَرَ عَلَيْهِ"},{"kind":"text","text":", (S, A, Mgh, O, Msb,) aor."},{"kind":"text","text":"(S, O, Msb) and"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"EavorN","text_ar":"عَثْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EuvuwrN","text_ar":"عُثُورٌ"},{"kind":"text","text":", (O, Msb, K, [the latter erroneously written in the CK"},{"kind":"arabic","text_bw":"Eavuwr","text_ar":"عَثُور"},{"kind":"text","text":",]) (tropical:)  ["},{"kind":"italic_en","text":"He stumbled on it; lighted on it by chance;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he got,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained, knowledge of it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sight and knowledge of it; became acquainted with it; knew it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saw it;"},{"kind":"text","text":"(S, A, Mgh, O, Msb, K, * TA;)"},{"kind":"italic_en","text":"accidentally,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without seeking;"},{"kind":"text","text":"(TA;) [and so"},{"kind":"arabic","text_bw":"Eavara bihi","text_ar":"عَثَرَ بِهِ"},{"kind":"text","text":"; (see an ex. voce"},{"kind":"arabic","text_bw":"A^a$orasu","text_ar":"اَشْرَسُ"},{"kind":"text","text":";)] and ↓"},{"kind":"arabic","text_bw":"A^aEovara","text_ar":"اَعْثَرَ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; but accord. to the usage of the Kur-án, you say"},{"kind":"arabic","text_bw":"A^aEovarotu gayoriY","text_ar":"اَعْثَرْتُ غَيْرِى"},{"kind":"text","text":": so in the Kitáb el-Abniyeh of IKtt. (TA. [See 4.]) You say,"},{"kind":"arabic","text_bw":"Eavara EalaY sir~i Alr~ajuli","text_ar":"عَثَرَ عَلَى سِرِّ الرَّجُلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He obtained knowledge of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became acquainted with, the secret of the man"},{"kind":"text","text":"["},{"kind":"italic_en","text":"accidentally"},{"kind":"text","text":"]. (TA.) [Hence,]"},{"kind":"arabic","text_bw":"faA_ino Euvira EalaY A^an~ahumaA A@sotaHaq~aA A_ivomFA","text_ar":"فَاـِنْ عُثِرَ عَلَى اَنَّهُمَا ا@سْتَحَقَّا اـِثْمًا"},{"kind":"text","text":", in the Kur [v. 106], means (tropical:)"},{"kind":"italic_en","text":"But if it become known,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seen,"},{"kind":"text","text":"(Ksh, Mgh, O, Bd, Jel,)"},{"kind":"italic_en","text":"that they two have done what has necessitated sin,"},{"kind":"text","text":"(Ksh, Bd, Jel,) and"},{"kind":"italic_en","text":"deserved its being said of them that they were sinners."},{"kind":"text","text":"(Ksh.) And"},{"kind":"arabic","text_bw":"Eavara","text_ar":"عَثَرَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuvuwrN","text_ar":"عُثُورٌ"},{"kind":"text","text":", as expl. by Lth, means (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"entered suddenly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unexpectedly, upon an affair upon which another had not so entered."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Eavara jad~uhu","text_ar":"عَثَرَ جَدُّهُ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (TA,) means (tropical:)"},{"kind":"italic_en","text":"His fortune,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good fortune, fell;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"taEisa","text_ar":"تَعِسَ"},{"kind":"text","text":"; (K, TA;) as being likened to one who has stumbled, or tripped, or fallen upon his face. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"Eavara AlEiroqu","text_ar":"عَثَرَ العِرْقُ"},{"kind":"text","text":", (Lh, K,) inf. n."},{"kind":"arabic","text_bw":"EavorN","text_ar":"عَثْرٌ"},{"kind":"text","text":", (Lh, TA,)"},{"kind":"italic_en","text":"The vein pulsed."},{"kind":"text","text":"(Lh, K, TA.) ―         -b7-"},{"kind":"arabic","text_bw":"Eavara bihi","text_ar":"عَثَرَ بِهِ"},{"kind":"text","text":": see 4. ―         -b8-  [Hence,]"},{"kind":"arabic","text_bw":"Eavara bihimo Alz~amaAnu","text_ar":"عَثَرَ بِهِمْ الزَّمَانُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, destroyed them:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"caused them to be overcome."},{"kind":"text","text":"(O.)"}],"source_refs":["S","A","Mgh","O","Msb","K","TA","Kr","Ksh","Bd","Jel","Lh"]}]}}