{"lemma":"جِبِلّاتٌ","slug":"جِبِلّاتٌ","root":"ج.ب.ل","root_slug":"ج-ب-ل","root_link":"/words/roots/ج-ب-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"جِبِلَّة","root":"جبل","pos":"N","occurrence_count":2},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n4973","n4984","n4985","n4986","n4987","n4990","n4991"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%90%D8%A8%D9%90%D9%84%D9%91%D8%A7%D8%AA%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4973","headword_ar":"جَبَلَهُ","root":"jbl","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(Msb, K) and"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jabolN","text_ar":"جَبْلٌ"},{"kind":"text","text":", (KL.)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"created him."},{"kind":"text","text":"(S, Msb, K, KL.) So in the phrase,"},{"kind":"arabic","text_bw":"jabalahu EalaY","text_ar":"جَبَلَهُ عَلَى"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"ElY Al$~aYo'i","text_ar":"على الشَّىْءِ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"created him with an adaptation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disposition, to such a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the thing; adapted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposed him, by nature thereto."},{"kind":"text","text":"(Msb.) It is said in a trad.,"},{"kind":"arabic","text_bw":"jubilati Alquluwbu EalaY Hub~i mano A^aHosana","text_ar":"جُبِلَتِ القُلُوبُ عَلَى حُبِّ مَنْ اَحْسَنَ"},{"kind":"arabic","text_bw":"A_ilayohaA wabugoDi mano A^asaA='a A_ilayohaA","text_ar":"اـِلَيْهَا وَبُغْضِ مَنْ اَسَا=ءَ اـِلَيْهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Hearts are created with a disposition to the love of him who does good to them, and the hatred of him who does evil to them"},{"kind":"text","text":"]. (TA.) ―         -b2-  Also, (K,) inf. n. as above, (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"jabarahu","text_ar":"جَبَرَهُ"},{"kind":"text","text":"[evidently as meaning"},{"kind":"italic_en","text":"He compelled him, against his will,"},{"kind":"arabic","text_bw":"EalaY AlA^amori","text_ar":"عَلَى الاَمْرِ"},{"kind":"italic_en","text":"to do the thing;"},{"kind":"text","text":"for he who is created with a disposition to do a thing is as though he were compelled to do it]; and so ↓"},{"kind":"arabic","text_bw":"Ajblhu","text_ar":"اجبلهُ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"A_ijobaAlN","text_ar":"اـِجْبَالٌ"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"arabic","text_bw":"jabila","text_ar":"جَبِلَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"became like a mountain"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"jabal","text_ar":"جَبَل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in bigness, thickness, coarseness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"roughness."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jabila Hadiyduhumo","text_ar":"جَبِلَ حَدِيدُهُمْ"},{"kind":"text","text":"(K, TA; in the CK,"},{"kind":"arabic","text_bw":"jabala","text_ar":"جَبَلَ"},{"kind":"text","text":"; and in a MS. copy of the K, without any vowels;) (assumed tropical:)"},{"kind":"italic_en","text":"Their iron was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blunt, such as would not penetrate."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":["S","Msb","K","God","TA"]},{"entry_id":"n4984","headword_ar":"جَبْلَةٌ","root":"jbl","body":[{"kind":"text","text":"(K, TA, [in the CK"},{"kind":"arabic","text_bw":"jabalapN","text_ar":"جَبَلَةٌ"},{"kind":"text","text":",]) and ↓"},{"kind":"arabic","text_bw":"jibolapN","text_ar":"جِبْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"face:"},{"kind":"text","text":"or the"},{"kind":"arabic","text_bw":"ba$arap","text_ar":"بَشَرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"external skin"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thereof:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"part thereof that is turned towards one."},{"kind":"text","text":"(K.)       -A2-  Also, (K,) or the former, (TA,)"},{"kind":"italic_en","text":"A vice, fault, defect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blemish."},{"kind":"text","text":"(K.)       -A3-  And"},{"kind":"italic_en","text":"Strength."},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"italic_en","text":"Hardness of the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground."},{"kind":"text","text":"(Lth, K.)       -A4-  See also"},{"kind":"arabic","text_bw":"jubolapN","text_ar":"جُبْلَةٌ"},{"kind":"text","text":":       -A5-  and see"},{"kind":"arabic","text_bw":"jibolaPN","text_ar":"جِبْلَپٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA"]},{"entry_id":"n4985","headword_ar":"جُبْلَةٌ","root":"jbl","body":[{"kind":"italic_en","text":"A camel's hump;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"jabolapN","text_ar":"جَبْلَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)       -A2-  See also"},{"kind":"arabic","text_bw":"jibil~N","text_ar":"جِبِلٌّ"},{"kind":"text","text":":       -A3-  and see"},{"kind":"arabic","text_bw":"jibil~apN","text_ar":"جِبِلَّةٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n4986","headword_ar":"جِبْلَةٌ","root":"jbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jibil~apN","text_ar":"جِبِلَّةٌ"},{"kind":"text","text":". ―         -b2-  Also The"},{"kind":"italic_en","text":"origin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stock,"},{"kind":"text","text":"(K, TA,) of any created thing; (TA;) and so ↓"},{"kind":"arabic","text_bw":"jubul~apN","text_ar":"جُبُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (K, TA.) ―         -b3-  The"},{"kind":"italic_en","text":"fundamental nature,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"composition,"},{"kind":"text","text":"of a mountain. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"vawobN","text_ar":"ثَوْبٌ"},{"kind":"arabic","text_bw":"jay~idu Aljibolapi","text_ar":"جَيِّدُ الجِبْلَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, good in respect of the thread"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"and the weaving."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"rajulN *uw jibolapK","text_ar":"رَجُلٌ ذُو جِبْلَةٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A big, thick, coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough, man."},{"kind":"text","text":"(S, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"jibil~N","text_ar":"جِبِلٌّ"},{"kind":"text","text":", in two places:       -A3-  and see"},{"kind":"arabic","text_bw":"jabolapN","text_ar":"جَبْلَةٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA"]},{"entry_id":"n4987","headword_ar":"جَبَلَةٌ","root":"jbl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jibil~apN","text_ar":"جِبِلَّةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n4990","headword_ar":"جُبُلَّةٌ","root":"jbl","body":[{"kind":"italic_en","text":"Much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an abundance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a large quantity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"number,"},{"kind":"text","text":"or anything; as also ↓"},{"kind":"arabic","text_bw":"jibil~apN","text_ar":"جِبِلَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)       -A2-  See also"},{"kind":"arabic","text_bw":"jibolapN","text_ar":"جِبْلَةٌ"},{"kind":"text","text":":       -A3-  and see what next follows, in two places."}],"source_refs":[]},{"entry_id":"n4991","headword_ar":"جِبِلَّةٌ","root":"jbl","body":[{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"jubul~apN","text_ar":"جُبُلَّةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jabiylapN","text_ar":"جَبِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"(Sgh, MF) and ↓"},{"kind":"arabic","text_bw":"jibolapN","text_ar":"جِبْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"(AA, S, K) and ↓"},{"kind":"arabic","text_bw":"jubolapN","text_ar":"جُبْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jabolapN","text_ar":"جَبْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"jabalapN","text_ar":"جَبَلَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) but this last, accord. to MF, is unknown, (TA,)"},{"kind":"italic_en","text":"Nature;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"natural, native, innate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"original, constitution, disposition, temper,"},{"kind":"text","text":"or other"},{"kind":"italic_en","text":"quality"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property; idiosyncrasy;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xiloqapN","text_ar":"خِلْقَةٌ"},{"kind":"text","text":"(AA, S, Sgh, Msb, K) and"},{"kind":"arabic","text_bw":"TabiyEapN","text_ar":"طَبِيعَةٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"gariyzapN","text_ar":"غَرِيزَةٌ"},{"kind":"text","text":"; all these signifying the same: (Msb:) pl. of the first"},{"kind":"arabic","text_bw":"jibil~aAtN","text_ar":"جِبِلَّاتٌ"},{"kind":"text","text":". (S.) Hence, in the Kur [xxvi. 184],"},{"kind":"arabic","text_bw":"waAljibil~apa AlA^aw~aliyna","text_ar":"وَالجِبِلَّةَ الاَوَّلِينَ"},{"kind":"text","text":", (S,) meaning"},{"kind":"arabic","text_bw":"Alxaliyqapa","text_ar":"الخَلِيقَةَ"},{"kind":"text","text":", (Jel,) or"},{"kind":"arabic","text_bw":"*awiy Aljibil~api","text_ar":"ذَوِي الجِبِلَّةِ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"And the preceding created beings:"},{"kind":"text","text":"(Bd:) El- Hasan read with damm [i. e. ↓"},{"kind":"arabic","text_bw":"Aljubul~apa","text_ar":"الجُبُلَّةَ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"Aljvbolapa","text_ar":"الجثبْلَةَ","orth_type":"arrow"},{"kind":"text","text":"]. (S.)       -A2-  See also"},{"kind":"arabic","text_bw":"jibil~N","text_ar":"جِبِلٌّ"},{"kind":"text","text":", in three places: ―         -b2-  and see"},{"kind":"arabic","text_bw":"jubul~apN","text_ar":"جُبُلَّةٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K","Sgh","MF","AA","TA","Jel","Bd"]}]}}