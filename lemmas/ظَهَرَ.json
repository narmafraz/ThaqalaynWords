{"lemma":"ظَهَرَ","slug":"ظَهَرَ","root":"ظ.ه.ر","root_slug":"ظ-ه-ر","root_link":"/words/roots/ظ-ه-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ظَهَرْتَ","in_corpus":true,"count":16,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ظَهَرْتِ","in_corpus":true,"count":16,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ظَهَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ظَهَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ظَهَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ظَهَرَ","in_corpus":true,"count":63,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ظَهَرَت","in_corpus":true,"count":16,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ظَهَرا","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ظَهَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ظَهَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ظَهَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَظْهَر","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَظْهَرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَظْهَرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَظْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَظْهَرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَظْهَرُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَظْهَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَظْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَظْهَر","in_corpus":true,"count":29,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَظْهَر","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَظْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَظْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَظْهَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَظْهَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَظْهَرُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَظْهَرُوا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَظْهَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَظْهَر","in_corpus":true,"count":15,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَظْهَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"ظَهَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"ظَهَرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":181,"cross_references":{"qac":{"found":true,"lemma_key":"ظَهَرَ","root":"ظهر","pos":"V","occurrence_count":10},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":17},"lanes":{"found":true,"entry_ids":["n27712"],"search_url":"https://lanelexicon.com/?s=%D8%B8%D9%8E%D9%87%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be outward, to be external, on the surface"},{"pos":"verb","gloss":"to be visible, to become visible, to be manifest, to become manifest"},{"pos":"verb","gloss":"to be perceptible, to become perceptible, to be obvious, to become obvious"},{"pos":"verb","gloss":"to be clear, to become clear, to be evident, to become evident"},{"pos":"verb","gloss":"to come to light, to appear, to emerge","examples":[{"text":"لِلنَّجَاحِ، يَجِبُ عَلَى الْمَرْءِ أَنْ يَشُقَّ طَرِيقًا حَتَّى عِنْدَمَا تَظْهَرُ التَّحَدِّيَاتُ.","english":"To succeed, one must forge a path even when challenges arise."}]},{"pos":"verb","gloss":"to seem"},{"pos":"verb","gloss":"to come out, to be published"},{"pos":"verb","gloss":"to arise, to result"},{"pos":"verb","gloss":"to climb, to mount, to ascend","tags":["transitive"]},{"pos":"verb","gloss":"to endorse"},{"pos":"noun","gloss":"back, rear, reverse"},{"pos":"noun","gloss":"deck, surface, top"},{"pos":"noun","gloss":"back"},{"pos":"noun","gloss":"cast iron"},{"pos":"noun","gloss":"noon, midday"},{"pos":"noun","gloss":"midday prayer"},{"pos":"noun","gloss":"afternoon, p.m."}]},"etymology":{"source":"wiktextract","text":"Cognate to Hebrew צהריים \\ צָהֳרַיִם (tsohoráyim) and צוהר \\ צֹהַר (tsóhar), and Aramaic טהרא (ṭahrā)."},"ipa":["/ðˤa.ha.ra/","/ðˤah.ha.ra/","/ðˤahr/","/ðˤuhr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27712","headword_ar":"ظَهَرَ","root":"Zhr","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"ZuhuwrN","text_ar":"ظُهُورٌ"},{"kind":"text","text":", (S, Mgh, Msb, K, &c.,) ["},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, outward, exterior, external, extrinsic,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exoteric:"},{"kind":"text","text":"and hence,]"},{"kind":"italic_en","text":"it appeared; became apparent, overt, open, perceptible"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perceived, manifest, plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident;"},{"kind":"text","text":"(S, Mgh, Msb, K, TA;)"},{"kind":"italic_en","text":"after having been concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"latent:"},{"kind":"text","text":"(Msb, TA:) and ↓"},{"kind":"arabic","text_bw":"tZAhr","text_ar":"تظاهر","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (Har p. 85.) Hence the phrase"},{"kind":"arabic","text_bw":"Zahara liY raA^oYN","text_ar":"ظَهَرَ لِى رَاْىٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"An idea,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"opinion, occurred to me"},{"kind":"text","text":"], said when one knows what he did not know before. (Msb.) [And"},{"kind":"arabic","text_bw":"h`*aA maA yaZoharu liY","text_ar":"هٰذَا مَا يَظْهَرُ لِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"This is what appears to me"},{"kind":"text","text":"to be the case, or to be the right way or course; or"},{"kind":"italic_en","text":"this is my opinion."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Zahara AlHamolu","text_ar":"ظَهَرَ الحَمْلُ"},{"kind":"text","text":", inf. n. as above, means"},{"kind":"italic_en","text":"Pregnancy became apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifest:"},{"kind":"text","text":"it is said that this is not the case in less than three months. (Msb.) And it is said in a trad. of 'Áïsheh,"},{"kind":"arabic","text_bw":"kaAna yuSal~iY AlEaSora","text_ar":"كَانَ يُصَلِّى العَصْرَ"},{"kind":"arabic","text_bw":"fiY HujoratiY qabola A^ano taZohara","text_ar":"فِى حُجْرَتِى قَبْلَ اَنْ تَظْهَرَ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"He used to perform the prayer of the afternoon in my chamber"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"before it"},{"kind":"text","text":"(meaning the sun)"},{"kind":"italic_en","text":"became high and apparent:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"waAl$~amosu fiY HujoratiY lamo taZoharo","text_ar":"وَالشَّمْسُ فِى حُجْرَتِى لَمْ تَظْهَرْ"},{"kind":"arabic","text_bw":"baEodu","text_ar":"بَعْدُ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"when the sun was in my chamber,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it not having risen high"},{"kind":"text","text":"so as to be on the flat roof [thereof]: referring to the Prophet. (O. [But"},{"kind":"arabic","text_bw":"AlEaSora","text_ar":"العَصْرَ"},{"kind":"text","text":"must be a mistranscription for"},{"kind":"arabic","text_bw":"Alfajora","text_ar":"الفَجْرَ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"the prayer of the dawn."},{"kind":"text","text":"]) The saying in the Kur [xxiv. 31],"},{"kind":"arabic","text_bw":"walaA yubodiyna ziynatahun~a A_il~aA maA Zahara minohaA","text_ar":"وَلَا يُبْدِينَ زِينَتَهُنَّ اـِلَّا مَا ظَهَرَ مِنْهَا"},{"kind":"text","text":"[which is app. best rendered"},{"kind":"italic_en","text":"And that they discover not their ornature except what is external thereof"},{"kind":"text","text":"] has been expl. in seven different ways, most correctly as meaning the clothes: (O, TA:) accord. to 'Áïsheh, it means the bracelet ("},{"kind":"arabic","text_bw":"Alqulob","text_ar":"القُلْب"},{"kind":"text","text":") and the ring ("},{"kind":"arabic","text_bw":"Alfataxap","text_ar":"الفَتَخَة"},{"kind":"text","text":"): and accord. to I'Ab, the hand and the signet-ring and the face. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He went forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out,"},{"kind":"text","text":"(Mgh, TA,)"},{"kind":"italic_en","text":"to the outside of a place."},{"kind":"text","text":"(O, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bird)"},{"kind":"italic_en","text":"migrated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went down,"},{"kind":"text","text":"from one country or region to another: used in this sense by AHn in relation to the vulture, migrating to Nejd. (L.) ―         -b4-"},{"kind":"arabic","text_bw":"Zahara Eanohu","text_ar":"ظَهَرَ عَنْهُ"},{"kind":"text","text":", said of a vice, or fault, (O, TA,) or a disgrace, (JK, A, O,) (tropical:)"},{"kind":"italic_en","text":"It did not cleave to him;"},{"kind":"text","text":"(A, O, TA;)"},{"kind":"italic_en","text":"it was remote from him;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"it quitted him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed from him."},{"kind":"text","text":"(JK.) ―         -b5-"},{"kind":"arabic","text_bw":"Zaharotu bihi","text_ar":"ظَهَرْتُ بِهِ"},{"kind":"text","text":", (O, TA,) inf. n."},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":", (K,) (assumed tropical:)"},{"kind":"italic_en","text":"I gloried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boasted, by reason of it."},{"kind":"text","text":"(O, K * TA.) [Respecting a meaning assigned to"},{"kind":"arabic","text_bw":"Zahara","text_ar":"ظَهَرَ"},{"kind":"arabic","text_bw":"bifulaAnK","text_ar":"بِفُلَانٍ"},{"kind":"text","text":"in the K, see 4.] ―         -b6-"},{"kind":"arabic","text_bw":"A^akala Alr~ajulu A^ukolapF","text_ar":"اَكَلَ الرَّجُلُ اُكْلَةً"},{"kind":"arabic","text_bw":"Zahara minohaA ZahorapF","text_ar":"ظَهَرَ مِنْهَا ظَهْرَةً"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"The man ate some food"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in consequence of which"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he became fat."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Zaharahu","text_ar":"ظَهَرَهُ"},{"kind":"italic_en","text":"He mounted it; went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got, upon it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon the top of it;"},{"kind":"text","text":"(S, A, * Mgh, O, Msb, K;) as also"},{"kind":"arabic","text_bw":"Zahara Ealayohi","text_ar":"ظَهَرَ عَلَيْهِ"},{"kind":"text","text":"; (O;) namely, a house, (S,) or a house-top, (A, Mgh, O,) and a mountain, (A,) and a wall; (O, Msb;) properly,"},{"kind":"italic_en","text":"he became upon its back:"},{"kind":"text","text":"(Mgh:) and [in like manner] one says,"},{"kind":"arabic","text_bw":"fulaAnN najodFA","text_ar":"فُلَانٌ نَجْدًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Zah~ara","text_ar":"ظَهَّرَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taZohiyrN","text_ar":"تَظْهِيرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Such a one mounted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went up, upon the high region"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Zahor","text_ar":"ظَهْر"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of Nejd."},{"kind":"text","text":"(O.) ―         -b2-  Hence, (Mgh, Msb,)"},{"kind":"arabic","text_bw":"Zahara Ealayohi","text_ar":"ظَهَرَ عَلَيْهِ"},{"kind":"text","text":"(S, Mgh, O, Msb, K) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"ZuhuwrN","text_ar":"ظُهُورٌ"},{"kind":"text","text":"(Bd in xxiv. 31) and"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"also, (Ham p. 301,)"},{"kind":"italic_en","text":"He overcame, conquered, subdued, overpowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mastered, him; gained the mastery"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"victory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prevailed, over him;"},{"kind":"text","text":"(S, Mgh, O, Msb, K;) namely, his enemy; (Msb;) and in like manner, ["},{"kind":"italic_en","text":"he conquered, won, achieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attained, it,"},{"kind":"text","text":"i. e.] a thing. (O, TA.) [The saying"},{"kind":"arabic","text_bw":"fulaAnN laA yaZoharu","text_ar":"فُلَانٌ لَا يَظْهَرُ"},{"kind":"arabic","text_bw":"Ealayohi A^aHadN","text_ar":"عَلَيْهِ اَحَدٌ"},{"kind":"text","text":"is expl. in the L and TA by the words"},{"kind":"arabic","text_bw":"AY lA yasolam","text_ar":"اى لا يَسْلَم"},{"kind":"text","text":", and said to be tropical: but Ibr D thinks that the correct reading is"},{"kind":"arabic","text_bw":"lA yusal~imu","text_ar":"لا يُسَلِّمُ"},{"kind":"text","text":", from"},{"kind":"arabic","text_bw":"Alt~asoliymu","text_ar":"التَّسْلِيمُ"},{"kind":"text","text":"; and that it is said of one who will not give up, or resign, what is in his hand; so that the meaning is, (tropical:)"},{"kind":"italic_en","text":"Such a one is a person whom no one will overcome in respect of that which he holds in his possession."},{"kind":"text","text":"] ―         -b3-  And [hence also]"},{"kind":"arabic","text_bw":"Zahara Ealayohi","text_ar":"ظَهَرَ عَلَيْهِ"},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"ZuhuwrN","text_ar":"ظُهُورٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He knew, became acquainted with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"got knowledge of, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Msb, TA.) So in the Kur xxiv. 31,"},{"kind":"arabic","text_bw":"waA@lT~ifolu","text_ar":"وَا@لطِّفْلُ"},{"kind":"arabic","text_bw":"A@l~a*iyna lamo yaZoharuwA EalaY EaworaAti A@ln~isaA='i","text_ar":"ا@لَّذِينَ لَمْ يَظْهَرُوا عَلَى عَوْرَاتِ ا@لنِّسَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the young children"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"who have not attained knowledge of the"},{"kind":"arabic","text_bw":"EwrAt","text_ar":"عورات"},{"kind":"text","text":", (Bd, Jel,) meaning ["},{"kind":"italic_en","text":"pudenda,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"parts between the navel and the knee,"},{"kind":"text","text":"(Jel,)"},{"kind":"italic_en","text":"of women,"},{"kind":"text","text":"by reason of their want of discrimination: (Bd:) or (tropical:)"},{"kind":"italic_en","text":"who have not attained to the generative faculty;"},{"kind":"text","text":"(O, Bd, * TA;) from"},{"kind":"arabic","text_bw":"AlZ~uhuwru","text_ar":"الظُّهُورُ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"Algalabapu","text_ar":"الغَلَبَةُ"},{"kind":"text","text":". (Bd.) So too in the Kur [xviii. 19],"},{"kind":"arabic","text_bw":"A_ino yaZoharuwA Ealayokumo","text_ar":"اـِنْ يَظْهَرُوا عَلَيْكُمْ"},{"kind":"italic_en","text":"If they get knowledge of you."},{"kind":"text","text":"(O, TA.) ―         -b4-  And [hence]"},{"kind":"arabic","text_bw":"Zahara Ealayohi","text_ar":"ظَهَرَ عَلَيْهِ"},{"kind":"text","text":", (Fr, A, O, TA,) and ↓"},{"kind":"arabic","text_bw":"AstZhrhu","text_ar":"استظهرهُ","orth_type":"arrow"},{"kind":"text","text":", (S, A, O, K,) (tropical:)"},{"kind":"italic_en","text":"He knew it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"learned it, by heart;"},{"kind":"text","text":"namely, the Kur-án; (A, O, TA;) and"},{"kind":"italic_en","text":"he recited it by heart:"},{"kind":"text","text":"(A, * TA; and so in the S and O in explanation of the latter:) or [simply]"},{"kind":"italic_en","text":"he recited it by heart;"},{"kind":"text","text":"namely, the Kur-án; as also ↓"},{"kind":"arabic","text_bw":"AZhrhu","text_ar":"اظهرهُ","orth_type":"arrow"},{"kind":"text","text":": (O, K, TA:) in the copies of the K we find"},{"kind":"arabic","text_bw":"A^aZoharotu EalaY AlquroA=ni","text_ar":"اَظْهَرْتُ عَلَى القُرْا=نِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aZoharotuhu","text_ar":"اَظْهَرْتُهُ"},{"kind":"text","text":"; but the former is a mistake for"},{"kind":"arabic","text_bw":"Zaharotu","text_ar":"ظَهَرْتُ"},{"kind":"text","text":", aor."},{"kind":"text","text":". (TA.)       -A3-  For another signification of"},{"kind":"arabic","text_bw":"Zahara Ealayohi","text_ar":"ظَهَرَ عَلَيْهِ"},{"kind":"text","text":", see 3.       -A4-"},{"kind":"arabic","text_bw":"Zahara biHaAjatiY","text_ar":"ظَهَرَ بِحَاجَتِى"},{"kind":"text","text":", (S, A, K,)"},{"kind":"page_break","n":1927},{"kind":"text","text":"aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"; (TK;) and ↓"},{"kind":"arabic","text_bw":"Zh~rhA","text_ar":"ظهّرها","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) in some copies of the K"},{"kind":"arabic","text_bw":"ZaharahaA","text_ar":"ظَهَرَهَا"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AZhrhA","text_ar":"اظهرها","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_iZohaArN","text_ar":"اـِظْهَارٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"AiZ~aharahaA","text_ar":"اِظَّهَرَهَا","orth_type":"arrow"},{"kind":"text","text":", (K,) of the measure"},{"kind":"arabic","text_bw":"AifotaEala","text_ar":"اِفْتَعَلَ"},{"kind":"text","text":"; (TA;) (tropical:)"},{"kind":"italic_en","text":"He held the object of my want in little,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light, estimation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in contempt;"},{"kind":"text","text":"(S, A;) [lit.]"},{"kind":"italic_en","text":"he put it behind"},{"kind":"text","text":"["},{"kind":"italic_en","text":"his"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"back;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"as though he put it away,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"out of his sight,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and paid no regard to it."},{"kind":"text","text":"(S, TA.) One says also,"},{"kind":"arabic","text_bw":"yaZoharuwna bihimo walaA yalotafituwna","text_ar":"يَظْهَرُونَ بِهِمْ وَلَا يَلْتَفِتُونَ"},{"kind":"arabic","text_bw":"A_ilaY A^aroHaAmihimo","text_ar":"اـِلَى اَرْحَامِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They hold them in contempt, and do not pay any regard to their ties of relationship"},{"kind":"text","text":"]. (S.) ―         -b2-  See also 10, in three places.       -A5-"},{"kind":"arabic","text_bw":"Zaharahu","text_ar":"ظَهَرَهُ"},{"kind":"text","text":", (O, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smote,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"his back."},{"kind":"text","text":"(O, K, TA.)       -A6-"},{"kind":"arabic","text_bw":"Zahira","text_ar":"ظَهِرَ"},{"kind":"text","text":", (S, O, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"ZaharN","text_ar":"ظَهَرٌ"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, O)"},{"kind":"italic_en","text":"had a complaint of his back."},{"kind":"text","text":"(S, O, K.)       -A7-"},{"kind":"arabic","text_bw":"Zahura","text_ar":"ظَهُرَ"},{"kind":"text","text":", (JK, O, L,) or"},{"kind":"arabic","text_bw":"Zahara","text_ar":"ظَهَرَ"},{"kind":"text","text":", (K, [but this is app. a mistranscription,]) inf. n."},{"kind":"arabic","text_bw":"ZahaArapN","text_ar":"ظَهَارَةٌ"},{"kind":"text","text":", (S, O, L, K,) said of a camel, (JK, S, O,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, strong"},{"kind":"text","text":"(JK, S, O, L, K)"},{"kind":"italic_en","text":"in the back."},{"kind":"text","text":"(L, K.)"}],"source_refs":["Msb","TA","O","Mgh","JK","A","K","S","Bd","Jel","Fr","L"]}]}}