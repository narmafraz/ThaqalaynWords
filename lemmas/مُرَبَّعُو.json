kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14561","headword_ar":"مُرْبِعٌ","root":"rbE","body":[{"kind":"text","text":": ―         -b2-  see"},{"kind":"arabic","text_bw":"marobuwEN","text_ar":"مَرْبُوعٌ"},{"kind":"text","text":".       -A2-  Applied to rain, (S, Msb, TA,)"},{"kind":"italic_en","text":"That comes in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":": [in the Ham p. 425, written"},{"kind":"arabic","text_bw":"marobaE","text_ar":"مَرْبَع"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"that induces the people to remain in their abodes and not to seek after herbage"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"that confines the people in their"},{"kind":"arabic","text_bw":"ribaAE","text_ar":"رِبَاع"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"dwellings"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by reason of its abundance"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"that causes the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"herbage called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"italic_en","text":"to grow"},{"kind":"text","text":": (TA:) or"},{"kind":"italic_en","text":"that causes the growth of that in which the camels may pasture at pleasure."},{"kind":"text","text":"(S.) ―         -b2-  With"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", applied to land ("},{"kind":"arabic","text_bw":"A^aroDN","text_ar":"اَرْضٌ"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"Abounding with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the herbage called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"mirobaAEN","text_ar":"مِرْبَاعٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-  Without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", applied to a she-camel, (As, S, K,)"},{"kind":"italic_en","text":"That brings forth in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"that has her young one with her;"},{"kind":"text","text":"(As, S, K;) the young one being called"},{"kind":"arabic","text_bw":"rubaEN","text_ar":"رُبَعٌ"},{"kind":"text","text":": (As, S:) as also ↓"},{"kind":"arabic","text_bw":"mirobaAEN","text_ar":"مِرْبَاعٌ","orth_type":"arrow"},{"kind":"text","text":": (As, TA:) or the latter signifies one"},{"kind":"italic_en","text":"that usually brings forth in the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"season called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"that brings forth in the beginning of the breeding-time"},{"kind":"text","text":": (As, S, K:) or"},{"kind":"italic_en","text":"that is early,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"before others, in becoming pregnant:"},{"kind":"text","text":"(TA:) and the former, so applied, signifies also one"},{"kind":"italic_en","text":"whose womb is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becomes, closed,"},{"kind":"text","text":"[app. in the season called"},{"kind":"arabic","text_bw":"rabiyE","text_ar":"رَبِيع"},{"kind":"text","text":", (see 4,)]"},{"kind":"italic_en","text":"so that it does not admit the seminal fluid."},{"kind":"text","text":"(TA.) ―         -b4-  Applied to a man, (tropical:)"},{"kind":"italic_en","text":"Having offspring born to him in the prime of his manhood."},{"kind":"text","text":"(TA.) [See 4]       -A3-  Also The"},{"kind":"italic_en","text":"sail of a full ship"},{"kind":"text","text":": (AA, K:) that of an empty ship is called"},{"kind":"arabic","text_bw":"ruwmiY~N","text_ar":"رُومِىٌّ"},{"kind":"text","text":". (AA, TA.)"}],"source_refs":["S","Msb","TA","As","K","AA"]},{"entry_id":"n14562","headword_ar":"مِرْبَعٌ","root":"rbE","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"mirobaEapN","text_ar":"مِرْبَعَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n14563","headword_ar":"مُرَبَّعٌ","root":"rbE","body":[{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"Having four portions"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"sides"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faces"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"angles"},{"kind":"text","text":"&c.; generally meaning either"},{"kind":"italic_en","text":"square"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quadrilateral"},{"kind":"text","text":"]: or"},{"kind":"italic_en","text":"of the form of a thing having four legs;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of the form of a quadruped."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"muval~avN","text_ar":"مُثَلَّثٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"murab~aEu AlHaAjibayoni","text_ar":"مُرَبَّعُ الحَاجِبَيْنِ"},{"kind":"text","text":"(assumed tropical:)  A man"},{"kind":"italic_en","text":"whose eyebrows have much hair;"},{"kind":"text","text":"as though he had four eyebrows. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"murab~aEN Aljabohapi","text_ar":"مُرَبَّعٌ الجَبْهَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Having a square forehead;"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"a slave."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K"]}]},"classical_definitions":null}