": "انكسر الشِّعْرُ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The poetry became"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "broken,"}, {"kind": "text", "text": "or]"}, {"kind": "italic_en", "text": "incorrect in measure."}, {"kind": "text", "text": "(TA.) ―         -b4-  ["}, {"kind": "arabic", "text_bw": "Anksr Alqawomu", "text_ar": "انكسر القَوْمُ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The people became broken,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "defeated."}, {"kind": "text", "text": "] ―         -b5-"}, {"kind": "arabic", "text_bw": "Anksr xaSomiY", "text_ar": "انكسر خَصْمِى"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "My adversary became defeated."}, {"kind": "text", "text": "] (A.) ―         -b6-  ["}, {"kind": "arabic", "text_bw": "Anksrt", "text_ar": "انكسرت"}, {"kind": "arabic", "text_bw": "nafosuhu", "text_ar": "نَفْسُهُ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "His spirit became broken,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "subdued:"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "Anksr", "text_ar": "انكسر"}, {"kind": "text", "text": ", alone,"}, {"kind": "italic_en", "text": "he became broken in spirit; his sharpness of temper, vehemence of mind,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fierceness, became broken,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "subdued; he became meek, gentle,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "humble."}, {"kind": "text", "text": "] ―         -b7-  ["}, {"kind": "arabic", "text_bw": "Anksr", "text_ar": "انكسر"}, {"kind": "text", "text": ", said of a man, also signifies, very frequently, (tropical:)"}, {"kind": "italic_en", "text": "He became languid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "languishing."}, {"kind": "text", "text": "See the act. part. n., below. And see 5.]"}, {"kind": "arabic", "text_bw": "fatorapN", "text_ar": "فَتْرَةٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "AinokisaArN", "text_ar": "اِنْكِسَارٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "DaEofN", "text_ar": "ضَعْفٌ"}, {"kind": "text", "text": "are syn. (S, art."}, {"kind": "arabic", "text_bw": "ftr", "text_ar": "فتر"}, {"kind": "text", "text": ".) ―         -b8-"}, {"kind": "arabic", "text_bw": "Anksr Eani Al$~aYo'i", "text_ar": "انكسر عَنِ الشَّىْءِ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He lacked power,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ability, to do,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "accomplish the thing."}, {"kind": "text", "text": "And"}, {"kind": "arabic", "text_bw": "Anksr", "text_ar": "انكسر"}, {"kind": "text", "text": "[alone] (assumed tropical:)"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it,"}, {"kind": "text", "text": "(said of anything, [man or beast,])"}, {"kind": "italic_en", "text": "remitted, flagged,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became remiss, in an affair, lacking power,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ability, to perform,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "accomplish, it."}, {"kind": "text", "text": "(TA.) ―         -b9-"}, {"kind": "arabic", "text_bw": "Anksr naZaru AlT~arofi", "text_ar": "انكسر نَظَرُ الطَّرْفِ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The look of the eye,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "eyes, became languid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "languishing;"}, {"kind": "text", "text": "syn."}, {"kind": "arabic", "text_bw": "fatara", "text_ar": "فَتَرَ"}, {"kind": "text", "text": ". (IKtt, in TA, art."}, {"kind": "arabic", "text_bw": "ftr", "text_ar": "فتر"}, {"kind": "text", "text": ".) And"}, {"kind": "arabic", "text_bw": "Anksr Tarofuhu", "text_ar": "انكسر طَرْفُهُ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "His eye,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "eyes,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "sight, became languid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "languishing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "not sharp"}, {"kind": "text", "text": "]. (T, K, art."}, {"kind": "arabic", "text_bw": "ftr", "text_ar": "فتر"}, {"kind": "text", "text": ".) ―         -b10-  Also"}, {"kind": "arabic", "text_bw": "Anksr", "text_ar": "انكسر"}, {"kind": "text", "text": ", said of the coldness of water, [and of cold, absolutely, and of the heat of water,] and of heat, [absolutely,] and of anything, (TA,) for instance, of a price, and so ↓"}, {"kind": "arabic", "text_bw": "kasara", "text_ar": "كَسَرَ", "orth_type": "arrow"}, {"kind": "text", "text": ", (Fr. in TA, art."}, {"kind": "arabic", "text_bw": "qT", "text_ar": "قط"}, {"kind": "text", "text": ",) (assumed tropical:)"}, {"kind": "italic_en", "text": "It abated,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became allayed;"}, {"kind": "text", "text": "or, [said of heat,]"}, {"kind": "italic_en", "text": "it became languid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "faint."}, {"kind": "text", "text": "(TA.) ―         -b11-  Said of dough, (assumed tropical:)"}, {"kind": "italic_en", "text": "It became soft, and leavened,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "good, and fit to be baked."}, {"kind": "text", "text": "(TA.) ―         -b12-  [Said of a garment, or piece of cloth, and skin, (assumed tropical:)"}, {"ki