{"lemma":"حَيِّزِ","slug":"حَيِّزِ","root":"ح.#.ز","root_slug":"ح-_-ز","root_link":"/words/roots/ح-_-ز","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n9485","n9733"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%8A%D9%90%D9%91%D8%B2%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"scope, range, extent; space; compartment","examples":[{"text":"فِي حَيِّزِ ٱلتَّنْفِيذِ","english":"into effect"}]}]},"etymology":null,"ipa":["/ħaj.jiz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9485","headword_ar":"حَيِّزٌ","root":"Hwz","body":[{"kind":"text","text":", (S, Mgh, Msb,) of the measure"},{"kind":"arabic","text_bw":"fayoEilN","text_ar":"فَيْعِلٌ"},{"kind":"text","text":", (Mgh, Msb,) from"},{"kind":"arabic","text_bw":"AlHawozu","text_ar":"الحَوْزُ"},{"kind":"text","text":", (S, * Mgh,) as signifying “ the drawing, collecting, or gathering, together, ” (Mgh,) originally"},{"kind":"arabic","text_bw":"HayowizN","text_ar":"حَيْوِزٌ"},{"kind":"text","text":", (TA,) and also contracted into"},{"kind":"arabic","text_bw":"HayozN","text_ar":"حَيْزٌ"},{"kind":"text","text":", (S, Msb, TA,) like"},{"kind":"arabic","text_bw":"hay~inN","text_ar":"هَيِّنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"hayonN","text_ar":"هَيْنٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"lay~inN","text_ar":"لَيِّنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"layonN","text_ar":"لَيْنٌ"},{"kind":"text","text":"; (S, TA;) [The"},{"kind":"italic_en","text":"continent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"container,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receptacle,"},{"kind":"text","text":"of anything; like"},{"kind":"arabic","text_bw":"bayoDapN","text_ar":"بَيْضَةٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"HawozapN","text_ar":"حَوْزَةٌ","orth_type":"arrow"},{"kind":"text","text":", q. v.:]"},{"kind":"italic_en","text":"any place in which a thing is:"},{"kind":"text","text":"(Mgh:) in scholastic theology, the"},{"kind":"italic_en","text":"imaginary portion of space occupied by a thing having extent, as a body;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by a thing not having extent, as an indivisible atom:"},{"kind":"text","text":"in philosophy, the"},{"kind":"italic_en","text":"inner surface of a container, which is contiguous"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in every part"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the outer surface of the thing contained:"},{"kind":"text","text":"and [hence,]"},{"kind":"arabic","text_bw":"AlHay~izu AlTabiyEiY~u","text_ar":"الحَيِّزُ الطَبِيعِىُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the proper natural place of a thing;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that in which the nature of a thing requires it to be."},{"kind":"text","text":"(KT.) ―         -b2-"},{"kind":"italic_en","text":"A quarter, tract, region,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place, considered relatively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"as part of a whole;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion, of a place;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"naAHiyapN","text_ar":"نَاحِيَةٌ"},{"kind":"text","text":"; (S, Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"HawozapN","text_ar":"حَوْزَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, Msb, K:) so the authors on practical law mean by"},{"kind":"arabic","text_bw":"Hay~izN","text_ar":"حَيِّزٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"such,"},{"kind":"text","text":"for instance,"},{"kind":"italic_en","text":"as a room,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an apartment, of a house:"},{"kind":"text","text":"(Mgh:) pl."},{"kind":"arabic","text_bw":"A^aHoyaAzN","text_ar":"اَحْيَازٌ"},{"kind":"text","text":", (S, Msb, TA,) which is extr., (TA,) being from the contracted form ["},{"kind":"arabic","text_bw":"HayozN","text_ar":"حَيْزٌ"},{"kind":"text","text":"]: (Msb:) by rule it should be"},{"kind":"arabic","text_bw":"A^aHowaAzN","text_ar":"اَحْوَازٌ"},{"kind":"text","text":", (Az, Msb, TA,) like"},{"kind":"arabic","text_bw":"A^amowaAtN","text_ar":"اَمْوَاتٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"may~itN","text_ar":"مَيِّتٌ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"mayotN","text_ar":"مَيْتٌ"},{"kind":"text","text":"]: (Az, TA:) or by rule [if from the uncontracted form"},{"kind":"arabic","text_bw":"Hay~izN","text_ar":"حَيِّزٌ"},{"kind":"text","text":"] it should be"},{"kind":"arabic","text_bw":"HayaAy^izu","text_ar":"حَيَايِزُ"},{"kind":"text","text":", with hemz, accord. to Sb; or"},{"kind":"arabic","text_bw":"HayaAwizu","text_ar":"حَيَاوِزُ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":", accord. to Abu-l-Hasan. (TA.)"},{"kind":"arabic","text_bw":"Hay~izu Ald~aAri","text_ar":"حَيِّزُ الدَّارِ"},{"kind":"text","text":", (S, Msb, TA,) as also"},{"kind":"arabic","text_bw":"Ald~Ari","text_ar":"الدّارِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hawozu","text_ar":"حَوْزُ","orth_type":"arrow"},{"kind":"text","text":", (TA,) signifies"},{"kind":"italic_en","text":"What is annexed to the house,"},{"kind":"text","text":"(S, TA,) or"},{"kind":"italic_en","text":"appertains thereto,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"maraAfiq","text_ar":"مَرَافِق"},{"kind":"text","text":"(S, Msb, TA)"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"manaAfiE","text_ar":"مَنَافِع"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"nawaAHK","text_ar":"نَوَاحٍ"},{"kind":"text","text":"; (Msb;) [i. e.,"},{"kind":"italic_en","text":"of the conveniences thereof, such as the privy and the kitchen and the like, and other parts or apartments;"},{"kind":"text","text":"] such are termed collectively"},{"kind":"arabic","text_bw":"A^aHoyaAzu Ald~aAri","text_ar":"اَحْيَازُ الدَّارِ"},{"kind":"text","text":"; (Msb;) and each part or apartment ("},{"kind":"arabic","text_bw":"naAHiyap","text_ar":"نَاحِيَة"},{"kind":"text","text":"), by itself, is termed"},{"kind":"arabic","text_bw":"Hay~izN","text_ar":"حَيِّزٌ"},{"kind":"text","text":". (TA.) ―         -b3-  [Hence the saying,]"},{"kind":"arabic","text_bw":"A^anaA fiY Hay~izihi wakanafihi","text_ar":"اَنَا فِى حَيِّزِهِ وَكَنَفِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I am in his quarter and protection"},{"kind":"text","text":"]. (A, TA.) ―         -b4-  [And hence also the saying,]"},{"kind":"arabic","text_bw":"fiY Hay~izi Alt~awaAtiru","text_ar":"فِى حَيِّزِ التَّوَاتِرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"In the manner, and place, of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that kind of transmission which is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"AltwAtr","text_ar":"التواتر"},{"kind":"text","text":"[which is “ transmission by such a number of persons as cannot be supposed to have agreed to a falsehood: ” as explained in the Mz, 3rd"},{"kind":"arabic","text_bw":"nwE","text_ar":"نوع"},{"kind":"text","text":"]. (Mgh.) ―         -b5-  And"},{"kind":"arabic","text_bw":"SaAra fiY Hay~izihi","text_ar":"صَارَ فِى حَيِّزِهِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HawozapN","text_ar":"حَوْزَةٌ"},{"kind":"text","text":". ―         -b6-  [And"},{"kind":"arabic","text_bw":"EalaY Hay~izihi","text_ar":"عَلَى حَيِّزِهِ"},{"kind":"italic_en","text":"By himself"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"itself."},{"kind":"text","text":"]"}],"source_refs":["S","Mgh","Msb","TA","K","Az"]},{"entry_id":"n9733","headword_ar":"حَيِّزٌ","root":"Hyz","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HayozN","text_ar":"حَيْزٌ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Hwz","text_ar":"حوز"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}