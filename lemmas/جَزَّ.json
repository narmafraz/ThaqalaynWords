us":105,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n5651"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to shear, to prune, to cut down, to fleece"},{"pos":"verb","gloss":"to slash, to gash"},{"pos":"verb","gloss":"to mow; to churn up"},{"pos":"noun","gloss":"verbal noun of جَزَّ (jazza) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":["/d͡ʒaz.za/","/d͡ʒazz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5651","headword_ar":"جَزَّ","root":"jz","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"jaz~N","text_ar":"جَزٌّ"},{"kind":"text","text":", (S, Mgh, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"jaz~apN","text_ar":"جَزَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) [but the latter seems to be an inf. n. of un.,]"},{"kind":"italic_en","text":"He cut"},{"kind":"text","text":"(Mgh, Msb, K) wool, (IDrd, S, Mgh, Msb,) [see"},{"kind":"arabic","text_bw":"Halaqa","text_ar":"حَلَقَ"},{"kind":"text","text":",] and, as some say, other things, (Msb,) or a dense thing, (Mgh,) or hair, (A, K,) and dry herbage, (K,) and seed-produce, (A,) and wheat, (S,) and palm-trees, (S, ISd, A, Mgh,) meaning their fruit; (Mgh;) as also ↓"},{"kind":"arabic","text_bw":"Ajtz~","text_ar":"اجتزّ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"Al$~iyHa wagayorahu","text_ar":"الشِّيحَ وَغَيْرَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aijotazazotu","text_ar":"اِجْتَزَزْتُ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Aijodazazotuhu","text_ar":"اِجْدَزَزْتُهُ","orth_type":"arrow"},{"kind":"text","text":", in the sense of"},{"kind":"arabic","text_bw":"jazazotuhu","text_ar":"جَزَزْتُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I cut the sheeh,"},{"kind":"text","text":"a species of wormwood,"},{"kind":"italic_en","text":"&c."},{"kind":"text","text":"]. (S.) You say also,"},{"kind":"arabic","text_bw":"jazazotu Alkabo$a","text_ar":"جَزَزْتُ الكَبْشَ"},{"kind":"arabic","text_bw":"wAln~aEojapa","text_ar":"والنَّعْجَةَ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"I shore,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sheared, the ram and the ewe"},{"kind":"text","text":"]; but of the she-goat and he-goat you say,"},{"kind":"arabic","text_bw":"HalaqotuhumaA","text_ar":"حَلَقْتُهُمَا"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"jaz~a Aln~axolapa","text_ar":"جَزَّ النَّخْلَةَ"},{"kind":"text","text":", (Lh, A, Mgh,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jaz~N","text_ar":"جَزٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jazaAzN","text_ar":"جَزَازٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jizaAzN","text_ar":"جِزَازٌ"},{"kind":"text","text":", (Lh, TA,) [like"},{"kind":"arabic","text_bw":"ja*~a","text_ar":"جَذَّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jad~a","text_ar":"جَدَّ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He cut off the fruit of the palm-tree."},{"kind":"text","text":"(Mgh, TA.)       -A2-  See also 4, in four places."}],"source_refs":["S","A","Msb","K","Mgh","IDrd","ISd","Lh","TA"]}]}}