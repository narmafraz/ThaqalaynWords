{"lemma":"أَوْبَةٍ","slug":"أَوْبَةٍ","root":"#.#.ب","root_slug":"_-_-ب","root_link":"/words/roots/_-_-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["n1463"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%88%D9%92%D8%A8%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of آبَ (ʔāba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"quick walking"},{"pos":"noun","gloss":"return"},{"pos":"noun","gloss":"coming homeward"},{"pos":"noun","gloss":"set of friends"},{"pos":"noun","gloss":"tent"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1463","headword_ar":"اَوْبَةٌ","root":"Awb","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^ayobapN","text_ar":"اَيْبَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"Return;"},{"kind":"text","text":"(T, A, K;) as also ↓"},{"kind":"arabic","text_bw":"A_iyaAbapN","text_ar":"اـِيَابَةٌ","orth_type":"arrow"},{"kind":"text","text":", a subst. from"},{"kind":"arabic","text_bw":"A=ba","text_ar":"ا=بَ"},{"kind":"text","text":". (Msb.) You say,"},{"kind":"arabic","text_bw":"liyahoniy^oka A^awobapu AlgaAy^ibi","text_ar":"لِيَهْنِيْكَ اَوْبَةُ الغَايِبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May the return of the absent give thee joy"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"fulAnN sariyEu AlA^awobapi","text_ar":"فُلانٌ سَرِيعُ الاَوْبَةِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AlA^ayobapi","text_ar":"الاَيْبَةِ","orth_type":"arrow"},{"kind":"italic_en","text":"Such a one is quick in return."},{"kind":"text","text":"(A 'Obeyd, T, S. *) ―         -b2-"},{"kind":"italic_en","text":"Return from disobedience to obedience; repentance."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"Ayb","text_ar":"ايب"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"kalaAmN laA A^awobapa lahu","text_ar":"كَلَامٌ لَا اَوْبَةَ لَهُ"},{"kind":"italic_en","text":"Speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"language, without profit."},{"kind":"text","text":"(A.)       -A2-"},{"kind":"arabic","text_bw":"A^awobapN","text_ar":"اَوْبَةٌ"},{"kind":"text","text":"is also the sing. of"},{"kind":"arabic","text_bw":"A^awobaAtN","text_ar":"اَوْبَاتٌ"},{"kind":"text","text":", which signifies The"},{"kind":"italic_en","text":"legs"},{"kind":"text","text":"of a beast. (K, TA.)"}],"source_refs":[]}]},"classical_definitions":null}