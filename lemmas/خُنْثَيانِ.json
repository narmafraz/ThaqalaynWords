{"lemma":"خُنْثَيانِ","slug":"خُنْثَيانِ","root":"خ.ن.ث","root_slug":"خ-ن-ث","root_link":"/words/roots/خ-ن-ث","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n11575"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D9%86%D9%92%D8%AB%D9%8E%D9%8A%D8%A7%D9%86%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11575","headword_ar":"خُنْثَى","root":"xnv","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A hermaphrodite;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one who has what is proper to the male and what is proper to the female:"},{"kind":"text","text":"Kr makes it an epithet, and says"},{"kind":"arabic","text_bw":"rajulN","text_ar":"رَجُلٌ"},{"kind":"arabic","text_bw":"xunovaY","text_ar":"خُنْثَى"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"one who has what is proper to men and what is proper to women,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"together;"},{"kind":"text","text":"(S, K;)"},{"kind":"italic_en","text":"one who has, by creation, the anterior pudendum of a man and that of a woman:"},{"kind":"text","text":"(Msb:) in the language of the lawyers,"},{"kind":"italic_en","text":"one who has what are proper to both sexes;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who has neither that of a man nor that of a woman:"},{"kind":"text","text":"but some of them say that the former meaning is the proper one; and that he who has no external organ of generation is adjoined to the class of the"},{"kind":"arabic","text_bw":"xnvY","text_ar":"خنثى"},{"kind":"text","text":"as being subject to the same special laws: (MF, TA:) the pl. is"},{"kind":"arabic","text_bw":"xanaAvaY","text_ar":"خَنَاثَى"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"xinaAvN","text_ar":"خِنَاثٌ"},{"kind":"text","text":". (Msb, K.)       -A2-  Also The"},{"kind":"italic_en","text":"plant called"},{"kind":"arabic","text_bw":"barowaAqN","text_ar":"بَرْوَاقٌ"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"asphodel"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"brq","text_ar":"برق"},{"kind":"text","text":".)"}],"source_refs":["S","Mgh","K","Msb","MF","TA"]}]},"classical_definitions":null}