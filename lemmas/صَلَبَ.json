en":"m","num":"p"},{"role":"present_2mp","form":"تَصْلِبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْلِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْلِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْلِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْلِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْلِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْلِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْلِبُوا","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْلِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصْلِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْلِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَلَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَلَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":true,"lemma_key":"صَلَبَ","root":"صلب","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":15},"lanes":{"found":true,"entry_ids":["n24675","n24679","n24680","n24681","n24682","n24686"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%84%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to crucify"},{"pos":"verb","gloss":"to barbecue"},{"pos":"verb","gloss":"to enkindle, to set on fire, to ignite"},{"pos":"verb","gloss":"to crucify","examples":[{"text":"لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَافٍ ثُمَّ لَأُصَلِّبَنَّكُمْ أَجْمَعِينَ"}]},{"pos":"verb","gloss":"to make crossed, to cross"},{"pos":"verb","gloss":"to cross oneself, to make the sign of the cross"},{"pos":"noun","gloss":"crucifixion","tags":["uncountable"]},{"pos":"verb","gloss":"to be or become rigid, to be or become solid, to be or become stiff, to be or become unyielding, to be or become sturdy"},{"pos":"verb","gloss":"to stiffen, to harden, to make sturdy, to render tough"},{"pos":"verb","gloss":"to support, to prop"},{"pos":"adj","gloss":"firm, stiff, solid","examples":[{"text":"وَٱلشَّكْوَسُ قَالَ أَبُو ٱلْخَيْرِ وَغَيْرِهِ هُوَ ٱلْوَرْدُ ٱلْفَحْصِيُّ وَقِيلَ ٱلْبَرِيُّ وَهُوَ نَوْعَانِ أَحَدُهُمَا يُسَمَّى بِٱلْعَجَمِيَّةِ ٱلرَّحْبَلُ وَرَقُهُ فِي قَدْرِ وَرَقِ ٱلزَّيْتُونِ وَأَطْوَلُ وَأَعْرَضُ أََغْبَرُ أَحْرَشُ وَأَغْصَانُهُ خَشِنَةٌ صُلْبَةٌ إِلَى ٱلْبَيَاضِ مَا هِيَ تَطْلَعُ فِي زَمَنِ ٱلرَّبِيعِ نُوْرُهُ كَٱلْوَرْدِ حَمْرَاءُ فَائِتَةٌ وَفِي وَسَطِهَا صُفْرَةٌ وَهَذَا هُوَ ٱلْمُسَمَّى ٱلْوَرْدُ ٱلْفَحْصِيُّ وَيُقَالُ إِنَّ ٱلْوَرْدَ إِنْ رَكِبَ فِيهِ فَيَنْجِبُ وَٱلنَّوْعُ ٱلثَّانِي مِنَ ٱلشَّكْوَسِ وَرَقُهُ أَصْغَرُ مِنْ وَرَقِ ٱلْأَوَّلِ وَأَشَدُّ خُضْرَةً وَهًوَ أَحْرَشُ بَيْنَ ٱلْاِسْتِدَارِ وَٱلطُّولِ وَأَغْصَانِهِ إِلَى ٱلْحَمْرَاءِ مَا هِيَ تَطْلَعُ وَرْدًا أَبْيَضَا نَاصِعَةً فِي وَسَطِهَا وَكِلَاهُمَا لَاحِقٌ بِٱلْأَشْجَارِ.","english":"And the rockrose, say Abū al-Ḵayr and others, is the field rose, and also the land rose, it is said, and there are two kinds: One is called in Berber raḥbal and its leaves are of the dimensions of the leaves of the olive but longer and wider, more gray and rugged, and its branches are rough, stiff and lean into white, and in spring it blossoms in roses of a red hue you almost miss, and in their mid there is yellow and this is called field rose, and it is said that if a rose is grafted onto it it will prevail. The second kind of rockrose has smaller leaves than the first, of a more intense green, and it is more rugged around and along, and its branches lean into red and spawn white roses, vivid in the middle. And both liaise with trees."}]},{"pos":"noun","gloss":"backbone, the bone extending from the base of the neck to the coccyx","examples":[{"text":"فَلْيَنْظُرِ ٱلْإِنْسَانُ مِمَّ خُلِقَ خُلِقَ مِنْ مَاءٍ دَافِقٍ يَخْرُجُ مِنْ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَائِبِ","english":"So let man look around: what is it that he was made of? / He was made out of out-flowing water. / From between the spine and the breastbone, it gushes out."}]},{"pos":"noun","gloss":"loins"},{"pos":"noun","gloss":"steel"},{"pos":"noun","gloss":"plural of صَلِيب (ṣalīb, “hard, solid”)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"Also Aramaic / Hebrew צָלַב (ṣāláḇ), Ge'ez ጸለበ (ṣäläbä), but mostly within Arabic a denominal verb of صَلِيب (ṣalīb, “cross”), plausibly also interpreted after the native صَلَّبَ (ṣallaba, “to prop up, to support”).\n\nDerived from the verbal noun of صَلَبَ (ṣalaba)."},"ipa":["/sˤulb/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24675","headword_ar":"صَلُبَ","root":"Slb","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"SalaAbapN","text_ar":"صَلَابَةٌ"},{"kind":"text","text":"; (S, M, A, Msb, K, &c.;) and"},{"kind":"arabic","text_bw":"Saliba","text_ar":"صَلِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (IKtt, A, K;) and ↓"},{"kind":"arabic","text_bw":"Sl~b","text_ar":"صلّب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taSoliybN","text_ar":"تَصْلِيبٌ"},{"kind":"text","text":"; (K; [but this last, accord. to the TA, is trans. only;]) said of a thing, (S, Msb,) [and of a man,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, firm, rigid, stiff, tough, strong, robust, sturdy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hardy;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ai$otad~a","text_ar":"اِشْتَدَّ"},{"kind":"text","text":"; (S, * A, * Msb, K; *)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"laAna","text_ar":"لَانَ"},{"kind":"text","text":". (M, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Salubati AlA^aroDu muno*u A^aEowaAmK","text_ar":"صَلُبَتِ الاَرْضُ مُنْذُ اَعْوَامٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The land has been hard"},{"kind":"text","text":"by lying waste"},{"kind":"italic_en","text":"for years"},{"kind":"text","text":"]; said of land that has not been sown for a long time. (A, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Saluba EalaY AlmaAli","text_ar":"صَلُبَ عَلَى المَالِ"},{"kind":"text","text":", inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tenacious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious, of property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the property."},{"kind":"text","text":"(M, L.) ―         -b4-  [And"},{"kind":"arabic","text_bw":"Saluba Al$~araAbu","text_ar":"صَلُبَ الشَّرَابُ"},{"kind":"text","text":", inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"The wine became strong."},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Had~u","text_ar":"حَدُّ"},{"kind":"arabic","text_bw":"Al$~araAbi","text_ar":"الشَّرَابِ"},{"kind":"text","text":"is expl. in the S and L, in art."},{"kind":"arabic","text_bw":"Hd","text_ar":"حد"},{"kind":"text","text":", as meaning"},{"kind":"arabic","text_bw":"SalaAbatuhu","text_ar":"صَلَابَتُهُ"},{"kind":"text","text":".)]       -A2-"},{"kind":"arabic","text_bw":"Salaba AlEiZaAma","text_ar":"صَلَبَ العِظَامَ"},{"kind":"text","text":", (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"ASTlbhA","text_ar":"اصطلبها","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He cooked,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"collected and cooked,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"the bones,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"and extracted their grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"to make use of it as a seasoning:"},{"kind":"text","text":"(TA:) or ↓"},{"kind":"arabic","text_bw":"ASTlb","text_ar":"اصطلب","orth_type":"arrow"},{"kind":"text","text":"[alone]"},{"kind":"italic_en","text":"he extracted the grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter, of bones,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"he collected bones, and extracted their grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oily matter,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"to make use of it as a seasoning."},{"kind":"text","text":"(S, Msb.) ―         -b2-  And in like manner one says of one who roasts, or broils, or fries, flesh-meat and makes its grease to flow: (M:) i. e. one says,"},{"kind":"arabic","text_bw":"Salaba All~aHoma","text_ar":"صَلَبَ اللَّحْمَ"},{"kind":"text","text":", (M, * K, TA,) and ↓"},{"kind":"arabic","text_bw":"ASTlb","text_ar":"اصطلب","orth_type":"arrow"},{"kind":"text","text":"[alone], (M,)"},{"kind":"italic_en","text":"He roasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"broiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fried, the flesh-meat,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"and made its grease to flow."},{"kind":"text","text":"(M, TA.) ―         -b3-  And, (K,) as Sh says, (TA,),"},{"kind":"arabic","text_bw":"Salabahu","text_ar":"صَلَبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, burned him:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"arabic","text_bw":"Salabatohu Al$~amosu","text_ar":"صَلَبَتْهُ الشَّمْسُ"},{"kind":"italic_en","text":"The sun burned him"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"causing his sweat to flow"},{"kind":"text","text":"]. (TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Salabahu","text_ar":"صَلَبَهُ"},{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"SalobN","text_ar":"صَلْبٌ"},{"kind":"text","text":"; (S, M, Msb;) and ↓"},{"kind":"arabic","text_bw":"Sl~bhu","text_ar":"صلّبهُ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) inf. n."},{"kind":"arabic","text_bw":"taSoliybN","text_ar":"تَصْلِيبٌ"},{"kind":"text","text":", (K,) or the verb with teshdeed is said of a pl. number; (S, A;;) ["},{"kind":"italic_en","text":"He crucified him;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he put him to death in a certain well-known manner;"},{"kind":"text","text":"(M, L;)"},{"kind":"italic_en","text":"he made him to be"},{"kind":"arabic","text_bw":"maSoluwb","text_ar":"مَصْلُوب"},{"kind":"text","text":"; (K) namely, one who had slain another; (Msb;) or a thief: (A:) from"},{"kind":"arabic","text_bw":"Salaba AlEiZaAma","text_ar":"صَلَبَ العِظَامَ"},{"kind":"text","text":"; because the oily matter, and the ichor mixed with blood, of the person so put to death flows. (M.) ―         -b5-  [Hence]"},{"kind":"arabic","text_bw":"AlS~alobu","text_ar":"الصَّلْبُ"},{"kind":"text","text":"in prayer means"},{"kind":"italic_en","text":"The placing the hands upon the flanks, in standing, and separating the arms from the body:"},{"kind":"text","text":"a posture forbidden by the Prophet because resembling that of a man when he is crucified ("},{"kind":"arabic","text_bw":"A_i*aA Suliba","text_ar":"اـِذَا صُلِبَ"},{"kind":"text","text":"), the arms of the man in this case being extended upon the timber. (TA.) ―         -b6-  [Hence also,]"},{"kind":"arabic","text_bw":"Salaba Ald~alowa","text_ar":"صَلَبَ الدَّلْوَ"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"Sal~abahaA","text_ar":"صَلَّبَهَا","orth_type":"arrow"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He put upon the"},{"kind":"arabic","text_bw":"dlw","text_ar":"دلو"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"leathern"},{"kind":"page_break","n":1712},{"kind":"italic_en","text":"bucket"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"what are called"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaliybaAni","text_ar":"صَلِيبَانِ","orth_type":"arrow"},{"kind":"text","text":", (M, L, K,) which are"},{"kind":"italic_en","text":"two pieces of wood placed cross-wise"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to keep it from collapsing"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"like what are called the"},{"kind":"arabic","text_bw":"EaroquwataAni","text_ar":"عَرْقُوَتَانِ"},{"kind":"text","text":". (M, L.)       -A3-"},{"kind":"arabic","text_bw":"Salabato Ealayohi Hum~aAhu","text_ar":"صَلَبَتْ عَلَيْهِ حُمَّاهُ"},{"kind":"text","text":", (S, M, A, Msb, * K,) aor."},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"His fever was continual,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"and vehement:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"was of the kind termed"},{"kind":"arabic","text_bw":"SaAlib","text_ar":"صَالِب"},{"kind":"text","text":"[q. v.]. (M, TA.)"}],"source_refs":["S","Msb","M","K","TA","A","L"]},{"entry_id":"n24679","headword_ar":"صُلْبٌ","root":"Slb","body":[{"kind":"italic_en","text":"Hard, firm, rigid, stiff, tough, strong, robust, sturdy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hardy;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$adiydN","text_ar":"شَدِيدٌ"},{"kind":"text","text":"; (S, A, Msb, * K;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"lay~inN","text_ar":"لَيِّنٌ"},{"kind":"text","text":"; (M, TA;) as also ↓"},{"kind":"arabic","text_bw":"SaliybN","text_ar":"صَلِيبٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Sul~abN","text_ar":"صُلَّبٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K) and ↓"},{"kind":"arabic","text_bw":"SalabN","text_ar":"صَلَبٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) pl. of the first or second, [accord. to analogy of the latter, and also of the last,]"},{"kind":"arabic","text_bw":"SilaAbN","text_ar":"صِلَابٌ"},{"kind":"text","text":". (M, A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SalabN","text_ar":"صَلَبٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"makaAnN","text_ar":"مَكَانٌ"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SalabN","text_ar":"صَلَبٌ","orth_type":"arrow"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"A rugged, stony place:"},{"kind":"text","text":"(M, K; *) or"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a rugged, extending place,"},{"kind":"text","text":"of the earth or ground; and ↓"},{"kind":"arabic","text_bw":"SalabN","text_ar":"صَلَبٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"a hard part"},{"kind":"text","text":"of the earth or ground: (S:) or this last,"},{"kind":"italic_en","text":"a tract of rugged depressed land stretching along between two hills:"},{"kind":"text","text":"(Sh, TA:) or the"},{"kind":"italic_en","text":"acclivities of hills;"},{"kind":"text","text":"and its pl. is"},{"kind":"arabic","text_bw":"A^aSolaAbN","text_ar":"اَصْلَابٌ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"A^aSolaAbN","text_ar":"اَصْلَابٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"hard, extending,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tracts"},{"kind":"text","text":"of] ground: (As, TA:) or"},{"kind":"italic_en","text":"hard and elevated"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tracts"},{"kind":"text","text":"of] ground: (IAar, TA:) and"},{"kind":"arabic","text_bw":"makaAnN SulobN","text_ar":"مَكَانٌ صُلْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a rugged, hard place:"},{"kind":"text","text":"(Msb:) the pl. (of"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":", S) is"},{"kind":"arabic","text_bw":"SilabapN","text_ar":"صِلَبَةٌ"},{"kind":"text","text":". (S, M, K.) One says of land that has not been sown for a long time, ↓"},{"kind":"arabic","text_bw":"A_in~ahaA A^aSolaAbN","text_ar":"اـِنَّهَا اَصْلَابٌ","orth_type":"arrow"},{"kind":"arabic","text_bw":"muno*u A^aEowaAmK","text_ar":"مُنْذُ اَعْوَامٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily it has been hard"},{"kind":"text","text":"by lying waste"},{"kind":"italic_en","text":"for years"},{"kind":"text","text":"]. (A, TA.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"huwa Sulobu AlmaEaAjimi","text_ar":"هُوَ صُلْبُ المَعَاجِمِ"},{"kind":"text","text":"(tropical:)  [lit."},{"kind":"italic_en","text":"He is hard,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in respect of the places of biting;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"he is strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resisting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"indomitable, of spirit;"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eaziyzu Aln~afosi","text_ar":"عَزِيزُ النَّفْسِ"},{"kind":"text","text":";) thus"},{"kind":"arabic","text_bw":"Sulobu AlmaEojami","text_ar":"صُلْبُ المَعْجَمِ"},{"kind":"text","text":"is expl. in the S and K in art."},{"kind":"arabic","text_bw":"Ejm","text_ar":"عجم"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Sulobu AlEuwdi","text_ar":"صُلْبُ العُودِ"},{"kind":"text","text":"(tropical:) [which means the same]. (A, TA.) And"},{"kind":"arabic","text_bw":"Sulobu AlEaSaA","text_ar":"صُلْبُ العَصَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AlEaSaA","text_ar":"العَصَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Saliybu","text_ar":"صَلِيبُ","orth_type":"arrow"},{"kind":"text","text":", applied to a tender of camels; [lit."},{"kind":"italic_en","text":"Hard,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in respect of the staff;"},{"kind":"text","text":"] meaning (assumed tropical:)"},{"kind":"italic_en","text":"hard, severe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rigorous, in his treatment of the camels:"},{"kind":"text","text":"Er-Rá'ee says,"},{"kind":"quote","text":"AlEaSaA baAdiY AlEuruwqi taraY lahu ↓ \n      Saliyobu\n                      \n                     \n                        EalayohaA A_i*aA maA A^ajodaba Aln~aAsu A_iSobaEaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Hard,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"having the veins"},{"kind":"text","text":"of his limbs"},{"kind":"italic_en","text":"appearing: thou wilt see him to have a finger pointing at them,"},{"kind":"text","text":"i. e. his camels, because of their good condition,"},{"kind":"italic_en","text":"when the people are afflicted with drought"},{"kind":"text","text":"]. (M, TA. But in the S, in art."},{"kind":"arabic","text_bw":"SbE","text_ar":"صبع"},{"kind":"text","text":", we find"},{"kind":"arabic","text_bw":"DaEiyf","text_ar":"ضَعِيف"},{"kind":"text","text":"in this verse instead of"},{"kind":"arabic","text_bw":"Saliyb","text_ar":"صَلِيب"},{"kind":"text","text":".) ―         -b4-  And [in like manner]"},{"kind":"arabic","text_bw":"huwa SulobN fiY diynihi","text_ar":"هُوَ صُلْبٌ فِى دِينِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Sul~abN","text_ar":"صُلَّبٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He is hard, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong, in his religion"},{"kind":"text","text":"]. (A, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"jaroYN SulobN","text_ar":"جَرْىٌ صُلْبٌ"},{"kind":"text","text":"(Lth, TA) or ↓"},{"kind":"arabic","text_bw":"SaliybN","text_ar":"صَلِيبٌ","orth_type":"arrow"},{"kind":"text","text":"(M, L, TA) (tropical:)"},{"kind":"italic_en","text":"A hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement, running."},{"kind":"text","text":"(Lth, M, L, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"SahiylN SulobN","text_ar":"صَهِيلٌ صُلْبٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A vehement neighing."},{"kind":"text","text":"(Lth, TA.) And"},{"kind":"arabic","text_bw":"SawotN","text_ar":"صَوْتٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"SaliybN","text_ar":"صَلِيبٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A vehement sound"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cry"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voice."},{"kind":"text","text":"(M, L, TA.)       -A2-  Also, (S, M, A, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"SulubN","text_ar":"صُلُبٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb, TA) and ↓"},{"kind":"arabic","text_bw":"SalabN","text_ar":"صَلَبٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K) and ↓"},{"kind":"arabic","text_bw":"SaAlibN","text_ar":"صَالِبٌ","orth_type":"arrow"},{"kind":"text","text":", (IAth, L, K,) which last is rarely used, (IAth, TA,) and is said to occur only in one instance, in poetry, but another instance of it in poetry is cited, (TA,) The"},{"kind":"italic_en","text":"back-bone;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"bone extending from the"},{"kind":"arabic","text_bw":"kaAhil","text_ar":"كَاهِل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"base of the neck"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to the"},{"kind":"arabic","text_bw":"Eajob","text_ar":"عَجْب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rump bone"},{"kind":"text","text":"]; (M, A, K;) the"},{"kind":"italic_en","text":"bone upon which the neck is set, extending to the root of the tail"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a beast"},{"kind":"text","text":"], and"},{"kind":"italic_en","text":"in a man to the"},{"kind":"arabic","text_bw":"EuSoEuS","text_ar":"عُصْعُص"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"os coccygis"},{"kind":"text","text":"]: (Zj in his “ Khalk el-Insán: ”) or"},{"kind":"italic_en","text":"a portion of the back:"},{"kind":"text","text":"(S:) and"},{"kind":"italic_en","text":"any portion of the back containing vertebræ:"},{"kind":"text","text":"(S, Msb, TA:) [and particularly the"},{"kind":"italic_en","text":"lumbar portion;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"lions:"},{"kind":"text","text":"] and the"},{"kind":"italic_en","text":"back"},{"kind":"text","text":"[absolutely]; as is said in an explanation of a verse of 'Adee Ibn-Zeyd cited in what follows: (M, TA:) pl. [of mult.]"},{"kind":"arabic","text_bw":"SilabapN","text_ar":"صِلَبَةٌ"},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^aSolubN","text_ar":"اَصْلُبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aSolaAbN","text_ar":"اَصْلَابٌ"},{"kind":"text","text":", (M, K,) each of which two is used in poetry in a sing. sense, as though every part of the"},{"kind":"arabic","text_bw":"Sulob","text_ar":"صُلْب"},{"kind":"text","text":"were regarded as a"},{"kind":"arabic","text_bw":"Sulob","text_ar":"صُلْب"},{"kind":"text","text":"in itself, and"},{"kind":"arabic","text_bw":"SilobapN","text_ar":"صِلْبَةٌ"},{"kind":"text","text":", (M, TA,) of which last ISd says, [but this I do not find in the M,] I do not think it to be of established authority, unless it be a contraction of"},{"kind":"arabic","text_bw":"SilabapN","text_ar":"صِلَبَةٌ"},{"kind":"text","text":". (TA.) Lh mentions, as a phrase of the Arabs,"},{"kind":"arabic","text_bw":"h`w^ulaA='i A^abonaA='u Silabatihimo","text_ar":"هٰوُلَا=ءِ اَبْنَا=ءُ صِلَبَتِهِمْ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"These are the sons of their loins:"},{"kind":"text","text":"because the sperma of the man is held to proceed from the"},{"kind":"arabic","text_bw":"Sulob","text_ar":"صُلْب"},{"kind":"text","text":"of the man, as is said in the Ksh &c. in lxxxvi. 7]. (M. [See also a similar phrase in the Kr iv. 27.]) ―         -b2-  [Hence"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":"is used as signifying The"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"of a page, as distinguished from the"},{"kind":"arabic","text_bw":"haAmi$","text_ar":"هَامِش"},{"kind":"text","text":"(or margin): and in like manner, of other things.] ―         -b3-  [Hence, likewise,]"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":"signifies also"},{"kind":"arabic","text_bw":"HasabN","text_ar":"حَسَبٌ"},{"kind":"text","text":"[meaning (assumed tropical:)"},{"kind":"italic_en","text":"Rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"&c.]: (AA, S, M, K:) and"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strength."},{"kind":"text","text":"(M, K.) A poet says, (M,) namely, 'Adee Ibn-Zeyd, (S, TA,)"},{"kind":"quote","text":"A_ijola A^an~a A@ll~`ha qado faD~alakumo\n                      \n                     \n                        fawoqa maA A^aHokiY biSulobK waA_izaAro"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Because God hath made you to have excellence above what I can relate, in rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in power, and abstinence from unlawful things"},{"kind":"text","text":"]: (S, M, TA:) AA says that"},{"kind":"arabic","text_bw":"Sulob","text_ar":"صُلْب"},{"kind":"text","text":"here signifies"},{"kind":"arabic","text_bw":"Hasab","text_ar":"حَسَب"},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"A_izaAr","text_ar":"اـِزَار"},{"kind":"text","text":"here signifies"},{"kind":"arabic","text_bw":"EafaAf","text_ar":"عَفَاف"},{"kind":"text","text":": (S, M, TA:) but some expl."},{"kind":"arabic","text_bw":"Sulob","text_ar":"صُلْب"},{"kind":"text","text":"here by both"},{"kind":"arabic","text_bw":"Hasab","text_ar":"حَسَب"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quw~ap","text_ar":"قُوَّة"},{"kind":"text","text":": and some relate the latter hemistich otherwise, i. e."},{"kind":"quote","text":"fawoqa mano A^aHokaA^a SulobFA biA_izaAro"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"above such as binds"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"back with an izár."},{"kind":"text","text":"(M, TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a","text_ar":"اـِنَّ"},{"kind":"arabic","text_bw":"AlmugaAliba Suloba A@ll~`hi magoluwbN","text_ar":"المُغَالِبَ صُلْبَ ا@للّٰهِ مَغْلُوبٌ"},{"kind":"text","text":", meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"Verily he who strives to overcome"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the power of God"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is overcome"},{"kind":"text","text":"]. (TA.) ―         -b4-  Also"},{"kind":"italic_en","text":"Coitus"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"jimaAE","text_ar":"جِمَاع"},{"kind":"text","text":"): because the sperma [of the man] issues from the part so called. (TA.)"}],"source_refs":["S","M","A","K","Sh","TA","As","IAar","Msb","Lth","L","IAth","AA"]},{"entry_id":"n24680","headword_ar":"صَلَبٌ","root":"Slb","body":[{"kind":"text","text":", and its pl."},{"kind":"arabic","text_bw":"A^aSolaAbN","text_ar":"اَصْلَابٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":", former half, in six places:       -A2-  and see also"},{"kind":"arabic","text_bw":"SaliybN","text_ar":"صَلِيبٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]},{"entry_id":"n24681","headword_ar":"صُلَبٌ","root":"Slb","body":[{"kind":"italic_en","text":"A certain bird,"},{"kind":"text","text":"(O, K,)"},{"kind":"italic_en","text":"resembling the"},{"kind":"arabic","text_bw":"Saqor","text_ar":"صَقْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"hawk"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"but which does not prey, and which is vehement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"loud, in its cry."},{"kind":"text","text":"(O.)"}],"source_refs":["O","K"]},{"entry_id":"n24682","headword_ar":"صُلُبٌ","root":"Slb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":", near the middle."}],"source_refs":[]},{"entry_id":"n24686","headword_ar":"صُلَّبٌ","root":"Slb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SulobN","text_ar":"صُلْبٌ"},{"kind":"text","text":", former half, in two places. ―         -b2-  Also"},{"kind":"italic_en","text":"A hard stone,"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"hardest of stones."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"italic_en","text":"Whetstones;"},{"kind":"text","text":"(S, M, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"Sul~abapN","text_ar":"صُلَّبَةٌ","orth_type":"arrow"},{"kind":"text","text":"(TA) and ↓"},{"kind":"arabic","text_bw":"Sul~abiY~N","text_ar":"صُلَّبِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(M, K, TA;) and ↓"},{"kind":"arabic","text_bw":"Sul~abiy~apN","text_ar":"صُلَّبِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, M, K, TA:) [or"},{"kind":"italic_en","text":"a whetstone:"},{"kind":"text","text":"] or ["},{"kind":"italic_en","text":"a thing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"like a whetstone."},{"kind":"text","text":"(A.) ―         -b4-  See also"},{"kind":"arabic","text_bw":"Sul~abiY~N","text_ar":"صُلَّبِىٌّ"},{"kind":"text","text":"."}],"source_refs":["TA","S","M","K"]}]}}