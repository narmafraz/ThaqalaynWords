{"lemma":"مِخْلَبَيْ","slug":"مِخْلَبَيْ","root":"خ.ل.ب","root_slug":"خ-ل-ب","root_link":"/words/roots/خ-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n11216","n11218"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%90%D8%AE%D9%92%D9%84%D9%8E%D8%A8%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"claw, nail, talon"},{"pos":"noun","gloss":"a reaping-hook that has no teeth, an undentate scythe for cutting grass"},{"pos":"noun","gloss":"butcher's hook"},{"pos":"noun","gloss":"a sort of surgical instrument"},{"pos":"noun","gloss":"chelate"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11216","headword_ar":"مِخْلَبٌ","root":"xlb","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"talon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claw,"},{"kind":"text","text":"of a bird or beast of prey;"},{"kind":"italic_en","text":"a tearing talon"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"claw;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"same to the bird"},{"kind":"text","text":"(S, Mgh, Msb)"},{"kind":"italic_en","text":"and to the beast of prey"},{"kind":"text","text":"(S, Msb)"},{"kind":"italic_en","text":"as the"},{"kind":"arabic","text_bw":"Zufur","text_ar":"ظُفُر"},{"kind":"italic_en","text":"to man;"},{"kind":"text","text":"(S, Mgh, Msb;) because the bird [or beast] cuts and rends with it the skin: (Msb:) the"},{"kind":"arabic","text_bw":"Zufur","text_ar":"ظُفُر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"nail"},{"kind":"text","text":"] (A, K) of any beast or bird of prey: or it is of a bird of prey; and the"},{"kind":"arabic","text_bw":"Zfr","text_ar":"ظفر"},{"kind":"text","text":"is of a bird that does not prey: (K:) pl."},{"kind":"arabic","text_bw":"maxaAlibu","text_ar":"مَخَالِبُ"},{"kind":"text","text":". (A.) [See also"},{"kind":"arabic","text_bw":"xilobN","text_ar":"خِلْبٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"A^ano$aba fiyhi maxaAlibahu","text_ar":"اَنْشَبَ فِيهِ مَخَالِبَهُ"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"He clung,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caught, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(A.) ―         -b2-  Also"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"minojal","text_ar":"مِنْجَل"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"reaping-hook"},{"kind":"text","text":"] (S, Msb, K) in a general sense: or (TA)"},{"kind":"italic_en","text":"that has no teeth."},{"kind":"text","text":"(S, Msb, TA.)"}],"source_refs":["S","Mgh","Msb","A","K","TA"]},{"entry_id":"n11218","headword_ar":"مُخَلَّبٌ","root":"xlb","body":[{"kind":"text","text":", applied to a garment, or piece of cloth, (S, TA,) means"},{"kind":"arabic","text_bw":"kaviyru Alwa$oYi","text_ar":"كَثِيرُ الوَشْىِ"},{"kind":"text","text":", (S, K, TA,) i. e. ["},{"kind":"italic_en","text":"Much variegated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"figured;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"of many colours."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"xilobN","text_ar":"خِلْبٌ"},{"kind":"text","text":".]"}],"source_refs":["S","TA","K"]}]}}