"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُفَنِّدُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُفَنِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُفَنِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُفَنِّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُفَنِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُفَنِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُفَنِّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُفَنِّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُفَنِّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُفَنِّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُفَنِّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"فَنَّدْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَنَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُفَنِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُفَنِّد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n34640","n34645","n34646","n34647"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D9%86%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34640","headword_ar":"فَنِدَ","root":"fnd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"fanadN","text_ar":"فَنَدٌ"},{"kind":"text","text":"; (S, M, A, O, L, K, TA;) or"},{"kind":"arabic","text_bw":"fnd","text_ar":"فند"},{"kind":"text","text":", [perhaps"},{"kind":"arabic","text_bw":"fanada","text_ar":"فَنَدَ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"fanida","text_ar":"فَنِدَ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"funuwdN","text_ar":"فُنُودٌ"},{"kind":"text","text":"; (IKtt, TA;) and ↓"},{"kind":"arabic","text_bw":"Afnd","text_ar":"افند","orth_type":"arrow"},{"kind":"text","text":", (S, IKtt, L,) inf. n."},{"kind":"arabic","text_bw":"A_ifonaAdN","text_ar":"اـِفْنَادٌ"},{"kind":"text","text":"; (S, L, K;)"},{"kind":"italic_en","text":"He lied; uttered a falsehood; said what was untrue:"},{"kind":"text","text":"(S, M, IKtt, A, O, L, K:) this is [said to be] the primary signification. (L.) ↓"},{"kind":"arabic","text_bw":"qawolK A_ifonaAdK","text_ar":"قَوْلٍ اـِفْنَادٍ","orth_type":"arrow"},{"kind":"text","text":"is used by a poet for"},{"kind":"arabic","text_bw":"qawolK *iY A_ifonaAdK","text_ar":"قَوْلٍ ذِى اـِفْنَادٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A saying having,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"characterized by, lying,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falsehood"},{"kind":"text","text":"]. (M, L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"fanida","text_ar":"فَنِدَ"},{"kind":"text","text":". aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"fanadN","text_ar":"فَنَدٌ"},{"kind":"text","text":", (M, O, K,)"},{"kind":"italic_en","text":"He erred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committed a mistake"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mistakes,"},{"kind":"text","text":"(M, O, K, TK,)"},{"kind":"italic_en","text":"in extreme old age,"},{"kind":"text","text":"(O,) in speech, or in judgment, or opinion: (M, K, TK:) and ↓"},{"kind":"arabic","text_bw":"Afnd","text_ar":"افند","orth_type":"arrow"},{"kind":"italic_en","text":"he made many mistakes in his speech."},{"kind":"text","text":"(As, TA in art."},{"kind":"arabic","text_bw":"shb","text_ar":"سهب"},{"kind":"text","text":".) ―         -b3-  And"},{"kind":"arabic","text_bw":"fanida","text_ar":"فَنِدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (IKtt, TA, TK,) inf. n."},{"kind":"arabic","text_bw":"fanadN","text_ar":"فَنَدٌ"},{"kind":"text","text":"; (T, S, M, IKtt, A, O, L, K;) and ↓"},{"kind":"arabic","text_bw":"Afnd","text_ar":"افند","orth_type":"arrow"},{"kind":"text","text":"; (S, M, IKtt, L;)"},{"kind":"italic_en","text":"He became weak in judgment by reason of extreme old age"},{"kind":"text","text":"(S, IKtt, A, O, L;) or"},{"kind":"italic_en","text":"he became unsound in mind,"},{"kind":"text","text":"(M, L, K,) ["},{"kind":"italic_en","text":"in such a state that"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligence, was denied,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproved."},{"kind":"text","text":"(T, M, K, TK,"},{"kind":"arabic","text_bw":"Alfanadu","text_ar":"الفَنَدُ"},{"kind":"text","text":"being expl. in the T and M and K by"},{"kind":"arabic","text_bw":"A_inokaAru AlEaqoli","text_ar":"اـِنْكَارُ العَقْلِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fanada","text_ar":"فَنَدَ"},{"kind":"text","text":"in the TK by"},{"kind":"arabic","text_bw":"Ankr Eqlh","text_ar":"انكر عقله"},{"kind":"text","text":"[meaning"},{"kind":"arabic","text_bw":"A^unokira Eaqoluhu","text_ar":"اُنْكِرَ عَقْلُهُ"},{"kind":"text","text":"], and in like manner"},{"kind":"arabic","text_bw":"Afnd","text_ar":"افند"},{"kind":"text","text":"[of which see the part. n.,"},{"kind":"arabic","text_bw":"mufonidN","text_ar":"مُفْنِدٌ"},{"kind":"text","text":", below, as expl. in the A],)"},{"kind":"italic_en","text":"by reason of extreme old age,"},{"kind":"text","text":"(T, M, K, TK,) or"},{"kind":"italic_en","text":"disease;"},{"kind":"text","text":"(M, K, TK:) primarily thus restricted to the case of old age, but sometimes used without the being so restricted: (M:) and ↓"},{"kind":"arabic","text_bw":"Afnd","text_ar":"افند","orth_type":"arrow"},{"kind":"text","text":"is also expl. as signifying"},{"kind":"italic_en","text":"he became weak in intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"doted:"},{"kind":"text","text":"(IKtt, TA:) and as signifying"},{"kind":"italic_en","text":"he became extremely aged,"},{"kind":"text","text":"because he who has become so speaks perverted language; from the same verb as signifying"},{"kind":"italic_en","text":"he lied."},{"kind":"text","text":"(L,) ―         -b4-  [And"},{"kind":"arabic","text_bw":"fanida","text_ar":"فَنِدَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"fanadN","text_ar":"فَنَدٌ"},{"kind":"text","text":", app. signifies also"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, impotent:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unthankful for the favour of God:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"finodN","text_ar":"فِنْدٌ"},{"kind":"text","text":".]"}],"source_refs":["TK","S","IKtt","L","M","A","O","K","TA","T"]},{"entry_id":"n34645","headword_ar":"فَنْدٌ","root":"fnd","body":[{"kind":"text","text":": see the next paragraph, first sentence."}],"source_refs":[]},{"entry_id":"n34646","headword_ar":"فِنْدٌ","root":"fnd","body":[{"kind":"text","text":"(T, S, M, A, O, L, K) and ↓"},{"kind":"arabic","text_bw":"fanodN","text_ar":"فَنْدٌ","orth_type":"arrow"},{"kind":"text","text":"(Ibn- 'Abbád, O, K)"},{"kind":"italic_en","text":"A great mountain:"},{"kind":"text","text":"(IF, O, K:) or"},{"kind":"italic_en","text":"a mountain apart from others:"},{"kind":"text","text":"(Ibn-Abi-l- Hadeed, TA:) or"},{"kind":"italic_en","text":"a portion of a mountain,"},{"kind":"text","text":"(Ibn- 'Abbád, S, O, K,) or"},{"kind":"italic_en","text":"a great portion thereof,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"having tallness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"length,"},{"kind":"text","text":"[app. the former,] (Ibn-'Abbád, S, O, K, TA,) and some add,"},{"kind":"italic_en","text":"with slenderness:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"round and tall and slender head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peak,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$imoraAx","text_ar":"شِمْرَاخ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of a mountain:"},{"kind":"text","text":"(T, A:) or"},{"kind":"italic_en","text":"a great peak"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"head"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$mrAx","text_ar":"شمراخ"},{"kind":"text","text":", T, L, or"},{"kind":"arabic","text_bw":"raA^os","text_ar":"رَاْس"},{"kind":"text","text":", M, L,)"},{"kind":"italic_en","text":"of a mountain:"},{"kind":"text","text":"(T, M, L:) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"rukon","text_ar":"رُكْن"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an outward part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the strongest side"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outward part,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a mountain:"},{"kind":"text","text":"(L:) pl."},{"kind":"arabic","text_bw":"A^afonaAdN","text_ar":"اَفْنَادٌ"},{"kind":"text","text":". (M, L.) One says of a bulky and heavy man,"},{"kind":"arabic","text_bw":"kaA^an~ahu finodN","text_ar":"كَاَنَّهُ فِنْدٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"As though he were a head,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"peak,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"$imoraAx","text_ar":"شِمْرَاخ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of a mountain."},{"kind":"text","text":"(A.) ―         -b2-  And the former ("},{"kind":"arabic","text_bw":"finodN","text_ar":"فِنْدٌ"},{"kind":"text","text":") is the sing. of"},{"kind":"arabic","text_bw":"A^afonaAd","text_ar":"اَفْنَاد"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"A^afonaAdu All~ayoli","text_ar":"اَفْنَادُ اللَّيْلِ"},{"kind":"text","text":", (T,) which means"},{"kind":"italic_en","text":"The component parts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portions, of the night."},{"kind":"text","text":"(T, O, K, TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A congregated party"},{"kind":"text","text":"(T, O, K, TA.)"},{"kind":"italic_en","text":"of men."},{"kind":"text","text":"(T, O.) One says,"},{"kind":"arabic","text_bw":"humo finodN EalaY HidapK","text_ar":"هُمْ فِنْدٌ عَلَى حِدَةٍ"},{"kind":"italic_en","text":"They are a party by itself."},{"kind":"text","text":"(T, TA.) And it is said in a trad., (T.) respecting the Prophet, (T, O, K,) that, when he died, (O.)"},{"kind":"arabic","text_bw":"Sal~aY Aln~aAsu Ealayohi A^afonaAdFA A^afonaAdFA","text_ar":"صَلَّى النَّاسُ عَلَيْهِ اَفْنَادًا اَفْنَادًا"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"The people prayed for him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"invoked blessing upon him,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one by one, without an Imám;"},{"kind":"text","text":"(Th, T, O, K;) or"},{"kind":"italic_en","text":"companies after companies:"},{"kind":"text","text":"(O, K:) and they were computed to be thirty thousand, with sixty thousand angels; two angels to every one (T, O, K) of the believers. (T, O.) And the Prophet"},{"kind":"page_break","n":2449},{"kind":"text","text":"said, (T, O, K,) after announcing that he would be among the first that should die, (T, O,)"},{"kind":"arabic","text_bw":"tat~abiEuwniY A^afonaAdFA A^afonaAdFA yuholiku baEoDukumo baEoDFA","text_ar":"تَتَّبِعُونِى اَفْنَادًا اَفْنَادًا يُهْلِكُ بَعْضُكُمْ بَعْضًا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"Ye will follow me"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in scattered companies, company after company;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"killing one another;"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^afonaAdFA","text_ar":"اَفْنَادًا"},{"kind":"text","text":"being pl. of"},{"kind":"arabic","text_bw":"finod","text_ar":"فِنْد"},{"kind":"text","text":"; (Nh, TA;) and in like manner is expl. a similar phrase in a trad. of 'Áïsheh: (T, TA:) or the former means ↓"},{"kind":"arabic","text_bw":"*awiY fanadK","text_ar":"ذَوِى فَنَدٍ","orth_type":"arrow"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"impotent;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unthankful;"},{"kind":"text","text":"lit]"},{"kind":"italic_en","text":"having impotence;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"unthankfulness for"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God's"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"favour."},{"kind":"text","text":"(O, K, TA.) ―         -b4-  And"},{"kind":"italic_en","text":"A sort,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"species:"},{"kind":"text","text":"(K, TA:) pl."},{"kind":"arabic","text_bw":"A^afonaAdN","text_ar":"اَفْنَادٌ"},{"kind":"text","text":": one says,"},{"kind":"arabic","text_bw":"jaAw^uwA A^afonaAdFA","text_ar":"جَاوُوا اَفْنَادًا"},{"kind":"italic_en","text":"They came being diverse sorts."},{"kind":"text","text":"(TA.) ―         -b5-  And"},{"kind":"italic_en","text":"A branch of a tree."},{"kind":"text","text":"(T, O, K. *) ―         -b6-  And"},{"kind":"italic_en","text":"Land upon which rain has not fallen;"},{"kind":"text","text":"(T, O, K;) also termed ↓"},{"kind":"arabic","text_bw":"findyp","text_ar":"فِندية","orth_type":"arrow"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"finodiy~apN","text_ar":"فِنْدِيَّةٌ"},{"kind":"text","text":"]. (T.)"}],"source_refs":["T","S","M","A","O","L","K","IF","TA"]},{"entry_id":"n34647","headword_ar":"فَنَدٌ","root":"fnd","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"fanida","text_ar":"فَنِدَ"},{"kind":"text","text":", q. v.: as a subst.,]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"fuHo$N","text_ar":"فُحْشٌ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"Exorbitance in speech"},{"kind":"text","text":"]; and"},{"kind":"italic_en","text":"error in judgment:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^afonaAdN","text_ar":"اَفْنَادٌ"},{"kind":"text","text":". (Ham p. 112.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"finodN","text_ar":"فِنْدٌ"},{"kind":"text","text":", near the end."}],"source_refs":[]}]},"classical_definitions":null}