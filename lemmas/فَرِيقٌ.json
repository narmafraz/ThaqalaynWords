t", "text": "]"}, {"kind": "italic_en", "text": "than the outgoer,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "outrunner, of the horses."}, {"kind": "text", "text": "(TA.) ―         -b3-"}, {"kind": "arabic", "text_bw": "niy~apN", "text_ar": "نِيَّةٌ"}, {"kind": "arabic", "text_bw": "farayqN", "text_ar": "فَرَيقٌ"}, {"kind": "text", "text": "means"}, {"kind": "arabic", "text_bw": "mufar~iqN", "text_ar": "مُفَرِّقٌ"}, {"kind": "text", "text": "[i. e."}, {"kind": "italic_en", "text": "A place to which one purposes journeying that separates widely"}, {"kind": "text", "text": "]: a poet says,"}, {"kind": "quote", "text": "A^aHaq~N A^an~a jiyoratanaA A@sotaqal~uwA\n                      \n                     \n                        faniy~atunaA waniy~atuhumo fariyqu"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Is it true that our neighbours have gone away, so that the place to which we purpose journeying and the place to which they purpose journeying are such as separate widely"}, {"kind": "text", "text": "]: he says"}, {"kind": "arabic", "text_bw": "fariyq", "text_ar": "فَرِيق"}, {"kind": "text", "text": "in like manner as one applies [the epithet]"}, {"kind": "arabic", "text_bw": "SadiyqN", "text_ar": "صَدِيقٌ"}, {"kind": "text", "text": "to a company of men. (Sb, TA.)       -A2-  Also A palm-tree ("}, {"kind": "arabic", "text_bw": "naxolapN", "text_ar": "نَخْلَةٌ"}, {"kind": "text", "text": ")"}, {"kind": "italic_en", "text": "in which is"}, {"kind": "text", "text": "[app. meaning"}, {"kind": "italic_en", "text": "out of which grows"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "another."}, {"kind": "text", "text": "(AA, AHn, O, TA.)"}], "source_refs": ["S", "Msb", "K", "TA", "CK", "MF"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}