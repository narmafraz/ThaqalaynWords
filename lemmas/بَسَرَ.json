{"lemma":"بَسَرَ","slug":"بَسَرَ","root":"ب.س.ر","root_slug":"ب-س-ر","root_link":"/words/roots/ب-س-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَسَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَسَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَسَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَسَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَسَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَسَرَ","in_corpus":true,"count":13,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَسَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَسَرا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَسَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَسَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَسَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْسُر","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْسُرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْسُرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْسُرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْسُرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْسُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْسُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْسُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْسُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْسُر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْسُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْسُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْسُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْسُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْسُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْسُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْسُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَسَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَسَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْسُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْسُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":15,"cross_references":{"qac":{"found":true,"lemma_key":"بَسَرَ","root":"بسر","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":6},"lanes":{"found":true,"entry_ids":["n2512"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B3%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to scowl, to frown, to glower, to grimace"},{"pos":"verb","gloss":"to look sullen, to look grim, to become surly, to look sulky, to look gloomy, to look glum"},{"pos":"noun","gloss":"verbal noun of بَسَرَ (basara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to take premature action, to begin too early with (something), to begin prematurely"},{"pos":"noun","gloss":"verbal noun of بَسَرَ (basara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"unripe dates","tags":["collective"],"examples":[{"text":"أما العليق فمعروف وأما الورد الجبلي وورد الكلب وهو المعروف عند أهل الطب بالنسرين قال أبو حنيفة الورد الجبلي يشبه الورد ويشبه ذلك بعض سنة العليق وثمره شبيه العنب الدليك وهو أحمر يشبه البسر إلا أن طرفه محدود وفي داخله شبه الصوف ونواره نوار الورد أبيض يشوبه حمرة","english":"In what concerns the bramble, it is well known, and in what concerns the mountain-rose and the dog-rose, it is well-known with the physicians as nisrīn; Abū Ḥanīfa said the mountain-rose resembles the rose and this resembles a bit the image of the bramble, and the fruit is similar to the dust-vine, it is red and resembles the unripe date, except that its tip is pointed, and in its inner there is a kind of wool, and its blossom is a white rose blossom with an admixture of red."}]}]},"etymology":{"source":"wiktextract","text":"Compare for the “unripe date” meaning Classical Syriac ܒܣܪܐ (*busrā, “unripe grape”), Jewish Babylonian Aramaic בֻּסְרָא (busrā), בּוּסְרָא (busrā, “unripe grape”), Hebrew בֹּסֶר (boser, “unripe grape”), Harsusi béser (“unripe dates”), Soqotri bišreh (“dwarf palm”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2512","headword_ar":"بَسَرَ","root":"bsr","body":[{"kind":"italic_en","text":"He took"},{"kind":"text","text":"anything"},{"kind":"italic_en","text":"when it was fresh, juicy, moist,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not flaccid;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"text","text":"[which is more commonly used]. (M, K, * TA.) [Hence,]"},{"kind":"arabic","text_bw":"basarobu Aln~abaAta","text_ar":"بَسَرْبُ النَّبَاتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"basorN","text_ar":"بَسْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I pastured"},{"kind":"text","text":"["},{"kind":"italic_en","text":"beasts"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon the herbage when it was fresh and juicy, I being the first to do so."},{"kind":"text","text":"(TA.) ―         -b2-  Also, (K,) aor. as above, (TA,) and so the inf. n., (M,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aEojala","text_ar":"اَعْجَلَ"},{"kind":"text","text":"[as meaning (assumed tropical:)"},{"kind":"italic_en","text":"He was quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beforehand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"before the proper time, with"},{"kind":"text","text":"a person or thing, or"},{"kind":"italic_en","text":"in doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"a thing]. (M, K.) [Hence,]"},{"kind":"arabic","text_bw":"basara Aln~aAqapa","text_ar":"بَسَرَ النَّاقَةَ"},{"kind":"text","text":", (As, S, M, K,) aor. and inf. n. as above; (M;) and ↓"},{"kind":"arabic","text_bw":"AbtsrhA","text_ar":"ابتسرها","orth_type":"arrow"},{"kind":"text","text":", (S, A,) and ↓"},{"kind":"arabic","text_bw":"tbs~rhA","text_ar":"تبسّرها","orth_type":"arrow"},{"kind":"text","text":"; (T;) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(the stallion)"},{"kind":"italic_en","text":"covered the she-camel without her desiring it:"},{"kind":"text","text":"(As, S, A:) or"},{"kind":"italic_en","text":"before she desired it."},{"kind":"text","text":"(M, K.) And in like manner,"},{"kind":"arabic","text_bw":"basara","text_ar":"بَسَرَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tbs~r","text_ar":"تبسّر","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a stallion)"},{"kind":"italic_en","text":"covered"},{"kind":"text","text":"a mare"},{"kind":"italic_en","text":"when she had only begun to feel the excitement of desire."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"arabic","text_bw":"AljaAriyapa","text_ar":"الجَارِيَةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He deflowered the girl before she had attained to puberty."},{"kind":"text","text":"(A, and Msb in art."},{"kind":"arabic","text_bw":"qD","text_ar":"قض"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"basara","text_ar":"بَسَرَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He fecundated"},{"kind":"text","text":"a palm-tree"},{"kind":"italic_en","text":"before the proper time for doing so."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"basara Als~iqaA='a","text_ar":"بَسَرَ السِّقَا=ءَ"},{"kind":"text","text":", (K,) inf. n. as above, (S,) (assumed tropical:)"},{"kind":"italic_en","text":"He drank the milk of the skin,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"gave it to be drunk,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"before it had become thick, and fit for churning."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"basara","text_ar":"بَسَرَ"},{"kind":"text","text":", (M, K,) aor. as above, (M, A,) and so the inf. n., (S, M,) (tropical:)"},{"kind":"italic_en","text":"He broke"},{"kind":"text","text":"a pustule: (A:) or"},{"kind":"italic_en","text":"he squeezed"},{"kind":"text","text":"a pustule, or a boil,"},{"kind":"italic_en","text":"before it was ripe:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he laid it open by peeling off its crust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab, before it was ripe;"},{"kind":"text","text":"(S, M, K;) as also ↓"},{"kind":"arabic","text_bw":"Absr","text_ar":"ابسر","orth_type":"arrow"},{"kind":"text","text":". (K.) And, inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He dug rivers when water was scarce:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought for,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, water"},{"kind":"text","text":"["},{"kind":"italic_en","text":"when it was scarce"},{"kind":"text","text":"]: and so, accord. to Az, ↓"},{"kind":"arabic","text_bw":"tbs~r","text_ar":"تبسّر","orth_type":"arrow"},{"kind":"text","text":". (L. [But for"},{"kind":"arabic","text_bw":"A*A ErA AlmA' Aw TAbh","text_ar":"اذا عرا الماء او طابه"},{"kind":"text","text":", as part of the explanation, I read"},{"kind":"arabic","text_bw":"A_i*aA Eaz~a AlmaA'u A^awo","text_ar":"اـِذَا عَزَّ المَاءُ اَوْ"},{"kind":"arabic","text_bw":"Talabahu","text_ar":"طَلَبَهُ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"basara Aln~ahora","text_ar":"بَسَرَ النَّهْرَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He dug a well in"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the bed of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the river, it being dry."},{"kind":"text","text":"(L. [But here, for"},{"kind":"arabic","text_bw":"w hw SAf","text_ar":"و هو صاف"},{"kind":"text","text":", I read"},{"kind":"arabic","text_bw":"w hw jaAf~N","text_ar":"و هو جَافٌّ"},{"kind":"text","text":".]) Also"},{"kind":"arabic","text_bw":"basara","text_ar":"بَسَرَ"},{"kind":"text","text":", (S, M, K,) aor. as above, (M,) and inf. n. as above (S, M) and"},{"kind":"arabic","text_bw":"bisaArN","text_ar":"بِسَارٌ"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"text","text":"(M, A, K) and ↓"},{"kind":"arabic","text_bw":"tbs~r","text_ar":"تبسّر","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Absr","text_ar":"ابسر","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) (tropical:)"},{"kind":"italic_en","text":"He sought, sought for"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, demanded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desired,"},{"kind":"text","text":"a thing that he wanted, or needed,"},{"kind":"italic_en","text":"in an improper time:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"in an improper place:"},{"kind":"text","text":"(S, M:) or"},{"kind":"italic_en","text":"in an improper manner:"},{"kind":"text","text":"(Jm:) or"},{"kind":"italic_en","text":"before its time."},{"kind":"text","text":"(A.) And the first of these verbs, (tropical:)"},{"kind":"italic_en","text":"He required"},{"kind":"text","text":"a debt"},{"kind":"italic_en","text":"to be paid before the time when it was due."},{"kind":"text","text":"(K, TA.) And (tropical:)"},{"kind":"italic_en","text":"He required"},{"kind":"text","text":"his debtor"},{"kind":"italic_en","text":"to pay a debt before the time when it was due:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"basara Aln~aAqapa","text_ar":"بَسَرَ النَّاقَةَ"},{"kind":"text","text":", explained above. (Sh, TA.) ―         -b3-  Also, inf. n."},{"kind":"arabic","text_bw":"basorN","text_ar":"بَسْرٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He began"},{"kind":"text","text":"a thing; and so ↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"basara bihi","text_ar":"بَسَرَ بِهِ"},{"kind":"text","text":"(TK) and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Abtsr","text_ar":"ابتسر","orth_type":"arrow"},{"kind":"text","text":"(TA, TK) (assumed tropical:)"},{"kind":"italic_en","text":"He began with it."},{"kind":"text","text":"(TA, TK.)       -A2-  Also, aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"basorN","text_ar":"بَسْرٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He mixed"},{"kind":"arabic","text_bw":"busor","text_ar":"بُسْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fullgrown unripe dates"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with others, in beverage of the kind called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":": the doing of which is forbidden in a trad.: (S:) or"},{"kind":"italic_en","text":"he mixed"},{"kind":"arabic","text_bw":"busor","text_ar":"بُسْر"},{"kind":"italic_en","text":"with fresh ripe dates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with dry dates, and made with them both together that kind of beverage."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"basara tamorFA","text_ar":"بَسَرَ تَمْرًا"},{"kind":"text","text":", (M, K,) aor. and inf. n. as above; and ↓"},{"kind":"arabic","text_bw":"bs~rhu","text_ar":"بسّرهُ","orth_type":"arrow"},{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"Absrhu","text_ar":"ابسرهُ","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He made, of dry dates, that kind of beverage, and mixed"},{"kind":"arabic","text_bw":"busor","text_ar":"بُسْر"},{"kind":"italic_en","text":"with it."},{"kind":"text","text":"(M, K.)       -A3-  Also, (M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"basorN","text_ar":"بَسْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"busuwrN","text_ar":"بُسُورٌ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"He frowned; contracted his face;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grinned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"displayed his teeth, frowning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contracting his face,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"looking sternly, austerely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"morosely;"},{"kind":"text","text":"(M, K;) as also"},{"kind":"arabic","text_bw":"basara wajohahu","text_ar":"بَسَرَ وَجْهَهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"busuwzN","text_ar":"بُسُوزٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"he did so excessively:"},{"kind":"text","text":"(Jel in lxxiv. 22:) or"},{"kind":"italic_en","text":"he looked with intense dislike"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","M","As","S","A","Jm","TK"]}]}}