%92%D9%83%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16453","headword_ar":"اركب","root":"rkb","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a colt)"},{"kind":"italic_en","text":"became fit for being ridden; attained to the fit time for being ridden."},{"kind":"text","text":"(S, Msb, K.) [See also"},{"kind":"arabic","text_bw":"murokibN","text_ar":"مُرْكِبٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"Arkbhu","text_ar":"اركبهُ"},{"kind":"italic_en","text":"He gave him, appointed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assigned him, an"},{"kind":"page_break","n":1143},{"kind":"italic_en","text":"animal on which to ride."},{"kind":"text","text":"(S.) [See also 2.] ―         -b2-"},{"kind":"arabic","text_bw":"A^arokabaniY xalofahu","text_ar":"اَرْكَبَنِى خَلْفَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He mounted me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made me to ride, behind him"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^arokabaniY marokabFA faArihFA","text_ar":"اَرْكَبَنِى مَرْكَبًا فَارِهًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He mounted me on a quick, brisk, sharp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong, beast"},{"kind":"text","text":"]. (A.) ―         -b3-  [Hence,"},{"kind":"arabic","text_bw":"Arkbhu A^amorFA","text_ar":"اركبهُ اَمْرًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made him to venture upon, embark in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"undertake, an affair."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"Arkbhu *anobFA","text_ar":"اركبهُ ذَنْبًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made him to commit a sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crime,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"]"}],"source_refs":[]},{"entry_id":"n16478","headword_ar":"اَرْكَبُ","root":"rkb","body":[{"kind":"italic_en","text":"Large in the"},{"kind":"arabic","text_bw":"rukobap","text_ar":"رُكْبَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"knee"},{"kind":"text","text":"]. (S, K.) ―         -b2-  A camel"},{"kind":"italic_en","text":"having one of his knees larger than the other."},{"kind":"text","text":"(S, K.)"}],"source_refs":[]}]},"classical_definitions":null}