"headword_ar":"خَلَالٌ","root":"xl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Dates in the state in which they are termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"balaHN","text_ar":"بَلَحٌ"},{"kind":"text","text":", (JK, T, S, K,) in the dial. of the people of El-Basrah; (T, TA;) i. e."},{"kind":"italic_en","text":"green dates:"},{"kind":"text","text":"(JK:) [but see"},{"kind":"arabic","text_bw":"balaHN","text_ar":"بَلَحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"busorN","text_ar":"بُسْرٌ"},{"kind":"text","text":":] n. un. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (JK, TA.)       -A2-"},{"kind":"arabic","text_bw":"huwa xalaAlahumo","text_ar":"هُوَ خَلَالَهُمْ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xalalN","text_ar":"خَلَلٌ"},{"kind":"text","text":"."}],"source_refs":["JK","T","S","K"]},{"entry_id":"n11177","headword_ar":"خُلَالٌ","root":"xl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xulaAlapN","text_ar":"خُلَالَةٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"An accident that happens in anything sweet so as to change its flavour to acidity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sourness."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n11178","headword_ar":"خِلَالٌ","root":"xl","body":[{"kind":"italic_en","text":"A thing with which one perforates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transpierces, a thing,"},{"kind":"text","text":"(JK, K,) either"},{"kind":"italic_en","text":"of iron"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of wood:"},{"kind":"text","text":"(JK:) pl."},{"kind":"arabic","text_bw":"A^axil~apN","text_ar":"اَخِلَّةٌ"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"italic_en","text":"A wooden thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pin"},{"kind":"text","text":"] (S, Msb,)"},{"kind":"italic_en","text":"with which one pins a garment,"},{"kind":"text","text":"(T, S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"conjoining its two edges:"},{"kind":"text","text":"(Mgh, Msb:) pl. as above: (S, Msb:) which also signifies the"},{"kind":"italic_en","text":"small pieces of wood with which one pins together the edges of the oblong pieces of cloth of a tent."},{"kind":"text","text":"(TA.) ―         -b3-  ["},{"kind":"italic_en","text":"A skewer for flesh-meat."},{"kind":"text","text":"] ―         -b4-"},{"kind":"italic_en","text":"A wooden pin which is inserted into the tongue of a young camel, in order that he may not such:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"which is fixed above the nose of a young camel, for that purpose."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"lhj","text_ar":"لهج"},{"kind":"text","text":".) ―         -b5-  ["},{"kind":"italic_en","text":"A toothpick;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a thing"},{"kind":"text","text":"("},{"kind":"italic_en","text":"of wood,"},{"kind":"text","text":"S, Msb)"},{"kind":"italic_en","text":"with which one extracts the remains of food between his teeth;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"xilaAlapN","text_ar":"خِلَالَةٌ","orth_type":"arrow"},{"kind":"text","text":". (Har p. 101.) ―         -b6-  ["},{"kind":"italic_en","text":"A long thorn or prickle:"},{"kind":"text","text":"such being often used as a pin and as a toothpick.]       -A2-  See also"},{"kind":"arabic","text_bw":"xulaAlapN","text_ar":"خُلَالَةٌ"},{"kind":"text","text":".       -A3-  And see"},{"kind":"arabic","text_bw":"xalalN","text_ar":"خَلَلٌ"},{"kind":"text","text":", in six places."}],"source_refs":["JK","K","S","Msb","T","Mgh"]},{"entry_id":"n11184","headword_ar":"خَلَّالٌ","root":"xl","body":[{"kind":"italic_en","text":"A seller of vinegar."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":[]}]}}