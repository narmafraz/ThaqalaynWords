{"lemma":"وَغَرِ","slug":"وَغَرِ","root":"#.غ.ر","root_slug":"_-غ-ر","root_link":"/words/roots/_-غ-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":6},"lanes":{"found":true,"entry_ids":["","n42147","n42148"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%BA%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become enraged, to become angry, to be filled with malice"},{"pos":"verb","gloss":"to become excessively hot"},{"pos":"noun","gloss":"verbal noun of وَغَرَ (waḡara)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"malice"},{"pos":"noun","gloss":"hate"},{"pos":"noun","gloss":"enmity"}]},"etymology":null,"ipa":["/wa.ɣa.ra/","/waɣr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42147","headword_ar":"وَغْرٌ","root":"wgr","body":[{"kind":"italic_en","text":"Rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite, and enmity; and a burning with wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage;"},{"kind":"text","text":"(S, A, K;) as also ↓"},{"kind":"arabic","text_bw":"wagarN","text_ar":"وَغَرٌ","orth_type":"arrow"},{"kind":"text","text":"; (A, K;) or the latter is an inf. n., (S, TA,) but the former is a simple subst.: (TA:) or the"},{"kind":"italic_en","text":"state of being filled with wrath,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rage:"},{"kind":"text","text":"(Msb:) from"},{"kind":"arabic","text_bw":"wagorapN","text_ar":"وَغْرَةٌ"},{"kind":"text","text":", explained below. (S.) You say,"},{"kind":"arabic","text_bw":"fiY Sadorihi EalaY~a wagorN","text_ar":"فِى صَدْرِهِ عَلَىَّ وَغْرٌ"},{"kind":"italic_en","text":"In his bosom is rancour,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"against me."},{"kind":"text","text":"(S,) And"},{"kind":"arabic","text_bw":"*ahaba wagoru Sadorihi","text_ar":"ذَهَبَ وَغْرُ صَدْرِهِ"},{"kind":"italic_en","text":"The rancour,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of his bosom departed."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"Alhadiy~apu tu*ohibu wagora AS~adori","text_ar":"الهَدِيَّةُ تُذْهِبُ وَغْرَ اصَّدْرِ"},{"kind":"italic_en","text":"The gift dispelleth the rancour, malevolence, malice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spite, and the heat, of the bosom."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","TA","Msb"]},{"entry_id":"n42148","headword_ar":"وَغَرٌ","root":"wgr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"wagorN","text_ar":"وَغْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}